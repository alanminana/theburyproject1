@page
@model AccessDeniedModel
@using System.Security.Claims
@{
    ViewData["Title"] = "Acceso denegado";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var sessionId  = "SEC_" + (User.FindFirst(ClaimTypes.NameIdentifier)?.Value?.GetHashCode() & 0x7FFF ?? 0).ToString("X4") + "_TB";
    var timestamp  = DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm:ss") + " UTC";
}

@section Styles {
    <link rel="stylesheet" href="~/css/standalone-tokens.css" asp-append-version="true" />
}

<div class="relative flex items-center justify-center min-h-full -m-8"
     style="background-color: var(--c-surface-lowest);">

    <!-- Background glows -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute -top-[20%] -right-[10%] w-[600px] h-[600px] rounded-full blur-[120px]"
             style="background-color: rgba(180,197,255,0.04);"></div>
        <div class="absolute -bottom-[20%] -left-[10%] w-[500px] h-[500px] rounded-full blur-[100px]"
             style="background-color: rgba(47,67,128,0.08);"></div>
    </div>

    <!-- Error card -->
    <div class="relative z-10 max-w-2xl w-full px-10 text-center py-16">

        <!-- Security icon with glow -->
        <div class="mb-8 inline-flex items-center justify-center w-32 h-32 rounded-full"
             style="background-color: var(--c-surface-high);
                    border: 1px solid rgba(180,197,255,0.15);
                    box-shadow: 0 0 40px -10px rgba(19,91,236,0.5);">
            <span class="material-symbols-outlined text-6xl"
                  style="color: var(--c-primary-light); font-variation-settings: 'FILL' 1;">security</span>
        </div>

        <!-- Heading -->
        <h2 class="text-5xl font-extrabold tracking-tight mb-6"
            style="color: var(--c-on-surface); letter-spacing: -0.03em;">
            403 — Acceso Denegado
        </h2>

        <p class="text-lg leading-relaxed mb-10 max-w-lg mx-auto"
           style="color: var(--c-on-surface-var);">
            No tenés los permisos necesarios para acceder a esta sección.
            Si creés que esto es un error, contactá al administrador del sistema.
        </p>

        <!-- Actions -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
            <a href="@Url.Action("Index", "Dashboard", new { area = string.Empty })"
               class="px-8 py-4 font-bold rounded-xl text-sm transition-all no-underline hover:brightness-110 active:scale-[0.98]"
               style="background-color: var(--c-primary-container);
                      color: var(--c-on-primary);
                      box-shadow: 0 0 20px rgba(19,91,236,0);"
               onmouseover="this.style.boxShadow='0 0 20px rgba(19,91,236,0.4)'"
               onmouseout="this.style.boxShadow='0 0 20px rgba(19,91,236,0)'">
                Volver al Dashboard
            </a>
            <a href="javascript:history.back()"
               class="flex items-center gap-2 font-medium transition-colors no-underline group"
               style="color: var(--c-primary-light);">
                <span>Volver atrás</span>
                <span class="material-symbols-outlined text-sm transition-transform group-hover:translate-x-1">arrow_forward</span>
            </a>
        </div>

        <!-- Status info panel -->
        <div class="mt-16 pt-8 grid grid-cols-2 gap-8"
             style="border-top: 1px solid rgba(67,70,85,0.15);">
            <div class="text-left">
                <span class="block text-[10px] uppercase tracking-widest font-bold mb-1"
                      style="color: rgba(195,197,216,0.45);">ID de Sesión</span>
                <code class="text-xs font-mono" style="color: rgba(180,197,255,0.6);">@sessionId</code>
            </div>
            <div class="text-right">
                <span class="block text-[10px] uppercase tracking-widest font-bold mb-1"
                      style="color: rgba(195,197,216,0.45);">Timestamp</span>
                <code class="text-xs font-mono" style="color: rgba(180,197,255,0.6);">@timestamp</code>
            </div>
        </div>
    </div>

    <!-- Decorative tape -->
    <div class="absolute bottom-10 left-10 flex items-center gap-4 select-none pointer-events-none"
         style="opacity: 0.18;">
        <span class="h-px w-20" style="background-color: var(--c-outline-var); display: block;"></span>
        <span class="text-[10px] tracking-[0.4em] uppercase font-bold"
              style="color: var(--c-on-surface-var);">Restricted Area</span>
        <span class="h-px w-20" style="background-color: var(--c-outline-var); display: block;"></span>
    </div>
</div>
