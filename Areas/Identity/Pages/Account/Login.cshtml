@page
@model LoginModel
@{
    ViewData["Title"] = Model.MostrarTerminos ? "Términos y Condiciones" : "Iniciar sesión";
    Layout = null;
}
<!DOCTYPE html>
<html class="dark" lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Iniciá sesión en TheBuryProject ERP." />
    <title>@(Model.MostrarTerminos ? "Términos y Condiciones" : "Iniciar sesión") — TheBuryProject</title>
    <link rel="stylesheet" href="~/css/local-fonts.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/ico/bury-logo-256.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/standalone-tokens.css" asp-append-version="true" />

</head>
<body style="background-color: var(--c-surface); color: var(--c-on-surface); font-family: 'Inter', sans-serif;"
      class="min-h-screen flex flex-col items-center justify-center">

    <!-- Main canvas -->
    <main class="w-full max-w-[440px] px-6 py-12">

        <!-- Brand -->
        <div class="flex flex-col items-center mb-10">
            <div class="w-16 h-16 mb-6 rounded-xl overflow-hidden flex items-center justify-center"
                 style="background-color: var(--c-primary-container); box-shadow: 0 4px 16px -4px rgba(19,91,236,0.2);">
                <img src="~/ico/bury-logo-256.png" alt="TheBuryProject" class="w-full h-full object-contain p-1" />
            </div>
            <h1 class="text-3xl font-black tracking-tight mb-2" style="color: var(--c-on-surface);">TheBuryProject</h1>
            <p class="text-xs uppercase tracking-wider font-semibold" style="color: var(--c-on-surface-var);">
                @(Model.MostrarTerminos ? "Términos y Condiciones de uso" : "Sistema de Gestión Empresarial")
            </p>
        </div>

        <!-- Auth card -->
        <div class="p-8 rounded-xl relative overflow-hidden"
             style="background-color: var(--c-surface-low); border: 1px solid rgba(67,70,85,0.30); box-shadow: 0 8px 24px -4px rgba(0,0,0,0.3);">

            <!-- Top accent line -->
            <div class="absolute top-0 left-0 w-full h-[2px]"
                 style="background: linear-gradient(to right, transparent, rgba(19,91,236,0.4), transparent);"></div>

            <!-- Error global -->
            @{
                var hasGlobalError = !ModelState.IsValid && ModelState.ContainsKey(string.Empty) &&
                                     ModelState[string.Empty]!.Errors.Any();
            }
            @if (hasGlobalError)
            {
                <div class="flex items-center gap-2 mb-6 px-4 py-3 rounded-lg text-sm font-medium"
                     role="alert"
                     style="background-color: rgba(255,180,171,0.10); border: 1px solid rgba(255,180,171,0.30); color: #ffb4ab;">
                    <span class="material-symbols-outlined text-[18px] shrink-0" aria-hidden="true">error</span>
                    <span>@ModelState[string.Empty]!.Errors.First().ErrorMessage</span>
                </div>
            }

            @if (Model.MostrarTerminos)
            {
                <!-- Texto legal -->
                <div class="rounded-lg mb-6 p-5 text-sm leading-relaxed overflow-y-auto"
                     style="background-color: var(--c-surface-container); border: 1px solid var(--c-outline-var); max-height: 260px; color: var(--c-on-surface-var);"
                     tabindex="0"
                     aria-label="Texto de los Términos y Condiciones de uso">
                    <h2 class="text-sm font-bold mb-2" style="color: var(--c-on-surface);">1. Objeto</h2>
                    <p class="mb-4">
                        Este sistema (en adelante, "el Sistema") es una herramienta de gestión interna de TheBuryProject
                        destinada exclusivamente al personal autorizado, para el registro y administración de operaciones
                        comerciales, financieras y administrativas de la empresa.
                    </p>

                    <h2 class="text-sm font-bold mb-2" style="color: var(--c-on-surface);">2. Uso autorizado</h2>
                    <p class="mb-4">
                        El acceso es personal e intransferible. El usuario se compromete a utilizar sus credenciales
                        exclusivamente para las tareas propias de su rol, a no compartirlas con terceros y a notificar
                        de inmediato cualquier uso indebido o sospecha de acceso no autorizado a su cuenta.
                    </p>

                    <h2 class="text-sm font-bold mb-2" style="color: var(--c-on-surface);">3. Confidencialidad</h2>
                    <p class="mb-4">
                        La información a la que se accede a través del Sistema (datos de clientes, proveedores,
                        operaciones financieras y de crédito, entre otros) es confidencial. El usuario se compromete a
                        no divulgarla, copiarla ni utilizarla fuera del ámbito laboral para el que fue autorizado.
                    </p>

                    <h2 class="text-sm font-bold mb-2" style="color: var(--c-on-surface);">4. Responsabilidad y trazabilidad</h2>
                    <p class="mb-4">
                        Todas las acciones realizadas dentro del Sistema quedan registradas junto con el usuario
                        responsable, fecha, hora y demás datos técnicos de la sesión, a efectos de auditoría y
                        trazabilidad interna.
                    </p>

                    <h2 class="text-sm font-bold mb-2" style="color: var(--c-on-surface);">5. Protección de datos personales</h2>
                    <p class="mb-0">
                        Los datos personales tratados a través del Sistema se manejan conforme a la normativa vigente
                        en materia de protección de datos personales (Ley 25.326 y normas complementarias), utilizándose
                        únicamente para los fines operativos de la empresa.
                    </p>
                </div>

                <form method="post" class="space-y-6">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />

                    <!-- Nombre completo -->
                    <div class="space-y-1.5">
                        <label asp-for="Input.NombreCompleto"
                               class="block text-[13px] uppercase tracking-wider font-semibold"
                               style="color: var(--c-on-surface);">
                            Nombre completo (para confirmar la aceptación)
                        </label>
                        <div class="relative group">
                            <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none"
                                 style="color: var(--c-on-surface-var);">
                                <span class="material-symbols-outlined text-lg" aria-hidden="true">badge</span>
                            </div>
                            <input asp-for="Input.NombreCompleto"
                                   type="text"
                                   autocomplete="name"
                                   placeholder="Nombre y apellido"
                                   class="w-full rounded-lg py-3.5 pl-12 pr-4 text-sm transition-[border-color,box-shadow] focus:outline-none focus:ring-2"
                                   style="background-color: var(--c-surface-container); color: var(--c-on-surface); border: 1px solid var(--c-outline-var); --tw-ring-color: rgba(19,91,236,0.5);" />
                        </div>
                        <span asp-validation-for="Input.NombreCompleto" class="block text-xs font-medium" style="color: #ffb4ab;"></span>
                    </div>

                    <!-- Checkbox aceptación -->
                    <div class="space-y-1.5">
                        <label class="flex items-start gap-3 cursor-pointer select-none">
                            <input asp-for="Input.AceptaTerminos"
                                   type="checkbox"
                                   class="mt-0.5 w-5 h-5 rounded cursor-pointer shrink-0"
                                   style="background-color: var(--c-surface-container); border: 1.5px solid var(--c-outline-var);" />
                            <span class="text-sm" style="color: var(--c-on-surface-var);">
                                Declaro que leí y acepto los Términos y Condiciones de uso descriptos arriba.
                            </span>
                        </label>
                        <span asp-validation-for="Input.AceptaTerminos" class="block text-xs font-medium" style="color: #ffb4ab;"></span>
                    </div>

                    <button type="submit"
                            class="w-full py-4 px-6 rounded-lg font-bold text-sm transition-[background-color,box-shadow,transform] hover:brightness-110 active:scale-[0.98] focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 mt-2"
                            style="background-color: var(--c-primary-container); color: var(--c-on-primary); box-shadow: 0 4px 16px -4px rgba(19,91,236,0.3); --tw-ring-color: rgba(19,91,236,0.6);">
                        Aceptar y continuar
                    </button>
                </form>

                <form method="post" asp-page-handler="Desafiar" class="mt-3 text-center">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                    <button type="submit"
                            class="text-xs underline bg-transparent p-0 cursor-pointer"
                            style="border: none; color: var(--c-on-surface-var);">
                        desafiar a los dioses
                    </button>
                </form>
            }
            else
            {
                <form method="post" class="space-y-6">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />

                    <!-- Usuario -->
                    <div class="space-y-1.5">
                        <label asp-for="Input.UserName"
                               class="block text-[13px] uppercase tracking-wider font-semibold"
                               style="color: var(--c-on-surface);">
                            Usuario
                        </label>
                        <div class="relative group">
                            <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none"
                                 style="color: var(--c-on-surface-var);" id="icon-username">
                                <span class="material-symbols-outlined text-lg" aria-hidden="true">person</span>
                            </div>
                            <input asp-for="Input.UserName"
                                   type="text"
                                   autocomplete="username"
                                   placeholder="usuario"
                                   class="w-full rounded-lg py-3.5 pl-12 pr-4 text-sm transition-[border-color,box-shadow] focus:outline-none focus:ring-2"
                                   style="background-color: var(--c-surface-container); color: var(--c-on-surface); border: 1px solid var(--c-outline-var); --tw-ring-color: rgba(19,91,236,0.5);" />
                        </div>
                        <span asp-validation-for="Input.UserName" class="block text-xs font-medium" style="color: #ffb4ab;"></span>
                    </div>

                    <!-- Password -->
                    <div class="space-y-1.5">
                        <div class="flex justify-between items-center">
                            <label asp-for="Input.Password"
                                   class="text-[13px] uppercase tracking-wider font-semibold"
                                   style="color: var(--c-on-surface);">
                                Contraseña
                            </label>
                            <a asp-page="./ForgotPassword"
                               class="text-xs font-medium hover:underline transition-colors no-underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-1 rounded"
                               style="color: var(--c-primary-light); --tw-ring-color: rgba(19,91,236,0.5);">
                                ¿Olvidaste tu contraseña?
                            </a>
                        </div>
                        <div class="relative group">
                            <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none"
                                 style="color: var(--c-on-surface-var);" id="icon-password">
                                <span class="material-symbols-outlined text-lg" aria-hidden="true">lock</span>
                            </div>
                            <input asp-for="Input.Password"
                                   type="password"
                                   id="input-password"
                                   autocomplete="current-password"
                                   placeholder="••••••••"
                                   class="w-full rounded-lg py-3.5 pl-12 pr-12 text-sm transition-[border-color,box-shadow] focus:outline-none focus:ring-2"
                                   style="background-color: var(--c-surface-container); color: var(--c-on-surface); border: 1px solid var(--c-outline-var); --tw-ring-color: rgba(19,91,236,0.5);" />
                            <button type="button"
                                    id="btn-toggle-pwd"
                                    aria-label="Mostrar u ocultar contraseña"
                                    class="absolute inset-y-0 right-4 flex items-center rounded transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-1"
                                    style="color: var(--c-on-surface-var); background: transparent; border: none; --tw-ring-color: rgba(19,91,236,0.5);">
                                <span class="material-symbols-outlined text-lg" id="pwd-eye" aria-hidden="true">visibility</span>
                            </button>
                        </div>
                        <span asp-validation-for="Input.Password" class="block text-xs font-medium" style="color: #ffb4ab;"></span>
                    </div>

                    <!-- Remember me -->
                    <div class="flex items-center pt-1">
                        <label class="flex items-center gap-3 cursor-pointer select-none">
                            <div class="relative flex items-center">
                                <input asp-for="Input.RememberMe"
                                       type="checkbox"
                                       id="remember-me"
                                       class="peer appearance-none w-5 h-5 rounded cursor-pointer transition-[background-color,border-color,box-shadow] focus:outline-none focus:ring-2"
                                       style="background-color: var(--c-surface-container); border: 1.5px solid var(--c-outline-var); --tw-ring-color: rgba(19,91,236,0.5);"
                                       onchange="this.nextElementSibling.style.opacity = this.checked ? '1' : '0'" />
                                <span class="material-symbols-outlined absolute inset-0 flex items-center justify-center pointer-events-none text-sm"
                                      style="color: var(--c-on-primary); opacity: 0;" id="check-icon" aria-hidden="true">check</span>
                            </div>
                            <span class="text-sm" style="color: var(--c-on-surface-var);">Recordar usuario</span>
                        </label>
                    </div>

                    <!-- Submit -->
                    <button type="submit"
                            class="w-full py-4 px-6 rounded-lg font-bold text-sm transition-[background-color,box-shadow,transform] hover:brightness-110 active:scale-[0.98] focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 mt-2"
                            style="background-color: var(--c-primary-container); color: var(--c-on-primary); box-shadow: 0 4px 16px -4px rgba(19,91,236,0.3); --tw-ring-color: rgba(19,91,236,0.6);">
                        Iniciar Sesión
                    </button>
                </form>
            }
        </div>

        <!-- Secondary actions -->
        @if (!Model.MostrarTerminos)
        {
            <div class="mt-8 text-center">
                <p class="text-sm" style="color: var(--c-on-surface-var);">
                    ¿No tenés acceso?
                    <span class="ml-1 font-semibold" style="color: var(--c-on-surface);">Contactá al administrador.</span>
                </p>
            </div>
        }
    </main>

    <!-- Footer -->
    <footer class="mt-auto py-6 w-full" style="border-top: 1px solid rgba(67,70,85,0.20);">
        <div class="max-w-[1200px] mx-auto px-10 flex flex-col md:flex-row justify-between items-center gap-3"
             style="color: rgba(195,197,216,0.55);">
            <div class="flex items-center gap-6">
                <span class="text-[11px] uppercase tracking-widest font-semibold tabular-nums">Sistema v1.0</span>
                <span class="w-1 h-1 rounded-full" style="background-color: rgba(67,70,85,0.5);"></span>
                <span class="text-[11px] uppercase tracking-widest font-semibold">Acceso Restringido</span>
            </div>
            <p class="text-[11px] uppercase tracking-widest font-semibold">© @DateTime.Now.Year TheBuryProject</p>
        </div>
    </footer>

    <script>
        const btn = document.getElementById('btn-toggle-pwd');
        const inp = document.getElementById('input-password');
        const eye = document.getElementById('pwd-eye');
        btn?.addEventListener('click', () => {
            const hidden = inp.type === 'password';
            inp.type = hidden ? 'text' : 'password';
            eye.textContent = hidden ? 'visibility_off' : 'visibility';
            btn.setAttribute('aria-label', hidden ? 'Ocultar contraseña' : 'Mostrar contraseña');
        });

        // Sync checkbox visual on load
        const cb = document.getElementById('remember-me');
        const ck = document.getElementById('check-icon');
        if (cb && ck) ck.style.opacity = cb.checked ? '1' : '0';

        // Highlight icon on input focus
        document.querySelectorAll('input[type=text], input[type=password]').forEach(input => {
            const wrapper = input.closest('.group');
            const icon = wrapper?.querySelector('.material-symbols-outlined');
            if (!icon) return;
            input.addEventListener('focus', () => icon.style.color = '#135bec');
            input.addEventListener('blur',  () => icon.style.color = 'var(--c-on-surface-var)');
        });
    </script>
</body>
</html>
