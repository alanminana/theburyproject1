@page
@model LoginModel
@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = null;
}
<!DOCTYPE html>
<html class="dark" lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Iniciá sesión en TheBuryProject ERP." />
    <title>Iniciar sesión — TheBuryProject</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Material+Symbols+Outlined:wght,FILL@@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/standalone-tokens.css" asp-append-version="true" />
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
    </style>
</head>
<body style="background-color: var(--c-surface); color: var(--c-on-surface); font-family: 'Inter', sans-serif;"
      class="min-h-screen flex flex-col items-center justify-center relative overflow-hidden selection:bg-primary/30">

    <!-- Background glow elements -->
    <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
        <div class="absolute -top-[10%] -left-[10%] w-[50%] h-[50%] rounded-full blur-[120px]"
             style="background-color: rgba(19,91,236,0.10);"></div>
        <div class="absolute top-[20%] right-[5%] w-[30%] h-[30%] rounded-full blur-[100px]"
             style="background-color: rgba(47,67,128,0.05);"></div>
        <div class="absolute bottom-0 left-0 w-full h-[40%]"
             style="background: linear-gradient(to top, #080e1a, transparent); opacity: 0.6;"></div>
    </div>

    <!-- Main canvas -->
    <main class="relative z-10 w-full max-w-[440px] px-6 py-12">

        <!-- Brand -->
        <div class="flex flex-col items-center mb-10">
            <div class="w-16 h-16 mb-6 flex items-center justify-center rounded-xl"
                 style="background-color: var(--c-primary-container); box-shadow: 0 0 40px -5px rgba(19,91,236,0.35);">
                <span class="material-symbols-outlined text-4xl" style="color: var(--c-on-primary);">rocket_launch</span>
            </div>
            <h1 class="text-3xl font-black tracking-tighter mb-2" style="color: var(--c-on-surface);">TheBuryProject</h1>
            <p class="text-[10px] uppercase tracking-[0.2em] font-bold" style="color: var(--c-on-surface-var);">Sistema de Gestión Empresarial</p>
        </div>

        <!-- Auth card -->
        <div class="p-8 rounded-xl relative overflow-hidden"
             style="background-color: var(--c-surface-low); border: 1px solid rgba(67,70,85,0.15); box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);">

            <!-- Top highlight line -->
            <div class="absolute top-0 left-0 w-full h-[2px]"
                 style="background: linear-gradient(to right, transparent, rgba(19,91,236,0.4), transparent);"></div>

            <!-- Error global -->
            @{
                var hasGlobalError = !ModelState.IsValid && ModelState.ContainsKey(string.Empty) &&
                                     ModelState[string.Empty]!.Errors.Any();
            }
            @if (hasGlobalError)
            {
                <div class="flex items-center gap-2 mb-6 px-4 py-3 rounded-lg text-sm font-medium"
                     style="background-color: rgba(255,180,171,0.08); border: 1px solid rgba(255,180,171,0.2); color: #ffb4ab;">
                    <span class="material-symbols-outlined text-[18px] shrink-0">error</span>
                    <span>@ModelState[string.Empty]!.Errors.First().ErrorMessage</span>
                </div>
            }

            <form method="post" class="space-y-6">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />

                <!-- Email -->
                <div class="space-y-2">
                    <label asp-for="Input.Email"
                           class="block text-[11px] uppercase tracking-widest font-bold ml-1"
                           style="color: var(--c-on-surface-var);">
                        Correo electrónico
                    </label>
                    <div class="relative group">
                        <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none transition-colors"
                             style="color: var(--c-on-surface-var);">
                            <span class="material-symbols-outlined text-lg">mail</span>
                        </div>
                        <input asp-for="Input.Email"
                               type="email"
                               autocomplete="username"
                               placeholder="usuario@empresa.com"
                               class="w-full rounded-lg py-4 pl-12 pr-4 text-sm border-0 transition-all focus:outline-none focus:ring-2"
                               style="background-color: var(--c-surface-container); color: var(--c-on-surface); --tw-ring-color: rgba(19,91,236,0.4);" />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-xs font-medium" style="color: #ffb4ab;"></span>
                </div>

                <!-- Password -->
                <div class="space-y-2">
                    <div class="flex justify-between items-center ml-1">
                        <label asp-for="Input.Password"
                               class="text-[11px] uppercase tracking-widest font-bold"
                               style="color: var(--c-on-surface-var);">
                            Contraseña
                        </label>
                        <a asp-page="./ForgotPassword"
                           class="text-xs font-medium hover:underline transition-colors no-underline"
                           style="color: var(--c-primary-light);">
                            ¿Olvidaste tu contraseña?
                        </a>
                    </div>
                    <div class="relative group">
                        <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none"
                             style="color: var(--c-on-surface-var);">
                            <span class="material-symbols-outlined text-lg">lock</span>
                        </div>
                        <input asp-for="Input.Password"
                               type="password"
                               id="input-password"
                               autocomplete="current-password"
                               placeholder="••••••••"
                               class="w-full rounded-lg py-4 pl-12 pr-12 text-sm border-0 transition-all focus:outline-none focus:ring-2"
                               style="background-color: var(--c-surface-container); color: var(--c-on-surface); --tw-ring-color: rgba(19,91,236,0.4);" />
                        <button type="button" id="btn-toggle-pwd"
                                class="absolute inset-y-0 right-4 flex items-center transition-colors border-0 bg-transparent"
                                style="color: var(--c-on-surface-var);">
                            <span class="material-symbols-outlined text-lg" id="pwd-eye">visibility</span>
                        </button>
                    </div>
                    <span asp-validation-for="Input.Password" class="text-xs font-medium" style="color: #ffb4ab;"></span>
                </div>

                <!-- Remember me -->
                <div class="flex items-center justify-between text-xs pt-1">
                    <label class="flex items-center gap-3 cursor-pointer group select-none">
                        <div class="relative flex items-center">
                            <input asp-for="Input.RememberMe"
                                   type="checkbox"
                                   id="remember-me"
                                   class="peer appearance-none w-5 h-5 rounded focus:ring-0 transition-all cursor-pointer border-0"
                                   style="background-color: var(--c-surface-container);"
                                   onchange="this.nextElementSibling.style.opacity = this.checked ? '1' : '0'" />
                            <span class="material-symbols-outlined absolute text-sm pointer-events-none left-[3px]"
                                  style="color: var(--c-on-primary); opacity: 0;" id="check-icon">check</span>
                        </div>
                        <span style="color: var(--c-on-surface-var);">Recordar usuario</span>
                    </label>
                </div>

                <!-- Submit -->
                <button type="submit"
                        class="w-full py-4 px-6 rounded-lg font-bold tracking-tight text-sm transition-all hover:brightness-110 active:scale-[0.98] mt-4"
                        style="background-color: var(--c-primary-container); color: var(--c-on-primary); box-shadow: 0 10px 25px -5px rgba(19,91,236,0.25);">
                    Iniciar Sesión
                </button>
            </form>
        </div>

        <!-- Secondary actions -->
        <div class="mt-8 text-center">
            <p class="text-sm" style="color: var(--c-on-surface-var);">
                ¿No tenés acceso?
                <span class="ml-1 font-bold" style="color: var(--c-on-surface-var);">Contactá al administrador.</span>
            </p>
        </div>
    </main>

    <!-- Footer -->
    <footer class="mt-auto py-8 w-full" style="border-top: 1px solid rgba(67,70,85,0.08);">
        <div class="max-w-[1200px] mx-auto px-10 flex flex-col md:flex-row justify-between items-center gap-4"
             style="color: rgba(195,197,216,0.35);">
            <div class="flex items-center gap-6">
                <span class="text-[10px] uppercase tracking-widest font-bold tabular-nums">Sistema v1.0</span>
                <span class="w-1 h-1 rounded-full" style="background-color: rgba(67,70,85,0.4);"></span>
                <span class="text-[10px] uppercase tracking-widest font-bold">Acceso Restringido</span>
            </div>
            <p class="text-[10px] uppercase tracking-widest font-bold">© @DateTime.Now.Year TheBuryProject</p>
        </div>
    </footer>

    <!-- Decorative corner -->
    <div class="fixed bottom-0 right-0 p-10 pointer-events-none" style="opacity: 0.15;">
        <div class="w-32 h-32 rounded-br-3xl"
             style="border-right: 1px solid rgba(19,91,236,0.4); border-bottom: 1px solid rgba(19,91,236,0.4);"></div>
    </div>

    <script>
        const btn = document.getElementById('btn-toggle-pwd');
        const inp = document.getElementById('input-password');
        const eye = document.getElementById('pwd-eye');
        btn?.addEventListener('click', () => {
            const hidden = inp.type === 'password';
            inp.type = hidden ? 'text' : 'password';
            eye.textContent = hidden ? 'visibility_off' : 'visibility';
        });

        // Sync checkbox visual on load
        const cb = document.getElementById('remember-me');
        const ck = document.getElementById('check-icon');
        if (cb && ck) ck.style.opacity = cb.checked ? '1' : '0';

        // Highlight icon on input focus
        document.querySelectorAll('input[type=email], input[type=password]').forEach(input => {
            const wrapper = input.closest('.group');
            const icon = wrapper?.querySelector('.material-symbols-outlined');
            if (!icon) return;
            input.addEventListener('focus', () => icon.style.color = '#135bec');
            input.addEventListener('blur',  () => icon.style.color = 'var(--c-on-surface-var)');
        });
    </script>
</body>
</html>
