@model TheBuryProject.ViewModels.PaginatedResult<TheBuryProject.ViewModels.AlertaStockViewModel>
@using TheBuryProject.Models.Enums
@{
    ViewData["Title"] = "Alertas de Stock";
    var filtro      = ViewBag.Filtro      as TheBuryProject.ViewModels.AlertaStockFiltroViewModel
                      ?? new TheBuryProject.ViewModels.AlertaStockFiltroViewModel();
    var tiposAlerta = ViewBag.TiposAlerta as TipoAlertaStock[]  ?? Array.Empty<TipoAlertaStock>();
    var prioridades = ViewBag.Prioridades as PrioridadAlerta[]  ?? Array.Empty<PrioridadAlerta>();
    var estados     = ViewBag.Estados     as EstadoAlerta[]     ?? Array.Empty<EstadoAlerta>();
}

<div class="space-y-6">

    @if (TempData["Success"] != null)
    {
        <div class="rounded-xl border border-emerald-800 bg-emerald-900/20 px-4 py-3 text-sm text-emerald-400">
            <span class="material-symbols-outlined text-base align-middle mr-1">check_circle</span>@TempData["Success"]
        </div>
    }
    @if (TempData["Info"] != null)
    {
        <div class="rounded-xl border border-slate-700 bg-slate-800/50 px-4 py-3 text-sm text-slate-300">
            <span class="material-symbols-outlined text-base align-middle mr-1">info</span>@TempData["Info"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="rounded-xl border border-red-800 bg-red-900/20 px-4 py-3 text-sm text-red-400">
            <span class="material-symbols-outlined text-base align-middle mr-1">error</span>@TempData["Error"]
        </div>
    }

    <form asp-action="Index" method="get">
        <div class="filter-panel-erp">
            <div class="mb-4 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <h2 class="text-base font-bold text-white">Filtros</h2>
                    <p class="text-sm text-slate-400">Filtrá alertas por producto, tipo, prioridad o estado.</p>
                </div>
                <span class="inline-flex items-center gap-2 rounded-full bg-slate-800 px-3 py-1 text-xs font-semibold text-slate-300">
                    <span class="material-symbols-outlined text-sm">tune</span>
                    @Model.TotalRecords resultado@(Model.TotalRecords == 1 ? "" : "s")
                </span>
            </div>

            <div class="grid grid-cols-1 gap-4 md:grid-cols-12">
                <div class="md:col-span-4">
                    <label class="mb-2 block text-xs font-bold uppercase tracking-wider text-slate-400">Producto</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">search</span>
                        <input type="text" name="ProductoNombre" value="@filtro.ProductoNombre"
                               placeholder="Nombre del producto..."
                               class="w-full rounded-lg border border-slate-700 bg-slate-900 py-2 pl-10 pr-4 text-sm text-white placeholder:text-slate-500 transition-all focus:border-primary focus:ring-2 focus:ring-primary/50" />
                    </div>
                </div>
                <div class="md:col-span-2">
                    <label class="mb-2 block text-xs font-bold uppercase tracking-wider text-slate-400">Tipo</label>
                    <select name="Tipo"
                            class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white transition-all focus:border-primary focus:ring-2 focus:ring-primary/50">
                        <option value="">Todos</option>
                        @foreach (var t in tiposAlerta)
                        {
                            <option value="@((int)t)" selected="@(filtro.Tipo == t ? "selected" : null)">@t</option>
                        }
                    </select>
                </div>
                <div class="md:col-span-2">
                    <label class="mb-2 block text-xs font-bold uppercase tracking-wider text-slate-400">Prioridad</label>
                    <select name="Prioridad"
                            class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white transition-all focus:border-primary focus:ring-2 focus:ring-primary/50">
                        <option value="">Todas</option>
                        @foreach (var p in prioridades)
                        {
                            <option value="@((int)p)" selected="@(filtro.Prioridad == p ? "selected" : null)">@p</option>
                        }
                    </select>
                </div>
                <div class="md:col-span-2">
                    <label class="mb-2 block text-xs font-bold uppercase tracking-wider text-slate-400">Estado</label>
                    <select name="Estado"
                            class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white transition-all focus:border-primary focus:ring-2 focus:ring-primary/50">
                        <option value="">Todos</option>
                        @foreach (var e in estados)
                        {
                            <option value="@((int)e)" selected="@(filtro.Estado == e ? "selected" : null)">@e</option>
                        }
                    </select>
                </div>
                <div class="flex items-end gap-2 md:col-span-2">
                    <button type="submit" class="inline-flex h-10 flex-1 items-center justify-center rounded-xl bg-primary px-6 text-sm font-bold text-white transition-colors hover:bg-primary/90">
                        Buscar
                    </button>
                    <a asp-action="Index" class="inline-flex h-10 items-center justify-center rounded-xl border border-slate-700 px-3 text-slate-400 transition-colors hover:bg-slate-800 no-underline" title="Limpiar filtros">
                        <span class="material-symbols-outlined">filter_alt_off</span>
                    </a>
                </div>
            </div>
        </div>
    </form>

    <section class="card-erp-panel">
        <div class="px-6 py-4 border-b border-slate-800 bg-slate-800/30 flex flex-wrap items-center gap-3">
            <h2 class="font-semibold text-slate-100 flex items-center gap-2 flex-1">
                <span class="material-symbols-outlined text-primary text-xl">warning</span>
                Alertas de Stock
                <span class="text-xs font-normal text-slate-400">· @Model.TotalRecords registros</span>
            </h2>
            <div class="flex flex-wrap items-center gap-2">
                <a asp-action="Criticos" class="btn-erp-danger btn-sm no-underline">
                    <span class="material-symbols-outlined text-base">crisis_alert</span>
                    Críticos
                </a>
                <a asp-action="Estadisticas" class="btn-erp-ghost btn-sm no-underline">
                    <span class="material-symbols-outlined text-base">bar_chart</span>
                    Estadísticas
                </a>
                <form asp-action="GenerarAlertas" method="post" class="inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-erp-secondary btn-sm"
                            onclick="return confirm('¿Generar alertas de stock ahora?')">
                        <span class="material-symbols-outlined text-base">refresh</span>
                        Generar alertas
                    </button>
                </form>
            </div>
        </div>

        @if (Model.Items.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-slate-800 bg-slate-800/50">
                            <th class="px-4 py-3 text-left font-medium text-slate-400">Producto</th>
                            <th class="px-4 py-3 text-left font-medium text-slate-400">Tipo</th>
                            <th class="px-4 py-3 text-center font-medium text-slate-400">Prioridad</th>
                            <th class="px-4 py-3 text-right font-medium text-slate-400">Stock actual</th>
                            <th class="px-4 py-3 text-right font-medium text-slate-400">Stock mínimo</th>
                            <th class="px-4 py-3 text-center font-medium text-slate-400">Estado</th>
                            <th class="px-4 py-3 text-left font-medium text-slate-400">Fecha</th>
                            <th class="px-4 py-3 text-center font-medium text-slate-400">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-800">
                        @foreach (var a in Model.Items)
                        {
                            var prioridadBadge = a.Prioridad switch
                            {
                                PrioridadAlerta.Critica => "badge-erp badge-erp-danger",
                                PrioridadAlerta.Alta    => "badge-erp badge-erp-warning",
                                PrioridadAlerta.Media   => "badge-erp badge-erp-info",
                                _                       => "badge-erp"
                            };
                            var tipoBadge = a.Tipo switch
                            {
                                TipoAlertaStock.StockAgotado  => "badge-erp badge-erp-danger",
                                TipoAlertaStock.StockCritico  => "badge-erp badge-erp-warning",
                                TipoAlertaStock.StockBajo     => "badge-erp badge-erp-info",
                                _                             => "badge-erp"
                            };
                            var estadoBadge = a.Estado switch
                            {
                                EstadoAlerta.Pendiente  => "badge-erp badge-erp-warning",
                                EstadoAlerta.EnProceso  => "badge-erp badge-erp-info",
                                EstadoAlerta.Resuelta   => "badge-erp badge-erp-success",
                                EstadoAlerta.Ignorada   => "badge-erp",
                                _                       => "badge-erp"
                            };
                            <tr class="hover:bg-slate-800/50 transition-colors @(a.NotificacionUrgente ? "bg-red-900/10" : "")">
                                <td class="px-4 py-3">
                                    <a asp-action="Details" asp-route-id="@a.Id"
                                       class="font-medium text-slate-100 hover:text-primary transition-colors">@a.ProductoNombre</a>
                                    <p class="text-xs text-slate-500">@a.ProductoCodigo · @a.CategoriaNombre</p>
                                </td>
                                <td class="px-4 py-3">
                                    <span class="@tipoBadge">@a.TipoDescripcion</span>
                                </td>
                                <td class="px-4 py-3 text-center">
                                    <span class="@prioridadBadge">@a.PrioridadDescripcion</span>
                                    @if (a.NotificacionUrgente)
                                    {
                                        <span class="material-symbols-outlined text-red-400 text-[14px] ml-1 align-middle">priority_high</span>
                                    }
                                </td>
                                <td class="px-4 py-3 text-right font-semibold @(a.StockActual <= 0 ? "text-red-400" : a.PorcentajeStockMinimo < 50 ? "text-amber-400" : "text-slate-100")">
                                    @a.StockActual.ToString("N0")
                                </td>
                                <td class="px-4 py-3 text-right text-slate-400">@a.StockMinimo.ToString("N0")</td>
                                <td class="px-4 py-3 text-center">
                                    <span class="@estadoBadge">@a.EstadoDescripcion</span>
                                </td>
                                <td class="px-4 py-3 text-slate-400 text-xs">
                                    @a.FechaAlerta.ToString("dd/MM/yyyy HH:mm")
                                    @if (a.EstaVencida)
                                    {
                                        <span class="block text-red-400">vencida</span>
                                    }
                                </td>
                                <td class="px-4 py-3">
                                    <div class="flex items-center justify-center gap-1">
                                        <a asp-action="Details" asp-route-id="@a.Id"
                                           class="inline-flex items-center rounded-lg px-2 py-1 text-xs bg-slate-800 text-slate-300 hover:text-white hover:bg-slate-700 transition-colors" title="Ver detalle">
                                            <span class="material-symbols-outlined text-[14px]">visibility</span>
                                        </a>
                                        @if (a.Estado == EstadoAlerta.Pendiente || a.Estado == EstadoAlerta.EnProceso)
                                        {
                                            <form asp-action="Resolver" method="post" class="inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@a.Id" />
                                                @if (a.RowVersion != null)
                                                {
                                                    <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(a.RowVersion)" />
                                                }
                                                <button type="submit"
                                                        class="inline-flex items-center rounded-lg px-2 py-1 text-xs bg-emerald-900/40 text-emerald-400 hover:bg-emerald-900/60 transition-colors"
                                                        title="Resolver">
                                                    <span class="material-symbols-outlined text-[14px]">check</span>
                                                </button>
                                            </form>
                                            <form asp-action="Ignorar" method="post" class="inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@a.Id" />
                                                @if (a.RowVersion != null)
                                                {
                                                    <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(a.RowVersion)" />
                                                }
                                                <button type="submit"
                                                        class="inline-flex items-center rounded-lg px-2 py-1 text-xs bg-slate-800 text-slate-400 hover:text-slate-200 hover:bg-slate-700 transition-colors"
                                                        title="Ignorar" onclick="return confirm('¿Ignorar esta alerta?')">
                                                    <span class="material-symbols-outlined text-[14px]">do_not_disturb</span>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="px-6 py-4 border-t border-slate-800 flex items-center justify-between text-sm text-slate-400">
                    <span>Mostrando @Model.FirstRecord–@Model.LastRecord de @Model.TotalRecords</span>
                    <div class="flex gap-2">
                        @if (Model.HasPreviousPage)
                        {
                            <a asp-action="Index"
                               asp-route-PageNumber="@(Model.PageNumber - 1)"
                               asp-route-Estado="@((int?)filtro.Estado)"
                               asp-route-Tipo="@((int?)filtro.Tipo)"
                               asp-route-Prioridad="@((int?)filtro.Prioridad)"
                               asp-route-ProductoNombre="@filtro.ProductoNombre"
                               class="btn-erp-ghost btn-erp-sm">Anterior</a>
                        }
                        @if (Model.HasNextPage)
                        {
                            <a asp-action="Index"
                               asp-route-PageNumber="@(Model.PageNumber + 1)"
                               asp-route-Estado="@((int?)filtro.Estado)"
                               asp-route-Tipo="@((int?)filtro.Tipo)"
                               asp-route-Prioridad="@((int?)filtro.Prioridad)"
                               asp-route-ProductoNombre="@filtro.ProductoNombre"
                               class="btn-erp-ghost btn-erp-sm">Siguiente</a>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="px-6 py-12 text-center text-sm text-slate-400">
                <span class="material-symbols-outlined text-4xl block mb-3">check_circle</span>
                No hay alertas de stock para los filtros seleccionados.
            </div>
        }
    </section>

</div>
