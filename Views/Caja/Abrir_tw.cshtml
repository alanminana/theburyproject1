@model TheBuryProject.ViewModels.AbrirCajaViewModel
@{
    ViewData["Title"] = "Abrir Caja";
    var cajas = ViewBag.Cajas as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var usuarioActual = User.Identity?.Name ?? "Usuario actual";
    var cajaSeleccionada = cajas?.FirstOrDefault(i => i.Value == (Model.CajaId == 0 ? string.Empty : Model.CajaId.ToString()));
    var terminalTexto = !string.IsNullOrWhiteSpace(Model.CajaNombre) ? Model.CajaNombre : cajaSeleccionada?.Text ?? "Seleccionar terminal";
    var terminalCodigo = !string.IsNullOrWhiteSpace(Model.CajaCodigo) ? Model.CajaCodigo : "Sin código cargado";
}

<div class="caja-page-shell space-y-8">

    <header class="space-y-6">
        <div class="flex items-center gap-2 text-sm font-medium text-slate-500 dark:text-slate-400">
            <a asp-action="Index" class="hover:text-primary transition-colors no-underline text-slate-500 dark:text-slate-400">Cajas</a>
            <span class="material-symbols-outlined text-xs">chevron_right</span>
            <span class="text-slate-900 dark:text-white">Abrir caja</span>
        </div>

        <div class="caja-page-header-layout">
            <div class="space-y-2">
                <h1 class="text-slate-900 dark:text-white text-4xl font-black tracking-tight">Abrir caja</h1>
                <p class="max-w-3xl text-sm text-slate-600 dark:text-slate-400 sm:text-base">
                    Iniciá una nueva jornada operativa seleccionando la terminal correcta, definiendo el fondo inicial y dejando contexto suficiente para el turno.
                </p>
            </div>
            <div class="caja-page-header-actions">
                <a asp-action="Index"
                   class="caja-page-header-action inline-flex items-center justify-center gap-2 rounded-lg bg-slate-100 dark:bg-slate-800 px-4 py-2.5 text-sm font-bold hover:bg-slate-200 dark:hover:bg-slate-700 transition-all no-underline text-slate-700 dark:text-slate-200 border border-slate-200 dark:border-slate-700">
                    <span class="material-symbols-outlined text-lg">arrow_back</span>
                    Volver
                </a>
            </div>
        </div>
    </header>

    @if (TempData["Error"] != null)
    {
        <div id="toast-error" class="flex items-center gap-3 bg-rose-500/10 border border-rose-500/20 text-rose-600 dark:text-rose-400 px-5 py-3 rounded-xl text-sm font-medium" role="alert">
            <span class="material-symbols-outlined text-lg">error</span>
            @TempData["Error"]
        </div>
    }

    <div asp-validation-summary="ModelOnly"
         class="rounded-xl border border-rose-500/20 bg-rose-500/10 px-4 py-3 text-sm text-rose-600 dark:text-rose-400 empty:hidden"
         role="alert"></div>

    <div class="caja-page-metrics caja-page-metrics--4">
        <article class="rounded-2xl border border-slate-200 bg-white/95 p-4 shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
            <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-slate-500 dark:text-slate-400">Terminal objetivo</p>
            <p data-caja-abrir-terminal-label class="mt-2 text-2xl font-black text-slate-900 dark:text-white">@terminalTexto</p>
            <p data-caja-abrir-terminal-copy class="mt-1 text-xs text-slate-500 dark:text-slate-400">@terminalCodigo</p>
        </article>
        <article class="rounded-2xl border border-slate-200 bg-white/95 p-4 shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
            <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-slate-500 dark:text-slate-400">Responsable</p>
            <p class="mt-2 text-2xl font-black text-slate-900 dark:text-white">@usuarioActual</p>
            <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">El turno quedará vinculado al usuario autenticado.</p>
        </article>
        <article class="rounded-2xl border border-primary/20 bg-primary/10 p-4 shadow-sm">
            <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-primary">Fondo inicial</p>
            <p data-caja-abrir-fondo-label class="mt-2 text-2xl font-black text-slate-900 dark:text-white">$@Model.MontoInicial.ToString("N2")</p>
            <p class="mt-1 text-xs text-slate-600 dark:text-slate-300">Base que estará disponible al momento de abrir la caja.</p>
        </article>
        <article class="rounded-2xl border border-emerald-500/20 bg-emerald-500/10 p-4 shadow-sm">
            <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-emerald-600 dark:text-emerald-400">Trazabilidad</p>
            <p class="mt-2 text-2xl font-black text-emerald-600 dark:text-emerald-400">Auditado</p>
            <p class="mt-1 text-xs text-emerald-600/80 dark:text-emerald-400/80">Apertura, movimientos y cierre quedarán registrados en el historial.</p>
        </article>
    </div>

    <form asp-action="Abrir" method="post" class="space-y-8">
        @Html.AntiForgeryToken()

        <div class="caja-page-main-grid caja-page-main-grid--aside-right">
            <section class="rounded-2xl border border-slate-200 bg-white/95 shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
                <div class="p-6 space-y-8">
                    <div class="space-y-2">
                        <div class="flex flex-wrap items-center gap-2">
                            <span class="material-symbols-outlined text-primary">lock_open</span>
                            <h2 class="text-slate-900 dark:text-white text-xl font-bold">Datos de apertura</h2>
                        </div>
                        <p class="text-sm text-slate-500 dark:text-slate-400">
                            Confirmá la terminal, ingresá el efectivo base y dejá observaciones si necesitás documentar el estado inicial del turno.
                        </p>
                    </div>

                    <div class="space-y-6">
                        <div class="flex flex-col gap-2">
                            <label asp-for="CajaId" class="text-sm font-semibold text-slate-700 dark:text-slate-300">Caja o terminal</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">point_of_sale</span>
                                <select asp-for="CajaId"
                                        asp-items="cajas"
                                        data-caja-abrir-select
                                        class="w-full rounded-lg border border-slate-200 bg-slate-50 py-3 pl-10 pr-4 text-slate-900 focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-800 dark:text-white">
                                    <option value="">Seleccione la terminal de caja</option>
                                </select>
                            </div>
                            <p class="text-xs text-slate-400 dark:text-slate-500">La terminal seleccionada recibirá todos los movimientos del nuevo turno hasta su cierre.</p>
                            <span asp-validation-for="CajaId" class="text-rose-500 text-xs"></span>
                        </div>

                        <div class="flex flex-col gap-2">
                            <label asp-for="MontoInicial" class="text-sm font-semibold text-slate-700 dark:text-slate-300">Monto inicial</label>
                            <div class="relative">
                                <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400 font-medium">$</span>
                                <input asp-for="MontoInicial"
                                       type="number"
                                       step="0.01"
                                       placeholder="0.00"
                                       data-caja-abrir-monto
                                       class="w-full rounded-lg border border-slate-200 bg-slate-50 py-3 pl-8 pr-4 text-slate-900 focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-800 dark:text-white" />
                            </div>
                            <p class="text-xs text-slate-400 dark:text-slate-500">Ingresá el efectivo disponible al momento de abrir la caja.</p>
                            <span asp-validation-for="MontoInicial" class="text-rose-500 text-xs"></span>
                        </div>

                        <div class="flex flex-col gap-2">
                            <label asp-for="ObservacionesApertura" class="text-sm font-semibold text-slate-700 dark:text-slate-300">
                                Observaciones de apertura <span class="text-slate-400 dark:text-slate-500 font-normal">(opcional)</span>
                            </label>
                            <textarea asp-for="ObservacionesApertura"
                                      rows="5"
                                      placeholder="Notas adicionales sobre el estado de la caja o del turno..."
                                      class="w-full rounded-lg border border-slate-200 bg-slate-50 p-4 text-slate-900 focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-800 dark:text-white"></textarea>
                        </div>
                    </div>
                </div>

                <div class="border-t border-slate-200 px-6 py-5 dark:border-slate-800">
                    <div class="caja-page-footer-actions">
                        <a asp-action="Index"
                           class="caja-page-footer-action inline-flex items-center justify-center rounded-lg border border-slate-200 bg-white px-8 py-3 text-slate-600 dark:border-slate-700 dark:bg-slate-900/60 dark:text-slate-300 font-bold hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors no-underline">
                            Cancelar
                        </a>
                        <button type="submit"
                                class="caja-page-footer-action inline-flex items-center justify-center gap-2 rounded-lg bg-primary px-10 py-3 text-white font-black shadow-lg shadow-primary/30 hover:bg-primary/90 transition-all active:scale-95">
                            <span class="material-symbols-outlined">lock_open</span>
                            Abrir caja
                        </button>
                    </div>
                </div>
            </section>

            <aside class="caja-form-panel-stack">
                <section class="rounded-2xl border border-slate-200 bg-white/95 p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
                    <div class="flex items-center gap-2 mb-4">
                        <span class="material-symbols-outlined text-primary">info</span>
                        <h2 class="text-slate-900 dark:text-white text-lg font-bold">Antes de abrir</h2>
                    </div>
                    <ul class="space-y-3 text-sm text-slate-700 dark:text-slate-300">
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-[18px] text-emerald-500 mt-0.5">check_circle</span>
                            Verificá que la terminal seleccionada sea la correcta para el turno.
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-[18px] text-emerald-500 mt-0.5">check_circle</span>
                            Registrá el efectivo inicial tal como quedó físicamente disponible.
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-[18px] text-emerald-500 mt-0.5">check_circle</span>
                            Si la caja ya está operativa, el sistema bloqueará una nueva apertura.
                        </li>
                    </ul>
                </section>

                <section class="rounded-2xl border border-amber-400/30 bg-amber-500/10 p-6 shadow-sm">
                    <div class="flex items-center gap-2 mb-3">
                        <span class="material-symbols-outlined text-amber-500">rule</span>
                        <h2 class="text-slate-900 dark:text-white text-lg font-bold">Impacto del turno</h2>
                    </div>
                    <p class="text-sm text-slate-700 dark:text-slate-300 leading-relaxed">
                        Una vez abierta la caja, todas las ventas, ingresos y egresos quedarán vinculados a este turno hasta su cierre y arqueo final.
                    </p>
                </section>
            </aside>
        </div>
    </form>
</div>

@section Styles {
    <partial name="_CajaModuleStyles" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/caja-abrir.js" asp-append-version="true"></script>
}
