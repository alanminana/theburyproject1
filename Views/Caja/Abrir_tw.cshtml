@model TheBuryProject.ViewModels.AbrirCajaViewModel
@{
    ViewData["Title"] = "Abrir Caja";
    var cajas = ViewBag.Cajas as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var usuarioActual = User.Identity?.Name ?? "Usuario actual";
    var cajaSeleccionada = cajas?.FirstOrDefault(i => i.Value == (Model.CajaId == 0 ? string.Empty : Model.CajaId.ToString()));
    var terminalTexto = !string.IsNullOrWhiteSpace(Model.CajaNombre) ? Model.CajaNombre : cajaSeleccionada?.Text ?? "Seleccionar terminal";
    var terminalCodigo = !string.IsNullOrWhiteSpace(Model.CajaCodigo) ? Model.CajaCodigo : "Sin código cargado";
}

<div class="caja-page-shell" style="padding-bottom:3rem">

    <a asp-action="Index" class="inline-flex items-center gap-1.5 text-sm muted hover:text-white transition" style="text-decoration:none">
        <span class="material-symbols-outlined" style="font-size:18px">arrow_back</span>Volver a cajas
    </a>

    <div class="page-head" style="margin-top:.85rem">
        <div class="min-w-0">
            <h1 class="page-title">Abrir caja</h1>
            <p class="page-sub">Iniciá un turno declarando el fondo inicial. A partir de la apertura quedan registrados todos los movimientos hasta el cierre.</p>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-bad" style="margin-top:1rem">
            <span class="material-symbols-outlined">error</span>
            <span>@TempData["Error"]</span>
        </div>
    }

    <div class="grid-kpi" style="margin-top:1.5rem">
        <div class="kpi">
            <div class="kpi-label">Terminal</div>
            <div data-caja-abrir-terminal-label class="kpi-value">@terminalTexto</div>
            <div data-caja-abrir-terminal-copy class="kpi-foot">@terminalCodigo</div>
        </div>
        <div class="kpi">
            <div class="kpi-label">Responsable</div>
            <div class="kpi-value">@usuarioActual</div>
            <div class="kpi-foot">Turno vinculado al usuario autenticado.</div>
        </div>
        <div class="kpi kpi--accent">
            <div class="kpi-label">Fondo inicial</div>
            <div data-caja-abrir-fondo-label class="kpi-value">$@Model.MontoInicial.ToString("N2")</div>
            <div class="kpi-foot">Base para el arqueo al cierre.</div>
        </div>
        <div class="kpi">
            <div class="kpi-label">Apertura</div>
            <div class="kpi-value num">@DateTime.Now.ToString("dd/MM · HH:mm")</div>
            <div class="kpi-foot">Fecha y hora de inicio del turno.</div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4" style="margin-top:1.5rem">

        <form asp-action="Abrir" method="post" class="lg:col-span-2 card card-pad">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 class="alert alert-bad empty:hidden"
                 role="alert"
                 style="margin-bottom:1rem"></div>

            <h2 class="font-semibold text-white">Datos de apertura</h2>
            <p class="text-sm muted-2" style="margin-top:.2rem;margin-bottom:1.25rem">Confirmá la caja y el monto con el que arranca el turno.</p>

            <div class="space-y-4">
                <div>
                    <label asp-for="CajaId" class="label">Caja a abrir <span class="req">*</span></label>
                    <select asp-for="CajaId" asp-items="cajas" class="field" data-caja-abrir-select
                            data-caja-ultimo-cierre-url="@Url.Action("UltimoEfectivoCierre")">
                        <option value="">Seleccioná una caja disponible…</option>
                    </select>
                    <p class="hint">Solo se listan cajas disponibles (sin turno abierto).</p>
                    <span asp-validation-for="CajaId" class="text-rose-500 text-xs"></span>
                </div>

                <div>
                    <label asp-for="MontoInicial" class="label">Fondo inicial <span class="req">*</span></label>
                    <div class="field-money">
                        <span class="cur">$</span>
                        <input asp-for="MontoInicial" type="number" step="0.01" min="0" class="field" placeholder="0.00" data-caja-abrir-monto />
                    </div>
                    <p class="hint">Por defecto toma el efectivo del último cierre de esta caja. Podés ajustarlo si el fondo real es otro.</p>
                    <span asp-validation-for="MontoInicial" class="text-rose-500 text-xs"></span>
                </div>

                <div class="flex flex-wrap gap-1.5">
                    <button type="button" class="btn btn-ghost btn-sm" onclick="setMonto(10000)">$ 10.000</button>
                    <button type="button" class="btn btn-ghost btn-sm" onclick="setMonto(15000)">$ 15.000</button>
                    <button type="button" class="btn btn-ghost btn-sm" onclick="setMonto(20000)">$ 20.000</button>
                    <button type="button" class="btn btn-ghost btn-sm" onclick="setMonto(30000)">$ 30.000</button>
                </div>

                <div>
                    <label asp-for="ObservacionesApertura" class="label">Observaciones del turno <span class="muted-2 font-normal">(opcional)</span></label>
                    <textarea asp-for="ObservacionesApertura" class="field" placeholder="Notas de apertura: novedades, billetes recibidos, etc."></textarea>
                </div>
            </div>

            <div class="flex flex-col-reverse sm:flex-row justify-end gap-2"
                 style="margin-top:1.5rem;padding-top:1rem;border-top:1px solid #1f2937">
                <a asp-action="Index" class="btn btn-ghost" style="text-decoration:none">Cancelar</a>
                <button type="submit" class="btn btn-primary">
                    <span class="material-symbols-outlined">lock_open</span>Abrir caja
                </button>
            </div>
        </form>

        <aside class="space-y-4">
            <div class="card card-pad">
                <div class="flex items-center gap-2" style="margin-bottom:.75rem">
                    <span class="material-symbols-outlined" style="color:#f5c518;font-size:20px">tips_and_updates</span>
                    <h3 class="font-semibold text-white">Buenas prácticas</h3>
                </div>
                <ul class="help-list">
                    <li><span class="material-symbols-outlined">payments</span>Contá el efectivo físico antes de declarar el fondo inicial.</li>
                    <li><span class="material-symbols-outlined">badge</span>El turno queda a tu nombre: vos sos responsable hasta el cierre.</li>
                    <li><span class="material-symbols-outlined">schedule</span>Una caja solo puede tener un turno abierto a la vez.</li>
                </ul>
            </div>
            <div class="alert alert-info">
                <span class="material-symbols-outlined">info</span>
                <div>Abrir la caja <strong>no genera asientos contables</strong>. Solo habilita el registro de ingresos y egresos del turno.</div>
            </div>
        </aside>
    </div>

</div>

@section Styles {
    <partial name="_CajaModuleStyles" />
}
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/caja-abrir.js" asp-append-version="true"></script>
    <script>
        function setMonto(v) {
            const input = document.querySelector('[data-caja-abrir-monto]');
            if (input) { input.value = v; input.dispatchEvent(new Event('input')); }
        }
    </script>
}
