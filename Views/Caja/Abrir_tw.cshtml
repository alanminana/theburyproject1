@model TheBuryProject.ViewModels.AbrirCajaViewModel
@{
    ViewData["Title"] = "Abrir Caja";
    var cajas = ViewBag.Cajas as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
}

<div class="flex-1 w-full max-w-4xl mx-auto px-4 pt-10 pb-6">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-900 dark:text-white tracking-tight">Abrir caja</h1>
            <p class="text-slate-500 dark:text-slate-400 mt-2 max-w-lg">Inicie una nueva jornada operativa seleccionando la terminal y el monto base.</p>
        </div>
        <div>
            <a asp-action="Index"
               class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-slate-100 dark:bg-surface-dark border border-slate-200 dark:border-border-dark text-slate-700 dark:text-slate-200 rounded-lg font-semibold text-sm hover:bg-slate-200 dark:hover:bg-slate-800 transition-all no-underline">
                <span class="material-symbols-outlined text-sm">arrow_back</span>
                Volver
            </a>
        </div>
    </div>

    <!-- Validation / Toasts -->
    <div asp-validation-summary="ModelOnly" class="text-rose-500 text-sm mb-4"></div>

    @if (TempData["Error"] != null)
    {
        <div id="toast-error" class="flex items-center gap-3 bg-rose-500/10 border border-rose-500/20 text-rose-600 dark:text-rose-400 px-5 py-3 rounded-xl text-sm font-medium mb-4">
            <span class="material-symbols-outlined text-lg">error</span>
            @TempData["Error"]
        </div>
    }

    <!-- Main Form Card -->
    <form asp-action="Abrir" method="post"
          class="bg-white dark:bg-surface-dark rounded-xl border border-slate-200 dark:border-border-dark shadow-2xl overflow-hidden">
        @Html.AntiForgeryToken()

        <div class="p-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

                <!-- Form Column -->
                <div class="space-y-6">
                    <!-- Caja Select -->
                    <div>
                        <label asp-for="CajaId" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Caja / Terminal</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 dark:text-slate-500">point_of_sale</span>
                            <select asp-for="CajaId" asp-items="cajas"
                                    class="w-full pl-10 pr-4 py-3 bg-slate-50 dark:bg-background-dark border border-slate-200 dark:border-border-dark rounded-lg text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-primary transition-all">
                                <option value="">Seleccione la terminal de caja</option>
                            </select>
                        </div>
                        <span asp-validation-for="CajaId" class="text-rose-500 text-xs"></span>
                    </div>

                    <!-- Monto Inicial -->
                    <div>
                        <label asp-for="MontoInicial" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">Monto inicial</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400 font-medium">$</span>
                            <input asp-for="MontoInicial" type="number" step="0.01" placeholder="0.00"
                                   class="w-full pl-8 pr-4 py-3 bg-slate-50 dark:bg-background-dark border border-slate-200 dark:border-border-dark rounded-lg text-slate-900 dark:text-white font-medium focus:ring-2 focus:ring-primary focus:border-primary transition-all placeholder:text-slate-400 dark:placeholder:text-slate-600" />
                        </div>
                        <p class="text-xs text-slate-400 dark:text-slate-500 mt-2 italic">Ingrese el efectivo disponible en caja al momento de apertura.</p>
                        <span asp-validation-for="MontoInicial" class="text-rose-500 text-xs"></span>
                    </div>

                    <!-- Observaciones -->
                    <div>
                        <label asp-for="ObservacionesApertura" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">
                            Observaciones de apertura <span class="text-slate-400 dark:text-slate-500 font-normal">(opcional)</span>
                        </label>
                        <textarea asp-for="ObservacionesApertura" rows="4"
                                  placeholder="Notas adicionales sobre el estado de la caja..."
                                  class="w-full p-4 bg-slate-50 dark:bg-background-dark border border-slate-200 dark:border-border-dark rounded-lg text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-primary transition-all placeholder:text-slate-400 dark:placeholder:text-slate-600"></textarea>
                    </div>
                </div>

                <!-- Info/Summary Column -->
                <div class="flex flex-col">
                    <div class="bg-primary/5 border border-primary/20 rounded-xl p-6 h-full flex flex-col justify-center">
                        <div class="flex items-start gap-4 mb-4">
                            <div class="bg-primary/20 p-2 rounded-lg">
                                <span class="material-symbols-outlined text-primary">info</span>
                            </div>
                            <h3 class="text-lg font-bold text-slate-900 dark:text-white">Recordatorio de seguridad</h3>
                        </div>
                        <p class="text-slate-600 dark:text-slate-300 leading-relaxed text-sm mb-6">
                            Recuerde que una vez abierta la caja, todos los movimientos
                            (<span class="text-slate-900 dark:text-white font-medium">ventas, ingresos y egresos</span>)
                            quedarán vinculados a este turno hasta su cierre y arqueo correspondiente.
                        </p>
                        <div class="space-y-3">
                            <div class="flex items-center gap-3 text-slate-500 dark:text-slate-400 text-sm">
                                <span class="material-symbols-outlined text-green-500 text-sm">check_circle</span>
                                Registro de auditoría activo
                            </div>
                            <div class="flex items-center gap-3 text-slate-500 dark:text-slate-400 text-sm">
                                <span class="material-symbols-outlined text-green-500 text-sm">check_circle</span>
                                Asignación de usuario inmediata
                            </div>
                            <div class="flex items-center gap-3 text-slate-500 dark:text-slate-400 text-sm">
                                <span class="material-symbols-outlined text-green-500 text-sm">check_circle</span>
                                Control de base en efectivo
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Actions Footer -->
        <div class="bg-slate-50 dark:bg-background-dark/80 px-8 py-6 border-t border-slate-100 dark:border-border-dark flex flex-col sm:flex-row justify-end gap-4">
            <a asp-action="Index"
               class="px-6 py-2.5 bg-transparent border border-slate-300 dark:border-border-dark text-slate-600 dark:text-slate-300 font-semibold rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-all no-underline text-center order-2 sm:order-1">
                Cancelar
            </a>
            <button type="submit"
                    class="px-8 py-2.5 bg-primary text-white font-bold rounded-lg shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all flex items-center justify-center gap-2 order-1 sm:order-2">
                <span class="material-symbols-outlined text-xl">lock_open</span>
                Abrir caja
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/caja-abrir.js"></script>
}
