@model TheBuryProject.ViewModels.CerrarCajaViewModel
@{
    ViewData["Title"] = "Cerrar Caja";
    var returnUrl = ViewBag.ReturnUrl as string;
    var movimientosCount = Model.Movimientos?.Count ?? 0;
}

<div class="caja-page-shell space-y-8">
    <a asp-action="DetallesApertura" asp-route-id="@Model.AperturaCajaId" class="inline-flex items-center gap-1.5 text-sm muted hover:text-white transition no-underline">
        <span class="material-symbols-outlined" style="font-size:18px">arrow_back</span>Volver al turno
    </a>

    <div class="page-head">
        <div class="min-w-0">
            <h1 class="page-title">Cerrar caja · Arqueo</h1>
            <p class="page-sub">Contá el efectivo físico en la caja y registralo. Vamos a comparar contra lo esperado por el sistema.</p>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div id="toast-error" class="flex items-center gap-3 bg-rose-500/10 border border-rose-500/20 text-rose-400 px-5 py-3 rounded-xl text-sm font-medium" role="alert">
            <span class="material-symbols-outlined text-lg">error</span>@TempData["Error"]
        </div>
    }

    <div class="grid-kpi">
        <div class="kpi">
            <div class="kpi-label">Fondo inicial</div>
            <div class="kpi-value">$@Model.MontoInicialSistema.ToString("N2")</div>
        </div>
        <div class="kpi kpi--ok">
            <div class="kpi-label">Ingresos</div>
            <div class="kpi-value">$@Model.TotalIngresosSistema.ToString("N2")</div>
        </div>
        <div class="kpi kpi--bad">
            <div class="kpi-label">Egresos</div>
            <div class="kpi-value">$@Model.TotalEgresosSistema.ToString("N2")</div>
        </div>
        <div class="kpi kpi--accent">
            <div class="kpi-label">Esperado (sistema)</div>
            <div class="kpi-value" id="monto-esperado" data-value="@Model.MontoEsperadoSistema.ToString(System.Globalization.CultureInfo.InvariantCulture)">$@Model.MontoEsperadoSistema.ToString("N2")</div>
        </div>
    </div>

    <div asp-validation-summary="ModelOnly" class="rounded-xl border border-rose-500/20 bg-rose-500/10 px-4 py-3 text-sm text-rose-400 empty:hidden" role="alert"></div>

    <form asp-action="Cerrar" method="post" id="form-cerrar">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="AperturaCajaId" />
        <input type="hidden" asp-for="ChequesContados" value="0" />
        <input type="hidden" asp-for="ValesContados" value="0" />
        @if (!string.IsNullOrEmpty(returnUrl))
        {
            <input type="hidden" name="returnUrl" value="@returnUrl" />
        }

        <div class="grid grid-cols-1 lg:grid-cols-5 gap-4">
            <section class="lg:col-span-3 card card-pad">
                <h2 class="font-semibold text-white">Arqueo de cierre</h2>
                <p class="text-sm muted mt-0.5 mb-4">Ingresá el efectivo real contado. La diferencia se calcula automáticamente.</p>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 items-end">
                    <div>
                        <label asp-for="EfectivoContado" class="label">Efectivo real contado <span class="req">*</span></label>
                        <div class="field-money">
                            <span class="cur">$</span>
                            <input asp-for="EfectivoContado" type="number" step="0.01" placeholder="0.00" class="field arqueo-input" autofocus />
                        </div>
                        <span asp-validation-for="EfectivoContado" class="text-rose-500 text-xs"></span>
                    </div>
                    <div class="card-2 p-3">
                        <div class="text-[.68rem] uppercase tracking-wide muted-2 font-semibold">Esperado por sistema</div>
                        <div class="text-lg font-semibold text-white num mt-0.5">$@Model.MontoEsperadoSistema.ToString("N2")</div>
                    </div>
                </div>

                <div class="result-card mt-4" id="result">
                    <div class="flex items-center justify-between gap-3">
                        <div>
                            <div class="result-label">Diferencia</div>
                            <div class="result-value" id="diferencia-valor">$0,00</div>
                        </div>
                        <span id="diferencia-status" class="chip" style="visibility:hidden">Exacto</span>
                    </div>
                    <p class="text-sm mt-2" id="diferencia-help" style="color:var(--muted)">Ingresá el efectivo contado para ver la diferencia.</p>
                    <span class="material-symbols-outlined hidden" id="diferencia-icon">check_circle</span>
                    <span class="hidden" id="total-real">$0,00</span>
                </div>

                <div data-caja-justificacion class="hidden" style="margin-top:1.25rem">
                    <label asp-for="JustificacionDiferencia" class="label">Justificación de la diferencia <span class="req">*</span></label>
                    <textarea asp-for="JustificacionDiferencia" id="justificacion" rows="3" disabled placeholder="Explicá el origen del sobrante o faltante." class="field"></textarea>
                    <span asp-validation-for="JustificacionDiferencia" class="text-rose-500 text-xs"></span>
                </div>

                <div style="margin-top:1.25rem">
                    <label asp-for="DetalleArqueo" class="label">Detalle del arqueo <span class="muted-2 font-normal">(desglose de billetes, opcional)</span></label>
                    <textarea asp-for="DetalleArqueo" rows="3" placeholder="Ej. 10 x $1000, 5 x $500..." class="field"></textarea>
                </div>

                <div style="margin-top:1rem">
                    <label asp-for="ObservacionesCierre" class="label">Observaciones del cierre <span class="muted-2 font-normal">(opcional)</span></label>
                    <textarea asp-for="ObservacionesCierre" rows="3" placeholder="Novedades del turno para el responsable del próximo." class="field"></textarea>
                </div>

                <div class="alert alert-bad" style="margin-top:1.25rem">
                    <span class="material-symbols-outlined">warning</span>
                    <div><strong>El cierre es irreversible.</strong> Una vez cerrado el turno no se pueden agregar ni editar movimientos. La caja vuelve a estado Disponible.</div>
                </div>

                <div class="mt-5 pt-4 flex flex-col-reverse sm:flex-row justify-end gap-2" style="border-top:1px solid var(--line)">
                    <a asp-action="DetallesApertura" asp-route-id="@Model.AperturaCajaId" class="btn btn-ghost no-underline">Cancelar</a>
                    <button type="submit" class="btn btn-primary"><span class="material-symbols-outlined">lock</span>Cerrar caja</button>
                </div>
            </section>

            <aside class="lg:col-span-2 space-y-4">
                <div class="card card-pad">
                    <h3 class="font-semibold text-white mb-2">Datos de apertura</h3>
                    <dl>
                        <div class="defrow"><dt>Caja</dt><dd>@Model.CajaNombre</dd></div>
                        <div class="defrow"><dt>Apertura</dt><dd class="num">@(Model.FechaApertura?.ToString("dd/MM · HH:mm") ?? "—")</dd></div>
                        <div class="defrow"><dt>Responsable</dt><dd>@Model.UsuarioApertura</dd></div>
                        <div class="defrow"><dt>Movimientos</dt><dd class="num">@movimientosCount</dd></div>
                    </dl>
                </div>

                <div class="card card-pad">
                    <div class="flex items-center gap-2 mb-3">
                        <span class="material-symbols-outlined" style="color:#f5c518;font-size:20px">balance</span>
                        <h3 class="font-semibold text-white">Cómo leer el arqueo</h3>
                    </div>
                    <ul class="help-list">
                        <li><span class="material-symbols-outlined" style="color:#34d399">add_circle</span><span><strong>Sobrante:</strong> contaste más de lo esperado.</span></li>
                        <li><span class="material-symbols-outlined" style="color:#fb7185">remove_circle</span><span><strong>Faltante:</strong> contaste menos de lo esperado.</span></li>
                        <li><span class="material-symbols-outlined" style="color:#34d399">check_circle</span><span><strong>Sin diferencia:</strong> el efectivo coincide exacto.</span></li>
                    </ul>
                </div>
            </aside>
        </div>
    </form>
</div>

@section Styles {
    <partial name="_CajaModuleStyles" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/caja-cerrar.js" asp-append-version="true"></script>
}
