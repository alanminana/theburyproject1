@model TheBuryProject.ViewModels.CajaViewModel
@{
    ViewData["Title"] = "Nueva Caja";
    var codigoActual = Model?.Codigo ?? string.Empty;
    var nombreActual = Model?.Nombre ?? string.Empty;
    var sucursalActual = Model?.Sucursal ?? string.Empty;
    var ubicacionActual = Model?.Ubicacion ?? string.Empty;
    var descripcionActual = Model?.Descripcion ?? string.Empty;
    var activa = Model?.Activa ?? true;
    var ubicacionResumen = string.Join(" • ", new[] { sucursalActual, ubicacionActual }.Where(v => !string.IsNullOrWhiteSpace(v)));
}

<div class="caja-page-shell" style="padding-bottom:1.5rem">

    <!-- Back link -->
    <a asp-action="Index" class="inline-flex items-center gap-1.5 text-sm muted hover:text-white transition" style="text-decoration:none">
        <span class="material-symbols-outlined" style="font-size:18px">arrow_back</span>Volver a cajas
    </a>

    <!-- Page head -->
    <div class="page-head" style="margin-top:.6rem">
        <div class="min-w-0">
            <h1 class="page-title">Nueva caja</h1>
            <p class="page-sub">Definí una terminal de caja. Las cajas se pueden abrir, operar y archivar sin perder su historial.</p>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-bad" style="margin-top:1rem">
            <span class="material-symbols-outlined">error</span>
            <span>@TempData["Error"]</span>
        </div>
    }

    <!-- Preview KPIs -->
    <div class="grid-kpi" style="margin-top:1rem">
        <div class="kpi">
            <div class="kpi-label">Código</div>
            <div data-caja-preview-code class="kpi-value mono">@(string.IsNullOrWhiteSpace(codigoActual) ? "Pendiente" : codigoActual)</div>
        </div>
        <div class="kpi">
            <div class="kpi-label">Nombre</div>
            <div data-caja-preview-name class="kpi-value">@(string.IsNullOrWhiteSpace(nombreActual) ? "Nueva terminal" : nombreActual)</div>
        </div>
        <div data-caja-preview-status-card
             class="rounded-2xl border p-4 shadow-sm @(activa ? "border-emerald-500/20 bg-emerald-500/10" : "border-rose-500/20 bg-rose-500/10")">
            <div class="kpi-label">Estado inicial</div>
            <div data-caja-preview-status
                 class="mt-2 text-2xl font-black @(activa ? "text-emerald-600 dark:text-emerald-400" : "text-rose-600 dark:text-rose-400")">@(activa ? "Activa" : "Inactiva")</div>
            <div data-caja-preview-status-copy
                 class="mt-1 text-xs @(activa ? "text-emerald-600/80 dark:text-emerald-400/80" : "text-rose-600/80 dark:text-rose-400/80")">
                @(activa ? "Quedará disponible para aperturas y operaciones." : "Se mantendrá fuera del flujo operativo hasta volver a activarla.")
            </div>
        </div>
        <div class="kpi">
            <div class="kpi-label">Ubicación</div>
            <div data-caja-preview-location class="kpi-value">@(string.IsNullOrWhiteSpace(ubicacionResumen) ? "Sin definir" : ubicacionResumen)</div>
        </div>
    </div>

    <!-- Main grid: form (col-span-2) + aside -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4" style="margin-top:1rem">

        <!-- Form -->
        <form asp-action="Create" method="post" class="lg:col-span-2 card card-pad">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 class="alert alert-bad empty:hidden"
                 role="alert"
                 style="margin-bottom:1rem"></div>

            <h2 class="font-semibold text-white">Datos de la caja</h2>
            <p class="text-sm muted-2" style="margin-top:.2rem;margin-bottom:1.25rem">El código identifica la caja en todo el módulo y no debería cambiar una vez en uso.</p>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label asp-for="Codigo" class="label">Código <span class="req">*</span></label>
                    <input asp-for="Codigo" class="field mono" placeholder="Ej. CAJA-01" required data-caja-form-codigo />
                    <span asp-validation-for="Codigo" class="text-rose-500 text-xs"></span>
                </div>
                <div>
                    <label asp-for="Nombre" class="label">Nombre <span class="req">*</span></label>
                    <input asp-for="Nombre" class="field" placeholder="Ej. Caja Recepción" required data-caja-form-nombre />
                    <span asp-validation-for="Nombre" class="text-rose-500 text-xs"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4" style="margin-top:1rem">
                <div>
                    <label asp-for="Sucursal" class="label">Sucursal <span class="req">*</span></label>
                    <input asp-for="Sucursal" class="field" placeholder="Ej. Casa Central" data-caja-form-sucursal />
                </div>
                <div>
                    <label asp-for="Ubicacion" class="label">Ubicación operativa</label>
                    <input asp-for="Ubicacion" class="field" placeholder="Ej. Mostrador / Recepción" data-caja-form-ubicacion />
                </div>
            </div>

            <div style="margin-top:1rem">
                <label asp-for="Descripcion" class="label">Descripción <span class="muted-2 font-normal">(opcional)</span></label>
                <textarea asp-for="Descripcion" class="field" placeholder="Notas internas sobre el uso de esta caja.">@descripcionActual</textarea>
            </div>

            <div class="card-2 flex items-center justify-between" style="margin-top:1.25rem;padding:1rem">
                <div>
                    <div class="font-medium text-white text-sm">Caja activa</div>
                    <div class="text-xs muted-2">Si está activa, se puede abrir un turno. Desactivala para pausarla sin archivar.</div>
                </div>
                <label class="relative inline-flex items-center cursor-pointer" style="flex-shrink:0;margin-left:1rem">
                    <input asp-for="Activa" type="checkbox" class="sr-only peer" data-caja-form-activa />
                    <div class="w-11 h-6 bg-slate-600 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                </label>
            </div>

            <div class="flex flex-col-reverse sm:flex-row justify-end gap-2"
                 style="margin-top:1.5rem;padding-top:1rem;border-top:1px solid #1f2937">
                <a asp-action="Index" class="btn btn-ghost" style="text-decoration:none">Cancelar</a>
                <button type="submit" class="btn btn-primary">
                    <span class="material-symbols-outlined">save</span>Crear caja
                </button>
            </div>
        </form>

        <!-- Aside -->
        <aside class="space-y-4">
            <div class="card card-pad">
                <div class="flex items-center gap-2" style="margin-bottom:.75rem">
                    <span class="material-symbols-outlined" style="color:#f5c518;font-size:20px">tips_and_updates</span>
                    <h3 class="font-semibold text-white">Buenas prácticas</h3>
                </div>
                <ul class="help-list">
                    <li><span class="material-symbols-outlined">tag</span>Usá un código corto y consistente: CAJA-01, CAJA-02…</li>
                    <li><span class="material-symbols-outlined">store</span>Asociá la caja a la sucursal donde opera físicamente.</li>
                    <li><span class="material-symbols-outlined">archive</span>Las cajas con historial se archivan, no se eliminan.</li>
                </ul>
            </div>
            <div class="alert alert-info">
                <span class="material-symbols-outlined">info</span>
                <div>Crear una caja <strong>no abre un turno</strong>. Después podés abrirla desde el listado de cajas.</div>
            </div>
        </aside>
    </div>

</div>

@section Styles {
    <partial name="_CajaModuleStyles" />
}
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/caja-form.js" asp-append-version="true"></script>
}
