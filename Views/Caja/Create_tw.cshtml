@model TheBuryProject.ViewModels.CajaViewModel
@* Superficie canónica de Caja: priorizar la evolución UX en full-page. *@
@{
    ViewData["Title"] = "Nueva Caja";
    var codigoActual = Model?.Codigo ?? string.Empty;
    var nombreActual = Model?.Nombre ?? string.Empty;
    var sucursalActual = Model?.Sucursal ?? string.Empty;
    var ubicacionActual = Model?.Ubicacion ?? string.Empty;
    var descripcionActual = Model?.Descripcion ?? string.Empty;
    var activa = Model?.Activa ?? true;
    var ubicacionResumen = string.Join(" • ", new[] { sucursalActual, ubicacionActual }.Where(value => !string.IsNullOrWhiteSpace(value)));
}

<div class="caja-page-shell space-y-8">

    <header class="space-y-6">
        <div class="flex items-center gap-2 text-sm font-medium text-slate-500 dark:text-slate-400">
            <a asp-action="Index" class="hover:text-primary transition-colors no-underline text-slate-500 dark:text-slate-400">Cajas</a>
            <span class="material-symbols-outlined text-xs">chevron_right</span>
            <span class="text-slate-900 dark:text-white">Nueva caja</span>
        </div>

        <div class="caja-page-header-layout">
            <div class="space-y-2">
                <h1 class="text-slate-900 dark:text-white text-4xl font-black tracking-tight">Nueva caja</h1>
                <p class="max-w-3xl text-sm text-slate-600 dark:text-slate-400 sm:text-base">
                    Registrá una nueva terminal de caja con datos claros, ubicación operativa y estado inicial consistente con el uso esperado.
                </p>
            </div>
            <div class="caja-page-header-actions">
                <a asp-action="Index"
                   class="caja-page-header-action inline-flex items-center justify-center gap-2 rounded-lg bg-slate-100 dark:bg-slate-800 px-4 py-2.5 text-sm font-bold hover:bg-slate-200 dark:hover:bg-slate-700 transition-all no-underline text-slate-700 dark:text-slate-200 border border-slate-200 dark:border-slate-700">
                    <span class="material-symbols-outlined text-lg">arrow_back</span>
                    Volver
                </a>
            </div>
        </div>
    </header>

    @if (TempData["Error"] != null)
    {
        <div id="toast-error" class="flex items-center gap-3 bg-rose-500/10 border border-rose-500/20 text-rose-600 dark:text-rose-400 px-5 py-3 rounded-xl text-sm font-medium" role="alert">
            <span class="material-symbols-outlined text-lg">error</span>
            @TempData["Error"]
        </div>
    }

    <div asp-validation-summary="ModelOnly"
         class="rounded-xl border border-rose-500/20 bg-rose-500/10 px-4 py-3 text-sm text-rose-600 dark:text-rose-400 empty:hidden"
         role="alert"></div>

    <div class="caja-page-metrics caja-page-metrics--4">
        <article class="rounded-2xl border border-slate-200 bg-white/95 p-4 shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
            <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-slate-500 dark:text-slate-400">Código</p>
            <p data-caja-preview-code class="mt-2 text-2xl font-black text-slate-900 dark:text-white">@(string.IsNullOrWhiteSpace(codigoActual) ? "Pendiente" : codigoActual)</p>
            <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">Identificador interno visible para operaciones y soporte.</p>
        </article>
        <article class="rounded-2xl border border-slate-200 bg-white/95 p-4 shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
            <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-slate-500 dark:text-slate-400">Nombre</p>
            <p data-caja-preview-name class="mt-2 text-2xl font-black text-slate-900 dark:text-white">@(string.IsNullOrWhiteSpace(nombreActual) ? "Nueva terminal" : nombreActual)</p>
            <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">Etiqueta legible para usuarios durante la operatoria diaria.</p>
        </article>
        <article data-caja-preview-status-card class="rounded-2xl border @(activa ? "border-emerald-500/20 bg-emerald-500/10" : "border-slate-200 bg-white/95 dark:border-slate-800 dark:bg-slate-900/60") p-4 shadow-sm">
            <p class="text-[11px] font-bold uppercase tracking-[0.18em] @(activa ? "text-emerald-600 dark:text-emerald-400" : "text-slate-500 dark:text-slate-400")">Estado inicial</p>
            <p data-caja-preview-status class="mt-2 text-2xl font-black @(activa ? "text-emerald-600 dark:text-emerald-400" : "text-slate-900 dark:text-white")">@(activa ? "Activa" : "Inactiva")</p>
            <p data-caja-preview-status-copy class="mt-1 text-xs @(activa ? "text-emerald-600/80 dark:text-emerald-400/80" : "text-slate-500 dark:text-slate-400")">
                @(activa ? "Quedará disponible para nuevas aperturas y operaciones." : "Se registrará en sistema sin quedar operativa todavía.")
            </p>
        </article>
        <article class="rounded-2xl border border-primary/20 bg-primary/10 p-4 shadow-sm">
            <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-primary">Ubicación operativa</p>
            <p data-caja-preview-location class="mt-2 text-2xl font-black text-slate-900 dark:text-white">@(string.IsNullOrWhiteSpace(ubicacionResumen) ? "Sin definir" : ubicacionResumen)</p>
            <p class="mt-1 text-xs text-slate-600 dark:text-slate-300">Sucursal y ubicación física para identificar rápidamente la terminal.</p>
        </article>
    </div>

    <form asp-action="Create" method="post" class="space-y-8" data-caja-form-page>
        @Html.AntiForgeryToken()

        <div class="caja-page-main-grid caja-page-main-grid--aside-right">
            <section class="rounded-2xl border border-slate-200 bg-white/95 shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
                <div class="p-6 space-y-8">
                    <div class="space-y-2">
                        <div class="flex flex-wrap items-center gap-2">
                            <span class="material-symbols-outlined text-primary">point_of_sale</span>
                            <h2 class="text-slate-900 dark:text-white text-xl font-bold">Configuración principal</h2>
                        </div>
                        <p class="text-sm text-slate-500 dark:text-slate-400">
                            Definí los datos base de la terminal para que el equipo pueda ubicarla y operarla sin ambigüedades.
                        </p>
                    </div>

                    <div class="space-y-6">
                        <div class="caja-form-fields-grid caja-form-fields-grid--2">
                            <div class="flex flex-col gap-2">
                                <label asp-for="Codigo" class="text-sm font-semibold text-slate-700 dark:text-slate-300">
                                    Código <span class="text-rose-500">*</span>
                                </label>
                                <div class="relative">
                                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">tag</span>
                                    <input asp-for="Codigo"
                                           type="text"
                                           placeholder="Ej: C01-HQ"
                                           required
                                           data-caja-form-codigo
                                           class="w-full rounded-lg border border-slate-200 bg-slate-50 py-3 pl-10 pr-4 text-slate-900 focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-800 dark:text-white" />
                                </div>
                                <span asp-validation-for="Codigo" class="text-rose-500 text-xs"></span>
                            </div>

                            <div class="flex flex-col gap-2">
                                <label asp-for="Nombre" class="text-sm font-semibold text-slate-700 dark:text-slate-300">
                                    Nombre <span class="text-rose-500">*</span>
                                </label>
                                <div class="relative">
                                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">point_of_sale</span>
                                    <input asp-for="Nombre"
                                           type="text"
                                           placeholder="Ej: Caja Principal 01"
                                           required
                                           data-caja-form-nombre
                                           class="w-full rounded-lg border border-slate-200 bg-slate-50 py-3 pl-10 pr-4 text-slate-900 focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-800 dark:text-white" />
                                </div>
                                <span asp-validation-for="Nombre" class="text-rose-500 text-xs"></span>
                            </div>
                        </div>

                        <div class="caja-form-fields-grid caja-form-fields-grid--2">
                            <div class="flex flex-col gap-2">
                                <label asp-for="Sucursal" class="text-sm font-semibold text-slate-700 dark:text-slate-300">Sucursal</label>
                                <div class="relative">
                                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">store</span>
                                    <input asp-for="Sucursal"
                                           type="text"
                                           placeholder="Ej: Casa Central"
                                           data-caja-form-sucursal
                                           class="w-full rounded-lg border border-slate-200 bg-slate-50 py-3 pl-10 pr-4 text-slate-900 focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-800 dark:text-white" />
                                </div>
                            </div>

                            <div class="flex flex-col gap-2">
                                <label asp-for="Ubicacion" class="text-sm font-semibold text-slate-700 dark:text-slate-300">Ubicación</label>
                                <div class="relative">
                                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">location_on</span>
                                    <input asp-for="Ubicacion"
                                           type="text"
                                           placeholder="Ej: Planta baja - Zona A"
                                           data-caja-form-ubicacion
                                           class="w-full rounded-lg border border-slate-200 bg-slate-50 py-3 pl-10 pr-4 text-slate-900 focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-800 dark:text-white" />
                                </div>
                            </div>
                        </div>

                        <div class="flex flex-col gap-2">
                            <label asp-for="Descripcion" class="text-sm font-semibold text-slate-700 dark:text-slate-300">Descripción</label>
                            <textarea asp-for="Descripcion"
                                      rows="4"
                                      placeholder="Detalles adicionales sobre esta terminal de caja..."
                                      class="w-full rounded-lg border border-slate-200 bg-slate-50 p-4 text-slate-900 focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-800 dark:text-white">@descripcionActual</textarea>
                        </div>

                        <div class="rounded-2xl border border-slate-200 bg-slate-50/80 p-5 dark:border-slate-700 dark:bg-slate-800/70">
                            <div class="flex items-center gap-3">
                                <label class="relative inline-flex items-center cursor-pointer">
                                    <input asp-for="Activa" type="checkbox" class="sr-only peer" data-caja-form-activa />
                                    <div class="w-11 h-6 bg-slate-300 dark:bg-slate-600 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                                </label>
                                <div class="space-y-1">
                                    <p class="text-sm font-semibold text-slate-700 dark:text-slate-300">Caja activa</p>
                                    <p class="text-xs text-slate-500 dark:text-slate-400">Si queda activa, estará disponible para apertura y operaciones inmediatamente.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="border-t border-slate-200 px-6 py-5 dark:border-slate-800">
                    <div class="caja-page-footer-actions">
                        <a asp-action="Index"
                           class="caja-page-footer-action inline-flex items-center justify-center rounded-lg border border-slate-200 bg-white px-8 py-3 text-slate-600 dark:border-slate-700 dark:bg-slate-900/60 dark:text-slate-300 font-bold hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors no-underline">
                            Cancelar
                        </a>
                        <button type="submit"
                                class="caja-page-footer-action inline-flex items-center justify-center gap-2 rounded-lg bg-primary px-10 py-3 text-white font-black shadow-lg shadow-primary/30 hover:bg-primary/90 transition-all active:scale-95">
                            <span class="material-symbols-outlined">add</span>
                            Crear caja
                        </button>
                    </div>
                </div>
            </section>

            <aside class="caja-form-panel-stack">
                <section class="rounded-2xl border border-slate-200 bg-white/95 p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
                    <div class="flex items-center gap-2 mb-4">
                        <span class="material-symbols-outlined text-primary">monitoring</span>
                        <h2 class="text-slate-900 dark:text-white text-lg font-bold">Impacto del alta</h2>
                    </div>
                    <p class="text-sm text-slate-700 dark:text-slate-300 leading-relaxed">
                        La caja creada quedará disponible en el módulo principal y podrá usarse para aperturas, movimientos y cierres según su estado inicial.
                    </p>
                </section>

                <section class="rounded-2xl border border-amber-400/30 bg-amber-500/10 p-6 shadow-sm">
                    <div class="flex items-center gap-2 mb-3">
                        <span class="material-symbols-outlined text-amber-500">rule</span>
                        <h2 class="text-slate-900 dark:text-white text-lg font-bold">Buenas prácticas</h2>
                    </div>
                    <ul class="space-y-3 text-sm text-slate-700 dark:text-slate-300">
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-[18px] text-amber-500 mt-0.5">check_circle</span>
                            Usá un código corto, estable y fácil de reconocer para soporte y auditoría.
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-[18px] text-amber-500 mt-0.5">check_circle</span>
                            Definí sucursal y ubicación para evitar ambigüedades entre terminales.
                        </li>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-[18px] text-amber-500 mt-0.5">check_circle</span>
                            Si la caja no debe operar todavía, dejala inactiva y activala cuando corresponda.
                        </li>
                    </ul>
                </section>
            </aside>
        </div>
    </form>
</div>

@section Styles {
    <partial name="_CajaModuleStyles" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/caja-form.js" asp-append-version="true"></script>
}
