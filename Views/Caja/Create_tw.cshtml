@model TheBuryProject.ViewModels.CajaViewModel
@{
    ViewData["Title"] = "Nueva Caja";
}

<div class="flex-1 w-full max-w-3xl mx-auto px-4 pt-10 pb-6">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-900 dark:text-white tracking-tight">Nueva caja</h1>
            <p class="text-slate-500 dark:text-slate-400 mt-2 max-w-lg">Registre una nueva terminal de caja en el sistema.</p>
        </div>
        <a asp-action="Index"
           class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-200 rounded-lg font-semibold text-sm hover:bg-slate-200 dark:hover:bg-slate-700 transition-all no-underline">
            <span class="material-symbols-outlined text-sm">arrow_back</span>
            Volver
        </a>
    </div>

    <div asp-validation-summary="ModelOnly" class="text-rose-500 text-sm mb-4"></div>

    @if (TempData["Error"] != null)
    {
        <div id="toast-error" class="flex items-center gap-3 bg-rose-500/10 border border-rose-500/20 text-rose-600 dark:text-rose-400 px-5 py-3 rounded-xl text-sm font-medium mb-4">
            <span class="material-symbols-outlined text-lg">error</span>
            @TempData["Error"]
        </div>
    }

    <form asp-action="Create" method="post"
          class="bg-white dark:bg-slate-900/50 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
        @Html.AntiForgeryToken()

        <div class="p-6 md:p-8 space-y-6">

            <!-- Código + Nombre -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="flex flex-col gap-2">
                    <label asp-for="Codigo" class="text-sm font-semibold text-slate-700 dark:text-slate-300">
                        Código <span class="text-rose-500">*</span>
                    </label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">tag</span>
                        <input asp-for="Codigo" type="text" placeholder="Ej: C01-HQ" required
                               class="w-full pl-10 pr-4 py-3 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-primary transition-all" />
                    </div>
                    <span asp-validation-for="Codigo" class="text-rose-500 text-xs"></span>
                </div>
                <div class="flex flex-col gap-2">
                    <label asp-for="Nombre" class="text-sm font-semibold text-slate-700 dark:text-slate-300">
                        Nombre <span class="text-rose-500">*</span>
                    </label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">point_of_sale</span>
                        <input asp-for="Nombre" type="text" placeholder="Ej: Caja Principal 01" required
                               class="w-full pl-10 pr-4 py-3 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-primary transition-all" />
                    </div>
                    <span asp-validation-for="Nombre" class="text-rose-500 text-xs"></span>
                </div>
            </div>

            <!-- Sucursal + Ubicación -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="flex flex-col gap-2">
                    <label asp-for="Sucursal" class="text-sm font-semibold text-slate-700 dark:text-slate-300">Sucursal</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">store</span>
                        <input asp-for="Sucursal" type="text" placeholder="Ej: Casa Central"
                               class="w-full pl-10 pr-4 py-3 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-primary transition-all" />
                    </div>
                </div>
                <div class="flex flex-col gap-2">
                    <label asp-for="Ubicacion" class="text-sm font-semibold text-slate-700 dark:text-slate-300">Ubicación</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">location_on</span>
                        <input asp-for="Ubicacion" type="text" placeholder="Ej: Planta baja - Zona A"
                               class="w-full pl-10 pr-4 py-3 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-primary transition-all" />
                    </div>
                </div>
            </div>

            <!-- Descripción -->
            <div class="flex flex-col gap-2">
                <label asp-for="Descripcion" class="text-sm font-semibold text-slate-700 dark:text-slate-300">Descripción</label>
                <textarea asp-for="Descripcion" rows="3"
                          placeholder="Detalles adicionales sobre esta terminal de caja..."
                          class="w-full p-4 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-primary transition-all"></textarea>
            </div>

            <!-- Activa toggle -->
            <div class="flex items-center gap-3 p-4 bg-slate-50 dark:bg-slate-800/50 rounded-lg border border-slate-200 dark:border-slate-700">
                <label class="relative inline-flex items-center cursor-pointer">
                    <input asp-for="Activa" type="checkbox" class="sr-only peer" checked />
                    <div class="w-11 h-6 bg-slate-300 dark:bg-slate-600 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                </label>
                <div>
                    <p class="text-sm font-semibold text-slate-700 dark:text-slate-300">Caja activa</p>
                    <p class="text-xs text-slate-400">La caja estará disponible para apertura y operaciones</p>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="bg-slate-50 dark:bg-slate-800/30 px-6 md:px-8 py-5 border-t border-slate-100 dark:border-slate-700 flex flex-col sm:flex-row justify-end gap-3">
            <a asp-action="Index"
               class="px-6 py-2.5 border border-slate-300 dark:border-slate-700 text-slate-600 dark:text-slate-300 font-semibold rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-all no-underline text-center text-sm">
                Cancelar
            </a>
            <button type="submit"
                    class="px-8 py-2.5 bg-primary text-white font-bold rounded-lg shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all flex items-center justify-center gap-2 text-sm">
                <span class="material-symbols-outlined text-lg">add</span>
                Crear caja
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/caja-form.js"></script>
}
