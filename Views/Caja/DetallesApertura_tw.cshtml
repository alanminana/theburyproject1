@model TheBuryProject.ViewModels.CajaConciliacionViewModel
@{
    ViewData["Title"] = "Detalle de caja";
}

<div class="caja-page-shell cc-shell space-y-4" data-caja-detalle>

    <a asp-action="Index" class="inline-flex items-center gap-1.5 text-sm muted hover:text-white transition no-underline cc-noprint">
        <span class="material-symbols-outlined" style="font-size:18px">arrow_back</span>Volver a cajas
    </a>

    <div class="page-head">
        <div class="min-w-0">
            <div class="flex items-center gap-2 flex-wrap">
                <h1 class="page-title">@Model.NombreCaja</h1>
                @if (!string.IsNullOrWhiteSpace(Model.CodigoCaja))
                {
                    <span class="chip chip-neutral mono">@Model.CodigoCaja</span>
                }
                @if (Model.EstaCerrada)
                {
                    <span class="chip chip-neutral"><span class="material-symbols-outlined">lock</span>Turno cerrado</span>
                }
                else
                {
                    <span class="chip chip-live"><span class="dot"></span>Turno abierto</span>
                }
            </div>
            <p class="page-sub">
                Abierta por <strong>@Model.Responsable</strong> · @Model.FechaApertura.ToString("dd/MM/yyyy HH:mm")
                @if (!string.IsNullOrWhiteSpace(Model.Ubicacion) || !string.IsNullOrWhiteSpace(Model.Sucursal))
                {
                    <text> · @($"{Model.Ubicacion} {Model.Sucursal}".Trim())</text>
                }
            </p>
        </div>
        <div class="head-actions cc-noprint">
            <button type="button" data-caja-print class="btn btn-ghost">
                <span class="material-symbols-outlined">print</span>Imprimir
            </button>
            @if (Model.PuedeOperar)
            {
                <a asp-action="RegistrarMovimiento" asp-route-aperturaId="@Model.AperturaId" class="btn btn-soft no-underline">
                    <span class="material-symbols-outlined">add_card</span>Nuevo movimiento
                </a>
                <a asp-action="Cerrar" asp-route-aperturaId="@Model.AperturaId" class="btn btn-primary no-underline">
                    <span class="material-symbols-outlined">lock</span>Cerrar caja
                </a>
            }
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-bad cc-noprint" role="alert">
            <span class="material-symbols-outlined">error</span><span>@TempData["Error"]</span>
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-ok cc-noprint" role="status">
            <span class="material-symbols-outlined">check_circle</span><span>@TempData["Success"]</span>
        </div>
    }

    <partial name="_ConciliacionCards" model="Model" />
    <partial name="_ConciliacionTabs" model="Model" />

    <div class="cc-print-foot">
        Responsable: @Model.Responsable · Turno abierto el @Model.FechaApertura.ToString("dd/MM/yyyy HH:mm") · Impreso @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
    </div>
</div>

@section Styles {
    <partial name="_CajaModuleStyles" />
}

@section Scripts {
    <script src="~/js/caja-conciliacion.js" asp-append-version="true"></script>
}
