@model TheBuryProject.ViewModels.CajaConciliacionViewModel
@{
    ViewData["Title"] = "Detalle de cierre";
    var returnUrl = ViewBag.ReturnUrl as string;
    var volverUrl = !string.IsNullOrEmpty(returnUrl) ? returnUrl : Url.Action("Historial");

    var difClass = Model.DiferenciaCaja > 0 ? "chip-warn" : (Model.DiferenciaCaja < 0 ? "chip-bad" : "chip-ok");
    var difIcon = Model.DiferenciaCaja > 0 ? "add_circle" : (Model.DiferenciaCaja < 0 ? "remove_circle" : "check_circle");
    var difLabel = Model.DiferenciaCaja > 0 ? "Sobrante" : (Model.DiferenciaCaja < 0 ? "Faltante" : "Exacto");
}

<div class="caja-page-shell cc-shell space-y-4" data-caja-detalle>

    <a href="@volverUrl" class="inline-flex items-center gap-1.5 text-sm muted hover:text-white transition no-underline cc-noprint">
        <span class="material-symbols-outlined" style="font-size:18px">arrow_back</span>Volver al historial
    </a>

    <div class="page-head">
        <div class="min-w-0">
            <div class="flex items-center gap-2 flex-wrap">
                <h1 class="page-title">Cierre de @Model.NombreCaja</h1>
                @if (!string.IsNullOrWhiteSpace(Model.CodigoCaja))
                {
                    <span class="chip chip-neutral mono">@Model.CodigoCaja</span>
                }
                <span class="chip chip-neutral"><span class="material-symbols-outlined">lock</span>Cerrada</span>
                <span class="chip @difClass"><span class="material-symbols-outlined">@difIcon</span>@difLabel</span>
            </div>
            <p class="page-sub">
                Turno del @Model.FechaApertura.ToString("dd/MM/yyyy")
                · Abrió <strong>@Model.Responsable</strong>
                @if (!string.IsNullOrWhiteSpace(Model.UsuarioCierre))
                {
                    <text> · Cerró <strong>@Model.UsuarioCierre</strong></text>
                }
                @if (Model.FechaCierre.HasValue)
                {
                    <text> · @Model.FechaCierre.Value.ToString("dd/MM/yyyy HH:mm")</text>
                }
            </p>
        </div>
        <div class="head-actions cc-noprint">
            <button type="button" data-caja-print class="btn btn-ghost">
                <span class="material-symbols-outlined">print</span>Imprimir
            </button>
            <a asp-action="DetallesApertura" asp-route-id="@Model.AperturaId" class="btn btn-soft no-underline">
                <span class="material-symbols-outlined">open_in_new</span>Ver apertura original
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-ok cc-noprint" role="status">
            <span class="material-symbols-outlined">check_circle</span><span>@TempData["Success"]</span>
        </div>
    }

    <div class="alert alert-info cc-noprint">
        <span class="material-symbols-outlined">verified</span>
        <div>Cierre auditado y firmado. Este registro es de solo lectura; el conteo físico de abajo es una calculadora de verificación.</div>
    </div>

    <partial name="_ConciliacionCards" model="Model" />
    <partial name="_ConciliacionTabs" model="Model" />

    <div class="cc-print-foot">
        Responsable apertura: @Model.Responsable · Responsable cierre: @Model.UsuarioCierre
        · Cierre: @(Model.FechaCierre?.ToString("dd/MM/yyyy HH:mm") ?? "—") · Impreso @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
    </div>
</div>

@section Styles {
    <partial name="_CajaModuleStyles" />
}

@section Scripts {
    <script src="~/js/caja-conciliacion.js" asp-append-version="true"></script>
}
