@model TheBuryProject.ViewModels.HistorialCierresViewModel
@{
    ViewData["Title"] = "Historial de Cierres";
    var cierres = Model.Cierres ?? new List<TheBuryProject.Models.Entities.CierreCaja>();
    var cajas = ViewBag.Cajas as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var fechaDesde = ViewBag.FechaDesde as DateTime?;
    var fechaHasta = ViewBag.FechaHasta as DateTime?;

    var cierresExactos = Model.TotalCierres - Model.CierresConDiferencia;
    var cierresSobrante = cierres.Count(c => c.Diferencia > 0);
    var cierresFaltante = cierres.Count(c => c.Diferencia < 0);

    var topSobrantes = cierres.Where(c => c.Diferencia > 0).OrderByDescending(c => c.Diferencia).Take(5).ToList();
    var topFaltantes = cierres.Where(c => c.Diferencia < 0).OrderBy(c => c.Diferencia).Take(5).ToList();

    var filtroCajaActivo = ViewBag.CajaId != null || fechaDesde.HasValue || fechaHasta.HasValue;
    var filtroCajaExpanded = ((bool)filtroCajaActivo) ? "true" : "false";
    var filtroCajaHidden   = ((bool)filtroCajaActivo) ? "false" : "true";
}

<div class="caja-page-shell" style="padding-bottom:3rem">

    <!-- Back link -->
    <a asp-action="Index" class="inline-flex items-center gap-1.5 text-sm muted hover:text-white transition" style="text-decoration:none">
        <span class="material-symbols-outlined" style="font-size:18px">arrow_back</span>Volver a cajas
    </a>

    <!-- Page head -->
    <div class="page-head" style="margin-top:.85rem">
        <div class="min-w-0">
            <h1 class="page-title">Historial de cierres</h1>
            <p class="page-sub">Auditá los cierres de caja: diferencias, sobrantes y faltantes por turno.</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-ok" style="margin-top:1rem">
            <span class="material-symbols-outlined">check_circle</span>
            <span>@TempData["Success"]</span>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-bad" style="margin-top:1rem">
            <span class="material-symbols-outlined">error</span>
            <span>@TempData["Error"]</span>
        </div>
    }

    <!-- KPIs -->
    <div class="grid-kpi" style="margin-top:1.5rem">
        <div class="kpi">
            <div class="kpi-label">Cierres del período</div>
            <div class="kpi-value">@Model.TotalCierres</div>
            <div class="kpi-foot">@cierres.Count cierre@(cierres.Count == 1 ? "" : "s") en la consulta</div>
        </div>
        <div class="kpi kpi--ok">
            <div class="kpi-label">Exactitud</div>
            <div class="kpi-value">@Model.PorcentajeCierresExactos.ToString("F0")%</div>
            <div class="kpi-foot">@cierresExactos exacto@(cierresExactos == 1 ? "" : "s")</div>
        </div>
        <div class="kpi kpi--warn">
            <div class="kpi-label">Sobrantes</div>
            <div class="kpi-value">@cierresSobrante</div>
            <div class="kpi-foot">cierre@(cierresSobrante == 1 ? "" : "s") con sobrante</div>
        </div>
        <div class="kpi kpi--bad">
            <div class="kpi-label">Faltantes</div>
            <div class="kpi-value">@cierresFaltante</div>
            <div class="kpi-foot">cierre@(cierresFaltante == 1 ? "" : "s") con faltante</div>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card card-pad" style="margin-top:1.5rem">
        <button type="button"
                id="btn-toggle-filtros"
                data-expanded="@filtroCajaExpanded"
                aria-controls="filtros-body"
                class="flex items-center justify-between w-full"
                style="background:none;border:0;cursor:pointer;color:inherit;font:inherit;padding:0">
            <span class="font-medium text-white flex items-center gap-2">
                <span class="material-symbols-outlined" style="font-size:19px;color:#94a3b8">filter_alt</span>Filtros
            </span>
            <span class="material-symbols-outlined muted filter-panel-erp__toggle-icon">expand_more</span>
        </button>
        <div id="filtros-body" class="filter-panel-erp__body" data-hidden="@filtroCajaHidden" style="margin-top:1rem">
            <form asp-action="Historial" method="get" class="caja-historial-filter-form">
                <div>
                    <label class="label" for="f-caja">Caja</label>
                    <select id="f-caja" name="cajaId" class="field">
                        <option value="">Todas las cajas</option>
                        @if (cajas != null)
                        {
                            @foreach (var item in cajas)
                            {
                                <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                            }
                        }
                    </select>
                </div>
                <div>
                    <label class="label" for="f-desde">Desde</label>
                    <input id="f-desde" type="date" name="fechaDesde"
                           value="@(fechaDesde?.ToString("yyyy-MM-dd"))"
                           class="field" />
                </div>
                <div>
                    <label class="label" for="f-hasta">Hasta</label>
                    <input id="f-hasta" type="date" name="fechaHasta"
                           value="@(fechaHasta?.ToString("yyyy-MM-dd"))"
                           class="field" />
                </div>
                <button type="submit" class="btn btn-primary btn-block">
                    <span class="material-symbols-outlined">search</span>Filtrar
                </button>
                <a asp-action="Historial" class="btn btn-ghost btn-block" style="text-decoration:none">
                    <span class="material-symbols-outlined">backspace</span>Limpiar
                </a>
            </form>
        </div>
    </div>

    <!-- Tabla desktop -->
    <div class="card hide-mobile"
         data-oc-scroll
         style="overflow:hidden;margin-top:1rem;--oc-scroll-min-width:66rem;--oc-scroll-fade-light:rgba(248,250,252,.98);--oc-scroll-fade-dark:rgba(15,23,42,.95)">
        <div data-oc-scroll-hint
             class="caja-page-scroll-hint caja-historial-scroll-hint flex items-center justify-between gap-3 rounded-lg border border-slate-700 bg-slate-800/60 px-3 py-2 text-xs text-slate-300"
             style="margin:.75rem .75rem 0"
             hidden>
            <div class="flex items-center gap-2 font-semibold">
                <span class="material-symbols-outlined text-base text-primary" aria-hidden="true">swipe</span>
                <span id="caja-historial-scroll-hint">Deslizá la tabla para revisar montos, diferencias y acciones</span>
            </div>
            <span class="rounded-full bg-slate-800 px-2 py-1 text-[11px] font-bold uppercase tracking-wide text-slate-400">Scroll horizontal</span>
        </div>
        <div class="relative" data-oc-scroll-shell>
            <div data-oc-scroll-fade="left" class="pointer-events-none absolute inset-y-0 left-0 z-10 w-5" hidden></div>
            <div data-oc-scroll-fade="right" class="pointer-events-none absolute inset-y-0 right-0 z-10 w-8" hidden></div>
            <div class="overflow-x-auto focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/40"
                 data-oc-scroll-region
                 role="region"
                 aria-label="Tabla del historial de cierres"
                 aria-describedby="caja-historial-scroll-hint"
                 tabindex="0">
                @if (cierres.Any())
                {
                    <table data-oc-scroll-table class="tbl">
                        <thead>
                            <tr>
                                <th>Cierre</th>
                                <th>Caja</th>
                                <th>Responsable</th>
                                <th>Fecha cierre</th>
                                <th style="text-align:right">Esperado</th>
                                <th style="text-align:right">Contado</th>
                                <th style="text-align:right">Diferencia</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cierre in cierres)
                            {
                                var cajaNombre = cierre.AperturaCaja?.Caja?.Nombre ?? "—";
                                var userApertura = cierre.AperturaCaja?.UsuarioApertura ?? "—";
                                var userCierre = cierre.UsuarioCierre ?? "—";
                                var dif = cierre.Diferencia;
                                var esSobrante = dif > 0;
                                var esFaltante = dif < 0;
                                var chipClass = esSobrante ? "chip-warn" : (esFaltante ? "chip-bad" : "chip-ok");
                                var difSign = esSobrante ? "+ " : (esFaltante ? "− " : "");
                                <tr>
                                    <td class="mono muted-2">#@cierre.Id</td>
                                    <td style="color:#e2e8f0">@cajaNombre</td>
                                    <td>
                                        <div style="color:#e2e8f0;font-size:.875rem">@userCierre</div>
                                        @if (userApertura != userCierre)
                                        {
                                            <div class="muted-2" style="font-size:.75rem">Apertura: @userApertura</div>
                                        }
                                    </td>
                                    <td class="num muted">@cierre.FechaCierre.ToLocalTime().ToString("dd/MM · HH:mm")</td>
                                    <td class="num" style="text-align:right">$ @cierre.MontoEsperadoSistema.ToString("N2")</td>
                                    <td class="num" style="text-align:right">$ @cierre.MontoTotalReal.ToString("N2")</td>
                                    <td style="text-align:right">
                                        <span class="chip @chipClass num">@difSign$ @Math.Abs(dif).ToString("N2")</span>
                                    </td>
                                    <td style="text-align:right">
                                        <a asp-action="DetallesCierre" asp-route-id="@cierre.Id"
                                           class="btn btn-ghost btn-sm" style="text-decoration:none">Ver detalle</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty">
                        <div class="empty-ic"><span class="material-symbols-outlined">history_toggle_off</span></div>
                        <h3>Sin cierres</h3>
                        <p>No se encontraron cierres en el período seleccionado.</p>
                    </div>
                }
            </div>
        </div>
        @if (cierres.Any())
        {
            <div class="text-xs muted-2 flex items-center justify-between"
                 style="border-top:1px solid #1f2937;padding:.625rem 1rem">
                <span>@cierres.Count cierre@(cierres.Count == 1 ? "" : "s")</span>
            </div>
        }
    </div>

    <!-- Mobile cards -->
    <div class="m-card" style="margin-top:1rem">
        @if (cierres.Any())
        {
            @foreach (var cierre in cierres)
            {
                var cajaNombreM = cierre.AperturaCaja?.Caja?.Nombre ?? "—";
                var difM = cierre.Diferencia;
                var chipClassM = difM > 0 ? "chip-warn" : (difM < 0 ? "chip-bad" : "chip-ok");
                var difSignM = difM > 0 ? "+ " : (difM < 0 ? "− " : "");
                <a asp-action="DetallesCierre" asp-route-id="@cierre.Id"
                   class="card card-pad block" style="text-decoration:none;margin-bottom:.625rem">
                    <div class="flex items-center justify-between">
                        <div>
                            <div style="color:#e2e8f0;font-weight:500">@cajaNombreM</div>
                            <div class="mono muted-2" style="font-size:.75rem">@cierre.FechaCierre.ToLocalTime().ToString("dd/MM · HH:mm")</div>
                        </div>
                        <span class="chip @chipClassM num">@difSignM$ @Math.Abs(difM).ToString("N2")</span>
                    </div>
                    <div class="flex justify-between muted" style="margin-top:.5rem;font-size:.75rem">
                        <span>Esperado $ @cierre.MontoEsperadoSistema.ToString("N2")</span>
                        <span>Contado $ @cierre.MontoTotalReal.ToString("N2")</span>
                    </div>
                </a>
            }
        }
        else
        {
            <div class="empty">
                <div class="empty-ic"><span class="material-symbols-outlined">history_toggle_off</span></div>
                <h3>Sin cierres</h3>
                <p>No se encontraron cierres en el período seleccionado.</p>
            </div>
        }
    </div>

    <!-- Top sobrantes / faltantes -->
    @if (topSobrantes.Any() || topFaltantes.Any())
    {
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4" style="margin-top:1.5rem">
            @if (topSobrantes.Any())
            {
                <div class="card card-pad">
                    <h3 class="font-semibold text-white flex items-center gap-2" style="margin-bottom:.75rem">
                        <span class="material-symbols-outlined" style="color:#fbbf24;font-size:20px">trending_up</span>Top sobrantes
                    </h3>
                    <ol class="space-y-2.5">
                        @foreach (var s in topSobrantes)
                        {
                            <li class="flex items-center justify-between text-sm">
                                <span class="muted">@(s.AperturaCaja?.Caja?.Nombre ?? "—") · @s.UsuarioCierre · @s.FechaCierre.ToLocalTime().ToString("dd/MM")</span>
                                <span class="chip chip-warn num">+ $ @s.Diferencia.ToString("N2")</span>
                            </li>
                        }
                    </ol>
                </div>
            }
            @if (topFaltantes.Any())
            {
                <div class="card card-pad">
                    <h3 class="font-semibold text-white flex items-center gap-2" style="margin-bottom:.75rem">
                        <span class="material-symbols-outlined" style="color:#fb7185;font-size:20px">trending_down</span>Top faltantes
                    </h3>
                    <ol class="space-y-2.5">
                        @foreach (var f in topFaltantes)
                        {
                            <li class="flex items-center justify-between text-sm">
                                <span class="muted">@(f.AperturaCaja?.Caja?.Nombre ?? "—") · @f.UsuarioCierre · @f.FechaCierre.ToLocalTime().ToString("dd/MM")</span>
                                <span class="chip chip-bad num">− $ @Math.Abs(f.Diferencia).ToString("N2")</span>
                            </li>
                        }
                    </ol>
                </div>
            }
        </div>
    }

</div>

@section Styles {
    <partial name="_CajaModuleStyles" />
}

@section Scripts {
    <script src="~/js/module-index.js" asp-append-version="true"></script>
    <script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
    <script src="~/js/caja-historial.js" asp-append-version="true"></script>
}
