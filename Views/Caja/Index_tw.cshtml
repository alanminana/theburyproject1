@model TheBuryProject.ViewModels.CajasListViewModel
@using TheBuryProject.Models.Enums

@{
    ViewData["Title"] = "Cajas";
    ViewData["MetaDescription"] = "Administración de cajas, aperturas, cierres y movimientos de efectivo del ERP TheBuryProject.";

    var abiertas = Model.AperturasAbiertas?.ToList() ?? new List<TheBuryProject.Models.Entities.AperturaCaja>();
    var activas = Model.CajasActivas?.ToList() ?? new List<TheBuryProject.Models.Entities.Caja>();
    var inactivas = Model.CajasInactivas?.ToList() ?? new List<TheBuryProject.Models.Entities.Caja>();

    var currentUser = ViewBag.CurrentUser as string ?? User.Identity?.Name ?? "";
    var esAdmin = (bool)(ViewBag.EsAdmin ?? false);

    var aperturasMostradas = esAdmin
        ? abiertas
        : abiertas.Where(a => a.UsuarioApertura == currentUser).ToList();

    var cajasDisponibles = activas.Count(c => c.Estado != EstadoCaja.Abierta);
    var cajasEnUso = activas.Count(c => c.Estado == EstadoCaja.Abierta);

    var saldoTurnos = aperturasMostradas.Sum(a =>
    {
        var movs = a.Movimientos?.Where(m => !m.IsDeleted).ToList()
            ?? new List<TheBuryProject.Models.Entities.MovimientoCaja>();
        return a.MontoInicial
            + movs.Where(m => m.Tipo == TipoMovimientoCaja.Ingreso).Sum(m => m.Monto)
            - movs.Where(m => m.Tipo == TipoMovimientoCaja.Egreso).Sum(m => m.Monto);
    });
}

<div class="caja-index-shell flex min-h-full items-start gap-0">
    <div id="cajaMainContent" class="caja-page-shell flex-1 min-w-0 space-y-8">

        <!-- Page header -->
        <div class="page-head">
            <div class="min-w-0">
                <h1 class="page-title">Cajas</h1>
                <p class="page-sub">Operá los turnos abiertos, gestioná tus cajas y revisá el historial de cierres.</p>
            </div>
            <div class="head-actions">
                <a asp-action="Historial" class="btn btn-ghost no-underline">
                    <span class="material-symbols-outlined">history</span>Historial de cierres
                </a>
                @if (esAdmin)
                {
                    <button type="button" data-caja-open-create class="btn btn-primary">
                        <span class="material-symbols-outlined">add</span>Nueva caja
                    </button>
                }
            </div>
        </div>

        <!-- Feedback slot -->
        <div id="caja-index-feedback-slot" class="space-y-3" aria-live="polite"></div>

        @if (TempData["Success"] != null)
        {
            <div class="toast-msg alert-erp alert-erp-success" role="status">
                <span class="material-symbols-outlined" aria-hidden="true">check_circle</span>
                @TempData["Success"]
            </div>
        }
        @if (TempData["Warning"] != null)
        {
            <div class="toast-msg alert-erp alert-erp-warning" role="alert">
                <span class="material-symbols-outlined" aria-hidden="true">warning</span>
                @TempData["Warning"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="toast-msg alert-erp alert-erp-error" role="alert">
                <span class="material-symbols-outlined" aria-hidden="true">error</span>
                @TempData["Error"]
            </div>
        }

        <!-- KPIs -->
        <div class="grid-kpi">
            <div class="kpi kpi--ok">
                <div class="kpi-label"><span class="material-symbols-outlined" style="font-size:15px">lock_open</span>Turnos abiertos</div>
                <div class="kpi-value">@aperturasMostradas.Count</div>
                <div class="kpi-foot">de @activas.Count cajas activas</div>
            </div>
            <div class="kpi kpi--accent">
                <div class="kpi-label"><span class="material-symbols-outlined" style="font-size:15px">payments</span>Efectivo esperado</div>
                <div class="kpi-value">$@saldoTurnos.ToString("N2")</div>
                <div class="kpi-foot">suma de turnos en curso</div>
            </div>
            <div class="kpi">
                <div class="kpi-label"><span class="material-symbols-outlined" style="font-size:15px">pending_actions</span>Cajas en uso</div>
                <div class="kpi-value">@cajasEnUso</div>
                <div class="kpi-foot">con turno activo</div>
            </div>
            <div class="kpi">
                <div class="kpi-label"><span class="material-symbols-outlined" style="font-size:15px">inventory_2</span>Cajas disponibles</div>
                <div class="kpi-value">@cajasDisponibles</div>
                <div class="kpi-foot">listas para abrir turno</div>
            </div>
        </div>

        <!-- ===== Turnos abiertos ===== -->
        <section>
            <div class="flex items-center justify-between gap-3 mb-3">
                <div class="flex items-center gap-2">
                    <h2 class="text-base font-semibold text-white">@(esAdmin ? "Cajas abiertas ahora" : "Mi caja abierta")</h2>
                    @if (aperturasMostradas.Any())
                    {
                        <span class="chip chip-live"><span class="dot"></span>En vivo</span>
                    }
                </div>
            </div>

            @if (aperturasMostradas.Any())
            {
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
                    @foreach (var apertura in aperturasMostradas)
                    {
                        var movs = apertura.Movimientos?.Where(m => !m.IsDeleted).ToList()
                            ?? new List<TheBuryProject.Models.Entities.MovimientoCaja>();
                        var totalIngresos = movs.Where(m => m.Tipo == TipoMovimientoCaja.Ingreso).Sum(m => m.Monto);
                        var totalEgresos = movs.Where(m => m.Tipo == TipoMovimientoCaja.Egreso).Sum(m => m.Monto);
                        var saldoActual = apertura.MontoInicial + totalIngresos - totalEgresos;
                        var esPropietario = apertura.UsuarioApertura == currentUser;

                        <article class="card card-pad">
                            <div class="flex items-start justify-between gap-3">
                                <div class="min-w-0">
                                    <div class="flex items-center gap-2 flex-wrap">
                                        <h3 class="font-semibold text-white">@(apertura.Caja?.Nombre ?? "—")</h3>
                                        @if (!string.IsNullOrWhiteSpace(apertura.Caja?.Codigo))
                                        {
                                            <span class="chip mono chip-neutral">@apertura.Caja.Codigo</span>
                                        }
                                    </div>
                                    <div class="mt-1 text-xs muted flex items-center gap-1.5">
                                        <span class="material-symbols-outlined" style="font-size:14px">person</span>
                                        @apertura.UsuarioApertura · abierta @apertura.FechaApertura.ToString("HH:mm")
                                    </div>
                                </div>
                                <span class="chip chip-ok"><span class="material-symbols-outlined">lock_open</span>Abierta</span>
                            </div>
                            <div class="mt-4 grid grid-cols-3 gap-2">
                                <div class="card-2 p-2.5">
                                    <div class="text-[.68rem] uppercase tracking-wide muted-2 font-semibold">Fondo</div>
                                    <div class="mt-0.5 text-sm font-semibold text-white num">$@apertura.MontoInicial.ToString("N2")</div>
                                </div>
                                <div class="card-2 p-2.5">
                                    <div class="text-[.68rem] uppercase tracking-wide muted-2 font-semibold">Ingresos</div>
                                    <div class="mt-0.5 text-sm font-semibold text-emerald-400 num">$@totalIngresos.ToString("N2")</div>
                                </div>
                                <div class="card-2 p-2.5">
                                    <div class="text-[.68rem] uppercase tracking-wide muted-2 font-semibold">Esperado</div>
                                    <div class="mt-0.5 text-sm font-semibold text-white num">$@saldoActual.ToString("N2")</div>
                                </div>
                            </div>
                            @if (esAdmin || esPropietario)
                            {
                                <div class="mt-4 flex flex-wrap gap-2">
                                    <a asp-action="DetallesApertura" asp-route-id="@apertura.Id"
                                       class="btn btn-soft btn-sm no-underline">
                                        <span class="material-symbols-outlined">visibility</span>Ver turno
                                    </a>
                                    <a asp-action="RegistrarMovimiento" asp-route-aperturaId="@apertura.Id"
                                       class="btn btn-soft btn-sm no-underline">
                                        <span class="material-symbols-outlined">add_card</span>Movimiento
                                    </a>
                                    <a asp-action="Cerrar" asp-route-aperturaId="@apertura.Id"
                                       class="btn btn-primary btn-sm no-underline" style="margin-left:auto">
                                        <span class="material-symbols-outlined">lock</span>Cerrar caja
                                    </a>
                                </div>
                            }
                        </article>
                    }
                </div>
            }
            else
            {
                <div class="card p-8 text-center caja-empty-state">
                    <span class="material-symbols-outlined text-4xl text-slate-500" aria-hidden="true">point_of_sale</span>
                    @if (esAdmin)
                    {
                        <p class="mt-2 text-sm text-slate-500">No hay cajas abiertas en este momento.</p>
                        <a asp-action="Abrir" class="mt-4 btn btn-soft btn-sm no-underline">
                            <span class="material-symbols-outlined">lock_open</span>Abrir una caja
                        </a>
                    }
                    else
                    {
                        <p class="mt-2 text-sm text-slate-500">No tiene ninguna caja abierta a su nombre.</p>
                        <p class="mt-1 text-xs text-slate-400">Seleccione una caja disponible y ábrala para operar.</p>
                    }
                </div>
            }
        </section>

        <!-- ===== Tus cajas ===== -->
        @if (activas.Any() || inactivas.Any())
        {
            <section>
                <div class="flex items-end justify-between gap-3 mb-3 flex-wrap">
                    <h2 class="text-base font-semibold text-white">Tus cajas</h2>
                    <div class="flex gap-1.5 flex-wrap" role="tablist" aria-label="Filtrar cajas">
                        <button class="btn btn-soft btn-sm filter-tab" data-filter="all" aria-pressed="true">
                            Todas <span class="muted-2">@(activas.Count + inactivas.Count)</span>
                        </button>
                        @if (cajasDisponibles > 0)
                        {
                            <button class="btn btn-ghost btn-sm filter-tab" data-filter="disp" aria-pressed="false">
                                Disponibles <span class="muted-2">@cajasDisponibles</span>
                            </button>
                        }
                        @if (cajasEnUso > 0)
                        {
                            <button class="btn btn-ghost btn-sm filter-tab" data-filter="uso" aria-pressed="false">
                                En uso <span class="muted-2">@cajasEnUso</span>
                            </button>
                        }
                        @if (inactivas.Any())
                        {
                            <button class="btn btn-ghost btn-sm filter-tab" data-filter="arch" aria-pressed="false">
                                Archivadas <span class="muted-2">@inactivas.Count</span>
                            </button>
                        }
                    </div>
                </div>

                <!-- Desktop table -->
                <div class="card hide-mobile" style="overflow:hidden">
                    <div class="tbl-wrap">
                        <table class="tbl">
                            <thead>
                                <tr>
                                    <th>Caja</th>
                                    <th>Ubicación</th>
                                    <th>Estado</th>
                                    <th style="text-align:right">Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="cajas-activas-tbody">
                                @foreach (var caja in activas)
                                {
                                    var estaAbierta = caja.Estado == EstadoCaja.Abierta;
                                    var aperturaActiva = abiertas.FirstOrDefault(a => a.CajaId == caja.Id);
                                    var esMiApertura = aperturaActiva?.UsuarioApertura == currentUser;
                                    var rowState = estaAbierta ? "uso" : "disp";

                                    <tr data-caja-row-id="@caja.Id" data-state="@rowState"
                                        class="transition-colors hover:bg-slate-800/30">
                                        <td>
                                            <div class="font-medium text-white">@caja.Nombre</div>
                                            <div class="mono text-xs muted-2">@caja.Codigo</div>
                                        </td>
                                        <td class="muted">
                                            @(caja.Sucursal ?? "—")@(!string.IsNullOrEmpty(caja.Ubicacion) ? " · " + caja.Ubicacion : "")
                                        </td>
                                        <td>
                                            @if (estaAbierta)
                                            {
                                                <span class="chip chip-info"><span class="material-symbols-outlined">bolt</span>En uso</span>
                                            }
                                            else
                                            {
                                                <span class="chip chip-ok">Disponible</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="row-actions">
                                                @if (estaAbierta)
                                                {
                                                    @if (aperturaActiva != null && (esAdmin || esMiApertura))
                                                    {
                                                        <a asp-action="DetallesApertura" asp-route-id="@aperturaActiva.Id"
                                                           class="btn btn-soft btn-sm no-underline" title="Ver apertura activa">
                                                            <span class="material-symbols-outlined">visibility</span>Ver turno
                                                        </a>
                                                    }
                                                    else if (!esAdmin)
                                                    {
                                                        <span class="text-xs font-medium text-amber-500">En uso</span>
                                                    }
                                                    @if (esAdmin)
                                                    {
                                                        <button type="button" data-caja-open-edit data-caja-id="@caja.Id"
                                                                class="btn btn-ghost btn-sm" aria-label="Editar"
                                                                aria-disabled="true" style="opacity:.45;pointer-events:none">
                                                            <span class="material-symbols-outlined">edit</span>
                                                        </button>
                                                    }
                                                }
                                                else
                                                {
                                                    <a asp-action="Abrir" asp-route-cajaId="@caja.Id"
                                                       class="btn btn-primary btn-sm no-underline">
                                                        <span class="material-symbols-outlined">lock_open</span>Abrir
                                                    </a>
                                                    @if (esAdmin)
                                                    {
                                                        <button type="button" data-caja-open-edit data-caja-id="@caja.Id"
                                                                class="btn btn-ghost btn-sm" aria-label="Editar">
                                                            <span class="material-symbols-outlined">edit</span>
                                                        </button>
                                                        <form asp-action="Delete" method="post" class="inline-flex"
                                                              data-caja-delete-form
                                                              data-confirm-message="¿Está seguro de eliminar esta caja?">
                                                            <input type="hidden" name="id" value="@caja.Id" />
                                                            <input type="hidden" name="rowVersion"
                                                                   value="@Convert.ToBase64String(caja.RowVersion)" />
                                                            <button type="submit" class="btn btn-ghost btn-sm"
                                                                    aria-label="Eliminar">
                                                                <span class="material-symbols-outlined"
                                                                      style="color:#fb7185">delete</span>
                                                            </button>
                                                        </form>
                                                    }
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            @if (inactivas.Any())
                            {
                                <tbody id="cajas-inactivas-tbody">
                                    @foreach (var caja in inactivas)
                                    {
                                        <tr data-state="arch" class="transition-colors hover:bg-slate-800/30" hidden>
                                            <td>
                                                <div class="font-medium text-slate-400">@caja.Nombre</div>
                                                <div class="mono text-xs muted-2">@caja.Codigo</div>
                                            </td>
                                            <td class="muted">@(caja.Sucursal ?? "— archivada")</td>
                                            <td><span class="chip chip-neutral">Archivada</span></td>
                                            <td>
                                                <div class="row-actions">
                                                    <button type="button" data-caja-open-edit data-caja-id="@caja.Id"
                                                            class="btn btn-ghost btn-sm" title="Reactivar / Editar">
                                                        <span class="material-symbols-outlined">restore_from_trash</span>Reactivar
                                                    </button>
                                                    <form asp-action="Delete" method="post" class="inline-flex"
                                                          data-caja-delete-form
                                                          data-confirm-message="¿Eliminar permanentemente esta caja inactiva?">
                                                        <input type="hidden" name="id" value="@caja.Id" />
                                                        <input type="hidden" name="rowVersion"
                                                               value="@Convert.ToBase64String(caja.RowVersion)" />
                                                        <button type="submit" class="btn btn-ghost btn-sm"
                                                                aria-label="Eliminar permanentemente">
                                                            <span class="material-symbols-outlined"
                                                                  style="color:#fb7185">delete</span>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            }
                        </table>
                    </div>
                </div>

                <!-- Mobile cards -->
                <div class="m-card space-y-2.5" id="cajas-m-cards">
                    @foreach (var caja in activas)
                    {
                        var estaAbiertaM = caja.Estado == EstadoCaja.Abierta;
                        var aperturaActivaM = abiertas.FirstOrDefault(a => a.CajaId == caja.Id);
                        var esMiAperturaM = aperturaActivaM?.UsuarioApertura == currentUser;
                        var rowStateM = estaAbiertaM ? "uso" : "disp";

                        <article class="card card-pad" data-state="@rowStateM">
                            <div class="flex items-center justify-between gap-2">
                                <div>
                                    <div class="font-medium text-white">@caja.Nombre</div>
                                    <div class="mono text-xs muted-2">@caja.Codigo · @(caja.Sucursal ?? "—")</div>
                                </div>
                                @if (estaAbiertaM)
                                {
                                    <span class="chip chip-info"><span class="material-symbols-outlined">bolt</span>En uso</span>
                                }
                                else
                                {
                                    <span class="chip chip-ok">Disponible</span>
                                }
                            </div>
                            <div class="mt-3 flex gap-2">
                                @if (estaAbiertaM && aperturaActivaM != null && (esAdmin || esMiAperturaM))
                                {
                                    <a asp-action="DetallesApertura" asp-route-id="@aperturaActivaM.Id"
                                       class="btn btn-soft btn-sm btn-block no-underline">
                                        <span class="material-symbols-outlined">visibility</span>Ver turno
                                    </a>
                                }
                                else if (!estaAbiertaM)
                                {
                                    <a asp-action="Abrir" asp-route-cajaId="@caja.Id"
                                       class="btn btn-primary btn-sm btn-block no-underline">
                                        <span class="material-symbols-outlined">lock_open</span>Abrir
                                    </a>
                                }
                                @if (esAdmin)
                                {
                                    <button type="button" data-caja-open-edit data-caja-id="@caja.Id"
                                            class="btn btn-ghost btn-sm" aria-label="Editar">
                                        <span class="material-symbols-outlined">edit</span>
                                    </button>
                                }
                            </div>
                        </article>
                    }
                    @foreach (var caja in inactivas)
                    {
                        <article class="card card-pad" data-state="arch" hidden>
                            <div class="flex items-center justify-between gap-2">
                                <div>
                                    <div class="font-medium text-slate-400">@caja.Nombre</div>
                                    <div class="mono text-xs muted-2">@caja.Codigo · archivada</div>
                                </div>
                                <span class="chip chip-neutral">Archivada</span>
                            </div>
                            <div class="mt-3 flex gap-2">
                                <button type="button" data-caja-open-edit data-caja-id="@caja.Id"
                                        class="btn btn-ghost btn-sm btn-block">
                                    <span class="material-symbols-outlined">restart_alt</span>Reactivar
                                </button>
                            </div>
                        </article>
                    }
                </div>
            </section>
        }
        else
        {
            <div class="card p-8 text-center caja-empty-state">
                <span class="material-symbols-outlined text-4xl text-slate-500" aria-hidden="true">inventory</span>
                <p class="mt-2 text-sm text-slate-500">No hay cajas activas configuradas.</p>
            </div>
        }

    </div>

    <!-- Panel acoplable Crear / Editar Caja -->
    <div id="modalCajaContainer" class="shrink-0"></div>
</div>

@section Styles {
    <partial name="_CajaModuleStyles" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
    <script src="~/js/caja-index.js" asp-append-version="true"></script>
}
