@model TheBuryProject.ViewModels.CajasListViewModel
@using TheBuryProject.Models.Enums
@{
    ViewData["Title"] = "Módulo de Cajas";
    ViewData["MetaDescription"] = "Administración de cajas, aperturas, cierres y movimientos de efectivo del ERP TheBuryProject.";
    var abiertas = Model.AperturasAbiertas?.ToList() ?? new List<TheBuryProject.Models.Entities.AperturaCaja>();
    var activas = Model.CajasActivas?.ToList() ?? new List<TheBuryProject.Models.Entities.Caja>();
    var inactivas = Model.CajasInactivas?.ToList() ?? new List<TheBuryProject.Models.Entities.Caja>();
    var currentUser = ViewBag.CurrentUser as string ?? User.Identity?.Name ?? "";
    var esAdmin = (bool)(ViewBag.EsAdmin ?? false);
    var aperturasMostradas = esAdmin
        ? abiertas
        : abiertas.Where(a => a.UsuarioApertura == currentUser).ToList();
    var cajasDisponibles = activas.Count(c => c.Estado != EstadoCaja.Abierta);
    var cajasEnUso = activas.Count(c => c.Estado == EstadoCaja.Abierta);
}

<div class="caja-index-shell flex min-h-full items-start gap-0">
<div id="cajaMainContent" class="caja-page-shell flex-1 min-w-0 space-y-8">

    <div class="flex flex-wrap items-center gap-3">
        <h1 class="text-base font-black text-white flex-1">Módulo de Cajas</h1>
        <a asp-action="Historial" class="btn-erp-secondary btn-sm no-underline">
            <span class="material-symbols-outlined text-[16px]">history</span>
            Historial de cierres
        </a>
        @if (esAdmin)
        {
            <button type="button" data-caja-open-create class="btn-erp-primary btn-sm">
                <span class="material-symbols-outlined text-[16px]">add_circle</span>
                Nueva caja
            </button>
        }
    </div>

    <!-- TempData Alerts -->
    <div id="caja-index-feedback-slot" class="space-y-3" aria-live="polite"></div>
    @if (TempData["Success"] != null)
    {
        <div class="toast-msg flex items-center gap-3 rounded-xl border border-emerald-500/20 bg-emerald-500/10 p-4 text-sm font-semibold text-emerald-400" role="status">
            <span class="material-symbols-outlined">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Warning"] != null)
    {
        <div class="toast-msg flex items-center gap-3 rounded-xl border border-amber-500/20 bg-amber-500/10 p-4 text-sm font-semibold text-amber-400" role="alert">
            <span class="material-symbols-outlined">warning</span>
            @TempData["Warning"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="toast-msg flex items-center gap-3 rounded-xl border border-rose-500/20 bg-rose-500/10 p-4 text-sm font-semibold text-rose-400" role="alert">
            <span class="material-symbols-outlined">error</span>
            @TempData["Error"]
        </div>
    }
    <!-- ═══════════════════════════════════════════════════ -->
    <!-- Cajas Abiertas (Aperturas activas) -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="space-y-4">
        <div class="caja-page-section-header caja-index-section-header">
            <div class="space-y-2">
                <div class="flex flex-wrap items-center gap-2">
                    <span class="material-symbols-outlined text-primary">sensors</span>
                    <h2 class="text-lg font-bold text-white">
                        @(esAdmin ? "Cajas actualmente abiertas" : "Mi caja abierta")
                    </h2>
                    <span class="px-2 py-0.5 rounded bg-primary/20 text-primary text-[10px] font-bold uppercase tracking-wider">En vivo</span>
                </div>
                <p class="text-sm text-slate-400">
                    Turnos en curso con accesos rápidos para registrar movimientos, revisar actividad y cerrar caja.
                </p>
            </div>
            <div class="caja-index-section-badge inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-900/60 px-3 py-2 text-xs font-semibold text-slate-300">
                <span class="material-symbols-outlined text-sm text-primary">monitoring</span>
                @aperturasMostradas.Count @(aperturasMostradas.Count == 1 ? "apertura visible" : "aperturas visibles")
            </div>
        </div>

        @if (aperturasMostradas.Any())
        {
            <div class="card-erp-panel p-4"
                 data-oc-scroll
                 style="--oc-scroll-min-width: 70rem; --oc-scroll-fade-light: rgba(248, 250, 252, 0.98); --oc-scroll-fade-dark: rgba(15, 23, 42, 0.95);">
                <div data-oc-scroll-hint
                 class="caja-page-scroll-hint caja-index-scroll-hint mb-3 flex items-center justify-between gap-3 rounded-lg border border-slate-700 bg-slate-800/60 px-3 py-2 text-xs text-slate-300"
                     hidden>
                    <div class="flex items-center gap-2 font-semibold">
                        <span class="material-symbols-outlined text-base text-primary" aria-hidden="true">swipe</span>
                        <span id="caja-scroll-hint-abiertas">Deslizá la tabla para ver más columnas y acciones</span>
                    </div>
                    <span class="rounded-full bg-slate-800 px-2 py-1 text-[11px] font-bold uppercase tracking-wide text-slate-400">
                        Scroll horizontal
                    </span>
                </div>

                <div class="relative" data-oc-scroll-shell>
                    <div data-oc-scroll-fade="left"
                         class="pointer-events-none absolute inset-y-0 left-0 z-10 w-5"
                         hidden></div>
                    <div data-oc-scroll-fade="right"
                         class="pointer-events-none absolute inset-y-0 right-0 z-10 w-8"
                         hidden></div>

                    <div class="overflow-x-auto rounded-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/40 focus-visible:ring-offset-2 focus-visible:ring-offset-slate-50 dark:focus-visible:ring-offset-background-dark"
                         data-oc-scroll-region
                         role="region"
                         aria-label="Tabla de cajas abiertas"
                         aria-describedby="caja-scroll-hint-abiertas"
                         tabindex="0">
                        <table data-oc-scroll-table class="w-full text-left border-collapse">
                            <thead class="bg-slate-800/50">
                                <tr>
                                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider whitespace-nowrap">Caja / Código</th>
                                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider whitespace-nowrap">Usuario Apertura</th>
                                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider whitespace-nowrap">Fecha / Hora</th>
                                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider whitespace-nowrap">Fondo inicial</th>
                                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider whitespace-nowrap">Movimientos</th>
                                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider whitespace-nowrap">
                                        <span class="flex items-center gap-1">
                                            Saldo en caja
                                            <span class="material-symbols-outlined text-[13px] text-slate-400" title="Efectivo físico esperado: fondo inicial + ingresos (efectivo, tarjeta, cheque, cobros de cuota) − egresos. No incluye ventas a crédito personal ni cuenta corriente.">info</span>
                                        </span>
                                    </th>
                                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider text-right whitespace-nowrap">Acciones</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-800">
                                @foreach (var apertura in aperturasMostradas)
                                {
                                    var movs = apertura.Movimientos ?? new List<TheBuryProject.Models.Entities.MovimientoCaja>();
                                    var cantMov = movs.Count(m => !m.IsDeleted);
                                    var totalIngresos = movs.Where(m => !m.IsDeleted && m.Tipo == TipoMovimientoCaja.Ingreso).Sum(m => m.Monto);
                                    var totalEgresos = movs.Where(m => !m.IsDeleted && m.Tipo == TipoMovimientoCaja.Egreso).Sum(m => m.Monto);
                                    var saldoActual = apertura.MontoInicial + totalIngresos - totalEgresos;
                                    var esPropietario = apertura.UsuarioApertura == currentUser;

                                    <tr class="hover:bg-slate-800/30 transition-colors">
                                        <td class="px-6 py-4">
                                            <div class="flex flex-col">
                                                <span class="text-sm font-bold text-white">@(apertura.Caja?.Nombre ?? "—")</span>
                                                <span class="text-xs text-slate-400">@(apertura.Caja?.Codigo ?? "—")</span>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <div class="flex items-center gap-2">
                                                <div class="size-6 rounded-full bg-primary/20 flex items-center justify-center">
                                                    <span class="material-symbols-outlined text-primary text-xs">person</span>
                                                </div>
                                                <span class="text-sm text-slate-300">@apertura.UsuarioApertura</span>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <div class="flex flex-col">
                                                <span class="text-sm text-slate-300">@apertura.FechaApertura.ToString("dd/MM/yyyy")</span>
                                                <span class="text-xs text-slate-400">@apertura.FechaApertura.ToString("HH:mm") hs</span>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <span class="font-mono text-sm text-slate-400">@apertura.MontoInicial.ToString("C2")</span>
                                        </td>
                                        <td class="px-6 py-4">
                                            <div class="flex flex-col gap-1">
                                                <span class="px-2 py-0.5 rounded-full bg-slate-800 text-xs font-bold text-slate-400 w-fit">
                                                    @cantMov @(cantMov == 1 ? "movimiento" : "movimientos")
                                                </span>
                                                @if (totalIngresos > 0 || totalEgresos > 0)
                                                {
                                                    <div class="flex items-center gap-2 text-[11px]">
                                                        @if (totalIngresos > 0)
                                                        {
                                                            <span class="text-emerald-500 font-semibold">+@totalIngresos.ToString("C2")</span>
                                                        }
                                                        @if (totalEgresos > 0)
                                                        {
                                                            <span class="text-rose-400 font-semibold">−@totalEgresos.ToString("C2")</span>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <div class="flex flex-col gap-0.5">
                                                <span class="font-mono text-base font-black @(saldoActual >= apertura.MontoInicial ? "text-emerald-500" : "text-amber-400")">
                                                    @saldoActual.ToString("C2")
                                                </span>
                                                <span class="text-[10px] text-slate-400 uppercase tracking-wide">Solo efectivo físico</span>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 text-right">
                                            @if (esAdmin || esPropietario)
                                            {
                                                <div class="flex min-w-max flex-wrap items-center justify-end gap-2">
                                                    <a asp-action="DetallesApertura" asp-route-id="@apertura.Id"
                                                       class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg bg-slate-800 hover:bg-primary/10 text-slate-300 hover:text-primary text-xs font-bold border border-slate-700 transition-colors no-underline"
                                                       title="Ver movimientos y operaciones">
                                                        <span class="material-symbols-outlined text-base">list_alt</span>
                                                        <span class="caja-index-action-label">Ver movimientos</span>
                                                    </a>
                                                    <a asp-action="RegistrarMovimiento" asp-route-aperturaId="@apertura.Id"
                                                       class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg bg-primary/10 text-primary text-xs font-bold border border-primary/20 hover:bg-primary hover:text-white transition-colors no-underline"
                                                       title="Registrar movimiento">
                                                        <span class="material-symbols-outlined text-base">add_card</span>
                                                        <span class="caja-index-action-label">Movimiento</span>
                                                    </a>
                                                    <a asp-action="Cerrar" asp-route-aperturaId="@apertura.Id"
                                                       class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg bg-rose-500/10 text-rose-500 text-xs font-bold border border-rose-500/20 hover:bg-rose-500 hover:text-white transition-colors no-underline">
                                                        <span class="material-symbols-outlined text-base">lock</span>
                                                        <span class="caja-index-action-label">Cerrar caja</span>
                                                    </a>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-xs text-slate-400 italic">Sin acceso</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="card-erp-panel p-8 text-center">
                <span class="material-symbols-outlined text-4xl text-slate-300 text-slate-600">point_of_sale</span>
                @if (esAdmin)
                {
                    <p class="text-sm text-slate-500 mt-2">No hay cajas abiertas en este momento.</p>
                    <a asp-action="Abrir"
                       class="inline-flex items-center gap-2 mt-4 px-4 py-2 rounded-lg bg-primary/10 text-primary text-xs font-bold hover:bg-primary/20 transition-colors no-underline">
                        <span class="material-symbols-outlined text-sm">lock_open</span> Abrir una caja
                    </a>
                }
                else
                {
                    <p class="text-sm text-slate-500 mt-2">No tiene ninguna caja abierta a su nombre.</p>
                    <p class="text-xs text-slate-400 mt-1">Seleccione una caja disponible en el maestro y ábrala para operar.</p>
                }
            </div>
        }
    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- Maestro de Cajas Activas -->
    <!-- ═══════════════════════════════════════════════════ -->
    <section class="space-y-4">
        <div class="caja-page-section-header caja-index-section-header">
            <div class="space-y-2">
                <div class="flex flex-wrap items-center gap-2">
                    <span class="material-symbols-outlined text-primary">point_of_sale</span>
                    <h2 class="text-lg font-bold text-white">Maestro de Cajas Activas</h2>
                </div>
                <p class="text-sm text-slate-400">
                    Terminales disponibles para apertura, con acceso a la apertura activa o a su gestión administrativa.
                </p>
            </div>
            <div class="caja-index-section-badge inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-900/60 px-3 py-2 text-xs font-semibold text-slate-300">
                <span class="material-symbols-outlined text-sm text-primary">inventory_2</span>
                @activas.Count activas · @cajasDisponibles listas para abrir
            </div>
        </div>

        @if (activas.Any())
        {
            <div class="card-erp-panel p-4"
                 data-oc-scroll
                 style="--oc-scroll-min-width: 52rem; --oc-scroll-fade-light: rgba(248, 250, 252, 0.98); --oc-scroll-fade-dark: rgba(15, 23, 42, 0.95);">
                <div data-oc-scroll-hint
                 class="caja-page-scroll-hint caja-index-scroll-hint mb-3 flex items-center justify-between gap-3 rounded-lg border border-slate-700 bg-slate-800/60 px-3 py-2 text-xs text-slate-300"
                     hidden>
                    <div class="flex items-center gap-2 font-semibold">
                        <span class="material-symbols-outlined text-base text-primary" aria-hidden="true">swipe</span>
                        <span id="caja-scroll-hint-activas">Deslizá la tabla para ver estados y acciones</span>
                    </div>
                    <span class="rounded-full bg-slate-800 px-2 py-1 text-[11px] font-bold uppercase tracking-wide text-slate-400">
                        Scroll horizontal
                    </span>
                </div>

                <div class="relative" data-oc-scroll-shell>
                    <div data-oc-scroll-fade="left"
                         class="pointer-events-none absolute inset-y-0 left-0 z-10 w-5"
                         hidden></div>
                    <div data-oc-scroll-fade="right"
                         class="pointer-events-none absolute inset-y-0 right-0 z-10 w-8"
                         hidden></div>

                    <div class="overflow-x-auto rounded-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/40 focus-visible:ring-offset-2 focus-visible:ring-offset-slate-50 dark:focus-visible:ring-offset-background-dark"
                         data-oc-scroll-region
                         role="region"
                         aria-label="Tabla del maestro de cajas activas"
                         aria-describedby="caja-scroll-hint-activas"
                         tabindex="0">
                        <table data-oc-scroll-table class="w-full text-left border-collapse">
                            <thead class="bg-slate-800/50">
                                <tr>
                                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider whitespace-nowrap">Código</th>
                                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider whitespace-nowrap">Nombre de Caja</th>
                                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider whitespace-nowrap">Sucursal / Ubicación</th>
                                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider whitespace-nowrap">Estado</th>
                                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider text-right whitespace-nowrap">Gestión</th>
                                </tr>
                            </thead>
                            <tbody id="cajas-activas-tbody" class="divide-y divide-slate-800">
                                @foreach (var caja in activas)
                                {
                                    var estaAbierta = caja.Estado == EstadoCaja.Abierta;
                                    var aperturaActiva = abiertas.FirstOrDefault(a => a.CajaId == caja.Id);
                                    var esMiApertura = aperturaActiva?.UsuarioApertura == currentUser;
                                    <tr data-caja-row-id="@caja.Id" class="hover:bg-slate-800/30 transition-colors">
                                        <td class="px-6 py-4 text-sm font-mono text-slate-500">@caja.Codigo</td>
                                        <td class="px-6 py-4 text-sm font-bold text-white">@caja.Nombre</td>
                                        <td class="px-6 py-4">
                                            <div class="flex flex-col">
                                                <span class="text-sm text-slate-300">@(caja.Sucursal ?? "—")</span>
                                                @if (!string.IsNullOrEmpty(caja.Ubicacion))
                                                {
                                                    <span class="text-xs text-slate-400">@caja.Ubicacion</span>
                                                }
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            @if (estaAbierta)
                                            {
                                                <div class="flex items-center gap-2 text-emerald-500">
                                                    <span class="size-2 rounded-full bg-emerald-500 animate-pulse"></span>
                                                    <span class="text-xs font-bold uppercase">Abierta</span>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="flex items-center gap-2 text-slate-400">
                                                    <span class="size-2 rounded-full bg-slate-400"></span>
                                                    <span class="text-xs font-bold uppercase">Cerrada</span>
                                                </div>
                                            }
                                        </td>
                                        <td class="px-6 py-4 text-right">
                                            <div class="flex min-w-max flex-wrap items-center justify-end gap-2">
                                                @if (estaAbierta)
                                                {
                                                    @if (aperturaActiva != null && (esAdmin || esMiApertura))
                                                    {
                                                        <a asp-action="DetallesApertura" asp-route-id="@aperturaActiva.Id"
                                                           class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg bg-slate-800 text-slate-300 text-xs font-bold border border-slate-700 hover:bg-primary/10 hover:text-primary transition-colors no-underline"
                                                           title="Ver apertura activa">
                                                            <span class="material-symbols-outlined text-base">open_in_new</span>
                                                            <span class="caja-index-action-label">Ver apertura</span>
                                                        </a>
                                                    }
                                                    else if (!esAdmin)
                                                    {
                                                        <span class="text-xs text-amber-500 font-medium px-2">En uso</span>
                                                    }
                                                }
                                                else
                                                {
                                                    <a asp-action="Abrir" asp-route-cajaId="@caja.Id"
                                                       class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg bg-primary text-white text-xs font-bold hover:opacity-90 transition-colors no-underline">
                                                        <span class="material-symbols-outlined text-base">lock_open</span>
                                                        <span class="caja-index-action-label">Abrir caja</span>
                                                    </a>
                                                }
                                                @if (esAdmin)
                                                {
                                                    <button type="button"
                                                            data-caja-open-edit
                                                            data-caja-id="@caja.Id"
                                                            class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg bg-slate-900/70 text-slate-300 text-xs font-bold border border-slate-700 hover:bg-slate-800 transition-colors"
                                                            title="Editar">
                                                        <span class="material-symbols-outlined text-base">edit</span>
                                                        <span class="caja-index-action-label">Editar</span>
                                                    </button>
                                                    @if (!estaAbierta)
                                                    {
                                                        <form asp-action="Delete"
                                                              method="post"
                                                              class="inline-flex"
                                                              data-caja-delete-form
                                                              data-confirm-message="¿Está seguro de eliminar esta caja?">
                                                            <input type="hidden" name="id" value="@caja.Id" />
                                                            <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(caja.RowVersion)" />
                                                            <button type="submit"
                                                                    class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg bg-rose-500/10 text-rose-500 text-xs font-bold border border-rose-500/20 hover:bg-rose-500 hover:text-white transition-colors"
                                                                    title="Eliminar">
                                                                <span class="material-symbols-outlined text-base">delete</span>
                                                                <span class="caja-index-action-label">Eliminar</span>
                                                            </button>
                                                        </form>
                                                    }
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="card-erp-panel p-8 text-center">
                <span class="material-symbols-outlined text-4xl text-slate-300 text-slate-600">inventory</span>
                <p class="text-sm text-slate-500 mt-2">No hay cajas activas configuradas.</p>
            </div>
        }
    </section>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- Cajas Inactivas / Depreciadas -->
    <!-- ═══════════════════════════════════════════════════ -->
    @if (inactivas.Any())
    {
        <section class="space-y-4">
            <div class="caja-page-section-header caja-index-section-header">
                <div class="space-y-2">
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-slate-500">archive</span>
                        <h2 class="text-lg font-bold text-slate-400">Cajas Inactivas / Depreciadas</h2>
                    </div>
                    <p class="text-sm text-slate-400">
                        Historial de cajas archivadas con acceso a reactivación o eliminación definitiva.
                    </p>
                </div>
                <div class="caja-index-section-badge inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-900/60 px-3 py-2 text-xs font-semibold text-slate-300">
                    <span class="material-symbols-outlined text-sm text-slate-500">inventory</span>
                    @inactivas.Count @(inactivas.Count == 1 ? "caja archivada" : "cajas archivadas")
                </div>
            </div>
            <div class="card-erp-panel p-4 opacity-80"
                 data-oc-scroll
                 style="--oc-scroll-min-width: 46rem; --oc-scroll-fade-light: rgba(248, 250, 252, 0.98); --oc-scroll-fade-dark: rgba(15, 23, 42, 0.95);">
                <div data-oc-scroll-hint
                     class="caja-index-scroll-hint mb-3 flex items-center justify-between gap-3 rounded-lg border border-slate-700 bg-slate-800/60 px-3 py-2 text-xs text-slate-300"
                     hidden>
                    <div class="flex items-center gap-2 font-semibold">
                        <span class="material-symbols-outlined text-base text-primary" aria-hidden="true">swipe</span>
                        <span id="caja-scroll-hint-inactivas">Deslizá la tabla para ver la gestión de cajas archivadas</span>
                    </div>
                    <span class="rounded-full bg-slate-800 px-2 py-1 text-[11px] font-bold uppercase tracking-wide text-slate-400">
                        Scroll horizontal
                    </span>
                </div>

                <div class="relative" data-oc-scroll-shell>
                    <div data-oc-scroll-fade="left"
                         class="pointer-events-none absolute inset-y-0 left-0 z-10 w-5"
                         hidden></div>
                    <div data-oc-scroll-fade="right"
                         class="pointer-events-none absolute inset-y-0 right-0 z-10 w-8"
                         hidden></div>

                    <div class="overflow-x-auto rounded-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/40 focus-visible:ring-offset-2 focus-visible:ring-offset-slate-50 dark:focus-visible:ring-offset-background-dark"
                         data-oc-scroll-region
                         role="region"
                         aria-label="Tabla de cajas inactivas"
                         aria-describedby="caja-scroll-hint-inactivas"
                         tabindex="0">
                        <table data-oc-scroll-table class="w-full text-left border-collapse">
                            <thead class="bg-slate-800/50">
                                <tr>
                                    <th class="px-6 py-3 text-xs font-bold text-slate-400 uppercase tracking-wider whitespace-nowrap">Código</th>
                                    <th class="px-6 py-3 text-xs font-bold text-slate-400 uppercase tracking-wider whitespace-nowrap">Nombre</th>
                                    <th class="px-6 py-3 text-xs font-bold text-slate-400 uppercase tracking-wider whitespace-nowrap">Antigua Sucursal</th>
                                    <th class="px-6 py-3 text-xs font-bold text-slate-400 uppercase tracking-wider text-right whitespace-nowrap">Acciones</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-800">
                                @foreach (var caja in inactivas)
                                {
                                    <tr class="hover:bg-slate-800/30 transition-colors">
                                        <td class="px-6 py-3 text-sm font-mono text-slate-400 italic line-through">@caja.Codigo</td>
                                        <td class="px-6 py-3 text-sm text-slate-500">@caja.Nombre</td>
                                        <td class="px-6 py-3 text-sm text-slate-500">@(caja.Sucursal ?? "—")</td>
                                        <td class="px-6 py-3 text-right">
                                            <div class="flex min-w-max flex-wrap items-center justify-end gap-2">
                                                <button type="button"
                                                        data-caja-open-edit
                                                        data-caja-id="@caja.Id"
                                                        class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg bg-slate-900/70 text-slate-300 text-xs font-bold border border-slate-700 hover:bg-slate-800 transition-colors"
                                                        title="Reactivar / Editar">
                                                    <span class="material-symbols-outlined text-base">restore_from_trash</span>
                                                    <span class="caja-index-action-label">Reactivar</span>
                                                </button>
                                                <form asp-action="Delete"
                                                      method="post"
                                                      class="inline-flex"
                                                      data-caja-delete-form
                                                      data-confirm-message="¿Eliminar permanentemente esta caja inactiva?">
                                                    <input type="hidden" name="id" value="@caja.Id" />
                                                    <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(caja.RowVersion)" />
                                                    <button type="submit"
                                                            class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg bg-rose-500/10 text-rose-500 text-xs font-bold border border-rose-500/20 hover:bg-rose-500 hover:text-white transition-colors"
                                                            title="Eliminar permanentemente">
                                                        <span class="material-symbols-outlined text-base">delete_forever</span>
                                                        <span class="caja-index-action-label">Eliminar</span>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </section>
    }
</div>
<!-- Panel acoplable Crear / Editar Caja -->
<div id="modalCajaContainer" class="shrink-0"></div>
</div>

@section Styles {
    <partial name="_CajaModuleStyles" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
    <script src="~/js/caja-index.js" asp-append-version="true"></script>
}
