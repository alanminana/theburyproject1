@model TheBuryProject.ViewModels.MovimientoCajaViewModel
@using TheBuryProject.Models.Enums
@{
    ViewData["Title"] = "Registrar Movimiento";
    var esEgreso = Model.Tipo == TipoMovimientoCaja.Egreso;
    var saldoActualValue = Model.SaldoActual ?? 0m;
    var saldoActual = Model.SaldoActual.HasValue ? $"$ {Model.SaldoActual.Value:N2}" : "No disponible";
}

<div class="caja-page-shell space-y-4">
    <a asp-action="DetallesApertura" asp-route-id="@Model.AperturaCajaId" class="inline-flex items-center gap-1.5 text-sm muted hover:text-white transition no-underline">
        <span class="material-symbols-outlined" style="font-size:18px">arrow_back</span>Volver al turno
    </a>

    <div class="page-head">
        <div class="min-w-0">
            <h1 class="page-title">Registrar movimiento</h1>
            <p class="page-sub">Sumá un ingreso o egreso de efectivo al turno abierto de <strong>@(Model.CajaNombre ?? "Caja")</strong>.</p>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div id="toast-error" class="flex items-center gap-3 bg-rose-500/10 border border-rose-500/20 text-rose-400 px-5 py-3 rounded-xl text-sm font-medium" role="alert">
            <span class="material-symbols-outlined text-lg">error</span>@TempData["Error"]
        </div>
    }

    <div asp-validation-summary="ModelOnly" class="rounded-xl border border-rose-500/20 bg-rose-500/10 px-4 py-3 text-sm text-rose-400 empty:hidden" role="alert"></div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
        <form asp-action="RegistrarMovimiento" method="post" class="lg:col-span-2 card card-pad">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="AperturaCajaId" />
            <input type="hidden" asp-for="Tipo" id="input-tipo" />
            <input type="hidden" asp-for="Observaciones" />

            <label class="label">Tipo de movimiento <span class="req">*</span></label>
            <div id="tipo-toggle" class="segment" role="group" aria-label="Tipo de movimiento">
                <button type="button" data-tipo="0" data-tone="in" aria-pressed="@((!esEgreso).ToString().ToLowerInvariant())" class="tipo-btn">
                    <span class="material-symbols-outlined">south_west</span>Ingreso
                </button>
                <button type="button" data-tipo="1" data-tone="out" aria-pressed="@(esEgreso.ToString().ToLowerInvariant())" class="tipo-btn">
                    <span class="material-symbols-outlined">north_east</span>Egreso
                </button>
            </div>
            <p id="tipo-help" class="text-sm muted mt-2">
                @(esEgreso ? "Los egresos descuentan saldo de la caja y requieren mayor claridad en la justificación." : "Los ingresos suman saldo a la caja y deben quedar correctamente documentados.")
            </p>
            <span asp-validation-for="Tipo" class="text-rose-500 text-xs"></span>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4" style="margin-top:1.25rem">
                <div>
                    <label asp-for="Concepto" class="label">Concepto <span class="req">*</span></label>
                    <select asp-for="Concepto" id="select-concepto" data-initial-value="@((int)Model.Concepto)" class="field" required></select>
                    <span asp-validation-for="Concepto" class="text-rose-500 text-xs"></span>
                </div>
                <div>
                    <label asp-for="Monto" class="label">Monto <span class="req">*</span></label>
                    <div class="field-money">
                        <span class="cur">$</span>
                        <input asp-for="Monto" type="number" step="0.01" placeholder="0.00" required class="field" />
                    </div>
                    <span asp-validation-for="Monto" class="text-rose-500 text-xs"></span>
                </div>
            </div>

            <div style="margin-top:1rem">
                <label asp-for="Referencia" class="label">Referencia <span class="muted-2 font-normal">(comprobante, recibo, factura)</span></label>
                <input asp-for="Referencia" type="text" placeholder="Ej. FAC-A-0099 / REC-222" class="field" />
            </div>

            <div style="margin-top:1rem">
                <label asp-for="Descripcion" class="label">Descripción <span class="muted-2 font-normal">(opcional)</span></label>
                <textarea asp-for="Descripcion" rows="2" required placeholder="Detalle del movimiento para la trazabilidad del turno." class="field"></textarea>
                <span asp-validation-for="Descripcion" class="text-rose-500 text-xs"></span>
            </div>

            <div class="mt-5 pt-4 flex flex-col-reverse sm:flex-row justify-end gap-2" style="border-top:1px solid var(--line)">
                <a asp-action="DetallesApertura" asp-route-id="@Model.AperturaCajaId" class="btn btn-ghost no-underline">Cancelar</a>
                <button type="submit" class="btn btn-primary" id="submit-btn">
                    <span class="material-symbols-outlined">check</span>Registrar @(esEgreso ? "egreso" : "ingreso")
                </button>
            </div>
        </form>

        <aside class="space-y-4">
            <div class="card card-pad" id="impact-card">
                <div class="flex items-center gap-2 mb-3">
                    <span class="material-symbols-outlined" id="impact-icon" style="color:@(esEgreso ? "#fb7185" : "#34d399");font-size:20px">@(esEgreso ? "trending_down" : "trending_up")</span>
                    <h3 class="font-semibold text-white">Impacto en la caja</h3>
                </div>
                <dl>
                    <div class="defrow"><dt>Efectivo esperado actual</dt><dd class="num" id="impact-base" data-value="@saldoActualValue.ToString(System.Globalization.CultureInfo.InvariantCulture)">@saldoActual</dd></div>
                    <div class="defrow"><dt id="impact-label">@(esEgreso ? "Este egreso" : "Este ingreso")</dt><dd class="num" id="impact-delta" style="color:@(esEgreso ? "#fb7185" : "#34d399")">$ 0,00</dd></div>
                    <div class="defrow"><dt class="font-medium" style="color:#e2e8f0">Nuevo esperado</dt><dd class="num font-semibold text-white" id="impact-total">@saldoActual</dd></div>
                </dl>
            </div>

            <div class="card card-pad">
                <div class="flex items-center gap-2 mb-3">
                    <span class="material-symbols-outlined" style="color:#f5c518;font-size:20px">tips_and_updates</span>
                    <h3 class="font-semibold text-white">Buenas prácticas</h3>
                </div>
                <ul class="help-list">
                    <li><span class="material-symbols-outlined">receipt_long</span>Cargá siempre la referencia del comprobante: facilita el arqueo.</li>
                    <li><span class="material-symbols-outlined">bolt</span>Los egresos disminuyen el efectivo esperado del cierre.</li>
                </ul>
            </div>

            <div class="alert alert-ok">
                <span class="material-symbols-outlined">verified_user</span>
                <div>Transacción segura. El movimiento queda firmado con tu usuario y la hora exacta.</div>
            </div>

            @* hidden como atributo: caja-registrar-movimiento.js reescribe className y borraría la clase "hidden". *@
            <span id="tipo-card-label" hidden>@(esEgreso ? "Egreso" : "Ingreso")</span>
            <span id="tipo-card-copy" hidden></span>
            <span id="tipo-panel-badge" hidden>@(esEgreso ? "Egreso" : "Ingreso")</span>
            <span id="tipo-panel-title" hidden></span>
            <span id="tipo-panel-copy" hidden></span>
        </aside>
    </div>
</div>

@section Styles {
    <partial name="_CajaModuleStyles" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/caja-registrar-movimiento.js" asp-append-version="true"></script>
}
