@model TheBuryProject.ViewModels.CajaViewModel

<div id="modal-caja" class="lg:h-full">
    <!-- Backdrop (solo mobile) -->
    <div id="modal-caja-backdrop" class="fixed inset-0 z-50 bg-black/60 backdrop-blur-sm lg:hidden hidden opacity-0 transition-opacity duration-300"></div>

    <!-- Panel -->
    <div id="modal-caja-panel" class="fixed top-0 right-0 z-50 h-full w-full max-w-lg lg:sticky lg:top-0 lg:z-auto lg:h-auto lg:w-[28rem] lg:max-w-none lg:max-h-[calc(100vh-4rem)] bg-slate-900 rounded-l-2xl lg:rounded-2xl border-l lg:border border-slate-800 shadow-2xl flex flex-col translate-x-full lg:translate-x-0 transition-transform duration-300 ease-out">

        <!-- Header -->
        <div class="flex items-center justify-between p-6 border-b border-slate-800 shrink-0">
            <div>
                <h3 class="text-xl font-extrabold text-white">Editar caja</h3>
                <p class="text-xs text-slate-400 mt-1">Terminal <span class="font-semibold text-slate-200 mono">@Model.Codigo</span></p>
            </div>
            <button type="button" data-caja-close-modal aria-label="Cerrar"
                    class="p-1.5 rounded-lg hover:bg-slate-800 text-slate-400 hover:text-slate-200 transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <!-- Body -->
        <form id="formCaja" asp-action="Edit" asp-route-id="@Model.Id" method="post" class="flex flex-col flex-1 overflow-hidden">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="RowVersion" />
            <input type="hidden" asp-for="Estado" />

            <div id="modal-caja-errors" class="hidden mx-6 mt-4 p-3 rounded-lg bg-rose-500/10 border border-rose-500/20 text-rose-500 text-sm" role="alert"></div>

            <div class="p-6 overflow-y-auto flex-1 space-y-5">
                <div class="grid grid-cols-2 gap-2.5">
                    <div class="kpi">
                        <div class="kpi-label">Código</div>
                        <div class="text-base font-semibold text-white mt-1 mono">@(string.IsNullOrWhiteSpace(Model.Codigo) ? "—" : Model.Codigo)</div>
                    </div>
                    <div class="kpi">
                        <div class="kpi-label">Nombre</div>
                        <div class="text-base font-semibold text-white mt-1">@(string.IsNullOrWhiteSpace(Model.Nombre) ? "Sin nombre" : Model.Nombre)</div>
                    </div>
                    <div class="kpi">
                        <div class="kpi-label">Estado</div>
                        <div class="text-base font-semibold mt-1" style="color:@(Model.Activa ? "#34d399" : "#94a3b8")">@(Model.Activa ? "Activa" : "Inactiva")</div>
                    </div>
                    <div class="kpi">
                        <div class="kpi-label">Ubicación</div>
                        <div class="text-base font-semibold text-white mt-1">@(string.IsNullOrWhiteSpace(Model.Ubicacion) ? "—" : Model.Ubicacion)</div>
                    </div>
                </div>

                <!-- Código + Nombre -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label asp-for="Codigo" class="label">Código <span class="req">*</span></label>
                        <div class="field-icon">
                            <span class="material-symbols-outlined">tag</span>
                            <input asp-for="Codigo" type="text" placeholder="Ej: C01-HQ" required class="field mono" />
                        </div>
                        <span asp-validation-for="Codigo" class="text-rose-500 text-xs"></span>
                    </div>
                    <div>
                        <label asp-for="Nombre" class="label">Nombre <span class="req">*</span></label>
                        <div class="field-icon">
                            <span class="material-symbols-outlined">point_of_sale</span>
                            <input asp-for="Nombre" type="text" placeholder="Ej: Caja Principal 01" required class="field" />
                        </div>
                        <span asp-validation-for="Nombre" class="text-rose-500 text-xs"></span>
                    </div>
                </div>

                <!-- Sucursal + Ubicación -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label asp-for="Sucursal" class="label">Sucursal</label>
                        <div class="field-icon">
                            <span class="material-symbols-outlined">store</span>
                            <input asp-for="Sucursal" type="text" placeholder="Ej: Casa Central" class="field" />
                        </div>
                    </div>
                    <div>
                        <label asp-for="Ubicacion" class="label">Ubicación</label>
                        <div class="field-icon">
                            <span class="material-symbols-outlined">location_on</span>
                            <input asp-for="Ubicacion" type="text" placeholder="Ej: Planta baja - Zona A" class="field" />
                        </div>
                    </div>
                </div>

                <!-- Descripción -->
                <div>
                    <label asp-for="Descripcion" class="label">Descripción</label>
                    <textarea asp-for="Descripcion" rows="2"
                              placeholder="Detalles adicionales sobre esta terminal de caja..."
                              class="field"></textarea>
                </div>

                <!-- Activa -->
                <div class="card-2 p-3 flex items-center justify-between gap-3">
                    <div>
                        <div class="text-sm font-semibold text-slate-300">Caja activa</div>
                        <div class="text-xs muted-2">Disponible para apertura y operaciones</div>
                    </div>
                    <label class="caja-switch">
                        <input asp-for="Activa" type="checkbox" />
                        <span class="caja-switch-track"></span>
                    </label>
                </div>

                <div class="card card-pad">
                    <div class="flex items-center gap-2 mb-3">
                        <span class="material-symbols-outlined" style="color:#f5c518;font-size:20px">tips_and_updates</span>
                        <h3 class="font-semibold text-white">Buenas prácticas</h3>
                    </div>
                    <ul class="help-list">
                        <li><span class="material-symbols-outlined">tag</span>Mantené el código estable si la caja ya tiene historial.</li>
                        <li><span class="material-symbols-outlined">store</span>Actualizá sucursal y ubicación cuando cambie el punto físico.</li>
                        <li><span class="material-symbols-outlined">archive</span>Desactivá la caja para pausarla sin perder trazabilidad.</li>
                    </ul>
                </div>

                <div class="alert alert-info">
                    <span class="material-symbols-outlined">info</span>
                    <div>Editar datos de caja no modifica aperturas, cierres ni movimientos ya registrados.</div>
                </div>
            </div>

            <!-- Footer -->
            <div class="flex gap-3 p-6 border-t border-slate-800 shrink-0 justify-end">
                <button type="button" data-caja-close-modal class="btn btn-ghost">Cancelar</button>
                <button type="submit" id="btnGuardarCaja" class="btn btn-primary">
                    <span class="material-symbols-outlined">save</span>Guardar cambios
                </button>
            </div>
        </form>
    </div>
</div>
