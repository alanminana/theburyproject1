@model CatalogoUnificadoViewModel
@{
    ViewData["Title"] = "Inventario";
    ViewData["MetaDescription"] = "Catálogo de productos, control de stock, listas de precios y movimientos de inventario del ERP TheBuryProject.";
    var productos = Model.Productos.ToList();
    var total = Model.TotalResultados;
    var stockBajoCount = Model.ProductosStockBajo;
    var productosActivos = productos.Count(p => p.Activo);
    var productosInactivos = productos.Count - productosActivos;
    var categoriasActivas = Model.CategoriasListado.Count(c => c.Activo);
    var marcasActivas = Model.MarcasListado.Count(m => m.Activo);
}

@section Styles {
    <link rel="stylesheet" href="~/css/horizontal-scroll-affordance.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/catalogo-module.css" asp-append-version="true" />
}


<!-- TempData Alerts -->
@if (TempData["Success"] != null)
{
    <div class="toast-msg flex items-center gap-3 rounded-xl border border-emerald-500/20 bg-emerald-500/10 p-4 text-sm font-semibold text-emerald-400" role="status">
        <span class="material-symbols-outlined">check_circle</span>
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="toast-msg flex items-center gap-3 rounded-xl border border-red-500/20 bg-red-500/10 p-4 text-sm font-semibold text-red-400" role="alert">
        <span class="material-symbols-outlined">error</span>
        @TempData["Error"]
    </div>
}

<!-- Main Card with Tabs -->
<div class="card-erp-panel overflow-hidden">

    <!-- Tab Bar + Actions -->
    <div class="flex flex-col gap-4 border-b border-slate-800 bg-slate-800/20 px-4 py-4 xl:flex-row xl:items-center xl:justify-between">
        <div class="flex overflow-x-auto" id="catalogo-tabs">
            <button type="button" data-catalogo-tab="productos"
                    class="shrink-0 px-5 py-3 text-sm font-bold border-b-2 border-primary text-primary bg-primary/10 transition-colors">
                Productos
            </button>
            <button type="button" data-catalogo-tab="categorias"
                    class="shrink-0 px-5 py-3 text-sm font-bold border-b-2 border-transparent text-slate-400 hover:text-white hover:bg-white/5 transition-colors">
                Categorías
                <span class="ml-1 text-xs text-slate-400">(@Model.TotalCategorias)</span>
            </button>
            <button type="button" data-catalogo-tab="marcas"
                    class="shrink-0 px-5 py-3 text-sm font-bold border-b-2 border-transparent text-slate-400 hover:text-white hover:bg-white/5 transition-colors">
                Marcas
                <span class="ml-1 text-xs text-slate-400">(@Model.TotalMarcas)</span>
            </button>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center xl:justify-end">
            <button type="button" id="btn-movimientos-inventario" class="btn-erp-ghost btn-sm sm:w-auto">
                <span class="material-symbols-outlined text-sm">swap_vert</span>
                Movimientos
            </button>
            <button type="button" id="btn-ajuste-masivo" data-catalogo-modal-open="precio"
                    class="btn-erp-secondary btn-sm sm:w-auto">
                <span class="material-symbols-outlined text-sm">edit_calendar</span>
                <span id="btn-ajuste-masivo-label">Ajuste Masivo</span>
                <span id="btn-ajuste-masivo-badge" class="hidden items-center justify-center min-w-5 h-5 px-1.5 rounded-full bg-amber-500 text-white text-[10px] font-black">
                    <span id="btn-ajuste-masivo-count">0</span>
                </span>
            </button>
            <div id="catalogo-selection-chip" class="hidden items-center gap-2 rounded-full border border-amber-500/20 bg-amber-500/10 px-3 py-1 text-[11px] font-bold text-amber-400">
                <span class="material-symbols-outlined text-[14px]">checklist</span>
                <span><span id="catalogo-selection-chip-count">0</span> seleccionados</span>
            </div>
        </div>
    </div>

    <!-- Tab: Productos -->
    <div id="tab-productos">
        <div class="border-b border-slate-800 px-5 py-4">
            <div class="flex flex-col gap-2 lg:flex-row lg:items-center lg:justify-between">
                <div>
                    <h2 class="text-base font-bold text-white">Productos del catálogo</h2>
                    <p class="text-sm text-slate-400">
                        Filtrá, seleccioná productos y lanzá ajustes masivos desde la misma grilla.
                    </p>
                </div>
                <div class="flex items-center gap-3">
                    <span class="inline-flex items-center rounded-full bg-slate-800 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.16em] text-slate-300">
                        <span id="productos-visible-count">@productos.Count</span>&nbsp;visibles
                    </span>
                    <button type="button" id="btn-crear-producto" data-catalogo-modal-open="producto"
                            class="btn-erp-primary btn-sm">
                        <span class="material-symbols-outlined text-sm">add</span>
                        Nuevo Producto
                    </button>
                </div>
            </div>
        </div>

        <!-- Filters -->
        <form id="filterForm" method="get" asp-controller="Catalogo" asp-action="Index"
              class="border-b border-slate-800 bg-slate-900/30 p-4">
            <div class="flex flex-wrap items-end gap-4">
                <div class="flex-1 min-w-[200px]">
                    <label class="text-slate-400 text-[10px] font-bold mb-1.5 block uppercase tracking-wider">Buscar Producto</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg">search</span>
                        <input id="catalogo-search-input" name="searchTerm" value="@Model.SearchTerm" type="text"
                               aria-label="Buscar producto por nombre o código"
                               class="w-full bg-slate-800 border-none rounded-lg pl-10 pr-4 py-2 text-sm focus:ring-2 focus:ring-primary/50 transition-colors text-white placeholder:text-slate-500"
                               placeholder="Nombre o código..." autocomplete="off" />
                    </div>
                </div>
                <div class="w-48">
                    <label class="text-slate-400 text-[10px] font-bold mb-1.5 block uppercase tracking-wider">Categoría</label>
                    <select id="catalogo-select-categoria" name="categoriaId"
                            aria-label="Categoría"
                            class="w-full bg-slate-800 border-none rounded-lg px-4 py-2 text-sm focus:ring-2 focus:ring-primary/50 transition-colors text-white">
                        <option value="">Todas</option>
                        @if (Model.CategoriasFiltro != null)
                        {
                            @foreach (var cat in Model.CategoriasFiltro)
                            {
                                <option value="@cat.Value" selected="@(cat.Selected ? "selected" : null)">@cat.Text</option>
                            }
                        }
                    </select>
                </div>
                <div class="w-48">
                    <label class="text-slate-400 text-[10px] font-bold mb-1.5 block uppercase tracking-wider">Marca</label>
                    <select id="catalogo-select-marca" name="marcaId"
                            aria-label="Marca"
                            class="w-full bg-slate-800 border-none rounded-lg px-4 py-2 text-sm focus:ring-2 focus:ring-primary/50 transition-colors text-white">
                        <option value="">Todas</option>
                        @if (Model.MarcasFiltro != null)
                        {
                            @foreach (var marca in Model.MarcasFiltro)
                            {
                                <option value="@marca.Value" selected="@(marca.Selected ? "selected" : null)">@marca.Text</option>
                            }
                        }
                    </select>
                </div>
                <div class="w-48">
                    <label class="text-slate-400 text-[10px] font-bold mb-1.5 block uppercase tracking-wider">Estado Stock</label>
                    <select id="catalogo-select-stock" name="stockBajo"
                            aria-label="Estado de stock"
                            class="w-full bg-slate-800 border-none rounded-lg px-4 py-2 text-sm focus:ring-2 focus:ring-primary/50 transition-colors text-white">
                        <option value="false" selected="@(!Model.StockBajo ? "selected" : null)">Cualquiera</option>
                        <option value="true" selected="@(Model.StockBajo ? "selected" : null)">Stock Bajo</option>
                    </select>
                </div>
                @if (Model.ListasPreciosFiltro != null && Model.ListasPreciosFiltro.Any())
                {
                    <div class="w-48">
                        <label class="text-slate-400 text-[10px] font-bold mb-1.5 block uppercase tracking-wider">Lista Precios</label>
                        <select id="catalogo-select-listaprecio" name="listaPrecioId"
                                aria-label="Lista de precios"
                                class="w-full bg-slate-800 border-none rounded-lg px-4 py-2 text-sm focus:ring-2 focus:ring-primary/50 transition-colors text-white">
                            <option value="">Predeterminada</option>
                            @foreach (var lp in Model.ListasPreciosFiltro)
                            {
                                <option value="@lp.Value" selected="@(lp.Selected ? "selected" : null)">@lp.Text</option>
                            }
                        </select>
                    </div>
                }
                <div class="flex gap-2">
                    <button type="submit"
                            class="p-2.5 bg-primary/10 text-primary hover:bg-primary hover:text-white rounded-lg transition-colors"
                            title="Filtrar">
                        <span class="material-symbols-outlined text-lg">filter_list</span>
                    </button>
                    @if (Model.TieneFiltrosActivos)
                    {
                        <a asp-controller="Catalogo" asp-action="Index"
                           class="p-2.5 bg-slate-200 bg-slate-800 text-slate-300 hover:bg-slate-300 hover:bg-slate-700 rounded-lg transition-colors no-underline"
                           title="Limpiar filtros">
                            <span class="material-symbols-outlined text-lg">clear_all</span>
                        </a>
                    }
                </div>
            </div>
        </form>

        <!-- Products Table -->
        <div data-oc-scroll class="relative" style="--oc-scroll-min-width: 1120px;">
            <div data-oc-scroll-hint hidden class="px-5 pt-4 text-xs font-semibold uppercase tracking-[0.16em] text-slate-400 lg:hidden">
                Deslizá la tabla para ver stock, precios y acciones.
            </div>
            <div data-oc-scroll-shell class="relative">
                <div data-oc-scroll-fade="left" hidden class="absolute inset-y-0 left-0 z-10 w-6 bg-gradient-to-r from-slate-900 via-slate-900/95 to-transparent"></div>
                <div data-oc-scroll-fade="right" hidden class="absolute inset-y-0 right-0 z-10 w-6 bg-gradient-to-l from-slate-900 via-slate-900/95 to-transparent"></div>
                <div data-oc-scroll-region class="overflow-x-auto scroll-smooth" tabindex="0" role="region" aria-label="Tabla de productos del catálogo">
            <table class="w-full text-left border-collapse" data-oc-scroll-table style="min-width: var(--oc-scroll-min-width);">
                <thead>
                    <tr class="bg-slate-800/30 border-b border-slate-800">
                        <th class="w-10 px-3 py-4">
                            <input type="checkbox" id="chk-select-all"
                                   class="rounded border-slate-600 text-primary focus:ring-primary cursor-pointer"
                                   aria-label="Seleccionar todos los productos" />
                        </th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Código</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Producto</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Categoría</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Marca</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400 text-center">Stock</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Precio vigente</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400 text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody id="productos-tbody" class="divide-y divide-slate-800">
                    @if (productos.Any())
                    {
                        @foreach (var p in productos)
                        {
                            // Stock badge — colors match mockup
                            string stockBg, stockText;
                            switch (p.EstadoStock)
                            {
                                case "Sin Stock":
                                    stockBg = "bg-red-500/20 text-red-400 border border-red-500/30";
                                    stockText = "Agotado";
                                    break;
                                case "Stock Bajo":
                                    stockBg = "bg-orange-500/20 text-orange-400 border border-orange-500/30";
                                    stockText = $"{p.StockActual:G29} Unid.";
                                    break;
                                default:
                                    stockBg = "bg-green-500/20 text-green-400 border border-green-500/30";
                                    stockText = $"{p.StockActual:G29} Unid.";
                                    break;
                            }
                            string searchData = string.Join(" ", new[] { p.Codigo ?? "", p.Nombre ?? "", p.Descripcion ?? "", p.CategoriaNombre ?? "", p.MarcaNombre ?? "" }).ToLowerInvariant().Trim();

                            <tr class="hover:bg-white/5 transition-colors @(!p.Activo ? "opacity-50" : "")"
                                data-catalogo-producto-id="@p.ProductoId"
                                data-producto-codigo="@p.Codigo"
                                data-producto-nombre="@p.Nombre"
                                data-search="@searchData">
                                <td class="w-10 px-3 py-4">
                                    <input type="checkbox" class="chk-producto rounded border-slate-600 text-primary focus:ring-primary cursor-pointer"
                                           value="@p.ProductoId"
                                           aria-label="Seleccionar @p.Nombre" />
                                </td>
                                <td class="px-6 py-4 text-sm font-mono text-slate-400">@p.Codigo</td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded bg-slate-800 flex items-center justify-center overflow-hidden flex-shrink-0">
                                            <span class="material-symbols-outlined text-slate-400 text-lg">package_2</span>
                                        </div>
                                        <div>
                                            <span class="text-sm font-semibold text-white">@p.Nombre</span>
                                            @if (!string.IsNullOrEmpty(p.Descripcion))
                                            {
                                                <p class="text-[10px] text-slate-400 truncate max-w-[200px]">@p.Descripcion</p>
                                            }
                                            @if (!p.Activo)
                                            {
                                                <span class="text-[10px] font-bold text-red-400">Inactivo</span>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-sm text-slate-300">@(p.CategoriaNombre ?? "—")</td>
                                <td class="px-6 py-4 text-sm text-slate-300">@(p.MarcaNombre ?? "—")</td>
                                <td class="px-6 py-4 text-center">
                                    <span class="inline-flex items-center px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider @stockBg">
                                        @stockText
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    <p class="text-sm font-bold text-white">$ @p.PrecioActual.ToString("N2")</p>
                                    @if (p.TienePrecioLista)
                                    {
                                        <p data-prod-precio-label class="text-[10px] text-slate-400">Vigente por lista: @p.ListaPrecioActualNombre</p>
                                        <p data-prod-precio-base-label class="text-[10px] text-slate-500">Base/fallback: $ @p.PrecioBase.ToString("N2")</p>
                                    }
                                    else
                                    {
                                        <p data-prod-precio-label class="text-[10px] text-slate-400">Base/fallback</p>
                                    }
                                    @if (p.MargenPorcentaje > 0)
                                    {
                                        <p data-prod-margen class="text-[10px] text-emerald-400">+@p.MargenPorcentaje.ToString("N1")% margen</p>
                                    }
                                    <p class="text-[10px] text-slate-400">
                                        Comisión vendedor:
                                        @if (p.ComisionPorcentaje > 0)
                                        {
                                            <span data-producto-comision>@p.ComisionPorcentaje.ToString("N2")%</span>
                                        }
                                        else
                                        {
                                            <span data-producto-comision>Sin comisión</span>
                                        }
                                    </p>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex flex-wrap justify-end gap-2">
                                        <button type="button" data-catalogo-modal-open="historial-precio" data-catalogo-producto-id="@p.ProductoId"
                                                class="row-action row-action--primary" title="Historial de precio">
                                            <span class="material-symbols-outlined">history</span>
                                            <span class="row-action__label">Historial</span>
                                        </button>
                                        <button type="button"
                                                data-comision-producto-id="@p.ProductoId"
                                                data-comision-producto-nombre="@p.Nombre"
                                                data-comision-porcentaje="@p.ComisionPorcentaje.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                class="row-action row-action--primary"
                                                title="Comisión vendedor: @p.ComisionPorcentaje.ToString("N2")%">
                                            <span class="material-symbols-outlined">percent</span>
                                            <span class="row-action__label">Comisión</span>
                                        </button>
                                        <button type="button"
                                                data-condiciones-pago-producto-id="@p.ProductoId"
                                                data-condiciones-pago-producto-nombre="@p.Nombre"
                                                class="row-action row-action--primary"
                                                title="Condiciones de pago">
                                            <span class="material-symbols-outlined">payments</span>
                                            <span class="row-action__label">Condiciones de pago</span>
                                        </button>
                                        <button type="button" data-prod-edit-id="@p.ProductoId"
                                                class="inline-flex items-center gap-1.5 rounded-lg border border-slate-700 px-2.5 py-1.5 text-xs font-semibold text-slate-300 transition-colors hover:border-slate-600 hover:bg-slate-800 hover:text-white" title="Editar">
                                            <span class="material-symbols-outlined text-base">edit</span>
                                            <span>Editar</span>
                                        </button>
                                        <button type="button" data-prod-delete-id="@p.ProductoId" data-prod-delete-nombre="@p.Nombre"
                                                class="inline-flex items-center gap-1.5 rounded-lg border border-red-500/30 px-2.5 py-1.5 text-xs font-semibold text-red-400 transition-colors hover:bg-red-500/10 hover:text-red-400" title="Eliminar">
                                            <span class="material-symbols-outlined text-base">delete</span>
                                            <span>Eliminar</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="py-12 text-center">
                                <span class="material-symbols-outlined text-4xl text-slate-300 text-slate-600 mb-2 block">inventory_2</span>
                                <p class="text-sm font-bold text-slate-400">No se encontraron productos</p>
                                @if (Model.TieneFiltrosActivos)
                                {
                                    <p class="text-xs text-slate-400 mt-1">Prueba ajustando los filtros de búsqueda.</p>
                                }
                            </td>
                        </tr>
                    }
                    <tr id="productos-search-empty" style="display:none">
                        <td colspan="8" class="py-12 text-center">
                            <div class="flex flex-col items-center gap-2 opacity-50">
                                <span class="material-symbols-outlined text-4xl">search_off</span>
                                <p class="text-sm font-bold text-slate-300">Sin resultados para "<span id="productos-search-term"></span>"</p>
                                <p class="text-xs text-slate-400">Revisá el texto o limpiá la búsqueda.</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
                </div>
            </div>
        </div>

        <!-- Selection Bar (hidden by default, shown when products selected) -->
        <div id="selection-bar" class="hidden fixed bottom-6 left-1/2 z-40 w-[min(760px,calc(100vw-2rem))] -translate-x-1/2 rounded-2xl border border-primary/30 px-5 py-4 shadow-2xl shadow-slate-900/10 backdrop-blur-xl bg-slate-950/95 shadow-black/30 flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div class="flex min-w-0 items-center gap-4">
                <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-primary/10 text-primary">
                    <span class="material-symbols-outlined text-lg">checklist</span>
                </div>
                <div class="min-w-0">
                    <span class="block text-sm font-black text-white"><span id="selection-count">0</span> producto(s) listos para ajustar</span>
                    <p class="text-xs text-slate-400">El ajuste puede usar solo esta selección o podés cambiar el alcance dentro del modal.</p>
                </div>
            </div>
            <div class="flex w-full shrink-0 flex-col gap-2 sm:w-auto sm:flex-row sm:items-center">
                <button type="button" data-catalogo-action="clear-selection" class="w-full px-4 py-2 text-xs font-bold text-slate-500 transition-colors hover:text-slate-400 hover:text-slate-200 sm:w-auto">
                    Deseleccionar
                </button>
                <button type="button" data-catalogo-modal-open="precio-selection"
                        class="flex w-full items-center justify-center gap-2 rounded-xl bg-amber-500 px-4 py-2 text-xs font-bold text-white shadow-sm transition-colors hover:bg-amber-600 sm:w-auto">
                    <span class="material-symbols-outlined text-sm">trending_up</span>
                    Ajustar selección (<span id="selection-count-btn">0</span>)
                </button>
            </div>
        </div>

        <!-- Footer -->
        <div class="flex flex-col gap-2 border-t border-slate-800 px-6 py-4 text-xs text-slate-400 sm:flex-row sm:items-center sm:justify-between">
            <span class="text-xs text-slate-400">
                Mostrando <span id="productos-footer-count">@productos.Count</span> de @total productos
                @if (Model.TieneFiltrosActivos)
                {
                    <text>(filtrado)</text>
                }
            </span>
            <span>La última columna concentra historial, edición y eliminación.</span>
        </div>
    </div>

    <!-- Tab: Categorías -->
    <div id="tab-categorias" class="hidden">
        <div class="border-b border-slate-800 px-5 py-4">
            <div class="flex flex-col gap-2 lg:flex-row lg:items-center lg:justify-between">
                <div>
                    <h2 class="text-base font-bold text-white">Categorías registradas</h2>
                    <p class="text-sm text-slate-400">
                        Mantené la estructura del catálogo y revisá jerarquías activas e inactivas.
                    </p>
                </div>
                <div class="flex items-center gap-3">
                    <span class="inline-flex items-center rounded-full bg-slate-800 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.16em] text-slate-300">
                        @Model.CategoriasListado.Count() visibles
                    </span>
                    <button type="button" id="btn-crear-categoria" data-catalogo-modal-open="categoria"
                            class="btn-erp-primary btn-sm">
                        <span class="material-symbols-outlined text-sm">add</span>
                        Nueva Categoría
                    </button>
                </div>
            </div>
        </div>

        <!-- Categories Table -->
        <div data-oc-scroll class="relative" style="--oc-scroll-min-width: 980px;">
            <div data-oc-scroll-hint hidden class="px-5 pt-4 text-xs font-semibold uppercase tracking-[0.16em] text-slate-400 lg:hidden">
                Deslizá la tabla para ver la jerarquía y las acciones.
            </div>
            <div data-oc-scroll-shell class="relative">
                <div data-oc-scroll-fade="left" hidden class="absolute inset-y-0 left-0 z-10 w-6 bg-gradient-to-r from-slate-900 via-slate-900/95 to-transparent"></div>
                <div data-oc-scroll-fade="right" hidden class="absolute inset-y-0 right-0 z-10 w-6 bg-gradient-to-l from-slate-900 via-slate-900/95 to-transparent"></div>
                <div data-oc-scroll-region class="overflow-x-auto scroll-smooth" tabindex="0" role="region" aria-label="Tabla de categorías del catálogo">
            <table class="w-full text-left border-collapse" data-oc-scroll-table style="min-width: var(--oc-scroll-min-width);">
                <thead>
                    <tr class="bg-slate-800/30 border-b border-slate-800">
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Código</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Categoría</th>
