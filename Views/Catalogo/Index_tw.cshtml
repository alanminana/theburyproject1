        </div>

        <form id="form-condiciones-pago-producto" class="flex min-h-0 flex-1 flex-col" autocomplete="off">
            @Html.AntiForgeryToken()
            <input type="hidden" id="condiciones-pago-producto-id" value="" />

            <div class="min-h-0 flex-1 overflow-y-auto px-6 py-6 sm:px-8">
                <div class="mb-5 rounded-xl border border-amber-500/20 bg-amber-500/10 px-4 py-3 text-sm text-amber-200">
