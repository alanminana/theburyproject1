                        <div class="mb-3 flex items-center justify-between gap-3">
                            <h3 class="text-sm font-black uppercase tracking-[0.16em] text-slate-300">Medios de pago</h3>
                            <span id="condiciones-pago-count" class="rounded-full bg-slate-800 px-3 py-1 text-[11px] font-bold text-slate-400">0 configurados</span>
                        </div>
                        <div id="condiciones-pago-medios" class="grid gap-3"></div>
                    </section>

                    <aside class="min-w-0">
                        <div class="mb-3 flex items-center justify-between gap-3">
