        <!-- Form -->
        <form id="form-nueva-categoria" method="post" asp-controller="Categoria" asp-action="CreateAjax">
            @Html.AntiForgeryToken()

            <!-- Scrollable Content -->
            <div class="flex-1 overflow-y-auto p-6 space-y-6" style="max-height: calc(90vh - 140px);">

                <!-- Validation Summary -->
                <div id="cat-modal-validation-summary" class="hidden bg-red-500/10 border border-red-500/20 rounded-lg p-4 flex gap-3">
                    <span class="material-symbols-outlined text-red-500">error</span>
                    <div>
                        <h4 class="text-sm font-bold text-red-500">Errores de validación</h4>
                        <p id="cat-modal-validation-text" class="text-xs text-red-400/80 mt-1"></p>
                    </div>
                </div>

                <!-- Section: Datos de la categoría -->
                <div class="bg-white dark:bg-slate-900/50 rounded-xl border border-slate-200 dark:border-slate-800 p-6">
                    <div class="flex items-center gap-2 mb-6 border-b border-slate-100 dark:border-slate-800 pb-4">
