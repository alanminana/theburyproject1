                </div>
                <button type="button" data-condiciones-pago-close class="inline-flex h-10 w-10 items-center justify-center rounded-lg text-slate-400 transition-colors hover:bg-slate-800 hover:text-white" aria-label="Cerrar">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
        </header>

