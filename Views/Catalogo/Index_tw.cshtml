                            <span id="condiciones-pago-tarjetas-count" class="rounded-full bg-slate-800 px-3 py-1 text-[11px] font-bold text-slate-400">0 tarjetas</span>
                        </div>
                        <div id="condiciones-pago-tarjetas" class="grid gap-3"></div>
                    </aside>
                </div>
            </div>

            <footer class="border-t border-slate-800 bg-[#131a27] px-6 py-5 sm:px-8">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <p class="text-xs text-slate-400">El backend valida cuotas, porcentajes, duplicados y concurrencia.</p>
                    <div class="flex flex-col gap-3 sm:flex-row">
                        <button type="button" data-condiciones-pago-close class="inline-flex h-11 w-full items-center justify-center rounded-lg border border-slate-700 px-6 text-sm font-bold text-slate-300 transition-colors hover:bg-slate-800 sm:w-auto">
                            Cancelar
                        </button>
                        <button type="submit" id="btn-guardar-condiciones-pago" class="inline-flex h-11 w-full items-center justify-center gap-2 rounded-lg bg-primary px-6 text-sm font-bold text-white shadow-lg shadow-primary/20 transition-colors hover:brightness-110 sm:w-auto">
                            <span class="material-symbols-outlined text-[18px]">save</span>
                            Guardar condiciones
                        </button>
                    </div>
                </div>
            </footer>
        </form>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════
     MODAL: Asignar Comisión Vendedor
     ═══════════════════════════════════════════════════════════════ -->
<div id="modal-comision-vendedor" class="fixed inset-0 z-50 hidden items-center justify-center p-4 sm:p-6">
    <div class="absolute inset-0 bg-slate-900/80 backdrop-blur-sm" data-comision-modal-close></div>
    <div class="relative w-full max-w-md flex flex-col overflow-hidden rounded-2xl border border-slate-800 bg-[#111827] shadow-2xl">

        <header class="border-b border-slate-800 px-6 py-5 flex items-center justify-between">
            <div>
                <div class="inline-flex items-center gap-1.5 rounded-full bg-slate-800 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.16em] text-slate-300 mb-2">
                    <span class="material-symbols-outlined text-sm">percent</span>
                    Comisión vendedor
                </div>
                <h2 class="text-lg font-bold text-white" id="comision-modal-nombre">—</h2>
            </div>
            <button type="button" data-comision-modal-close
                    class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-slate-400 transition-colors hover:bg-slate-800">
                <span class="material-symbols-outlined">close</span>
            </button>
        </header>

        <form id="form-comision-vendedor" method="post" action="@Url.Action("ActualizarComisionVendedor", "Producto")">
            @Html.AntiForgeryToken()
            <input type="hidden" id="comision-modal-productoId" name="productoId" value="" />

            <div class="p-6 space-y-4">
                <div id="comision-modal-validation" class="hidden bg-red-500/10 border border-red-500/20 rounded-lg p-4 flex gap-3">
                    <span class="material-symbols-outlined text-red-500 shrink-0">error</span>
                    <p id="comision-modal-validation-text" class="text-xs text-red-400/80 self-center"></p>
                </div>
                <div id="comision-modal-success" class="hidden bg-emerald-500/10 border border-emerald-500/20 rounded-lg p-4 flex gap-3">
                    <span class="material-symbols-outlined text-emerald-500 shrink-0">check_circle</span>
                    <p id="comision-modal-success-text" class="text-xs text-emerald-400/80 self-center"></p>
                </div>

                <div class="space-y-2">
                    <label for="comision-modal-porcentaje" class="text-sm font-medium text-slate-300">Porcentaje de comisión</label>
                    <div class="relative">
                        <input id="comision-modal-porcentaje" name="porcentajeComision" type="number"
                               min="0" max="100" step="0.01"
                               class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 pr-10 focus:ring-2 focus:ring-primary outline-none text-white" />
                        <span class="absolute right-3 top-2 text-slate-400 font-bold select-none">%</span>
                    </div>
                    <p class="text-xs text-slate-400">Ingresá 0 para sin comisión. Máximo 100.</p>
                </div>
            </div>

            <footer class="flex items-center justify-end gap-3 px-6 py-4 border-t border-slate-800 bg-slate-900/50">
                <button type="button" data-comision-modal-close
                        class="inline-flex items-center justify-center px-6 py-2.5 text-sm font-semibold text-slate-400 transition-colors hover:text-white">
                    Cancelar
                </button>
                <button type="submit" id="btn-guardar-comision"
                        class="inline-flex items-center gap-1.5 rounded-lg bg-primary px-6 py-2.5 text-sm font-bold text-white shadow-lg shadow-primary/20 transition-colors hover:bg-primary/90">
                    <span class="material-symbols-outlined text-[18px]">save</span>
                    Guardar
                </button>
            </footer>
        </form>
    </div>
</div>

