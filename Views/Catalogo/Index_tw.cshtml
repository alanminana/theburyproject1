@model CatalogoUnificadoViewModel
@{
    ViewData["Title"] = "Inventario";
    var productos = Model.Productos.ToList();
    var total = Model.TotalResultados;
    var stockBajoCount = Model.ProductosStockBajo;
}

<!-- Header -->
<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
    <div>
        <h2 class="text-3xl font-black tracking-tight">Gestión de Inventario</h2>
        <p class="text-slate-500 dark:text-slate-400 mt-1">Administra tu inventario de forma eficiente.</p>
    </div>
    <button type="button" id="btn-movimientos-inventario"
            class="flex items-center justify-center gap-2 rounded-lg h-10 px-5 bg-slate-200 dark:bg-slate-800 text-slate-900 dark:text-white text-sm font-bold transition-colors hover:bg-slate-300 dark:hover:bg-slate-700">
        <span class="material-symbols-outlined text-[18px]">swap_vert</span>
        Movimientos de Inventario
    </button>
</div>

<!-- TempData Alerts -->
@if (TempData["Success"] != null)
{
    <div class="rounded-xl border border-emerald-500/20 bg-emerald-500/10 p-4 flex items-center gap-3 text-emerald-600 dark:text-emerald-400 mb-6">
        <span class="material-symbols-outlined">check_circle</span>
        <span class="text-sm font-medium">@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="rounded-xl border border-red-500/20 bg-red-500/10 p-4 flex items-center gap-3 text-red-500 dark:text-red-400 mb-6">
        <span class="material-symbols-outlined">error</span>
        <span class="text-sm font-medium">@TempData["Error"]</span>
    </div>
}

<!-- Stock Bajo Metric -->
@if (stockBajoCount > 0)
{
    <div class="flex justify-start mb-6">
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 p-5 rounded-xl flex items-center justify-between overflow-hidden w-full max-w-sm shadow-sm">
            <div>
                <p class="text-slate-500 dark:text-slate-400 text-sm font-medium">Stock Bajo</p>
                <p class="text-2xl font-black text-slate-900 dark:text-white mt-1">@stockBajoCount</p>
                <p class="text-orange-500 text-xs mt-1 font-semibold">Requiere atención</p>
            </div>
            <div class="w-12 h-12 bg-orange-500/10 text-orange-500 rounded-lg flex items-center justify-center">
                <span class="material-symbols-outlined">warning</span>
            </div>
        </div>
    </div>
}

<!-- Main Card with Tabs -->
<div class="bg-white dark:bg-slate-900/40 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">

    <!-- Tab Bar + Actions -->
    <div class="flex items-center justify-between border-b border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-800/20">
        <div class="flex" id="catalogo-tabs">
            <button type="button" data-tab="productos"
                    class="px-8 py-4 text-sm font-bold border-b-2 border-primary text-primary bg-primary/10 transition-colors">
                Productos
            </button>
            <button type="button" data-tab="categorias"
                    class="px-8 py-4 text-sm font-bold border-b-2 border-transparent text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 transition-colors">
                Categorías
                <span class="ml-1 text-xs text-slate-400">(@Model.TotalCategorias)</span>
            </button>
            <button type="button" data-tab="marcas"
                    class="px-8 py-4 text-sm font-bold border-b-2 border-transparent text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 transition-colors">
                Marcas
                <span class="ml-1 text-xs text-slate-400">(@Model.TotalMarcas)</span>
            </button>
        </div>
        <div class="flex flex-wrap items-center justify-end gap-3 px-6 py-3">
            <button type="button" id="btn-ajuste-masivo" onclick="PrecioModal.open()"
                    class="flex items-center gap-2 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-white px-4 py-2 rounded-lg transition-all border border-slate-200 dark:border-slate-700 text-xs font-bold cursor-pointer">
                <span class="material-symbols-outlined text-sm">edit_calendar</span>
                <span id="btn-ajuste-masivo-label">Ajuste Masivo</span>
                <span id="btn-ajuste-masivo-badge" class="hidden items-center justify-center min-w-5 h-5 px-1.5 rounded-full bg-amber-500 text-white text-[10px] font-black">
                    <span id="btn-ajuste-masivo-count">0</span>
                </span>
            </button>
            <div id="catalogo-selection-chip" class="hidden items-center gap-2 rounded-full border border-amber-500/20 bg-amber-500/10 px-3 py-1 text-[11px] font-bold text-amber-600 dark:text-amber-400">
                <span class="material-symbols-outlined text-[14px]">checklist</span>
                <span><span id="catalogo-selection-chip-count">0</span> seleccionados</span>
            </div>
            <!-- Dynamic Create buttons (JS toggles visibility based on active tab) -->
            <button type="button" id="btn-crear-producto" onclick="ProductoModal.open()"
                    class="flex items-center gap-2 bg-primary hover:bg-blue-700 text-white px-4 py-2 rounded-lg shadow-sm transition-all text-xs font-bold cursor-pointer">
                <span class="material-symbols-outlined text-sm">add</span>
                Nuevo Producto
            </button>
            <button type="button" id="btn-crear-categoria" onclick="CategoriaModal.open()"
                    class="hidden items-center gap-2 bg-primary hover:bg-blue-700 text-white px-4 py-2 rounded-lg shadow-sm transition-all text-xs font-bold cursor-pointer">
                <span class="material-symbols-outlined text-sm">add</span>
                Nueva Categoría
            </button>
            <button type="button" id="btn-crear-marca" onclick="MarcaModal.open()"
                    class="hidden items-center gap-2 bg-primary hover:bg-blue-700 text-white px-4 py-2 rounded-lg shadow-sm transition-all text-xs font-bold cursor-pointer">
                <span class="material-symbols-outlined text-sm">add</span>
                Nueva Marca
            </button>
        </div>
    </div>

    <!-- Tab: Productos -->
    <div id="tab-productos">
        <!-- Filters -->
        <form id="filterForm" method="get" asp-controller="Catalogo" asp-action="Index"
              class="p-4 border-b border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-900/30">
            <div class="flex flex-wrap items-end gap-4">
                <div class="flex-1 min-w-[200px]">
                    <label class="text-slate-500 dark:text-slate-400 text-[10px] font-bold mb-1.5 block uppercase tracking-wider">Buscar Producto</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg">search</span>
                        <input name="searchTerm" value="@Model.SearchTerm" type="text"
                               class="w-full bg-slate-50 dark:bg-slate-800 border-none rounded-lg pl-10 pr-4 py-2 text-sm focus:ring-2 focus:ring-primary/50 transition-all text-slate-900 dark:text-white placeholder:text-slate-500"
                               placeholder="Nombre o código..." />
                    </div>
                </div>
                <div class="w-48">
                    <label class="text-slate-500 dark:text-slate-400 text-[10px] font-bold mb-1.5 block uppercase tracking-wider">Categoría</label>
                    <select name="categoriaId"
                            class="w-full bg-slate-50 dark:bg-slate-800 border-none rounded-lg px-4 py-2 text-sm focus:ring-2 focus:ring-primary/50 transition-all text-slate-900 dark:text-white">
                        <option value="">Todas</option>
                        @if (Model.CategoriasFiltro != null)
                        {
                            @foreach (var cat in Model.CategoriasFiltro)
                            {
                                <option value="@cat.Value" selected="@(cat.Selected ? "selected" : null)">@cat.Text</option>
                            }
                        }
                    </select>
                </div>
                <div class="w-48">
                    <label class="text-slate-500 dark:text-slate-400 text-[10px] font-bold mb-1.5 block uppercase tracking-wider">Marca</label>
                    <select name="marcaId"
                            class="w-full bg-slate-50 dark:bg-slate-800 border-none rounded-lg px-4 py-2 text-sm focus:ring-2 focus:ring-primary/50 transition-all text-slate-900 dark:text-white">
                        <option value="">Todas</option>
                        @if (Model.MarcasFiltro != null)
                        {
                            @foreach (var marca in Model.MarcasFiltro)
                            {
                                <option value="@marca.Value" selected="@(marca.Selected ? "selected" : null)">@marca.Text</option>
                            }
                        }
                    </select>
                </div>
                <div class="w-48">
                    <label class="text-slate-500 dark:text-slate-400 text-[10px] font-bold mb-1.5 block uppercase tracking-wider">Estado Stock</label>
                    <select name="stockBajo"
                            class="w-full bg-slate-50 dark:bg-slate-800 border-none rounded-lg px-4 py-2 text-sm focus:ring-2 focus:ring-primary/50 transition-all text-slate-900 dark:text-white">
                        <option value="false" selected="@(!Model.StockBajo ? "selected" : null)">Cualquiera</option>
                        <option value="true" selected="@(Model.StockBajo ? "selected" : null)">Stock Bajo</option>
                    </select>
                </div>
                @if (Model.ListasPreciosFiltro != null && Model.ListasPreciosFiltro.Any())
                {
                    <div class="w-48">
                        <label class="text-slate-500 dark:text-slate-400 text-[10px] font-bold mb-1.5 block uppercase tracking-wider">Lista Precios</label>
                        <select name="listaPrecioId"
                                class="w-full bg-slate-50 dark:bg-slate-800 border-none rounded-lg px-4 py-2 text-sm focus:ring-2 focus:ring-primary/50 transition-all text-slate-900 dark:text-white">
                            <option value="">Predeterminada</option>
                            @foreach (var lp in Model.ListasPreciosFiltro)
                            {
                                <option value="@lp.Value" selected="@(lp.Selected ? "selected" : null)">@lp.Text</option>
                            }
                        </select>
                    </div>
                }
                <div class="flex gap-2">
                    <button type="submit"
                            class="p-2.5 bg-primary/10 text-primary hover:bg-primary hover:text-white rounded-lg transition-colors"
                            title="Filtrar">
                        <span class="material-symbols-outlined text-lg">filter_list</span>
                    </button>
                    @if (Model.TieneFiltrosActivos)
                    {
                        <a asp-controller="Catalogo" asp-action="Index"
                           class="p-2.5 bg-slate-200 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:bg-slate-300 dark:hover:bg-slate-700 rounded-lg transition-colors no-underline"
                           title="Limpiar filtros">
                            <span class="material-symbols-outlined text-lg">clear_all</span>
                        </a>
                    }
                </div>
            </div>
        </form>

        <!-- Products Table -->
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 dark:bg-slate-800/30 border-b border-slate-200 dark:border-slate-800">
                        <th class="w-10 px-3 py-4">
                            <input type="checkbox" id="chk-select-all"
                                   class="rounded border-slate-300 dark:border-slate-600 text-primary focus:ring-primary cursor-pointer" />
                        </th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Código</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Producto</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Categoría</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Marca</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 text-center">Stock</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Precio</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                    @if (productos.Any())
                    {
                        @foreach (var p in productos)
                        {
                            // Stock badge — colors match mockup
                            string stockBg, stockText;
                            switch (p.EstadoStock)
                            {
                                case "Sin Stock":
                                    stockBg = "bg-red-500/20 text-red-400 border border-red-500/30";
                                    stockText = "Agotado";
                                    break;
                                case "Stock Bajo":
                                    stockBg = "bg-orange-500/20 text-orange-400 border border-orange-500/30";
                                    stockText = $"{p.StockActual:G29} Unid.";
                                    break;
                                default:
                                    stockBg = "bg-green-500/20 text-green-400 border border-green-500/30";
                                    stockText = $"{p.StockActual:G29} Unid.";
                                    break;
                            }

                            <tr class="hover:bg-slate-50 dark:hover:bg-white/5 transition-colors @(!p.Activo ? "opacity-50" : "")"
                                data-producto-id="@p.ProductoId"
                                data-producto-codigo="@p.Codigo"
                                data-producto-nombre="@p.Nombre">
                                <td class="w-10 px-3 py-4">
                                    <input type="checkbox" class="chk-producto rounded border-slate-300 dark:border-slate-600 text-primary focus:ring-primary cursor-pointer"
                                           value="@p.ProductoId" />
                                </td>
                                <td class="px-6 py-4 text-sm font-mono text-slate-500 dark:text-slate-400">@p.Codigo</td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded bg-slate-100 dark:bg-slate-800 flex items-center justify-center overflow-hidden flex-shrink-0">
                                            <span class="material-symbols-outlined text-slate-400 text-lg">package_2</span>
                                        </div>
                                        <div>
                                            <span class="text-sm font-semibold text-slate-900 dark:text-white">@p.Nombre</span>
                                            @if (!string.IsNullOrEmpty(p.Descripcion))
                                            {
                                                <p class="text-[10px] text-slate-400 truncate max-w-[200px]">@p.Descripcion</p>
                                            }
                                            @if (!p.Activo)
                                            {
                                                <span class="text-[10px] font-bold text-red-400">Inactivo</span>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-300">@(p.CategoriaNombre ?? "—")</td>
                                <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-300">@(p.MarcaNombre ?? "—")</td>
                                <td class="px-6 py-4 text-center">
                                    <span class="inline-flex items-center px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider @stockBg">
                                        @stockText
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    <p class="text-sm font-bold text-slate-900 dark:text-white">$ @p.PrecioActual.ToString("N2")</p>
                                    @if (p.TienePrecioLista)
                                    {
                                        <p class="text-[10px] text-slate-400">Lista: @Model.ListaPrecioActualNombre</p>
                                    }
                                    @if (p.MargenPorcentaje > 0)
                                    {
                                        <p class="text-[10px] text-emerald-400">+@p.MargenPorcentaje.ToString("N1")% margen</p>
                                    }
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex justify-end gap-2">
                                        <button type="button" onclick="HistorialPrecioModal.open(@p.ProductoId)"
                                                class="p-1.5 text-slate-400 hover:text-primary transition-colors" title="Historial de precio">
                                            <span class="material-symbols-outlined text-lg">history</span>
                                        </button>
                                        <a asp-controller="Producto" asp-action="Edit" asp-route-id="@p.ProductoId"
                                           class="p-1.5 text-slate-400 hover:text-white transition-colors no-underline" title="Editar">
                                            <span class="material-symbols-outlined text-lg">edit</span>
                                        </a>
                                        <a asp-controller="Producto" asp-action="Delete" asp-route-id="@p.ProductoId"
                                           class="p-1.5 text-slate-400 hover:text-red-400 transition-colors no-underline" title="Eliminar">
                                            <span class="material-symbols-outlined text-lg">delete</span>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="py-12 text-center">
                                <span class="material-symbols-outlined text-4xl text-slate-300 dark:text-slate-600 mb-2 block">inventory_2</span>
                                <p class="text-sm font-bold text-slate-500 dark:text-slate-400">No se encontraron productos</p>
                                @if (Model.TieneFiltrosActivos)
                                {
                                    <p class="text-xs text-slate-400 mt-1">Prueba ajustando los filtros de búsqueda.</p>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Selection Bar (hidden by default, shown when products selected) -->
        <div id="selection-bar" class="hidden fixed bottom-6 left-1/2 z-40 w-[min(760px,calc(100vw-2rem))] -translate-x-1/2 rounded-2xl border border-primary/30 bg-white/95 dark:bg-slate-950/95 shadow-2xl shadow-slate-900/10 dark:shadow-black/30 backdrop-blur-xl px-5 py-4 items-center justify-between gap-4">
            <div class="flex min-w-0 items-center gap-4">
                <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-primary/10 text-primary">
                    <span class="material-symbols-outlined text-lg">checklist</span>
                </div>
                <div class="min-w-0">
                    <span class="block text-sm font-black text-slate-900 dark:text-white"><span id="selection-count">0</span> producto(s) listos para ajustar</span>
                    <p class="text-xs text-slate-500 dark:text-slate-400">El ajuste puede usar solo esta selección o podés cambiar el alcance dentro del modal.</p>
                </div>
            </div>
            <div class="flex shrink-0 items-center gap-2">
                <button type="button" onclick="ProductSelection.clearAll()" class="px-4 py-2 text-xs font-bold text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition-colors">
                    Deseleccionar
                </button>
                <button type="button" onclick="PrecioModal.openWithSelection(ProductSelection.getIds())"
                        class="flex items-center gap-2 bg-amber-500 hover:bg-amber-600 text-white px-4 py-2 rounded-xl shadow-sm transition-all text-xs font-bold cursor-pointer">
                    <span class="material-symbols-outlined text-sm">trending_up</span>
                    Ajustar selección (<span id="selection-count-btn">0</span>)
                </button>
            </div>
        </div>

        <!-- Footer -->
        <div class="px-6 py-4 border-t border-slate-200 dark:border-slate-800 flex items-center justify-between">
            <span class="text-xs text-slate-500 dark:text-slate-400">
                Mostrando @productos.Count de @total productos
                @if (Model.TieneFiltrosActivos)
                {
                    <text>(filtrado)</text>
                }
            </span>
        </div>
    </div>

    <!-- Tab: Categorías -->
    <div id="tab-categorias" class="hidden">
        <!-- Categories Table -->
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 dark:bg-slate-800/30 border-b border-slate-200 dark:border-slate-800">
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Código</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Categoría</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Categoría Padre</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 text-center">Estado</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                    @if (Model.CategoriasListado.Any())
                    {
                        @foreach (var cat in Model.CategoriasListado)
                        {
                            <tr class="hover:bg-slate-50 dark:hover:bg-white/5 transition-colors @(!cat.Activo ? "opacity-50" : "")">
                                <td class="px-6 py-4 text-sm font-mono text-slate-500 dark:text-slate-400">@cat.Codigo</td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded bg-slate-100 dark:bg-slate-800 flex items-center justify-center flex-shrink-0">
                                            <span class="material-symbols-outlined text-slate-400 text-lg">category</span>
                                        </div>
                                        <div>
                                            <span class="text-sm font-semibold text-slate-900 dark:text-white">@cat.Nombre</span>
                                            @if (!string.IsNullOrEmpty(cat.Descripcion))
                                            {
                                                <p class="text-[10px] text-slate-400 truncate max-w-[250px]">@cat.Descripcion</p>
                                            }
                                            @if (!cat.Activo)
                                            {
                                                <span class="text-[10px] font-bold text-red-400">Inactivo</span>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-300">@(cat.ParentNombre ?? "—")</td>
                                <td class="px-6 py-4 text-center">
                                    @if (cat.Activo)
                                    {
                                        <span class="inline-flex items-center px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-green-500/20 text-green-400 border border-green-500/30">
                                            Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-red-500/20 text-red-400 border border-red-500/30">
                                            Inactivo
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex justify-end gap-2">
                                        <a asp-controller="Categoria" asp-action="Edit" asp-route-id="@cat.Id"
                                           class="p-1.5 text-slate-400 hover:text-white transition-colors no-underline" title="Editar">
                                            <span class="material-symbols-outlined text-lg">edit</span>
                                        </a>
                                        <a asp-controller="Categoria" asp-action="Delete" asp-route-id="@cat.Id"
                                           class="p-1.5 text-slate-400 hover:text-red-400 transition-colors no-underline" title="Eliminar">
                                            <span class="material-symbols-outlined text-lg">delete</span>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="py-12 text-center">
                                <span class="material-symbols-outlined text-4xl text-slate-300 dark:text-slate-600 mb-2 block">category</span>
                                <p class="text-sm font-bold text-slate-500 dark:text-slate-400">No se encontraron categorías</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <!-- Footer -->
        <div class="px-6 py-4 border-t border-slate-200 dark:border-slate-800 flex items-center justify-between">
            <span class="text-xs text-slate-500 dark:text-slate-400">
                Mostrando @Model.CategoriasListado.Count() categorías
            </span>
        </div>
    </div>

    <!-- Tab: Marcas -->
    <div id="tab-marcas" class="hidden">
        <!-- Brands Table -->
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 dark:bg-slate-800/30 border-b border-slate-200 dark:border-slate-800">
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Código</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Marca</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Marca Padre</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">País de Origen</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 text-center">Estado</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                    @if (Model.MarcasListado.Any())
                    {
                        @foreach (var marca in Model.MarcasListado)
                        {
                            <tr class="hover:bg-slate-50 dark:hover:bg-white/5 transition-colors @(!marca.Activo ? "opacity-50" : "")">
                                <td class="px-6 py-4 text-sm font-mono text-slate-500 dark:text-slate-400">@marca.Codigo</td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded bg-slate-100 dark:bg-slate-800 flex items-center justify-center flex-shrink-0">
                                            <span class="material-symbols-outlined text-slate-400 text-lg">branding_watermark</span>
                                        </div>
                                        <div>
                                            <span class="text-sm font-semibold text-slate-900 dark:text-white">@marca.Nombre</span>
                                            @if (!string.IsNullOrEmpty(marca.Descripcion))
                                            {
                                                <p class="text-[10px] text-slate-400 truncate max-w-[250px]">@marca.Descripcion</p>
                                            }
                                            @if (!marca.Activo)
                                            {
                                                <span class="text-[10px] font-bold text-red-400">Inactivo</span>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-300">@(marca.ParentNombre ?? "—")</td>
                                <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-300">@(marca.PaisOrigen ?? "—")</td>
                                <td class="px-6 py-4 text-center">
                                    @if (marca.Activo)
                                    {
                                        <span class="inline-flex items-center px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-green-500/20 text-green-400 border border-green-500/30">
                                            Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-red-500/20 text-red-400 border border-red-500/30">
                                            Inactivo
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex justify-end gap-2">
                                        <a asp-controller="Marca" asp-action="Edit" asp-route-id="@marca.Id"
                                           class="p-1.5 text-slate-400 hover:text-white transition-colors no-underline" title="Editar">
                                            <span class="material-symbols-outlined text-lg">edit</span>
                                        </a>
                                        <a asp-controller="Marca" asp-action="Delete" asp-route-id="@marca.Id"
                                           class="p-1.5 text-slate-400 hover:text-red-400 transition-colors no-underline" title="Eliminar">
                                            <span class="material-symbols-outlined text-lg">delete</span>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="py-12 text-center">
                                <span class="material-symbols-outlined text-4xl text-slate-300 dark:text-slate-600 mb-2 block">branding_watermark</span>
                                <p class="text-sm font-bold text-slate-500 dark:text-slate-400">No se encontraron marcas</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <!-- Footer -->
        <div class="px-6 py-4 border-t border-slate-200 dark:border-slate-800 flex items-center justify-between">
            <span class="text-xs text-slate-500 dark:text-slate-400">
                Mostrando @Model.MarcasListado.Count() marcas
            </span>
        </div>
    </div>
</div>

<!-- Modal: Nuevo Producto -->
<div id="modal-nuevo-producto" class="fixed inset-0 z-50 hidden items-center justify-center p-4 sm:p-6">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-slate-900/80 backdrop-blur-sm" onclick="ProductoModal.close()"></div>

    <!-- Modal Container -->
    <div class="relative w-full max-w-4xl max-h-[90vh] overflow-hidden bg-white dark:bg-[#111827] rounded-xl shadow-2xl border border-slate-200 dark:border-slate-800 flex flex-col">

        <!-- Header -->
        <header class="flex items-center justify-between border-b border-slate-200 dark:border-slate-800 px-6 py-4">
            <div class="flex flex-col">
                <div class="flex items-center gap-2 text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">
                    <span>Inventario</span>
                    <span class="material-symbols-outlined text-sm">chevron_right</span>
                    <span class="text-primary">Productos</span>
                </div>
                <h2 class="text-xl font-bold text-slate-900 dark:text-white">Nuevo Producto</h2>
                <p class="text-sm text-slate-500 dark:text-slate-400">Completa los datos para dar de alta un nuevo producto en el catálogo</p>
            </div>
            <button type="button" onclick="ProductoModal.close()" class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-full transition-colors text-slate-400">
                <span class="material-symbols-outlined">close</span>
            </button>
        </header>

        <!-- Form -->
        <form id="form-nuevo-producto" method="post" asp-controller="Producto" asp-action="CreateAjax">
            @Html.AntiForgeryToken()

            <!-- Scrollable Content -->
            <div class="flex-1 overflow-y-auto p-6 space-y-8" style="max-height: calc(90vh - 140px);">

                <!-- Validation Summary -->
                <div id="modal-validation-summary" class="hidden bg-red-500/10 border border-red-500/20 rounded-lg p-4 flex gap-3">
                    <span class="material-symbols-outlined text-red-500">error</span>
                    <div>
                        <h4 class="text-sm font-bold text-red-500">Errores de validación</h4>
                        <p id="modal-validation-text" class="text-xs text-red-400/80 mt-1"></p>
                    </div>
                </div>

                <!-- Section 1: Información Básica -->
                <section>
                    <div class="flex items-center gap-2 mb-4 border-l-4 border-primary pl-3">
                        <h3 class="text-lg font-semibold text-slate-900 dark:text-white">Información Básica</h3>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-700 dark:text-slate-300">Código</label>
                            <input name="Codigo" type="text"
                                   class="w-full bg-white dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all"
                                   placeholder="Ej: PROD-001" />
                            <span data-valmsg-for="Codigo" class="text-xs text-red-500 hidden"></span>
                        </div>
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-700 dark:text-slate-300">Nombre</label>
                            <input name="Nombre" type="text"
                                   class="w-full bg-white dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all"
                                   placeholder="Nombre comercial del producto" />
                            <span data-valmsg-for="Nombre" class="text-xs text-red-500 hidden"></span>
                        </div>
                        <div class="md:col-span-2 space-y-1">
                            <label class="text-sm font-medium text-slate-700 dark:text-slate-300">Descripción</label>
                            <textarea name="Descripcion" rows="3"
                                      class="w-full bg-white dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all"
                                      placeholder="Detalles técnicos o comerciales..."></textarea>
                        </div>
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-700 dark:text-slate-300">Categoría</label>
                            <select name="CategoriaId" id="modal-categoriaId"
                                    class="w-full bg-white dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all">
                                <option value="">Seleccionar categoría</option>
                                @if (Model.CategoriasFiltro != null)
                                {
                                    @foreach (var cat in Model.CategoriasFiltro)
                                    {
                                        <option value="@cat.Value">@cat.Text</option>
                                    }
                                }
                            </select>
                            <span data-valmsg-for="CategoriaId" class="text-xs text-red-500 hidden"></span>
                        </div>
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-700 dark:text-slate-300">Subcategoría</label>
                            <select name="SubcategoriaId" id="modal-subcategoriaId"
                                    class="w-full bg-white dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all">
                                <option value="">Seleccionar subcategoría</option>
                            </select>
                        </div>
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-700 dark:text-slate-300">Marca</label>
                            <select name="MarcaId" id="modal-marcaId"
                                    class="w-full bg-white dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all">
                                <option value="">Seleccionar marca</option>
                                @if (Model.MarcasFiltro != null)
                                {
                                    @foreach (var marca in Model.MarcasFiltro)
                                    {
                                        <option value="@marca.Value">@marca.Text</option>
                                    }
                                }
                            </select>
                            <span data-valmsg-for="MarcaId" class="text-xs text-red-500 hidden"></span>
                        </div>
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-700 dark:text-slate-300">Submarca</label>
                            <select name="SubmarcaId" id="modal-submarcaId"
                                    class="w-full bg-white dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all">
                                <option value="">Seleccionar submarca</option>
                            </select>
                        </div>
                    </div>
                </section>

                <!-- Section 2: Precios -->
                <section>
                    <div class="flex items-center gap-2 mb-4 border-l-4 border-primary pl-3">
                        <h3 class="text-lg font-semibold text-slate-900 dark:text-white">Precios</h3>
                    </div>
                    <div class="bg-primary/10 border border-primary/20 rounded-lg p-3 flex gap-3 mb-6">
                        <span class="material-symbols-outlined text-primary">info</span>
                        <p class="text-xs text-slate-600 dark:text-slate-300">Los precios se ingresan sin IVA. El sistema calculará el precio final automáticamente.</p>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-700 dark:text-slate-300">Precio de Costo</label>
                            <div class="relative">
                                <span class="absolute left-3 top-2 text-slate-500">$</span>
                                <input name="PrecioCompra" id="modal-precioCompra" type="number" step="0.01" min="0"
                                       class="w-full bg-white dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-lg pl-7 pr-4 py-2 focus:ring-2 focus:ring-primary outline-none" />
                            </div>
                            <span data-valmsg-for="PrecioCompra" class="text-xs text-red-500 hidden"></span>
                        </div>
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-700 dark:text-slate-300">Venta sin IVA</label>
                            <div class="relative">
                                <span class="absolute left-3 top-2 text-slate-500">$</span>
                                <input name="PrecioVenta" id="modal-precioVenta" type="number" step="0.01" min="0"
                                       class="w-full bg-white dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-lg pl-7 pr-4 py-2 focus:ring-2 focus:ring-primary outline-none" />
                            </div>
                            <span data-valmsg-for="PrecioVenta" class="text-xs text-red-500 hidden"></span>
                        </div>
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-700 dark:text-slate-300">IVA Aplicable</label>
                            <select name="PorcentajeIVA" id="modal-porcentajeIVA"
                                    class="w-full bg-white dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary outline-none">
                                <option value="21" selected>21%</option>
                                <option value="10.5">10.5%</option>
                                <option value="27">27%</option>
                                <option value="0">0%</option>
                            </select>
                        </div>
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-700 dark:text-slate-300">Precio Final (IVA)</label>
                            <div class="relative">
                                <span class="absolute left-3 top-2 text-primary font-bold">$</span>
                                <input id="modal-precioFinal" type="text" readonly value="0.00"
                                       class="w-full bg-primary/5 border border-primary/30 text-primary font-bold rounded-lg pl-7 pr-4 py-2 outline-none" />
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Section 3: Características -->
                <section>
                    <div class="flex items-center gap-2 mb-4 border-l-4 border-primary pl-3">
                        <h3 class="text-lg font-semibold text-slate-900 dark:text-white">Características</h3>
                    </div>
                    <div class="overflow-hidden border border-slate-200 dark:border-slate-800 rounded-lg mb-2">
                        <table class="w-full text-left text-sm border-collapse">
                            <thead class="bg-slate-50 dark:bg-slate-800/50">
                                <tr>
                                    <th class="px-4 py-3 font-semibold">Nombre de la característica</th>
                                    <th class="px-4 py-3 font-semibold">Valor</th>
                                    <th class="px-4 py-3 font-semibold w-20 text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="modal-caracteristicas-body" class="divide-y divide-slate-200 dark:divide-slate-800">
                                <!-- Dynamic rows inserted by JS -->
                            </tbody>
                            <tfoot>
                                <tr class="bg-slate-50/30 dark:bg-slate-900/30">
                                    <td class="px-2 py-2">
                                        <input id="modal-caract-nombre" type="text"
                                               class="w-full text-xs bg-transparent border-none focus:ring-0 placeholder-slate-500"
                                               placeholder="Ej: Material" />
                                    </td>
                                    <td class="px-2 py-2">
                                        <input id="modal-caract-valor" type="text"
                                               class="w-full text-xs bg-transparent border-none focus:ring-0 placeholder-slate-500"
                                               placeholder="Ej: Acero" />
                                    </td>
                                    <td class="px-2 py-2 text-center">
                                        <button type="button" onclick="ProductoModal.addCaracteristica()"
                                                class="bg-primary hover:bg-primary/90 text-white p-1.5 rounded-lg transition-colors">
                                            <span class="material-symbols-outlined text-sm">add</span>
                                        </button>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                    <p class="text-[11px] text-slate-500 dark:text-slate-400 pl-1 italic">
                        Ejemplo: Color: Negro, Material: Acero, Memoria: 16GB
                    </p>
                </section>

                <!-- Section 4: Stock & Configuración -->
                <section>
                    <div class="flex items-center gap-2 mb-4 border-l-4 border-primary pl-3">
                        <h3 class="text-lg font-semibold text-slate-900 dark:text-white">Stock &amp; Configuración</h3>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">
                        <div class="grid grid-cols-2 gap-4">
                            <div class="space-y-1">
                                <label class="text-sm font-medium text-slate-700 dark:text-slate-300">Stock Actual</label>
                                <input name="StockActual" type="number" min="0" step="1" value="0"
                                       class="w-full bg-white dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary outline-none" />
                            </div>
                            <div class="space-y-1">
                                <label class="text-sm font-medium text-slate-700 dark:text-slate-300">Stock Mínimo</label>
                                <input name="StockMinimo" type="number" min="0" step="1" value="0"
                                       class="w-full bg-white dark:bg-slate-900 border border-slate-300 dark:border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary outline-none" />
                            </div>
                        </div>
                        <div class="flex items-center justify-between p-4 bg-slate-50 dark:bg-slate-800/30 rounded-lg border border-slate-200 dark:border-slate-800">
                            <div>
                                <p class="text-sm font-bold text-slate-900 dark:text-white">Producto Activo</p>
                                <p class="text-xs text-slate-500 dark:text-slate-400">Habilitar este producto para la venta</p>
                            </div>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input name="Activo" type="checkbox" value="true" checked class="sr-only peer" />
                                <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none rounded-full peer dark:bg-slate-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-primary"></div>
                            </label>
                        </div>
                    </div>
                </section>
            </div>

            <!-- Footer -->
            <footer class="flex items-center justify-end gap-3 px-6 py-4 border-t border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50">
                <button type="button" onclick="ProductoModal.close()"
                        class="px-6 py-2 text-sm font-semibold text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">
                    Cancelar
                </button>
                <button type="submit" id="btn-guardar-producto"
                        class="px-8 py-2 text-sm font-bold text-white bg-primary hover:bg-primary/90 rounded-lg shadow-lg shadow-primary/20 transition-all">
                    Guardar Producto
                </button>
            </footer>
        </form>
    </div>
</div>

<!-- Modal: Nueva Categoría -->
<div id="modal-nueva-categoria" class="fixed inset-0 z-50 hidden items-center justify-center p-4 sm:p-6">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-slate-900/80 backdrop-blur-sm" onclick="CategoriaModal.close()"></div>

    <!-- Modal Container -->
    <div class="relative w-full max-w-3xl max-h-[90vh] overflow-hidden bg-white dark:bg-[#111827] rounded-xl shadow-2xl border border-slate-200 dark:border-slate-800 flex flex-col">

        <!-- Header -->
        <header class="flex items-center justify-between border-b border-slate-200 dark:border-slate-800 px-6 py-4">
            <div class="flex flex-col">
                <div class="flex items-center gap-2 text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">
