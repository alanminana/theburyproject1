                </thead>
                <tbody id="categorias-tbody" class="divide-y divide-slate-800">
                    @if (Model.CategoriasListado.Any())
                    {
                        @foreach (var cat in Model.CategoriasListado)
                        {
                            <tr class="hover:bg-white/5 transition-colors @(!cat.Activo ? "opacity-50" : "")">
                                <td class="px-6 py-4 text-sm font-mono text-slate-400">@cat.Codigo</td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded bg-slate-800 flex items-center justify-center flex-shrink-0">
                                            <span class="material-symbols-outlined text-slate-400 text-lg">category</span>
                                        </div>
                                        <div>
                                            <span class="text-sm font-semibold text-white">@cat.Nombre</span>
                                            @if (!string.IsNullOrEmpty(cat.Descripcion))
                                            {
                                                <p class="text-[10px] text-slate-400 truncate max-w-[250px]">@cat.Descripcion</p>
                                            }
                                            @if (!cat.Activo)
                                            {
                                                <span class="text-[10px] font-bold text-red-400">Inactivo</span>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-sm text-slate-300">@(cat.ParentNombre ?? "—")</td>
                                <td class="px-6 py-4 text-center">
                                    @if (cat.Activo)
                                    {
                                        <span class="inline-flex items-center px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-green-500/20 text-green-400 border border-green-500/30">
                                            Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-red-500/20 text-red-400 border border-red-500/30">
                                            Inactivo
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex flex-wrap justify-end gap-2">
                                        <button type="button" data-cat-edit-id="@cat.Id"
                                                class="inline-flex items-center gap-1.5 rounded-lg border border-slate-700 px-2.5 py-1.5 text-xs font-semibold text-slate-300 transition-colors hover:border-slate-600 hover:bg-slate-800 hover:text-white" title="Editar">
                                            <span class="material-symbols-outlined text-base">edit</span>
                                            <span>Editar</span>
                                        </button>
                                        <button type="button" data-cat-delete-id="@cat.Id" data-cat-delete-nombre="@cat.Nombre"
                                                class="inline-flex items-center gap-1.5 rounded-lg border border-red-500/30 px-2.5 py-1.5 text-xs font-semibold text-red-400 transition-colors hover:bg-red-500/10 hover:text-red-400" title="Eliminar">
                                            <span class="material-symbols-outlined text-base">delete</span>
                                            <span>Eliminar</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="py-12 text-center">
                                <span class="material-symbols-outlined text-4xl text-slate-300 text-slate-600 mb-2 block">category</span>
                                <p class="text-sm font-bold text-slate-400">No se encontraron categorías</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
                </div>
            </div>
        </div>
        <!-- Footer -->
        <div class="flex flex-col gap-2 border-t border-slate-800 px-6 py-4 text-xs text-slate-400 sm:flex-row sm:items-center sm:justify-between">
            <span class="text-xs text-slate-400">
                Mostrando @Model.CategoriasListado.Count() categorías
            </span>
            <span>Acciones rápidas disponibles al final de cada fila.</span>
        </div>
    </div>

    <!-- Tab: Marcas -->
    <div id="tab-marcas" class="hidden">
        <div class="border-b border-slate-800 px-5 py-4">
            <div class="flex flex-col gap-2 lg:flex-row lg:items-center lg:justify-between">
                <div>
                    <h2 class="text-base font-bold text-white">Marcas registradas</h2>
                    <p class="text-sm text-slate-400">
                        Revisá cobertura de marcas, submarcas y país de origen sin salir del índice.
                    </p>
                </div>
                <div class="flex items-center gap-3">
                    <span class="inline-flex items-center rounded-full bg-slate-800 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.16em] text-slate-300">
                        @Model.MarcasListado.Count() visibles
                    </span>
                    <button type="button" id="btn-crear-marca" data-catalogo-modal-open="marca"
                            class="btn-erp-primary btn-sm">
                        <span class="material-symbols-outlined text-sm">add</span>
                        Nueva Marca
                    </button>
                </div>
            </div>
        </div>

        <!-- Brands Table -->
        <div data-oc-scroll class="relative" style="--oc-scroll-min-width: 1020px;">
            <div data-oc-scroll-hint hidden class="px-5 pt-4 text-xs font-semibold uppercase tracking-[0.16em] text-slate-400 lg:hidden">
                Deslizá la tabla para revisar origen, estado y acciones.
            </div>
            <div data-oc-scroll-shell class="relative">
                <div data-oc-scroll-fade="left" hidden class="absolute inset-y-0 left-0 z-10 w-6 bg-gradient-to-r from-slate-900 via-slate-900/95 to-transparent"></div>
                <div data-oc-scroll-fade="right" hidden class="absolute inset-y-0 right-0 z-10 w-6 bg-gradient-to-l from-slate-900 via-slate-900/95 to-transparent"></div>
                <div data-oc-scroll-region class="overflow-x-auto scroll-smooth" tabindex="0" role="region" aria-label="Tabla de marcas del catálogo">
            <table class="w-full text-left border-collapse" data-oc-scroll-table style="min-width: var(--oc-scroll-min-width);">
                <thead>
                    <tr class="bg-slate-800/30 border-b border-slate-800">
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Código</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Marca</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Marca Padre</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">País de Origen</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400 text-center">Estado</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400 text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody id="marcas-tbody" class="divide-y divide-slate-800">
                    @if (Model.MarcasListado.Any())
                    {
                        @foreach (var marca in Model.MarcasListado)
                        {
                            <tr class="hover:bg-white/5 transition-colors @(!marca.Activo ? "opacity-50" : "")">
                                <td class="px-6 py-4 text-sm font-mono text-slate-400">@marca.Codigo</td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded bg-slate-800 flex items-center justify-center flex-shrink-0">
                                            <span class="material-symbols-outlined text-slate-400 text-lg">branding_watermark</span>
                                        </div>
                                        <div>
                                            <span class="text-sm font-semibold text-white">@marca.Nombre</span>
                                            @if (!string.IsNullOrEmpty(marca.Descripcion))
                                            {
                                                <p class="text-[10px] text-slate-400 truncate max-w-[250px]">@marca.Descripcion</p>
                                            }
                                            @if (!marca.Activo)
                                            {
                                                <span class="text-[10px] font-bold text-red-400">Inactivo</span>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-sm text-slate-300">@(marca.ParentNombre ?? "—")</td>
                                <td class="px-6 py-4 text-sm text-slate-300">@(marca.PaisOrigen ?? "—")</td>
                                <td class="px-6 py-4 text-center">
                                    @if (marca.Activo)
                                    {
                                        <span class="inline-flex items-center px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-green-500/20 text-green-400 border border-green-500/30">
                                            Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-red-500/20 text-red-400 border border-red-500/30">
                                            Inactivo
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex flex-wrap justify-end gap-2">
                                        <button type="button" data-marca-edit-id="@marca.Id"
                                                class="inline-flex items-center gap-1.5 rounded-lg border border-slate-700 px-2.5 py-1.5 text-xs font-semibold text-slate-300 transition-colors hover:border-slate-600 hover:bg-slate-800 hover:text-white" title="Editar">
                                            <span class="material-symbols-outlined text-base">edit</span>
                                            <span>Editar</span>
                                        </button>
                                        <button type="button" data-marca-delete-id="@marca.Id" data-marca-delete-nombre="@marca.Nombre"
                                                class="inline-flex items-center gap-1.5 rounded-lg border border-red-500/30 px-2.5 py-1.5 text-xs font-semibold text-red-400 transition-colors hover:bg-red-500/10 hover:text-red-400" title="Eliminar">
                                            <span class="material-symbols-outlined text-base">delete</span>
                                            <span>Eliminar</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="py-12 text-center">
                                <span class="material-symbols-outlined text-4xl text-slate-300 text-slate-600 mb-2 block">branding_watermark</span>
                                <p class="text-sm font-bold text-slate-400">No se encontraron marcas</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
                </div>
            </div>
        </div>
        <!-- Footer -->
        <div class="flex flex-col gap-2 border-t border-slate-800 px-6 py-4 text-xs text-slate-400 sm:flex-row sm:items-center sm:justify-between">
            <span class="text-xs text-slate-400">
                Mostrando @Model.MarcasListado.Count() marcas
            </span>
            <span>Revisá origen, estado y acciones desde la misma grilla.</span>
        </div>
    </div>
</div>

<!-- Modal: Nuevo Producto -->
<div id="modal-nuevo-producto" class="fixed inset-0 z-50 hidden items-center justify-center p-4 sm:p-6">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-slate-900/80 backdrop-blur-sm" data-catalogo-modal-close="producto"></div>

    <!-- Modal Container -->
    <div class="relative flex max-h-[92vh] w-full max-w-5xl flex-col overflow-hidden rounded-2xl border border-slate-800 bg-[#111827] shadow-2xl">

        <!-- Header -->
        <header class="border-b border-slate-800 px-6 py-5">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <div class="flex flex-col gap-3">
                <div class="flex items-center gap-2 text-xs font-medium text-slate-400">
                    <span>Inventario</span>
                    <span class="material-symbols-outlined text-sm">chevron_right</span>
                    <span class="text-primary">Productos</span>
                </div>
                <div class="space-y-1">
                    <h2 class="text-xl font-bold text-white sm:text-2xl">Nuevo Producto</h2>
                    <p class="max-w-2xl text-sm text-slate-400">Completá la ficha principal, validá precios y dejá listo el stock inicial sin salir del índice.</p>
                </div>
                <div class="flex flex-wrap gap-2">
                    <span class="inline-flex items-center gap-2 rounded-full bg-slate-800 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.16em] text-slate-300">
                        <span class="material-symbols-outlined text-sm">sell</span>
                        Alta directa en catálogo
                    </span>
                    <span class="inline-flex items-center gap-2 rounded-full bg-primary/10 px-3 py-1 text-[11px] font-semibold text-primary">
                        <span class="material-symbols-outlined text-sm">percent</span>
                        IVA calculado automáticamente
                    </span>
                </div>
            </div>
            <button type="button" data-catalogo-modal-close="producto" class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-slate-400 transition-colors hover:bg-slate-800">
                <span class="material-symbols-outlined">close</span>
            </button>
            </div>
        </header>

        <!-- Form -->
        <form id="form-nuevo-producto" method="post" asp-controller="Producto" asp-action="CreateAjax"
              class="flex flex-col flex-1 overflow-hidden">
            @Html.AntiForgeryToken()

            <!-- Scrollable Content -->
            <div class="flex-1 overflow-y-auto p-6 space-y-8">

                <!-- Validation Summary -->
                <div id="modal-validation-summary" class="hidden bg-red-500/10 border border-red-500/20 rounded-lg p-4 flex gap-3">
                    <span class="material-symbols-outlined text-red-500">error</span>
                    <div>
                        <h4 class="text-sm font-bold text-red-500">Errores de validación</h4>
                        <p id="modal-validation-text" class="text-xs text-red-400/80 mt-1"></p>
                    </div>
                </div>

          

                <!-- Section 1: Información Básica -->
                <section>
                    <div class="flex items-center gap-2 mb-4 border-l-4 border-primary pl-3">
                        <h3 class="text-lg font-semibold text-white">Información Básica</h3>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-300">Código</label>
                            <input name="Codigo" type="text"
                                   class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-colors"
                                   placeholder="Ej: PROD-001" />
                            <span data-valmsg-for="Codigo" class="text-xs text-red-500 hidden"></span>
                        </div>
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-300">Nombre</label>
                            <input name="Nombre" type="text"
                                   class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-colors"
                                   placeholder="Nombre comercial del producto" />
                            <span data-valmsg-for="Nombre" class="text-xs text-red-500 hidden"></span>
                        </div>
                        <div class="md:col-span-2 space-y-1">
                            <label class="text-sm font-medium text-slate-300">Descripción</label>
                            <textarea name="Descripcion" rows="3"
                                      class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-colors"
                                      placeholder="Detalles técnicos o comerciales..."></textarea>
                        </div>
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-300">Categoría</label>
                            <div class="autocomplete-erp" id="ac-categoria">
                                <div class="relative">
                                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 text-lg pointer-events-none">search</span>
                                    <input type="text" id="ac-categoria-input" autocomplete="off"
                                           class="w-full bg-slate-900 border border-slate-700 rounded-lg pl-9 pr-8 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-colors text-white placeholder:text-slate-500"
                                           placeholder="Buscar categoría..." />
                                    <button type="button" id="ac-categoria-clear" class="absolute right-2 top-1/2 -translate-y-1/2 text-slate-500 hover:text-white hidden transition-colors">
                                        <span class="material-symbols-outlined text-base">close</span>
                                    </button>
                                </div>
                                <input type="hidden" name="CategoriaId" id="modal-categoriaId" />
                                <div id="ac-categoria-dropdown" class="hidden absolute z-50 w-full mt-1 bg-slate-900 border border-slate-700 rounded-lg shadow-xl overflow-hidden max-h-52 overflow-y-auto"></div>
                            </div>
                            <span data-valmsg-for="CategoriaId" class="text-xs text-red-500 hidden"></span>
                        </div>
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-300">Subcategoría</label>
                            <select name="SubcategoriaId" id="modal-subcategoriaId"
                                    class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-colors">
                                <option value="">Seleccionar subcategoría</option>
                            </select>
                        </div>
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-300">Marca</label>
                            <div class="autocomplete-erp" id="ac-marca">
                                <div class="relative">
                                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 text-lg pointer-events-none">search</span>
                                    <input type="text" id="ac-marca-input" autocomplete="off"
                                           class="w-full bg-slate-900 border border-slate-700 rounded-lg pl-9 pr-8 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-colors text-white placeholder:text-slate-500"
                                           placeholder="Buscar marca..." />
                                    <button type="button" id="ac-marca-clear" class="absolute right-2 top-1/2 -translate-y-1/2 text-slate-500 hover:text-white hidden transition-colors">
                                        <span class="material-symbols-outlined text-base">close</span>
                                    </button>
                                </div>
                                <input type="hidden" name="MarcaId" id="modal-marcaId" />
                                <div id="ac-marca-dropdown" class="hidden absolute z-50 w-full mt-1 bg-slate-900 border border-slate-700 rounded-lg shadow-xl overflow-hidden max-h-52 overflow-y-auto"></div>
                            </div>
                            <span data-valmsg-for="MarcaId" class="text-xs text-red-500 hidden"></span>
                        </div>
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-300">Submarca</label>
                            <select name="SubmarcaId" id="modal-submarcaId"
                                    class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-colors">
                                <option value="">Seleccionar submarca</option>
                            </select>
                        </div>
                    </div>
                </section>

                <!-- Section 2: Precios -->
                <section>
                    <div class="flex items-center gap-2 mb-4 border-l-4 border-primary pl-3">
                        <h3 class="text-lg font-semibold text-white">Precios</h3>
                    </div>
                    <div class="bg-primary/10 border border-primary/20 rounded-lg p-3 flex gap-3 mb-6">
                        <span class="material-symbols-outlined text-primary">info</span>
                        <p class="text-xs text-slate-300">Los precios base se ingresan sin IVA. Si hay precio vigente en una lista, la venta usará el precio de lista.</p>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-5 gap-4">
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-300">Precio de Costo</label>
                            <div class="relative">
                                <span class="absolute left-3 top-2 text-slate-500">$</span>
                                <input name="PrecioCompra" id="modal-precioCompra" type="number" step="0.01" min="0"
                                       class="w-full bg-slate-900 border border-slate-700 rounded-lg pl-7 pr-4 py-2 focus:ring-2 focus:ring-primary outline-none" />
                            </div>
                            <span data-valmsg-for="PrecioCompra" class="text-xs text-red-500 hidden"></span>
                        </div>
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-300">Precio base sin IVA</label>
                            <div class="relative">
                                <span class="absolute left-3 top-2 text-slate-500">$</span>
                                <input name="PrecioVenta" id="modal-precioVenta" type="number" step="0.01" min="0"
                                       class="w-full bg-slate-900 border border-slate-700 rounded-lg pl-7 pr-4 py-2 focus:ring-2 focus:ring-primary outline-none" />
                            </div>
                            <span data-valmsg-for="PrecioVenta" class="text-xs text-red-500 hidden"></span>
                        </div>
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-300">Alícuota IVA</label>
                            <select name="AlicuotaIVAId" id="modal-alicuotaIVAId"
                                    class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary outline-none">
                                <option value="">— Sin alícuota —</option>
                                @if (ViewBag.AlicuotasIVADatos != null)
                                {
                                    foreach (var a in ViewBag.AlicuotasIVADatos)
                                    {
                                        <option value="@a.Id" data-porcentaje="@a.Porcentaje">@a.Texto</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-300">% IVA (fallback)</label>
                            <select name="PorcentajeIVA" id="modal-porcentajeIVA"
                                    class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary outline-none">
                                <option value="21" selected>21%</option>
                                <option value="10.5">10.5%</option>
                                <option value="27">27%</option>
                                <option value="0">0%</option>
                            </select>
                        </div>
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-300">Precio base final con IVA</label>
                            <div class="relative">
                                <span class="absolute left-3 top-2 text-primary font-bold">$</span>
                                <input id="modal-precioFinal" type="text" readonly value="0.00"
                                       class="w-full bg-primary/5 border border-primary/30 text-primary font-bold rounded-lg pl-7 pr-4 py-2 outline-none" />
                            </div>
                        </div>
                    </div>
                    <div class="mt-4 grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-300">Máx. cuotas sin interés</label>
                            <input name="MaxCuotasSinInteresPermitidas" id="modal-maxCuotasSinInteres" type="number" min="1" max="60"
                                   class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary outline-none"
                                   placeholder="Sin restricción" />
                            <span data-valmsg-for="MaxCuotasSinInteresPermitidas" class="text-xs text-red-500 hidden"></span>
                            <p class="text-xs text-slate-500">Vacío = usa el máximo de la tarjeta. Solo aplica a tarjetas sin interés.</p>
                        </div>
                    </div>
                </section>

                <!-- Section 3: Características -->
                <section>
                    <div class="flex items-center gap-2 mb-4 border-l-4 border-primary pl-3">
                        <h3 class="text-lg font-semibold text-white">Características</h3>
                    </div>
                    <div class="flex flex-col gap-3">
                        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                            <p class="text-xs text-slate-400">Deslizá la tabla para revisar y completar las características del producto.</p>
                            <span id="modal-caracteristicas-count" class="inline-flex items-center rounded-full bg-slate-800 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.16em] text-slate-300">0 cargadas</span>
                        </div>
                        <div class="relative" data-oc-scroll style="--oc-scroll-min-width: 760px;">
                            <div data-oc-scroll-hint class="mb-2 hidden items-center gap-2 text-xs font-medium text-slate-400">
                                <span class="material-symbols-outlined text-sm">swipe</span>
                                Deslizá para ver y editar las columnas.
                            </div>
                            <div data-oc-scroll-shell class="relative overflow-hidden rounded-lg border border-slate-800">
                                <div data-oc-scroll-fade="left" class="pointer-events-none absolute inset-y-0 left-0 hidden w-8 bg-gradient-to-r from-[#111827] via-[#111827]/95 to-transparent"></div>
                                <div data-oc-scroll-fade="right" class="pointer-events-none absolute inset-y-0 right-0 hidden w-8 bg-gradient-to-l from-[#111827] via-[#111827]/95 to-transparent"></div>
                                <div data-oc-scroll-region tabindex="0" role="region" aria-label="Tabla de características del producto" class="overflow-x-auto">
                                    <table data-oc-scroll-table class="w-full border-collapse text-left text-sm" style="min-width: var(--oc-scroll-min-width);">
                                        <thead class="bg-slate-800/50">
                                            <tr>
                                                <th class="px-4 py-3 font-semibold">Nombre de la característica</th>
                                                <th class="px-4 py-3 font-semibold">Valor</th>
                                                <th class="px-4 py-3 w-20 text-center font-semibold">Acciones</th>
                                            </tr>
                                        </thead>
                                        <tbody id="modal-caracteristicas-body" class="divide-y divide-slate-800">
                                            <!-- Dynamic rows inserted by JS -->
                                        </tbody>
                                        <tfoot>
                                            <tr class="/30 bg-slate-900/30">
                                                <td class="px-2 py-2">
                                                    <input id="modal-caract-nombre" type="text"
                                                           class="w-full border-none bg-transparent text-xs placeholder-slate-500 focus:ring-0"
                                                           placeholder="Ej: Material" />
                                                </td>
                                                <td class="px-2 py-2">
                                                    <input id="modal-caract-valor" type="text"
                                                           class="w-full border-none bg-transparent text-xs placeholder-slate-500 focus:ring-0"
                                                           placeholder="Ej: Acero" />
                                                </td>
                                                <td class="px-2 py-2 text-center">
                                                    <button type="button" data-catalogo-action="product-add-caracteristica"
                                                            class="btn-erp-primary btn-sm">
                                                        <span class="material-symbols-outlined text-sm">add</span>
                                                    </button>
                                                </td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                    <p class="text-[11px] text-slate-400 pl-1 italic">
                        Ejemplo: Color: Negro, Material: Acero, Memoria: 16GB
                    </p>
                </section>

                <!-- Section 4: Stock & Configuración -->
                <section>
                    <div class="flex items-center gap-2 mb-4 border-l-4 border-primary pl-3">
                        <h3 class="text-lg font-semibold text-white">Stock &amp; Configuración</h3>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">
                        <div class="grid grid-cols-2 gap-4">
                            <div class="space-y-1">
                                <label class="text-sm font-medium text-slate-300">Stock Actual</label>
                                <input name="StockActual" type="number" min="0" step="1" value="0"
                                       class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary outline-none" />
                            </div>
                            <div class="space-y-1">
                                <label class="text-sm font-medium text-slate-300">Stock Mínimo</label>
                                <input name="StockMinimo" type="number" min="0" step="1" value="0"
                                       class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary outline-none" />
                            </div>
                        </div>
                        <div class="flex items-center justify-between p-4 bg-slate-800/30 rounded-lg border border-slate-800">
                            <div>
                                <p class="text-sm font-bold text-white">Producto Activo</p>
                                <p class="text-xs text-slate-400">Habilitar este producto para la venta</p>
                            </div>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input name="Activo" type="checkbox" value="true" checked class="sr-only peer" />
                                <div class="w-11 h-6 bg-slate-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-600 after:border after:rounded-full after:h-5 after:w-5 after:transition-colors peer-checked:bg-primary"></div>
                            </label>
                        </div>
                    </div>
                </section>
            </div>

            <!-- Footer -->
            <footer class="grid gap-3 border-t border-slate-800 bg-slate-900/50 px-6 py-4 sm:flex sm:items-center sm:justify-end">
                <button type="button" data-catalogo-modal-close="producto"
                        class="inline-flex w-full items-center justify-center px-6 py-2.5 text-sm font-semibold text-slate-400 transition-colors hover:text-white sm:w-auto">
                    Cancelar
                </button>
                <button type="submit" id="btn-guardar-producto"
                        class="inline-flex w-full items-center justify-center rounded-lg bg-primary px-8 py-2.5 text-sm font-bold text-white shadow-lg shadow-primary/20 transition-colors hover:bg-primary/90 sm:w-auto">
                    Guardar Producto
                </button>
            </footer>
        </form>
    </div>
</div>

<!-- Modal: Editar Producto -->
<div id="modal-editar-producto" class="fixed inset-0 z-50 hidden items-center justify-center p-4 sm:p-6">
    <div class="absolute inset-0 bg-slate-900/80 backdrop-blur-sm" data-prod-edit-modal-close></div>
    <div class="relative flex max-h-[92vh] w-full max-w-5xl flex-col overflow-hidden rounded-2xl border border-slate-800 bg-[#111827] shadow-2xl">

        <header class="border-b border-slate-800 px-6 py-5 flex items-center justify-between">
            <div>
                <h2 class="text-xl font-bold text-white">Editar Producto</h2>
                <p class="text-sm text-slate-400 mt-0.5">Modificá los datos del producto sin salir del catálogo.</p>
            </div>
            <button type="button" data-prod-edit-modal-close class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-slate-400 transition-colors hover:bg-slate-800">
                <span class="material-symbols-outlined">close</span>
            </button>
        </header>

        <form id="form-editar-producto" method="post" action="/Producto/EditAjax/0"
              class="flex flex-col flex-1 overflow-hidden">
            @Html.AntiForgeryToken()
            <input type="hidden" id="prod-edit-id" name="Id" value="" />
            <input type="hidden" id="prod-edit-rowversion" name="RowVersion" value="" />

            <div class="flex-1 overflow-y-auto p-6 space-y-8">

                <!-- Validation Summary -->
                <div id="prod-edit-validation-summary" class="hidden bg-red-500/10 border border-red-500/20 rounded-lg p-4 flex gap-3">
                    <span class="material-symbols-outlined text-red-500">error</span>
                    <div>
                        <h4 class="text-sm font-bold text-red-500">Errores de validación</h4>
                        <p id="prod-edit-validation-text" class="text-xs text-red-400/80 mt-1"></p>
                    </div>
                </div>

                <!-- Información Básica -->
                <section>
                    <div class="flex items-center gap-2 mb-4 border-l-4 border-primary pl-3">
                        <h3 class="text-lg font-semibold text-white">Información Básica</h3>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-300">Código</label>
                            <input id="prod-edit-codigo" name="Codigo" type="text" class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-colors text-white" />
                            <span data-valmsg-for="Codigo" class="text-xs text-red-500 hidden"></span>
                        </div>
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-300">Nombre</label>
                            <input id="prod-edit-nombre" name="Nombre" type="text" class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-colors text-white" />
                            <span data-valmsg-for="Nombre" class="text-xs text-red-500 hidden"></span>
                        </div>
                        <div class="md:col-span-2 space-y-1">
                            <label class="text-sm font-medium text-slate-300">Descripción</label>
                            <textarea id="prod-edit-descripcion" name="Descripcion" rows="2" class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-colors text-white"></textarea>
                        </div>
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-300">Categoría</label>
                            <select id="prod-edit-categoriaId" name="CategoriaId" class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary outline-none text-white">
                                <option value="">Seleccionar categoría</option>
                            </select>
                            <span data-valmsg-for="CategoriaId" class="text-xs text-red-500 hidden"></span>
                        </div>
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-300">Subcategoría</label>
                            <select id="prod-edit-subcategoriaId" name="SubcategoriaId" class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary outline-none text-white">
                                <option value="">Sin subcategoría</option>
                            </select>
                        </div>
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-300">Marca</label>
                            <select id="prod-edit-marcaId" name="MarcaId" class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary outline-none text-white">
                                <option value="">Seleccionar marca</option>
                            </select>
                            <span data-valmsg-for="MarcaId" class="text-xs text-red-500 hidden"></span>
                        </div>
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-300">Submarca</label>
                            <select id="prod-edit-submarcaId" name="SubmarcaId" class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary outline-none text-white">
                                <option value="">Sin submarca</option>
                            </select>
                        </div>
                    </div>
                </section>

                <!-- Precios -->
                <section>
                    <div class="flex items-center gap-2 mb-4 border-l-4 border-primary pl-3">
                        <h3 class="text-lg font-semibold text-white">Precios</h3>
                    </div>
                    <div id="prod-edit-precio-contexto" class="bg-primary/10 border border-primary/20 rounded-lg p-3 flex gap-3 mb-4">
                        <span class="material-symbols-outlined text-primary">info</span>
                        <p id="prod-edit-precio-contexto-texto" class="text-xs text-slate-300">Este valor se usa como base/fallback. Si el producto tiene precio vigente en una lista, la venta usará el precio de lista.</p>
                    </div>
                    <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-300">Precio de Costo</label>
                            <div class="relative">
                                <span class="absolute left-3 top-2 text-slate-500">$</span>
                                <input id="prod-edit-precioCompra" name="PrecioCompra" type="number" step="0.01" min="0" class="w-full bg-slate-900 border border-slate-700 rounded-lg pl-7 pr-4 py-2 focus:ring-2 focus:ring-primary outline-none text-white" />
                            </div>
                        </div>
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-300">Precio base sin IVA</label>
                            <div class="relative">
                                <span class="absolute left-3 top-2 text-slate-500">$</span>
                                <input id="prod-edit-precioVenta" name="PrecioVenta" type="number" step="0.01" min="0" class="w-full bg-slate-900 border border-slate-700 rounded-lg pl-7 pr-4 py-2 focus:ring-2 focus:ring-primary outline-none text-white" />
                            </div>
                            <span data-valmsg-for="PrecioVenta" class="text-xs text-red-500 hidden"></span>
                        </div>
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-300">Alícuota IVA</label>
                            <select id="prod-edit-alicuotaIVAId" name="AlicuotaIVAId" class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary outline-none text-white">
                                <option value="">— Sin alícuota —</option>
                                @if (ViewBag.AlicuotasIVADatos != null)
                                {
                                    foreach (var a in ViewBag.AlicuotasIVADatos)
                                    {
                                        <option value="@a.Id" data-porcentaje="@a.Porcentaje">@a.Texto</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-300">% IVA (fallback)</label>
                            <select id="prod-edit-porcentajeIVA" name="PorcentajeIVA" class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary outline-none text-white">
                                <option value="21">21%</option>
                                <option value="10.5">10.5%</option>
                                <option value="27">27%</option>
                                <option value="0">0%</option>
                            </select>
                        </div>
                        <input type="hidden" id="prod-edit-comisionPorcentaje" name="ComisionPorcentaje" value="0" />
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-300">Precio base final con IVA</label>
                            <div class="relative">
                                <span class="absolute left-3 top-2 text-primary font-bold">$</span>
                                <input id="prod-edit-precioFinal" type="text" readonly class="w-full bg-primary/5 border border-primary/30 text-primary font-bold rounded-lg pl-7 pr-4 py-2 outline-none" />
                            </div>
                        </div>
                    </div>
                    <div class="mt-4 grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div class="space-y-1">
                            <label class="text-sm font-medium text-slate-300">Máx. cuotas sin interés</label>
                            <input id="prod-edit-maxCuotasSinInteres" name="MaxCuotasSinInteresPermitidas" type="number" min="1" max="60"
                                   class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary outline-none text-white"
                                   placeholder="Sin restricción" />
                            <span data-valmsg-for="MaxCuotasSinInteresPermitidas" class="text-xs text-red-500 hidden"></span>
                            <p class="text-xs text-slate-500">Vacío = usa el máximo de la tarjeta. Solo aplica a tarjetas sin interés.</p>
                        </div>
                    </div>
                </section>

                <!-- Características -->
                <section>
                    <div class="flex items-center justify-between mb-4">
                        <div class="flex items-center gap-2 border-l-4 border-primary pl-3">
                            <h3 class="text-lg font-semibold text-white">Características</h3>
                        </div>
                        <span id="prod-edit-caracteristicas-count" class="inline-flex items-center rounded-full bg-slate-800 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.16em] text-slate-300">0 cargadas</span>
                    </div>
                    <div class="overflow-hidden rounded-lg border border-slate-800">
                        <table class="w-full border-collapse text-left text-sm">
                            <thead class="bg-slate-800/50">
                                <tr>
                                    <th class="px-4 py-3 font-semibold text-slate-300">Característica</th>
                                    <th class="px-4 py-3 font-semibold text-slate-300">Valor</th>
                                    <th class="px-4 py-3 w-16 text-center font-semibold text-slate-300"></th>
                                </tr>
                            </thead>
                            <tbody id="prod-edit-caracteristicas-body" class="divide-y divide-slate-800"></tbody>
                            <tfoot>
                                <tr class="bg-slate-900/30 border-t border-slate-800">
                                    <td class="px-4 py-2">
                                        <input id="prod-edit-caract-nombre" type="text" class="w-full border-none bg-transparent text-xs text-white placeholder-slate-500 focus:ring-0 outline-none" placeholder="Nueva característica" />
                                    </td>
                                    <td class="px-4 py-2">
                                        <input id="prod-edit-caract-valor" type="text" class="w-full border-none bg-transparent text-xs text-white placeholder-slate-500 focus:ring-0 outline-none" placeholder="Valor" />
                                    </td>
                                    <td class="px-4 py-2 text-center">
                                        <button type="button" data-prod-edit-add-caract class="inline-flex items-center justify-center rounded bg-primary/20 text-primary hover:bg-primary/30 transition-colors w-7 h-7">
                                            <span class="material-symbols-outlined text-sm">add</span>
                                        </button>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </section>

                <!-- Stock & Estado -->
                <section>
                    <div class="flex items-center gap-2 mb-4 border-l-4 border-primary pl-3">
                        <h3 class="text-lg font-semibold text-white">Stock &amp; Estado</h3>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">
                        <div class="grid grid-cols-2 gap-4">
                            <div class="space-y-1">
                                <label class="text-sm font-medium text-slate-300">Stock Actual</label>
                                <input id="prod-edit-stockActual" name="StockActual" type="number" min="0" step="1" class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary outline-none text-white" />
                            </div>
                            <div class="space-y-1">
                                <label class="text-sm font-medium text-slate-300">Stock Mínimo</label>
                                <input id="prod-edit-stockMinimo" name="StockMinimo" type="number" min="0" step="1" class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary outline-none text-white" />
                            </div>
                        </div>
                        <div class="flex items-center justify-between p-4 bg-slate-800/30 rounded-lg border border-slate-800">
                            <div>
                                <p class="text-sm font-bold text-white">Producto Activo</p>
                                <p class="text-xs text-slate-400">Habilitar este producto para la venta</p>
                            </div>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input id="prod-edit-activo" name="Activo" type="checkbox" value="true" class="sr-only peer" />
                                <div class="w-11 h-6 bg-slate-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-600 after:border after:rounded-full after:h-5 after:w-5 after:transition-colors peer-checked:bg-primary"></div>
                            </label>
                        </div>
                    </div>
                </section>

            </div>

            <footer class="grid gap-3 border-t border-slate-800 bg-slate-900/50 px-6 py-4 sm:flex sm:items-center sm:justify-end">
                <button type="button" data-prod-edit-modal-close class="inline-flex w-full items-center justify-center px-6 py-2.5 text-sm font-semibold text-slate-400 transition-colors hover:text-white sm:w-auto">
                    Cancelar
                </button>
                <button type="submit" id="btn-guardar-producto-edit" class="inline-flex w-full items-center justify-center gap-2 rounded-lg bg-primary px-8 py-2.5 text-sm font-bold text-white shadow-lg shadow-primary/20 transition-colors hover:bg-primary/90 sm:w-auto">
                    <span class="material-symbols-outlined text-base">save</span>
                    Guardar Cambios
                </button>
            </footer>
        </form>
    </div>
</div>

<!-- Modal: Nueva Categoría -->
<div id="modal-nueva-categoria" class="fixed inset-0 z-50 hidden items-center justify-center p-4 sm:p-6">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-slate-900/80 backdrop-blur-sm" data-catalogo-modal-close="categoria"></div>

    <!-- Modal Container -->
    <div class="relative w-full max-w-3xl max-h-[90vh] overflow-hidden bg-[#111827] rounded-xl shadow-2xl border border-slate-800 flex flex-col">

        <!-- Header -->
        <header class="flex items-center justify-between border-b border-slate-800 px-6 py-4">
            <div class="flex flex-col">
                <div class="flex items-center gap-2 text-xs font-medium text-slate-400 mb-1">
                    <span>Inventario</span>
                    <span class="material-symbols-outlined text-sm">chevron_right</span>
                    <span class="text-primary">Categorías</span>
                </div>
                <h2 class="text-xl font-bold text-white">Nueva Categoría</h2>
                <p class="text-sm text-slate-400">Administra las categorías de tus productos para organizar mejor tu inventario.</p>
            </div>
            <button type="button" data-catalogo-modal-close="categoria" class="p-2 hover:bg-slate-800 rounded-full transition-colors text-slate-400">
                <span class="material-symbols-outlined">close</span>
            </button>
        </header>

        <!-- Form -->
        <form id="form-nueva-categoria" method="post" asp-controller="Categoria" asp-action="CreateAjax">
            @Html.AntiForgeryToken()

            <!-- Scrollable Content -->
            <div class="flex-1 overflow-y-auto p-6 space-y-6 modal-scroll-90-140">

                <!-- Validation Summary -->
                <div id="cat-modal-validation-summary" class="hidden bg-red-500/10 border border-red-500/20 rounded-lg p-4 flex gap-3">
                    <span class="material-symbols-outlined text-red-500">error</span>
                    <div>
