                            <input name="Codigo" type="text"
                                   class="rounded-lg border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-white focus:ring-primary focus:border-primary transition-all"
                                   placeholder="Ej: CAT-001" />
                            <span data-valmsg-for="Codigo" class="text-xs text-red-500 hidden"></span>
                        </div>
                        <div class="flex flex-col gap-2">
                            <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Nombre</label>
                            <input name="Nombre" type="text"
                                   class="rounded-lg border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-white focus:ring-primary focus:border-primary transition-all"
                                   placeholder="Nombre de la categoría" />
                            <span data-valmsg-for="Nombre" class="text-xs text-red-500 hidden"></span>
                        </div>
                        <div class="flex flex-col gap-2 md:col-span-2">
                            <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Descripción</label>
                            <textarea name="Descripcion" rows="3"
                                      class="rounded-lg border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-white focus:ring-primary focus:border-primary transition-all"
                                      placeholder="Añade una descripción detallada..."></textarea>
                        </div>
                        <div class="flex flex-col gap-2 md:col-span-2">
                            <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Categoría Padre</label>
                            <select name="ParentId" id="cat-modal-parentId"
                                    class="rounded-lg border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-white focus:ring-primary focus:border-primary transition-all">
                                <option value="">Ninguna (Categoría Principal)</option>
                                @if (Model.CategoriasFiltro != null)
                                {
                                    @foreach (var cat in Model.CategoriasFiltro)
                                    {
                                        <option value="@cat.Value">@cat.Text</option>
                                    }
                                }
                            </select>
                            <p class="text-xs text-slate-500 dark:text-slate-400 italic">Selecciona una categoría superior si esta es una subcategoría</p>
                        </div>
                    </div>
                </div>

                <!-- Section: Opciones -->
                <div class="bg-white dark:bg-slate-900/50 rounded-xl border border-slate-200 dark:border-slate-800 p-6">
                    <div class="flex items-center gap-2 mb-6 border-b border-slate-100 dark:border-slate-800 pb-4">
                        <span class="material-symbols-outlined text-primary">settings</span>
                        <h3 class="text-slate-900 dark:text-white text-xl font-bold">Opciones</h3>
                    </div>
                    <div class="space-y-6">
                        <div class="flex items-start justify-between gap-4">
                            <div class="flex flex-col gap-1">
                                <p class="text-sm font-semibold text-slate-700 dark:text-slate-300">Control de serie por defecto</p>
                                <p class="text-xs text-slate-500 dark:text-slate-400">Activa esto si los productos de esta categoría requieren control de número de serie</p>
                            </div>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input name="ControlSerieDefault" type="checkbox" value="true" class="sr-only peer" />
                                <div class="w-11 h-6 bg-slate-300 dark:bg-slate-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                            </label>
                        </div>
                        <div class="flex items-start justify-between gap-4">
                            <div class="flex flex-col gap-1">
                                <p class="text-sm font-semibold text-slate-700 dark:text-slate-300">Activo</p>
                                <p class="text-xs text-slate-500 dark:text-slate-400">Define si esta categoría está disponible para ser usada en el sistema</p>
                            </div>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input name="Activo" type="checkbox" value="true" checked class="sr-only peer" />
                                <div class="w-11 h-6 bg-slate-300 dark:bg-slate-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <footer class="flex items-center justify-end gap-3 px-6 py-4 border-t border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50">
                <button type="button" onclick="CategoriaModal.close()"
                        class="px-6 py-2.5 rounded-lg border border-slate-200 dark:border-slate-800 text-slate-700 dark:text-slate-300 font-bold text-sm hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                    Cancelar
                </button>
                <button type="submit" id="btn-guardar-categoria"
                        class="px-6 py-2.5 rounded-lg bg-primary text-white font-bold text-sm hover:bg-primary/90 shadow-lg shadow-primary/20 transition-all flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">save</span>
                    Guardar Categoría
                </button>
            </footer>
        </form>
    </div>
</div>

<!-- Modal: Nueva Marca -->
<div id="modal-nueva-marca" class="fixed inset-0 z-50 hidden items-center justify-center p-4 sm:p-6">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-slate-900/80 backdrop-blur-sm" onclick="MarcaModal.close()"></div>

    <!-- Modal Container -->
    <div class="relative w-full max-w-2xl max-h-[90vh] overflow-hidden bg-white dark:bg-[#111827] rounded-xl shadow-2xl border border-slate-200 dark:border-slate-800 flex flex-col">

        <!-- Header -->
        <header class="flex items-center justify-between border-b border-slate-200 dark:border-slate-800 px-6 py-4">
            <div class="flex flex-col">
                <div class="flex items-center gap-2 text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">
                    <span>Inventario</span>
                    <span class="material-symbols-outlined text-sm">chevron_right</span>
                    <span class="text-primary">Marcas</span>
                </div>
                <h2 class="text-xl font-bold text-slate-900 dark:text-white">Nueva Marca</h2>
                <p class="text-sm text-slate-500 dark:text-slate-400">Registra una nueva marca o submarca en el sistema.</p>
            </div>
            <button type="button" onclick="MarcaModal.close()" class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-full transition-colors text-slate-400">
                <span class="material-symbols-outlined">close</span>
            </button>
        </header>

        <!-- Form -->
        <form id="form-nueva-marca" method="post" asp-controller="Marca" asp-action="CreateAjax">
            @Html.AntiForgeryToken()

            <!-- Scrollable Content -->
            <div class="flex-1 overflow-y-auto p-6 space-y-6" style="max-height: calc(90vh - 140px);">

                <!-- Validation Summary -->
                <div id="marca-modal-validation-summary" class="hidden bg-red-500/10 border border-red-500/20 rounded-lg p-4 flex gap-3">
                    <span class="material-symbols-outlined text-red-500">error</span>
                    <div>
                        <h4 class="text-sm font-bold text-red-500">Errores de validación</h4>
                        <p id="marca-modal-validation-text" class="text-xs text-red-400/80 mt-1"></p>
                    </div>
                </div>

                <!-- Section: Datos de la marca -->
                <div class="bg-white dark:bg-slate-900/50 rounded-xl border border-slate-200 dark:border-slate-800 p-6">
                    <div class="flex items-center gap-2 mb-6 border-b border-slate-100 dark:border-slate-800 pb-4">
                        <span class="material-symbols-outlined text-primary">branding_watermark</span>
                        <h3 class="text-slate-900 dark:text-white text-xl font-bold">Datos de la marca</h3>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="flex flex-col gap-2">
                            <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Código</label>
                            <input name="Codigo" type="text"
                                   class="rounded-lg border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-white focus:ring-primary focus:border-primary transition-all"
                                   placeholder="Ej: SAM" />
                            <span data-valmsg-for="Codigo" class="text-xs text-red-500 hidden"></span>
                        </div>
                        <div class="flex flex-col gap-2">
                            <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Nombre</label>
                            <input name="Nombre" type="text"
                                   class="rounded-lg border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-white focus:ring-primary focus:border-primary transition-all"
                                   placeholder="Nombre de la marca" />
                            <span data-valmsg-for="Nombre" class="text-xs text-red-500 hidden"></span>
                        </div>
                        <div class="flex flex-col gap-2 md:col-span-2">
                            <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Marca Padre (Submarca de)</label>
                            <select name="ParentId" id="marca-modal-parentId"
                                    class="rounded-lg border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-white focus:ring-primary focus:border-primary transition-all">
                                <option value="">Ninguna (Marca Principal)</option>
                                @if (Model.MarcasFiltro != null)
                                {
                                    @foreach (var m in Model.MarcasFiltro)
                                    {
                                        <option value="@m.Value">@m.Text</option>
                                    }
                                }
                            </select>
                            <p class="text-xs text-slate-500 dark:text-slate-400 italic">Selecciona una marca superior si esta es una submarca</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <footer class="flex items-center justify-end gap-3 px-6 py-4 border-t border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50">
                <button type="button" onclick="MarcaModal.close()"
                        class="px-6 py-2.5 rounded-lg border border-slate-200 dark:border-slate-800 text-slate-700 dark:text-slate-300 font-bold text-sm hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                    Cancelar
                </button>
                <button type="submit" id="btn-guardar-marca"
                        class="px-6 py-2.5 rounded-lg bg-primary text-white font-bold text-sm hover:bg-primary/90 shadow-lg shadow-primary/20 transition-all flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">save</span>
                    Guardar Marca
                </button>
            </footer>
        </form>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════
     MODAL: Historial de Cambios de Precio (por producto)
     ═══════════════════════════════════════════════════════════════ -->
<div id="modal-historial-precio" class="fixed inset-0 z-50 hidden">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="HistorialPrecioModal.close()"></div>

    <!-- Panel -->
    <div class="absolute right-0 top-0 h-full w-full max-w-5xl bg-white dark:bg-[#161d2c] shadow-2xl flex flex-col animate-slide-in-right">
        <!-- Header -->
        <header class="flex items-center justify-between px-8 py-6 border-b border-slate-200 dark:border-slate-800">
            <div class="flex items-center gap-4">
                <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 text-primary">
                    <span class="material-symbols-outlined text-2xl">history</span>
                </div>
                <div>
                    <h2 class="text-xl font-bold tracking-tight dark:text-white">Historial de Cambios de Precio</h2>
                    <div class="flex items-center gap-2 mt-1">
                        <span id="historial-producto-nombre" class="text-sm font-medium text-slate-500 dark:text-slate-400"></span>
                        <span id="historial-producto-codigo" class="text-xs px-2 py-0.5 rounded bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-500 font-mono"></span>
                    </div>
                </div>
            </div>
            <button type="button" onclick="HistorialPrecioModal.close()" class="group flex items-center justify-center h-10 w-10 rounded-full hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                <span class="material-symbols-outlined text-slate-500 group-hover:text-slate-900 dark:group-hover:text-white">close</span>
            </button>
        </header>

        <!-- Table Content -->
        <div class="flex-1 overflow-x-auto overflow-y-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 dark:bg-[#1c2536] text-slate-600 dark:text-slate-400 uppercase text-[11px] font-bold tracking-wider">
                        <th class="px-8 py-4">Fecha y Hora</th>
                        <th class="px-6 py-4">Usuario</th>
                        <th class="px-6 py-4">Motivo</th>
                        <th class="px-6 py-4 text-right">Precio Ant.</th>
                        <th class="px-6 py-4 text-right">Precio Nuevo</th>
                        <th class="px-6 py-4 text-center">Variación</th>
                        <th class="px-8 py-4 text-right">Acción</th>
                    </tr>
                </thead>
                <tbody id="historial-precio-tbody" class="divide-y divide-slate-100 dark:divide-slate-800">
                    <!-- Rows populated by JS -->
                </tbody>
            </table>

            <!-- Loading -->
            <div id="historial-precio-loading" class="hidden py-16 text-center">
                <div class="w-8 h-8 border-3 border-primary border-t-transparent rounded-full animate-spin mx-auto mb-3"></div>
                <span class="text-sm text-slate-500 dark:text-slate-400">Cargando historial...</span>
            </div>

            <!-- Empty state -->
            <div id="historial-precio-empty" class="hidden py-16 text-center">
                <span class="material-symbols-outlined text-4xl text-slate-300 dark:text-slate-600 mb-2 block">info</span>
                <p class="text-sm font-bold text-slate-500 dark:text-slate-400">No hay cambios de precio registrados</p>
            </div>
        </div>

        <!-- Footer -->
        <footer class="flex items-center justify-end gap-3 px-8 py-6 border-t border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-[#131a27]">
            <button type="button" onclick="HistorialPrecioModal.close()"
                    class="px-8 h-11 rounded-lg bg-primary text-white text-sm font-bold shadow-lg shadow-primary/20 hover:brightness-110 active:scale-95 transition-all">
                Cerrar
            </button>
        </footer>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════
     MODAL: Aumento de Precios (3 pasos: Alcance → Configuración → Vista previa)
     ═══════════════════════════════════════════════════════════════ -->
<div id="modal-aumento-precios" class="fixed inset-0 z-50 hidden">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="PrecioModal.close()"></div>

    <!-- Panel -->
    <div class="absolute right-0 top-0 h-full w-full max-w-2xl bg-white dark:bg-slate-950 shadow-2xl flex flex-col animate-slide-in-right">
        <!-- Header -->
        <header class="flex items-center justify-between px-6 py-4 border-b border-slate-200 dark:border-slate-800">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-amber-500/10 rounded-xl flex items-center justify-center">
                        <span class="material-symbols-outlined text-amber-500">trending_up</span>
                    </div>
                    <div>
                        <h2 class="text-lg font-bold text-slate-900 dark:text-white">Aumento de Precios</h2>
                        <p class="text-xs text-slate-500 dark:text-slate-400">Ajuste masivo por selección, categoría, marca o todo el catálogo</p>
                    </div>
                </div>
            <button type="button" onclick="PrecioModal.close()" class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-full transition-colors text-slate-400">
                <span class="material-symbols-outlined">close</span>
            </button>
        </header>

        <!-- Step Indicator -->
        <div class="flex items-center gap-0 px-6 py-3 bg-slate-50 dark:bg-slate-900/50 border-b border-slate-200 dark:border-slate-800">
            <div id="step-ind-1" class="flex items-center gap-2">
                <span class="w-7 h-7 rounded-full bg-primary text-white text-xs font-bold flex items-center justify-center">1</span>
                <span class="text-xs font-bold text-primary">Alcance</span>
            </div>
            <div class="flex-1 h-px bg-slate-200 dark:bg-slate-700 mx-3"></div>
            <div id="step-ind-2" class="flex items-center gap-2">
                <span class="w-7 h-7 rounded-full bg-slate-200 dark:bg-slate-700 text-slate-500 dark:text-slate-400 text-xs font-bold flex items-center justify-center">2</span>
                <span class="text-xs font-medium text-slate-400 dark:text-slate-500">Configuración</span>
            </div>
            <div class="flex-1 h-px bg-slate-200 dark:bg-slate-700 mx-3"></div>
            <div id="step-ind-3" class="flex items-center gap-2">
                <span class="w-7 h-7 rounded-full bg-slate-200 dark:bg-slate-700 text-slate-500 dark:text-slate-400 text-xs font-bold flex items-center justify-center">3</span>
                <span class="text-xs font-medium text-slate-400 dark:text-slate-500">Vista previa</span>
            </div>
        </div>

        <!-- Scrollable Content -->
        <div class="flex-1 overflow-y-auto p-6" style="max-height: calc(90vh - 200px);">

            <!-- Validation Summary -->
            <div id="precio-modal-validation-summary" class="hidden bg-red-500/10 border border-red-500/20 rounded-lg p-4 flex gap-3 mb-6">
                <span class="material-symbols-outlined text-red-500">error</span>
                <div>
                    <h4 class="text-sm font-bold text-red-500">Error</h4>
                    <p id="precio-modal-validation-text" class="text-xs text-red-400/80 mt-1"></p>
                </div>
            </div>

            <!-- ════ PASO 1: Alcance ════ -->
            <div id="precio-step-1" class="space-y-4">
                <h3 class="text-slate-900 dark:text-white text-base font-bold">¿A qué productos aplicar el ajuste?</h3>
                <div id="precio-selection-summary" class="hidden items-start gap-3 rounded-xl border border-amber-500/20 bg-amber-500/10 px-4 py-3">
                    <span class="material-symbols-outlined text-amber-500">playlist_add_check</span>
                    <div>
                        <span class="block text-sm font-bold text-amber-700 dark:text-amber-400">Hay <span id="precio-selection-summary-count">0</span> productos seleccionados</span>
                        <p class="text-xs text-amber-700/80 dark:text-amber-400/80 mt-0.5">Se va a sugerir esa selección como alcance inicial, pero podés cambiarlo antes de aplicar el ajuste.</p>
                    </div>
                </div>
                <div class="grid grid-cols-1 gap-3">
                    <!-- Radio Card: Seleccionados -->
                    <label id="precio-scope-seleccionados" class="precio-scope-card group flex items-center gap-4 p-4 rounded-xl border-2 border-dashed border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900/50 cursor-not-allowed opacity-60 transition-all">
                        <input type="radio" name="precio-scope" value="seleccionados" class="hidden" disabled />
                        <div class="w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center shrink-0">
                            <span class="material-symbols-outlined text-amber-500">checklist</span>
                        </div>
                        <div class="flex-1">
                            <div class="flex flex-wrap items-center gap-2">
                                <span class="text-sm font-bold text-slate-900 dark:text-white">Productos seleccionados (<span id="precio-scope-sel-count">0</span>)</span>
                                <span id="precio-scope-sel-badge" class="hidden rounded-full bg-amber-500/15 px-2 py-0.5 text-[10px] font-black uppercase tracking-wider text-amber-600 dark:text-amber-400">Recomendado</span>
                            </div>
                            <p id="precio-scope-sel-helper" class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">Seleccioná productos en la tabla para habilitar esta opción</p>
                        </div>
                        <span class="w-5 h-5 rounded-full border-2 border-slate-300 dark:border-slate-600 group-[.selected]:border-primary group-[.selected]:bg-primary flex items-center justify-center transition-all">
                            <span class="w-2 h-2 rounded-full bg-white scale-0 group-[.selected]:scale-100 transition-transform"></span>
                        </span>
                    </label>

                    <!-- Radio Card: Todos -->
                    <label class="precio-scope-card group flex items-center gap-4 p-4 rounded-xl border-2 border-slate-200 dark:border-slate-700 hover:border-primary/50 cursor-pointer transition-all bg-white dark:bg-slate-900/50">
                        <input type="radio" name="precio-scope" value="todos" class="hidden" checked />
                        <div class="w-10 h-10 rounded-xl bg-blue-500/10 flex items-center justify-center shrink-0">
                            <span class="material-symbols-outlined text-blue-500">select_all</span>
                        </div>
                        <div class="flex-1">
                            <span class="text-sm font-bold text-slate-900 dark:text-white">Todos los productos</span>
                            <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">Aplicar ajuste a todo el catálogo activo</p>
                        </div>
                        <span class="w-5 h-5 rounded-full border-2 border-slate-300 dark:border-slate-600 group-[.selected]:border-primary group-[.selected]:bg-primary flex items-center justify-center transition-all">
                            <span class="w-2 h-2 rounded-full bg-white scale-0 group-[.selected]:scale-100 transition-transform"></span>
                        </span>
                    </label>

                    <!-- Radio Card: Categoría -->
                    <label class="precio-scope-card group flex items-center gap-4 p-4 rounded-xl border-2 border-slate-200 dark:border-slate-700 hover:border-primary/50 cursor-pointer transition-all bg-white dark:bg-slate-900/50">
                        <input type="radio" name="precio-scope" value="categoria" class="hidden" />
                        <div class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center shrink-0">
                            <span class="material-symbols-outlined text-emerald-500">category</span>
                        </div>
                        <div class="flex-1">
                            <span class="text-sm font-bold text-slate-900 dark:text-white">Categoría específica</span>
                            <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">Aplicar ajuste a una categoría</p>
                        </div>
                        <span class="w-5 h-5 rounded-full border-2 border-slate-300 dark:border-slate-600 group-[.selected]:border-primary group-[.selected]:bg-primary flex items-center justify-center transition-all">
                            <span class="w-2 h-2 rounded-full bg-white scale-0 group-[.selected]:scale-100 transition-transform"></span>
                        </span>
                    </label>
                    <!-- Category Dropdown (hidden by default) -->
                    <div id="precio-cat-select-wrapper" class="hidden pl-14">
                        <select id="precio-categoria-id"
                                class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-white focus:ring-primary focus:border-primary transition-all text-sm">
                            <option value="">Seleccionar categoría...</option>
                            @if (Model.CategoriasFiltro != null)
                            {
                                @foreach (var c in Model.CategoriasFiltro)
                                {
                                    <option value="@c.Value">@c.Text</option>
                                }
                            }
                        </select>
                    </div>

                    <!-- Radio Card: Marca -->
                    <label class="precio-scope-card group flex items-center gap-4 p-4 rounded-xl border-2 border-slate-200 dark:border-slate-700 hover:border-primary/50 cursor-pointer transition-all bg-white dark:bg-slate-900/50">
                        <input type="radio" name="precio-scope" value="marca" class="hidden" />
                        <div class="w-10 h-10 rounded-xl bg-purple-500/10 flex items-center justify-center shrink-0">
                            <span class="material-symbols-outlined text-purple-500">branding_watermark</span>
                        </div>
                        <div class="flex-1">
                            <span class="text-sm font-bold text-slate-900 dark:text-white">Marca específica</span>
                            <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">Aplicar ajuste a una marca</p>
                        </div>
                        <span class="w-5 h-5 rounded-full border-2 border-slate-300 dark:border-slate-600 group-[.selected]:border-primary group-[.selected]:bg-primary flex items-center justify-center transition-all">
                            <span class="w-2 h-2 rounded-full bg-white scale-0 group-[.selected]:scale-100 transition-transform"></span>
                        </span>
                    </label>
                    <!-- Brand Dropdown (hidden by default) -->
                    <div id="precio-marca-select-wrapper" class="hidden pl-14">
                        <select id="precio-marca-id"
                                class="w-full rounded-lg border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-white focus:ring-primary focus:border-primary transition-all text-sm">
                            <option value="">Seleccionar marca...</option>
                            @if (Model.MarcasFiltro != null)
                            {
                                @foreach (var m in Model.MarcasFiltro)
                                {
                                    <option value="@m.Value">@m.Text</option>
                                }
                            }
                        </select>
                    </div>
                </div>
            </div>

            <!-- ════ PASO 2: Configuración ════ -->
            <div id="precio-step-2" class="hidden space-y-6">
                <div class="bg-white dark:bg-slate-900/50 rounded-xl border border-slate-200 dark:border-slate-800 p-6 space-y-5">
                    <div class="flex items-center gap-2 mb-2 border-b border-slate-100 dark:border-slate-800 pb-4">
                        <span class="material-symbols-outlined text-primary">tune</span>
                        <h3 class="text-slate-900 dark:text-white text-base font-bold">Configuración del ajuste</h3>
                    </div>

                    <!-- Motivo -->
                    <div class="flex flex-col gap-2">
                        <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Motivo del ajuste</label>
                        <select id="precio-motivo"
                                class="rounded-lg border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-white focus:ring-primary focus:border-primary transition-all text-sm">
                            <option value="Ajuste por inflación">Ajuste por inflación</option>
                            <option value="Aumento de costos">Aumento de costos</option>
                            <option value="Ajuste estacional">Ajuste estacional</option>
                            <option value="Promoción">Promoción</option>
                            <option value="Otro">Otro</option>
                        </select>
                    </div>

                    <!-- Tipo de ajuste + Valor -->
                    <div class="grid grid-cols-2 gap-4">
                        <div class="flex flex-col gap-2">
                            <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Tipo de ajuste</label>
                            <div class="flex rounded-lg overflow-hidden border border-slate-200 dark:border-slate-700">
                                <button type="button" id="precio-tipo-porcentaje"
                                        class="flex-1 py-2.5 text-sm font-bold bg-primary text-white transition-colors">
                                    % Porcentaje
                                </button>
                                <button type="button" id="precio-tipo-monto"
                                        class="flex-1 py-2.5 text-sm font-bold bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 transition-colors">
                                    $ Monto fijo
                                </button>
                            </div>
                        </div>
                        <div class="flex flex-col gap-2">
                            <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Valor</label>
                            <div class="relative">
                                <span id="precio-valor-prefix" class="absolute left-3 top-1/2 -translate-y-1/2 text-sm font-bold text-slate-400">%</span>
                                <input type="number" id="precio-valor" step="0.01" min="0"
                                       class="w-full pl-8 rounded-lg border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-white focus:ring-primary focus:border-primary transition-all text-sm"
                                       placeholder="0.00" />
                            </div>
                        </div>
                    </div>

                    <!-- Redondeo -->
                    <div class="flex flex-col gap-2">
                        <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Redondeo</label>
                        <div class="flex gap-3">
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="precio-redondeo" value="none" checked
                                       class="text-primary focus:ring-primary" />
                                <span class="text-sm text-slate-700 dark:text-slate-300">Sin redondeo</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="precio-redondeo" value="entero"
                                       class="text-primary focus:ring-primary" />
                                <span class="text-sm text-slate-700 dark:text-slate-300">Sin decimales</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="precio-redondeo" value="99"
                                       class="text-primary focus:ring-primary" />
                                <span class="text-sm text-slate-700 dark:text-slate-300">Redondear al .99</span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ════ PASO 3: Vista previa ════ -->
            <div id="precio-step-3" class="hidden space-y-4">
                <!-- Summary bar -->
                <div class="flex items-center justify-between bg-amber-500/10 border border-amber-500/20 rounded-xl p-4">
                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-amber-500">info</span>
                        <div>
                            <span id="precio-preview-summary" class="text-sm font-bold text-amber-700 dark:text-amber-400"></span>
                            <p id="precio-preview-detail" class="text-xs text-amber-600/70 dark:text-amber-400/70 mt-0.5"></p>
                        </div>
                    </div>
                </div>

                <!-- Preview table -->
                <div class="bg-white dark:bg-slate-900/50 rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm">
                            <thead>
                                <tr class="bg-slate-50 dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800">
                                    <th class="text-left px-4 py-3 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Producto</th>
                                    <th class="text-right px-4 py-3 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Precio Actual</th>
                                    <th class="text-right px-4 py-3 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Ajuste</th>
                                    <th class="text-right px-4 py-3 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Precio Nuevo</th>
                                </tr>
                            </thead>
                            <tbody id="precio-preview-tbody">
                                <!-- Rows populated by JS -->
                            </tbody>
                        </table>
                    </div>
                    <div id="precio-preview-more" class="hidden px-4 py-3 text-center border-t border-slate-200 dark:border-slate-800">
                        <span class="text-xs text-slate-500 dark:text-slate-400"></span>
                    </div>
                </div>

                <!-- Loading overlay for preview -->
                <div id="precio-preview-loading" class="hidden flex items-center justify-center py-12">
                    <div class="flex flex-col items-center gap-3">
                        <div class="w-8 h-8 border-3 border-primary border-t-transparent rounded-full animate-spin"></div>
                        <span class="text-sm text-slate-500 dark:text-slate-400">Calculando precios...</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <footer class="flex items-center justify-between px-6 py-4 border-t border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50">
            <button type="button" id="precio-btn-back" onclick="PrecioModal.prevStep()" class="hidden px-5 py-2.5 rounded-lg border border-slate-200 dark:border-slate-800 text-slate-700 dark:text-slate-300 font-bold text-sm hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors flex items-center gap-2">
                <span class="material-symbols-outlined text-[16px]">arrow_back</span>
                Anterior
            </button>
            <div class="flex-1"></div>
            <div class="flex items-center gap-3">
                <button type="button" onclick="PrecioModal.close()"
                        class="px-5 py-2.5 rounded-lg border border-slate-200 dark:border-slate-800 text-slate-700 dark:text-slate-300 font-bold text-sm hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                    Cancelar
                </button>
                <button type="button" id="precio-btn-next" onclick="PrecioModal.nextStep()"
                        class="px-5 py-2.5 rounded-lg bg-primary text-white font-bold text-sm hover:bg-primary/90 shadow-lg shadow-primary/20 transition-all flex items-center gap-2">
                    Siguiente
                    <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                </button>
                <button type="button" id="precio-btn-apply" onclick="PrecioModal.apply()"
                        class="hidden px-5 py-2.5 rounded-lg bg-amber-500 text-white font-bold text-sm hover:bg-amber-600 shadow-lg shadow-amber-500/20 transition-all flex items-center gap-2">
                    <span class="material-symbols-outlined text-[16px]">check</span>
                    Aplicar Aumento
                </button>
            </div>
        </footer>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════════ -->
<!-- Modal: Movimientos de Inventario                                 -->
<!-- ══════════════════════════════════════════════════════════════════ -->
<div id="modal-movimientos" class="hidden fixed inset-0 z-[60] flex items-start justify-center overflow-y-auto bg-black/50 backdrop-blur-sm p-4 md:p-8">
    <div class="bg-background-light dark:bg-background-dark rounded-2xl w-full max-w-[1280px] shadow-2xl border border-slate-200 dark:border-slate-800 animate-fade-in">

        <!-- Modal Header -->
        <div class="flex flex-wrap justify-between items-start gap-4 p-6 pb-0">
            <div class="flex flex-col gap-1">
                <h1 class="text-slate-900 dark:text-white text-3xl font-black leading-tight tracking-tight">Movimientos de Inventario</h1>
                <p class="text-slate-500 dark:text-slate-400 text-base font-normal">Historial completo de entradas, salidas y ajustes de stock.</p>
            </div>
            <button type="button" id="btn-cerrar-movimientos"
                    class="flex items-center justify-center gap-2 rounded-lg h-10 px-4 bg-slate-200 dark:bg-slate-800 text-slate-900 dark:text-white text-sm font-bold transition-colors hover:bg-slate-300 dark:hover:bg-slate-700">
                <span class="material-symbols-outlined text-sm">arrow_back</span>
                <span>Volver al Inventario</span>
            </button>
        </div>

        <!-- Modal Body -->
        <div class="flex flex-col gap-6 p-6">

            <!-- Stats Summary -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                <div class="flex flex-col gap-2 rounded-xl p-6 border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/50">
                    <p class="text-slate-500 dark:text-slate-400 text-sm font-medium">Total Movimientos (Hoy)</p>
                    <div class="flex items-baseline gap-2">
                        <p class="text-slate-900 dark:text-white text-2xl font-bold" id="mov-stat-total">0</p>
                    </div>
                </div>
                <div class="flex flex-col gap-2 rounded-xl p-6 border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/50">
                    <p class="text-slate-500 dark:text-slate-400 text-sm font-medium">Entradas (Unidades)</p>
                    <div class="flex items-baseline gap-2">
                        <p class="text-slate-900 dark:text-white text-2xl font-bold" id="mov-stat-entradas">0</p>
                    </div>
                </div>
                <div class="flex flex-col gap-2 rounded-xl p-6 border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/50">
                    <p class="text-slate-500 dark:text-slate-400 text-sm font-medium">Salidas (Unidades)</p>
                    <div class="flex items-baseline gap-2">
                        <p class="text-slate-900 dark:text-white text-2xl font-bold" id="mov-stat-salidas">0</p>
                    </div>
                </div>
                <div class="flex flex-col gap-2 rounded-xl p-6 border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/50">
                    <p class="text-slate-500 dark:text-slate-400 text-sm font-medium">Ajustes</p>
                    <div class="flex items-baseline gap-2">
                        <p class="text-slate-900 dark:text-white text-2xl font-bold" id="mov-stat-ajustes">0</p>
                    </div>
                </div>
            </div>

            <!-- Filters Section -->
            <div class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/50 p-6">
                <h3 class="text-slate-900 dark:text-white text-lg font-bold mb-4 flex items-center gap-2">
                    <span class="material-symbols-outlined">filter_list</span>
                    Filtros de Búsqueda
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                    <div class="flex flex-col gap-1.5">
                        <label class="text-sm font-medium text-slate-600 dark:text-slate-400">Rango de Fechas</label>
                        <div class="flex items-center gap-2">
                            <input id="mov-fecha-desde" type="date" class="w-full rounded-lg bg-slate-100 dark:bg-slate-800 border-none text-sm focus:ring-2 focus:ring-primary text-slate-900 dark:text-white" />
                            <span class="text-slate-400">-</span>
                            <input id="mov-fecha-hasta" type="date" class="w-full rounded-lg bg-slate-100 dark:bg-slate-800 border-none text-sm focus:ring-2 focus:ring-primary text-slate-900 dark:text-white" />
                        </div>
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <label class="text-sm font-medium text-slate-600 dark:text-slate-400">Tipo de Movimiento</label>
                        <select id="mov-tipo" class="w-full rounded-lg bg-slate-100 dark:bg-slate-800 border-none text-sm focus:ring-2 focus:ring-primary text-slate-900 dark:text-white">
                            <option value="">Todos los tipos</option>
                            <option value="IngresoPorCompra">Ingreso por Compra</option>
                            <option value="EgresoPorVenta">Egreso por Venta</option>
                            <option value="AjustePositivo">Ajuste Positivo</option>
                            <option value="AjusteNegativo">Ajuste Negativo</option>
                            <option value="Devolucion">Devolución</option>
                        </select>
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <label class="text-sm font-medium text-slate-600 dark:text-slate-400">Producto (SKU/Nombre)</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm">search</span>
                            <input id="mov-producto" type="text" class="w-full pl-10 rounded-lg bg-slate-100 dark:bg-slate-800 border-none text-sm focus:ring-2 focus:ring-primary text-slate-900 dark:text-white" placeholder="Ej: CPU-001..." />
                        </div>
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <label class="text-sm font-medium text-slate-600 dark:text-slate-400">Almacén/Ubicación</label>
                        <select id="mov-almacen" class="w-full rounded-lg bg-slate-100 dark:bg-slate-800 border-none text-sm focus:ring-2 focus:ring-primary text-slate-900 dark:text-white">
                            <option>Todos los almacenes</option>
                            <option>Almacén Central</option>
                            <option>Bodega Norte</option>
                            <option>Showroom Principal</option>
                        </select>
                    </div>
                </div>
                <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-slate-200 dark:border-slate-800">
                    <button type="button" id="btn-mov-limpiar" class="px-4 py-2 text-sm font-bold text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">Limpiar</button>
                    <button type="button" id="btn-mov-buscar" class="px-6 py-2 rounded-lg bg-primary text-white text-sm font-bold hover:bg-primary/90 transition-colors">Buscar Movimientos</button>
                </div>
            </div>

            <!-- Actions Bar -->
            <div class="flex justify-between items-center px-2">
                <p class="text-sm text-slate-500 dark:text-slate-400">Mostrando <span class="font-bold text-slate-900 dark:text-white" id="mov-count-showing">0</span> de <span class="font-bold text-slate-900 dark:text-white" id="mov-count-total">0</span> movimientos</p>
                <div class="flex gap-2">
                    <button type="button" class="flex items-center gap-2 px-3 py-1.5 rounded-lg border border-slate-200 dark:border-slate-800 text-xs font-bold hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                        <span class="material-symbols-outlined text-sm">picture_as_pdf</span> PDF
                    </button>
                    <button type="button" class="flex items-center gap-2 px-3 py-1.5 rounded-lg border border-slate-200 dark:border-slate-800 text-xs font-bold hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                        <span class="material-symbols-outlined text-sm">description</span> Excel
                    </button>
                </div>
            </div>

            <!-- Movements Table -->
            <div class="overflow-x-auto rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/50">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="border-b border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-800/30">
                            <th class="px-4 py-4 text-sm font-bold text-slate-700 dark:text-slate-300">Fecha/Hora</th>
                            <th class="px-4 py-4 text-sm font-bold text-slate-700 dark:text-slate-300">Tipo</th>
                            <th class="px-4 py-4 text-sm font-bold text-slate-700 dark:text-slate-300">Producto</th>
                            <th class="px-4 py-4 text-sm font-bold text-slate-700 dark:text-slate-300">Cant.</th>
                            <th class="px-4 py-4 text-sm font-bold text-slate-700 dark:text-slate-300">Referencia</th>
                            <th class="px-4 py-4 text-sm font-bold text-slate-700 dark:text-slate-300">Usuario</th>
                            <th class="px-4 py-4 text-sm font-bold text-slate-700 dark:text-slate-300">Saldo Post.</th>
                            <th class="px-4 py-4 text-sm font-bold text-slate-700 dark:text-slate-300 text-right">Acción</th>
                        </tr>
                    </thead>
                    <tbody id="mov-tbody" class="divide-y divide-slate-100 dark:divide-slate-800">
                        <!-- Rows populated by JS or empty state -->
                        <tr id="mov-empty-state">
                            <td colspan="8" class="py-16 text-center">
                                <div class="flex flex-col items-center gap-2 opacity-40">
                                    <span class="material-symbols-outlined text-4xl">swap_vert</span>
                                    <p class="text-slate-500 dark:text-slate-400 text-base">No hay movimientos para mostrar</p>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="flex items-center justify-between border-t border-slate-200 dark:border-slate-800 pt-6">
                <div class="flex items-center gap-2">
                    <span class="text-sm text-slate-500 dark:text-slate-400">Filas por página:</span>
                    <select id="mov-page-size" class="bg-transparent border-none text-sm font-bold focus:ring-0 text-slate-900 dark:text-white">
                        <option>25</option>
                        <option>50</option>
                        <option>100</option>
                    </select>
                </div>
                <div class="flex items-center gap-1" id="mov-pagination">
                    <!-- Pagination rendered by JS -->
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/catalogo-index.js"></script>
    <script src="~/js/producto-crear-modal.js"></script>
    <script src="~/js/categoria-crear-modal.js"></script>
    <script src="~/js/marca-crear-modal.js"></script>
    <script src="~/js/precio-aumento-modal.js"></script>
    <script src="~/js/historial-precio-modal.js"></script>
    <script src="~/js/movimientos-inventario-modal.js"></script>
}
