@model ClienteViewModel
@{
    ViewData["Title"] = "Nuevo Cliente";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="max-w-4xl mx-auto pb-24">
    <!-- Header -->
    <div class="flex items-center gap-3 mb-6">
        <a asp-action="Index"
           class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors no-underline text-inherit">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div>
            <h1 class="text-2xl font-bold">Nuevo Cliente</h1>
            <p class="text-sm text-slate-500">Registrar un nuevo cliente en el sistema</p>
        </div>
    </div>

    <form asp-action="Create" method="post" id="clienteForm">
        <div asp-validation-summary="ModelOnly"
             class="mb-4 text-sm text-red-500 bg-red-500/10 border border-red-500/20 rounded-lg p-3 empty:hidden"></div>

        @if (returnUrl != null)
        {
            <input type="hidden" name="returnUrl" value="@returnUrl" />
        }

        <div class="space-y-5">

            <!-- ═══════════════ Datos Personales ═══════════════ -->
            <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm section-card" data-section="personal">
                <button type="button" onclick="toggleSection('personal')"
                        class="w-full flex items-center justify-between p-5 text-left">
                    <div class="flex items-center gap-3">
                        <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center">
                            <span class="material-symbols-outlined text-primary text-xl">person</span>
                        </div>
                        <div>
                            <h2 class="text-base font-bold">Datos Personales</h2>
                            <p class="text-xs text-slate-500">Información básica del cliente</p>
                        </div>
                    </div>
                    <span class="material-symbols-outlined text-slate-400 section-chevron transition-transform" id="chevron-personal">expand_more</span>
                </button>
                <div class="px-5 pb-5" id="content-personal">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div>
                            <label asp-for="TipoDocumento" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Tipo Documento *</label>
                            <select asp-for="TipoDocumento" asp-items="@(ViewBag.TiposDocumento as SelectList)"
                                    class="w-full px-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors">
                            </select>
                            <span asp-validation-for="TipoDocumento" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="NumeroDocumento" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Número Documento *</label>
                            <input asp-for="NumeroDocumento" placeholder="Ej: 30456789"
                                   class="w-full px-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                            <span asp-validation-for="NumeroDocumento" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="CuilCuit" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">CUIL/CUIT</label>
                            <input asp-for="CuilCuit" placeholder="Solo números, 11 dígitos" maxlength="11"
                                   class="w-full px-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                            <span asp-validation-for="CuilCuit" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="EstadoCivil" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Estado Civil</label>
                            <select asp-for="EstadoCivil" asp-items="@(ViewBag.EstadosCiviles as SelectList)"
                                    class="w-full px-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors">
                                <option value="">Seleccionar...</option>
                            </select>
                            <span asp-validation-for="EstadoCivil" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="Apellido" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Apellido *</label>
                            <input asp-for="Apellido" placeholder="Apellido del cliente"
                                   class="w-full px-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                            <span asp-validation-for="Apellido" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="Nombre" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Nombre *</label>
                            <input asp-for="Nombre" placeholder="Nombre del cliente"
                                   class="w-full px-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                            <span asp-validation-for="Nombre" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="FechaNacimiento" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Fecha de Nacimiento</label>
                            <input asp-for="FechaNacimiento" type="date"
                                   class="w-full px-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                            <span asp-validation-for="FechaNacimiento" class="text-xs text-red-500 mt-1"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ═══════════════ Datos del Cónyuge ═══════════════ -->
            <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm section-card" data-section="conyuge">
                <button type="button" onclick="toggleSection('conyuge')"
                        class="w-full flex items-center justify-between p-5 text-left">
                    <div class="flex items-center gap-3">
                        <div class="w-9 h-9 rounded-lg bg-pink-500/10 flex items-center justify-center">
                            <span class="material-symbols-outlined text-pink-500 text-xl">favorite</span>
                        </div>
                        <div>
                            <h2 class="text-base font-bold">Datos del Cónyuge</h2>
                            <p class="text-xs text-slate-500">Información del cónyuge o pareja</p>
                        </div>
                    </div>
                    <span class="material-symbols-outlined text-slate-400 section-chevron transition-transform rotate-180" id="chevron-conyuge">expand_more</span>
                </button>
                <div class="px-5 pb-5 hidden" id="content-conyuge">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div class="md:col-span-3">
                            <label asp-for="ConyugeNombreCompleto" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Nombre Completo</label>
                            <input asp-for="ConyugeNombreCompleto" placeholder="Nombre y apellido del cónyuge"
                                   class="w-full px-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                            <span asp-validation-for="ConyugeNombreCompleto" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="ConyugeTipoDocumento" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Tipo Documento</label>
                            <select asp-for="ConyugeTipoDocumento" asp-items="@(ViewBag.TiposDocumento as SelectList)"
                                    class="w-full px-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors">
                                <option value="">Seleccionar...</option>
                            </select>
                            <span asp-validation-for="ConyugeTipoDocumento" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="ConyugeNumeroDocumento" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Número Documento</label>
                            <input asp-for="ConyugeNumeroDocumento" placeholder="Ej: 30456789"
                                   class="w-full px-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                            <span asp-validation-for="ConyugeNumeroDocumento" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="ConyugeTelefono" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Teléfono</label>
                            <input asp-for="ConyugeTelefono" type="tel" placeholder="Ej: 3814567890"
                                   class="w-full px-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                            <span asp-validation-for="ConyugeTelefono" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="ConyugeSueldo" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Sueldo</label>
                            <div class="relative">
                                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm font-bold">$</span>
                                <input asp-for="ConyugeSueldo" step="0.01" placeholder="0.00"
                                       class="w-full pl-7 pr-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm font-bold focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                            </div>
                            <span asp-validation-for="ConyugeSueldo" class="text-xs text-red-500 mt-1"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ═══════════════ Datos de Contacto ═══════════════ -->
            <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm section-card" data-section="contacto">
                <button type="button" onclick="toggleSection('contacto')"
                        class="w-full flex items-center justify-between p-5 text-left">
                    <div class="flex items-center gap-3">
                        <div class="w-9 h-9 rounded-lg bg-green-500/10 flex items-center justify-center">
                            <span class="material-symbols-outlined text-green-500 text-xl">call</span>
                        </div>
                        <div>
                            <h2 class="text-base font-bold">Datos de Contacto</h2>
                            <p class="text-xs text-slate-500">Teléfono, email y dirección</p>
                        </div>
                    </div>
                    <span class="material-symbols-outlined text-slate-400 section-chevron transition-transform" id="chevron-contacto">expand_more</span>
                </button>
                <div class="px-5 pb-5" id="content-contacto">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div>
                            <label asp-for="Telefono" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Teléfono *</label>
                            <input asp-for="Telefono" type="tel" placeholder="Ej: 3814567890"
                                   class="w-full px-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                            <span asp-validation-for="Telefono" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="TelefonoAlternativo" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Teléfono Alternativo</label>
                            <input asp-for="TelefonoAlternativo" type="tel" placeholder="Ej: 3814567890"
                                   class="w-full px-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                            <span asp-validation-for="TelefonoAlternativo" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="Email" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Email</label>
                            <input asp-for="Email" type="email" placeholder="ejemplo@correo.com"
                                   class="w-full px-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                            <span asp-validation-for="Email" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div class="md:col-span-3">
                            <label asp-for="Domicilio" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Domicilio *</label>
                            <input asp-for="Domicilio" placeholder="Calle, número, piso, depto"
                                   class="w-full px-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                            <span asp-validation-for="Domicilio" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="Localidad" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Localidad</label>
                            <input asp-for="Localidad" placeholder="Ej: San Miguel de Tucumán"
                                   class="w-full px-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                            <span asp-validation-for="Localidad" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="Provincia" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Provincia</label>
                            <select asp-for="Provincia" asp-items="@(ViewBag.Provincias as SelectList)"
                                    class="w-full px-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors">
                                <option value="">Seleccionar...</option>
                            </select>
                            <span asp-validation-for="Provincia" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="CodigoPostal" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Código Postal</label>
                            <input asp-for="CodigoPostal" placeholder="Ej: 4000"
                                   class="w-full px-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                            <span asp-validation-for="CodigoPostal" class="text-xs text-red-500 mt-1"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ═══════════════ Datos Laborales ═══════════════ -->
            <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm section-card" data-section="laboral">
                <button type="button" onclick="toggleSection('laboral')"
                        class="w-full flex items-center justify-between p-5 text-left">
                    <div class="flex items-center gap-3">
                        <div class="w-9 h-9 rounded-lg bg-amber-500/10 flex items-center justify-center">
                            <span class="material-symbols-outlined text-amber-500 text-xl">work</span>
                        </div>
                        <div>
                            <h2 class="text-base font-bold">Datos Laborales</h2>
                            <p class="text-xs text-slate-500">Empleo e ingresos del cliente</p>
                        </div>
                    </div>
                    <span class="material-symbols-outlined text-slate-400 section-chevron transition-transform rotate-180" id="chevron-laboral">expand_more</span>
                </button>
                <div class="px-5 pb-5 hidden" id="content-laboral">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div>
                            <label asp-for="Empleador" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Empleador</label>
                            <input asp-for="Empleador" placeholder="Nombre de la empresa"
                                   class="w-full px-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                            <span asp-validation-for="Empleador" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="TipoEmpleo" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Tipo de Empleo</label>
                            <select asp-for="TipoEmpleo" asp-items="@(ViewBag.TiposEmpleo as SelectList)"
                                    class="w-full px-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors">
                                <option value="">Seleccionar...</option>
                            </select>
                            <span asp-validation-for="TipoEmpleo" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="Sueldo" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Sueldo</label>
                            <div class="relative">
                                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm font-bold">$</span>
                                <input asp-for="Sueldo" step="0.01" placeholder="0.00"
                                       class="w-full pl-7 pr-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm font-bold focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                            </div>
                            <span asp-validation-for="Sueldo" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="TelefonoLaboral" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Teléfono Laboral</label>
                            <input asp-for="TelefonoLaboral" type="tel" placeholder="Ej: 3814567890"
                                   class="w-full px-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                            <span asp-validation-for="TelefonoLaboral" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="TiempoTrabajo" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Tiempo de Trabajo</label>
                            <input asp-for="TiempoTrabajo" placeholder="Ej: 3 años"
                                   class="w-full px-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                            <span asp-validation-for="TiempoTrabajo" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div class="flex items-end">
                            <label class="flex items-center gap-3 cursor-pointer py-2.5">
                                <input asp-for="TieneReciboSueldo" type="checkbox"
                                       class="w-5 h-5 rounded border-slate-300 dark:border-slate-600 text-primary focus:ring-primary/50" />
                                <span class="text-sm font-semibold">Tiene Recibo de Sueldo</span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ═══════════════ Configuración de Crédito Personalizada ═══════════════ -->
            <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm section-card" data-section="credito">
                <button type="button" onclick="toggleSection('credito')"
                        class="w-full flex items-center justify-between p-5 text-left">
                    <div class="flex items-center gap-3">
                        <div class="w-9 h-9 rounded-lg bg-violet-500/10 flex items-center justify-center">
                            <span class="material-symbols-outlined text-violet-500 text-xl">tune</span>
                        </div>
                        <div>
                            <h2 class="text-base font-bold">Configuración de Crédito Personalizada</h2>
                            <p class="text-xs text-slate-500">Parámetros crediticios específicos para este cliente</p>
                        </div>
                    </div>
                    <span class="material-symbols-outlined text-slate-400 section-chevron transition-transform rotate-180" id="chevron-credito">expand_more</span>
                </button>
                <div class="px-5 pb-5 hidden" id="content-credito">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div class="md:col-span-3">
                            <label asp-for="PerfilCreditoPreferidoId" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Perfil de Crédito Preferido</label>
                            <select asp-for="PerfilCreditoPreferidoId" asp-items="@(ViewBag.PerfilesCredito as SelectList)"
                                    class="w-full px-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors">
                                <option value="">Sin perfil preferido</option>
                            </select>
                            <span asp-validation-for="PerfilCreditoPreferidoId" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="TasaInteresMensualPersonalizada" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Tasa Interés Mensual (%)</label>
                            <div class="relative">
                                <input asp-for="TasaInteresMensualPersonalizada" step="0.01" placeholder="Ej: 5.00"
                                       class="w-full px-3 pr-8 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                                <span class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm font-bold">%</span>
                            </div>
                            <span asp-validation-for="TasaInteresMensualPersonalizada" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="GastosAdministrativosPersonalizados" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Gastos Administrativos (%)</label>
                            <div class="relative">
                                <input asp-for="GastosAdministrativosPersonalizados" step="0.01" placeholder="Ej: 2.00"
                                       class="w-full px-3 pr-8 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                                <span class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm font-bold">%</span>
                            </div>
                            <span asp-validation-for="GastosAdministrativosPersonalizados" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="CuotasMaximasPersonalizadas" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Cuotas Máximas</label>
                            <input asp-for="CuotasMaximasPersonalizadas" type="number" min="1" max="120" placeholder="Ej: 24"
                                   class="w-full px-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                            <span asp-validation-for="CuotasMaximasPersonalizadas" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="MontoMinimoPersonalizado" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Monto Mínimo ($)</label>
                            <div class="relative">
                                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm font-bold">$</span>
                                <input asp-for="MontoMinimoPersonalizado" id="montoMinimo" step="0.01" placeholder="0.00"
                                       class="w-full pl-7 pr-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm font-bold focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                            </div>
                            <span asp-validation-for="MontoMinimoPersonalizado" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div>
                            <label asp-for="MontoMaximoPersonalizado" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Monto Máximo ($)</label>
                            <div class="relative">
                                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm font-bold">$</span>
                                <input asp-for="MontoMaximoPersonalizado" id="montoMaximo" step="0.01" placeholder="0.00"
                                       class="w-full pl-7 pr-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm font-bold focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                            </div>
                            <span asp-validation-for="MontoMaximoPersonalizado" class="text-xs text-red-500 mt-1"></span>
                            <p id="montoError" class="text-xs text-red-500 mt-1 hidden">El monto mínimo no puede ser mayor al monto máximo</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ═══════════════ Observaciones y Estado ═══════════════ -->
            <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm section-card" data-section="observaciones">
                <button type="button" onclick="toggleSection('observaciones')"
                        class="w-full flex items-center justify-between p-5 text-left">
                    <div class="flex items-center gap-3">
                        <div class="w-9 h-9 rounded-lg bg-slate-500/10 flex items-center justify-center">
                            <span class="material-symbols-outlined text-slate-500 text-xl">notes</span>
                        </div>
                        <div>
                            <h2 class="text-base font-bold">Observaciones y Estado</h2>
                            <p class="text-xs text-slate-500">Notas y estado del cliente</p>
                        </div>
                    </div>
                    <span class="material-symbols-outlined text-slate-400 section-chevron transition-transform" id="chevron-observaciones">expand_more</span>
                </button>
                <div class="px-5 pb-5" id="content-observaciones">
                    <div class="space-y-4">
                        <div>
                            <label asp-for="Observaciones" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Observaciones</label>
                            <textarea asp-for="Observaciones" rows="4" placeholder="Notas internas sobre el cliente..."
                                      class="w-full px-3 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm resize-none focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors"></textarea>
                            <span asp-validation-for="Observaciones" class="text-xs text-red-500 mt-1"></span>
                        </div>
                        <div>
                            <label class="flex items-center gap-3 cursor-pointer">
                                <input asp-for="Activo" type="checkbox"
                                       class="w-5 h-5 rounded border-slate-300 dark:border-slate-600 text-primary focus:ring-primary/50" />
                                <div>
                                    <span class="text-sm font-bold">Cliente Activo</span>
                                    <p class="text-xs text-slate-500">Los clientes inactivos no pueden generar nuevos créditos</p>
                                </div>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- Sticky Footer -->
        <div class="fixed bottom-0 left-0 right-0 bg-white/80 dark:bg-slate-900/80 backdrop-blur-lg border-t border-slate-200 dark:border-slate-800 z-40">
            <div class="max-w-4xl mx-auto flex items-center justify-between px-6 py-4">
                <a asp-action="Index"
                   class="px-5 py-2.5 text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors no-underline">
                    Cancelar
                </a>
                <button type="submit" id="btnGuardar"
                        class="px-6 py-2.5 bg-primary text-white text-sm font-bold rounded-lg hover:bg-primary/90 transition-colors flex items-center gap-2 shadow-md">
                    <span class="material-symbols-outlined text-lg">person_add</span>
                    Crear Cliente
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/cliente-form.js" asp-append-version="true"></script>
}
