@model ClienteViewModel
@{
    ViewData["Title"] = "Eliminar Cliente";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="max-w-2xl mx-auto">
    <!-- Header -->
    <div class="flex items-center gap-3 mb-6">
        <a asp-action="Index"
           class="p-2 hover:bg-slate-800 rounded-lg transition-colors no-underline text-inherit">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div>
            <h1 class="text-2xl font-bold">Eliminar Cliente</h1>
            <p class="text-sm text-slate-500">Esta acción no se puede deshacer</p>
        </div>
    </div>

    <!-- Warning -->
    <div class="flex items-start gap-3 bg-red-500/10 border border-red-500/20 rounded-xl p-4 mb-6">
        <span class="material-symbols-outlined text-red-500 text-xl mt-0.5">warning</span>
        <div>
            <p class="text-sm font-bold text-red-500">¿Estás seguro de que deseas eliminar este cliente?</p>
            <p class="text-xs text-red-400 mt-1">Se eliminará toda la información asociada. Los créditos vinculados podrían verse afectados.</p>
        </div>
    </div>

    <!-- Client Summary -->
    <div class="bg-slate-900 rounded-xl border border-slate-800 shadow-sm mb-6">
        <!-- Datos Personales -->
        <div class="p-5 border-b border-slate-800">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center">
                    <span class="material-symbols-outlined text-primary text-xl">person</span>
                </div>
                <h2 class="text-base font-bold">Datos Personales</h2>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4 text-sm">
                <div>
                    <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Nombre Completo</p>
                    <p class="font-semibold">@Model.Apellido @Model.Nombre</p>
                </div>
                <div>
                    <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Documento</p>
                    <p class="font-semibold">@Model.TipoDocumento @Model.NumeroDocumento</p>
                </div>
                <div>
                    <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Estado Civil</p>
                    <p class="font-semibold">@(Model.EstadoCivil ?? "—")</p>
                </div>
                @if (Model.FechaNacimiento.HasValue)
                {
                    <div>
                        <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Fecha Nacimiento</p>
                        <p class="font-semibold">@Model.FechaNacimiento.Value.ToString("dd/MM/yyyy")</p>
                    </div>
                }
            </div>
        </div>

        <!-- Datos de Contacto -->
        <div class="p-5 border-b border-slate-800">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-9 h-9 rounded-lg bg-green-500/10 flex items-center justify-center">
                    <span class="material-symbols-outlined text-green-500 text-xl">call</span>
                </div>
                <h2 class="text-base font-bold">Datos de Contacto</h2>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4 text-sm">
                <div>
                    <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Teléfono</p>
                    <p class="font-semibold">@Model.Telefono</p>
                </div>
                @if (!string.IsNullOrEmpty(Model.Email))
                {
                    <div>
                        <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Email</p>
                        <p class="font-semibold">@Model.Email</p>
                    </div>
                }
                <div class="col-span-2 md:col-span-3">
                    <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Domicilio</p>
                    <p class="font-semibold">@Model.Domicilio</p>
                </div>
            </div>
        </div>

        <!-- Estado -->
        <div class="p-5">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-9 h-9 rounded-lg bg-slate-500/10 flex items-center justify-center">
                    <span class="material-symbols-outlined text-slate-500 text-xl">info</span>
                </div>
                <h2 class="text-base font-bold">Estado</h2>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4 text-sm">
                <div>
                    <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Estado</p>
                    @if (Model.Activo)
                    {
                        <span class="inline-flex items-center gap-1 text-xs font-bold uppercase px-2.5 py-1 rounded-full bg-green-500/10 text-green-500 border border-green-500/20">Activo</span>
                    }
                    else
                    {
                        <span class="inline-flex items-center gap-1 text-xs font-bold uppercase px-2.5 py-1 rounded-full bg-red-500/10 text-red-500 border border-red-500/20">Inactivo</span>
                    }
                </div>
                <div>
                    <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Créditos Totales</p>
                    <p class="font-semibold">@Model.CreditosTotales</p>
                </div>
                <div>
                    <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Créditos Activos</p>
                    <p class="font-semibold">@Model.CreditosActivos</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        @if (returnUrl != null)
        {
            <input type="hidden" name="returnUrl" value="@returnUrl" />
        }

        <div class="flex items-center justify-between">
            <a asp-action="Index"
               class="px-5 py-2.5 text-sm font-semibold text-slate-300 hover:bg-slate-800 rounded-lg transition-colors no-underline">
                Cancelar
            </a>
            <button type="submit"
                    class="px-6 py-2.5 bg-red-600 text-white text-sm font-bold rounded-lg hover:bg-red-700 transition-colors flex items-center gap-2 shadow-md">
                <span class="material-symbols-outlined text-lg">delete</span>
                Confirmar Eliminación
            </button>
        </div>
    </form>
</div>
