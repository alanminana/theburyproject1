@using TheBuryProject.Models.Enums
@model ClienteDetalleViewModel
@{
    ViewData["Title"] = "Detalle de Cliente";
    var c = Model.Cliente;
    var apt = Model.AptitudCrediticia;
    var panel = Model.CreditoDisponiblePanel;
    var returnUrl = ViewData["ReturnUrl"] as string;

    var esNoApto = apt?.Estado == EstadoCrediticioCliente.NoApto;
    var esRequiereAut = apt?.Estado == EstadoCrediticioCliente.RequiereAutorizacion;
    var esApto = apt?.Estado == EstadoCrediticioCliente.Apto;
    var documentosVerificados = Model.Documentos?.Count(d => d.Estado == EstadoDocumento.Verificado) ?? 0;
    var documentosPendientes = Model.Documentos?.Count(d => d.Estado == EstadoDocumento.Pendiente) ?? 0;
    var documentosFaltantes = apt?.Documentacion?.DocumentosFaltantes?.Count ?? 0;
    var documentosTotal = (Model.Documentos?.Count ?? 0) + documentosFaltantes;
    var limiteDisponible = panel?.Valores?.Disponible ?? 0m;
    var limiteTotal = panel?.Valores?.Limite ?? 0m;
    var limiteUsado = panel?.Valores?.SaldoVigente ?? Math.Max(0m, limiteTotal - limiteDisponible);
    var porcentajeLibre = panel?.PorcentajeLibre ?? 0m;
    var aptitudLabel = esNoApto ? "No apto" : esRequiereAut ? "Requiere autorizacion" : esApto ? "Apto" : "No evaluado";
    var aptitudChip = esNoApto ? "chip-bad" : esRequiereAut ? "chip-warn" : esApto ? "chip-ok" : "chip-neutral";
    var aptitudCard = esNoApto ? "is-no" : esRequiereAut ? "is-aut" : esApto ? "is-apto" : string.Empty;
    var aptitudIcon = esNoApto ? "block" : esRequiereAut ? "gpp_maybe" : esApto ? "verified" : "help";
    var resultTone = esNoApto ? "is-bad" : esRequiereAut ? "is-warn" : "is-ok";
    var moraLabel = apt?.Mora != null && apt.Mora.TieneMora ? $"{apt.Mora.DiasMaximoMora} dias" : "Al dia";
    var moraChip = apt?.Mora != null && apt.Mora.TieneMora ? "chip-warn" : "chip-ok";
    // FASE 11D: el chip/panel BCRA distingue nunca-consultado / consulta OK /
    // error sin ultimo exito / error usando ultima consulta valida (FASE 11C),
    // en vez de colapsar todo error en "Pendiente". apt.Bcra ya resuelve la
    // situacion/descripcion efectiva (ultimo exito cuando el ultimo intento
    // fallo) via el mismo clasificador puro que usa la aptitud crediticia.
    var tieneCuil = !string.IsNullOrWhiteSpace(c.CuilCuit);
    var bcraOk = c.SituacionCrediticiaConsultaOk == true;
    var bcraTieneUltimoExito = c.SituacionCrediticiaUltimoExitoUtc.HasValue && c.SituacionCrediticiaBcraUltimoExito.HasValue;
    var bcraNuncaConsultado = tieneCuil && !c.SituacionCrediticiaUltimaConsultaUtc.HasValue && !bcraTieneUltimoExito;
    var bcraUsandoUltimoExito = tieneCuil && !bcraOk && bcraTieneUltimoExito;
    var bcraMensaje = apt?.Bcra?.Mensaje;
    var bcraVal = apt?.Bcra?.Situacion;
    var bcraDesc = !tieneCuil
        ? "CUIL/CUIT no cargado"
        : (apt?.Bcra?.Descripcion ?? "Sin consultar");
    var bcraPeriodo = bcraUsandoUltimoExito ? c.SituacionCrediticiaPeriodoUltimoExito : c.SituacionCrediticiaPeriodo;
    var bcraFecha = c.SituacionCrediticiaUltimaConsultaUtc;
    var bcraTone = bcraVal is 0 or 1 ? "is-ok" : bcraVal == 2 ? "is-warn" : bcraVal.HasValue ? "is-bad" : "is-warn";
    var bcraDot = bcraVal is 0 or 1 ? "bg-green-500" : bcraVal == 2 ? "bg-amber-500" : bcraVal.HasValue ? "bg-red-500" : "bg-slate-400";
    var bcraColor = bcraVal is 0 or 1 ? "text-green-500" : bcraVal == 2 ? "text-amber-500" : bcraVal.HasValue ? "text-red-500" : "text-slate-400";
    var bcraEstadoResumen = !tieneCuil ? "Sin CUIL" : bcraDesc;
    string bcraChipLabel, bcraChipIcon, bcraChip;
    if (!tieneCuil)
    {
        bcraChipLabel = "Sin CUIL"; bcraChipIcon = "remove"; bcraChip = "chip-neutral";
    }
    else if (bcraNuncaConsultado)
    {
        bcraChipLabel = "Sin consultar"; bcraChipIcon = "schedule"; bcraChip = "chip-neutral";
    }
    else if (bcraOk)
    {
        bcraChipLabel = "Consulta OK"; bcraChipIcon = "check"; bcraChip = "chip-ok";
    }
    else if (bcraUsandoUltimoExito)
    {
        bcraChipLabel = "Usando ultima consulta valida"; bcraChipIcon = "history"; bcraChip = "chip-warn";
    }
    else
    {
        bcraChipLabel = "Error BCRA"; bcraChipIcon = "priority_high"; bcraChip = "chip-bad";
    }
    var nivelAutomatico = panel?.Valores?.NivelCreditoAutomatico ?? c.PuntajeCliente;
    var nivelManual = panel?.Valores?.NivelCreditoManual;
    var nivelFinal = panel?.Valores?.NivelCreditoFinal ?? nivelAutomatico;
    var fuenteNivel = string.Equals(panel?.Valores?.FuenteNivelCredito, "Manual", StringComparison.OrdinalIgnoreCase) ? "Manual" : "Automatico";
    var tieneNivelManual = nivelManual.HasValue;
    var motivoNivelManual = panel?.Valores?.MotivoNivelCreditoManual;
    var pagoCreditoChip = !c.TieneHistorialCredito ? "chip-neutral" : c.PagaCreditosEnTermino ? "chip-ok" : "chip-warn";
    var pagoCreditoIcon = !c.TieneHistorialCredito ? "hourglass_empty" : c.PagaCreditosEnTermino ? "task_alt" : "report";
    var pagoCreditoLabel = !c.TieneHistorialCredito ? "Sin historial" : c.PagaCreditosEnTermino ? "Paga en termino" : "Con atraso";
    var nivelesDisponibles = panel?.NivelesDisponibles ?? new List<ClienteNivelCreditoOpcionViewModel>();
    var clienteNombre = string.IsNullOrWhiteSpace(c.NombreCompleto)
        ? $"{c.Apellido}, {c.Nombre}".Trim(' ', ',')
        : c.NombreCompleto;
    var iniciales = $"{(string.IsNullOrWhiteSpace(c.Apellido) ? "?" : c.Apellido.Trim()[0])}{(string.IsNullOrWhiteSpace(c.Nombre) ? "?" : c.Nombre.Trim()[0])}".ToUpperInvariant();
    var progressClass = ProgressWidthClass(Convert.ToDouble(porcentajeLibre));
    var returnToDetails = Url.Action("Details", "Cliente", new { id = c.Id });

    var aptitudResumen = esApto ? "Puede operar a credito"
        : esRequiereAut ? "Requiere autorizacion para operar"
        : esNoApto ? "No puede operar a credito"
        : "Aptitud sin evaluar";

    // El banner de aptitud solo se muestra si hay algo que necesita atencion.
    var docAtencion = (apt?.Documentacion?.Completa == false) || documentosPendientes > 0 || documentosFaltantes > 0;
    var bcraAtencion = tieneCuil && (!bcraOk || (bcraVal.HasValue && bcraVal.Value >= 2));
    var moraActiva = apt?.Mora != null && apt.Mora.TieneMora;
    var sinLimite = (panel?.TieneErrorConfiguracion == true) || limiteTotal <= 0m;
    var mostrarBanner = !esApto || docAtencion || bcraAtencion || moraActiva || sinLimite || tieneNivelManual;

    string ProgressWidthClass(double percentage)
    {
        var clamped = Math.Clamp((int)Math.Round(percentage, MidpointRounding.AwayFromZero), 0, 100);
        return $"progress-w-{clamped}";
    }

    string Dash(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;

    string DocumentoChip(DocumentoClienteViewModel doc) => doc.Estado switch
    {
        EstadoDocumento.Verificado => "chip-ok",
        EstadoDocumento.Rechazado => "chip-bad",
        EstadoDocumento.Vencido => "chip-warn",
        _ => "chip-warn"
    };

    string DocumentoIcon(DocumentoClienteViewModel doc) => doc.Estado switch
    {
        EstadoDocumento.Verificado => "check",
        EstadoDocumento.Rechazado => "block",
        EstadoDocumento.Vencido => "schedule",
        _ => "pending"
    };
}

@section Styles {
    <partial name="_ClienteModuleStyles" />
}

@if (TempData["Success"] != null || TempData["Error"] != null)
{
    <div id="clienteIndexFeedback" class="shell" style="margin-top:1rem" role="alert" aria-live="polite">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-ok"><span class="material-symbols-outlined">check_circle</span><span class="flex-1 self-center">@TempData["Success"]</span></div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-bad"><span class="material-symbols-outlined">error</span><span class="flex-1 self-center">@TempData["Error"]</span></div>
        }
    </div>
}
else
{
    <div id="clienteIndexFeedback" class="hidden shell" style="margin-top:1rem" role="alert" aria-live="polite"></div>
}

<main class="shell" style="padding-top:1.5rem;padding-bottom:3rem">
    @if (!string.IsNullOrWhiteSpace(returnUrl))
    {
        <a href="@returnUrl" class="inline-flex items-center gap-1.5 text-sm muted hover:text-white transition" style="text-decoration:none">
            <span class="material-symbols-outlined" style="font-size:18px">arrow_back</span>Volver a clientes
        </a>
    }
    else
    {
        <a asp-action="Index" class="inline-flex items-center gap-1.5 text-sm muted hover:text-white transition" style="text-decoration:none">
            <span class="material-symbols-outlined" style="font-size:18px">arrow_back</span>Volver a clientes
        </a>
    }

    <div class="page-head" style="margin-top:.95rem">
        <div class="min-w-0">
            <div class="flex items-center gap-3">
                <div class="avatar avatar-lg">@iniciales</div>
                <div class="min-w-0">
                    <div class="flex items-center gap-2 flex-wrap">
                        <h1 class="page-title" style="font-size:1.4rem">@clienteNombre</h1>
                        <span class="chip @aptitudChip"><span class="material-symbols-outlined">@aptitudIcon</span>@aptitudLabel</span>
                        <span class="chip @(c.Activo ? "chip-ok" : "chip-neutral")">@(c.Activo ? "Activo" : "Inactivo")</span>
                    </div>
                    <p class="page-sub" style="margin-top:.3rem">
                        @c.TipoDocumento <span class="mono">@c.NumeroDocumento</span>
                        <span class="muted-2"> · </span> CUIL <span class="mono">@Dash(c.CuilCuit)</span>
                        @if (c.FechaNacimiento.HasValue)
                        {
                            <span class="muted-2"> · </span><span>@c.FechaNacimiento.Value.ToString("dd/MM/yyyy")</span>
                        }
                    </p>
                </div>
            </div>
        </div>
        <div class="head-actions">
            <button type="button" class="btn btn-ghost" onclick="window.print()"><span class="material-symbols-outlined">print</span>Imprimir</button>
            <a asp-action="Edit" asp-route-id="@c.Id" asp-route-returnUrl="@returnToDetails" class="btn btn-soft"><span class="material-symbols-outlined">edit</span>Editar perfil</a>
            <a asp-controller="Credito" asp-action="Create" asp-route-clienteId="@c.Id" class="btn btn-primary"><span class="material-symbols-outlined">add_card</span>Nuevo credito</a>
        </div>
    </div>

    <div class="grid-kpi" style="margin-top:1.5rem">
        <div class="kpi kpi--accent">
            <div class="kpi-label"><span class="material-symbols-outlined" style="font-size:15px">account_balance_wallet</span>Credito disponible</div>
            <div class="kpi-value">@limiteDisponible.ToString("C0")</div>
            <div class="mt-2 bar"><div class="bar-fill is-accent @progressClass"></div></div>
            <div class="kpi-foot">@porcentajeLibre.ToString("N0")% libre de @limiteTotal.ToString("C0")</div>
        </div>
        <div class="kpi @(esApto ? "kpi--ok" : esNoApto ? "kpi--bad" : esRequiereAut ? "kpi--warn" : string.Empty)">
            <div class="kpi-label"><span class="material-symbols-outlined" style="font-size:15px">verified_user</span>Estado de aptitud</div>
            <div class="kpi-value" style="font-size:1.3rem;margin-top:.5rem">@aptitudLabel</div>
            <div class="kpi-foot">@aptitudResumen</div>
        </div>
        <div class="kpi">
            <div class="kpi-label"><span class="material-symbols-outlined" style="font-size:15px">folder_shared</span>Documentos</div>
            <div class="kpi-value">@documentosVerificados<span class="text-base muted-2 font-normal"> / @documentosTotal</span></div>
            <div class="kpi-foot">@documentosPendientes pendientes · @documentosFaltantes faltantes</div>
        </div>
        <div class="kpi">
            <div class="kpi-label"><span class="material-symbols-outlined" style="font-size:15px">account_balance</span>Situacion BCRA</div>
            <div class="kpi-value" style="font-size:1.3rem;margin-top:.5rem">@bcraEstadoResumen</div>
            <div class="kpi-foot">@(string.IsNullOrWhiteSpace(bcraPeriodo) ? "Periodo sin informar" : $"Periodo {bcraPeriodo}")</div>
        </div>
    </div>

    @if (mostrarBanner)
    {
        <div class="apt-card @aptitudCard" style="margin-top:1.25rem">
            <div class="apt-ic"><span class="material-symbols-outlined">@aptitudIcon</span></div>
            <div class="flex-1 min-w-0">
                <div class="font-semibold text-white">@aptitudLabel para operar</div>
                <p class="text-sm muted mt-0.5">
                    @if (!string.IsNullOrWhiteSpace(apt?.Motivo))
                    {
                        @apt.Motivo
                    }
                    else if (esApto && tieneNivelManual)
                    {
                        <text>Apto con puntaje crediticio asignado manualmente.</text>
                    }
                    else if (esApto)
                    {
                        <text>Revisar documentacion o situacion BCRA pendiente antes de operar.</text>
                    }
                    else if (esRequiereAut)
                    {
                        <text>Puede requerir autorizacion antes de emitir nuevas operaciones.</text>
                    }
                    else if (esNoApto)
                    {
                        <text>Revisar documentacion, mora o configuracion antes de operar.</text>
                    }
                    else
                    {
                        <text>La aptitud aun no fue evaluada.</text>
                    }
                </p>
            </div>
            <form asp-action="RecalcularAptitud" method="post" class="shrink-0">
                @Html.AntiForgeryToken()
                <input type="hidden" name="clienteId" value="@c.Id" />
                @if (!string.IsNullOrWhiteSpace(returnUrl))
                {
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                }
                <button type="submit" class="btn btn-soft btn-sm"><span class="material-symbols-outlined">refresh</span>Recalcular aptitud</button>
            </form>
        </div>
    }

    @if (Model.VentasPendientesAutorizacion != null && Model.VentasPendientesAutorizacion.Any())
    {
        var puedeAutorizarVentas = User.TienePermiso("ventas", "authorize");
        <div class="alert alert-warn" style="margin-top:1.25rem;align-items:flex-start">
            <span class="material-symbols-outlined">gpp_maybe</span>
            <div class="flex-1 min-w-0">
                <div class="font-semibold text-white">Ventas pendientes de autorización</div>
                <div class="mt-2 space-y-2">
                    @foreach (var venta in Model.VentasPendientesAutorizacion)
                    {
                        <div class="flex items-center justify-between gap-2 flex-wrap">
                            <div class="min-w-0 text-sm">
                                <span class="mono">@venta.Numero</span>
                                <span class="muted-2"> · </span>@venta.Fecha.ToString("dd/MM/yyyy")
                                <span class="muted-2"> · </span>@venta.Total.ToString("C0")
                                @if (!string.IsNullOrWhiteSpace(venta.Resumen))
                                {
                                    <div class="text-xs muted-2">@venta.Resumen</div>
                                }
                            </div>
                            @if (puedeAutorizarVentas)
                            {
                                <a asp-controller="Venta" asp-action="Autorizar" asp-route-id="@venta.VentaId" class="btn btn-soft btn-sm shrink-0">Ver autorización</a>
                            }
                            else
                            {
                                <a asp-controller="Venta" asp-action="Details" asp-route-id="@venta.VentaId" class="btn btn-ghost btn-sm shrink-0">Ver venta</a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4" style="margin-top:1.25rem">
        <div class="lg:col-span-2 space-y-4">
            <section class="card card-pad">
                <div class="flex items-start justify-between gap-3 mb-4 flex-wrap">
                    <h2 class="font-semibold text-white flex items-center gap-2"><span class="material-symbols-outlined" style="color:#f5c518;font-size:20px">credit_score</span>Calificacion crediticia</h2>
                    <div class="flex items-center gap-2 flex-wrap">
                        <button type="button" class="btn btn-soft btn-sm" data-cliente-open-nivel-manual><span class="material-symbols-outlined">rule_settings</span>Asignar puntaje manual</button>
                        <button type="button" class="btn btn-ghost btn-sm" data-cliente-open-limites><span class="material-symbols-outlined">tune</span>Limites por puntaje</button>
                    </div>
                </div>

                @if (panel?.TieneErrorConfiguracion == true)
                {
                    <div class="alert alert-warn"><span class="material-symbols-outlined">warning</span><span>@panel.MensajeError</span></div>
                }
                else
                {
                    <div class="result-card @resultTone">
                        <div class="result-label">Credito disponible</div>
                        <div class="result-value">@limiteDisponible.ToString("C0")</div>
                        <div class="mt-3 bar"><div class="bar-fill @(esNoApto ? "is-bad" : esRequiereAut ? "is-warn" : "is-ok") @progressClass"></div></div>
                        <div class="mt-2 flex items-center justify-between text-xs muted-2"><span>Saldo usado @limiteUsado.ToString("C0")</span><span>Limite asignado @limiteTotal.ToString("C0")</span></div>
                    </div>
                }

                <div class="minimetric mt-4">
                    <div class="mm-label">Puntaje crediticio</div>
                    <div class="flex items-center gap-2 flex-wrap" style="margin-top:.25rem">
                        <div class="mm-value num" style="margin-top:0;font-size:1.4rem">@nivelFinal<span class="text-xs muted-2 font-normal"> / 5</span></div>
                        <span class="chip @(tieneNivelManual ? "chip-warn" : "chip-ok")">@fuenteNivel</span>
                    </div>
                    @if (tieneNivelManual)
                    {
                        <div class="text-xs muted-2" style="margin-top:.4rem">Manual: @nivelManual/5 &bull; Automatico calculado: @nivelAutomatico/5</div>
                    }
                </div>

                <div class="text-xs muted-2 font-semibold uppercase mt-4" style="letter-spacing:.04em">Desglose</div>
                <dl class="kv mt-1">
                    <div class="kv-row"><dt>Fuente del puntaje</dt><dd><span class="chip @(tieneNivelManual ? "chip-warn" : "chip-ok")">@fuenteNivel</span></dd></div>
                    <div class="kv-row"><dt>Origen del cupo</dt><dd>@Dash(panel?.Valores?.OrigenLimite)</dd></div>
                    <div class="kv-row"><dt>Documentacion</dt><dd>@(apt?.Documentacion?.Completa == true ? "Completa" : "Incompleta")</dd></div>
                    <div class="kv-row"><dt>BCRA</dt><dd>@bcraEstadoResumen</dd></div>
                    <div class="kv-row"><dt>Mora</dt><dd><span class="chip @moraChip">@moraLabel</span></dd></div>
                    <div class="kv-row"><dt>Override manual</dt><dd>@(tieneNivelManual ? "Si" : "No")</dd></div>
                    @if (tieneNivelManual && !string.IsNullOrWhiteSpace(motivoNivelManual))
                    {
                        <div class="kv-row"><dt>Motivo manual</dt><dd>@motivoNivelManual</dd></div>
                    }
                    @if (apt?.Mora != null && apt.Mora.TieneMora)
                    {
                        <div class="kv-row"><dt>Monto en mora</dt><dd>@apt.Mora.MontoTotalMora.ToString("C0")</dd></div>
                    }
                </dl>
                @if (apt?.Mora?.MensajeUmbralDias != null)
                {
                    <div class="text-xs muted-2 mt-2">@apt.Mora.MensajeUmbralDias</div>
                }

                <div class="mt-4 pt-4" style="border-top:1px solid rgba(255,255,255,.07)">
                    <button type="button" class="flex items-center justify-between w-full" data-cliente-details-toggle="scoring" aria-expanded="false" style="background:none;border:none;cursor:pointer;padding:0;text-align:left">
                        <span class="flex items-center gap-2 text-sm font-semibold text-white">
                            <span class="material-symbols-outlined" style="color:#f5c518;font-size:18px">stars</span>
                            Scoring de comportamiento
                            <span class="muted-2 font-normal">@c.PuntajeCliente / 5</span>
                        </span>
                        <span class="material-symbols-outlined muted-2" id="chevron-scoring">expand_more</span>
                    </button>
                    <div id="content-scoring" class="hidden mt-3">
                        <div class="flex items-center gap-3 flex-wrap mb-3">
                            <span class="pips">
                                @for (var i = 1; i <= 5; i++)
                                {
                                    <span class="pip @(i <= Math.Clamp(c.PuntajeCliente, 0, 5) ? "on-ok" : string.Empty)"></span>
                                }
                            </span>
                            <span class="chip @pagoCreditoChip">
                                <span class="material-symbols-outlined">@pagoCreditoIcon</span>@pagoCreditoLabel
                            </span>
                        </div>
                        <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
                            <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:.6rem;padding:.7rem .8rem">
                                <div class="text-xs muted-2 flex items-center gap-1"><span class="material-symbols-outlined" style="font-size:14px">schedule</span>Antiguedad</div>
                                <div class="font-semibold text-white mt-1">@c.AntiguedadDias<span class="text-xs muted-2 font-normal"> dias</span></div>
                            </div>
                            <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:.6rem;padding:.7rem .8rem">
                                <div class="text-xs muted-2 flex items-center gap-1"><span class="material-symbols-outlined" style="font-size:14px">shopping_cart</span>Ultima venta</div>
                                <div class="font-semibold text-white mt-1">@(c.UltimaVentaFecha?.ToString("dd/MM/yyyy") ?? "Sin ventas")</div>
                            </div>
                            <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:.6rem;padding:.7rem .8rem">
                                <div class="text-xs muted-2 flex items-center gap-1"><span class="material-symbols-outlined" style="font-size:14px">receipt_long</span>Compras</div>
                                <div class="font-semibold text-white mt-1">@c.CantidadComprasCliente</div>
                            </div>
                            <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:.6rem;padding:.7rem .8rem">
                                <div class="text-xs muted-2 flex items-center gap-1"><span class="material-symbols-outlined" style="font-size:14px">verified</span>Creditos en termino</div>
                                <div class="font-semibold text-white mt-1">@c.CreditosEnTermino</div>
                            </div>
                            <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:.6rem;padding:.7rem .8rem">
                                <div class="text-xs muted-2 flex items-center gap-1"><span class="material-symbols-outlined" style="font-size:14px">warning</span>Creditos con atraso</div>
                                <div class="font-semibold mt-1" style="color:@(c.CreditosConAtraso > 0 ? "#f5b21a" : "#fff")">@c.CreditosConAtraso</div>
                            </div>
                        </div>
                        <form asp-action="RecalcularPuntaje" method="post" class="mt-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="clienteId" value="@c.Id" />
                            @if (!string.IsNullOrWhiteSpace(returnUrl))
                            {
                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                            }
                            <button type="submit" class="btn btn-soft btn-sm"><span class="material-symbols-outlined">refresh</span>Recalcular scoring</button>
                        </form>
                    </div>
                </div>

                <div class="mt-4 pt-4" style="border-top:1px solid rgba(255,255,255,.07)">
                    <button type="button" class="flex items-center justify-between w-full" data-cliente-details-toggle="historial" aria-expanded="false" style="background:none;border:none;cursor:pointer;padding:0;text-align:left">
                        <span class="flex items-center gap-2 text-sm font-semibold text-white">
                            <span class="material-symbols-outlined" style="color:#f5c518;font-size:18px">history</span>
                            Historial de puntaje
                        </span>
                        <span class="material-symbols-outlined muted-2" id="chevron-historial">expand_more</span>
                    </button>
                    <div id="content-historial" class="hidden mt-3">
                        @if (Model.HistorialPuntaje != null && Model.HistorialPuntaje.Any())
                        {
                            <div class="tbl-wrap puntaje-history-wrapper" data-oc-scroll>
                                <table class="tbl puntaje-history-table">
                                    <thead>
                                        <tr>
                                            <th>Fecha</th>
                                            <th>Puntaje anterior</th>
                                            <th>Puntaje nuevo</th>
                                            <th>Origen</th>
                                            <th>Registrado por</th>
                                            <th>Observacion</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var h in Model.HistorialPuntaje)
                                        {
                                            <tr>
                                                <td>@h.Fecha.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                                <td>@(h.PuntajeAnterior.HasValue ? h.PuntajeAnterior.Value.ToString() : "-")</td>
                                                <td>@h.PuntajeNuevo</td>
                                                <td>@h.Origen</td>
                                                <td>@Dash(h.RegistradoPor)</td>
                                                <td>@Dash(h.Observacion)</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="ph">
                                <span class="material-symbols-outlined">history</span>
                                <div class="ph-label">historial de puntaje</div>
                                <p class="text-xs muted-2" style="max-width:34ch">Todavia no hay cambios de puntaje registrados.</p>
                            </div>
                        }
                    </div>
                </div>
            </section>

            <section class="card card-pad">
                <h2 class="font-semibold text-white mb-3 flex items-center gap-2"><span class="material-symbols-outlined" style="color:#94a3b8;font-size:20px">badge</span>Datos personales</h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6">
                    <dl class="kv">
                        <div class="kv-row"><dt>Nombre completo</dt><dd>@clienteNombre</dd></div>
                        <div class="kv-row"><dt>Documento</dt><dd class="mono">@c.TipoDocumento @c.NumeroDocumento</dd></div>
                        <div class="kv-row"><dt>CUIL / CUIT</dt><dd class="mono">@Dash(c.CuilCuit)</dd></div>
                    </dl>
                    <dl class="kv">
                        <div class="kv-row"><dt>Fecha de nacimiento</dt><dd>@(c.FechaNacimiento.HasValue ? c.FechaNacimiento.Value.ToString("dd/MM/yyyy") : "-")@(c.Edad.HasValue ? $" · {c.Edad} anos" : string.Empty)</dd></div>
                        <div class="kv-row"><dt>Estado civil</dt><dd>@Dash(c.EstadoCivil)</dd></div>
                        <div class="kv-row"><dt>Conyuge</dt><dd>@Dash(c.ConyugeNombreCompleto)</dd></div>
                    </dl>
                </div>
            </section>

            <section class="card card-pad">
                <h2 class="font-semibold text-white mb-3 flex items-center gap-2"><span class="material-symbols-outlined" style="color:#94a3b8;font-size:20px">call</span>Contacto</h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6">
                    <dl class="kv">
                        <div class="kv-row"><dt>Telefono</dt><dd>@Dash(c.Telefono)</dd></div>
                        <div class="kv-row"><dt>Telefono alternativo</dt><dd>@Dash(c.TelefonoAlternativo)</dd></div>
                        <div class="kv-row"><dt>Email</dt><dd>@Dash(c.Email)</dd></div>
                    </dl>
                    <dl class="kv">
                        <div class="kv-row"><dt>Domicilio</dt><dd>@Dash(c.Domicilio)</dd></div>
                        <div class="kv-row"><dt>Localidad</dt><dd>@Dash(c.Localidad)</dd></div>
                        <div class="kv-row"><dt>Provincia</dt><dd>@Dash(c.Provincia)</dd></div>
                    </dl>
                </div>
            </section>

            <section class="card card-pad">
                <div class="flex items-center justify-between gap-3 mb-3">
                    <h2 class="font-semibold text-white flex items-center gap-2"><span class="material-symbols-outlined" style="color:#94a3b8;font-size:20px">payments</span>Creditos del cliente</h2>
                    <a asp-controller="Credito" asp-action="Index" asp-route-clienteId="@c.Id" class="btn btn-ghost btn-sm">Ver todos<span class="material-symbols-outlined">chevron_right</span></a>
                </div>
                @if (Model.CreditosActivos != null && Model.CreditosActivos.Any())
                {
                    <div class="tbl-wrap" data-oc-scroll>
                        <table class="tbl creditos-cliente-table">
                            <thead>
                                <tr>
                                    <th>Credito</th>
                                    <th>Estado</th>
                                    <th>Monto</th>
                                    <th>Saldo</th>
                                    <th>Fecha</th>
                                    <th class="text-right">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var credito in Model.CreditosActivos)
                                {
                                    <tr>
                                        <td class="mono">@(credito.Numero ?? $"#{credito.Id}")</td>
                                        <td><span class="chip chip-info">@credito.Estado</span></td>
                                        <td>@credito.MontoAprobado.ToString("C0")</td>
                                        <td>@credito.SaldoPendiente.ToString("C0")</td>
                                        <td>@credito.FechaSolicitud.ToString("dd/MM/yyyy")</td>
                                        <td>
                                            <div class="row-actions">
                                                <a asp-controller="Credito" asp-action="Details" asp-route-id="@credito.Id" class="btn btn-ghost btn-sm"><span class="material-symbols-outlined">visibility</span>Ver</a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="ph">
                        <span class="material-symbols-outlined">table_rows</span>
                        <div class="ph-label">listado de creditos del cliente</div>
                        <p class="text-xs muted-2" style="max-width:34ch">Sin creditos registrados para este cliente.</p>
                    </div>
                }
            </section>
        </div>

        <aside class="space-y-4">
            <div class="card card-pad" id="bcra-panel">
                <div class="flex items-center justify-between gap-2 mb-3">
                    <h3 class="font-semibold text-white flex items-center gap-2"><span class="material-symbols-outlined" style="color:#f5c518;font-size:20px">account_balance</span>Situacion BCRA</h3>
                    <span class="chip @bcraChip" id="bcra-chip"><span class="material-symbols-outlined" id="bcra-chip-icon">@bcraChipIcon</span><span id="bcra-chip-label">@bcraChipLabel</span></span>
                </div>
                <div class="result-card @bcraTone" style="padding:.85rem 1rem">
                    <div class="flex items-center justify-between">
                        <div class="result-label">Situacion crediticia</div>
                        <span class="text-2xl font-bold @bcraColor">@(bcraVal?.ToString() ?? "-")</span>
                    </div>
                    <div class="flex items-center gap-2 text-sm mt-0.5">
                        <div class="h-2 w-2 rounded-full @bcraDot" id="bcra-dot"></div>
                        <span class="font-bold @bcraColor" id="bcra-desc">@bcraDesc</span>
                    </div>
                </div>
                @if (bcraUsandoUltimoExito)
                {
                    <p class="text-xs muted mt-2" id="bcra-aviso" role="status">@bcraMensaje</p>
                }
                else
                {
                    <p class="text-xs muted mt-2 hidden" id="bcra-aviso" role="status"></p>
                }
                <dl class="kv mt-3">
                    <div class="kv-row"><dt>CUIL / CUIT</dt><dd class="mono">@Dash(c.CuilCuit)</dd></div>
                    <div class="kv-row"><dt>Periodo informado</dt><dd>@Dash(bcraPeriodo)</dd></div>
                    <div class="kv-row">
                        <dt>Ultima consulta</dt>
                        <dd id="bcra-meta">@(bcraFecha.HasValue ? bcraFecha.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm") : "Pendiente de consulta")</dd>
                    </div>
                </dl>
                @if (tieneCuil)
                {
                    <button type="button" id="bcra-btn" data-cliente-bcra-refresh data-cliente-id="@c.Id" class="btn btn-soft btn-sm btn-block" style="margin-top:.9rem">
                        <span class="material-symbols-outlined" id="bcra-icon">sync</span>Actualizar BCRA
                    </button>
                }
            </div>

            <div class="card card-pad">
                <div class="flex items-center justify-between gap-2 mb-3">
                    <h3 class="font-semibold text-white flex items-center gap-2"><span class="material-symbols-outlined" style="color:#94a3b8;font-size:20px">folder_shared</span>Documentacion</h3>
                    <span class="chip @(documentosPendientes > 0 || documentosFaltantes > 0 ? "chip-warn" : "chip-ok")">@documentosPendientes pendientes</span>
                </div>
                @if (apt?.Documentacion != null && !apt.Documentacion.Completa && apt.Documentacion.DocumentosFaltantes.Any())
                {
                    <div class="alert alert-warn" style="margin-bottom:.75rem">
                        <span class="material-symbols-outlined">warning</span>
                        <span>Faltan: @string.Join(", ", apt.Documentacion.DocumentosFaltantes)</span>
                    </div>
                }

             
                <div class="space-y-2">
                    @if (Model.Documentos != null && Model.Documentos.Any())
                    {
                        @foreach (var doc in Model.Documentos)
                        {
                            var esPendiente = doc.Estado == EstadoDocumento.Pendiente;
                            var esVerificado = doc.Estado == EstadoDocumento.Verificado;
                            <div class="doc-row">
                                <div class="doc-ic"><span class="material-symbols-outlined">description</span></div>
                                <div class="flex-1 min-w-0">
                                    <div class="text-sm text-white">@doc.TipoDocumentoNombre</div>
                                    <div class="text-xs muted-2">Cargado @doc.FechaSubida.ToString("dd/MM/yyyy")</div>
                                </div>
                                <span class="chip @DocumentoChip(doc)"><span class="material-symbols-outlined">@DocumentoIcon(doc)</span>@doc.EstadoNombre</span>
                                <div class="flex items-center gap-1">
                                    <a asp-controller="DocumentoCliente" asp-action="Descargar" asp-route-id="@doc.Id" class="btn btn-ghost btn-sm" title="Ver documento"><span class="material-symbols-outlined">download</span></a>
                                    @if (esPendiente)
                                    {
                                        <form asp-controller="DocumentoCliente" asp-action="Verificar" asp-route-id="@doc.Id" asp-route-returnUrl="@returnToDetails" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-ghost btn-sm" title="Aprobar documento"><span class="material-symbols-outlined">task_alt</span></button>
                                        </form>
                                        <form asp-controller="DocumentoCliente" asp-action="Rechazar" asp-route-id="@doc.Id" asp-route-returnUrl="@returnToDetails" method="post" data-cliente-reject-form>
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="motivo" class="motivo-hidden" />
                                            <button type="submit" class="btn btn-ghost btn-sm" title="Rechazar documento"><span class="material-symbols-outlined">block</span></button>
                                        </form>
                                    }
                                    @if (!esVerificado)
                                    {
                                        <button type="button" data-cliente-upload-open data-tipo-documento-value="@((int)doc.TipoDocumento)" data-tipo-documento-label="@doc.TipoDocumentoNombre" data-replace-id="@doc.Id" class="btn btn-ghost btn-sm" title="Reemplazar archivo">
                                            <span class="material-symbols-outlined">upload</span>
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    }

                    @if (apt?.Documentacion != null && apt.Documentacion.DocumentosFaltantes.Any())
                    {
                        @foreach (var faltante in apt.Documentacion.DocumentosFaltantes)
                        {
                            var yaSubido = Model.Documentos?.Any(d => d.TipoDocumentoNombre == faltante) ?? false;
                            if (!yaSubido)
                            {
                                <div class="doc-row">
                                    <div class="doc-ic"><span class="material-symbols-outlined">description</span></div>
                                    <div class="flex-1 min-w-0">
                                        <div class="text-sm text-white">@faltante</div>
                                        <div class="text-xs muted-2">Esperando carga</div>
                                    </div>
                                    <span class="chip chip-warn">Pendiente</span>
                                    <button type="button" data-cliente-upload-open data-tipo-documento-value="" data-tipo-documento-label="@faltante" class="btn btn-ghost btn-sm" title="Subir archivo">
                                        <span class="material-symbols-outlined">upload</span>
                                    </button>
                                </div>
                            }
                        }
                    }
                @{
                    var garante = Model.GaranteInfo;
                }
                <div class="doc-row" style="margin-bottom:.75rem" id="garantePanel">
                    <div class="doc-ic"><span class="material-symbols-outlined">supervisor_account</span></div>
                    <div class="flex-1 min-w-0">
                        <div class="text-sm text-white" style="font-weight:500;margin-bottom:.35rem">Garante</div>
                        <p class="text-xs muted-2" style="margin-bottom:.5rem">El garante no aumenta el cupo asignado.</p>

                        @if (garante != null)
                        {
                            <!-- Garante asignado: mostrar estado -->
                            <div id="garanteAsignado">
                                <div style="display:flex;align-items:center;gap:.5rem;flex-wrap:wrap">
                                    <span class="text-sm text-white">@garante.NombreCompleto</span>
                                    <span class="text-xs muted-2">DNI @garante.NumeroDocumento</span>
                                    @if (garante.EsValido)
                                    {
                                        <span class="chip chip-ok" style="font-size:.7rem">Válido</span>
                                    }
                                    else
                                    {
                                        <span class="chip chip-bad" style="font-size:.7rem">Inválido</span>
                                    }
                                </div>
                                <div class="text-xs muted-2" style="margin-top:.2rem">
                                    Puntaje @garante.PuntajeCliente/5 &bull; @garante.CantidadGarantiasActivas garantía(s) activa(s) &bull; Alta @garante.FechaAlta.ToString("dd/MM/yyyy")
                                </div>
                                @if (!garante.EsValido && garante.MotivosInvalidez.Any())
                                {
                                    <ul style="margin:.3rem 0 0 1rem;padding:0;list-style:disc" class="text-xs" aria-label="Motivos de invalidez">
                                        @foreach (var motivo in garante.MotivosInvalidez)
                                        {
                                            <li style="color:#fb7185">@motivo</li>
                                        }
                                    </ul>
                                }
                                <div style="display:flex;gap:.4rem;margin-top:.5rem;flex-wrap:wrap">
                                    <button type="button" class="btn btn-ghost btn-sm"
                                            data-garante-cambiar
                                            data-cliente-id="@c.Id"
                                            title="Cambiar garante">
                                        <span class="material-symbols-outlined" style="font-size:14px">swap_horiz</span> Cambiar
                                    </button>
                                    <button type="button" class="btn btn-ghost btn-sm"
                                            data-garante-remover
                                            data-cliente-id="@c.Id"
                                            title="Quitar garante"
                                            style="color:#fb7185">
                                        <span class="material-symbols-outlined" style="font-size:14px">remove_circle_outline</span> Quitar
                                    </button>
                                </div>
                            </div>
                        }
                        else
                        {
                            <!-- Sin garante: botón para asignar -->
                            <div id="garanteSinAsignar">
                                <div class="text-xs muted-2">Sin garante asignado</div>
                                <button type="button" class="btn btn-ghost btn-sm" style="margin-top:.4rem"
                                        data-garante-asignar
                                        data-cliente-id="@c.Id">
                                    <span class="material-symbols-outlined" style="font-size:14px">person_add</span> Asignar garante
                                </button>
                            </div>
                        }
                    </div>
                </div>

                <!-- Modal: Asignar / Cambiar garante -->
                <div id="garanteModal" class="overlay hidden" role="dialog" aria-modal="true" aria-labelledby="garanteModalTitle">
                    <div class="modal">
                        <div class="modal-card card" style="max-width:540px">
                            <div class="drawer-head">
                                <div class="avatar avatar-sm avatar--slate">
                                    <span class="material-symbols-outlined" style="font-size:17px">supervisor_account</span>
                                </div>
                                <div class="min-w-0 flex-1">
                                    <h2 id="garanteModalTitle" class="sec-title">Asignar garante</h2>
                                    <p class="sec-sub">Buscá un cliente existente para asignar como garante.</p>
                                </div>
                                <button type="button" class="btn btn-ghost btn-sm" data-garante-modal-cerrar aria-label="Cerrar">
                                    <span class="material-symbols-outlined">close</span>
                                </button>
                            </div>

                            <div style="padding:1rem 1.25rem">
                                <label class="label" for="garanteBuscador">Buscar cliente</label>
                                <input type="text" id="garanteBuscador" class="field" placeholder="Apellido, nombre o DNI..." autocomplete="off" />
                                <div id="garanteResultados" style="margin-top:.5rem;max-height:220px;overflow-y:auto"></div>

                                <div id="garanteSeleccionado" class="hidden" style="margin-top:.75rem;padding:.6rem;background:rgba(255,255,255,.05);border-radius:6px">
                                    <div class="text-sm text-white" id="garanteSelNombre"></div>
                                    <div class="text-xs muted-2" id="garanteSelInfo"></div>
                                </div>

                                <div style="margin-top:.6rem">
                                    <label class="label" for="garanteObservacion">Observación (opcional)</label>
                                    <input type="text" id="garanteObservacion" class="field" placeholder="Motivo o nota..." maxlength="500" />
                                </div>

                                <div id="garanteError" class="hidden" style="margin-top:.5rem;color:#fb7185;font-size:.8rem"></div>
                            </div>

                            <div style="padding:.75rem 1.25rem 1rem;display:flex;gap:.5rem;justify-content:flex-end">
                                <button type="button" class="btn btn-ghost btn-sm" data-garante-modal-cerrar>Cancelar</button>
                                <button type="button" class="btn btn-primary btn-sm" id="garanteConfirmar" disabled>Confirmar</button>
                            </div>
                        </div>
                    </div>
                </div>

                </div>
                <a asp-controller="DocumentoCliente" asp-action="Index" asp-route-clienteId="@c.Id" class="btn btn-ghost btn-sm btn-block" style="margin-top:.9rem">Ver toda la documentacion<span class="material-symbols-outlined">chevron_right</span></a>
            </div>

            <div class="card card-pad" style="border-color:rgba(244,63,94,.25)">
                <h3 class="font-semibold text-white mb-1">Zona sensible</h3>
                <p class="text-sm muted mb-3">Dar de baja al cliente lo oculta del listado operativo. Se conserva el historial.</p>
                <a asp-action="Delete" asp-route-id="@c.Id" asp-route-returnUrl="@returnUrl" class="btn btn-ghost btn-sm btn-block" style="color:#fb7185;border-color:rgba(244,63,94,.3)"><span class="material-symbols-outlined">delete</span>Eliminar cliente</a>
            </div>
        </aside>
    </div>
</main>

<div id="limitesModalContainer"></div>

<div id="nivelManualModal"
     class="overlay hidden"
     aria-labelledby="nivelManualModalTitle" aria-modal="true" role="dialog">
    <div class="modal">
        <div class="modal-card card" style="max-width:620px">
            <div class="drawer-head">
                <div class="avatar avatar-sm avatar--slate"><span class="material-symbols-outlined" style="font-size:17px">rule_settings</span></div>
                <div class="min-w-0 flex-1">
                    <h2 id="nivelManualModalTitle" class="sec-title">Asignar puntaje manual</h2>
                    <p class="sec-sub">El puntaje manual pisa el calculo automatico hasta que se limpie.</p>
                </div>
                <button type="button" data-cliente-close-nivel-manual class="btn btn-ghost btn-sm" aria-label="Cerrar"><span class="material-symbols-outlined">close</span></button>
            </div>
            <form id="nivelManualForm"
                  asp-action="AsignarNivelCreditoManual"
                  method="post"
                  data-saldo-usado="@limiteUsado.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                @Html.AntiForgeryToken()
                <input type="hidden" name="clienteId" value="@c.Id" />
                @if (!string.IsNullOrWhiteSpace(returnUrl))
                {
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                }
                <div class="drawer-body">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        <div class="minimetric">
                            <div class="mm-label">Puntaje actual</div>
                            <div class="mm-value num">@nivelFinal<span class="text-xs muted-2 font-normal"> / 5</span></div>
                        </div>
                        <div class="minimetric">
                            <div class="mm-label">Limite actual</div>
                            <div class="mm-value num">@limiteTotal.ToString("C0")</div>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 gap-4 mt-4">
                        <div>
                            <label for="nivelCreditoManual" class="label">Puntaje crediticio manual <span class="req">*</span></label>
                            <select id="nivelCreditoManual" name="nivelCreditoManual" class="field" required>
                                @foreach (var opcion in nivelesDisponibles)
                                {
                                    <option value="@opcion.Nivel"
                                            data-limit="@opcion.LimiteMonto.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                            selected="@(nivelManual == opcion.Nivel ? "selected" : null)">
                                        @opcion.Texto - @opcion.LimiteMonto.ToString("C0")
                                    </option>
                                }
                            </select>
                        </div>
                        <div>
                            <label for="nivelManualMotivo" class="label">Motivo <span class="req">*</span></label>
                            <textarea id="nivelManualMotivo" name="motivo" rows="3" maxlength="1000" class="field" required placeholder="Describi por que se asigna este puntaje"></textarea>
                        </div>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                            <div class="minimetric">
                                <div class="mm-label">Nuevo limite</div>
                                <div class="mm-value num" id="nivelManualNuevoLimite">-</div>
                            </div>
                            <div class="minimetric">
                                <div class="mm-label">Disponible estimado</div>
                                <div class="mm-value num" id="nivelManualNuevoDisponible">-</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="drawer-foot">
                    <button type="button" data-cliente-close-nivel-manual class="btn btn-ghost">Cancelar</button>
                    <button type="submit" class="btn btn-primary"><span class="material-symbols-outlined">save</span>Guardar puntaje</button>
                </div>
            </form>
            @if (tieneNivelManual)
            {
                <form asp-action="LimpiarNivelCreditoManual" method="post" class="drawer-foot" style="border-top:1px solid rgba(255,255,255,.08)">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="clienteId" value="@c.Id" />
                    @if (!string.IsNullOrWhiteSpace(returnUrl))
                    {
                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                    }
                    <label for="limpiarNivelManualMotivo" class="sr-only">Motivo para limpiar</label>
                    <input id="limpiarNivelManualMotivo" name="motivo" class="field" required maxlength="1000" placeholder="Motivo para limpiar el override" />
                    <button type="submit" class="btn btn-ghost" style="color:#fbbf24;border-color:rgba(251,191,36,.35)">
                        <span class="material-symbols-outlined">restart_alt</span>Volver al automatico
                    </button>
                </form>
            }
        </div>
    </div>
</div>

<div id="rejectDocModal"
     class="overlay hidden"
     aria-labelledby="rejectDocModalTitle" aria-modal="true" role="dialog">
    <div class="modal">
        <div class="modal-card card">
            <div class="drawer-head">
                <div class="avatar avatar-sm avatar--slate"><span class="material-symbols-outlined" style="font-size:17px">block</span></div>
                <div class="min-w-0 flex-1">
                    <h2 id="rejectDocModalTitle" class="sec-title">Rechazar documento</h2>
                    <p class="sec-sub">El motivo quedara registrado en el historial.</p>
                </div>
                <button type="button" id="rejectDocModalClose" class="btn btn-ghost btn-sm" aria-label="Cerrar"><span class="material-symbols-outlined">close</span></button>
            </div>
            <div class="drawer-body">
                <label for="rejectDocMotivo" class="label">Motivo <span class="req">*</span></label>
                <textarea id="rejectDocMotivo" rows="3" maxlength="500" class="field" placeholder="Describi el motivo del rechazo"></textarea>
                <p id="rejectDocMotivoError" class="err-text hidden">El motivo es obligatorio.</p>
            </div>
            <div class="drawer-foot">
                <button type="button" id="rejectDocModalCancelBtn" class="btn btn-ghost">Cancelar</button>
                <button type="button" id="rejectDocModalConfirmBtn" class="btn btn-danger"><span class="material-symbols-outlined">block</span>Confirmar rechazo</button>
            </div>
        </div>
    </div>
</div>

<div id="uploadDocModal" class="overlay hidden" aria-modal="true" role="dialog" aria-label="Subir documento">
    <div class="modal">
        <div class="modal-card card" style="max-width:560px">
            <div class="drawer-head">
                <div class="avatar avatar-sm avatar--slate"><span class="material-symbols-outlined" style="font-size:17px">upload_file</span></div>
                <div class="min-w-0 flex-1">
                    <h2 class="sec-title">Subir documento</h2>
                    <p id="uploadModalSubtitle" class="sec-sub">Adjuntar documentacion para @clienteNombre</p>
                </div>
                <button type="button" data-cliente-upload-close class="btn btn-ghost btn-sm" aria-label="Cerrar"><span class="material-symbols-outlined">close</span></button>
            </div>
            <form id="uploadDocForm" asp-controller="DocumentoCliente" asp-action="Upload" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ClienteId" value="@c.Id" />
                <input type="hidden" name="returnToDetails" value="true" />
                <input type="hidden" name="returnUrl" value="@returnToDetails" />
                <input type="hidden" name="DocumentoAReemplazarId" id="modalReplaceId" value="" />
                <input type="hidden" name="ReemplazarExistente" id="modalReemplazar" value="false" />

                <div class="drawer-body">
                    <div id="uploadModalErrors" class="alert alert-bad hidden" style="margin-bottom:1rem"></div>
                    <div class="grid grid-cols-1 gap-4">
                        <div>
                            <label for="modalTipoDocumento" class="label">Tipo de documento</label>
                            <select name="TipoDocumento" id="modalTipoDocumento" class="field">
                                <option value="">Seleccionar tipo</option>
                                <option value="1">DNI</option>
                                <option value="2">Recibo de Sueldo</option>
                                <option value="3">Servicio</option>
                                <option value="6">Constancia CUIL</option>
                                <option value="8">Veraz</option>
                                <option value="99">Otro</option>
                            </select>
                        </div>
                        <div>
                            <label class="label">Archivo</label>
                            <div id="modalDropZone" class="ph" style="position:relative;cursor:pointer">
                                <input type="file" name="Archivo" id="modalArchivoInput" accept=".pdf,.jpg,.jpeg,.png" style="position:absolute;inset:0;opacity:0;cursor:pointer" />
                                <div id="modalDropContent">
                                    <span class="material-symbols-outlined">cloud_upload</span>
                                    <div class="ph-label">arrastrar o seleccionar archivo</div>
                                    <p class="text-xs muted-2">PDF, JPG, PNG - max. 5 MB</p>
                                </div>
                                <div id="modalFilePreview" class="hidden">
                                    <span class="material-symbols-outlined">description</span>
                                    <p id="modalFileName" class="text-sm font-semibold text-white"></p>
                                    <p id="modalFileSize" class="text-xs muted-2"></p>
                                </div>
                            </div>
                        </div>
                        <div>
                            <label for="modalFechaVencimiento" class="label">Fecha de vencimiento</label>
                            <input type="date" name="FechaVencimiento" id="modalFechaVencimiento" class="field" />
                            <p class="hint">Opcional. Dejar vacio si el documento no vence.</p>
                        </div>
                        <div>
                            <label for="modalObservaciones" class="label">Observaciones</label>
                            <textarea name="Observaciones" id="modalObservaciones" rows="2" class="field" placeholder="Notas o aclaraciones"></textarea>
                        </div>
                    </div>
                </div>
                <div class="drawer-foot">
                    <button type="button" data-cliente-upload-close class="btn btn-ghost">Cancelar</button>
                    <button type="submit" id="btnSubirDoc" class="btn btn-primary"><span class="material-symbols-outlined">cloud_upload</span>Subir documento</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/cliente-index.js" asp-append-version="true"></script>
    <script src="~/js/cliente-details.js" asp-append-version="true"></script>

    <script>
    // ── Módulo garante ────────────────────────────────────────────────────────
    (function () {
        const modal       = document.getElementById('garanteModal');
        const buscador    = document.getElementById('garanteBuscador');
        const resultados  = document.getElementById('garanteResultados');
        const selBox      = document.getElementById('garanteSeleccionado');
        const selNombre   = document.getElementById('garanteSelNombre');
        const selInfo     = document.getElementById('garanteSelInfo');
        const obsInput    = document.getElementById('garanteObservacion');
        const errBox      = document.getElementById('garanteError');
        const btnConfirmar = document.getElementById('garanteConfirmar');

        if (!modal) return; // no está en el DOM (sin permiso o sin sección)

        let selectedClienteId = null;
        let activoClienteId   = null; // clienteId del titular

        function abrirModal(clienteId) {
            activoClienteId   = clienteId;
            selectedClienteId = null;
            if (buscador)    buscador.value = '';
            if (resultados)  resultados.innerHTML = '';
            if (selBox)      selBox.classList.add('hidden');
            if (obsInput)    obsInput.value = '';
            if (errBox)      { errBox.textContent = ''; errBox.classList.add('hidden'); }
            if (btnConfirmar) btnConfirmar.disabled = true;
            modal.classList.remove('hidden');
            buscador && buscador.focus();
        }

        function cerrarModal() {
            modal.classList.add('hidden');
        }

        document.querySelectorAll('[data-garante-asignar],[data-garante-cambiar]').forEach(btn => {
            btn.addEventListener('click', () => abrirModal(btn.dataset.clienteId ?? btn.dataset.garanteAsignar ?? btn.dataset.garanteCambiar));
        });

        document.querySelectorAll('[data-garante-modal-cerrar]').forEach(btn => {
            btn.addEventListener('click', cerrarModal);
        });

        modal.addEventListener('click', e => { if (e.target === modal) cerrarModal(); });

        // ── Búsqueda AJAX ────────────────────────────────────────────────────
        let debounce = null;
        buscador && buscador.addEventListener('input', () => {
            clearTimeout(debounce);
            debounce = setTimeout(async () => {
                const q = buscador.value.trim();
                if (q.length < 2) { resultados.innerHTML = ''; return; }

                resultados.innerHTML = '<div class="text-xs muted-2" style="padding:.4rem">Buscando...</div>';
                try {
                    const resp = await fetch(`/Cliente/BuscarPosiblesGarantes?q=${encodeURIComponent(q)}&clienteId=${activoClienteId}`);
                    const data = await resp.json();

                    if (!data.length) {
                        resultados.innerHTML = '<div class="text-xs muted-2" style="padding:.4rem">Sin resultados.</div>';
                        return;
                    }

                    resultados.innerHTML = data.map(d => `
                        <div class="doc-row" style="cursor:pointer;padding:.4rem .5rem;border-radius:4px"
                             data-garante-candidato
                             data-id="${d.clienteId}"
                             data-nombre="${d.nombreCompleto}"
                             data-dni="${d.numeroDocumento}"
                             data-puntaje="${d.puntajeCliente}"
                             data-compras="${d.cantidadCompras}"
                             data-garantias="${d.garantiasActivas}">
                            <div class="flex-1 min-w-0">
                                <div class="text-sm text-white">${d.nombreCompleto}</div>
                                <div class="text-xs muted-2">DNI ${d.numeroDocumento} &bull; Puntaje ${d.puntajeCliente}/5 &bull; ${d.cantidadCompras} compra(s) &bull; ${d.garantiasActivas} garantia(s)</div>
                            </div>
                        </div>`).join('');

                    resultados.querySelectorAll('[data-garante-candidato]').forEach(row => {
                        row.addEventListener('click', () => seleccionarCandidato(row));
                    });
                } catch {
                    resultados.innerHTML = '<div class="text-xs" style="color:#fb7185;padding:.4rem">Error al buscar.</div>';
                }
            }, 300);
        });

        function seleccionarCandidato(row) {
            selectedClienteId = row.dataset.id;
            selNombre.textContent = row.dataset.nombre;
            selInfo.textContent   = `DNI ${row.dataset.dni} — Puntaje ${row.dataset.puntaje}/5 — ${row.dataset.compras} compra(s) — ${row.dataset.garantias} garantía(s) activa(s)`;
            selBox.classList.remove('hidden');
            resultados.innerHTML = '';
            if (buscador) buscador.value = row.dataset.nombre;
            btnConfirmar.disabled = false;
            errBox.textContent = ''; errBox.classList.add('hidden');
        }

        // ── Confirmar asignación ─────────────────────────────────────────────
        btnConfirmar && btnConfirmar.addEventListener('click', async () => {
            if (!selectedClienteId) return;
            btnConfirmar.disabled = true;

            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
            try {
                const resp = await fetch('/Cliente/AsignarGarante', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                    body: JSON.stringify({
                        clienteId: parseInt(activoClienteId),
                        garanteClienteId: parseInt(selectedClienteId),
                        observacion: obsInput ? obsInput.value.trim() : null
                    })
                });

                if (resp.ok) {
                    cerrarModal();
                    window.location.reload();
                } else {
                    const data = await resp.json();
                    errBox.textContent = data.error ?? 'Error al asignar garante.';
                    errBox.classList.remove('hidden');
                    btnConfirmar.disabled = false;
                }
            } catch {
                errBox.textContent = 'Error de red. Intentá de nuevo.';
                errBox.classList.remove('hidden');
                btnConfirmar.disabled = false;
            }
        });

        // ── Remover garante ──────────────────────────────────────────────────
        document.querySelectorAll('[data-garante-remover]').forEach(btn => {
            btn.addEventListener('click', async () => {
                if (!confirm('¿Confirmás que querés quitar el garante de este cliente?')) return;

                const clienteId = btn.dataset.clienteId;
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
                try {
                    const resp = await fetch('/Cliente/RemoverGarante', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                        body: JSON.stringify({ clienteId: parseInt(clienteId), motivo: 'Removido desde ficha de cliente.' })
                    });

                    if (resp.ok) {
                        window.location.reload();
                    } else {
                        const data = await resp.json();
                        alert(data.error ?? 'Error al quitar el garante.');
                    }
                } catch {
                    alert('Error de red. Intentá de nuevo.');
                }
            });
        });
    })();
    </script>
}
