@model ClienteFilterViewModel
@{
    ViewData["Title"] = "Gestión de Clientes";
    ViewData["MetaDescription"] = "Administración de clientes, límites de crédito y documentación asociada en el ERP TheBuryProject.";

    var clientes = Model.Clientes?.ToList() ?? new List<ClienteViewModel>();
    var totalEnPagina = clientes.Count;
    var filtroClienteActivo = !string.IsNullOrWhiteSpace(Model.SearchTerm)
                            || Model.SoloActivos.HasValue
                            || !string.IsNullOrWhiteSpace(Model.TipoDocumento);
    var totalResultados = Model.TotalResultados > 0 ? Model.TotalResultados : totalEnPagina;

    string ClienteNombre(ClienteViewModel cliente)
    {
        if (!string.IsNullOrWhiteSpace(cliente.NombreCompleto))
        {
            return cliente.NombreCompleto;
        }

        return $"{cliente.Apellido}, {cliente.Nombre}".Trim(' ', ',');
    }

    string RiesgoTexto(ClienteViewModel cliente)
    {
        var riesgo = cliente.NivelRiesgo.ToString();

        if (riesgo.Contains("Rechazado")) return "No apto";
        if (riesgo.Contains("Condicional") || riesgo.Contains("Limitado")) return "Requiere aut.";

        return cliente.PuntajeRiesgo > 0 ? "Apto" : "No evaluado";
    }

    string RiesgoChip(ClienteViewModel cliente)
    {
        var riesgo = cliente.NivelRiesgo.ToString();

        if (riesgo.Contains("Rechazado")) return "chip-bad";
        if (riesgo.Contains("Condicional") || riesgo.Contains("Limitado")) return "chip-warn";

        return cliente.PuntajeRiesgo > 0 ? "chip-ok" : "chip-neutral";
    }

    string RiesgoIcon(ClienteViewModel cliente)
    {
        var chip = RiesgoChip(cliente);

        if (chip == "chip-bad") return "block";
        if (chip == "chip-warn") return "gpp_maybe";
        if (chip == "chip-ok") return "verified";

        return "remove";
    }

    int RiesgoPct(ClienteViewModel cliente)
    {
        if (cliente.PuntajeRiesgo <= 0) return 0;

        return Math.Clamp(
            (int)Math.Round((double)cliente.PuntajeRiesgo * 10, MidpointRounding.AwayFromZero),
            0,
            100
        );
    }

    string BarClass(ClienteViewModel cliente)
    {
        var chip = RiesgoChip(cliente);

        if (chip == "chip-bad") return "is-bad";
        if (chip == "chip-warn") return "is-warn";

        return "is-ok";
    }
}

@section Styles {
    <partial name="_ClienteModuleStyles" />
}

@if (TempData["Success"] != null || TempData["Error"] != null)
{
    <div id="clienteIndexFeedback" class="shell cliente-feedback" role="alert" aria-live="polite">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-ok">
                <span class="material-symbols-outlined" aria-hidden="true">check_circle</span>
                <span class="flex-1 self-center">@TempData["Success"]</span>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-bad">
                <span class="material-symbols-outlined" aria-hidden="true">error</span>
                <span class="flex-1 self-center">@TempData["Error"]</span>
            </div>
        }
    </div>
}
else
{
    <div id="clienteIndexFeedback" class="hidden shell cliente-feedback" role="alert" aria-live="polite"></div>
}

<main class="shell cliente-index" aria-labelledby="cliente-page-title">
    <header class="page-head cliente-page-head">
        <div class="page-head__copy min-w-0">
            <h1 id="cliente-page-title" class="page-title">Gestión de Clientes</h1>
            <p class="page-sub">
                Buscá clientes, revisá aptitud crediticia y administrá documentación asociada.
            </p>
        </div>

        <div class="head-actions cliente-head-actions" aria-label="Acciones principales de clientes">
            <button type="button" class="btn btn-primary cliente-primary-action" data-cliente-modal-open="create">
                <span class="material-symbols-outlined" aria-hidden="true">person_add</span>
                Nuevo cliente
            </button>

            <a asp-controller="DocumentoCliente" asp-action="Index" class="btn btn-ghost">
                <span class="material-symbols-outlined" aria-hidden="true">folder_shared</span>
                Documentos
            </a>

            <a asp-controller="Credito" asp-action="Index" class="btn btn-ghost">
                <span class="material-symbols-outlined" aria-hidden="true">credit_score</span>
                Créditos
            </a>

            <button type="button" class="btn btn-soft cliente-admin-action" data-cliente-open-limites>
                <span class="material-symbols-outlined" aria-hidden="true">tune</span>
                Límites por puntaje
            </button>
        </div>
    </header>

    <section class="cliente-section" aria-labelledby="cliente-list-title">
        <div class="cliente-list-head">
            <div class="cliente-list-title">
                <h2 id="cliente-list-title" class="sec-title">Listado de clientes</h2>

                @if (filtroClienteActivo)
                {
                    <span class="chip chip-info">
                        <span class="material-symbols-outlined" aria-hidden="true">filter_alt</span>
                        Filtros activos
                    </span>
                }
            </div>

            <span class="cliente-result-summary" aria-live="polite">
                Mostrando @totalEnPagina de @totalResultados clientes
            </span>
        </div>

        <form id="filterForm" method="get" asp-action="Index" class="filters card card-pad cliente-filters"
              role="search" aria-label="Buscar y filtrar clientes">
            <div class="field-icon cliente-search-field">
                <span class="material-symbols-outlined" aria-hidden="true">search</span>
                <input name="SearchTerm" value="@Model.SearchTerm" class="field" placeholder="Buscar cliente..."
                       autocomplete="off" aria-label="Buscar cliente por nombre, documento, teléfono o email">
            </div>

            <select name="SoloActivos" class="field cliente-filter-select" aria-label="Estado del cliente">
                <option value="">Todos los estados</option>

                @if (Model.SoloActivos == true)
                {
                    <option value="true" selected>Solo activos</option>
                }
                else
                {
                    <option value="true">Solo activos</option>
                }

                @if (Model.SoloActivos == false)
                {
                    <option value="false" selected>Solo inactivos</option>
                }
                else
                {
                    <option value="false">Solo inactivos</option>
                }
            </select>

            <select name="TipoDocumento" class="field cliente-filter-select" aria-label="Tipo de documento">
                @if (string.IsNullOrWhiteSpace(Model.TipoDocumento))
                {
                    <option value="" selected>Todo documento</option>
                }
                else
                {
                    <option value="">Todo documento</option>
                }

                @if (ViewBag.TiposDocumento != null)
                {
                    foreach (var tipo in (SelectList)ViewBag.TiposDocumento)
                    {
                        var tipoValue = string.IsNullOrWhiteSpace(tipo.Value) ? tipo.Text : tipo.Value;

                        if (Model.TipoDocumento == tipoValue)
                        {
                            <option value="@tipoValue" selected>@tipo.Text</option>
                        }
                        else
                        {
                            <option value="@tipoValue">@tipo.Text</option>
                        }
                    }
                }
            </select>

            <button type="submit" class="btn btn-soft">
                <span class="material-symbols-outlined" aria-hidden="true">filter_list</span>
                Filtrar
            </button>

            @if (filtroClienteActivo)
            {
                <a asp-action="Index" class="btn btn-ghost">
                    <span class="material-symbols-outlined" aria-hidden="true">close</span>
                    Limpiar
                </a>
            }
        </form>

        <div class="card cliente-table-card hide-mobile" data-oc-scroll>
            <div class="scroll-hint cliente-scroll-hint hide-mobile" data-oc-scroll-hint hidden>
                <span class="material-symbols-outlined" aria-hidden="true">swipe</span>
                Deslizá para ver más
            </div>

            <div data-oc-scroll-shell>
                <div data-oc-scroll-fade="left" hidden></div>
                <div data-oc-scroll-fade="right" hidden></div>

                <div class="tbl-wrap" data-oc-scroll-region tabindex="0" role="region"
                     aria-label="Listado de clientes en tabla" aria-describedby="result-count cliente-table-help">
                    <table class="tbl cliente-table" data-oc-scroll-table>
                        <colgroup>
                            <col class="cliente-col-nombre" />
                            <col class="cliente-col-documento" />
                            <col class="cliente-col-contacto" />
                            <col class="cliente-col-aptitud" />
                            <col class="cliente-col-credito" />
                            <col class="cliente-col-estado" />
                            <col class="cliente-col-acciones" />
                        </colgroup>

                        <thead>
                            <tr>
                                <th scope="col">Cliente</th>
                                <th scope="col">Documento</th>
                                <th scope="col">Contacto</th>
                                <th scope="col">Aptitud</th>
                                <th scope="col">Crédito</th>
                                <th scope="col">Estado</th>
                                <th scope="col" class="text-right">Acciones</th>
                            </tr>
                        </thead>

                        <tbody id="clientes-body">
                            @if (clientes.Any())
                            {
                                foreach (var c in clientes)
                                {
                                    var pct = RiesgoPct(c);
                                    var estado = c.Activo ? "activo" : "inactivo";
                                    var rowName = ClienteNombre(c);
                                    var telefono = string.IsNullOrWhiteSpace(c.Telefono) ? "Sin teléfono" : c.Telefono;
                                    var email = string.IsNullOrWhiteSpace(c.Email) ? "Sin email" : c.Email;
                                    var docSecundario = string.IsNullOrWhiteSpace(c.CuilCuit) ? c.TipoDocumento : c.CuilCuit;

                                    <tr data-cliente-row-id="@c.Id" data-estado="@estado" data-tipodoc="@c.TipoDocumento">
                                        <td>
                                            <div class="cliente-name-cell" title="@rowName">
                                                <div class="font-medium @(c.Activo ? "text-white" : "text-slate-400")">
                                                    @rowName
                                                </div>
                                            </div>
                                        </td>

                                        <td>
                                            <div class="mono text-sm text-slate-200" title="@c.NumeroDocumento">
                                                @c.NumeroDocumento
                                            </div>
                                            <div class="mono text-xs muted-2" title="@docSecundario">
                                                @docSecundario
                                            </div>
                                        </td>

                                        <td>
                                            <div class="text-sm muted" title="@telefono">@telefono</div>
                                            <div class="text-xs muted-2" title="@email">@email</div>
                                        </td>

                                        <td>
                                            <span class="chip @RiesgoChip(c)">
                                                <span class="material-symbols-outlined" aria-hidden="true">@RiesgoIcon(c)</span>
                                                @RiesgoTexto(c)
                                            </span>
                                        </td>

                                        <td>
                                            <div class="cliente-credit-cell">
                                                <span class="text-sm font-semibold text-white num">
                                                    @((c.MontoAdeudado ?? 0m).ToString("C"))
                                                </span>
                                                <span class="text-xs muted-2">
                                                    @(pct > 0 ? $"{pct}%" : "-")
                                                </span>
                                            </div>

                                            <div class="bar" aria-hidden="true">
                                                <div class="bar-fill @BarClass(c)" style="width:@pct%"></div>
                                            </div>
                                        </td>

                                        <td>
                                            <span class="chip @(c.Activo ? "chip-ok" : "chip-neutral")">
                                                @(c.Activo ? "Activo" : "Inactivo")
                                            </span>
                                        </td>

                                        <td>
                                            <div class="row-actions">
                                                <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-soft btn-sm"
                                                   title="Ver legajo de @rowName">
                                                    <span class="material-symbols-outlined" aria-hidden="true">visibility</span>
                                                    Ver
                                                </a>

                                                <button type="button" class="btn btn-ghost btn-sm cliente-row-action--icon"
                                                        data-cliente-modal-open="edit" data-cliente-id="@c.Id"
                                                        aria-label="Editar @rowName" title="Editar @rowName">
                                                    <span class="material-symbols-outlined" aria-hidden="true">edit</span>
                                                </button>

                                                <a asp-controller="Credito" asp-action="Index" asp-route-clienteId="@c.Id"
                                                   class="btn btn-ghost btn-sm cliente-row-action--icon"
                                                   aria-label="Ver créditos de @rowName" title="Ver créditos de @rowName">
                                                    <span class="material-symbols-outlined"
                                                          aria-hidden="true">credit_score</span>
                                                </a>

                                                <details class="cliente-row-menu relative" data-cliente-row-menu>
                                                    <summary
                                                        class="btn btn-ghost btn-sm cursor-pointer cliente-row-action--icon"
                                                        aria-label="Más acciones para @rowName"
                                                        title="Más acciones para @rowName">
                                                        <span class="material-symbols-outlined"
                                                              aria-hidden="true">more_vert</span>
                                                    </summary>

                                                    <div class="cliente-row-menu__content">
                                                        <button type="button"
                                                                data-delete-url="@Url.Action("Delete", new { id = c.Id })"
                                                                data-nombre="@rowName"
                                                                class="cliente-row-menu__item cliente-row-menu__item--danger">
                                                            <span class="material-symbols-outlined"
                                                                  aria-hidden="true">delete</span>
                                                            Eliminar
                                                        </button>
                                                    </div>
                                                </details>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="cliente-table-footer">
                <span id="result-count">Mostrando @totalEnPagina de @totalResultados clientes</span>
                <span id="cliente-table-help">
                    Acciones directas: ver, editar y créditos. Eliminación queda en el menú de fila.
                </span>
            </div>
        </div>

        <div class="m-card cliente-mobile-list" id="clientes-cards" aria-label="Listado de clientes en tarjetas">
            @foreach (var c in clientes)
            {
                var rowName = ClienteNombre(c);
                var pct = RiesgoPct(c);
                var telefono = string.IsNullOrWhiteSpace(c.Telefono) ? "Sin teléfono" : c.Telefono;
                var email = string.IsNullOrWhiteSpace(c.Email) ? "Sin email" : c.Email;

                <article class="card card-pad cliente-mobile-card" data-cliente-row-id="@c.Id"
                         data-estado="@(c.Activo ? "activo" : "inactivo")" data-tipodoc="@c.TipoDocumento">
                    <div class="cliente-card-top">
                        <div class="cliente-mobile-person">
                            <div class="cliente-mobile-person__text">
                                <div class="font-medium @(c.Activo ? "text-white" : "text-slate-400")">
                                    @rowName
                                </div>
                                <div class="mono text-xs muted-2">@c.NumeroDocumento</div>
                            </div>
                        </div>

                        <span class="chip @RiesgoChip(c)">
                            <span class="material-symbols-outlined" aria-hidden="true">@RiesgoIcon(c)</span>
                            @RiesgoTexto(c)
                        </span>
                    </div>

                    <div class="cliente-card-meta">
                        <span class="chip @(c.Activo ? "chip-ok" : "chip-neutral")">
                            @(c.Activo ? "Activo" : "Inactivo")
                        </span>

                        <span class="cliente-card-contact" title="@telefono">@telefono</span>
                        <span class="cliente-card-contact" title="@email">@email</span>
                    </div>

                    <div class="minimetric cliente-card-credit">
                        <div class="mm-label">Crédito</div>
                        <div class="mm-value num">
                            @((c.MontoAdeudado ?? 0m).ToString("C"))
                            <span class="text-xs muted-2 font-normal">
                                @(pct > 0 ? $"· {pct}%" : string.Empty)
                            </span>
                        </div>

                        <div class="bar cliente-card-bar" aria-hidden="true">
                            <div class="bar-fill @BarClass(c)" style="width:@pct%"></div>
                        </div>
                    </div>

                    <div class="cliente-card-actions">
                        <a asp-action="Details" asp-route-id="@c.Id"
                           class="btn btn-soft btn-sm btn-block cliente-card-actions__primary">
                            <span class="material-symbols-outlined" aria-hidden="true">visibility</span>
                            Ver legajo
                        </a>

                        <button type="button" class="btn btn-ghost btn-sm" data-cliente-modal-open="edit"
                                data-cliente-id="@c.Id" aria-label="Editar @rowName">
                            <span class="material-symbols-outlined" aria-hidden="true">edit</span>
                            Editar
                        </button>

                        <a asp-controller="Credito" asp-action="Index" asp-route-clienteId="@c.Id"
                           class="btn btn-ghost btn-sm" aria-label="Ver créditos de @rowName">
                            <span class="material-symbols-outlined" aria-hidden="true">credit_score</span>
                            Créditos
                        </a>

                        <details class="cliente-card-menu" data-cliente-row-menu>
                            <summary class="btn btn-ghost btn-sm btn-block">
                                <span class="material-symbols-outlined" aria-hidden="true">more_horiz</span>
                                Más acciones
                            </summary>

                            <div class="cliente-card-menu__content">
                                <button type="button" data-delete-url="@Url.Action("Delete", new { id = c.Id })"
                                        data-nombre="@rowName" class="cliente-row-menu__item cliente-row-menu__item--danger">
                                    <span class="material-symbols-outlined" aria-hidden="true">delete</span>
                                    Eliminar
                                </button>
                            </div>
                        </details>
                    </div>
                </article>
            }
        </div>

        @if (!clientes.Any())
        {
            <div class="card cliente-empty-card" id="empty-state">
                <div class="empty">
                    <div class="empty-ic">
                        <span class="material-symbols-outlined" aria-hidden="true">person_search</span>
                    </div>

                    <h3>Sin resultados</h3>
                    <p>No encontramos clientes con esos filtros. Probá con otros términos o limpiá la búsqueda.</p>

                    <a asp-action="Index" class="btn btn-soft btn-sm empty-action">
                        <span class="material-symbols-outlined" aria-hidden="true">close</span>
                        Limpiar filtros
                    </a>
                </div>
            </div>
        }
    </section>
</main>

<div id="limitesModalContainer"></div>

<partial name="_ClienteModal" />

@section Scripts {
    <script src="~/js/module-index.js" asp-append-version="true"></script>
    <script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
    <script src="~/js/cliente-index.js" asp-append-version="true"></script>
    <script src="~/js/cliente-cuil.js" asp-append-version="true"></script>
    <script src="~/js/cliente-modal.js" asp-append-version="true"></script>
}
