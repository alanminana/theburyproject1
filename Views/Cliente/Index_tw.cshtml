@model ClienteFilterViewModel
@{
    ViewData["Title"] = "Gestión de Clientes";
    ViewData["MetaDescription"] = "Administración de clientes, límites de crédito y documentación asociada en el ERP TheBuryProject.";

    var clientes = Model.Clientes?.ToList() ?? new List<ClienteViewModel>();
    var totalEnPagina = clientes.Count;
    var clientesActivos = clientes.Count(c => c.Activo);
    var filtroClienteActivo = !string.IsNullOrEmpty(Model.SearchTerm)
                            || Model.SoloActivos.HasValue
                            || !string.IsNullOrEmpty(Model.TipoDocumento);
    var totalResultados = Model.TotalResultados > 0 ? Model.TotalResultados : totalEnPagina;
    var clientesConAtencion = clientes.Count(c => c.CuotasImpagas > 0 || c.NivelRiesgo.ToString().Contains("Rechazado"));
    var montoRegistrado = clientes.Sum(c => c.MontoAdeudado ?? 0m);
    var docsPendientes = 0;

    string ClienteNombre(ClienteViewModel cliente)
    {
        if (!string.IsNullOrWhiteSpace(cliente.NombreCompleto))
        {
            return cliente.NombreCompleto;
        }

        return $"{cliente.Apellido}, {cliente.Nombre}".Trim(' ', ',');
    }

    string Iniciales(ClienteViewModel cliente)
    {
        var apellido = string.IsNullOrWhiteSpace(cliente.Apellido) ? string.Empty : cliente.Apellido.Trim();
        var nombre = string.IsNullOrWhiteSpace(cliente.Nombre) ? string.Empty : cliente.Nombre.Trim();
        var initials = $"{(apellido.Length > 0 ? apellido[0] : '?')}{(nombre.Length > 0 ? nombre[0] : '?')}";
        return initials.ToUpperInvariant();
    }

    string RiesgoTexto(ClienteViewModel cliente)
    {
        var riesgo = cliente.NivelRiesgo.ToString();
        if (riesgo.Contains("Rechazado")) return "No apto";
        if (riesgo.Contains("Condicional") || riesgo.Contains("Limitado")) return "Requiere aut.";
        return cliente.PuntajeRiesgo > 0 ? "Apto" : "No evaluado";
    }

    string RiesgoChip(ClienteViewModel cliente)
    {
        var riesgo = cliente.NivelRiesgo.ToString();
        if (riesgo.Contains("Rechazado")) return "chip-bad";
        if (riesgo.Contains("Condicional") || riesgo.Contains("Limitado")) return "chip-warn";
        return cliente.PuntajeRiesgo > 0 ? "chip-ok" : "chip-neutral";
    }

    string RiesgoIcon(ClienteViewModel cliente)
    {
        var chip = RiesgoChip(cliente);
        if (chip == "chip-bad") return "block";
        if (chip == "chip-warn") return "gpp_maybe";
        if (chip == "chip-ok") return "verified";
        return "remove";
    }

    int RiesgoPct(ClienteViewModel cliente)
    {
        if (cliente.PuntajeRiesgo <= 0) return 0;
        return Math.Clamp((int)Math.Round((double)cliente.PuntajeRiesgo * 10, MidpointRounding.AwayFromZero), 0, 100);
    }

    string BarClass(ClienteViewModel cliente)
    {
        var chip = RiesgoChip(cliente);
        if (chip == "chip-bad") return "is-bad";
        if (chip == "chip-warn") return "is-warn";
        return "is-ok";
    }

    string PersonaSubtitulo(ClienteViewModel cliente)
    {
        var partes = new List<string>();
        if (!string.IsNullOrWhiteSpace(cliente.EstadoCivil)) partes.Add(cliente.EstadoCivil);
        if (cliente.Edad.HasValue) partes.Add($"{cliente.Edad} años");
        if (!partes.Any() && !string.IsNullOrWhiteSpace(cliente.TipoEmpleo)) partes.Add(cliente.TipoEmpleo);
        return partes.Any() ? string.Join(" · ", partes) : "Sin datos adicionales";
    }
}

@section Styles {
    <partial name="_ClienteModuleStyles" />
}

@if (TempData["Success"] != null || TempData["Error"] != null)
{
    <div id="clienteIndexFeedback" class="shell" style="margin-top:1rem" role="alert" aria-live="polite">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-ok"><span class="material-symbols-outlined">check_circle</span><span class="flex-1 self-center">@TempData["Success"]</span></div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-bad"><span class="material-symbols-outlined">error</span><span class="flex-1 self-center">@TempData["Error"]</span></div>
        }
    </div>
}
else
{
    <div id="clienteIndexFeedback" class="hidden shell" style="margin-top:1rem" role="alert" aria-live="polite"></div>
}

<main class="shell" style="padding-top:1.75rem;padding-bottom:3rem">
    <div class="page-head">
        <div class="min-w-0">
            <h1 class="page-title">Gestión de Clientes</h1>
            <p class="page-sub">Administrá clientes, límites de crédito y documentación asociada. Evaluá aptitud crediticia y situación BCRA.</p>
        </div>
        <div class="head-actions">
            <a asp-controller="DocumentoCliente" asp-action="Index" class="btn btn-ghost"><span class="material-symbols-outlined">folder_shared</span>Documentos</a>
            <a asp-controller="Credito" asp-action="Index" class="btn btn-ghost"><span class="material-symbols-outlined">credit_score</span>Créditos</a>
            <button type="button" class="btn btn-soft" data-cliente-open-limites><span class="material-symbols-outlined">tune</span>Límites por puntaje</button>
            <button type="button" class="btn btn-primary" data-cliente-modal-open="create"><span class="material-symbols-outlined">person_add</span>Nuevo cliente</button>
        </div>
    </div>

    <div class="grid-kpi" style="margin-top:1.5rem">
        <div class="kpi">
            <div class="kpi-label"><span class="material-symbols-outlined" style="font-size:15px">groups</span>Clientes activos</div>
            <div class="kpi-value">@clientesActivos</div>
            <div class="kpi-foot">de @totalResultados registrados</div>
        </div>
        <div class="kpi kpi--accent">
            <div class="kpi-label"><span class="material-symbols-outlined" style="font-size:15px">account_balance_wallet</span>Crédito registrado</div>
            <div class="kpi-value">@montoRegistrado.ToString("C0")</div>
            <div class="kpi-foot">monto adeudado visible</div>
        </div>
        <div class="kpi kpi--warn">
            <div class="kpi-label"><span class="material-symbols-outlined" style="font-size:15px">gpp_maybe</span>Requieren atención</div>
            <div class="kpi-value">@clientesConAtencion</div>
            <div class="kpi-foot">mora · no aptos · revisión</div>
        </div>
        <div class="kpi">
            <div class="kpi-label"><span class="material-symbols-outlined" style="font-size:15px">draft</span>Docs pendientes</div>
            <div class="kpi-value">@docsPendientes</div>
            <div class="kpi-foot">se gestionan desde documentación</div>
        </div>
    </div>

    <section style="margin-top:2.25rem">
        <div class="flex items-center justify-between gap-3 mb-3 flex-wrap">
            <div class="flex items-center gap-2">
                <h2 class="text-base font-semibold text-white">Clientes</h2>
                <span class="chip chip-neutral mono">@totalEnPagina en esta página</span>
                @if (filtroClienteActivo)
                {
                    <span class="chip chip-info"><span class="material-symbols-outlined">filter_alt</span>Filtros activos</span>
                }
            </div>
            <div class="scroll-hint hide-mobile" data-oc-scroll-hint><span class="material-symbols-outlined" style="font-size:15px">swipe</span>Deslizá para ver más</div>
        </div>

        <form id="filterForm" method="get" asp-action="Index" class="filters card card-pad" style="padding:.85rem;margin-bottom:.9rem">
            <div class="field-icon">
                <span class="material-symbols-outlined">search</span>
                <input name="SearchTerm" value="@Model.SearchTerm" class="field" placeholder="Buscar por nombre, documento o CUIL/CUIT..." aria-label="Buscar cliente por nombre, documento o contacto">
            </div>
            <select name="SoloActivos" class="field" style="max-width:170px" aria-label="Estado del cliente">
                <option value="">Todos los estados</option>
                @if (Model.SoloActivos == true)
                {
                    <option value="true" selected>Solo activos</option>
                }
                else
                {
                    <option value="true">Solo activos</option>
                }
                @if (Model.SoloActivos == false)
                {
                    <option value="false" selected>Solo inactivos</option>
                }
                else
                {
                    <option value="false">Solo inactivos</option>
                }
            </select>
            <select name="TipoDocumento" class="field" style="max-width:160px" aria-label="Tipo de documento">
                @if (string.IsNullOrEmpty(Model.TipoDocumento))
                {
                    <option value="" selected>Todo documento</option>
                }
                else
                {
                    <option value="">Todo documento</option>
                }
                @if (ViewBag.TiposDocumento != null)
                {
                    foreach (var tipo in (SelectList)ViewBag.TiposDocumento)
                    {
                        var tipoValue = string.IsNullOrEmpty(tipo.Value) ? tipo.Text : tipo.Value;
                        if (Model.TipoDocumento == tipoValue)
                        {
                            <option value="@tipoValue" selected>@tipo.Text</option>
                        }
                        else
                        {
                            <option value="@tipoValue">@tipo.Text</option>
                        }
                    }
                }
            </select>
            <button type="submit" class="btn btn-soft"><span class="material-symbols-outlined">filter_list</span>Filtrar</button>
            @if (filtroClienteActivo)
            {
                <a asp-action="Index" class="btn btn-ghost"><span class="material-symbols-outlined">close</span>Limpiar</a>
            }
        </form>

        <div class="card hide-mobile" style="overflow:hidden" data-oc-scroll>
            <div class="tbl-wrap" data-oc-scroll-table>
                <table class="tbl">
                    <thead>
                        <tr>
                            <th>Cliente</th>
                            <th>Documento</th>
                            <th>Contacto</th>
                            <th>Aptitud</th>
                            <th>Crédito</th>
                            <th>Estado</th>
                            <th style="text-align:right">Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="clientes-body">
                        @if (clientes.Any())
                        {
                            foreach (var c in clientes)
                            {
                                var pct = RiesgoPct(c);
                                var estado = c.Activo ? "activo" : "inactivo";
                                var avatarClass = c.Activo ? "avatar" : "avatar avatar--off";
                                var rowName = ClienteNombre(c);
                                <tr data-cliente-row-id="@c.Id" data-estado="@estado" data-tipodoc="@c.TipoDocumento">
                                    <td>
                                        <div class="flex items-center gap-2.5">
                                            <div class="@avatarClass">@Iniciales(c)</div>
                                            <div class="min-w-0">
                                                <div class="font-medium @(c.Activo ? "text-white" : "text-slate-400")">@rowName</div>
                                                <div class="text-xs muted-2">@PersonaSubtitulo(c)</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="mono text-sm text-slate-200">@c.NumeroDocumento</div>
                                        <div class="mono text-xs muted-2">@(string.IsNullOrWhiteSpace(c.CuilCuit) ? c.TipoDocumento : c.CuilCuit)</div>
                                    </td>
                                    <td>
                                        <div class="text-sm muted">@(string.IsNullOrWhiteSpace(c.Telefono) ? "Sin teléfono" : c.Telefono)</div>
                                        <div class="text-xs muted-2">@(string.IsNullOrWhiteSpace(c.Email) ? "Sin email" : c.Email)</div>
                                    </td>
                                    <td><span class="chip @RiesgoChip(c)"><span class="material-symbols-outlined">@RiesgoIcon(c)</span>@RiesgoTexto(c)</span></td>
                                    <td style="min-width:150px">
                                        <div class="flex items-center justify-between mb-1"><span class="text-sm font-semibold text-white num">@((c.MontoAdeudado ?? 0m).ToString("C"))</span><span class="text-xs muted-2">@(pct > 0 ? $"{pct}%" : "-")</span></div>
                                        <div class="bar"><div class="bar-fill @BarClass(c)" style="width:@pct%"></div></div>
                                    </td>
                                    <td><span class="chip @(c.Activo ? "chip-ok" : "chip-neutral")">@(c.Activo ? "Activo" : "Inactivo")</span></td>
                                    <td>
                                        <div class="row-actions">
                                            <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-soft btn-sm"><span class="material-symbols-outlined">visibility</span>Ver</a>
                                            <button type="button" class="btn btn-ghost btn-sm" data-cliente-modal-open="edit" data-cliente-id="@c.Id" aria-label="Editar @rowName"><span class="material-symbols-outlined">edit</span></button>
                                            <a asp-controller="Credito" asp-action="Index" asp-route-clienteId="@c.Id" class="btn btn-ghost btn-sm" aria-label="Ver créditos de @rowName"><span class="material-symbols-outlined">credit_score</span></a>
                                            <details class="cliente-row-menu relative" data-cliente-row-menu>
                                                <summary class="btn btn-ghost btn-sm cursor-pointer" aria-label="Más acciones para @rowName"><span class="material-symbols-outlined">more_vert</span></summary>
                                                <div class="cliente-row-menu__content">
                                                    <button type="button" data-delete-url="@Url.Action("Delete", new { id = c.Id })" data-nombre="@rowName" class="cliente-row-menu__item cliente-row-menu__item--danger">
                                                        <span class="material-symbols-outlined text-[16px]">delete</span>Eliminar
                                                    </button>
                                                </div>
                                            </details>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <div class="px-4 py-2.5 text-xs muted-2 flex items-center justify-between" style="border-top:1px solid var(--line)">
                <span id="result-count">Mostrando @totalEnPagina de @totalResultados clientes</span>
                <span class="text-xs font-semibold muted">Acciones directas: ver, editar y créditos. Eliminación queda en el menú de fila.</span>
            </div>
        </div>

        <div class="m-card space-y-2.5" id="clientes-cards">
            @foreach (var c in clientes)
            {
                var rowName = ClienteNombre(c);
                var pct = RiesgoPct(c);
                <article class="card card-pad" data-cliente-row-id="@c.Id" data-estado="@(c.Activo ? "activo" : "inactivo")">
                    <div class="flex items-center justify-between gap-2">
                        <div class="flex items-center gap-2.5">
                            <div class="@(c.Activo ? "avatar" : "avatar avatar--off")">@Iniciales(c)</div>
                            <div><div class="font-medium @(c.Activo ? "text-white" : "text-slate-400")">@rowName</div><div class="mono text-xs muted-2">@c.NumeroDocumento</div></div>
                        </div>
                        <span class="chip @RiesgoChip(c)">@RiesgoTexto(c)</span>
                    </div>
                    <div class="mt-3 minimetric"><div class="mm-label">Crédito</div><div class="mm-value num">@((c.MontoAdeudado ?? 0m).ToString("C")) <span class="text-xs muted-2 font-normal">@(pct > 0 ? $"· {pct}%" : string.Empty)</span></div></div>
                    <div class="mt-3 flex gap-2">
                        <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-soft btn-sm btn-block"><span class="material-symbols-outlined">visibility</span>Ver legajo</a>
                        <button type="button" class="btn btn-ghost btn-sm" data-cliente-modal-open="edit" data-cliente-id="@c.Id" aria-label="Editar @rowName"><span class="material-symbols-outlined">edit</span></button>
                    </div>
                </article>
            }
        </div>

        @if (!clientes.Any())
        {
            <div class="card" id="empty-state">
                <div class="empty">
                    <div class="empty-ic"><span class="material-symbols-outlined">person_search</span></div>
                    <h3>Sin resultados</h3>
                    <p>No encontramos clientes con esos filtros. Probá con otros términos o limpiá la búsqueda.</p>
                    <a asp-action="Index" class="btn btn-soft btn-sm" style="margin-top:1rem"><span class="material-symbols-outlined">close</span>Limpiar filtros</a>
                </div>
            </div>
        }
    </section>
</main>

<div id="limitesModalContainer"></div>

<partial name="_ClienteModal" />

@section Scripts {
    <script src="~/js/module-index.js" asp-append-version="true"></script>
    <script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
    <script src="~/js/cliente-index.js" asp-append-version="true"></script>
    <script src="~/js/cliente-modal.js" asp-append-version="true"></script>
}
