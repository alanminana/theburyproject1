@model ClienteFilterViewModel
@{
    ViewData["Title"] = "Gestión de Clientes";
    ViewData["MetaDescription"] = "Administración de clientes, límites de crédito y documentación asociada en el ERP TheBuryProject.";

    var totalEnPagina = Model.Clientes?.Count() ?? 0;
    var clientesActivos = Model.Clientes?.Count(c => c.Activo) ?? 0;

    string ProgressWidthClass(double percentage)
    {
        var clamped = Math.Clamp((int)Math.Round(percentage, MidpointRounding.AwayFromZero), 0, 100);
        return $"progress-w-{clamped}";
    }
}

@section Styles {
    <partial name="_ClienteModuleStyles" />
}

<div class="space-y-6">

    <!-- TempData Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="toast-msg flex items-center gap-3 rounded-xl border border-emerald-500/20 bg-emerald-500/10 p-4 text-sm font-semibold text-emerald-400" role="status">
            <span class="material-symbols-outlined">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="toast-msg flex items-center gap-3 rounded-xl border border-red-500/20 bg-red-500/10 p-4 text-sm font-semibold text-red-400" role="alert">
            <span class="material-symbols-outlined">error</span>
            @TempData["Error"]
        </div>
    }

    <div id="clienteIndexFeedback"
         class="hidden rounded-xl border px-4 py-3 text-sm font-semibold"
         role="alert"
         aria-live="polite"></div>

    @{
        var filtroClienteActivo = !string.IsNullOrEmpty(Model.SearchTerm)
                               || Model.SoloActivos.HasValue
                               || !string.IsNullOrEmpty(Model.TipoDocumento);
    }

    <!-- Main panel -->
    <section data-oc-scroll style="--oc-scroll-min-width: 60rem;" class="card-erp-panel overflow-hidden">
        <div class="border-b border-slate-800 px-5 py-4">
            <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
                <div class="min-w-0">
                    <h2 class="text-base font-bold text-white">Clientes registrados</h2>
                    <p class="text-sm text-slate-400">Buscá perfiles, revisá contacto y ejecutá acciones comerciales desde una grilla compacta.</p>
                </div>
                <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center lg:justify-end">
                    <div class="flex flex-wrap items-center gap-2">
                        <span class="badge-erp badge-erp-neutral">
                            <span class="material-symbols-outlined text-sm">list_alt</span>
                            @totalEnPagina visibles
                        </span>
                        <span class="badge-erp badge-erp-success">
                            <span class="material-symbols-outlined text-sm">check_circle</span>
                            @clientesActivos activos
                        </span>
                        @if (filtroClienteActivo)
                        {
                            <span class="badge-erp badge-erp-primary">
                                <span class="material-symbols-outlined text-sm">filter_alt</span>
                                Filtros activos
                            </span>
                        }
                    </div>
                    <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
                        <div class="flex flex-wrap items-center gap-1 rounded-lg border border-slate-800 bg-slate-900/40 p-1">
                            <button type="button" data-cliente-open-limites class="btn-erp-ghost btn-sm">
                                <span class="material-symbols-outlined text-[16px]">tune</span>
                                Límites
                            </button>
                            <a asp-controller="DocumentoCliente" asp-action="Index"
                               class="btn-erp-ghost btn-sm no-underline">
                                <span class="material-symbols-outlined text-[16px]">description</span>
                                Docs
                            </a>
                            <a asp-controller="Credito" asp-action="Index"
                               class="btn-erp-ghost btn-sm no-underline">
                                <span class="material-symbols-outlined text-[16px]">payments</span>
                                Créditos
                            </a>
                        </div>
                        <button type="button" data-cliente-modal-open="create" class="btn-erp-primary btn-sm sm:w-auto">
                            <span class="material-symbols-outlined text-[16px]">person_add</span>
                            Nuevo Cliente
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <form id="filterForm" method="get" asp-action="Index"
              class="border-b border-slate-800 bg-slate-900/30 p-4">
            <div class="flex flex-wrap items-end gap-4">
                <div class="min-w-[220px] flex-1">
                    <label class="mb-1.5 block text-[10px] font-bold uppercase tracking-wider text-slate-400">Buscar cliente</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-lg text-slate-400">search</span>
                        <input name="SearchTerm"
                               value="@Model.SearchTerm"
                               type="text"
                               aria-label="Buscar cliente por nombre, documento o contacto"
                               class="w-full rounded-lg border-none bg-slate-800 py-2 pl-10 pr-4 text-sm text-white placeholder:text-slate-500 transition-colors focus:ring-2 focus:ring-primary/50"
                               placeholder="Nombre, documento o contacto..." />
                    </div>
                </div>
                <div class="w-44">
                    <label class="mb-1.5 block text-[10px] font-bold uppercase tracking-wider text-slate-400">Estado</label>
                    <select name="SoloActivos"
                            aria-label="Estado del cliente"
                            class="filter-select-erp">
                        <option value="">Todos</option>
                        @if (Model.SoloActivos == true)
                        {
                            <option value="true" selected>Activo</option>
                        }
                        else
                        {
                            <option value="true">Activo</option>
                        }
                        @if (Model.SoloActivos == false)
                        {
                            <option value="false" selected>Inactivo</option>
                        }
                        else
                        {
                            <option value="false">Inactivo</option>
                        }
                    </select>
                </div>
                <div class="w-48">
                    <label class="mb-1.5 block text-[10px] font-bold uppercase tracking-wider text-slate-400">Documento</label>
                    <select name="TipoDocumento"
                            aria-label="Tipo de documento"
                            class="filter-select-erp">
                        @if (string.IsNullOrEmpty(Model.TipoDocumento))
                        {
                            <option value="" selected>Todos</option>
                        }
                        else
                        {
                            <option value="">Todos</option>
                        }
                        @if (ViewBag.TiposDocumento != null)
                        {
                            @foreach (var tipo in (SelectList)ViewBag.TiposDocumento)
                            {
                                var tipoValue = string.IsNullOrEmpty(tipo.Value) ? tipo.Text : tipo.Value;
                                if (Model.TipoDocumento == tipoValue)
                                {
                                    <option value="@tipoValue" selected>@tipo.Text</option>
                                }
                                else
                                {
                                    <option value="@tipoValue">@tipo.Text</option>
                                }
                            }
                        }
                    </select>
                </div>
                <div class="flex gap-2">
                    <button type="submit"
                            class="inline-flex h-9 items-center justify-center gap-2 rounded-lg bg-primary/10 px-3 text-sm font-bold text-primary transition-colors hover:bg-primary hover:text-white"
                            title="Filtrar clientes">
                        <span class="material-symbols-outlined text-lg">filter_list</span>
                        <span>Filtrar</span>
                    </button>
                    @if (filtroClienteActivo)
                    {
                        <a asp-action="Index"
                           class="inline-flex h-9 items-center justify-center rounded-lg bg-slate-800 px-3 text-slate-300 transition-colors hover:bg-slate-700 hover:text-white no-underline"
                           title="Limpiar filtros">
                            <span class="material-symbols-outlined text-lg">clear_all</span>
                        </a>
                    }
                </div>
            </div>
        </form>

        <p data-oc-scroll-hint hidden class="px-5 pt-4 text-xs font-semibold uppercase tracking-[0.16em] text-slate-400 lg:hidden">
            Deslizá la tabla para ver crédito, estado y acciones completas.
        </p>
        <div data-oc-scroll-shell class="relative">
            <div data-oc-scroll-fade="left" hidden></div>
            <div data-oc-scroll-fade="right" hidden></div>
            <div data-oc-scroll-region tabindex="0" role="region" aria-label="Tabla de clientes">
                <table class="w-full border-collapse text-left" data-oc-scroll-table>
                    <thead>
                        <tr class="border-b border-slate-800 bg-slate-800/30">
                            <th class="px-5 py-3 text-xs font-bold uppercase tracking-wider text-slate-400">Cliente</th>
                            <th class="px-5 py-3 text-xs font-bold uppercase tracking-wider text-slate-400">Contacto</th>
                            <th class="px-5 py-3 text-xs font-bold uppercase tracking-wider text-slate-400">Domicilio</th>
                            <th class="px-5 py-3 text-xs font-bold uppercase tracking-wider text-slate-400">Riesgo</th>
                            <th class="px-5 py-3 text-right text-xs font-bold uppercase tracking-wider text-slate-400">Crédito</th>
                            <th class="px-5 py-3 text-xs font-bold uppercase tracking-wider text-slate-400">Estado</th>
                            <th class="px-5 py-3 text-right text-xs font-bold uppercase tracking-wider text-slate-400">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-800">
                        @if (Model.Clientes != null && Model.Clientes.Any())
                        {
                            @foreach (var c in Model.Clientes)
                            {
                                var initials = (!string.IsNullOrEmpty(c.Nombre) && !string.IsNullOrEmpty(c.Apellido))
                                    ? $"{c.Nombre[0]}{c.Apellido[0]}".ToUpper()
                                    : "??";

                                var puntaje = (int)c.PuntajeRiesgo;
                                var puntajeColor = puntaje >= 700 ? "emerald" : (puntaje >= 400 ? "amber" : "red");
                                var puntajePct = Math.Min(100, Math.Max(0, puntaje / 10));

                                var tipoCliente = c.Sueldo.HasValue && c.Sueldo > 200000 ? "Mayorista" : "Minorista";

                                <tr class="transition-colors hover:bg-white/5">
                                    <td class="px-5 py-3">
                                        <div class="flex items-center gap-3">
                                            <div class="flex size-9 shrink-0 items-center justify-center rounded-lg border border-primary/20 bg-primary/10 text-sm font-bold text-primary">
                                                @initials
                                            </div>
                                            <div class="min-w-0">
                                                <p class="truncate text-sm font-bold text-white">@c.Apellido @c.Nombre</p>
                                                <p class="mt-0.5 flex flex-wrap items-center gap-1.5 text-[11px] text-slate-500">
                                                    <span class="font-mono">@(c.TipoDocumento ?? "DNI")-@c.NumeroDocumento</span>
                                                    <span class="h-1 w-1 rounded-full bg-slate-700"></span>
                                                    <span class="uppercase tracking-[0.12em]">@tipoCliente</span>
                                                </p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-5 py-3">
                                        <div class="flex max-w-[16rem] flex-col gap-0.5 text-sm">
                                            <span class="text-slate-200">@(c.Telefono ?? "Sin teléfono")</span>
                                            <span class="truncate text-xs text-slate-500">@(c.Email ?? "Sin email")</span>
                                        </div>
                                    </td>
                                    <td class="max-w-[13rem] truncate px-5 py-3 text-sm text-slate-400" title="@c.Domicilio">
                                        @(c.Domicilio ?? "—")
                                    </td>
                                    <td class="px-5 py-3">
                                        @if (puntaje > 0)
                                        {
                                            <div class="flex items-center gap-2">
                                                <span class="text-sm font-bold text-@(puntajeColor)-400">@puntaje</span>
                                                <div class="h-1.5 w-14 overflow-hidden rounded-full bg-slate-700">
                                                    <div class="h-full rounded-full bg-@(puntajeColor)-500 @ProgressWidthClass(puntajePct)"></div>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-sm font-bold text-slate-600">--</span>
                                        }
                                    </td>
                                    <td class="px-5 py-3 text-right text-sm font-bold text-white">
                                        @(c.MontoAdeudado.HasValue ? c.MontoAdeudado.Value.ToString("C") : "$0,00")
                                    </td>
                                    <td class="px-5 py-3">
                                        @if (c.Activo)
                                        {
                                            <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-500/10 px-2.5 py-1 text-xs font-bold text-emerald-400">
                                                <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                                                Activo
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-800 px-2.5 py-1 text-xs font-bold text-slate-400">
                                                <span class="h-1.5 w-1.5 rounded-full bg-slate-500"></span>
                                                Inactivo
                                            </span>
                                        }
                                    </td>
                                    <td class="px-5 py-3 text-right">
                                        <div class="flex items-center justify-end gap-1">
                                            <a asp-action="Details"
                                               asp-route-id="@c.Id"
                                               class="row-action row-action--primary no-underline"
                                               title="Ver detalle"
                                               aria-label="Ver detalle de @c.Apellido @c.Nombre">
                                                <span class="material-symbols-outlined">visibility</span>
                                                <span class="row-action__label">Ver</span>
                                            </a>
                                            <button type="button"
                                                    data-cliente-modal-open="edit"
                                                    data-cliente-id="@c.Id"
                                                    class="row-action"
                                                    title="Editar"
                                                    aria-label="Editar @c.Apellido @c.Nombre">
                                                <span class="material-symbols-outlined">edit</span>
                                                <span class="row-action__label">Editar</span>
                                            </button>
                                            <a asp-controller="Credito"
                                               asp-action="Index"
                                               asp-route-clienteId="@c.Id"
                                               class="row-action row-action--primary no-underline"
                                               title="Ver créditos"
                                               aria-label="Ver créditos de @c.Apellido @c.Nombre">
                                                <span class="material-symbols-outlined">payments</span>
                                                <span class="row-action__label">Crédito</span>
                                            </a>
                                            <details class="cliente-row-menu relative" data-cliente-row-menu>
                                                <summary class="row-action cursor-pointer" title="Más acciones" aria-label="Más acciones para @c.Apellido @c.Nombre">
                                                    <span class="material-symbols-outlined">more_vert</span>
                                                    <span class="row-action__label">Más</span>
                                                </summary>
                                                <div class="cliente-row-menu__content">
                                                    <button type="button"
                                                            data-delete-url="@Url.Action("Delete", new { id = c.Id })"
                                                            data-nombre="@c.Apellido @c.Nombre"
                                                            class="cliente-row-menu__item cliente-row-menu__item--danger">
                                                        <span class="material-symbols-outlined text-[16px]">delete</span>
                                                        Eliminar
                                                    </button>
                                                </div>
                                            </details>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="px-6 py-12 text-center">
                                    <div class="flex flex-col items-center gap-2">
                                        <span class="material-symbols-outlined text-4xl text-slate-600">person_off</span>
                                        <p class="text-sm font-semibold text-slate-400">No se encontraron clientes</p>
                                        <p class="text-xs text-slate-500">Intentá con otros filtros o agregá un nuevo cliente</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="flex flex-col gap-2 border-t border-slate-800 bg-slate-900/30 px-5 py-3 sm:flex-row sm:items-center sm:justify-between">
            <span class="text-xs text-slate-500">
                Mostrando @totalEnPagina de @Model.TotalResultados clientes
            </span>
            <span class="text-xs font-semibold text-slate-400">
                Acciones directas: detalle, edición y crédito. Eliminación queda en el menú de fila.
            </span>
        </div>
    </section>

    <div id="limitesModalContainer"></div>
</div>

<partial name="_ClienteModal" />

@section Scripts {
    <script src="~/js/module-index.js" asp-append-version="true"></script>
    <script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
    <script src="~/js/cliente-index.js" asp-append-version="true"></script>
    <script src="~/js/cliente-modal.js" asp-append-version="true"></script>
}
