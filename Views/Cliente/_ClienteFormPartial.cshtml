@model ClienteViewModel
@{
    var isEdit = Model.Id > 0;
    var formAction = isEdit ? Url.Action("EditAjax", "Cliente") : Url.Action("CreateAjax", "Cliente");
    var title = isEdit ? "Editar cliente" : "Nuevo cliente";
    var subtitle = isEdit
        ? $"Modificá los datos de {Model.Apellido} {Model.Nombre}. Las métricas crediticias se preservan."
        : "Registrá un cliente con sus datos personales, de contacto y laborales.";
    var submitIcon = isEdit ? "save" : "person_add";
    var submitText = isEdit ? "Guardar cambios" : "Crear cliente";
    var nombreResumen = string.IsNullOrWhiteSpace(Model.NombreCompleto)
        ? (isEdit ? $"{Model.Apellido}, {Model.Nombre}".Trim(' ', ',') : "Nuevo cliente")
        : Model.NombreCompleto;
    var nivelRiesgo = Model.NivelRiesgo.ToString();
    var chipRiesgo = nivelRiesgo.Contains("Rechazado")
        ? "chip-bad"
        : nivelRiesgo.Contains("Condicional") || nivelRiesgo.Contains("Limitado")
            ? "chip-warn"
            : "chip-ok";
}

<header class="drawer-head">
    <div class="min-w-0">
        <div class="breadcrumb" style="margin-bottom:.35rem">
            <span>Clientes</span>
            <span class="sep">/</span>
            @if (isEdit)
            {
                <span class="muted">@Model.Apellido @Model.Nombre</span>
                <span class="sep">/</span>
            }
            <span style="color:#cbd5e1">@(isEdit ? "Editar" : "Nuevo")</span>
        </div>
        <div class="flex items-center gap-2 flex-wrap">
            <h2 class="page-title" style="margin:0">@title</h2>
            @if (isEdit)
            {
                <span class="chip @chipRiesgo"><span class="material-symbols-outlined">verified</span>@nivelRiesgo</span>
            }
        </div>
        <p class="page-sub">@subtitle</p>
    </div>
    <button type="button" id="modal-cliente-cancel" class="btn btn-ghost" style="margin-left:auto">
        Cancelar
    </button>
</header>

<form id="cliente-modal-form" action="@formAction" method="post" novalidate class="flex min-h-0 flex-1 flex-col">
    @Html.AntiForgeryToken()

    @if (isEdit)
    {
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="RowVersion" />
        <input type="hidden" asp-for="NombreCompleto" />
        <input type="hidden" asp-for="PuntajeRiesgo" />
        <input type="hidden" asp-for="NivelRiesgo" />
        <input type="hidden" asp-for="CreditosTotales" />
        <input type="hidden" asp-for="CreditosActivos" />
        <input type="hidden" asp-for="CuotasImpagas" />
        <input type="hidden" asp-for="MontoAdeudado" />
    }

    <div class="drawer-body">
        <div id="cliente-modal-validation" class="alert alert-bad hidden" style="margin-bottom:1rem">
            <span class="material-symbols-outlined">error</span>
            <ul id="cliente-modal-error-list" class="m-0 list-disc pl-4"></ul>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
            <div class="lg:col-span-2 card" style="overflow:hidden">
                <div style="padding:.4rem .4rem 0">
                    <div class="tabs" role="tablist" id="form-tabs">
                        <button type="button" class="tab" role="tab" aria-selected="true" aria-controls="t-personal" data-cliente-tab="t-personal">
                            <span class="material-symbols-outlined">badge</span>Personales
                        </button>
                        <button type="button" class="tab" role="tab" aria-selected="false" aria-controls="t-conyuge" data-cliente-tab="t-conyuge">
                            <span class="material-symbols-outlined">diversity_3</span>Cónyuge
                        </button>
                        <button type="button" class="tab" role="tab" aria-selected="false" aria-controls="t-contacto" data-cliente-tab="t-contacto">
                            <span class="material-symbols-outlined">call</span>Contacto
                        </button>
                        <button type="button" class="tab" role="tab" aria-selected="false" aria-controls="t-laboral" data-cliente-tab="t-laboral">
                            <span class="material-symbols-outlined">work</span>Laboral
                        </button>
                        <button type="button" class="tab" role="tab" aria-selected="false" aria-controls="t-refs" data-cliente-tab="t-refs">
                            <span class="material-symbols-outlined">contacts</span>Referencias
                        </button>
                        <button type="button" class="tab" role="tab" aria-selected="false" aria-controls="t-credito" data-cliente-tab="t-credito">
                            <span class="material-symbols-outlined">credit_score</span>Crediticio
                        </button>
                    </div>
                </div>

                <div class="card-pad">
                    <section class="tab-panel is-active" id="t-personal" role="tabpanel" data-cliente-section="personal">
                        <div class="sec-head"><span class="sec-num">1</span><div><div class="sec-title">Datos personales</div><div class="sec-sub">Identificación del titular.</div></div></div>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label asp-for="TipoDocumento" class="label">Tipo de documento <span class="req">*</span></label>
                                <select asp-for="TipoDocumento" asp-items="@(ViewBag.TiposDocumento as SelectList)" class="field"></select>
                            </div>
                            <div>
                                <label asp-for="NumeroDocumento" class="label">Número de documento <span class="req">*</span></label>
                                <input asp-for="NumeroDocumento" class="field mono" placeholder="00.000.000" />
                            </div>
                            <div class="sm:col-span-2">
                                <label asp-for="CuilCuit" class="label">CUIL / CUIT</label>
                                <input asp-for="CuilCuit" class="field mono" placeholder="00-00000000-0" maxlength="13" inputmode="numeric" />
                            </div>
                            <div>
                                <label asp-for="Apellido" class="label">Apellido <span class="req">*</span></label>
                                <input asp-for="Apellido" class="field" placeholder="Apellido" />
                            </div>
                            <div>
                                <label asp-for="Nombre" class="label">Nombre <span class="req">*</span></label>
                                <input asp-for="Nombre" class="field" placeholder="Nombre" />
                            </div>
                            <div>
                                <label asp-for="FechaNacimiento" class="label">Fecha de nacimiento</label>
                                <input asp-for="FechaNacimiento" type="date" class="field" />
                            </div>
                            <div>
                                <label asp-for="EstadoCivil" class="label">Estado civil</label>
                                <select asp-for="EstadoCivil" asp-items="@(ViewBag.EstadosCiviles as SelectList)" class="field" id="f-civil">
                                    <option value="">Seleccionar...</option>
                                </select>
                            </div>
                        </div>
                    </section>

                    <section class="tab-panel" id="t-conyuge" role="tabpanel" data-cliente-section="conyuge">
                        <div class="sec-head"><span class="sec-num">2</span><div><div class="sec-title">Datos del cónyuge</div><div class="sec-sub">Requerido si el cliente está casado o en pareja.</div></div></div>
                        <div class="alert alert-info" style="margin-bottom:1rem"><span class="material-symbols-outlined">info</span><div>Completá esta sección solo si corresponde por estado civil.</div></div>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div class="sm:col-span-2">
                                <label asp-for="ConyugeNombreCompleto" class="label">Nombre completo del cónyuge</label>
                                <input asp-for="ConyugeNombreCompleto" class="field" placeholder="Apellido y nombre" />
                            </div>
                            <div>
                                <label asp-for="ConyugeTipoDocumento" class="label">Tipo de documento</label>
                                <select asp-for="ConyugeTipoDocumento" asp-items="@(ViewBag.TiposDocumento as SelectList)" class="field">
                                    <option value="">Seleccionar...</option>
                                </select>
                            </div>
                            <div>
                                <label asp-for="ConyugeNumeroDocumento" class="label">Número de documento</label>
                                <input asp-for="ConyugeNumeroDocumento" class="field mono" placeholder="00.000.000" />
                            </div>
                            <div>
                                <label asp-for="ConyugeTelefono" class="label">Teléfono</label>
                                <input asp-for="ConyugeTelefono" type="tel" class="field" placeholder="11 0000-0000" />
                            </div>
                            <div>
                                <label asp-for="ConyugeSueldo" class="label">Sueldo</label>
                                <div class="field-money">
                                    <span class="cur">$</span>
                                    <input asp-for="ConyugeSueldo" step="0.01" class="field mono" placeholder="0" />
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="tab-panel" id="t-contacto" role="tabpanel" data-cliente-section="contacto">
                        <div class="sec-head"><span class="sec-num">3</span><div><div class="sec-title">Datos de contacto</div><div class="sec-sub">Teléfono, correo y domicilio.</div></div></div>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label asp-for="Telefono" class="label">Teléfono <span class="req">*</span></label>
                                <div class="field-icon"><span class="material-symbols-outlined">call</span><input asp-for="Telefono" type="tel" class="field" placeholder="11 0000-0000" /></div>
                            </div>
                            <div>
                                <label asp-for="TelefonoAlternativo" class="label">Teléfono alternativo</label>
                                <div class="field-icon"><span class="material-symbols-outlined">call</span><input asp-for="TelefonoAlternativo" type="tel" class="field" placeholder="11 0000-0000" /></div>
                            </div>
                            <div>
                                <label asp-for="Email" class="label">Email</label>
                                <div class="field-icon"><span class="material-symbols-outlined">mail</span><input asp-for="Email" type="email" class="field" placeholder="correo@mail.com" /></div>
                            </div>
                            <div>
                                <label asp-for="CodigoPostal" class="label">Código postal</label>
                                <input asp-for="CodigoPostal" class="field mono" placeholder="0000" />
                            </div>
                            <div class="sm:col-span-2">
                                <label asp-for="Domicilio" class="label">Domicilio <span class="req">*</span></label>
                                <input asp-for="Domicilio" class="field" placeholder="Calle, número, piso, depto" />
                            </div>
                            <div>
                                <label asp-for="Localidad" class="label">Localidad</label>
                                <input asp-for="Localidad" class="field" placeholder="Localidad" />
                            </div>
                            <div>
                                <label asp-for="Provincia" class="label">Provincia</label>
                                <select asp-for="Provincia" asp-items="@(ViewBag.Provincias as SelectList)" class="field">
                                    <option value="">Seleccionar...</option>
                                </select>
                            </div>
                        </div>
                    </section>

                    <section class="tab-panel" id="t-laboral" role="tabpanel" data-cliente-section="laboral">
                        <div class="sec-head"><span class="sec-num">4</span><div><div class="sec-title">Datos laborales</div><div class="sec-sub">Fuente de ingresos del cliente.</div></div></div>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label asp-for="TipoEmpleo" class="label">Situación laboral</label>
                                <select asp-for="TipoEmpleo" asp-items="@(ViewBag.TiposEmpleo as SelectList)" class="field">
                                    <option value="">Seleccionar...</option>
                                </select>
                            </div>
                            <div>
                                <label asp-for="TiempoTrabajo" class="label">Antigüedad</label>
                                <input asp-for="TiempoTrabajo" class="field" placeholder="Ej. 4 años" />
                            </div>
                            <div class="sm:col-span-2">
                                <label asp-for="Empleador" class="label">Empleador / Razón social</label>
                                <input asp-for="Empleador" class="field" placeholder="Nombre de la empresa" />
                            </div>
                            <div>
                                <label asp-for="Sueldo" class="label">Ingreso mensual neto</label>
                                <div class="field-money">
                                    <span class="cur">$</span>
                                    <input asp-for="Sueldo" step="0.01" class="field mono" placeholder="0" />
                                </div>
                            </div>
                            <div>
                                <label asp-for="TelefonoLaboral" class="label">Teléfono laboral</label>
                                <input asp-for="TelefonoLaboral" type="tel" class="field" placeholder="11 0000-0000" />
                            </div>
                            <div class="sm:col-span-2">
                                <label class="flex cursor-pointer items-center gap-3 py-2">
                                    <input asp-for="TieneReciboSueldo" type="checkbox" />
                                    <span class="text-sm font-semibold">Tiene recibo de sueldo</span>
                                </label>
                            </div>
                        </div>
                    </section>

                    <section class="tab-panel" id="t-refs" role="tabpanel" data-cliente-section="referencias">
                        <div class="sec-head"><span class="sec-num">5</span><div><div class="sec-title">Referencias</div><div class="sec-sub">Contactos personales o comerciales que avalan al cliente.</div></div></div>
                        <div class="ph">
                            <span class="material-symbols-outlined">contacts</span>
                            <div class="ph-label">SIN CAMPOS EN EL MODELO ACTUAL</div>
                            <p class="muted" style="margin:0;max-width:46ch;font-size:.85rem">La referencia visual contempla esta sección, pero el formulario anterior no tenía campos enlazados para referencias. Se mantiene como punto de carga posterior sin enviar datos mock.</p>
                        </div>
                    </section>

                    <section class="tab-panel" id="t-credito" role="tabpanel" data-cliente-section="crediticio">
                        <div class="sec-head"><span class="sec-num">6</span><div><div class="sec-title">Configuración crediticia</div><div class="sec-sub">Parámetros iniciales y observaciones.</div></div></div>
                        <div class="alert alert-info" style="margin-bottom:1rem"><span class="material-symbols-outlined">@(isEdit ? "shield_lock" : "auto_awesome")</span><div>@(isEdit ? "Las métricas crediticias calculadas se preservan ocultas y no se editan manualmente." : "El puntaje de riesgo y el límite se calculan automáticamente tras la evaluación.")</div></div>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div class="sm:col-span-2">
                                <label asp-for="PerfilCreditoPreferidoId" class="label">Perfil de crédito preferido</label>
                                <select asp-for="PerfilCreditoPreferidoId" asp-items="@(ViewBag.PerfilesCredito as SelectList)" class="field">
                                    <option value="">Sin perfil preferido</option>
                                </select>
                            </div>
                            <div>
                                <label asp-for="TasaInteresMensualPersonalizada" class="label">Tasa interés mensual (%)</label>
                                <input asp-for="TasaInteresMensualPersonalizada" step="0.01" class="field mono" placeholder="Ej. 5.00" />
                            </div>
                            <div>
                                <label asp-for="GastosAdministrativosPersonalizados" class="label">Gastos administrativos (%)</label>
                                <input asp-for="GastosAdministrativosPersonalizados" step="0.01" class="field mono" placeholder="Ej. 2.00" />
                            </div>
                            <div>
                                <label asp-for="CuotasMaximasPersonalizadas" class="label">Cuotas máximas</label>
                                <input asp-for="CuotasMaximasPersonalizadas" type="number" min="1" max="120" class="field mono" placeholder="Ej. 24" />
                            </div>
                            <div>
                                <label asp-for="MontoMinimoPersonalizado" class="label">Monto mínimo ($)</label>
                                <div class="field-money">
                                    <span class="cur">$</span>
                                    <input asp-for="MontoMinimoPersonalizado" id="montoMinimo" step="0.01" class="field mono" placeholder="0" />
                                </div>
                            </div>
                            <div>
                                <label asp-for="MontoMaximoPersonalizado" class="label">Monto máximo ($)</label>
                                <div class="field-money">
                                    <span class="cur">$</span>
                                    <input asp-for="MontoMaximoPersonalizado" id="montoMaximo" step="0.01" class="field mono" placeholder="0" />
                                </div>
                                <p id="montoError" class="err-text hidden">El monto mínimo no puede ser mayor al monto máximo</p>
                            </div>
                            <div class="sm:col-span-2">
                                <label asp-for="Observaciones" class="label">Observaciones</label>
                                <textarea asp-for="Observaciones" class="field" placeholder="Notas internas sobre el cliente (no visibles para el cliente)."></textarea>
                            </div>
                            <div class="sm:col-span-2">
                                <label class="flex cursor-pointer items-center gap-3 py-2">
                                    <input asp-for="Activo" type="checkbox" />
                                    <span class="text-sm font-semibold">Cliente activo</span>
                                </label>
                            </div>
                        </div>
                    </section>
                </div>
            </div>

            <aside class="space-y-4">
                <div class="card card-pad">
                    <div class="text-xs uppercase tracking-wide muted-2 font-semibold mb-3">Resumen</div>
                    <div class="flex items-center gap-3 mb-4">
                        <div class="avatar avatar-lg" id="pv-avatar">@($"{Model.Apellido?.FirstOrDefault()}{Model.Nombre?.FirstOrDefault()}".ToUpperInvariant())</div>
                        <div class="min-w-0"><div class="font-semibold text-white" id="pv-name">@nombreResumen</div><div class="mono text-xs muted-2" id="pv-doc">@(Model.NumeroDocumento ?? "-")</div></div>
                    </div>
                    <dl class="kv">
                        @if (isEdit)
                        {
                            <div class="kv-row"><dt>Estado</dt><dd><span class="chip @(Model.Activo ? "chip-ok" : "chip-neutral")">@(Model.Activo ? "Activo" : "Inactivo")</span></dd></div>
                            <div class="kv-row"><dt>Aptitud</dt><dd><span class="chip @chipRiesgo">@nivelRiesgo</span></dd></div>
                            <div class="kv-row"><dt>Score</dt><dd class="num">@Model.PuntajeRiesgo</dd></div>
                        }
                        else
                        {
                            <div class="kv-row"><dt>Estado inicial</dt><dd><span class="chip chip-ok">Activo</span></dd></div>
                            <div class="kv-row"><dt>Aptitud</dt><dd><span class="chip chip-neutral">Sin evaluar</span></dd></div>
                            <div class="kv-row"><dt>Límite</dt><dd class="num">Por puntaje</dd></div>
                        }
                    </dl>
                </div>
                <div class="card card-pad">
                    <div class="flex items-center gap-2 mb-3"><span class="material-symbols-outlined" style="color:@(isEdit ? "#fbbf24" : "#f5c518");font-size:20px">@(isEdit ? "shield_lock" : "tips_and_updates")</span><h3 class="font-semibold text-white">@(isEdit ? "Datos preservados" : "Recordá")</h3></div>
                    @if (isEdit)
                    {
                        <p class="text-sm muted leading-relaxed">Puntaje, nivel de riesgo, créditos, cuotas impagas y monto adeudado se conservan en campos ocultos.</p>
                    }
                    else
                    {
                        <ul class="help-list">
                            <li><span class="material-symbols-outlined">badge</span>Documento y CUIL/CUIT deben ser únicos.</li>
                            <li><span class="material-symbols-outlined">gpp_good</span>La aptitud se evalúa después de guardar.</li>
                        </ul>
                    }
                </div>
            </aside>
        </div>
    </div>

    <div class="drawer-foot">
        <div class="text-xs muted-2 flex items-center gap-1.5 mr-auto"><span class="material-symbols-outlined" style="font-size:16px">lock</span>Los datos se guardan de forma segura.</div>
        <button type="button" id="modal-cliente-cancel-bottom" class="btn btn-ghost">Cancelar</button>
        <button type="submit" class="btn btn-primary"><span class="material-symbols-outlined">@submitIcon</span>@submitText</button>
    </div>
</form>
