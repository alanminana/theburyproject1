@* Shell del modal AJAX de alta / edición.
   El contenido se inyecta en #modal-cliente-content desde cliente-modal.js. *@
<div id="modal-cliente" class="overlay hidden" aria-modal="true" role="dialog" aria-label="Formulario de cliente">
    <div id="modal-cliente-backdrop"></div>

    <div id="modal-cliente-panel" class="drawer-panel drawer-panel-wide cliente-panel-slide-in">
        <div id="modal-cliente-loading">
            <div class="flex flex-col items-center gap-3 text-center">
                <div class="spinner" aria-hidden="true"></div>
                <p class="text-sm font-medium muted">Cargando formulario...</p>
            </div>
        </div>

        <div id="modal-cliente-content" class="hidden"></div>
    </div>
</div>
