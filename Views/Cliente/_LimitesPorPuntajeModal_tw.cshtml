@model ClienteCreditoLimitesViewModel
@{
    var puedeAdministrar = ViewBag.PuedeAdministrarLimites as bool? ?? false;
    var highlightScores = new[] { 3, 5 };
}

<div id="limitesModal" class="overlay open" aria-modal="true" role="dialog" aria-labelledby="limitesModalTitle">
    <div class="modal">
        <div class="modal-card card" style="max-width:720px">
            <div class="drawer-head">
                <div class="avatar avatar-sm avatar--slate">
                    <span class="material-symbols-outlined" style="font-size:17px">tune</span>
                </div>
                <div class="min-w-0 flex-1">
                    <h2 id="limitesModalTitle" class="sec-title">Limites por puntaje</h2>
                    <p class="sec-sub">Configuracion de monto maximo para cada nivel de riesgo crediticio.</p>
                </div>
                <button type="button" data-cliente-close-limites-modal class="btn btn-ghost btn-sm" aria-label="Cerrar">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <form id="formLimites" asp-action="LimitesPorPuntajeGuardar" method="post">
                @Html.AntiForgeryToken()
                <div class="drawer-body">
                    <div id="limitesErrores" class="alert alert-bad hidden" style="margin-bottom:1rem"></div>
                    <div id="limitesExito" class="alert alert-ok hidden" style="margin-bottom:1rem"></div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                        @for (int i = 0; i < Model.Items.Count; i++)
                        {
                            var item = Model.Items[i];
                            var score = (int)item.Puntaje;
                            var isHighlight = highlightScores.Contains(score);

                            <input type="hidden" name="Items[@i].Id" value="@item.Id" />
                            <input type="hidden" name="Items[@i].Puntaje" value="@score" />
                            <input type="hidden" name="Items[@i].Activo" value="@item.Activo.ToString().ToLower()" />

                            <div class="card-2" style="padding:.8rem">
                                <div class="flex items-center justify-between gap-3">
                                    <div class="flex items-center gap-3">
                                        <span class="avatar avatar-sm @(isHighlight ? string.Empty : "avatar--slate")">@score</span>
                                        <div>
                                            <div class="text-sm font-semibold text-white">Puntaje @score</div>
                                            <div class="text-xs muted-2">@item.Puntaje</div>
                                        </div>
                                    </div>
                                    <div class="field-money" style="width:9rem">
                                        <span class="cur">$</span>
                                        <input name="Items[@i].LimiteMonto"
                                               type="number"
                                               step="1"
                                               min="0"
                                               value="@((int)item.LimiteMonto)"
                                               class="field"
                                               @(!puedeAdministrar ? "disabled" : "") />
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    @if (!puedeAdministrar)
                    {
                        <div class="alert alert-info" style="margin-top:1rem">
                            <span class="material-symbols-outlined">lock</span>
                            <span>No tenes permiso para modificar los limites. La configuracion se muestra en modo lectura.</span>
                        </div>
                    }
                </div>

                <div class="drawer-foot">
                    <button type="button" data-cliente-close-limites-modal class="btn btn-ghost">Cancelar</button>
                    @if (puedeAdministrar)
                    {
                        <button type="submit" id="btnGuardarLimites" class="btn btn-primary">
                            <span class="material-symbols-outlined">save</span>Guardar configuracion
                        </button>
                    }
                </div>
            </form>
        </div>
    </div>
</div>
