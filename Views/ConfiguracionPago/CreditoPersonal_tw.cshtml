}

<!-- ── SAVEBAR STICKY ── -->
<div class="cred-savebar mt-6 py-3 px-4 flex items-center justify-between gap-3 flex-wrap rounded-b-xl">
    @if (puedeEditar)
    {
        <p class="text-xs text-slate-500 flex items-center gap-1.5">
            <span class="material-symbols-outlined text-amber-400" style="font-size:14px">edit_note</span>
