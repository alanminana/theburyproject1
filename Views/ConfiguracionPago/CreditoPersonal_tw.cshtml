@model CreditoPersonalConfigViewModel
@{
    ViewData["Title"] = "Configuracion de Credito Personal";
    var returnUrl = ViewData["ReturnUrl"] as string;
    var volverHref = !string.IsNullOrWhiteSpace(returnUrl)
        ? returnUrl
        : Url.Action("Index", "Credito") ?? "/Credito";
    var perfiles = Model.Perfiles ?? new List<PerfilCreditoViewModel>();
    var limites = Model.LimitesPorPuntaje ?? new List<ClienteCreditoLimiteItemViewModel>();
    var limitesActivos = limites.Count(l => l.Activo);
    var limiteClienteNuevo = limites.FirstOrDefault(l => l.Puntaje == 0)?.LimiteMonto ?? 0m;
    var puedeEditar = User.TienePermiso("configuracion", "update");
    var puedeConfigMora = User.TienePermiso("mora", "config");
    var dg = Model.DefaultsGlobales ?? new DefaultsGlobalesViewModel();
    var sf = Model.SemaforoFinanciero ?? new SemaforoFinancieroViewModel();
}

@section Styles {
    <partial name="_CreditoModuleStyles" />
    <style>
        .cp-shell { display: grid; grid-template-columns: 220px minmax(0,1fr); gap: 1.5rem; }
        .cp-nav { position: sticky; top: 1rem; align-self: start; }
        .cp-nav-link {
            display: flex; align-items: center; gap: .55rem; width: 100%;
            padding: .5rem .65rem; border-radius: 8px; border: 1px solid transparent;
            background: transparent; color: #94a3b8; font-size: .81rem; line-height: 1.25;
            text-align: left; cursor: pointer; transition: background .12s, border-color .12s, color .12s;
        }
        .cp-nav-link:hover { background: #131e33; color: #e2e8f0; }
        .cp-nav-link.is-active { background: rgba(6,182,212,.13); border-color: rgba(6,182,212,.35); color: #f8fafc; }
        .cp-num {
            width: 21px; height: 21px; border-radius: 5px; background: #1e293b;
            display: inline-flex; align-items: center; justify-content: center;
            font-size: .66rem; font-weight: 700; color: #94a3b8; flex-shrink: 0;
        }
        .cp-nav-link.is-active .cp-num { background: #06b6d4; color: #04222a; }
        .cp-section { display: none; border: 1px solid #1e293b; border-radius: 12px; background: rgba(15,23,42,.5); padding: 1.25rem; }
        .cp-section.is-active { display: block; }
        .cp-head { display: flex; align-items: flex-start; gap: .9rem; margin-bottom: 1rem; }
        .cp-icon {
            width: 38px; height: 38px; border-radius: 10px; flex-shrink: 0;
            display: flex; align-items: center; justify-content: center;
            background: rgba(6,182,212,.12); color: #67e8f9;
        }
        .cp-tag { font-size: .66rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: #64748b; }
        .cp-card { background: #0f172a; border: 1px solid #1e293b; border-radius: 10px; padding: .85rem 1rem; }
        .cp-notice {
            display: flex; gap: .75rem; align-items: flex-start;
            border: 1px solid rgba(6,182,212,.28); background: rgba(6,182,212,.06);
            border-radius: 10px; padding: .85rem 1rem;
        }
        .cp-notice-warn { border-color: rgba(245,158,11,.32); background: rgba(245,158,11,.06); }
        .cp-divider { height: 1px; background: #1e293b; margin: .45rem .5rem; }
        .cp-field {
            width: 100%; height: 42px; border-radius: 8px; border: 1px solid #334155;
            background: #0f172a; color: #f1f5f9; padding: 0 .75rem; font-size: .875rem;
        }
        .cp-field-money { padding-left: 1.75rem; }
        .cp-field:focus { outline: none; border-color: #06b6d4; }
        .cp-field[readonly], .cp-field:disabled { opacity: .62; cursor: default; }
        .cp-label { display:block; margin-bottom:.35rem; color:#94a3b8; font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.04em; }
        .cp-hint { margin-top:.28rem; color:#64748b; font-size:.72rem; line-height:1.4; }
        .cp-pill {
            display:inline-flex; align-items:center; gap:.25rem; border-radius:999px; padding:.15rem .5rem;
            font-size:.66rem; font-weight:700; text-transform:uppercase; letter-spacing:.05em;
            border:1px solid rgba(6,182,212,.22); background:rgba(6,182,212,.1); color:#67e8f9;
        }
        .cp-pill-green { border-color:rgba(34,197,94,.22); background:rgba(34,197,94,.1); color:#86efac; }
        .cp-pill-amber { border-color:rgba(245,158,11,.25); background:rgba(245,158,11,.1); color:#fcd34d; }
        .cp-profile details summary { display:flex; align-items:center; gap:.7rem; padding:.75rem .9rem; cursor:pointer; list-style:none; background:#0f172a; border:1px solid #1e293b; border-radius:10px; }
        .cp-profile details[open] summary { border-radius:10px 10px 0 0; border-bottom-color:transparent; }
        .cp-profile .profile-body { background:#080f1d; border:1px solid #1e293b; border-top:none; border-radius:0 0 10px 10px; padding:1rem; }
        .cp-chevron { transition: transform .18s; }
        details[open] .cp-chevron { transform: rotate(180deg); }
        .cp-modal-bg { background: rgba(2,6,18,.78); backdrop-filter: blur(3px); }
        .cp-modal-card { background:#0f1829; border:1px solid #1e293b; border-radius:16px; box-shadow:0 25px 50px rgba(0,0,0,.55); }
        .cp-savebar {
            position: sticky; bottom: 0; z-index: 30; backdrop-filter: blur(10px);
            background: rgba(11,18,32,.92); border-top: 1px solid #1f2937;
        }
        @@media (max-width: 1023px) {
            .cp-shell { display: block; }
            .cp-nav { display: none; }
        }
    </style>
}

<div class="rounded-xl border border-slate-800 bg-slate-900/60 p-5 mb-6">
    <nav aria-label="Breadcrumb" class="text-xs text-slate-500 flex items-center gap-1.5 flex-wrap mb-3">
        <a asp-controller="Home" asp-action="Index" class="hover:text-slate-300 no-underline">Inicio</a>
        <span class="material-symbols-outlined text-[13px]">chevron_right</span>
        <a asp-controller="Credito" asp-action="Index" class="hover:text-slate-300 no-underline">Creditos</a>
        <span class="material-symbols-outlined text-[13px]">chevron_right</span>
        <span class="text-slate-300">Configuracion</span>
    </nav>
    <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4">
        <div class="min-w-0 max-w-3xl">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl shrink-0 flex items-center justify-center border border-cyan-500/25 bg-cyan-500/10">
                    <span class="material-symbols-outlined text-cyan-300">request_quote</span>
                </div>
                <div>
                    <h1 class="text-2xl font-semibold text-white tracking-tight">Configuracion de Credito Personal</h1>
                    <p class="text-sm text-slate-400 mt-0.5">Parametros financieros, limites reales por puntaje y perfiles operativos.</p>
                </div>
            </div>
        </div>
        <div class="flex items-center gap-2 flex-wrap shrink-0">
            <a asp-controller="ConfiguracionContratoCredito" asp-action="Index"
               asp-route-returnUrl="@($"{Context.Request.Path}{Context.Request.QueryString}")"
               class="btn-erp-secondary py-2 text-sm no-underline">
                <span class="material-symbols-outlined text-[17px]">contract</span>
                Plantilla contrato
            </a>
            @if (puedeConfigMora)
            {
                <a asp-controller="Mora" asp-action="ConfiguracionExpandida"
                   asp-route-returnUrl="@($"{Context.Request.Path}{Context.Request.QueryString}")"
                   class="btn-erp-secondary py-2 text-sm no-underline">
                    <span class="material-symbols-outlined text-[17px]">tune</span>
                    Configuración de mora
                </a>
            }
            <a href="@volverHref" class="btn-erp-ghost py-2 text-sm no-underline">
                <span class="material-symbols-outlined text-[17px]">arrow_back</span>
                Volver
            </a>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="mb-4 flex items-center gap-3 rounded-xl border border-emerald-500/20 bg-emerald-500/10 p-4 text-sm font-semibold text-emerald-400" role="status">
        <span class="material-symbols-outlined">check_circle</span>
        @TempData["Success"]
    </div>
}

<form asp-action="CreditoPersonal" asp-controller="ConfiguracionPago" method="post" id="credito-config-form">
    @Html.AntiForgeryToken()
    @if (!string.IsNullOrWhiteSpace(returnUrl))
    {
        <input type="hidden" name="returnUrl" value="@returnUrl" />
    }

    <div asp-validation-summary="ModelOnly" class="mb-4 rounded-xl border border-rose-500/20 bg-rose-500/10 p-4 text-sm font-semibold text-rose-400"></div>

    <div class="cp-shell">
        <aside class="cp-nav">
            <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-2.5">
                <p class="text-[10px] uppercase tracking-wider text-slate-500 font-semibold px-2 pt-1 pb-2">Secciones</p>
                <nav id="sec-nav" class="space-y-0.5">
                    <button type="button" class="cp-nav-link is-active" data-target="s1"><span class="cp-num">1</span> Resumen operativo</button>
                    <button type="button" class="cp-nav-link" data-target="s2"><span class="cp-num">2</span> Config financiera</button>
                    <button type="button" class="cp-nav-link" data-target="s3"><span class="cp-num">3</span> Limites por puntaje</button>
                    <button type="button" class="cp-nav-link" data-target="s4"><span class="cp-num">4</span> Perfiles de credito</button>
                    <div class="cp-divider"></div>
                    <p class="text-[9px] uppercase tracking-wider text-slate-600 font-semibold px-2 pb-1">Soporte</p>
                    <button type="button" class="cp-nav-link" data-target="s5"><span class="cp-num">5</span> Semaforo visual</button>
                    <button type="button" class="cp-nav-link" data-target="s6"><span class="cp-num">6</span> Reglas canonicas</button>
                </nav>
            </div>
        </aside>

        <main class="space-y-5 min-w-0">
            <div class="lg:hidden">
                <label class="cp-label" for="msel">Seccion</label>
                <select id="msel" class="cp-field">
                    <option value="s1">1 - Resumen operativo</option>
                    <option value="s2">2 - Config financiera</option>
                    <option value="s3">3 - Limites por puntaje</option>
                    <option value="s4">4 - Perfiles de credito</option>
                    <option value="s5">5 - Semaforo visual</option>
                    <option value="s6">6 - Reglas canonicas</option>
                </select>
            </div>

            <section id="s1" class="cp-section is-active">
                <div class="cp-head">
                    <div class="cp-icon"><span class="material-symbols-outlined">dashboard</span></div>
                    <div class="min-w-0">
                        <div class="cp-tag">Seccion 1</div>
                        <h2 class="text-lg font-semibold text-white">Resumen operativo</h2>
                        <p class="text-sm text-slate-400 mt-0.5">Estado actual de la configuracion activa de credito personal.</p>
                    </div>
                </div>

                <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-5 gap-3">
                    <div class="cp-card">
                        <div class="flex items-center gap-1.5 text-[10px] uppercase tracking-wide text-slate-500">
                            <span class="material-symbols-outlined text-blue-400 text-[13px]">percent</span> Tasa mensual
                        </div>
                        <div class="mt-1.5 text-xl font-semibold text-white font-mono" id="r-tasa">@dg.TasaMensual.ToString("0.00") %</div>
                    </div>
                    <div class="cp-card">
                        <div class="flex items-center gap-1.5 text-[10px] uppercase tracking-wide text-slate-500">
                            <span class="material-symbols-outlined text-cyan-300 text-[13px]">view_timeline</span> Cuotas base
                        </div>
                        <div class="mt-1.5 text-xl font-semibold text-white font-mono" id="r-cuotas">@dg.MinCuotas - @dg.MaxCuotas</div>
                    </div>
                    <div class="cp-card">
                        <div class="flex items-center gap-1.5 text-[10px] uppercase tracking-wide text-slate-500">
                            <span class="material-symbols-outlined text-amber-300 text-[13px]">payments</span> Gastos
                        </div>
                        <div class="mt-1.5 text-lg font-semibold text-white font-mono" id="r-gastos">$ @dg.GastosAdministrativos.ToString("N0")</div>
                    </div>
                    <div class="cp-card">
                        <div class="flex items-center gap-1.5 text-[10px] uppercase tracking-wide text-slate-500">
                            <span class="material-symbols-outlined text-green-400 text-[13px]">speed</span> Limite puntaje 0
                        </div>
                        <div class="mt-1.5 text-lg font-semibold text-white font-mono">$ @limiteClienteNuevo.ToString("N0")</div>
                    </div>
                    <div class="cp-card">
                        <div class="flex items-center gap-1.5 text-[10px] uppercase tracking-wide text-slate-500">
                            <span class="material-symbols-outlined text-violet-300 text-[13px]">groups</span> Perfiles
                        </div>
                        <div class="mt-1.5 text-xl font-semibold text-white font-mono">@perfiles.Count</div>
                    </div>
                </div>

                <div class="cp-notice mt-4">
                    <span class="material-symbols-outlined text-cyan-300 mt-0.5 shrink-0 text-[17px]">info</span>
                    <div class="text-sm text-slate-300">
                        El cupo real se calcula con <strong class="text-cyan-200">PuntajeCliente 0-5</strong> contra <strong class="text-cyan-200">PuntajesCreditoLimite</strong>.
                        La aptitud de venta sigue en <strong class="text-cyan-200">ClienteAptitudService</strong> y la mora en su pantalla canonica.
                    </div>
                </div>
            </section>

            <section id="s2" class="cp-section">
                <div class="cp-head">
                    <div class="cp-icon" style="background:rgba(245,197,24,.12);color:#f5c518;">
                        <span class="material-symbols-outlined">calculate</span>
                    </div>
                    <div class="min-w-0">
                        <div class="cp-tag">Seccion 2</div>
                        <h2 class="text-lg font-semibold text-white">Configuracion financiera base</h2>
                        <p class="text-sm text-slate-400 mt-0.5">Defaults globales usados cuando no hay perfil o configuracion personalizada del cliente.</p>
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    <div class="space-y-4">
                        <div>
                            <label asp-for="DefaultsGlobales.TasaMensual" class="cp-label">Tasa mensual (%)</label>
                            <input asp-for="DefaultsGlobales.TasaMensual" type="number" step="0.01" min="0" max="100"
                                   readonly="@(!puedeEditar)" class="cp-field" data-summary="tasa" />
                            <p class="cp-hint">Tasa nominal mensual aplicada al capital financiado. <span id="s2-tea-hint" class="text-cyan-400/80 font-mono"></span></p>
                            <span asp-validation-for="DefaultsGlobales.TasaMensual" class="text-xs text-red-500"></span>
                        </div>

                        <div>
                            <label class="cp-label">Cuotas permitidas</label>
                            <div class="grid grid-cols-[1fr_auto_1fr] items-end gap-2">
                                <div>
                                    <span class="text-[10px] text-slate-500 mb-1 block">Desde</span>
                                    <input asp-for="DefaultsGlobales.MinCuotas" type="number" min="1" max="120"
                                           readonly="@(!puedeEditar)" class="cp-field font-mono" data-summary="min-cuotas" />
                                    <span asp-validation-for="DefaultsGlobales.MinCuotas" class="text-xs text-red-500"></span>
                                </div>
                                <span class="material-symbols-outlined text-slate-500 mb-2.5 shrink-0 text-[18px]">arrow_forward</span>
                                <div>
                                    <span class="text-[10px] text-slate-500 mb-1 block">Hasta</span>
                                    <input asp-for="DefaultsGlobales.MaxCuotas" type="number" min="1" max="120"
                                           readonly="@(!puedeEditar)" class="cp-field font-mono" data-summary="max-cuotas" />
                                    <span asp-validation-for="DefaultsGlobales.MaxCuotas" class="text-xs text-red-500"></span>
                                </div>
                            </div>
                            <p class="cp-hint">Los perfiles pueden reemplazar este rango para clientes o ventas puntuales.</p>
                        </div>
                    </div>

                    <div class="space-y-4">
                        <div>
                            <label asp-for="DefaultsGlobales.GastosAdministrativos" class="cp-label">Gastos administrativos</label>
                            <div class="relative">
                                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 text-sm font-mono pointer-events-none">$</span>
                                <input asp-for="DefaultsGlobales.GastosAdministrativos" type="number" step="0.01" min="0"
                                       readonly="@(!puedeEditar)" class="cp-field cp-field-money font-mono" data-summary="gastos" />
                            </div>
                            <p class="cp-hint">Monto fijo que se suma al capital al configurar el credito.</p>
                            <span asp-validation-for="DefaultsGlobales.GastosAdministrativos" class="text-xs text-red-500"></span>
                        </div>

                        <div class="cp-notice cp-notice-warn">
                            <span class="material-symbols-outlined text-amber-300 shrink-0 mt-0.5 text-[16px]">priority_high</span>
                            <div class="text-sm text-slate-300">
                                Estos valores son fallback global. Si el cliente tiene perfil preferido o valores personalizados, el flujo de configuracion del credito resuelve esa prioridad.
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-6 pt-5 border-t border-slate-800">
                    <div class="flex items-start justify-between gap-3 flex-wrap mb-3">
                        <div class="min-w-0">
                            <h3 class="text-sm font-semibold text-white">Recargo por cantidad de cuotas</h3>
                            <p class="text-xs text-slate-400 mt-0.5">
                                Activa las cuotas disponibles y asigna una tasa mensual propia a cada una (ej. cuota 1 = 1%, cuota 5 = 10%).
                                Si no hay cuotas configuradas aca, se usa la tasa mensual unica de arriba para todo el rango.
                            </p>
                        </div>
                        @if (puedeEditar)
                        {
                            <button type="button" data-open-modal="m-cuota" class="btn-erp-secondary shrink-0 text-sm py-2">
                                <span class="material-symbols-outlined text-[15px]">add</span> Agregar cuota
                            </button>
                        }
                    </div>

                    <span asp-validation-for="CuotasCreditoPersonal" class="block mb-3 text-xs text-red-400"></span>

                    @{ var cuotasCredito = Model.CuotasCreditoPersonal ?? new List<CuotaCreditoPersonalViewModel>(); }

                    @if (cuotasCredito.Count > 0)
                    {
                        <div class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 gap-3">
                            @for (var i = 0; i < cuotasCredito.Count; i++)
                            {
                                var cuota = cuotasCredito[i];
                                <div class="cp-card">
                                    <input type="hidden" asp-for="CuotasCreditoPersonal[i].Id" />
                                    <input type="hidden" asp-for="CuotasCreditoPersonal[i].CantidadCuotas" />
                                    <input type="hidden" asp-for="CuotasCreditoPersonal[i].Orden" />

                                    <div class="flex items-center justify-between gap-2">
                                        <div class="flex items-center gap-2 min-w-0">
                                            <span class="w-8 h-8 rounded-lg bg-cyan-500/10 border border-cyan-500/25 text-cyan-200 font-bold text-xs flex items-center justify-center shrink-0">@cuota.CantidadCuotas</span>
                                            <p class="text-sm font-semibold text-white truncate">@cuota.CantidadCuotas cuota@(cuota.CantidadCuotas != 1 ? "s" : "")</p>
                                        </div>
                                        <label class="inline-flex items-center gap-1.5 text-[11px] font-semibold text-slate-300 shrink-0">
                                            <input asp-for="CuotasCreditoPersonal[i].Activo" disabled="@(!puedeEditar)" class="rounded border-slate-600 bg-slate-900 text-primary focus:ring-primary" />
                                            Activa
                                        </label>
                                    </div>

                                    <div class="mt-3">
                                        <label asp-for="CuotasCreditoPersonal[i].TasaMensual" class="cp-label">Tasa mensual (%)</label>
                                        <input asp-for="CuotasCreditoPersonal[i].TasaMensual" type="number" step="0.01" min="0" max="100"
                                               readonly="@(!puedeEditar)" class="cp-field font-mono" />
                                        <span asp-validation-for="CuotasCreditoPersonal[i].TasaMensual" class="text-xs text-red-400"></span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="rounded-xl border border-dashed border-slate-700 bg-slate-950/30 p-6 text-center">
                            <span class="material-symbols-outlined text-slate-600 text-[28px]">view_timeline</span>
                            <p class="mt-2 text-sm text-slate-500">No hay cuotas configuradas. Se usa la tasa y el rango unicos de arriba.</p>
                        </div>
                    }
                </div>
            </section>

            <section id="s3" class="cp-section">
                <div class="cp-head">
                    <div class="cp-icon"><span class="material-symbols-outlined">speed</span></div>
                    <div class="min-w-0 flex-1">
                        <div class="flex items-center gap-2 flex-wrap mb-0.5">
                            <div class="cp-tag">Seccion 3</div>
                            <span class="cp-pill cp-pill-green">@limitesActivos activos</span>
                        </div>
                        <h2 class="text-lg font-semibold text-white">Limites reales por puntaje</h2>
                        <p class="text-sm text-slate-400 mt-0.5">Configuracion canonical de cupo: puntaje interno 0 a 5.</p>
                    </div>
                </div>

                <span asp-validation-for="LimitesPorPuntaje" class="block mb-3 text-xs text-red-400"></span>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    @for (var i = 0; i < limites.Count; i++)
                    {
                        var item = limites[i];
                        <div class="cp-card">
                            <input type="hidden" asp-for="LimitesPorPuntaje[i].Id" />
                            <input type="hidden" asp-for="LimitesPorPuntaje[i].Puntaje" />

                            <div class="flex items-start justify-between gap-3">
                                <div class="flex items-center gap-3 min-w-0">
                                    <span class="w-9 h-9 rounded-lg bg-cyan-500/10 border border-cyan-500/25 text-cyan-200 font-bold flex items-center justify-center">@item.Puntaje</span>
                                    <div class="min-w-0">
                                        <p class="text-sm font-semibold text-white">Puntaje @item.Puntaje</p>
                                        <p class="text-xs text-slate-500">@(item.Puntaje == 0 ? "Cliente nuevo" : "Comportamiento crediticio")</p>
                                    </div>
                                </div>
                                <label class="inline-flex items-center gap-2 text-xs font-semibold text-slate-300">
                                    <input asp-for="LimitesPorPuntaje[i].Activo" disabled="@(!puedeEditar)" class="rounded border-slate-600 bg-slate-900 text-primary focus:ring-primary" />
                                    Activo
                                </label>
                            </div>

                            <div class="mt-3">
                                <label asp-for="LimitesPorPuntaje[i].LimiteMonto" class="cp-label">Limite de credito</label>
                                <div class="relative">
                                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 text-sm font-mono pointer-events-none">$</span>
                                    <input asp-for="LimitesPorPuntaje[i].LimiteMonto" type="number" step="1" min="0"
                                           readonly="@(!puedeEditar)" class="cp-field cp-field-money font-mono" />
                                </div>
                                <span asp-validation-for="LimitesPorPuntaje[i].LimiteMonto" class="text-xs text-red-400"></span>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <section id="s4" class="cp-section">
                <div class="cp-head">
                    <div class="cp-icon" style="background:rgba(168,85,247,.12);color:#c084fc;">
                        <span class="material-symbols-outlined">groups</span>
                    </div>
                    <div class="min-w-0 flex-1">
                        <div class="flex items-center gap-2 flex-wrap mb-0.5">
                            <div class="cp-tag">Seccion 4</div>
                            <span class="cp-pill">@perfiles.Count perfil@(perfiles.Count != 1 ? "es" : "")</span>
                        </div>
                        <h2 class="text-lg font-semibold text-white">Perfiles de credito</h2>
                        <p class="text-sm text-slate-400 mt-0.5">Tasa, gastos y rango de cuotas aplicables por perfil.</p>
                    </div>
                    @if (puedeEditar)
                    {
                        <button type="button" data-open-modal="m-perfil" class="btn-erp-primary shrink-0 text-sm py-2 ml-2">
                            <span class="material-symbols-outlined text-[15px]">add</span> Nuevo perfil
                        </button>
                    }
                </div>

                <div class="space-y-2.5 cp-profile">
                    @for (var i = 0; i < perfiles.Count; i++)
                    {
                        var perfil = perfiles[i];
                        <input type="hidden" asp-for="Perfiles[i].Id" />
                        <details @(i == 0 ? "open" : "")>
                            <summary>
                                <div class="w-8 h-8 rounded-lg shrink-0 flex items-center justify-center text-xs font-bold border border-violet-500/30 bg-violet-500/10 text-violet-300">
                                    @(i + 1)
                                </div>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-semibold text-white truncate">@(string.IsNullOrWhiteSpace(perfil.Nombre) ? $"Perfil {i + 1}" : perfil.Nombre)</p>
                                    <p class="text-xs text-slate-500 truncate">@(string.IsNullOrWhiteSpace(perfil.Descripcion) ? "Sin descripcion" : perfil.Descripcion)</p>
                                </div>
                                <div class="flex items-center gap-2 shrink-0 flex-wrap justify-end">
                                    <span class="@(perfil.Activo ? "cp-pill cp-pill-green" : "cp-pill")">@(perfil.Activo ? "Activo" : "Inactivo")</span>
                                    <span class="hidden sm:inline text-[10px] font-mono text-slate-500 bg-slate-800/60 border border-slate-700/40 rounded-full px-2 py-0.5">Tasa @perfil.TasaMensual.ToString("0.##")% - @perfil.MinCuotas/@perfil.MaxCuotas cuotas</span>
                                    <span class="material-symbols-outlined cp-chevron text-slate-500 text-[17px]">expand_more</span>
                                </div>
                            </summary>
                            <div class="profile-body">
                                <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-3">
                                    <div>
                                        <label asp-for="Perfiles[i].Nombre" class="cp-label">Nombre</label>
                                        <input asp-for="Perfiles[i].Nombre" readonly="@(!puedeEditar)" class="cp-field" />
                                    </div>
                                    <div>
                                        <label asp-for="Perfiles[i].Descripcion" class="cp-label">Descripcion</label>
                                        <input asp-for="Perfiles[i].Descripcion" readonly="@(!puedeEditar)" class="cp-field" />
                                    </div>
                                    <div>
                                        <label asp-for="Perfiles[i].TasaMensual" class="cp-label">Tasa mensual (%)</label>
                                        <input asp-for="Perfiles[i].TasaMensual" type="number" step="0.01" min="0" max="100" readonly="@(!puedeEditar)" class="cp-field font-mono" />
                                    </div>
                                    <div>
                                        <label asp-for="Perfiles[i].GastosAdministrativos" class="cp-label">Gastos admin ($)</label>
                                        <input asp-for="Perfiles[i].GastosAdministrativos" type="number" step="0.01" min="0" readonly="@(!puedeEditar)" class="cp-field font-mono" />
                                    </div>
                                    <div>
                                        <label asp-for="Perfiles[i].MinCuotas" class="cp-label">Min cuotas</label>
                                        <input asp-for="Perfiles[i].MinCuotas" type="number" min="1" max="120" readonly="@(!puedeEditar)" class="cp-field font-mono" />
                                    </div>
                                    <div>
                                        <label asp-for="Perfiles[i].MaxCuotas" class="cp-label">Max cuotas</label>
                                        <input asp-for="Perfiles[i].MaxCuotas" type="number" min="1" max="120" readonly="@(!puedeEditar)" class="cp-field font-mono" />
                                    </div>
                                    <div>
                                        <label asp-for="Perfiles[i].Orden" class="cp-label">Orden</label>
                                        <input asp-for="Perfiles[i].Orden" type="number" readonly="@(!puedeEditar)" class="cp-field font-mono" />
                                    </div>
                                    <div class="flex items-end">
                                        <label class="inline-flex items-center gap-2 rounded-lg border border-slate-700 bg-slate-800 px-3 py-2.5 text-sm font-semibold text-slate-300 cursor-pointer">
                                            <input asp-for="Perfiles[i].Activo" disabled="@(!puedeEditar)" class="rounded border-slate-600 bg-slate-900 text-primary focus:ring-primary" />
                                            Activo
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </details>
                    }

                    @if (perfiles.Count == 0)
                    {
                        <div class="rounded-xl border border-dashed border-slate-700 bg-slate-950/30 p-8 text-center">
                            <span class="material-symbols-outlined text-slate-600 text-[32px]">folder_open</span>
                            <p class="mt-2 text-sm text-slate-500">No hay perfiles configurados.</p>
                        </div>
                    }
                </div>
            </section>

            <section id="s5" class="cp-section">
                <div class="cp-head">
                    <div class="cp-icon" style="background:rgba(16,185,129,.12);color:#34d399;">
                        <span class="material-symbols-outlined">monitoring</span>
                    </div>
                    <div class="min-w-0">
                        <div class="cp-tag">Seccion 5 - solo visual</div>
                        <h2 class="text-lg font-semibold text-white">Semaforo de simulacion financiera</h2>
                        <p class="text-sm text-slate-400 mt-0.5">Colores de la simulacion del plan; no decide aptitud ni cupo.</p>
                    </div>
                </div>

                <div class="cp-notice cp-notice-warn mb-4">
                    <span class="material-symbols-outlined text-amber-300 shrink-0 mt-0.5 text-[16px]">palette</span>
                    <div class="text-sm text-slate-300">Estos ratios solo cambian el color de la relacion cuota/monto financiado en la simulacion.</div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label asp-for="SemaforoFinanciero.RatioVerdeMax" class="cp-label">Ratio maximo verde</label>
                        <input asp-for="SemaforoFinanciero.RatioVerdeMax" type="number" step="0.01" min="0.01" max="0.99" readonly="@(!puedeEditar)" class="cp-field" />
                        <p class="cp-hint">Ej: 0.08 muestra verde si la cuota llega hasta el 8% del monto financiado.</p>
                        <span asp-validation-for="SemaforoFinanciero.RatioVerdeMax" class="text-xs text-red-500"></span>
                    </div>
                    <div>
                        <label asp-for="SemaforoFinanciero.RatioAmarilloMax" class="cp-label">Ratio maximo amarillo</label>
                        <input asp-for="SemaforoFinanciero.RatioAmarilloMax" type="number" step="0.01" min="0.01" max="0.99" readonly="@(!puedeEditar)" class="cp-field" />
                        <p class="cp-hint">Por encima de este ratio la simulacion se muestra en rojo.</p>
                        <span asp-validation-for="SemaforoFinanciero.RatioAmarilloMax" class="text-xs text-red-500"></span>
                    </div>
                </div>
            </section>

            <section id="s6" class="cp-section">
                <div class="cp-head">
                    <div class="cp-icon" style="background:rgba(148,163,184,.12);color:#cbd5e1;">
                        <span class="material-symbols-outlined">account_tree</span>
                    </div>
                    <div class="min-w-0">
                        <div class="cp-tag">Seccion 6</div>
                        <h2 class="text-lg font-semibold text-white">Reglas canonicas relacionadas</h2>
                        <p class="text-sm text-slate-400 mt-0.5">Referencia operativa de donde vive cada decision.</p>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    <div class="cp-card">
                        <p class="text-sm font-semibold text-white">Aptitud de venta</p>
                        <p class="mt-1 text-xs text-slate-400 leading-relaxed">Documentacion, cupo, mora y BCRA/Veraz se evalúan en ClienteAptitudService y ValidacionVentaService.</p>
                    </div>
                    <div class="cp-card">
                        <p class="text-sm font-semibold text-white">Score por mora</p>
                        <p class="mt-1 text-xs text-slate-400 leading-relaxed">Los impactos automaticos por mora se configuran desde la pantalla canonica de mora.</p>
                    </div>
                    <div class="cp-card">
                        <p class="text-sm font-semibold text-white">Garante y documentos</p>
                        <p class="mt-1 text-xs text-slate-400 leading-relaxed">El garante valido puede sustituir recibo de sueldo; BCRA/Veraz es obligatorio para evaluar credito.</p>
                    </div>
                    <div class="cp-card">
                        <p class="text-sm font-semibold text-white">Autorizacion manual</p>
                        <p class="mt-1 text-xs text-slate-400 leading-relaxed">La autorizacion es puntual por venta y no modifica el puntaje ni el limite futuro del cliente.</p>
                    </div>
                </div>
            </section>
        </main>
    </div>

    @if (puedeEditar)
    {
        <div id="m-perfil" class="hidden fixed inset-0 z-50 cp-modal-bg flex items-center justify-center p-4" data-modal-backdrop>
            <div class="cp-modal-card w-full max-w-lg p-6" role="dialog" aria-modal="true" aria-labelledby="nuevoPerfilTitulo">
                <header class="flex items-start justify-between gap-3 mb-5">
                    <div>
                        <h3 id="nuevoPerfilTitulo" class="text-lg font-semibold text-white">Nuevo perfil de credito</h3>
                        <p class="text-xs text-slate-500 mt-0.5">Valores especificos para un tipo de cliente.</p>
                    </div>
                    <button type="button" data-close-modal="m-perfil" class="rounded-lg border border-slate-700 bg-slate-800 p-1.5 text-slate-400 hover:text-white" aria-label="Cerrar">
                        <span class="material-symbols-outlined text-[17px]">close</span>
                    </button>
                </header>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-3">
                    <div class="sm:col-span-2">
                        <label for="nuevoPerfilNombre" class="cp-label">Nombre</label>
                        <input id="nuevoPerfilNombre" name="nuevoPerfilNombre" placeholder="Ej. Cliente frecuente" class="cp-field" />
                    </div>
                    <div class="sm:col-span-2">
                        <label for="nuevoPerfilDescripcion" class="cp-label">Descripcion</label>
                        <input id="nuevoPerfilDescripcion" name="nuevoPerfilDescripcion" placeholder="Notas internas del perfil" class="cp-field" />
                    </div>
                    <div>
                        <label for="nuevoPerfilTasaMensual" class="cp-label">Tasa mensual (%)</label>
                        <input id="nuevoPerfilTasaMensual" name="nuevoPerfilTasaMensual" type="number" step="0.01" min="0" max="100" value="0" class="cp-field font-mono" />
                    </div>
                    <div>
                        <label for="nuevoPerfilGastosAdministrativos" class="cp-label">Gastos administrativos ($)</label>
                        <input id="nuevoPerfilGastosAdministrativos" name="nuevoPerfilGastosAdministrativos" type="number" step="0.01" min="0" value="0" class="cp-field font-mono" />
                    </div>
                    <div>
                        <label for="nuevoPerfilMinCuotas" class="cp-label">Cuota minima</label>
                        <input id="nuevoPerfilMinCuotas" name="nuevoPerfilMinCuotas" type="number" min="1" max="120" value="1" class="cp-field font-mono" />
                    </div>
                    <div>
                        <label for="nuevoPerfilMaxCuotas" class="cp-label">Cuota maxima</label>
                        <input id="nuevoPerfilMaxCuotas" name="nuevoPerfilMaxCuotas" type="number" min="1" max="120" value="24" class="cp-field font-mono" />
                    </div>
                    <div>
                        <label for="nuevoPerfilOrden" class="cp-label">Orden</label>
                        <input id="nuevoPerfilOrden" name="nuevoPerfilOrden" type="number" value="0" class="cp-field font-mono" />
                    </div>
                    <div class="flex items-end">
                        <label class="inline-flex items-center gap-2 rounded-lg border border-slate-700 bg-slate-800 px-3 py-2.5 text-sm font-semibold text-slate-300 cursor-pointer w-full h-[42px]">
                            <input id="nuevoPerfilActivo" name="nuevoPerfilActivo" type="checkbox" value="true" checked class="rounded border-slate-600 bg-slate-900 text-primary focus:ring-primary" />
                            Activo
                        </label>
                    </div>
                </div>

                <footer class="mt-5 flex justify-end gap-2">
                    <button type="button" data-close-modal="m-perfil" class="btn-erp-ghost">Cancelar</button>
                    <button type="submit" class="btn-erp-primary">
                        <span class="material-symbols-outlined text-[15px]">add</span> Crear perfil
                    </button>
                </footer>
            </div>
        </div>

        <div id="m-cuota" class="hidden fixed inset-0 z-50 cp-modal-bg flex items-center justify-center p-4" data-modal-backdrop>
            <div class="cp-modal-card w-full max-w-sm p-6" role="dialog" aria-modal="true" aria-labelledby="nuevaCuotaTitulo">
                <header class="flex items-start justify-between gap-3 mb-5">
                    <div>
                        <h3 id="nuevaCuotaTitulo" class="text-lg font-semibold text-white">Nueva cuota de credito personal</h3>
                        <p class="text-xs text-slate-500 mt-0.5">Cantidad de cuotas y su tasa mensual propia.</p>
                    </div>
                    <button type="button" data-close-modal="m-cuota" class="rounded-lg border border-slate-700 bg-slate-800 p-1.5 text-slate-400 hover:text-white" aria-label="Cerrar">
                        <span class="material-symbols-outlined text-[17px]">close</span>
                    </button>
                </header>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-3">
                    <div>
                        <label for="nuevaCuotaCantidad" class="cp-label">Cantidad de cuotas</label>
                        @* value vacío por defecto: el modal "Agregar cuota" comparte el form de configuración; con un
                           valor por defecto (p.ej. 1) el botón "Guardar configuración" posteaba esa cuota como nueva y
                           chocaba con un plan ya existente ("Cantidades de cuotas duplicadas"). Vacío ⇒ Guardar no agrega. *@
                        <input id="nuevaCuotaCantidad" name="nuevaCuotaCantidad" type="number" min="1" max="120" value="" class="cp-field font-mono" />
                    </div>
                    <div>
                        <label for="nuevaCuotaTasaMensual" class="cp-label">Tasa mensual (%)</label>
                        <input id="nuevaCuotaTasaMensual" name="nuevaCuotaTasaMensual" type="number" step="0.01" min="0" max="100" value="0" class="cp-field font-mono" />
                    </div>
                    <div class="sm:col-span-2 flex items-end">
                        <label class="inline-flex items-center gap-2 rounded-lg border border-slate-700 bg-slate-800 px-3 py-2.5 text-sm font-semibold text-slate-300 cursor-pointer w-full h-[42px]">
                            <input id="nuevaCuotaActivo" name="nuevaCuotaActivo" type="checkbox" value="true" checked class="rounded border-slate-600 bg-slate-900 text-primary focus:ring-primary" />
                            Activa
                        </label>
                    </div>
                </div>

                <footer class="mt-5 flex justify-end gap-2">
                    <button type="button" data-close-modal="m-cuota" class="btn-erp-ghost">Cancelar</button>
                    <button type="submit" class="btn-erp-primary">
                        <span class="material-symbols-outlined text-[15px]">add</span> Agregar cuota
                    </button>
                </footer>
            </div>
        </div>
    }

    <div class="cp-savebar mt-6 py-3 px-4 flex items-center justify-between gap-3 flex-wrap rounded-b-xl">
        @if (puedeEditar)
        {
            <p class="text-xs text-slate-500 flex items-center gap-1.5">
                <span class="material-symbols-outlined text-amber-400 text-[14px]">edit_note</span>
                Los cambios se guardan juntos.
            </p>
            <div class="flex gap-2">
                <a href="@volverHref" class="btn-erp-ghost py-2 text-sm no-underline">Descartar</a>
                <button type="submit" class="btn-erp-primary py-2 text-sm">
                    <span class="material-symbols-outlined text-[16px]">save</span>
                    Guardar configuracion
                </button>
            </div>
        }
        else
        {
            <p class="text-xs text-slate-500 flex items-center gap-1.5">
                <span class="material-symbols-outlined text-slate-500 text-[14px]">lock</span>
                Vista en modo lectura.
            </p>
            <a href="@volverHref" class="btn-erp-ghost py-2 text-sm no-underline">Volver</a>
        }
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    (function () {
        var CREDIT_SECTIONS = ['s1', 's2', 's3', 's4', 's5', 's6'];

        function money(value) {
            var number = parseFloat(value || '0');
            return '$ ' + number.toLocaleString('es-AR', { maximumFractionDigits: 0 });
        }

        function updateSummary() {
            var tasa = document.querySelector('[data-summary="tasa"]');
            var minC = document.querySelector('[data-summary="min-cuotas"]');
            var maxC = document.querySelector('[data-summary="max-cuotas"]');
            var gastos = document.querySelector('[data-summary="gastos"]');
            var rTasa = document.getElementById('r-tasa');
            var rCuotas = document.getElementById('r-cuotas');
            var rGastos = document.getElementById('r-gastos');

            if (tasa && rTasa) rTasa.textContent = parseFloat(tasa.value || '0').toFixed(2) + ' %';
            if (minC && maxC && rCuotas) rCuotas.textContent = (minC.value || '?') + ' - ' + (maxC.value || '?');
            if (gastos && rGastos) rGastos.textContent = money(gastos.value);
        }

        function updateTea() {
            var tasaEl = document.querySelector('[data-summary="tasa"]');
            var hint = document.getElementById('s2-tea-hint');
            if (!tasaEl || !hint) return;

            var tasa = parseFloat(tasaEl.value || '0');
            if (tasa <= 0) {
                hint.textContent = '';
                return;
            }

            var tea = (Math.pow(1 + tasa / 100, 12) - 1) * 100;
            hint.textContent = 'TEA aprox. ' + tea.toFixed(2) + '%';
        }

        function showSection(id) {
            if (CREDIT_SECTIONS.indexOf(id) === -1) id = 's1';

            CREDIT_SECTIONS.forEach(function (sid) {
                var el = document.getElementById(sid);
                if (el) el.classList.toggle('is-active', sid === id);
            });

            document.querySelectorAll('[data-target]').forEach(function (btn) {
                btn.classList.toggle('is-active', btn.dataset.target === id);
            });

            var select = document.getElementById('msel');
            if (select) select.value = id;

            try { history.replaceState(null, '', '#' + id); } catch (e) { }
        }

        function openModal(id) {
            var el = document.getElementById(id);
            if (!el) return;
            el.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function closeModal(id) {
            var el = document.getElementById(id);
            if (!el) return;
            el.classList.add('hidden');
            document.body.style.overflow = '';
        }

        document.querySelectorAll('[data-open-modal]').forEach(function (btn) {
            btn.addEventListener('click', function () { openModal(btn.dataset.openModal); });
        });

        document.querySelectorAll('[data-close-modal]').forEach(function (btn) {
            btn.addEventListener('click', function () { closeModal(btn.dataset.closeModal); });
        });

        document.querySelectorAll('[data-modal-backdrop]').forEach(function (backdrop) {
            backdrop.addEventListener('click', function (event) {
                if (event.target === backdrop) closeModal(backdrop.id);
            });
        });

        document.addEventListener('keydown', function (event) {
            if (event.key === 'Escape') closeModal('m-perfil');
        });

        var nav = document.getElementById('sec-nav');
        if (nav) {
            nav.addEventListener('click', function (event) {
                var btn = event.target.closest('[data-target]');
                if (btn) showSection(btn.dataset.target);
            });
        }

        var mobileSelect = document.getElementById('msel');
        if (mobileSelect) {
            mobileSelect.addEventListener('change', function () { showSection(mobileSelect.value); });
        }

        document.querySelectorAll('[data-summary]').forEach(function (input) {
            input.addEventListener('input', function () {
                updateSummary();
                updateTea();
            });
        });

        var initHash = window.location.hash.replace('#', '');
        showSection(CREDIT_SECTIONS.indexOf(initHash) !== -1 ? initHash : 's1');
        updateTea();
    })();
    </script>
}
