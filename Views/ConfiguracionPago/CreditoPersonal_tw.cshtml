</form>

<!-- ── MODAL: HISTORIAL DE CAMBIOS (fuera del form, solo lectura) ── -->
<div id="m-historial" class="hidden fixed inset-0 z-50 cred-modal-bg flex items-center justify-center p-4"
     onclick="if(event.target===this)closeCreditoModal('m-historial')">
    <div class="cred-modal-card w-full max-w-2xl p-6" onclick="event.stopPropagation()">
        <header class="flex items-start justify-between gap-3 mb-4">
            <div>
                <h3 class="text-lg font-semibold text-white">Historial de cambios</h3>
                <p class="text-xs text-slate-500 mt-0.5">Registro de modificaciones recientes a la configuración.</p>
            </div>
            <button type="button" onclick="closeCreditoModal('m-historial')"
                    class="rounded-lg border border-slate-700 bg-slate-800 p-1.5 text-slate-400 hover:text-white">
                <span class="material-symbols-outlined" style="font-size:17px">close</span>
            </button>
        </header>
        <div class="rounded-xl border border-slate-700/50 bg-slate-950/40 p-8 text-center">
            <span class="material-symbols-outlined text-slate-600" style="font-size:36px">history</span>
            <p class="mt-2 text-sm text-slate-500">Historial de cambios pendiente de implementación backend.</p>
            <p class="mt-1 text-xs text-slate-600">Esta funcionalidad estará disponible en una fase posterior.</p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    (function () {
        // ── Modales ──
        function openCreditoModal(id) {
            var el = document.getElementById(id);
            if (el) { el.classList.remove('hidden'); document.body.style.overflow = 'hidden'; }
        }
        function closeCreditoModal(id) {
            var el = document.getElementById(id);
            if (el) { el.classList.add('hidden'); document.body.style.overflow = ''; }
        }
        window.openCreditoModal = openCreditoModal;
        window.closeCreditoModal = closeCreditoModal;

        // Cerrar modales con Escape
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                ['m-perfil', 'm-historial'].forEach(closeCreditoModal);
            }
        });

        // ── Resumen (S1) ──
        function creditoUpdateResumen() {
            var tasa = document.querySelector('[name="DefaultsGlobales.TasaMensual"]');
            var gastos = document.querySelector('[name="DefaultsGlobales.GastosAdministrativos"]');
            var minC = document.querySelector('[name="DefaultsGlobales.MinCuotas"]');
            var maxC = document.querySelector('[name="DefaultsGlobales.MaxCuotas"]');
            var aprobado = document.querySelector('[name="ScoringThresholds.PuntajeMinimoParaAprobacion"]');
            var garante = document.querySelector('[name="ScoringThresholds.MontoRequiereGarante"]');

            if (tasa) { var rt = document.getElementById('r-tasa'); if (rt) rt.textContent = parseFloat(tasa.value || 0).toFixed(2) + ' %'; }
            if (gastos) { var rg = document.getElementById('r-gastos'); if (rg) rg.textContent = '$ ' + parseFloat(gastos.value || 0).toFixed(0); }
            if (minC && maxC) { var rc = document.getElementById('r-cuotas'); if (rc) rc.textContent = (minC.value || '?') + ' – ' + (maxC.value || '?'); }
            if (aprobado) { var ra = document.getElementById('r-aprobado'); if (ra) ra.textContent = (aprobado.value || '?') + ' pts'; }
            if (garante) {
                var rgar = document.getElementById('r-garante');
                if (rgar) {
                    var v = parseInt(garante.value || 0);
                    rgar.textContent = '$ ' + v.toLocaleString('es-AR');
                }
            }
        }
        window.creditoUpdateResumen = creditoUpdateResumen;

        // ── Banda visual (S4) ──
        function creditoUpdateBand() {
            var aprobadoEl = document.querySelector('[name="ScoringThresholds.PuntajeMinimoParaAprobacion"]');
            var analisisEl = document.querySelector('[name="ScoringThresholds.PuntajeMinimoParaAnalisis"]');
            if (!aprobadoEl || !analisisEl) return;
            var ap = parseInt(aprobadoEl.value) || 70;
            var an = parseInt(analisisEl.value) || 50;
            var band = document.getElementById('approval-band');
            if (band) {
                var divs = band.querySelectorAll('div');
                if (divs[0]) divs[0].style.flex = an;
                if (divs[1]) divs[1].style.flex = Math.max(1, ap - an);
                if (divs[2]) divs[2].style.flex = Math.max(1, 100 - ap);
            }
            var lblAn = document.getElementById('band-label-analisis');
            var lblAp = document.getElementById('band-label-aprobado');
            if (lblAn) lblAn.textContent = '≥ ' + an + ' análisis';
            if (lblAp) lblAp.textContent = '≥ ' + ap + ' aprobado';
        }
        window.creditoUpdateBand = creditoUpdateBand;

        // ── Navegación por secciones ──
        var secNav = document.getElementById('sec-nav');
        if (secNav) {
            secNav.addEventListener('click', function (e) {
                var btn = e.target.closest('[data-target]');
                if (!btn) return;
                var target = document.getElementById(btn.dataset.target);
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
                secNav.querySelectorAll('.sec-nav-link').forEach(function (b) { b.classList.remove('sec-active'); });
                btn.classList.add('sec-active');
            });
        }

        // ── Selector mobile ──
        var msel = document.getElementById('msel');
        if (msel) {
            msel.addEventListener('change', function () {
                var target = document.getElementById(msel.value);
                if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            });
        }

        // ── IntersectionObserver para marcar activo en nav ──
        if (typeof IntersectionObserver !== 'undefined' && secNav) {
            var sections = ['s1','s2','s3','s4','s5','s6','s7','s8'].map(function(id){ return document.getElementById(id); }).filter(Boolean);
            var obs = new IntersectionObserver(function(entries) {
                entries.forEach(function(entry) {
                    if (entry.isIntersecting) {
                        var id = entry.target.id;
                        secNav.querySelectorAll('.sec-nav-link').forEach(function(b) {
                            b.classList.toggle('sec-active', b.dataset.target === id);
                        });
                        if (msel) msel.value = id;
                    }
                });
            }, { threshold: 0.25 });
            sections.forEach(function(s){ obs.observe(s); });
        }
    })();
    </script>
}
