                <div class="sm:col-span-2">
                    <label for="nuevoPerfilDescripcion" class="cred-label">Descripción</label>
                    <input id="nuevoPerfilDescripcion" name="nuevoPerfilDescripcion" placeholder="Notas internas del perfil" class="cred-field" />
                </div>
