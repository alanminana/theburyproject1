                    <input id="nuevoPerfilTasaMensual" name="nuevoPerfilTasaMensual" type="number" step="0.01" min="0" max="100" value="0" class="cred-field font-mono" />
                </div>
                <div>
                    <label for="nuevoPerfilGastosAdministrativos" class="cred-label">Gastos administrativos ($)</label>
                    <input id="nuevoPerfilGastosAdministrativos" name="nuevoPerfilGastosAdministrativos" type="number" step="0.01" min="0" value="0" class="cred-field font-mono" />
                </div>
                <div>
                    <label for="nuevoPerfilMinCuotas" class="cred-label">Cuota mínima</label>
                    <input id="nuevoPerfilMinCuotas" name="nuevoPerfilMinCuotas" type="number" min="1" max="120" value="1" class="cred-field font-mono" />
                </div>
                <div>
                    <label for="nuevoPerfilMaxCuotas" class="cred-label">Cuota máxima</label>
                    <input id="nuevoPerfilMaxCuotas" name="nuevoPerfilMaxCuotas" type="number" min="1" max="120" value="24" class="cred-field font-mono" />
                </div>
                <div>
                    <label for="nuevoPerfilOrden" class="cred-label">Orden</label>
                    <input id="nuevoPerfilOrden" name="nuevoPerfilOrden" type="number" value="0" class="cred-field font-mono" />
                </div>
                <div class="flex items-end">
                    <label class="inline-flex items-center gap-2 rounded-lg border border-slate-700 bg-slate-800 px-3 py-2.5 text-sm font-semibold text-slate-300 cursor-pointer">
                        <input type="hidden" name="nuevoPerfilActivo" value="false" />
                        <input type="checkbox" name="nuevoPerfilActivo" value="true" checked class="rounded border-slate-600 bg-slate-900 text-primary focus:ring-primary" />
                        Activo al crear
                    </label>
                </div>
            </div>
            <footer class="mt-5 flex justify-end gap-2">
                <button type="button" onclick="closeCreditoModal('m-perfil')" class="btn-erp-ghost">Cancelar</button>
                <button type="submit" class="btn-erp-primary">
                    <span class="material-symbols-outlined text-[15px]">add</span> Crear perfil
