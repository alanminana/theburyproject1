@using TheBuryProject.Models.Enums
@using System.Globalization
@model ConfiguracionPagoGlobalAdminViewModel
@{
    ViewData["Title"] = "Configuracion de pagos";
    var puedeEditar = User.TienePermiso("configuraciones", "update");

    static string TipoPagoDisplay(TipoPago tipoPago) => tipoPago switch
    {
        TipoPago.Efectivo => "Efectivo",
        TipoPago.Transferencia => "Transferencia",
        TipoPago.TarjetaDebito => "Tarjeta debito",
        TipoPago.TarjetaCredito => "Tarjeta credito",
        TipoPago.Cheque => "Cheque",
        TipoPago.CreditoPersonal => "Credito personal",
        TipoPago.MercadoPago => "Mercado Pago",
        TipoPago.CuentaCorriente => "Cuenta corriente",
        TipoPago.Tarjeta => "Tarjeta legacy",
        _ => tipoPago.ToString()
    };

    static string AjusteFirmado(decimal ajuste) => ajuste > 0m
        ? $"+{ajuste:0.##}%"
        : $"{ajuste:0.##}%";

    static string AjusteModo(decimal ajuste) => ajuste switch
    {
        > 0m => "recargo",
        < 0m => "descuento",
        _ => "sin ajuste"
    };

    static string AjusteClass(decimal ajuste) => ajuste switch
    {
        > 0m => "pay-chip pay-chip-warn",
        < 0m => "pay-chip pay-chip-ok",
        _ => "pay-chip pay-chip-muted"
    };

    static string EstadoClass(bool activo) => activo
        ? "pay-chip pay-chip-ok"
        : "pay-chip pay-chip-warn";

    static string MetodoIcon(TipoPago tipoPago) => tipoPago switch
    {
        TipoPago.Efectivo => "payments",
        TipoPago.Transferencia => "account_balance",
        TipoPago.TarjetaDebito => "credit_card",
        TipoPago.TarjetaCredito => "credit_card",
        TipoPago.Cheque => "receipt_long",
        TipoPago.CreditoPersonal => "credit_score",
        TipoPago.MercadoPago => "qr_code_2",
        TipoPago.CuentaCorriente => "account_balance_wallet",
        _ => "tune"
    };
}

@section Styles {
    <style>
        .payments-shell {
            --pay-bg: #0b1220;
            --pay-panel: #0f172a;
            --pay-panel-soft: #111827;
            --pay-panel-strong: #111827;
            --pay-row: #0a1322;
            --pay-line: rgba(148, 163, 184, .2);
            --pay-line-strong: rgba(59, 130, 246, .45);
            --pay-text: #f8fafc;
            --pay-muted: #94a3b8;
            --pay-soft: #cbd5e1;
            --pay-accent: #60a5fa;
            --pay-accent-strong: #3b82f6;
            --pay-warn: #f4be6a;
            --pay-danger: #fb7185;
            color: var(--pay-text);
        }

        .payments-hero {
            position: relative;
            overflow: hidden;
            border: 1px solid var(--pay-line);
            border-radius: 20px;
            background:
                radial-gradient(circle at 16% 8%, rgba(59, 130, 246, .18), transparent 30rem),
                radial-gradient(circle at 84% 15%, rgba(168, 85, 247, .12), transparent 24rem),
                linear-gradient(135deg, rgba(17, 24, 39, .98), rgba(11, 18, 32, .98));
            box-shadow: 0 24px 80px rgba(0, 0, 0, .34);
        }

        .payments-hero::after {
            content: "";
            position: absolute;
            inset: 0;
            pointer-events: none;
            background-image:
                linear-gradient(rgba(255,255,255,.035) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);
            background-size: 36px 36px;
            mask-image: linear-gradient(110deg, black, transparent 70%);
        }

        .payments-hero-inner {
            position: relative;
            z-index: 1;
        }

        .pay-panel {
            border: 1px solid var(--pay-line);
            border-radius: 16px;
            background: var(--pay-panel);
            box-shadow: 0 16px 48px rgba(0, 0, 0, .22);
        }

        .pay-panel-strong {
            border-color: var(--pay-line-strong);
            background: var(--pay-panel-strong);
        }

        .pay-section-title {
            color: var(--pay-text);
            font-size: .82rem;
            font-weight: 800;
            letter-spacing: .08em;
            text-transform: uppercase;
        }

        .pay-muted {
            color: var(--pay-muted);
        }

        .pay-chip {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            border: 1px solid var(--pay-line);
            border-radius: .65rem;
            padding: .32rem .68rem;
            font-size: .75rem;
            font-weight: 800;
            line-height: 1;
            white-space: nowrap;
        }

        .pay-chip-ok {
            border-color: rgba(52, 195, 143, .34);
            background: rgba(52, 195, 143, .11);
            color: #a8f2d6;
        }

        .pay-chip-warn {
            border-color: rgba(244, 190, 106, .34);
            background: rgba(244, 190, 106, .11);
            color: #ffe0a9;
        }

        .pay-chip-muted {
            border-color: rgba(154, 181, 172, .22);
            background: rgba(154, 181, 172, .08);
            color: #cbd8d2;
        }

        .pay-chip-blue {
            border-color: rgba(59, 130, 246, .5);
            background: rgba(59, 130, 246, .16);
            color: #bfdbfe;
        }

        .pay-input {
            height: 2.75rem;
            width: 100%;
            border-radius: .8rem;
            border: 1px solid rgba(154, 181, 172, .28);
            background: rgba(10, 19, 34, .9);
            padding: 0 .8rem;
            color: var(--pay-text);
            font-size: .9rem;
            outline: none;
            transition: border-color .2s ease, box-shadow .2s ease, background-color .2s ease;
        }

        .pay-input:focus {
            border-color: rgba(96, 165, 250, .85);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, .16);
            background: rgba(15, 23, 42, .98);
        }

        .pay-label {
            display: block;
            margin-bottom: .4rem;
            color: #b9cbc4;
            font-size: .72rem;
            font-weight: 800;
            letter-spacing: .08em;
            text-transform: uppercase;
        }

        .pay-summary-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: .8rem;
        }

        .pay-workspace {
            display: grid;
            grid-template-columns: minmax(13rem, 16rem) minmax(0, 1fr);
            gap: 1rem;
            align-items: start;
        }

        .pay-method-nav {
            position: sticky;
            top: 1rem;
            border: 1px solid rgba(30, 42, 61, .95);
            border-radius: 16px;
            background: #0f172a;
            padding: .8rem;
        }

        .pay-method-link {
            display: grid;
            grid-template-columns: auto minmax(0, 1fr) auto;
            align-items: center;
            gap: .65rem;
            width: 100%;
            border: 1px solid transparent;
            border-radius: .75rem;
            padding: .72rem .75rem;
            color: #cbd5e1;
            text-decoration: none;
            transition: border-color .2s ease, background-color .2s ease, color .2s ease;
        }

        .pay-method-link:hover,
        .pay-method-link:focus {
            border-color: rgba(59, 130, 246, .38);
            background: rgba(30, 41, 59, .82);
            color: #f8fafc;
            outline: none;
        }

        .pay-method-link.is-active {
            border-color: rgba(59, 130, 246, .5);
            background: rgba(59, 130, 246, .18);
            color: #eff6ff;
        }

        .pay-method-link .material-symbols-outlined {
            color: #93c5fd;
            font-size: 1.15rem;
        }

        .pay-method-count {
            min-width: 1.8rem;
            border-radius: .55rem;
            background: rgba(15, 23, 42, .92);
            padding: .22rem .4rem;
            text-align: center;
            color: #94a3b8;
            font-size: .72rem;
            font-weight: 800;
            font-variant-numeric: tabular-nums;
        }

        .pay-card {
            border: 1px solid rgba(30, 42, 61, .95);
            border-radius: 14px;
            background: #0f172a;
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, .03);
        }

        .pay-plan-row {
            border: 1px solid rgba(30, 42, 61, .9);
            border-radius: .8rem;
            background: var(--pay-row);
        }

        @@media (max-width: 900px) {
            .pay-summary-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .pay-workspace {
                grid-template-columns: minmax(0, 1fr);
            }

            .pay-method-nav {
                position: static;
            }

            .pay-method-nav-list {
                display: grid;
                grid-template-columns: repeat(2, minmax(0, 1fr));
                gap: .5rem;
            }
        }

        @@media (max-width: 520px) {
            .pay-summary-grid {
                grid-template-columns: minmax(0, 1fr);
            }

            .pay-method-nav-list {
                grid-template-columns: minmax(0, 1fr);
            }
        }
    </style>
}

<div class="payments-shell space-y-6">
    <section class="payments-hero p-5 sm:p-7 lg:p-8">
        <div class="payments-hero-inner flex flex-col gap-7 xl:flex-row xl:items-end xl:justify-between">
            <div class="max-w-4xl space-y-5">
                <nav aria-label="Breadcrumb" class="text-sm font-medium text-slate-300">
                    <ol class="flex flex-wrap items-center gap-y-1">
                        <li><a asp-controller="Home" asp-action="Index" class="no-underline hover:text-emerald-200">Inicio</a></li>
                        <li><span class="mx-2 text-slate-500">/</span></li>
                        <li class="text-white">Configuracion de pagos</li>
                    </ol>
                </nav>

                <div class="space-y-3">
                    <span class="pay-chip pay-chip-blue">
                        <span class="material-symbols-outlined text-[16px]">payments</span>
                        Metodos globales
                    </span>
                    <div class="space-y-2">
                        <h1 class="max-w-3xl text-3xl font-black tracking-tight text-white sm:text-5xl">
                            Configuracion de pagos
                        </h1>
                        <p class="max-w-3xl text-sm leading-relaxed text-slate-300 sm:text-base">
                            Administra disponibilidad, tarjetas y planes reutilizables. Los elementos inactivos conservan historial y dejan de ofrecerse en los flujos que consultan la configuracion global.
                        </p>
                    </div>
                </div>
            </div>

            <div class="grid w-full grid-cols-1 gap-3 sm:grid-cols-2 xl:w-auto">
                <a asp-controller="ConfiguracionPago" asp-action="CreditoPersonal"
                   asp-route-returnUrl="@($"{Context.Request.Path}{Context.Request.QueryString}")"
                   class="btn-erp-secondary justify-center no-underline">
                    <span class="material-symbols-outlined text-[20px]">credit_score</span>
                    Credito personal
                </a>
                <a asp-controller="Home" asp-action="Index" class="btn-erp-ghost justify-center no-underline">
                    <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                    Volver
                </a>
            </div>
        </div>
    </section>

    @if (TempData["Error"] != null)
    {
        <div class="toast-msg flex items-center gap-3 rounded-2xl border border-rose-500/30 bg-rose-500/10 p-4 text-sm font-semibold text-rose-200" role="alert">
            <span class="material-symbols-outlined">error</span>
            @TempData["Error"]
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="toast-msg flex items-center gap-3 rounded-2xl border border-emerald-500/30 bg-emerald-500/10 p-4 text-sm font-semibold text-emerald-200" role="status">
            <span class="material-symbols-outlined">check_circle</span>
            @TempData["Success"]
        </div>
    }

    <section class="pay-summary-grid">
        <article class="pay-panel p-4">
            <p class="pay-section-title pay-muted">Medios</p>
            <p class="mt-3 text-3xl font-black tabular-nums text-white">@Model.TotalMedios</p>
        </article>
        <article class="pay-panel p-4">
            <p class="pay-section-title pay-muted">Tarjetas</p>
            <p class="mt-3 text-3xl font-black tabular-nums text-white">@Model.TotalTarjetas</p>
        </article>
        <article class="pay-panel p-4">
            <p class="pay-section-title pay-muted">Planes</p>
            <p class="mt-3 text-3xl font-black tabular-nums text-white">@Model.TotalPlanes</p>
        </article>
        <article class="pay-panel p-4">
            <p class="pay-section-title pay-muted">Inactivos</p>
            <p class="mt-3 text-3xl font-black tabular-nums text-amber-200">@Model.TotalInactivos</p>
        </article>
    </section>

    <section class="pay-panel pay-panel-strong p-5">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
            <div class="max-w-4xl">
                <p class="pay-section-title">Regla operativa</p>
                <p class="mt-2 text-sm leading-relaxed text-slate-300">
                    El ajuste se aplica una sola vez sobre el total. Un valor positivo es recargo, un valor negativo es descuento y cero deja el importe sin ajuste.
                    La cantidad de cuotas representa pagos exactos, no un maximo.
                </p>
                <div class="mt-3 flex flex-wrap gap-2">
                    <span class="pay-chip pay-chip-ok">-5% descuento</span>
                    <span class="pay-chip pay-chip-muted">0% sin ajuste</span>
                    <span class="pay-chip pay-chip-warn">+5% recargo</span>
                </div>
            </div>
            @if (!puedeEditar)
            {
                <span class="pay-chip pay-chip-muted self-start">
                    <span class="material-symbols-outlined text-[16px]">visibility</span>
                    Solo lectura
                </span>
            }
        </div>
    </section>

    @if (Model.Medios.Count == 0)
    {
        <section class="pay-panel p-8 text-center">
            <span class="material-symbols-outlined text-6xl text-slate-600">payments</span>
            <h2 class="mt-3 text-2xl font-black text-white">Sin medios configurados</h2>
            <p class="mt-2 text-sm text-slate-400">Todavia no hay configuracion global de pagos para administrar.</p>
        </section>
    }
    else
    {
        <section class="pay-workspace">
            <aside class="pay-method-nav" aria-label="Medios de pago configurados">
                <p class="pay-section-title pay-muted px-2 pb-3">Metodos</p>
                <nav class="pay-method-nav-list space-y-2">
                    @foreach (var medio in Model.Medios)
                    {
                        var tarjetasNav = medio.Tarjetas.Count;
                        var planesNav = medio.Planes.Count;
                        var medioActivoClass = medio.TipoPago == TipoPago.TarjetaCredito || medio.TipoPago == TipoPago.TarjetaDebito
                            ? "is-active"
                            : "";
                        <a href="#medio-@medio.Id" class="pay-method-link @medioActivoClass">
                            <span class="material-symbols-outlined">@MetodoIcon(medio.TipoPago)</span>
                            <span class="min-w-0">
                                <span class="block truncate text-sm font-black">@TipoPagoDisplay(medio.TipoPago)</span>
                                <span class="block truncate text-xs text-slate-500">@medio.Nombre</span>
                            </span>
                            <span class="pay-method-count" title="@tarjetasNav tarjetas, @planesNav planes">@planesNav</span>
                        </a>
                    }
                </nav>
            </aside>

            <div class="space-y-4">
                @foreach (var medio in Model.Medios)
                {
                    var permiteTarjetas = medio.TipoPago == TipoPago.TarjetaCredito || medio.TipoPago == TipoPago.TarjetaDebito;
                    var permitePlanesGlobales = medio.TipoPago != TipoPago.CreditoPersonal && medio.TipoPago != TipoPago.Tarjeta;
                    var tarjetas = medio.Tarjetas
                        .OrderByDescending(t => t.Activa)
                        .ThenBy(t => t.TipoTarjeta)
                        .ThenBy(t => t.Nombre)
                        .ToList();
                    var planesGenerales = medio.Planes
                        .Where(p => p.ConfiguracionTarjetaId is null)
                        .OrderByDescending(p => p.Activo)
                        .ThenBy(p => p.Orden)
                        .ThenBy(p => p.CantidadCuotas)
                        .ToList();

                    <details id="medio-@medio.Id" class="pay-panel overflow-hidden scroll-mt-4" @(permiteTarjetas ? "open" : "")>
                    <summary class="cursor-pointer list-none border-b border-slate-700/50 p-5">
                        <div class="flex flex-col gap-5 xl:flex-row xl:items-start xl:justify-between">
                            <div class="min-w-0 space-y-3">
                                <div class="flex flex-wrap items-center gap-2">
                                    <span class="material-symbols-outlined text-blue-300">@MetodoIcon(medio.TipoPago)</span>
                                    <h2 class="text-2xl font-black text-white">@TipoPagoDisplay(medio.TipoPago)</h2>
                                    <span class="pay-chip pay-chip-muted">@medio.Nombre</span>
                                    <span class="@EstadoClass(medio.Activo)">@(medio.Activo ? "Activo" : "Inactivo")</span>
                                </div>
                                <p class="max-w-4xl text-sm leading-relaxed text-slate-400">
                                    @(!string.IsNullOrWhiteSpace(medio.Descripcion) ? medio.Descripcion : "Metodo global con historial preservado. Al inactivarlo deja de estar disponible para nuevas operaciones que consulten activos.")
                                </p>
                            </div>

                            <div class="grid grid-cols-2 gap-3 text-sm sm:grid-cols-4 xl:min-w-[36rem]">
                                <div class="rounded-xl border border-slate-700/50 bg-black/20 p-3">
                                    <p class="pay-section-title pay-muted">Tarjetas</p>
                                    <p class="mt-2 font-black tabular-nums text-white">@tarjetas.Count</p>
                                </div>
                                <div class="rounded-xl border border-slate-700/50 bg-black/20 p-3">
                                    <p class="pay-section-title pay-muted">Planes</p>
                                    <p class="mt-2 font-black tabular-nums text-white">@medio.Planes.Count</p>
                                </div>
                                <div class="rounded-xl border border-slate-700/50 bg-black/20 p-3">
                                    <p class="pay-section-title pay-muted">Descuento</p>
                                    <p class="mt-2 font-black tabular-nums text-white">@(medio.PermiteDescuento ? $"{medio.PorcentajeDescuentoMaximo:0.##}%" : "No")</p>
                                </div>
                                <div class="rounded-xl border border-slate-700/50 bg-black/20 p-3">
                                    <p class="pay-section-title pay-muted">Recargo</p>
                                    <p class="mt-2 font-black tabular-nums text-white">@(medio.TieneRecargo ? $"{medio.PorcentajeRecargo:0.##}%" : "No")</p>
                                </div>
                            </div>
                        </div>
                    </summary>

                    <div class="space-y-5 p-5">
                        <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
                            <div>
                                <p class="pay-section-title">Administracion del metodo</p>
                                <p class="mt-1 text-sm text-slate-400">Tarjetas y planes se editan por separado para no mezclar estado operativo con reglas de cobro.</p>
                            </div>
                            <div class="flex flex-col gap-2 sm:flex-row">
                                @if (puedeEditar)
                                {
                                    <a asp-controller="ConfiguracionPago" asp-action="Edit" asp-route-id="@medio.Id" class="btn-erp-ghost justify-center no-underline">
                                        <span class="material-symbols-outlined text-[20px]">edit</span>
                                        Editar metodo
                                    </a>
                                }
                                <span class="pay-chip pay-chip-muted justify-center">
                                    <span class="material-symbols-outlined text-[16px]">history</span>
                                    Historial preservado
                                </span>
                            </div>
                        </div>

                        @if (!permitePlanesGlobales)
                        {
                            <div class="rounded-2xl border border-amber-500/25 bg-amber-500/10 p-4 text-sm font-semibold text-amber-100">
                                <span class="material-symbols-outlined align-middle text-[20px]">lock</span>
                                @(medio.TipoPago == TipoPago.CreditoPersonal
                                    ? "Credito personal se administra desde su pantalla dedicada."
                                    : "Este medio legacy no administra planes globales nuevos.")
                            </div>
                        }

                        @if (puedeEditar && permiteTarjetas)
                        {
                            <details class="rounded-2xl border border-dashed border-emerald-400/35 bg-emerald-400/5">
                                <summary class="flex cursor-pointer list-none items-center gap-2 p-4 text-sm font-black uppercase tracking-wider text-emerald-100">
                                            <span class="material-symbols-outlined text-blue-300">add_card</span>
                                    Agregar tarjeta
                                </summary>
                                <form asp-controller="ConfiguracionPago" asp-action="CrearTarjetaGlobal" method="post" class="space-y-4 border-t border-emerald-400/15 p-4">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="ConfiguracionPagoId" value="@medio.Id" />

                                    <div class="grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-4">
                                        <div>
                                            <label for="tarjeta-nombre-@medio.Id" class="pay-label">Nombre</label>
                                            <input id="tarjeta-nombre-@medio.Id" name="NombreTarjeta" maxlength="100" required class="pay-input" placeholder="Ej: Visa" />
                                        </div>
                                        <div>
                                            <label for="tarjeta-tipo-@medio.Id" class="pay-label">Tipo</label>
                                            <select id="tarjeta-tipo-@medio.Id" name="TipoTarjeta" required class="pay-input">
                                                @if (medio.TipoPago == TipoPago.TarjetaCredito)
                                                {
                                                    <option value="@((int)TipoTarjeta.Credito)" selected>Credito</option>
                                                }
                                                else
                                                {
                                                    <option value="@((int)TipoTarjeta.Debito)" selected>Debito</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="flex items-end">
                                            <label class="inline-flex h-11 w-full items-center gap-2 rounded-xl border border-slate-700/70 bg-black/20 px-3 text-sm font-semibold text-slate-200">
                                                <input name="Activa" type="checkbox" value="true" checked class="rounded border-slate-600 bg-slate-950 text-emerald-400 focus:ring-emerald-400" />
                                                Activa
                                            </label>
                                        </div>
                                        <div>
                                            <label for="tarjeta-observaciones-@medio.Id" class="pay-label">Observaciones</label>
                                            <input id="tarjeta-observaciones-@medio.Id" name="Observaciones" maxlength="500" class="pay-input" />
                                        </div>
                                    </div>

                                    <button type="submit" class="btn-erp-primary w-full sm:w-auto">
                                        <span class="material-symbols-outlined text-[20px]">save</span>
                                        Crear tarjeta
                                    </button>
                                </form>
                            </details>
                        }

                        @if (tarjetas.Count > 0)
                        {
                            <div class="grid grid-cols-1 gap-4 xl:grid-cols-2">
                                @foreach (var tarjeta in tarjetas)
                                {
                                    var planesTarjeta = medio.Planes
                                        .Where(p => p.ConfiguracionTarjetaId == tarjeta.Id)
                                        .OrderByDescending(p => p.Activo)
                                        .ThenBy(p => p.Orden)
                                        .ThenBy(p => p.CantidadCuotas)
                                        .ToList();

                                    <article class="pay-card">
