@using TheBuryProject.Models.Enums
@using System.Globalization
@model ConfiguracionPagoGlobalAdminViewModel
@{
    ViewData["Title"] = "Configuracion de pagos";
    var puedeEditar = User.TienePermiso("configuracion", "update");

    static string TipoPagoDisplay(TipoPago tipoPago) => tipoPago switch
    {
        TipoPago.Efectivo => "Efectivo",
        TipoPago.Transferencia => "Transferencia",
        TipoPago.TarjetaDebito => "Tarjeta debito",
        TipoPago.TarjetaCredito => "Tarjeta credito",
        TipoPago.Cheque => "Cheque",
        TipoPago.CreditoPersonal => "Credito personal",
        TipoPago.MercadoPago => "Mercado Pago",
        TipoPago.CuentaCorriente => "Cuenta corriente",
        TipoPago.Tarjeta => "Tarjeta legacy",
        _ => tipoPago.ToString()
    };

    static string TipoTarjetaDisplay(TipoTarjeta tipoTarjeta) => tipoTarjeta switch
    {
        TipoTarjeta.Credito => "Credito",
        TipoTarjeta.Debito => "Debito",
        _ => tipoTarjeta.ToString()
    };

    static string AjusteFirmado(decimal ajuste) => ajuste > 0m
        ? $"+{ajuste:0.##}%"
        : $"{ajuste:0.##}%";

    static string AjusteModo(decimal ajuste) => ajuste switch
    {
        > 0m => "recargo",
        < 0m => "descuento",
        _ => "sin ajuste"
    };

    static string AjusteClass(decimal ajuste) => ajuste switch
    {
        > 0m => "pay-badge pay-badge-warn",
        < 0m => "pay-badge pay-badge-ok",
        _ => "pay-badge pay-badge-muted"
    };

    static string EstadoClass(bool activo) => activo
        ? "pay-badge pay-badge-ok"
        : "pay-badge pay-badge-off";

    static string MetodoIcon(TipoPago tipoPago) => tipoPago switch
    {
        TipoPago.Efectivo => "payments",
        TipoPago.Transferencia => "account_balance",
        TipoPago.TarjetaDebito => "credit_card",
        TipoPago.TarjetaCredito => "credit_card",
        TipoPago.Cheque => "receipt_long",
        TipoPago.CreditoPersonal => "credit_score",
        TipoPago.MercadoPago => "qr_code_2",
        TipoPago.CuentaCorriente => "account_balance_wallet",
        _ => "tune"
    };

    var medioIdQuery = Context.Request.Query["medioId"].FirstOrDefault();
    var medioSeleccionado = Model.Medios.FirstOrDefault(m => m.Id.ToString() == medioIdQuery)
        ?? Model.Medios.FirstOrDefault(m => m.TipoPago == TipoPago.TarjetaCredito)
        ?? Model.Medios.FirstOrDefault(m => m.TipoPago == TipoPago.TarjetaDebito)
        ?? Model.Medios.FirstOrDefault();
}

@section Styles {
    <style>
        .payments-page {
            --pay-bg: #0b1220;
            --pay-shell: #111827;
            --pay-panel: #0f172a;
            --pay-row: #0a1322;
            --pay-line: #1e2a3d;
            --pay-line-soft: rgba(148, 163, 184, .18);
            --pay-text: #f8fafc;
            --pay-soft: #cbd5e1;
            --pay-muted: #94a3b8;
            --pay-dim: #64748b;
            --pay-accent: #3b82f6;
            --pay-ok: #34d399;
            --pay-warn: #fbbf24;
            --pay-danger: #fb7185;
            min-height: calc(100dvh - 5rem);
            margin: -1rem;
            padding: 1.25rem;
            background: var(--pay-bg);
            color: var(--pay-text);
        }

        .payments-page * {
            box-sizing: border-box;
        }

        .payments-shell-card {
            width: min(100%, 1240px);
            margin: 0 auto;
            border: 1px solid var(--pay-line);
            border-radius: 22px;
            background: var(--pay-shell);
            box-shadow: 0 28px 90px rgba(2, 6, 23, .55);
            overflow: hidden;
        }

        .payments-topbar {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 1rem;
            align-items: start;
            padding: 1.25rem;
            border-bottom: 1px solid var(--pay-line);
            background: linear-gradient(180deg, rgba(15, 23, 42, .98), rgba(17, 24, 39, .98));
        }

        .payments-title {
            margin: .35rem 0 0;
            font-size: clamp(1.6rem, 3vw, 2.35rem);
            line-height: 1.05;
            font-weight: 900;
            color: #fff;
            letter-spacing: 0;
            text-wrap: balance;
        }

        .payments-subtitle {
            max-width: 58rem;
            margin: .6rem 0 0;
            color: var(--pay-muted);
            font-size: .92rem;
            line-height: 1.6;
        }

        .payments-eyebrow,
        .pay-label {
            color: var(--pay-muted);
            font-size: .7rem;
            font-weight: 800;
            letter-spacing: .08em;
            text-transform: uppercase;
        }

        .payments-actions {
            display: flex;
            flex-wrap: wrap;
            justify-content: flex-end;
            gap: .55rem;
        }

        .payments-credit-note {
            display: inline-flex;
            max-width: 17rem;
            align-items: center;
            gap: .45rem;
            border: 1px solid rgba(251, 191, 36, .26);
            border-radius: .75rem;
            background: rgba(251, 191, 36, .08);
            padding: .55rem .7rem;
            color: #fde68a;
            font-size: .76rem;
            font-weight: 700;
            line-height: 1.25;
        }

        .payments-metrics {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: .65rem;
            padding: 1rem 1.25rem 0;
        }

        .payments-metric {
            min-width: 0;
            border: 1px solid var(--pay-line);
            border-radius: .9rem;
            background: #0f172a;
            padding: .85rem;
        }

        .payments-metric strong {
            display: block;
            margin-top: .25rem;
            color: #fff;
            font-size: 1.55rem;
            line-height: 1;
            font-variant-numeric: tabular-nums;
        }

        .payments-rule {
            margin: 1rem 1.25rem 0;
            border: 1px solid rgba(59, 130, 246, .34);
            border-radius: 1rem;
            background: rgba(59, 130, 246, .08);
            padding: .85rem 1rem;
        }

        .payments-layout {
            display: grid;
            grid-template-columns: 220px minmax(0, 1fr);
            gap: .9rem;
            align-items: start;
            padding: 1.25rem;
        }

        .methods-sidebar {
            position: sticky;
            top: 1rem;
            border: 1px solid var(--pay-line);
            border-radius: 1rem;
            background: #0f172a;
            padding: .75rem;
        }

        .methods-sidebar nav {
            display: grid;
            gap: .45rem;
            margin-top: .65rem;
        }

        .method-card {
            display: grid;
            grid-template-columns: 1.8rem minmax(0, 1fr) auto;
            gap: .55rem;
            align-items: center;
            min-height: 3.1rem;
            border: 1px solid transparent;
            border-radius: .8rem;
            background: #1e293b;
            padding: .55rem;
            color: var(--pay-soft);
            text-decoration: none;
            transition: border-color .18s ease, background-color .18s ease, transform .18s ease;
        }

        .method-card:hover,
        .method-card:focus-visible {
            border-color: rgba(59, 130, 246, .5);
            background: rgba(30, 41, 59, .88);
            color: #fff;
            outline: none;
            transform: translateY(-1px);
        }

        .method-card.is-selected {
            border-color: rgba(59, 130, 246, .58);
            background: rgba(59, 130, 246, .18);
            box-shadow: inset 3px 0 0 var(--pay-accent);
        }

        .method-card .material-symbols-outlined {
            color: #93c5fd;
            font-size: 1.15rem;
        }

        .method-name,
        .card-title {
            min-width: 0;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .method-name {
            display: block;
            font-size: .86rem;
            font-weight: 850;
        }

        .method-meta {
            display: block;
            margin-top: .1rem;
            color: var(--pay-dim);
            font-size: .72rem;
            font-weight: 650;
        }

        .method-count {
            min-width: 1.65rem;
            border-radius: .5rem;
            background: rgba(10, 19, 34, .85);
            padding: .2rem .35rem;
            color: var(--pay-muted);
            text-align: center;
            font-size: .72rem;
            font-weight: 900;
            font-variant-numeric: tabular-nums;
        }

        .payments-main {
            display: grid;
            gap: .85rem;
            min-width: 0;
        }

        .method-panel {
            scroll-margin-top: 1rem;
            border: 1px solid var(--pay-line);
            border-radius: 1rem;
            background: #0f172a;
            overflow: hidden;
        }

        .method-panel-header {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: .85rem;
            align-items: start;
            padding: 1rem;
            border-bottom: 1px solid var(--pay-line);
            background: rgba(15, 23, 42, .72);
        }

        .method-heading {
            display: flex;
            flex-wrap: wrap;
            gap: .45rem;
            align-items: center;
        }

        .method-heading h2 {
            margin: 0;
            color: #fff;
            font-size: 1.08rem;
            font-weight: 900;
        }

        .method-copy {
            max-width: 54rem;
            margin: .45rem 0 0;
            color: var(--pay-muted);
            font-size: .83rem;
            line-height: 1.45;
        }

        .method-stats {
            display: flex;
            flex-wrap: wrap;
            justify-content: flex-end;
            gap: .45rem;
        }

        .pay-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: .3rem;
            min-height: 1.55rem;
            border: 1px solid var(--pay-line-soft);
            border-radius: .55rem;
            padding: .22rem .5rem;
            font-size: .72rem;
            font-weight: 850;
            line-height: 1;
            white-space: nowrap;
        }

        .pay-badge-ok {
            border-color: rgba(52, 211, 153, .32);
            background: rgba(52, 211, 153, .1);
            color: #a7f3d0;
        }

        .pay-badge-warn {
            border-color: rgba(251, 191, 36, .34);
            background: rgba(251, 191, 36, .1);
            color: #fde68a;
        }

        .pay-badge-off {
            border-color: rgba(251, 113, 133, .32);
            background: rgba(251, 113, 133, .09);
            color: #fecdd3;
        }

        .pay-badge-muted {
            border-color: rgba(148, 163, 184, .22);
            background: rgba(148, 163, 184, .08);
            color: #cbd5e1;
        }

        .cards-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: .75rem;
            padding: 1rem;
        }

        /* Lista de tarjetas acoplables — una columna */
        .cards-list {
            display: grid;
            gap: .55rem;
            padding: .85rem 1rem;
        }

        /* Accordion por tarjeta */
        .payment-card-accordion {
            border: 1px solid var(--pay-line);
            border-radius: .9rem;
            background: #0f172a;
            overflow: hidden;
            transition: border-color .18s ease;
        }

        .payment-card-accordion[open] {
            border-color: rgba(59, 130, 246, .38);
        }

        .payment-card-summary {
            display: grid;
            grid-template-columns: 1.3rem minmax(0, 1fr) auto;
            gap: .6rem;
            align-items: center;
            padding: .72rem .85rem;
            cursor: pointer;
            list-style: none;
            user-select: none;
            transition: background-color .15s ease;
        }

        .payment-card-summary::-webkit-details-marker {
            display: none;
        }

        .payment-card-summary:hover {
            background: rgba(30, 41, 59, .55);
        }

        .payment-card-summary:focus-visible {
            outline: 2px solid var(--pay-accent);
            outline-offset: -2px;
            border-radius: .85rem;
        }

        .payment-card-chevron {
            color: var(--pay-dim);
            font-size: 1.15rem;
            flex-shrink: 0;
            transition: transform .18s ease;
        }

        .payment-card-accordion[open] .payment-card-chevron {
            transform: rotate(90deg);
        }

        .payment-card-main {
            display: flex;
            flex-wrap: wrap;
            gap: .4rem;
            align-items: center;
            min-width: 0;
        }

        .payment-card-meta {
            display: flex;
            flex-wrap: wrap;
            gap: .3rem;
            align-items: center;
            justify-content: flex-end;
        }

        .payment-card-body {
            border-top: 1px solid var(--pay-line);
            background: rgba(10, 19, 34, .4);
        }

        .payment-card-footer {
            display: flex;
            flex-wrap: wrap;
            gap: .5rem;
            padding: .65rem .85rem;
            border-top: 1px solid var(--pay-line);
            background: rgba(10, 19, 34, .3);
        }

        .inactive-card-note {
            margin: .65rem .85rem .25rem;
            padding-left: .6rem;
            border-left: 3px solid rgba(251, 113, 133, .45);
            color: #fecdd3;
            font-size: .78rem;
            font-weight: 700;
            line-height: 1.4;
        }

        .payment-card,
        .pay-details {
            border: 1px solid var(--pay-line);
            border-radius: .9rem;
            background: #0f172a;
        }

        .payment-card {
            min-width: 0;
            overflow: hidden;
        }

        .payment-card-header {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: .65rem;
            align-items: start;
            padding: .8rem;
            border-bottom: 1px solid var(--pay-line);
        }

        .card-title-row {
            display: flex;
            min-width: 0;
            flex-wrap: wrap;
            gap: .4rem;
            align-items: center;
        }

        .card-title {
            color: #fff;
            font-size: 1rem;
            font-weight: 900;
        }

        .card-subtitle,
        .empty-copy {
            margin-top: .25rem;
            color: var(--pay-dim);
            font-size: .75rem;
            line-height: 1.35;
        }

        .plan-list {
            display: grid;
            gap: .45rem;
            padding: .65rem;
        }

        .plan-row {
            border: 1px solid var(--pay-line);
            border-radius: .65rem;
            background: var(--pay-row);
            overflow: hidden;
        }

        .plan-summary,
        .compact-summary {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: .55rem;
            align-items: center;
            cursor: pointer;
            list-style: none;
        }

        .plan-summary {
            padding: .52rem .6rem;
        }

        .plan-summary::-webkit-details-marker,
        .compact-summary::-webkit-details-marker {
            display: none;
        }

        .plan-main {
            display: flex;
            min-width: 0;
            flex-wrap: wrap;
            gap: .35rem;
            align-items: center;
            color: var(--pay-soft);
            font-size: .82rem;
            font-weight: 800;
        }

        .plan-actions {
            display: flex;
            flex-wrap: wrap;
            justify-content: flex-end;
            gap: .35rem;
        }

        .details-body {
            border-top: 1px solid var(--pay-line);
            padding: .75rem;
            background: rgba(15, 23, 42, .74);
        }

        .compact-summary {
            padding: .7rem .8rem;
            color: var(--pay-soft);
            font-size: .82rem;
            font-weight: 900;
        }

        .compact-summary .material-symbols-outlined {
            color: #93c5fd;
            font-size: 1.05rem;
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: .65rem;
        }

        .form-grid .span-2 {
            grid-column: span 2;
        }

        .pay-field,
        .pay-select {
            width: 100%;
            min-height: 2.45rem;
            border: 1px solid rgba(148, 163, 184, .24);
            border-radius: .65rem;
            background: #0a1322;
            color: #f8fafc;
            padding: .52rem .65rem;
            font-size: .86rem;
            outline: none;
        }

        .pay-field:focus,
        .pay-select:focus {
            border-color: rgba(59, 130, 246, .8);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, .18);
        }

        .pay-check {
            display: inline-flex;
            align-items: center;
            gap: .45rem;
            min-height: 2.45rem;
            border: 1px solid rgba(148, 163, 184, .24);
            border-radius: .65rem;
            background: rgba(10, 19, 34, .85);
            padding: .52rem .65rem;
            color: var(--pay-soft);
            font-size: .84rem;
            font-weight: 750;
        }

        .pay-button-row {
            display: flex;
            flex-wrap: wrap;
            gap: .5rem;
            align-items: center;
            margin-top: .75rem;
        }

        .pay-mini-button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: .35rem;
            min-height: 2rem;
            border: 1px solid rgba(148, 163, 184, .24);
            border-radius: .6rem;
            background: rgba(15, 23, 42, .78);
            padding: .4rem .6rem;
            color: var(--pay-soft);
            font-size: .76rem;
            font-weight: 850;
            line-height: 1;
            text-decoration: none;
            cursor: pointer;
            transition: background-color .18s ease, border-color .18s ease, transform .18s ease;
        }

        .pay-mini-button:hover,
        .pay-mini-button:focus-visible {
            border-color: rgba(59, 130, 246, .5);
            background: rgba(59, 130, 246, .15);
            color: #fff;
            outline: none;
            transform: translateY(-1px);
        }

        .pay-mini-button.primary {
            border-color: rgba(59, 130, 246, .6);
            background: #2563eb;
            color: #eff6ff;
        }

        .pay-mini-button.danger {
            border-color: rgba(251, 113, 133, .34);
            color: #fecdd3;
        }

        .empty-state,
        .credit-debt {
            margin: 1rem;
            border: 1px solid var(--pay-line);
            border-radius: .9rem;
            background: rgba(10, 19, 34, .66);
            padding: 1rem;
        }

        .credit-debt {
            border-color: rgba(251, 191, 36, .28);
            color: #fde68a;
        }

        .legacy-note {
            margin-top: .5rem;
            color: var(--pay-dim);
            font-size: .72rem;
        }

        .toast-msg {
            margin: 1rem 1.25rem 0;
        }

        @@media (max-width: 980px) {
            .payments-layout {
                grid-template-columns: minmax(0, 1fr);
            }

            .methods-sidebar {
                position: static;
            }

            .methods-sidebar nav {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .cards-grid {
                grid-template-columns: minmax(0, 1fr);
            }
        }

        @@media (max-width: 700px) {
            .payments-page {
                margin: -.75rem;
                padding: .75rem;
            }

            .payments-shell-card {
                border-radius: 18px;
            }

            .payments-topbar,
            .method-panel-header,
            .payment-card-header {
                grid-template-columns: minmax(0, 1fr);
            }

            .payments-actions,
            .method-stats,
            .plan-actions {
                justify-content: flex-start;
            }

            .payments-metrics {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .form-grid {
                grid-template-columns: minmax(0, 1fr);
            }

            .form-grid .span-2 {
                grid-column: span 1;
            }
        }

        @@media (max-width: 430px) {
            .payments-topbar,
            .payments-layout,
            .cards-grid,
            .cards-list,
            .method-panel-header {
                padding: .8rem;
            }

            .payments-metrics {
                grid-template-columns: minmax(0, 1fr);
                padding: .8rem .8rem 0;
            }

            .payments-rule {
                margin: .8rem .8rem 0;
            }

            .methods-sidebar nav {
                grid-template-columns: minmax(0, 1fr);
            }

            .plan-summary {
                grid-template-columns: minmax(0, 1fr);
            }

            .payment-card-summary {
                grid-template-columns: 1.3rem minmax(0, 1fr);
            }

            .payment-card-meta {
                display: none;
            }

            .pay-mini-button,
            .pay-button-row button {
                width: 100%;
            }

            .payment-card-footer .pay-mini-button {
                width: auto;
            }
        }
    </style>
}

<div class="payments-page">
    <section class="payments-shell-card" aria-labelledby="payments-title">
        <header class="payments-topbar">
            <div>
                <div class="payments-eyebrow">Configuracion global de pagos</div>
                <h1 id="payments-title" class="payments-title">Configuracion de pagos</h1>
                <p class="payments-subtitle">
                    Administra medios, tarjetas y planes reutilizables. El ajuste se aplica una sola vez sobre el total.
                    Ajuste positivo = recargo, ajuste negativo = descuento. Cuotas indica la cantidad total de pagos.
                </p>
            </div>
            <div class="payments-actions">
                <span class="payments-credit-note">
                    <span class="material-symbols-outlined text-[18px]">info</span>
                    Credito personal se administra en una fase separada.
                </span>
                <a asp-controller="Home" asp-action="Index" class="pay-mini-button">
                    <span class="material-symbols-outlined text-[18px]">arrow_back</span>
                    Volver
                </a>
            </div>
        </header>

        @if (TempData["Error"] != null)
        {
            <div class="toast-msg flex items-center gap-3 rounded-xl border border-rose-500/30 bg-rose-500/10 p-3 text-sm font-semibold text-rose-200" role="alert">
                <span class="material-symbols-outlined">error</span>
                @TempData["Error"]
            </div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="toast-msg flex items-center gap-3 rounded-xl border border-emerald-500/30 bg-emerald-500/10 p-3 text-sm font-semibold text-emerald-200" role="status">
                <span class="material-symbols-outlined">check_circle</span>
                @TempData["Success"]
            </div>
        }

        <section class="payments-metrics" aria-label="Resumen">
            <article class="payments-metric">
                <span class="payments-eyebrow">Medios</span>
                <strong>@Model.TotalMedios</strong>
            </article>
            <article class="payments-metric">
                <span class="payments-eyebrow">Tarjetas</span>
                <strong>@Model.TotalTarjetas</strong>
            </article>
            <article class="payments-metric">
                <span class="payments-eyebrow">Planes</span>
                <strong>@Model.TotalPlanes</strong>
            </article>
            <article class="payments-metric">
                <span class="payments-eyebrow">Inactivos</span>
                <strong>@Model.TotalInactivos</strong>
            </article>
        </section>

        <section class="payments-rule">
            <div class="flex flex-wrap items-center gap-2">
                <span class="pay-badge pay-badge-ok">-5% descuento</span>
                <span class="pay-badge pay-badge-muted">0% sin ajuste</span>
                <span class="pay-badge pay-badge-warn">+5% recargo</span>
                @if (!puedeEditar)
                {
                    <span class="pay-badge pay-badge-muted">Solo lectura</span>
                }
            </div>
        </section>

        @if (Model.Medios.Count == 0)
        {
            <section class="empty-state text-center">
                <span class="material-symbols-outlined text-5xl text-slate-600">payments</span>
                <h2 class="mt-2 text-xl font-black text-white">Sin medios configurados</h2>
                <p class="empty-copy">Todavia no hay configuracion global de pagos para administrar.</p>
            </section>
        }
        else
        {
            <div class="payments-layout">
                <aside class="methods-sidebar" aria-label="Metodos de pago">
                    <div class="payments-eyebrow">Metodos</div>
                    <nav>
                        @for (var i = 0; i < Model.Medios.Count; i++)
                        {
                            var medio = Model.Medios[i];
                            var totalPlanesMetodo = medio.Planes.Count;
                            var totalTarjetasMetodo = medio.Tarjetas.Count;
                            var esMedioSeleccionado = medioSeleccionado?.Id == medio.Id;
                            <a asp-controller="ConfiguracionPago"
                               asp-action="MediosPago"
                               asp-route-medioId="@medio.Id"
                               class="method-card @(esMedioSeleccionado ? "is-selected" : "")"
                               aria-current="@(esMedioSeleccionado ? "page" : null)">
                                <span class="material-symbols-outlined">@MetodoIcon(medio.TipoPago)</span>
                                <span class="min-w-0">
                                    <span class="method-name">@TipoPagoDisplay(medio.TipoPago)</span>
                                    <span class="method-meta">@totalTarjetasMetodo tarjeta@(totalTarjetasMetodo == 1 ? "" : "s")</span>
                                </span>
                                <span class="method-count" title="@totalPlanesMetodo planes">@totalPlanesMetodo</span>
                            </a>
                        }
                    </nav>
                </aside>

                <main class="payments-main">
                    @if (medioSeleccionado != null)
                    {
                        var medio = medioSeleccionado;
                        var permiteTarjetas = medio.TipoPago == TipoPago.TarjetaCredito || medio.TipoPago == TipoPago.TarjetaDebito;
                        var permitePlanesGlobales = medio.TipoPago != TipoPago.CreditoPersonal && medio.TipoPago != TipoPago.Tarjeta;
                        var tarjetas = medio.Tarjetas
                            .OrderByDescending(t => t.Activa)
                            .ThenBy(t => t.TipoTarjeta)
                            .ThenBy(t => t.Nombre)
                            .ToList();
                        var planesGenerales = medio.Planes
                            .Where(p => p.ConfiguracionTarjetaId is null)
                            .OrderByDescending(p => p.Activo)
                            .ThenBy(p => p.Orden)
                            .ThenBy(p => p.CantidadCuotas)
                            .ToList();
                        var totalPlanes = medio.Planes.Count;

                        <section id="medio-@medio.Id" class="method-panel">
