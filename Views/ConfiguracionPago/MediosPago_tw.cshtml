                                                    {
                                                        <span class="pay-badge pay-badge-muted">Sin cuotas activas</span>
                                                    }
                                                    @if (planesInactivosTarjeta > 0)
                                                    {
                                                        <span class="pay-badge pay-badge-off">@planesInactivosTarjeta inactiva@(planesInactivosTarjeta == 1 ? "" : "s")</span>
                                                    }
                                                </span>
                                            </summary>

                                            <div class="payment-card-body">
                                                @if (!tarjeta.Activa)
                                                {
                                                    <p class="inactive-card-note">
                                                        Tarjeta quitada para nuevas operaciones. Puede reactivarse desde el footer de este bloque.
