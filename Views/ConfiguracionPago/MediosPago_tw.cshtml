                                                    <div class="space-y-3 border-t border-slate-700/50 p-4">
                                                        <form asp-controller="ConfiguracionPago" asp-action="EditarPlanGlobal" asp-route-id="@plan.Id" method="post" class="space-y-4">
                                                            @Html.AntiForgeryToken()
