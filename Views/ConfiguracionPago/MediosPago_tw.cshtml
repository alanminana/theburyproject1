                                                                    <div class="details-body">
                                                                        <form asp-controller="ConfiguracionPago" asp-action="EditarPlanGlobal" asp-route-id="@plan.Id" method="post">
                                                                            @Html.AntiForgeryToken()
                                                                            <input type="hidden" name="ConfiguracionPagoId" value="@medio.Id" />
                                                                            <input type="hidden" name="ConfiguracionTarjetaId" value="@tarjeta.Id" />
                                                                            <input type="hidden" name="TipoAjuste" value="@plan.TipoAjuste" />
                                                                            <div class="form-grid">
                                                                                <div>
                                                                                    <label class="pay-label">Cuotas</label>
                                                                                    <input name="CantidadCuotas" type="number" min="1" value="@plan.CantidadCuotas" required class="pay-field" />
                                                                                </div>
                                                                                <div>
                                                                                    <label class="pay-label">Ajuste %</label>
                                                                                    <input name="AjustePorcentaje" type="number" step="0.0001" min="-100.0000" max="999.9999" value="@plan.AjustePorcentaje.ToString(CultureInfo.InvariantCulture)" required class="pay-field" />
                                                                                </div>
                                                                                <div>
                                                                                    <label class="pay-label">Orden</label>
