                                                        </p>
                                                    }
                                                    else
                                                    {
                                                        @foreach (var plan in planesTarjeta)
                                                        {
                                                            <details class="plan-row">
                                                                <summary class="plan-summary">
                                                                    <span class="plan-main">
                                                                        <span>@plan.CantidadCuotas cuota@(plan.CantidadCuotas == 1 ? "" : "s") exacta@(plan.CantidadCuotas == 1 ? "" : "s")</span>
                                                                        <span class="@AjusteClass(plan.AjustePorcentaje)">@AjusteFirmado(plan.AjustePorcentaje) @AjusteModo(plan.AjustePorcentaje)</span>
                                                                        <span class="@EstadoClass(plan.Activo)">@(plan.Activo ? "Activo" : "Inactivo")</span>
                                                                    </span>
                                                                    <span class="plan-actions">
                                                                        <span class="pay-mini-button">Editar</span>
                                                                    </span>
