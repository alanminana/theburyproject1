                                                                                {
                                                                                    <option value="@tipoTarjeta" selected="@(tipoTarjeta == tarjeta.TipoTarjeta)">@TipoTarjetaDisplay(tipoTarjeta)</option>
                                                                                }
                                                                            </select>
                                                                        </div>
                                                                        <label class="pay-check">
                                                                            <input name="Activa" type="checkbox" value="true" checked="@tarjeta.Activa" />
                                                                            Activa
                                                                        </label>
                                                                        <div class="span-2">
                                                                            <label class="pay-label">Observaciones</label>
                                                                            <input name="Observaciones" maxlength="500" value="@tarjeta.Observaciones" class="pay-field" />
                                                                        </div>
                                                                    </div>
                                                                    <div class="pay-button-row">
                                                                        <button type="submit" class="pay-mini-button primary">
                                                                            <span class="material-symbols-outlined text-[17px]">save</span>
                                                                            Guardar tarjeta
                                                                        </button>
                                                                    </div>
                                                                </form>
                                                            </div>
                                                        </details>
                                                    }
                                                </div>

                                                @if (puedeEditar)
                                                {
                                                    <div class="payment-card-footer">
                                                        <form asp-controller="ConfiguracionPago" asp-action="CambiarEstadoTarjetaGlobal" asp-route-id="@tarjeta.Id" asp-route-medioId="@medio.Id" method="post">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="activa" value="@(!tarjeta.Activa)" />
                                                            <button type="submit" class="pay-mini-button @(tarjeta.Activa ? "danger" : "")">
                                                                <span class="material-symbols-outlined text-[17px]">@(tarjeta.Activa ? "toggle_off" : "toggle_on")</span>
                                                                @(tarjeta.Activa ? "Quitar tarjeta" : "Reactivar tarjeta")
                                                            </button>
                                                        </form>
                                                    </div>
                                                }
                                            </div>
                                        </details>
                                    }

                                    @if (tarjetas.Count == 0)
                                    {
                                        <div class="empty-state">
                                            <h3 class="text-base font-black text-white">Sin tarjetas configuradas</h3>
                                            <p class="empty-copy">Este metodo no tiene marcas o entidades asociadas.</p>
                                        </div>
