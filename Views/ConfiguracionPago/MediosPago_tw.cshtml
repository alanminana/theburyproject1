                                                <span class="payment-card-meta">
                                                    @if (planesActivosTarjeta > 0)
                                                    {
                                                        <span class="pay-badge pay-badge-ok">@planesActivosTarjeta cuota@(planesActivosTarjeta == 1 ? "" : "s") activa@(planesActivosTarjeta == 1 ? "" : "s")</span>
                                                    }
