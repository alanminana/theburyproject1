                                    {
                                        <p class="legacy-note">
                                            Campos legacy de recargo/descuento conservados solo como compatibilidad; la configuracion operativa vive en planes.
                                        </p>
                                    }
                                </div>
                                <div class="method-stats">
                                    <span class="pay-badge pay-badge-muted">@tarjetas.Count tarjeta@(tarjetas.Count == 1 ? "" : "s")</span>
                                    <span class="pay-badge pay-badge-muted">@totalPlanes plan@(totalPlanes == 1 ? "" : "es")</span>
                                    @if (puedeEditar)
                                    {
                                        <span class="pay-badge pay-badge-muted" title="La edicion del metodo requiere una vista separada. Pendiente de implementacion.">
                                            <span class="material-symbols-outlined" style="font-size:1rem">edit_off</span>
                                            Metodo
                                        </span>
                                    }
                                </div>
                            </header>

                            @if (medio.TipoPago == TipoPago.CreditoPersonal)
                            {
                                <div class="credit-debt">
                                    <strong>Credito personal tiene configuracion propia por tasa, scoring y perfiles de credito.</strong>
                                    <p class="mt-1 text-sm text-amber-100/80">Los cambios operativos se administran en la pantalla de configuracion de credito.</p>
                                    @if (puedeEditar)
                                    {
                                        <a asp-controller="ConfiguracionPago" asp-action="CreditoPersonal" class="pay-mini-button mt-2">
                                            <span class="material-symbols-outlined text-[17px]">tune</span>
                                            Administrar credito personal
                                        </a>
                                    }
                                </div>
                            }

                            <p class="px-4 py-2 text-xs text-slate-500">
                                Quitar oculta el elemento para nuevas operaciones, pero conserva el historial. Si se vuelve a cargar el mismo dato, se reactiva.
                            </p>

                            @if (permiteTarjetas)
                            {
                                <div class="cards-list" aria-label="Tarjetas del metodo">
                                    @foreach (var tarjeta in tarjetas)
                                    {
                                        var planesTarjeta = medio.Planes
                                            .Where(p => p.ConfiguracionTarjetaId == tarjeta.Id)
                                            .OrderByDescending(p => p.Activo)
                                            .ThenBy(p => p.Orden)
                                            .ThenBy(p => p.CantidadCuotas)
                                            .ToList();
                                        var planesActivosTarjeta = planesTarjeta.Count(p => p.Activo);
                                        var planesInactivosTarjeta = planesTarjeta.Count(p => !p.Activo);

                                        <details class="payment-card-accordion">
                                            <summary class="payment-card-summary">
                                                <span class="payment-card-chevron material-symbols-outlined" aria-hidden="true">chevron_right</span>
                                                <span class="payment-card-main">
                                                    <strong class="card-title">@tarjeta.Nombre</strong>
                                                    <span class="pay-badge pay-badge-muted">@TipoTarjetaDisplay(tarjeta.TipoTarjeta)</span>
                                                    <span class="@EstadoClass(tarjeta.Activa)">@(tarjeta.Activa ? "Activa" : "Inactiva")</span>
