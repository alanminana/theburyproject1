                                        </header>
                                        <div class="plan-list">
                                            @foreach (var plan in planesGenerales)
                                            {
                                                <details class="plan-row">
                                                    <summary class="plan-summary">
                                                        <span class="plan-main">
                                                            <span>@plan.CantidadCuotas cuota@(plan.CantidadCuotas == 1 ? "" : "s") exacta@(plan.CantidadCuotas == 1 ? "" : "s")</span>
                                                            <span class="@AjusteClass(plan.AjustePorcentaje)">@AjusteFirmado(plan.AjustePorcentaje) @AjusteModo(plan.AjustePorcentaje)</span>
                                                            <span class="@EstadoClass(plan.Activo)">@(plan.Activo ? "Activo" : "Inactivo")</span>
                                                        </span>
                                                        <span class="plan-actions">
                                                            <span class="pay-mini-button">Editar</span>
                                                        </span>
                                                    </summary>

                                                    @if (puedeEditar && permitePlanesGlobales)
                                                    {
                                                        <div class="details-body">
                                                            <form asp-controller="ConfiguracionPago" asp-action="EditarPlanGlobal" asp-route-id="@plan.Id" method="post">
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="ConfiguracionPagoId" value="@medio.Id" />
                                                                <input type="hidden" name="TipoAjuste" value="@plan.TipoAjuste" />
                                                                <div class="form-grid">
                                                                    <div>
                                                                        <label class="pay-label">Cuotas</label>
                                                                        <input name="CantidadCuotas" type="number" min="1" value="@plan.CantidadCuotas" required class="pay-field" />
                                                                    </div>
                                                                    <div>
                                                                        <label class="pay-label">Ajuste %</label>
                                                                        <input name="AjustePorcentaje" type="number" step="0.0001" min="-100.0000" max="999.9999" value="@plan.AjustePorcentaje.ToString(CultureInfo.InvariantCulture)" required class="pay-field" />
                                                                    </div>
                                                                    <div>
                                                                        <label class="pay-label">Orden</label>
                                                                        <input name="Orden" type="number" value="@plan.Orden" class="pay-field" />
                                                                    </div>
                                                                    <label class="pay-check">
                                                                        <input name="Activo" type="checkbox" value="true" checked="@plan.Activo" />
                                                                        Activo
                                                                    </label>
                                                                    <div>
                                                                        <label class="pay-label">Etiqueta</label>
                                                                        <input name="Etiqueta" maxlength="100" value="@plan.Etiqueta" class="pay-field" />
                                                                    </div>
                                                                    <div class="span-2">
                                                                        <label class="pay-label">Observaciones</label>
                                                                        <input name="Observaciones" maxlength="500" value="@plan.Observaciones" class="pay-field" />
