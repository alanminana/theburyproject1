                                                        Crear tarjeta
                                                    </button>
                                                </div>
                                            </form>
                                        </div>
                                    </details>
                                }
                            }

                            @if (planesGenerales.Count > 0 || (puedeEditar && permitePlanesGlobales && !permiteTarjetas))
                            {
