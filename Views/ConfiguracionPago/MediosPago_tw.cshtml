@section Scripts {
    <script>
        (() => {
            document.querySelectorAll('form[action*="TarjetaGlobal"]').forEach((form) => {
                form.addEventListener('submit', () => {
                    if (!form.checkValidity()) {
                        return;
                    }

                    const button = form.querySelector('button[type="submit"]');
                    if (!button) {
                        return;
                    }

                    button.disabled = true;
                    button.setAttribute('aria-busy', 'true');
                    button.innerHTML = '<span class="material-symbols-outlined text-[20px]">hourglass_top</span> Guardando...';
                });
            });
        })();
    </script>
}
