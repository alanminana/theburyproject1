                                                                                <div>
                                                                                    <label class="pay-label">Etiqueta</label>
                                                                                    <input name="Etiqueta" maxlength="100" value="@plan.Etiqueta" class="pay-field" />
                                                                                </div>
                                                                                <div class="span-2">
                                                                                    <label class="pay-label">Observaciones</label>
                                                                                    <input name="Observaciones" maxlength="500" value="@plan.Observaciones" class="pay-field" />
                                                                                </div>
                                                                            </div>
                                                                            <div class="pay-button-row">
                                                                                <button type="submit" class="pay-mini-button primary">
                                                                                    <span class="material-symbols-outlined text-[17px]">save</span>
                                                                                    Guardar plan
                                                                                </button>
                                                                            </div>
                                                                        </form>
                                                                        <form asp-controller="ConfiguracionPago" asp-action="CambiarEstadoPlanGlobal" asp-route-id="@plan.Id" asp-route-medioId="@medio.Id" method="post" class="pay-button-row">
                                                                            @Html.AntiForgeryToken()
                                                                            <input type="hidden" name="activo" value="@(!plan.Activo)" />
                                                                            <button type="submit" class="pay-mini-button @(plan.Activo ? "danger" : "")">
                                                                                <span class="material-symbols-outlined text-[17px]">@(plan.Activo ? "toggle_off" : "toggle_on")</span>
                                                                                @(plan.Activo ? "Quitar cuota" : "Reactivar cuota")
                                                                            </button>
                                                                        </form>
                                                                    </div>
                                                                }
                                                            </details>
                                                        }
                                                    }

                                                    @if (puedeEditar && permitePlanesGlobales)
                                                    {
                                                        <details class="pay-details">
                                                            <summary class="compact-summary">
                                                                <span class="flex items-center gap-2">
                                                                    <span class="material-symbols-outlined">add_circle</span>
                                                                    Agregar cuota
                                                                </span>
                                                                <span class="pay-badge pay-badge-muted">cuota exacta</span>
                                                            </summary>
                                                            <div class="details-body">
                                                                <form asp-controller="ConfiguracionPago" asp-action="CrearPlanGlobal" method="post">
                                                                    @Html.AntiForgeryToken()
                                                                    <input type="hidden" name="ConfiguracionPagoId" value="@medio.Id" />
                                                                    <input type="hidden" name="ConfiguracionTarjetaId" value="@tarjeta.Id" />
                                                                    <input type="hidden" name="TipoAjuste" value="@TipoAjustePagoPlan.Porcentaje" />
                                                                    <div class="form-grid">
                                                                        <div>
                                                                            <label class="pay-label">Cuotas</label>
                                                                            <input name="CantidadCuotas" type="number" min="1" value="1" required class="pay-field" />
                                                                        </div>
                                                                        <div>
                                                                            <label class="pay-label">Ajuste %</label>
                                                                            <input name="AjustePorcentaje" type="number" step="0.0001" min="-100.0000" max="999.9999" value="0" required class="pay-field" />
                                                                        </div>
                                                                        <div>
                                                                            <label class="pay-label">Orden</label>
                                                                            <input name="Orden" type="number" value="0" class="pay-field" />
                                                                        </div>
                                                                        <label class="pay-check">
                                                                            <input name="Activo" type="checkbox" value="true" checked />
                                                                            Activo
                                                                        </label>
                                                                        <div>
                                                                            <label class="pay-label">Etiqueta</label>
                                                                            <input name="Etiqueta" maxlength="100" class="pay-field" />
                                                                        </div>
                                                                        <div class="span-2">
                                                                            <label class="pay-label">Observaciones</label>
                                                                            <input name="Observaciones" maxlength="500" class="pay-field" />
                                                                        </div>
                                                                    </div>
                                                                    <div class="pay-button-row">
                                                                        <button type="submit" class="pay-mini-button primary">
                                                                            <span class="material-symbols-outlined text-[17px]">save</span>
                                                                            Crear cuota
                                                                        </button>
                                                                    </div>
                                                                </form>
                                                            </div>
                                                        </details>
                                                    }

                                                    @if (puedeEditar)
                                                    {
                                                        <details class="pay-details">
                                                            <summary class="compact-summary">
                                                                <span class="flex items-center gap-2">
                                                                    <span class="material-symbols-outlined">edit</span>
                                                                    Editar tarjeta
                                                                </span>
                                                            </summary>
                                                            <div class="details-body">
                                                                <form asp-controller="ConfiguracionPago" asp-action="EditarTarjetaGlobal" asp-route-id="@tarjeta.Id" method="post">
                                                                    @Html.AntiForgeryToken()
                                                                    <input type="hidden" name="ConfiguracionPagoId" value="@medio.Id" />
                                                                    <div class="form-grid">
                                                                        <div class="span-2">
                                                                            <label class="pay-label">Nombre</label>
                                                                            <input name="NombreTarjeta" maxlength="100" value="@tarjeta.Nombre" required class="pay-field" />
