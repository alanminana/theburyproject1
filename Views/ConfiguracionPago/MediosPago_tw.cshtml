                                    <article class="payment-card">
                                        <header class="payment-card-header">
                                            <div>
                                                <div class="card-title-row">
                                                    <span class="card-title">Plan general del medio</span>
                                                    <span class="pay-badge pay-badge-muted">@planesGenerales.Count plan@(planesGenerales.Count == 1 ? "" : "es")</span>
