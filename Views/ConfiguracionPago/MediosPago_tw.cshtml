                                        <span class="pay-badge pay-badge-muted">@medio.Nombre</span>
                                    </div>
                                    <p class="method-copy">
                                        @(!string.IsNullOrWhiteSpace(medio.Descripcion)
                                            ? medio.Descripcion
                                            : "Metodo global con historial preservado. Los planes usan cuotas exactas, no rangos.")
                                    </p>
