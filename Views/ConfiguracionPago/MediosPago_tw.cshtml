@using TheBuryProject.Models.Enums
@using System.Globalization
@model ConfiguracionPagoGlobalAdminViewModel
@{
    ViewData["Title"] = "Configuracion global de pagos";
    var puedeEditar = User.TienePermiso("configuraciones", "update");

    static string AjusteFirmado(decimal ajuste) => ajuste > 0m
        ? $"+{ajuste:0.##}%"
        : $"{ajuste:0.##}%";

    static string AjusteModo(decimal ajuste) => ajuste switch
    {
        > 0m => "recargo",
        < 0m => "descuento",
        _ => "sin ajuste"
    };

    static string AjusteClasses(decimal ajuste) => ajuste switch
    {
        > 0m => "border-amber-500/30 bg-amber-500/10 text-amber-200",
        < 0m => "border-emerald-500/30 bg-emerald-500/10 text-emerald-200",
        _ => "border-slate-700 bg-slate-900 text-slate-300"
    };

    static string TipoPagoDisplay(TipoPago tipoPago) => tipoPago switch
    {
        TipoPago.Efectivo => "Efectivo",
        TipoPago.Transferencia => "Transferencia",
        TipoPago.TarjetaDebito => "Tarjeta Debito",
        TipoPago.TarjetaCredito => "Tarjeta Credito",
        TipoPago.Cheque => "Cheque",
        TipoPago.CreditoPersonal => "Credito Personal",
        TipoPago.MercadoPago => "Mercado Pago",
        TipoPago.CuentaCorriente => "Cuenta Corriente",
        TipoPago.Tarjeta => "Tarjeta legacy",
        _ => tipoPago.ToString()
    };
}

<div class="space-y-8">
    <section class="card-erp-panel-padded">
        <header class="flex flex-col gap-6 xl:flex-row xl:items-start xl:justify-between">
            <div class="max-w-4xl space-y-4">
                <nav aria-label="Breadcrumb" class="flex text-sm font-medium text-slate-400">
                    <ol class="inline-flex flex-wrap items-center gap-y-1">
                        <li><a asp-controller="Home" asp-action="Index" class="hover:text-primary no-underline">Inicio</a></li>
                        <li><span class="mx-2 text-slate-500">/</span></li>
                        <li class="text-slate-100">Configuracion global de pagos</li>
                    </ol>
                </nav>
                <div class="space-y-3">
                    <span class="badge-erp badge-erp-primary">
                        <span class="material-symbols-outlined text-sm">payments</span>
                        Administracion
                    </span>
                    <div class="space-y-2">
                        <h1 class="text-3xl font-black tracking-tight text-white sm:text-4xl">Configuracion global de pagos</h1>
                        <p class="max-w-3xl text-sm leading-relaxed text-slate-400 sm:text-base">
                            Administra medios, tarjetas y planes globales. En ventas futuras, los elementos inactivos no estaran disponibles para seleccionar.
                        </p>
                    </div>
                </div>
            </div>

            <div class="flex w-full flex-col gap-3 sm:flex-row xl:w-auto xl:justify-end">
                <a asp-controller="ConfiguracionPago" asp-action="CreditoPersonal"
                   asp-route-returnUrl="@($"{Context.Request.Path}{Context.Request.QueryString}")"
                   class="btn-erp-secondary w-full sm:w-auto sm:py-2.5 no-underline">
                    <span class="material-symbols-outlined text-[20px]">credit_score</span>
                    Credito personal
                </a>
                <a asp-controller="Home" asp-action="Index" class="btn-erp-ghost w-full sm:w-auto sm:py-2.5 no-underline">
                    <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                    Volver
                </a>
            </div>
        </header>
    </section>

    @if (TempData["Error"] != null)
    {
        <div class="toast-msg flex items-center gap-3 rounded-xl border border-rose-500/20 bg-rose-500/10 p-4 text-sm font-semibold text-rose-400" role="alert">
            <span class="material-symbols-outlined">error</span>
            @TempData["Error"]
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="toast-msg flex items-center gap-3 rounded-xl border border-emerald-500/20 bg-emerald-500/10 p-4 text-sm font-semibold text-emerald-400" role="status">
            <span class="material-symbols-outlined">check_circle</span>
            @TempData["Success"]
        </div>
    }

    <section class="grid grid-cols-1 gap-4 md:grid-cols-4">
        <div class="card-erp-panel-padded">
            <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Medios</p>
            <p class="mt-2 text-3xl font-black text-white">@Model.TotalMedios</p>
        </div>
        <div class="card-erp-panel-padded">
            <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Tarjetas</p>
            <p class="mt-2 text-3xl font-black text-white">@Model.TotalTarjetas</p>
        </div>
        <div class="card-erp-panel-padded">
            <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Planes/cuotas</p>
            <p class="mt-2 text-3xl font-black text-white">@Model.TotalPlanes</p>
        </div>
        <div class="card-erp-panel-padded">
            <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Inactivos visibles</p>
            <p class="mt-2 text-3xl font-black text-amber-300">@Model.TotalInactivos</p>
        </div>
    </section>

    <section class="card-erp-panel-padded">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div class="space-y-2">
                <h2 class="text-xl font-bold text-white">Regla operativa</h2>
                <p class="max-w-3xl text-sm leading-relaxed text-slate-400">
                    El ajuste se aplica una sola vez sobre el total. Ajuste positivo = recargo, ajuste negativo = descuento, ajuste 0 = sin ajuste.
                    Cuotas indica la cantidad total de pagos, no interes mensual.
                </p>
            </div>
            @if (!puedeEditar)
            {
                <span class="inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-900 px-3 py-1.5 text-xs font-semibold text-slate-300">
                    <span class="material-symbols-outlined text-sm">visibility</span>
                    Solo lectura
                </span>
            }
        </div>
    </section>

    @if (Model.Medios.Count == 0)
    {
        <section class="card-erp-panel-padded text-center">
            <span class="material-symbols-outlined text-5xl text-slate-600">payments</span>
            <h2 class="mt-3 text-xl font-bold text-white">Sin medios configurados</h2>
            <p class="mt-2 text-sm text-slate-400">Todavia no hay configuracion global de pagos para administrar.</p>
        </section>
    }
    else
    {
        <section class="space-y-4">
            <div class="rounded-lg border border-slate-800 bg-slate-950/50 p-4 text-sm leading-relaxed text-slate-400">
                <p>
                    Alta libre de medios nuevos no se habilita en esta fase: los medios dependen de <span class="font-mono text-slate-200">TipoPago</span> y ese contrato impacta ventas, caja, reportes y comprobantes.
                    Editar o inactivar un medio existente se hace desde su configuracion actual.
                </p>
            </div>

            @foreach (var medio in Model.Medios)
            {
                var permiteTarjetas = medio.TipoPago == TipoPago.TarjetaCredito || medio.TipoPago == TipoPago.TarjetaDebito;
                var permitePlanesGlobales = medio.TipoPago != TipoPago.CreditoPersonal && medio.TipoPago != TipoPago.Tarjeta;
                var tarjetas = medio.Tarjetas
                    .OrderByDescending(t => t.Activa)
                    .ThenBy(t => t.TipoTarjeta)
                    .ThenBy(t => t.Nombre)
                    .ToList();
                var planesGenerales = medio.Planes
                    .Where(p => p.ConfiguracionTarjetaId is null)
                    .OrderByDescending(p => p.Activo)
                    .ThenBy(p => p.Orden)
                    .ThenBy(p => p.CantidadCuotas)
                    .ToList();

                <details class="card-erp-panel overflow-hidden" open="@(medio.TipoPago == TipoPago.TarjetaCredito || medio.TipoPago == TipoPago.TarjetaDebito)">
                    <summary class="cursor-pointer list-none border-b border-slate-800 bg-slate-950/40 p-5">
                        <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                            <div class="min-w-0 space-y-3">
                                <div class="flex flex-wrap items-center gap-2">
                                    <span class="material-symbols-outlined text-primary">payments</span>
                                    <h2 class="text-xl font-black text-white">@TipoPagoDisplay(medio.TipoPago)</h2>
                                    <span class="rounded-full border border-slate-700 px-2.5 py-1 text-xs font-bold text-slate-300">@medio.Nombre</span>
                                    <span class="rounded-full border px-2.5 py-1 text-xs font-bold @(medio.Activo ? "border-emerald-500/30 bg-emerald-500/10 text-emerald-300" : "border-amber-500/30 bg-amber-500/10 text-amber-300")">
                                        @(medio.Activo ? "Activo" : "Inactivo")
                                    </span>
                                </div>
                                <p class="max-w-3xl text-sm leading-relaxed text-slate-400">
                                    @(!string.IsNullOrWhiteSpace(medio.Descripcion) ? medio.Descripcion : "Metodo de pago global. Inactivar conserva historial y evita nuevas selecciones cuando el flujo lo consulta como activo.")
                                </p>
                            </div>

                            <div class="grid grid-cols-2 gap-3 text-sm sm:grid-cols-4 lg:min-w-[34rem]">
                                <div class="rounded-lg border border-slate-800 bg-slate-950/50 p-3">
                                    <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Tarjetas</p>
                                    <p class="mt-1 font-semibold text-slate-100">@tarjetas.Count</p>
                                </div>
                                <div class="rounded-lg border border-slate-800 bg-slate-950/50 p-3">
                                    <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Planes</p>
                                    <p class="mt-1 font-semibold text-slate-100">@medio.Planes.Count</p>
                                </div>
                                <div class="rounded-lg border border-slate-800 bg-slate-950/50 p-3">
                                    <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Descuento legacy</p>
                                    <p class="mt-1 font-semibold text-slate-100">@(medio.PermiteDescuento ? $"{medio.PorcentajeDescuentoMaximo:0.##}%" : "No")</p>
                                </div>
                                <div class="rounded-lg border border-slate-800 bg-slate-950/50 p-3">
                                    <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Recargo legacy</p>
                                    <p class="mt-1 font-semibold text-slate-100">@(medio.TieneRecargo ? $"{medio.PorcentajeRecargo:0.##}%" : "No")</p>
                                </div>
                            </div>
                        </div>
                    </summary>

                    <div class="space-y-5 p-5">
                        <div class="flex flex-col gap-3 xl:flex-row xl:items-center xl:justify-between">
                            <div>
                                <h3 class="text-base font-bold text-white">Metodo de pago</h3>
                                <p class="mt-1 text-sm text-slate-400">
                                    Los planes muestran cuotas especificas. No significan "hasta X cuotas".
                                </p>
                            </div>
                            <div class="flex flex-col gap-2 sm:flex-row">
                                @if (puedeEditar)
                                {
                                    <a asp-controller="ConfiguracionPago" asp-action="Edit" asp-route-id="@medio.Id" class="btn-erp-ghost w-full sm:w-auto no-underline">
                                        <span class="material-symbols-outlined text-[20px]">edit</span>
                                        Editar metodo
                                    </a>
                                }
                                <span class="inline-flex items-center gap-2 rounded-lg border border-slate-800 bg-slate-950 px-3 py-2 text-xs font-semibold text-slate-400">
                                    <span class="material-symbols-outlined text-[18px]">history</span>
                                    Inactivar conserva historial
                                </span>
                            </div>
                        </div>

                        @if (!permitePlanesGlobales)
                        {
                            <div class="rounded-lg border border-amber-500/20 bg-amber-500/10 p-4 text-sm font-semibold text-amber-200">
                                <span class="material-symbols-outlined align-middle text-[20px]">lock</span>
                                @(medio.TipoPago == TipoPago.CreditoPersonal
                                    ? "Credito Personal se administra en fase separada."
                                    : "Este medio es legacy y no administra planes globales nuevos.")
                            </div>
                        }

                        @if (puedeEditar && permiteTarjetas)
                        {
                            <details class="rounded-lg border border-dashed border-slate-700 bg-slate-950/40">
                                <summary class="flex cursor-pointer list-none items-center gap-2 p-4 text-sm font-black uppercase tracking-wider text-slate-300">
                                    <span class="material-symbols-outlined text-primary">add_card</span>
                                    Agregar tarjeta
                                </summary>
                                <form asp-controller="ConfiguracionPago" asp-action="CrearTarjetaGlobal" method="post" class="space-y-3 border-t border-slate-800 p-4">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="ConfiguracionPagoId" value="@medio.Id" />

                                    <div class="grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-4">
                                        <div class="flex flex-col gap-1.5">
                                            <label for="tarjeta-nombre-@medio.Id" class="text-xs font-bold uppercase tracking-wider text-slate-400">Nombre</label>
                                            <input id="tarjeta-nombre-@medio.Id" name="NombreTarjeta" maxlength="100" required
                                                   class="h-11 rounded-lg border border-slate-700 bg-slate-900 px-3 text-sm text-white focus:border-primary focus:ring-0"
                                                   placeholder="Ej: Visa" />
                                        </div>
                                        <div class="flex flex-col gap-1.5">
                                            <label for="tarjeta-tipo-@medio.Id" class="text-xs font-bold uppercase tracking-wider text-slate-400">Tipo</label>
                                            <select id="tarjeta-tipo-@medio.Id" name="TipoTarjeta" required
                                                    class="h-11 rounded-lg border border-slate-700 bg-slate-900 px-3 text-sm text-white focus:border-primary focus:ring-0">
                                                @if (medio.TipoPago == TipoPago.TarjetaCredito)
                                                {
                                                    <option value="@((int)TipoTarjeta.Credito)" selected>Credito</option>
                                                }
                                                else
                                                {
                                                    <option value="@((int)TipoTarjeta.Debito)" selected>Debito</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="flex items-end">
                                            <label class="inline-flex h-11 w-full items-center gap-2 rounded-lg border border-slate-700 bg-slate-900 px-3 text-sm font-semibold text-slate-300">
                                                <input name="Activa" type="checkbox" value="true" checked class="rounded border-slate-600 bg-slate-950 text-primary focus:ring-primary" />
                                                Activa
                                            </label>
                                        </div>
                                        <div class="flex flex-col gap-1.5">
                                            <label for="tarjeta-observaciones-@medio.Id" class="text-xs font-bold uppercase tracking-wider text-slate-400">Observaciones</label>
                                            <input id="tarjeta-observaciones-@medio.Id" name="Observaciones" maxlength="500"
                                                   class="h-11 rounded-lg border border-slate-700 bg-slate-900 px-3 text-sm text-white focus:border-primary focus:ring-0" />
                                        </div>
                                    </div>

                                    <button type="submit" class="btn-erp-primary w-full sm:w-auto">
                                        <span class="material-symbols-outlined text-[20px]">save</span>
                                        Crear tarjeta
                                    </button>
                                </form>
                            </details>
                        }

                        @if (tarjetas.Count == 0)
                        {
                            <section class="rounded-lg border border-slate-800 bg-slate-950/40 p-4">
                                <h3 class="text-sm font-bold text-white">Sin tarjetas configuradas</h3>
                                <p class="mt-1 text-sm text-slate-400">Este metodo no tiene marcas o entidades asociadas.</p>
                            </section>
                        }
                        else
                        {
                            <div class="space-y-4">
                                @foreach (var tarjeta in tarjetas)
                                {
                                    var planesTarjeta = medio.Planes
                                        .Where(p => p.ConfiguracionTarjetaId == tarjeta.Id)
                                        .OrderByDescending(p => p.Activo)
                                        .ThenBy(p => p.Orden)
                                        .ThenBy(p => p.CantidadCuotas)
                                        .ToList();
                                    var tienePlanesActivos = planesTarjeta.Any(p => p.Activo);

                                    <section class="rounded-lg border border-slate-800 bg-slate-950/40">
                                        <header class="flex flex-col gap-3 border-b border-slate-800 p-4 lg:flex-row lg:items-start lg:justify-between">
                                            <div class="space-y-2">
                                                <div class="flex flex-wrap items-center gap-2">
                                                    <span class="material-symbols-outlined text-slate-400">credit_card</span>
                                                    <h3 class="text-lg font-black text-white">@tarjeta.Nombre</h3>
                                                    <span class="rounded-full border border-slate-700 px-2.5 py-1 text-xs font-bold text-slate-300">@tarjeta.TipoTarjeta</span>
                                                    <span class="rounded-full border px-2.5 py-1 text-xs font-bold @(tarjeta.Activa ? "border-emerald-500/30 bg-emerald-500/10 text-emerald-300" : "border-amber-500/30 bg-amber-500/10 text-amber-300")">
                                                        @(tarjeta.Activa ? "Activa" : "Inactiva")
                                                    </span>
                                                </div>
                                                <p class="text-sm text-slate-400">@(tarjeta.Observaciones ?? "Sin observaciones.")</p>
                                                @if (!tienePlanesActivos)
                                                {
                                                    <p class="rounded-lg border border-amber-500/20 bg-amber-500/10 p-3 text-sm font-semibold text-amber-200">
                                                        Sin planes activos configurados. Esta tarjeta no deberia ofrecer cuotas en Nueva Venta hasta configurar al menos un plan.
                                                    </p>
                                                }
                                            </div>

                                            @if (puedeEditar)
                                            {
                                                <div class="flex flex-col gap-2 sm:flex-row">
                                                    <a href="#editar-tarjeta-@tarjeta.Id" class="btn-erp-ghost w-full sm:w-auto no-underline">
                                                        <span class="material-symbols-outlined text-[20px]">edit</span>
                                                        Editar tarjeta
                                                    </a>
                                                    <form asp-controller="ConfiguracionPago" asp-action="CambiarEstadoTarjetaGlobal" asp-route-id="@tarjeta.Id" method="post">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="activa" value="@(!tarjeta.Activa)" />
                                                        <button type="submit" class="btn-erp-ghost w-full sm:w-auto">
                                                            <span class="material-symbols-outlined text-[20px]">@(tarjeta.Activa ? "toggle_off" : "toggle_on")</span>
                                                            @(tarjeta.Activa ? "Inactivar" : "Reactivar")
                                                        </button>
                                                    </form>
                                                </div>
                                            }
                                        </header>

                                        <div class="space-y-4 p-4">
                                            <div>
                                                <h4 class="text-sm font-bold text-white">Planes activos e inactivos</h4>
                                                <p class="mt-1 text-xs leading-relaxed text-slate-500">Ajuste % firmado: negativo = descuento, positivo = recargo, 0 = sin ajuste.</p>
                                            </div>

                                            @if (planesTarjeta.Count == 0)
                                            {
                                                <p class="rounded-lg border border-slate-800 bg-slate-900/60 p-3 text-sm text-slate-400">Sin planes configurados para esta tarjeta.</p>
                                            }
                                            else
                                            {
                                                <div class="grid grid-cols-1 gap-3 xl:grid-cols-2">
                                                    @foreach (var plan in planesTarjeta)
                                                    {
                                                        <details class="rounded-lg border border-slate-800 bg-slate-900/70">
                                                            <summary class="flex cursor-pointer list-none flex-col gap-3 p-4 sm:flex-row sm:items-center sm:justify-between">
                                                                <span class="flex flex-wrap items-center gap-2">
                                                                    <span class="font-semibold text-slate-100">@plan.CantidadCuotas cuota@(plan.CantidadCuotas == 1 ? "" : "s")</span>
                                                                    <span class="rounded-full border px-2.5 py-1 text-xs font-bold @AjusteClasses(plan.AjustePorcentaje)">
                                                                        @AjusteFirmado(plan.AjustePorcentaje) @AjusteModo(plan.AjustePorcentaje)
                                                                    </span>
                                                                    <span class="rounded-full px-2.5 py-1 text-xs font-bold @(plan.Activo ? "bg-emerald-500/10 text-emerald-300" : "bg-amber-500/10 text-amber-300")">
                                                                        @(plan.Activo ? "Activo" : "Inactivo")
                                                                    </span>
                                                                </span>
                                                                <span class="text-xs font-semibold text-slate-500">@(plan.Etiqueta ?? plan.Observaciones ?? $"Orden {plan.Orden}")</span>
                                                            </summary>

                                                            @if (puedeEditar && permitePlanesGlobales)
                                                            {
                                                                <div class="space-y-3 border-t border-slate-800 p-4">
                                                                    <form asp-controller="ConfiguracionPago" asp-action="EditarPlanGlobal" asp-route-id="@plan.Id" method="post" class="space-y-3">
                                                                        @Html.AntiForgeryToken()
                                                                        <input type="hidden" name="ConfiguracionPagoId" value="@medio.Id" />
                                                                        <input type="hidden" name="ConfiguracionTarjetaId" value="@tarjeta.Id" />
                                                                        <input type="hidden" name="TipoAjuste" value="@plan.TipoAjuste" />

                                                                        <div class="grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-5">
                                                                            <div class="flex flex-col gap-1.5">
                                                                                <label class="text-xs font-bold uppercase tracking-wider text-slate-400">Cuotas</label>
                                                                                <input name="CantidadCuotas" type="number" min="1" value="@plan.CantidadCuotas" required class="h-11 rounded-lg border border-slate-700 bg-slate-950 px-3 text-sm text-white focus:border-primary focus:ring-0" />
                                                                            </div>
                                                                            <div class="flex flex-col gap-1.5">
                                                                                <label class="text-xs font-bold uppercase tracking-wider text-slate-400">Ajuste %</label>
                                                                                <input name="AjustePorcentaje" type="number" step="0.0001" min="-100.0000" max="999.9999" value="@plan.AjustePorcentaje.ToString(CultureInfo.InvariantCulture)" required class="h-11 rounded-lg border border-slate-700 bg-slate-950 px-3 text-sm text-white focus:border-primary focus:ring-0" />
                                                                            </div>
                                                                            <div class="flex flex-col gap-1.5">
                                                                                <label class="text-xs font-bold uppercase tracking-wider text-slate-400">Orden</label>
                                                                                <input name="Orden" type="number" value="@plan.Orden" class="h-11 rounded-lg border border-slate-700 bg-slate-950 px-3 text-sm text-white focus:border-primary focus:ring-0" />
                                                                            </div>
                                                                            <div class="flex items-end">
                                                                                <label class="inline-flex h-11 w-full items-center gap-2 rounded-lg border border-slate-700 bg-slate-950 px-3 text-sm font-semibold text-slate-300">
                                                                                    <input name="Activo" type="checkbox" value="true" checked="@plan.Activo" class="rounded border-slate-600 bg-slate-950 text-primary focus:ring-primary" />
                                                                                    Activo
                                                                                </label>
                                                                            </div>
                                                                            <div class="flex flex-col gap-1.5">
                                                                                <label class="text-xs font-bold uppercase tracking-wider text-slate-400">Etiqueta</label>
                                                                                <input name="Etiqueta" maxlength="100" value="@plan.Etiqueta" class="h-11 rounded-lg border border-slate-700 bg-slate-950 px-3 text-sm text-white focus:border-primary focus:ring-0" />
                                                                            </div>
