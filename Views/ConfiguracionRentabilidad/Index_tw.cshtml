@model ConfiguracionRentabilidadViewModel
@{
    ViewData["Title"] = "Configuracion de Rentabilidad";
    var puedeEditar = User.TienePermiso("configuracion", "update");
}

<div class="space-y-8">
    <section class="card-erp-panel-padded">
        <header class="flex flex-col gap-6 xl:flex-row xl:items-start xl:justify-between">
            <div class="max-w-3xl space-y-4">
                <nav aria-label="Breadcrumb" class="flex text-sm font-medium text-slate-400">
                    <ol class="inline-flex flex-wrap items-center gap-y-1">
                        <li><a asp-controller="Home" asp-action="Index" class="hover:text-primary no-underline">Inicio</a></li>
                        <li><span class="mx-2 text-slate-400">/</span></li>
                        <li><a asp-controller="Reporte" asp-action="Margenes" class="hover:text-primary no-underline">Margenes</a></li>
                        <li><span class="mx-2 text-slate-400">/</span></li>
                        <li class="text-slate-100">Configuracion</li>
                    </ol>
                </nav>
                <div class="space-y-3">
                    <span class="badge-erp badge-erp-primary">
                        <span class="material-symbols-outlined text-sm">tune</span>
                        Rentabilidad
                    </span>
                    <div class="space-y-2">
                        <h1 class="text-3xl font-black tracking-tight text-white sm:text-4xl">Configurar umbrales de margen</h1>
                        <p class="max-w-2xl text-sm leading-relaxed text-slate-400 sm:text-base">
                            Ajusta los limites globales que usa el reporte de margenes para clasificar productos con margen bajo y alto.
                        </p>
                    </div>
                </div>
            </div>

            <div class="flex w-full flex-col gap-3 sm:flex-row xl:w-auto xl:justify-end">
                <a asp-controller="Reporte" asp-action="Margenes" class="btn-erp-ghost w-full sm:w-auto sm:py-2.5 no-underline">
                    <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                    Volver
                </a>
            </div>
        </header>
    </section>

    @if (TempData["Success"] != null)
    {
        <div class="toast-msg flex items-center gap-3 rounded-xl border border-emerald-500/20 bg-emerald-500/10 p-4 text-sm font-semibold text-emerald-400" role="status">
            <span class="material-symbols-outlined">check_circle</span>
            @TempData["Success"]
        </div>
    }

    @if (!puedeEditar)
    {
        <div class="rounded-xl border border-amber-500/20 bg-amber-500/10 p-4 text-sm font-semibold text-amber-300">
            <span class="material-symbols-outlined text-base align-middle mr-1">lock</span>
            Tenes permiso de lectura. Para editar estos umbrales necesitas configuracion:update.
        </div>
    }

    <form asp-action="Index" asp-controller="ConfiguracionRentabilidad" method="post" class="space-y-8">
        <div asp-validation-summary="All" class="rounded-xl border border-rose-500/20 bg-rose-500/10 p-4 text-sm font-semibold text-rose-400"></div>

        <section class="card-erp-panel-padded">
            <div class="mb-6 flex items-center gap-2 border-b border-slate-800 pb-3">
                <span class="material-symbols-outlined text-primary">monitoring</span>
                <h2 class="text-xl font-bold text-white">Umbrales globales</h2>
            </div>

            <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                <div class="flex flex-col gap-1.5">
                    <label asp-for="MargenBajoMax" class="text-sm font-semibold text-slate-300"></label>
                    <div class="relative">
                        <input asp-for="MargenBajoMax" type="number" step="0.01" min="0" max="100" readonly="@(!puedeEditar)"
                               class="h-12 w-full rounded-lg border-2 border-slate-700 bg-slate-800 px-4 pr-10 text-white focus:border-primary focus:ring-0" />
                        <span class="pointer-events-none absolute inset-y-0 right-4 flex items-center text-sm font-bold text-slate-400">%</span>
                    </div>
                    <span asp-validation-for="MargenBajoMax" class="text-xs text-red-500"></span>
                    <p class="text-xs text-slate-500">Los productos por debajo de este valor se consideran margen bajo.</p>
                </div>

                <div class="flex flex-col gap-1.5">
                    <label asp-for="MargenAltoMin" class="text-sm font-semibold text-slate-300"></label>
                    <div class="relative">
                        <input asp-for="MargenAltoMin" type="number" step="0.01" min="0" max="100" readonly="@(!puedeEditar)"
                               class="h-12 w-full rounded-lg border-2 border-slate-700 bg-slate-800 px-4 pr-10 text-white focus:border-primary focus:ring-0" />
                        <span class="pointer-events-none absolute inset-y-0 right-4 flex items-center text-sm font-bold text-slate-400">%</span>
                    </div>
                    <span asp-validation-for="MargenAltoMin" class="text-xs text-red-500"></span>
                    <p class="text-xs text-slate-500">Los productos desde este valor se consideran margen alto.</p>
                </div>
            </div>
        </section>

        <div class="flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
            <a asp-controller="Reporte" asp-action="Margenes" class="btn-erp-ghost w-full sm:w-auto sm:py-2.5 no-underline">Cancelar</a>
            @if (puedeEditar)
            {
                <button type="submit" class="btn-erp-primary w-full sm:w-auto sm:py-2.5">
                    <span class="material-symbols-outlined text-[20px]">save</span>
                    Guardar umbrales
                </button>
            }
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
