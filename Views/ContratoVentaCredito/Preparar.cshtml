@{
    var ventaId = (int)ViewBag.VentaId;
    var contratoGenerado = (bool)ViewBag.ContratoGenerado;
    ViewData["Title"] = contratoGenerado ? "Contrato generado" : "Generar contrato";
}

<div class="fixed inset-0 z-[80] overflow-hidden bg-slate-950/80 backdrop-blur-sm"
     data-contrato-panel
     data-contrato-generado-inicial="@contratoGenerado.ToString().ToLowerInvariant()">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(59,130,246,0.12),transparent_38%),radial-gradient(circle_at_bottom_right,rgba(16,185,129,0.10),transparent_34%)]"></div>

    <aside class="absolute right-0 top-0 flex h-full w-full max-w-2xl flex-col border-l border-slate-800 bg-slate-950 text-slate-100 shadow-2xl shadow-black/50">
        <header class="shrink-0 border-b border-slate-800 bg-slate-950/95 px-6 py-5">
            <div class="flex items-start justify-between gap-4">
                <div class="min-w-0">
                    <p class="text-[10px] font-black uppercase tracking-[0.22em] text-slate-500">Contrato de venta</p>
                    <h1 class="mt-1 text-2xl font-black tracking-tight @(contratoGenerado ? "hidden" : "")"
                        data-contrato-title-pendiente>Generar contrato</h1>
                    <h1 class="mt-1 text-2xl font-black tracking-tight text-emerald-300 @(contratoGenerado ? "" : "hidden")"
                        data-contrato-title-generado>Contrato generado</h1>
                    <p class="mt-1 text-sm text-slate-400">Venta #@ventaId · Crédito Personal</p>
                </div>
                <a asp-controller="Venta" asp-action="Details" asp-route-id="@ventaId"
                   class="inline-flex size-10 shrink-0 items-center justify-center rounded-xl border border-slate-700 bg-slate-900 text-slate-400 transition-colors hover:border-slate-600 hover:text-white no-underline"
                   aria-label="Cerrar panel">
                    <span class="material-symbols-outlined text-[20px]">close</span>
                </a>
            </div>
        </header>

        <div class="min-h-0 flex-1 overflow-y-auto px-6 py-6">
            @if (TempData["Error"] is string errorMsg)
            {
                <div class="mb-4 rounded-xl border border-red-500/30 bg-red-500/10 p-4 text-sm text-red-300">
                    <span class="material-symbols-outlined align-middle text-sm">error</span>
                    @errorMsg
                </div>
            }

            <div id="contrato-feedback"
                 class="hidden mb-4 rounded-xl border border-red-500/30 bg-red-500/10 p-4 text-sm font-semibold text-red-300"
                 role="alert"></div>

            <section class="rounded-2xl border border-slate-800 bg-slate-900/70 p-5 shadow-xl">
                <div class="grid gap-3 sm:grid-cols-2">
                    <div class="rounded-xl border border-slate-800 bg-slate-950/60 p-4">
                        <p class="text-[10px] font-black uppercase tracking-[0.18em] text-slate-500">Paso 1</p>
                        <div class="mt-3 flex items-center gap-3">
                            <span class="flex size-10 items-center justify-center rounded-xl border border-amber-500/30 bg-amber-500/10 text-amber-300"
                                  data-contrato-step-pendiente>
                                <span class="material-symbols-outlined text-[20px]">contract</span>
                            </span>
                            <div>
                                <p class="text-sm font-bold text-white">Generar PDF</p>
                                <p class="text-xs text-slate-500">Contrato y pagaré</p>
                            </div>
                        </div>
                    </div>
                    <div class="rounded-xl border border-slate-800 bg-slate-950/60 p-4">
                        <p class="text-[10px] font-black uppercase tracking-[0.18em] text-slate-500">Paso 2</p>
                        <div class="mt-3 flex items-center gap-3">
                            <span class="flex size-10 items-center justify-center rounded-xl border border-emerald-500/30 bg-emerald-500/10 text-emerald-300">
                                <span class="material-symbols-outlined text-[20px]">verified</span>
                            </span>
                            <div>
                                <p class="text-sm font-bold text-white">Confirmar operación</p>
                                <p class="text-xs text-slate-500">Disponible con contrato</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="mt-5 rounded-2xl border border-amber-500/25 bg-amber-500/10 p-5 @(contratoGenerado ? "hidden" : "")"
                     data-contrato-state-pendiente>
                <div class="flex items-start gap-4">
                    <span class="flex size-12 shrink-0 items-center justify-center rounded-2xl border border-amber-500/30 bg-amber-500/15 text-amber-300">
                        <span class="material-symbols-outlined text-[26px]">priority_high</span>
                    </span>
                    <div class="min-w-0">
                        <p class="text-[11px] font-black uppercase tracking-[0.18em] text-amber-300">Requisito obligatorio</p>
                        <h2 class="mt-1 text-lg font-black text-white">Requisito obligatorio antes de continuar</h2>
                        <p class="mt-2 text-sm leading-6 text-amber-100/75">
                            Generá el contrato de venta y dejalo listo para imprimir. La operación no se puede confirmar hasta completar este requisito contractual.
                        </p>
                    </div>
                </div>
            </section>

            <section class="mt-5 rounded-2xl border border-emerald-500/30 bg-emerald-500/10 p-5 @(contratoGenerado ? "" : "hidden")"
                     data-contrato-state-generado>
                <div class="flex items-start gap-4">
                    <span class="flex size-12 shrink-0 items-center justify-center rounded-2xl border border-emerald-500/30 bg-emerald-500/15 text-emerald-300">
                        <span class="material-symbols-outlined text-[28px]">check_circle</span>
                    </span>
                    <div class="min-w-0">
                        <p class="text-[11px] font-black uppercase tracking-[0.18em] text-emerald-300">Documentación lista</p>
                        <h2 class="mt-1 text-lg font-black text-emerald-100">Documentación lista</h2>
                        <p class="mt-2 text-sm leading-6 text-emerald-100/75">
                            El contrato y el pagaré fueron generados. Revisá o imprimí el PDF antes de confirmar la operación.
                        </p>
                        <a asp-controller="ContratoVentaCredito" asp-action="Ver" asp-route-ventaId="@ventaId"
                           target="_blank" rel="noopener"
                           class="mt-4 inline-flex items-center gap-2 rounded-xl border border-emerald-500/30 bg-emerald-500/15 px-4 py-2.5 text-sm font-bold text-emerald-200 transition-colors hover:bg-emerald-500/25 no-underline"
                           data-contrato-ver-link>
                            <span class="material-symbols-outlined text-[20px]">print</span>
                            Ver / imprimir contrato
                        </a>
                    </div>
                </div>
            </section>
        </div>

        <footer class="shrink-0 border-t border-slate-800 bg-slate-950/95 px-6 py-5">
            <div class="flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
                <a asp-controller="Venta" asp-action="Details" asp-route-id="@ventaId"
                   class="inline-flex w-full items-center justify-center gap-2 rounded-xl border border-slate-700 bg-slate-900 px-5 py-3 text-sm font-bold text-slate-300 transition-colors hover:border-slate-600 hover:text-white sm:w-auto no-underline">
                    <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                    Volver a la venta
                </a>

                <form asp-controller="ContratoVentaCredito" asp-action="Generar" method="post"
                      class="w-full sm:w-auto @(contratoGenerado ? "hidden" : "")"
                      data-contrato-generar-form>
                    <input type="hidden" name="ventaId" value="@ventaId" />
                    <button type="submit"
                            class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-amber-500 px-5 py-3 text-sm font-black text-slate-950 shadow-lg shadow-amber-500/20 transition-colors hover:bg-amber-400 sm:w-auto"
                            data-contrato-generar-btn>
                        <span class="material-symbols-outlined text-[20px]">picture_as_pdf</span>
                        Generar e imprimir contrato
                    </button>
                </form>

                <form asp-controller="Venta" asp-action="Confirmar" method="post"
                      class="w-full sm:w-auto @(contratoGenerado ? "" : "hidden")"
                      data-contrato-confirmar-form>
                    <input type="hidden" name="id" value="@ventaId" />
                    <button type="submit"
                            class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-primary px-5 py-3 text-sm font-black text-white shadow-lg shadow-primary/20 transition-colors hover:bg-primary/90 sm:w-auto"
                            data-contrato-confirmar-btn>
                        <span class="material-symbols-outlined text-[20px]">check_circle</span>
                        Confirmar operación
                    </button>
                </form>
            </div>
        </footer>
    </aside>
</div>

@section Scripts {
    <script src="~/js/contrato-venta-credito-preparar.js" asp-append-version="true"></script>
}
