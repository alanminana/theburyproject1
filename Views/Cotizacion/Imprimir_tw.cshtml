@using TheBuryProject.Models.Enums
@using TheBuryProject.Services.Models
@model CotizacionResultado
@{
    Layout = null;
    var cliente = Model.ClienteNombre ?? Model.NombreClienteLibre ?? "Cliente mostrador";
    var titulo = $"Cotizacion {Model.Numero}";
    var totalMostrar = Model.TotalSeleccionado ?? Model.TotalBase;
}
<!doctype html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@titulo</title>
    <style>
        :root {
            color: #111827;
            background: #f3f4f6;
            font-family: Arial, Helvetica, sans-serif;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            padding: 24px;
            background: #f3f4f6;
        }

        .page {
            width: min(960px, 100%);
            margin: 0 auto;
            background: #ffffff;
            border: 1px solid #d1d5db;
            padding: 32px;
        }

        .actions {
            width: min(960px, 100%);
            margin: 0 auto 16px;
            display: flex;
            justify-content: flex-end;
            gap: 8px;
        }

        .button {
            border: 1px solid #111827;
            background: #111827;
            color: #ffffff;
            padding: 10px 14px;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
        }

        .button-secondary {
            background: #ffffff;
            color: #111827;
        }

        .header {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 24px;
            border-bottom: 2px solid #111827;
            padding-bottom: 20px;
        }

        .brand {
            font-size: 24px;
            font-weight: 800;
        }

        .muted {
            color: #4b5563;
            font-size: 12px;
        }

        .quote-box {
            min-width: 220px;
            border: 2px solid #111827;
            text-align: center;
        }

        .quote-type {
            border-bottom: 2px solid #111827;
            padding: 8px;
            font-size: 20px;
            font-weight: 800;
            text-transform: uppercase;
        }

        .quote-meta {
            padding: 12px;
            font-size: 13px;
            line-height: 1.7;
        }

        .badge {
            display: inline-block;
            border: 1px solid #d97706;
            color: #d97706;
            padding: 4px 10px;
            margin-top: 8px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
        }

        .badge-vencida {
            border-color: #dc2626;
            color: #dc2626;
        }

        .badge-convertida {
            border-color: #059669;
            color: #059669;
        }

        .badge-cancelada {
            border-color: #6b7280;
            color: #6b7280;
        }

        .section-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-top: 24px;
        }

        .section {
            border: 1px solid #d1d5db;
            padding: 16px;
        }

        .section h2 {
            margin: 0 0 12px;
            font-size: 13px;
            text-transform: uppercase;
        }

        .field {
            display: grid;
            grid-template-columns: 130px 1fr;
            gap: 10px;
            margin: 7px 0;
            font-size: 13px;
        }

        .field span:first-child {
            color: #4b5563;
            font-weight: 700;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 24px;
            font-size: 13px;
        }

        th {
            background: #f3f4f6;
            border: 1px solid #d1d5db;
            padding: 9px;
            text-align: left;
            text-transform: uppercase;
            font-size: 11px;
        }

        td {
            border: 1px solid #d1d5db;
            padding: 9px;
            vertical-align: top;
        }

        .number {
            text-align: right;
            white-space: nowrap;
        }

        .row-selected {
            background: #f0fdf4;
        }

        .totals {
            margin-top: 24px;
            margin-left: auto;
            width: min(360px, 100%);
            border: 1px solid #111827;
        }

        .total-row {
            display: grid;
            grid-template-columns: 1fr auto;
            border-bottom: 1px solid #d1d5db;
            padding: 10px 12px;
            font-size: 14px;
        }

        .total-row:last-child {
            border-bottom: 0;
            background: #111827;
            color: #ffffff;
            font-size: 18px;
            font-weight: 800;
        }

        .notes {
            margin-top: 24px;
            border-top: 1px solid #d1d5db;
            padding-top: 14px;
            font-size: 12px;
            color: #4b5563;
        }

        .disclaimer {
            margin-top: 24px;
            border: 1px dashed #d1d5db;
            padding: 12px 16px;
            font-size: 11px;
            color: #6b7280;
            text-align: center;
        }

        @@media (max-width: 720px) {
            body {
                padding: 12px;
            }

            .page {
                padding: 20px;
            }

            .header,
            .section-grid {
                grid-template-columns: 1fr;
            }

            .quote-box {
                min-width: 0;
            }
        }

        @@media print {
            :root,
            body {
                background: #ffffff;
            }

            body {
                padding: 0;
            }

            .actions {
                display: none;
            }

            .page {
                width: 100%;
                border: 0;
                padding: 0;
            }
        }
    </style>
</head>
<body>
    <div class="actions">
        <button type="button" class="button button-secondary" onclick="history.back()">Volver</button>
        <button type="button" class="button" onclick="window.print()">Imprimir</button>
    </div>

    <main class="page">
        <header class="header">
            <div>
                <div class="brand">The Bury Project</div>
                <p class="muted">Cotizacion de venta</p>
                @switch (Model.Estado)
                {
                    case EstadoCotizacion.Emitida:
                        <span class="badge">Emitida</span>
                        break;
                    case EstadoCotizacion.Vencida:
                        <span class="badge badge-vencida">Vencida</span>
                        break;
                    case EstadoCotizacion.ConvertidaAVenta:
                        <span class="badge badge-convertida">Convertida a venta</span>
                        break;
                    case EstadoCotizacion.Cancelada:
                        <span class="badge badge-cancelada">Cancelada</span>
                        break;
                    default:
                        <span class="badge">@Model.Estado</span>
                        break;
                }
            </div>
            <div class="quote-box">
                <div class="quote-type">Cotizacion</div>
                <div class="quote-meta">
                    <strong>Nro.</strong> @Model.Numero<br />
                    <strong>Fecha</strong> @Model.Fecha.ToLocalTime().ToString("dd/MM/yyyy")<br />
                    @if (Model.FechaVencimiento.HasValue)
                    {
                        <strong>Vence</strong><span> @Model.FechaVencimiento.Value.ToLocalTime().ToString("dd/MM/yyyy")</span>
                    }
                </div>
            </div>
        </header>

        <section class="section-grid">
            <div class="section">
                <h2>Cliente</h2>
                <div class="field"><span>Nombre</span><span>@cliente</span></div>
                @if (!string.IsNullOrWhiteSpace(Model.TelefonoClienteLibre))
                {
                    <div class="field"><span>Telefono</span><span>@Model.TelefonoClienteLibre</span></div>
                }
            </div>

            <div class="section">
                <h2>Pago seleccionado</h2>
                @if (Model.MedioPagoSeleccionado.HasValue)
                {
                    <div class="field"><span>Medio</span><span>@Model.MedioPagoSeleccionado</span></div>
                    @if (!string.IsNullOrWhiteSpace(Model.PlanSeleccionado))
                    {
                        <div class="field"><span>Plan</span><span>@Model.PlanSeleccionado</span></div>
                    }
                    @if (Model.CantidadCuotasSeleccionada.HasValue)
                    {
                        <div class="field"><span>Cuotas</span><span>@Model.CantidadCuotasSeleccionada</span></div>
                    }
                    @if (Model.ValorCuotaSeleccionada.HasValue)
                    {
                        <div class="field"><span>Valor cuota</span><span>@Model.ValorCuotaSeleccionada.Value.ToString("C2")</span></div>
                    }
                }
                else
                {
                    <p class="muted">Sin opcion de pago seleccionada.</p>
                }
            </div>
        </section>

        <table>
            <thead>
                <tr>
                    <th>Producto</th>
                    <th>Codigo</th>
                    <th class="number">Cantidad</th>
                    <th class="number">Precio unit.</th>
                    @if (Model.Detalles.Any(d => d.DescuentoPorcentajeSnapshot.HasValue || d.DescuentoImporteSnapshot.HasValue))
                    {
                        <th class="number">Descuento</th>
                    }
                    <th class="number">Subtotal</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var tieneDescuento = Model.Detalles.Any(d => d.DescuentoPorcentajeSnapshot.HasValue || d.DescuentoImporteSnapshot.HasValue);
                }
                @foreach (var item in Model.Detalles)
                {
                    <tr>
                        <td>@item.NombreProductoSnapshot</td>
                        <td class="muted">@item.CodigoProductoSnapshot</td>
                        <td class="number">@item.Cantidad</td>
                        <td class="number">@item.PrecioUnitarioSnapshot.ToString("C2")</td>
                        @if (tieneDescuento)
                        {
                            <td class="number">
                                @if (item.DescuentoPorcentajeSnapshot.HasValue)
                                {
                                    @($"{item.DescuentoPorcentajeSnapshot.Value:0.##}%")
                                }
                                else if (item.DescuentoImporteSnapshot.HasValue)
                                {
                                    @item.DescuentoImporteSnapshot.Value.ToString("C2")
                                }
                                else
                                {
                                    @("-")
                                }
                            </td>
                        }
                        <td class="number">@item.Subtotal.ToString("C2")</td>
                    </tr>
                }
            </tbody>
        </table>

        @if (Model.OpcionesPago.Any(o => o.Seleccionado))
        {
            var seleccionada = Model.OpcionesPago.First(o => o.Seleccionado);
            if (seleccionada.RecargoPorcentaje != 0 || seleccionada.DescuentoPorcentaje != 0 || seleccionada.InteresPorcentaje != 0)
            {
                <section style="margin-top:24px;border:1px solid #d1d5db;padding:16px;">
                    <h2 style="margin:0 0 12px;font-size:13px;text-transform:uppercase;">Ajuste por plan de pago</h2>
                    <table style="margin-top:0;">
                        <thead>
                            <tr>
                                <th>Medio / Plan</th>
                                @if (seleccionada.RecargoPorcentaje != 0)
                                {
                                    <th class="number">Recargo</th>
                                }
                                @if (seleccionada.DescuentoPorcentaje != 0)
                                {
                                    <th class="number">Descuento</th>
                                }
                                @if (seleccionada.InteresPorcentaje != 0)
                                {
                                    <th class="number">Interes</th>
                                }
                                <th class="number">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>@seleccionada.NombreMedioPago @seleccionada.Plan</td>
                                @if (seleccionada.RecargoPorcentaje != 0)
                                {
                                    <td class="number">@seleccionada.RecargoPorcentaje.ToString("0.##")%</td>
                                }
                                @if (seleccionada.DescuentoPorcentaje != 0)
                                {
                                    <td class="number">@seleccionada.DescuentoPorcentaje.ToString("0.##")%</td>
                                }
                                @if (seleccionada.InteresPorcentaje != 0)
                                {
                                    <td class="number">@seleccionada.InteresPorcentaje.ToString("0.##")%</td>
                                }
                                <td class="number">@seleccionada.Total.ToString("C2")</td>
                            </tr>
                        </tbody>
                    </table>
                </section>
            }
        }

        <section class="totals">
            <div class="total-row"><span>Subtotal</span><strong>@Model.Subtotal.ToString("C2")</strong></div>
            @if (Model.DescuentoTotal != 0)
            {
                <div class="total-row"><span>Descuento total</span><strong>@Model.DescuentoTotal.ToString("C2")</strong></div>
            }
            <div class="total-row"><span>Total base</span><strong>@Model.TotalBase.ToString("C2")</strong></div>
            @if (Model.TotalSeleccionado.HasValue && Model.TotalSeleccionado != Model.TotalBase)
            {
                <div class="total-row"><span>Total c/ plan</span><strong>@Model.TotalSeleccionado.Value.ToString("C2")</strong></div>
            }
            <div class="total-row"><span>Total</span><strong>@totalMostrar.ToString("C2")</strong></div>
        </section>

        @if (!string.IsNullOrWhiteSpace(Model.Observaciones))
        {
            <section class="notes">
                <strong>Observaciones:</strong> @Model.Observaciones
            </section>
        }

        <div class="disclaimer">
            Cotizacion sujeta a disponibilidad y vigencia de precios. Para descargar un PDF real, usar el boton <strong>Descargar PDF</strong> desde la pantalla de detalles.
        </div>
    </main>
</body>
</html>
