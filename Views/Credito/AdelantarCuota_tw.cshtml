@model PagarCuotaViewModel
@{
    ViewData["Title"] = "Adelantar Cuota";
    var returnUrl = ViewData["ReturnUrl"] as string;
    var montoPagadoInvariant = Model.MontoPagado.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
    var volverHref = !string.IsNullOrWhiteSpace(returnUrl)
        ? returnUrl
        : Url.Action("Details", "Credito", new { id = Model.CreditoId }) ?? $"/Credito/Details/{Model.CreditoId}";
}

@section Styles {
    <partial name="_CreditoModuleStyles" />
}

<div class="space-y-8">
    <section class="card-erp-panel-padded">
        <header class="flex flex-col gap-6 xl:flex-row xl:items-start xl:justify-between">
            <div class="max-w-3xl space-y-4">
                <nav aria-label="Breadcrumb" class="flex text-sm font-medium text-slate-400">
                    <ol class="inline-flex flex-wrap items-center gap-y-1">
                        <li><a asp-controller="Credito" asp-action="Index" class="hover:text-primary no-underline">Créditos</a></li>
                        <li><span class="mx-2 text-slate-400">/</span></li>
                        <li><a asp-controller="Credito" asp-action="Details" asp-route-id="@Model.CreditoId" class="hover:text-primary no-underline">Detalle</a></li>
                        <li><span class="mx-2 text-slate-400">/</span></li>
                        <li class="text-slate-100">Adelantar cuota</li>
                    </ol>
                </nav>

                <div class="space-y-3">
                    <span class="badge-erp badge-erp-warning">
                        <span class="material-symbols-outlined text-sm">fast_forward</span>
                        Adelanto de cuota
                    </span>
                    <div class="space-y-2">
                        <h1 class="text-3xl font-black tracking-tight text-white sm:text-4xl">Adelantar cuota #@Model.NumeroCuota</h1>
                        <p class="max-w-2xl text-sm leading-relaxed text-slate-400 sm:text-base">
                            Registrá el pago anticipado de la última cuota pendiente del crédito de <span class="font-semibold text-slate-200">@Model.ClienteNombre</span>. Esto reduce el plazo total del crédito.
                        </p>
                    </div>
                    <div class="flex flex-wrap items-center gap-3 text-sm text-slate-400">
                        <span class="inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-950/40 px-3 py-1.5 font-semibold text-slate-300">
                            <span class="material-symbols-outlined text-sm">person</span>
                            @Model.ClienteNombre
                        </span>
                        <span class="inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-950/40 px-3 py-1.5 font-semibold text-slate-300">
                            <span class="material-symbols-outlined text-sm">receipt_long</span>
                            @Model.NumeroCreditoTexto
                        </span>
                    </div>
                </div>
            </div>

            <div data-credito-adelanto-header-actions class="flex w-full flex-col gap-3 sm:flex-row xl:w-auto xl:justify-end">
                <a href="@volverHref"
                   class="btn-erp-ghost w-full sm:w-auto sm:py-2.5 no-underline">
                    <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                    Volver al crédito
                </a>
            </div>
        </header>

        <div class="mt-6 grid grid-cols-2 gap-4 lg:grid-cols-4">
            <div class="rounded-xl border border-slate-800 bg-slate-950/40 px-4 py-4">
                <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-slate-400">Cuota a adelantar</p>
                <p class="mt-2 text-2xl font-black text-white">#@Model.NumeroCuota</p>
                <p class="mt-1 text-xs text-slate-400">última cuota pendiente</p>
            </div>
            <div class="rounded-xl border border-slate-800 bg-slate-950/40 px-4 py-4">
                <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-slate-400">Monto cuota</p>
                <p class="mt-2 text-2xl font-black text-amber-400">@Model.MontoCuota.ToString("C")</p>
                <p class="mt-1 text-xs text-slate-400">sin punitorio aplicado</p>
            </div>
            <div class="rounded-xl border border-slate-800 bg-slate-950/40 px-4 py-4">
                <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-slate-400">Vencimiento</p>
                <p class="mt-2 text-2xl font-black text-white">@Model.FechaVencimiento.ToString("dd/MM")</p>
                <p class="mt-1 text-xs text-slate-400">@Model.FechaVencimiento.ToString("yyyy")</p>
            </div>
            <div class="rounded-xl border border-amber-500/20 bg-amber-500/10 px-4 py-4">
                <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-amber-400">Efecto del adelanto</p>
                <p class="mt-2 text-sm font-black text-amber-400">Reduce plazo</p>
                <p class="mt-1 text-xs text-amber-500 text-amber-400">la cuota se elimina del plan</p>
            </div>
        </div>
    </section>

    <div class="grid grid-cols-1 gap-6 xl:grid-cols-[minmax(0,1fr)_320px]">
        <section class="card-erp-panel-padded">
            <div class="space-y-1">
                <h2 class="text-lg font-bold text-white">Detalle de la cuota a adelantar</h2>
                <p class="text-sm text-slate-400">El adelanto cancela la última cuota pendiente sin aplicar punitorio.</p>
            </div>

            <div class="mt-6 grid grid-cols-2 gap-4 text-sm">
                <div>
                    <p class="mb-1 text-xs font-medium uppercase tracking-wider text-slate-500">Cuota</p>
                    <p class="font-bold text-white">#@Model.NumeroCuota</p>
                </div>
                <div>
                    <p class="mb-1 text-xs font-medium uppercase tracking-wider text-slate-500">Vencimiento</p>
                    <p class="font-bold text-white">@Model.FechaVencimiento.ToString("dd/MM/yyyy")</p>
                </div>
                <div>
                    <p class="mb-1 text-xs font-medium uppercase tracking-wider text-slate-500">Monto cuota</p>
                    <p class="font-bold text-white">@Model.MontoCuota.ToString("C")</p>
                </div>
                <div>
                    <p class="mb-1 text-xs font-medium uppercase tracking-wider text-slate-500">Punitorio</p>
                    <p class="font-bold text-emerald-400">No aplica</p>
                </div>
                <div class="col-span-2 rounded-xl border border-amber-500/20 bg-amber-500/10 px-4 py-4">
                    <p class="mb-1 text-xs font-medium uppercase tracking-wider text-amber-400">Total a pagar</p>
                    <p class="text-2xl font-black text-amber-400">@Model.TotalAPagar.ToString("C")</p>
                </div>
            </div>
        </section>

        <aside class="space-y-4">
            <section class="card-erp-panel p-5">
                <h2 class="flex items-center gap-2 text-sm font-bold text-white">
                    <span class="material-symbols-outlined text-[18px] text-amber-500">fast_forward</span>
                    Resultado del adelanto
                </h2>
                <ul class="mt-4 space-y-2 text-xs text-slate-400">
                    <li class="flex items-start gap-2">
                        <span class="material-symbols-outlined mt-0.5 text-[16px] text-emerald-500">check_circle</span>
                        La cuota adelantada se cancela del plan de pagos.
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="material-symbols-outlined mt-0.5 text-[16px] text-amber-500">info</span>
                        El plazo total del crédito se reduce en una cuota.
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="material-symbols-outlined mt-0.5 text-[16px] text-primary">payments</span>
                        No se aplica punitorio al tratarse de un adelanto voluntario.
                    </li>
                </ul>
            </section>
        </aside>
    </div>

    <form id="adelanto-form"
          asp-action="AdelantarCuota"
          method="post"
          class="card-erp-panel-padded">
        @Html.AntiForgeryToken()

        <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
            <div>
                <h2 class="text-lg font-bold text-white">Datos del adelanto</h2>
                <p class="text-sm text-slate-400">Confirmá la fecha y el medio de pago antes de registrar el adelanto.</p>
            </div>
        </div>

        <div asp-validation-summary="ModelOnly"
             class="mt-5 mb-4 text-sm text-red-500 bg-red-500/10 border border-red-500/20 rounded-lg p-3 empty:hidden"></div>

        <input type="hidden" asp-for="CreditoId" />
        <input type="hidden" asp-for="CuotaId" />
        <input type="hidden" asp-for="NumeroCuota" />
        <input type="hidden" asp-for="MontoCuota" />
        <input type="hidden" asp-for="MontoPunitorio" />
        <input type="hidden" asp-for="TotalAPagar" />
        <input type="hidden" asp-for="MontoPagado" value="@montoPagadoInvariant" />
        <input type="hidden" asp-for="ClienteNombre" />
        <input type="hidden" asp-for="NumeroCreditoTexto" />
        <input type="hidden" asp-for="FechaVencimiento" />
        <input type="hidden" asp-for="EstaVencida" />
        <input type="hidden" asp-for="DiasAtraso" />
        @if (returnUrl != null)
        {
            <input type="hidden" name="returnUrl" value="@returnUrl" />
        }

        <div class="mt-6 grid grid-cols-1 gap-5 md:grid-cols-2">
            <div>
                <label asp-for="FechaPago" class="mb-1.5 block text-sm font-semibold text-slate-200">Fecha de pago</label>
                <input asp-for="FechaPago"
                       type="date"
                       class="credito-input" />
                <span asp-validation-for="FechaPago" class="mt-1 text-xs text-red-500"></span>
            </div>

            <div>
                <label asp-for="MedioPago" class="mb-1.5 block text-sm font-semibold text-slate-200">Medio de pago</label>
                <select asp-for="MedioPago"
                        class="credito-input">
                    <option value="Efectivo">Efectivo</option>
                    <option value="Transferencia">Transferencia</option>
                    <option value="Tarjeta Débito">Tarjeta Débito</option>
                    <option value="Tarjeta Crédito">Tarjeta Crédito</option>
                    <option value="Cheque">Cheque</option>
                </select>
                <span asp-validation-for="MedioPago" class="mt-1 text-xs text-red-500"></span>
            </div>

            <div>
                <label asp-for="ComprobantePago" class="mb-1.5 block text-sm font-semibold text-slate-200">
                    Nº comprobante <span class="font-normal text-slate-400">(opcional)</span>
                </label>
                <input asp-for="ComprobantePago"
                       class="credito-input"
                       placeholder="Ej: TRF-00123" />
                <span asp-validation-for="ComprobantePago" class="mt-1 text-xs text-red-500"></span>
            </div>

            <div>
                <label asp-for="Observaciones" class="mb-1.5 block text-sm font-semibold text-slate-200">
                    Observaciones <span class="font-normal text-slate-400">(opcional)</span>
                </label>
                <textarea asp-for="Observaciones"
                          rows="3"
                          class="credito-input"
                          placeholder="Notas sobre el adelanto..."></textarea>
                <span asp-validation-for="Observaciones" class="mt-1 text-xs text-red-500"></span>
            </div>
        </div>

        <div class="mt-6 border-t border-slate-800 pt-5">
            <div data-credito-adelanto-footer-actions class="flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
                <a href="@volverHref"
                   class="btn-erp-ghost w-full sm:w-auto sm:py-2.5 no-underline">
                    <span class="material-symbols-outlined text-[20px]">close</span>
                    Cancelar
                </a>
                <button type="submit"
                        class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-amber-500 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-amber-500/20 transition-colors hover:bg-amber-600 sm:w-auto sm:py-2.5">
                    <span class="material-symbols-outlined text-[20px]">fast_forward</span>
                    Registrar adelanto
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/shared-ui.js" asp-append-version="true"></script>
}
