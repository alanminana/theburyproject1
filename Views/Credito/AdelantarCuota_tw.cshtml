@model PagarCuotaViewModel
@{
    ViewData["Title"] = "Adelantar Cuota";
    var returnUrl = ViewData["ReturnUrl"] as string;
    var montoPagadoInvariant = Model.MontoPagado.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
    var volverHref = !string.IsNullOrWhiteSpace(returnUrl)
        ? returnUrl
        : Url.Action("Details", "Credito", new { id = Model.CreditoId }) ?? $"/Credito/Details/{Model.CreditoId}";
}

@section Styles {
    <partial name="_CreditoModuleStyles" />
}

<main class="shell" style="padding-top:1.5rem;padding-bottom:3rem;max-width:680px">
    <a href="@volverHref" class="inline-flex items-center gap-1.5 text-sm muted hover:text-white transition" style="text-decoration:none">
        <span class="material-symbols-outlined" style="font-size:18px">arrow_back</span>
        Volver al crédito
    </a>

    <div class="page-head" style="margin-top:.95rem">
        <div class="min-w-0">
            <h1 class="page-title" style="font-size:1.4rem">Adelantar cuota</h1>
            <p class="page-sub" style="margin-top:.3rem">
                Crédito <span class="mono">@Model.NumeroCreditoTexto</span> · @Model.ClienteNombre
            </p>
        </div>
    </div>

    <div class="alert alert-info" style="margin-top:1.25rem">
        <span class="material-symbols-outlined">info</span>
        <div>
            Se adelanta la <strong>última cuota pendiente</strong> del plan (cuota @Model.NumeroCuota).
            El capital se descuenta del saldo y el plazo total del crédito se reduce.
        </div>
    </div>

    <form id="adelanto-form"
          asp-action="AdelantarCuota"
          method="post"
          class="card card-pad"
          style="margin-top:1.25rem">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly"
             class="alert alert-bad empty:hidden"
             style="margin-bottom:1rem"
             role="alert"></div>

        <input type="hidden" asp-for="CreditoId" />
        <input type="hidden" asp-for="CuotaId" />
        <input type="hidden" asp-for="NumeroCuota" />
        <input type="hidden" asp-for="MontoCuota" />
        <input type="hidden" asp-for="MontoPunitorio" />
        <input type="hidden" asp-for="TotalAPagar" />
        <input type="hidden" asp-for="MontoPagado" value="@montoPagadoInvariant" />
        <input type="hidden" asp-for="ClienteNombre" />
        <input type="hidden" asp-for="NumeroCreditoTexto" />
        <input type="hidden" asp-for="FechaVencimiento" />
        <input type="hidden" asp-for="EstaVencida" />
        <input type="hidden" asp-for="DiasAtraso" />
        @if (returnUrl != null)
        {
            <input type="hidden" name="returnUrl" value="@returnUrl" />
        }

        <div class="result-card is-ok">
            <div class="flex items-center justify-between">
                <div>
                    <div class="result-label">Cuota a adelantar</div>
                    <div class="result-value" style="font-size:1.6rem">@Model.TotalAPagar.ToString("C")</div>
                </div>
                <div class="text-right">
                    <div class="chip chip-info">Cuota @Model.NumeroCuota</div>
                    <div class="text-xs muted-2 mt-1.5">Vence @Model.FechaVencimiento.ToString("dd/MM/yyyy")</div>
                </div>
            </div>
        </div>

        <dl class="kv mt-4">
            <div class="kv-row">
                <dt>Monto de la cuota</dt>
                <dd class="num">@Model.MontoCuota.ToString("C")</dd>
            </div>
            <div class="kv-row">
                <dt>Punitorio</dt>
                <dd class="num">$ 0,00</dd>
            </div>
            <div class="kv-row">
                <dt>Efecto del adelanto</dt>
                <dd>Reduce plazo</dd>
            </div>
        </dl>

        <div class="sec-head" style="margin-top:1.5rem">
            <div class="sec-num">$</div>
            <div>
                <div class="sec-title">Datos del pago</div>
                <div class="sec-sub">Cómo se registra el adelanto.</div>
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <div>
                <label asp-for="FechaPago" class="label">Fecha de pago <span class="req">*</span></label>
                <input asp-for="FechaPago"
                       type="date"
                       class="field" />
                <span asp-validation-for="FechaPago" class="err-text"></span>
            </div>
            <div>
                <label asp-for="MedioPago" class="label">Medio de pago <span class="req">*</span></label>
                <select asp-for="MedioPago" class="field">
                    <option value="Efectivo">Efectivo</option>
                    <option value="Transferencia">Transferencia</option>
                    <option value="Tarjeta Débito">Tarjeta Débito</option>
                    <option value="Tarjeta Crédito">Tarjeta Crédito</option>
                    <option value="Cheque">Cheque</option>
                </select>
                <span asp-validation-for="MedioPago" class="err-text"></span>
            </div>
            <div>
                <label asp-for="ComprobantePago" class="label">N° de comprobante</label>
                <input asp-for="ComprobantePago"
                       class="field mono"
                       placeholder="Ej. 0001-00045822" />
                <span asp-validation-for="ComprobantePago" class="err-text"></span>
            </div>
            <div class="sm:col-span-2">
                <label asp-for="Observaciones" class="label">Observaciones</label>
                <textarea asp-for="Observaciones"
                          class="field"
                          placeholder="Comentario interno (opcional)..."></textarea>
                <span asp-validation-for="Observaciones" class="err-text"></span>
            </div>
        </div>

        <div class="flex flex-col-reverse sm:flex-row justify-end gap-2 mt-5 pt-5" style="border-top:1px solid var(--line)" data-credito-adelanto-footer-actions>
            <a href="@volverHref" class="btn btn-ghost">Cancelar</a>
            <button type="submit" class="btn btn-success">
                <span class="material-symbols-outlined">fast_forward</span>
                Registrar adelanto
            </button>
        </div>
    </form>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/shared-ui.js" asp-append-version="true"></script>
}
