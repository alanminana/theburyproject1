@model ConfiguracionCreditoVentaViewModel
@using TheBuryProject.Models.Enums
@{
    ViewData["Title"] = "Solicitud de Crédito Personal";
    var returnUrl = ViewData["ReturnUrl"] as string;
    var puedeConfigurarCreditoPersonal = User.TienePermiso("configuraciones", "view");

    var clienteConfig = Model.ClienteConfigPersonalizada;
    var perfilesActivos = Model.PerfilesActivos;
    var volverHref = !string.IsNullOrWhiteSpace(returnUrl)
        ? returnUrl
        : Model.VentaId.HasValue
            ? Url.Action("Details", "Venta", new { id = Model.VentaId.Value }) ?? $"/Venta/Details/{Model.VentaId.Value}"
            : Url.Action("Details", "Credito", new { id = Model.CreditoId }) ?? $"/Credito/Details/{Model.CreditoId}";

    var ventaTexto = Model.VentaId.HasValue ? $"Venta #{Model.VentaId.Value}" : "Venta sin asociar";
    var numeroCreditoTexto = string.IsNullOrWhiteSpace(Model.NumeroCredito) ? "Credito pendiente" : Model.NumeroCredito;
    var tituloResumenContrato = Model.ContratoGenerado
        ? "Contrato generado"
        : Model.PuedeGenerarContrato
            ? "Contrato pendiente generable"
            : "Contrato pendiente";
}

@section Styles {
    <partial name="_CreditoModuleStyles" />
}

<main class="shell" style="padding-top:1.5rem;padding-bottom:3rem">
    <a href="@volverHref"
       class="inline-flex items-center gap-1.5 text-sm muted hover:text-white transition"
       style="text-decoration:none"
       data-credito-config-cancel
       data-credito-cancel-url="@volverHref">
        <span class="material-symbols-outlined" style="font-size:18px">arrow_back</span>
        Volver a la venta
    </a>

    <div class="page-head" style="margin-top:.95rem">
        <div class="min-w-0">
            <h1 class="page-title" style="font-size:1.4rem">Configurar credito personal</h1>
            <p class="page-sub" style="margin-top:.3rem">
                @ventaTexto
                <span class="sep">.</span>
                Cliente @Model.ClienteNombre
                <span class="sep">.</span>
                Total a financiar <strong class="text-slate-200">$ @Model.MontoFinanciado.ToString("N2")</strong>
            </p>
        </div>
        <div class="head-actions" data-credito-config-header-actions>
            <a asp-controller="Cliente" asp-action="Edit" asp-route-id="@Model.ClienteId"
               asp-route-returnUrl="@($"{Context.Request.Path}{Context.Request.QueryString}")"
               class="btn btn-ghost">
                <span class="material-symbols-outlined">manage_accounts</span>
                Editar cliente
            </a>
            @if (puedeConfigurarCreditoPersonal)
            {
                <a asp-controller="ConfiguracionPago" asp-action="CreditoPersonal"
                   asp-route-returnUrl="@($"{Context.Request.Path}{Context.Request.QueryString}")"
                   class="btn btn-ghost">
                    <span class="material-symbols-outlined">settings</span>
                    Global y perfiles
                </a>
            }
            <a href="@volverHref" class="btn btn-ghost">
                <span class="material-symbols-outlined">arrow_back</span>
                Volver
            </a>
        </div>
    </div>

    <div asp-validation-summary="ModelOnly" class="alert alert-bad validation-summary-valid" style="margin-top:1rem"></div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-bad" role="alert" style="margin-top:1rem">
            <span class="material-symbols-outlined">error</span>
            <span>@TempData["Error"]</span>
        </div>
    }
    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warn" role="status" style="margin-top:1rem">
            <span class="material-symbols-outlined">warning</span>
            <span>@TempData["Warning"]</span>
        </div>
    }
    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info" role="status" style="margin-top:1rem">
            <span class="material-symbols-outlined">info</span>
            <span>@TempData["Info"]</span>
        </div>
    }

    <form asp-action="ConfigurarVenta" asp-controller="Credito" method="post" id="form-configurar-credito" data-credito-config-form>
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="CreditoId" />
        <input type="hidden" asp-for="VentaId" />
        <input type="hidden" asp-for="ClienteId" />
        <input type="hidden" asp-for="Monto" id="hdn-monto-venta" />
        <input type="hidden" asp-for="MontoFinanciado" id="hdn-monto-financiado" />
        <input type="hidden" asp-for="FuenteConfiguracion" id="hdn-fuente-configuracion" />
        @if (!string.IsNullOrEmpty(returnUrl))
        {
            <input type="hidden" name="returnUrl" value="@returnUrl" />
        }

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4" style="margin-top:1.25rem" data-credito-config>
            <div class="lg:col-span-2 space-y-4">
                <section class="card card-pad">
                    <div class="sec-head">
                        <div class="sec-num">1</div>
                        <div>
                            <div class="sec-title">Metodo de calculo</div>
                            <div class="sec-sub">Define de donde salen la tasa y los gastos.</div>
                        </div>
                    </div>
                    <label asp-for="MetodoCalculo" class="label">Metodo de calculo</label>
                    <select asp-for="MetodoCalculo"
                            asp-items="Html.GetEnumSelectList<MetodoCalculoCredito>()"
                            class="field"
                            id="select-metodo-calculo">
                        <option value="">Seleccione metodo...</option>
                    </select>
                    <span asp-validation-for="MetodoCalculo" class="err-text"></span>
                    <div class="alert alert-info hidden" id="metodo-info" style="margin-top:.85rem">
                        <span class="material-symbols-outlined">info</span>
                        <span id="metodo-info-texto"></span>
                    </div>
                </section>

                <section class="card card-pad" id="panel-perfil-credito">
                    <div class="sec-head">
                        <div class="sec-num">2</div>
                        <div>
                            <div class="sec-title">Perfil de credito</div>
                            <div class="sec-sub">Cada perfil define tasa, gastos y rango de cuotas.</div>
                        </div>
                    </div>
                    <label asp-for="PerfilCreditoSeleccionadoId" class="label">Perfil de credito</label>
                    <select asp-for="PerfilCreditoSeleccionadoId" class="field" id="select-perfil-credito">
                        <option value="">Seleccione perfil...</option>
                        @foreach (var p in perfilesActivos)
                        {
                            <option value="@p.Id"
                                    data-tasa="@p.TasaMensual"
                                    data-gastos="@p.GastosAdministrativos"
                                    data-min-cuotas="@p.MinCuotas"
                                    data-max-cuotas="@p.MaxCuotas"
                                    selected="@(Model.PerfilCreditoSeleccionadoId == p.Id)">
                                @p.Nombre @(p.Descripcion != null ? $"-- {p.Descripcion}" : "") - @p.TasaMensual.ToString("N2")% - gastos $@p.GastosAdministrativos.ToString("N2") - @p.MinCuotas a @p.MaxCuotas cuotas
                            </option>
                        }
                    </select>
                    <span asp-validation-for="PerfilCreditoSeleccionadoId" class="err-text"></span>
                </section>

                <section class="card card-pad">
                    <div class="sec-head">
                        <div class="sec-num">3</div>
                        <div>
                            <div class="sec-title">Cantidad de cuotas</div>
                            <div class="sec-sub" id="cuotas-rango-info">
                                Rango permitido: @Model.CuotasMinPermitidas a @Model.CuotasMaxPermitidas cuotas.
                                @if (!string.IsNullOrWhiteSpace(Model.RestriccionCreditoProductoDescripcion))
                                {
                                    <span>@Model.RestriccionCreditoProductoDescripcion</span>
                                }
                            </div>
                        </div>
                    </div>
                    @if (Model.MaxCuotasBase > Model.CuotasMaxPermitidas && Model.MaxCuotasCreditoProducto.HasValue)
                    {
                        <div class="alert alert-warn" style="margin-bottom:1rem" data-credito-restriccion-cuotas-producto>
                            <span class="material-symbols-outlined">info</span>
                            <span>
                                Maximo de cuotas reducido por condiciones del producto. El rango base permitia hasta
                                <strong>@Model.MaxCuotasBase cuotas</strong>, pero la configuracion de un producto limita el credito personal a
                                <strong>@Model.MaxCuotasCreditoProducto!.Value cuotas</strong>.
                                @if (!string.IsNullOrWhiteSpace(Model.ProductoRestrictivoNombre))
                                {
                                    <span data-credito-producto-restrictivo-nombre>(@Model.ProductoRestrictivoNombre)</span>
                                }
                                else if (Model.ProductoIdRestrictivo.HasValue)
                                {
                                    <span>(snapshot producto #@Model.ProductoIdRestrictivo.Value)</span>
                                }
                            </span>
                        </div>
                    }
                    <label asp-for="CantidadCuotas" class="label">Cantidad de cuotas</label>
                    <input asp-for="CantidadCuotas"
                           type="number"
                           min="@Model.CuotasMinPermitidas"
                           max="@Model.CuotasMaxPermitidas"
                           class="field"
                           list="cuotas-habilitadas-list"
                           id="txt-cuotas" />
                    <datalist id="cuotas-habilitadas-list">
                        @foreach (var plan in Model.ClienteConfigPersonalizada.CuotasHabilitadas)
                        {
                            <option value="@plan.CantidadCuotas">@plan.CantidadCuotas cuotas - @plan.TasaMensual.ToString("N2")% mensual</option>
                        }
                    </datalist>
                    <span asp-validation-for="CantidadCuotas" class="err-text"></span>
                </section>

                <section class="card card-pad">
                    <div class="sec-head">
                        <div class="sec-num">4</div>
                        <div>
                            <div class="sec-title">Valores del credito</div>
                            <div class="sec-sub">El backend valida los importes finales; esta pantalla solo previsualiza.</div>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="label">Cliente</label>
                            <input class="field" readonly value="@Model.ClienteNombre" />
                        </div>
                        <div>
                            <label class="label">Numero de credito</label>
                            <input class="field mono" readonly value="@numeroCreditoTexto" />
                        </div>
                        <div>
                            <label class="label">Monto total de venta</label>
                            <div class="field-money">
                                <span class="cur">$</span>
                                <input class="field" readonly value="@Model.Monto.ToString("N2")" id="txt-monto-venta-display" />
                            </div>
                        </div>
                        <div>
                            <label asp-for="Anticipo" class="label">Anticipo</label>
                            <div class="field-money">
                                <span class="cur">$</span>
                                <input asp-for="Anticipo" type="number" step="0.01" min="0" class="field" id="txt-anticipo" />
                            </div>
                            <span asp-validation-for="Anticipo" class="err-text"></span>
                        </div>
                        <div>
                            <div class="flex items-center justify-between">
                                <label asp-for="TasaMensual" class="label">Tasa mensual aplicada</label>
                                <span id="badge-tasa-fuente" class="chip chip-info hidden"></span>
                            </div>
                            <input asp-for="TasaMensual" type="number" step="0.01" min="0" max="100" class="field" id="txt-tasa" />
                            <span asp-validation-for="TasaMensual" class="err-text"></span>
                        </div>
                        <div>
                            <label asp-for="GastosAdministrativos" class="label">Gastos administrativos</label>
                            <div class="field-money">
                                <span class="cur">$</span>
                                <input asp-for="GastosAdministrativos" type="number" step="0.01" min="0" class="field" id="txt-gastos" />
                            </div>
                            <span asp-validation-for="GastosAdministrativos" class="err-text"></span>
                        </div>
                        <div>
                            <label asp-for="FechaPrimeraCuota" class="label">Primera fecha de vencimiento</label>
                            <input asp-for="FechaPrimeraCuota" type="date" class="field" id="txt-fecha-primera-cuota" />
                            <span asp-validation-for="FechaPrimeraCuota" class="err-text"></span>
                        </div>
                        <div>
                            <label class="label">Monto financiado</label>
                            <div class="result-card is-ok" style="padding:.85rem 1rem">
                                <div class="result-value" id="txt-monto-financiado" style="font-size:1.35rem">$ @Model.MontoFinanciado.ToString("N2")</div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>

            <aside>
                <div class="card card-pad" style="position:sticky;top:76px">
                    <h3 class="font-semibold text-white mb-3 flex items-center gap-2">
                        <span class="material-symbols-outlined" style="color:#f5c518;font-size:20px">summarize</span>
                        Resumen del plan
                    </h3>

                    <div id="plan-resumen-vacio" class="ph hidden">
                        <span class="material-symbols-outlined">calculate</span>
                        <div class="ph-label">selecciona metodo y cuotas</div>
                    </div>

                    <div id="plan-resumen" class="space-y-3">
                        <div id="plan-resumen-contenido">
                        <div class="result-card is-ok">
                            <div class="result-label">Cuota mensual</div>
                            <div class="result-value" id="plan-cuota-estimada">$ 0,00</div>
                        </div>
                        <dl class="kv mt-3">
                            <div class="kv-row"><dt>Monto a financiar</dt><dd class="num" id="plan-capital">$ @Model.MontoFinanciado.ToString("N2")</dd></div>
                            <div class="kv-row"><dt>Tasa mensual</dt><dd id="plan-tasa">0% Mensual</dd></div>
                            <div class="kv-row"><dt>Gastos administrativos</dt><dd class="num" id="plan-gastos">$ 0,00</dd></div>
                            <div class="kv-row"><dt>Cantidad de cuotas</dt><dd id="plan-cuotas-label">@Model.CantidadCuotas</dd></div>
                            <div class="kv-row"><dt>Interes total</dt><dd class="num" id="plan-interes">$ 0,00</dd></div>
                            <div class="kv-row"><dt>Total a pagar</dt><dd class="num" id="plan-total" style="color:#34d399;font-weight:600">$ 0,00</dd></div>
                        </dl>
                        <div id="plan-fecha-container" class="alert alert-info hidden" style="margin-top:.8rem">
                            <span class="material-symbols-outlined">event_upcoming</span>
                            <span>Primer vencimiento: <strong id="plan-fecha-pago">-</strong></span>
                        </div>
                        </div>
                    </div>

                    <section class="card-2" style="margin-top:1rem;padding:1rem" aria-labelledby="semaforo-title">
                        <div class="sec-title" id="semaforo-title">Evaluacion preliminar</div>
                        <div id="semaforo-panel" class="hidden" style="margin-top:.8rem">
                            <div id="semaforo-badge" class="flex items-center justify-between p-3 rounded-lg">
                                <div class="flex items-center gap-3">
                                    <div id="semaforo-dot" class="size-4 rounded-full animate-pulse"></div>
                                    <span id="semaforo-label" class="font-bold"></span>
                                </div>
                                <span id="semaforo-tag" class="text-[10px] uppercase font-black"></span>
                            </div>
                            <p id="semaforo-mensaje" class="muted text-sm italic mt-3"></p>
                            <div id="semaforo-alertas" class="space-y-3 mt-3"></div>
                        </div>
                        <div id="semaforo-vacio" class="ph" style="margin-top:.8rem;padding:1.25rem">
                            <span class="material-symbols-outlined">query_stats</span>
                            <div class="ph-label">completa condiciones para evaluar</div>
                        </div>
                    </section>

                    <section class="card-2" style="margin-top:1rem;padding:1rem">
                        <div class="sec-title">Documentacion contractual</div>
                        <p class="hint">@tituloResumenContrato</p>
                        @if (Model.ContratoGenerado)
                        {
                            <a asp-controller="ContratoVentaCredito" asp-action="Ver" asp-route-ventaId="@Model.VentaId"
                               target="_blank" rel="noopener" class="btn btn-success btn-block btn-sm" style="margin-top:.75rem">
                                <span class="material-symbols-outlined">print</span>
                                Ver / imprimir contrato
                            </a>
                        }
                        else if (!Model.PlantillaActivaDisponible)
                        {
                            <div class="alert alert-bad" style="margin-top:.75rem">
                                <span class="material-symbols-outlined">error</span>
                                <span>No hay ninguna plantilla de contrato activa y vigente.</span>
                            </div>
                        }
                        else if (Model.PuedeGenerarContrato)
                        {
                            <button type="submit"
                                    id="btn-generar-contrato"
                                    data-contrato-generar
                                    formaction="@Url.Action("Generar", "ContratoVentaCredito", new { ventaId = Model.VentaId })"
                                    formmethod="post"
                                    formtarget="_blank"
                                    formnovalidate
                                    class="btn btn-amber btn-block btn-sm"
                                    style="margin-top:.75rem">
                                <span class="material-symbols-outlined">picture_as_pdf</span>
                                Generar contrato de venta
                            </button>
                        }
                        else
                        {
                            <div class="alert alert-warn" style="margin-top:.75rem">
                                <span class="material-symbols-outlined">contract</span>
                                <span>Guarda primero la configuracion de cuotas para habilitar el contrato.</span>
                            </div>
                        }
                    </section>

                    <div class="flex flex-col gap-2" style="margin-top:1.1rem" data-credito-config-footer-actions>
                        @if (Model.CreditoEstaConfigurado && Model.VentaId.HasValue && Model.ContratoGenerado)
                        {
                            <a asp-action="Details" asp-controller="Venta" asp-route-id="@Model.VentaId.Value" class="btn btn-success btn-block">
                                <span class="material-symbols-outlined">shopping_cart_checkout</span>
                                Volver a confirmar venta
                            </a>
                        }
                        else if (Model.CreditoEstaConfigurado && Model.VentaId.HasValue && !Model.ContratoGenerado)
                        {
                            <div class="alert alert-warn">
                                <span class="material-symbols-outlined">contract</span>
                                <span>Genera el contrato de venta antes de continuar.</span>
                            </div>
                        }
                        else if (Model.CreditoEstaConfigurado)
                        {
                            <a asp-action="Details" asp-controller="Credito" asp-route-id="@Model.CreditoId" class="btn btn-success btn-block">
                                <span class="material-symbols-outlined">receipt_long</span>
                                Ver credito
                            </a>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-success btn-block" id="btn-confirmar-credito">
                                <span class="material-symbols-outlined">check_circle</span>
                                Confirmar credito
                            </button>
                        }
                        <button type="button"
                                class="btn btn-ghost btn-block btn-sm"
                                id="btn-cancelar-credito"
                                data-credito-config-cancel
                                data-credito-cancel-url="@volverHref">
                            Cancelar
                        </button>
                    </div>
                </div>
            </aside>
        </div>
    </form>
</main>

<script id="cliente-config-data" data-credito-json="cliente-config" type="application/json">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(clienteConfig, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }))
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/credito-module.js" asp-append-version="true"></script>
    <script src="~/js/configurar-venta-credito.js" asp-append-version="true"></script>
}
