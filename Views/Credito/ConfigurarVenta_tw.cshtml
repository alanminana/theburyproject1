@model ConfiguracionCreditoVentaViewModel
@using TheBuryProject.Models.Enums
@{
    ViewData["Title"] = "Solicitud de Crédito Personal";
    var returnUrl = ViewData["ReturnUrl"] as string;

    // Serializar datos del cliente para JS
    var clienteConfig = ViewBag.ClienteConfigPersonalizada;
    var perfilesActivos = ViewBag.PerfilesActivos as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

<div class="flex-1 flex flex-col items-center py-10 px-4 md:px-0">
    <div class="max-w-[1024px] w-full space-y-8">

        <!-- Header Section -->
        <div class="flex flex-col gap-2">
            <h1 class="text-slate-900 dark:text-white text-4xl font-black tracking-tight">Solicitud de Crédito Personal</h1>
            <p class="text-slate-500 dark:text-slate-400 text-base font-normal">Gestión y evaluación de financiamiento directo para clientes activos.</p>
        </div>

        <!-- Validation Summary -->
        <div asp-validation-summary="ModelOnly" class="hidden text-red-500 text-sm p-4 bg-red-500/10 rounded-lg border border-red-500/20"></div>

        <!-- TempData messages -->
        @if (TempData["Error"] != null)
        {
            <div class="toast-msg p-4 rounded-lg bg-red-500/10 border border-red-500/20 text-red-500 text-sm font-bold flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">error</span> @TempData["Error"]
            </div>
        }
        @if (TempData["Warning"] != null)
        {
            <div class="toast-msg p-4 rounded-lg bg-amber-500/10 border border-amber-500/20 text-amber-600 dark:text-amber-400 text-sm font-bold flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">warning</span> @TempData["Warning"]
            </div>
        }
        @if (TempData["Info"] != null)
        {
            <div class="toast-msg p-4 rounded-lg bg-blue-500/10 border border-blue-500/20 text-blue-600 dark:text-blue-400 text-sm font-bold flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">info</span> @TempData["Info"]
            </div>
        }

        <form asp-action="ConfigurarVenta" asp-controller="Credito" method="post" id="form-configurar-credito">
            <input type="hidden" asp-for="CreditoId" />
            <input type="hidden" asp-for="VentaId" />
            <input type="hidden" asp-for="ClienteId" />
            <input type="hidden" asp-for="MontoFinanciado" id="hdn-monto-financiado" />
            <input type="hidden" asp-for="FuenteConfiguracion" id="hdn-fuente-configuracion" />
            @if (!string.IsNullOrEmpty(returnUrl))
            {
                <input type="hidden" name="returnUrl" value="@returnUrl" />
            }

            <!-- Main Grid Layout -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

                <!-- Left Column: Forms -->
                <div class="lg:col-span-2 space-y-8">

                    <!-- Section: Datos de la Venta -->
                    <section class="bg-white dark:bg-slate-900/40 p-6 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
                        <div class="flex items-center gap-2 mb-6 border-b border-slate-100 dark:border-slate-800 pb-3">
                            <span class="material-symbols-outlined text-primary">shopping_cart</span>
                            <h2 class="text-slate-900 dark:text-white text-xl font-bold">Datos de la Venta</h2>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="flex flex-col gap-1.5">
                                <label class="text-slate-700 dark:text-slate-300 text-sm font-semibold">Cliente</label>
                                <input class="bg-slate-100 dark:bg-slate-800/50 border-none rounded-lg text-slate-500 dark:text-slate-400 h-12 px-4 cursor-not-allowed focus:ring-0"
                                       readonly value="@Model.ClienteNombre" />
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-slate-700 dark:text-slate-300 text-sm font-semibold">Número de Crédito</label>
                                <input class="bg-slate-100 dark:bg-slate-800/50 border-none rounded-lg text-slate-500 dark:text-slate-400 h-12 px-4 cursor-not-allowed focus:ring-0"
                                       readonly value="@(Model.NumeroCredito ?? "Pendiente")" />
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-slate-700 dark:text-slate-300 text-sm font-semibold">Monto Total de Venta</label>
                                <div class="relative">
                                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">$</span>
                                    <input class="bg-slate-100 dark:bg-slate-800/50 border-none rounded-lg text-slate-500 dark:text-slate-400 h-12 pl-8 pr-4 w-full cursor-not-allowed focus:ring-0"
                                           readonly value="@Model.Monto.ToString("N2")" id="txt-monto-venta-display" />
                                    <input type="hidden" asp-for="Monto" id="hdn-monto-venta" />
                                </div>
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-slate-700 dark:text-slate-300 text-sm font-semibold">Anticipo</label>
                                <div class="relative">
                                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-primary font-bold">$</span>
                                    <input asp-for="Anticipo" type="number" step="0.01" min="0" id="txt-anticipo"
                                           class="bg-slate-50 dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-700 focus:border-primary dark:focus:border-primary rounded-lg text-slate-900 dark:text-white h-12 pl-8 pr-4 w-full focus:ring-0 transition-all" />
                                </div>
                                <span asp-validation-for="Anticipo" class="text-red-500 text-xs"></span>
                            </div>
                        </div>
                        <div class="mt-6 p-4 bg-primary/5 dark:bg-primary/10 rounded-lg flex justify-between items-center border border-primary/20">
                            <span class="text-slate-600 dark:text-slate-300 font-medium">Monto Financiado</span>
                            <span id="txt-monto-financiado" class="text-primary text-2xl font-black tracking-tight">$ @Model.MontoFinanciado.ToString("N2")</span>
                        </div>
                    </section>

                    <!-- Section: Condiciones del Crédito -->
                    <section class="bg-white dark:bg-slate-900/40 p-6 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
                        <div class="flex items-center gap-2 mb-6 border-b border-slate-100 dark:border-slate-800 pb-3">
                            <span class="material-symbols-outlined text-primary">settings_applications</span>
                            <h2 class="text-slate-900 dark:text-white text-xl font-bold">Condiciones del Crédito</h2>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <!-- Método de Cálculo -->
                            <div class="flex flex-col gap-1.5">
                                <label asp-for="MetodoCalculo" class="text-slate-700 dark:text-slate-300 text-sm font-semibold">Método de Cálculo</label>
                                <select asp-for="MetodoCalculo" id="select-metodo-calculo"
                                        asp-items="Html.GetEnumSelectList<MetodoCalculoCredito>()"
                                        class="bg-slate-50 dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-700 focus:border-primary dark:focus:border-primary rounded-lg text-slate-900 dark:text-white h-12 px-4 w-full focus:ring-0">
                                    <option value="">Seleccione método...</option>
                                </select>
                                <span asp-validation-for="MetodoCalculo" class="text-red-500 text-xs"></span>
                                <p id="metodo-info" class="text-xs text-slate-500 dark:text-slate-400 mt-1 flex items-center gap-1 hidden">
                                    <span class="material-symbols-outlined text-[14px]">info</span>
                                    <span id="metodo-info-texto"></span>
                                </p>
                            </div>

                            <!-- Perfil de Crédito (visible solo con UsarPerfil) -->
                            <div class="flex flex-col gap-1.5" id="panel-perfil-credito">
                                <label class="text-slate-700 dark:text-slate-300 text-sm font-semibold">Perfil de Crédito</label>
                                <select asp-for="PerfilCreditoSeleccionadoId" id="select-perfil-credito"
                                        class="bg-slate-50 dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-700 focus:border-primary dark:focus:border-primary rounded-lg text-slate-900 dark:text-white h-12 px-4 w-full focus:ring-0">
                                    <option value="">Seleccione perfil...</option>
                                    @foreach (var p in perfilesActivos)
                                    {
                                        <option value="@p.Id"
                                                data-tasa="@p.TasaMensual"
                                                data-gastos="@p.GastosAdministrativos"
                                                data-min-cuotas="@p.MinCuotas"
                                                data-max-cuotas="@p.MaxCuotas"
                                                selected="@(Model.PerfilCreditoSeleccionadoId == (int)p.Id)">
                                            @p.Nombre @(p.Descripcion != null ? $"— {p.Descripcion}" : "")
                                        </option>
                                    }
                                </select>
                            </div>

                            <!-- Cantidad de Cuotas -->
                            <div class="flex flex-col gap-1.5">
                                <label asp-for="CantidadCuotas" class="text-slate-700 dark:text-slate-300 text-sm font-semibold">Cantidad de Cuotas</label>
                                <input asp-for="CantidadCuotas" type="number" min="1" max="120" id="txt-cuotas"
                                       class="bg-slate-50 dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-700 focus:border-primary dark:focus:border-primary rounded-lg text-slate-900 dark:text-white h-12 px-4 w-full focus:ring-0" />
                                <span asp-validation-for="CantidadCuotas" class="text-red-500 text-xs"></span>
                                <p id="cuotas-rango-info" class="text-xs text-slate-500 dark:text-slate-400 mt-1">Rango permitido: 1 a 120 cuotas.</p>
                            </div>

                            <!-- Tasa de Interés Mensual -->
                            <div class="flex flex-col gap-1.5">
                                <div class="flex items-center justify-between">
                                    <label asp-for="TasaMensual" class="text-slate-700 dark:text-slate-300 text-sm font-semibold">Tasa Mensual Aplicada</label>
                                    <span id="badge-tasa-fuente" class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-primary/20 text-primary uppercase hidden"></span>
                                </div>
                                <div class="relative">
                                    <input asp-for="TasaMensual" type="number" step="0.01" min="0.01" max="100" id="txt-tasa"
                                           class="bg-slate-50 dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-700 focus:border-primary dark:focus:border-primary rounded-lg text-slate-900 dark:text-white h-12 pl-4 pr-10 w-full focus:ring-0" />
                                    <span class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400">%</span>
                                </div>
                                <span asp-validation-for="TasaMensual" class="text-red-500 text-xs"></span>
                                <p class="text-xs text-slate-500 dark:text-slate-400 mt-1 flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[14px]">help</span>
                                    Sujeta a variación por perfil del cliente.
                                </p>
                            </div>

                            <!-- Gastos Administrativos -->
                            <div class="flex flex-col gap-1.5">
                                <label asp-for="GastosAdministrativos" class="text-slate-700 dark:text-slate-300 text-sm font-semibold">Gastos Administrativos</label>
                                <div class="relative">
                                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">$</span>
                                    <input asp-for="GastosAdministrativos" type="number" step="0.01" min="0" id="txt-gastos"
                                           class="bg-slate-50 dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-700 focus:border-primary dark:focus:border-primary rounded-lg text-slate-900 dark:text-white h-12 pl-8 pr-4 w-full focus:ring-0" />
                                </div>
                                <span asp-validation-for="GastosAdministrativos" class="text-red-500 text-xs"></span>
                            </div>

                            <!-- Fecha Primera Cuota -->
                            <div class="flex flex-col gap-1.5">
                                <label asp-for="FechaPrimeraCuota" class="text-slate-700 dark:text-slate-300 text-sm font-semibold">Fecha Primera Cuota</label>
                                <input asp-for="FechaPrimeraCuota" type="date" id="txt-fecha-primera-cuota"
                                       class="bg-slate-50 dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-700 focus:border-primary dark:focus:border-primary rounded-lg text-slate-900 dark:text-white h-12 px-4 w-full focus:ring-0" />
                                <span asp-validation-for="FechaPrimeraCuota" class="text-red-500 text-xs"></span>
                            </div>
                        </div>
                    </section>
                </div>

                <!-- Right Column: Summary & Evaluation -->
                <div class="space-y-8">

                    <!-- Section: Evaluación Preliminar -->
                    <section class="bg-white dark:bg-slate-900/40 p-6 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden relative">
                        <div class="absolute top-0 right-0 w-24 h-24 bg-yellow-500/10 rounded-full -mr-12 -mt-12 blur-2xl"></div>
                        <div class="flex items-center gap-2 mb-6 border-b border-slate-100 dark:border-slate-800 pb-3">
                            <span class="material-symbols-outlined text-primary">analytics</span>
                            <h2 class="text-slate-900 dark:text-white text-xl font-bold">Evaluación</h2>
                        </div>
                        <div class="flex flex-col gap-4">
                            <!-- Semáforo -->
                            <div id="semaforo-panel" class="hidden">
                                <div id="semaforo-badge" class="flex items-center justify-between p-3 rounded-lg">
                                    <div class="flex items-center gap-3">
                                        <div id="semaforo-dot" class="size-4 rounded-full animate-pulse"></div>
                                        <span id="semaforo-label" class="font-bold"></span>
                                    </div>
                                    <span id="semaforo-tag" class="text-[10px] uppercase font-black"></span>
                                </div>
                                <p id="semaforo-mensaje" class="text-slate-600 dark:text-slate-300 text-sm italic mt-3"></p>
                                <div id="semaforo-alertas" class="space-y-3 mt-3"></div>
                            </div>

                            <!-- Sin datos aún -->
                            <div id="semaforo-vacio" class="text-center py-6">
                                <span class="material-symbols-outlined text-4xl text-slate-300 dark:text-slate-700">query_stats</span>
                                <p class="text-sm text-slate-400 mt-2">Completá las condiciones para ver la evaluación.</p>
                            </div>
                        </div>
                    </section>

                    <!-- Section: Resumen de Plan -->
                    <section class="bg-slate-900 dark:bg-slate-900/60 p-6 rounded-xl border border-slate-800 shadow-xl text-white">
                        <div class="flex items-center gap-2 mb-6 border-b border-slate-800 pb-3">
                            <span class="material-symbols-outlined text-primary">receipt_long</span>
                            <h2 class="text-white text-xl font-bold">Resumen de Plan</h2>
                        </div>
                        <div id="plan-resumen-contenido" class="space-y-4">
                            <div class="flex justify-between items-center group">
                                <span class="text-slate-400 text-sm group-hover:text-slate-300 transition-colors">Cuota Estimada (<span id="plan-cuotas-label">0</span>x)</span>
                                <span id="plan-cuota-estimada" class="text-lg font-bold text-primary">$ 0,00</span>
                            </div>
                            <div class="flex justify-between items-center text-sm">
                                <span class="text-slate-400">Tasa Aplicada</span>
                                <span id="plan-tasa" class="text-slate-200">0% Mensual</span>
                            </div>
                            <div class="flex justify-between items-center text-sm border-b border-slate-800 pb-3">
                                <span class="text-slate-400">Interés Total</span>
                                <span id="plan-interes" class="text-slate-200">$ 0,00</span>
                            </div>
                            <div class="flex justify-between items-center text-sm pt-1">
                                <span class="text-slate-400">Capital Financiado</span>
                                <span id="plan-capital" class="text-slate-200 font-medium">$ 0,00</span>
                            </div>
                            <div class="flex justify-between items-center text-sm">
                                <span class="text-slate-400">Gastos Adm.</span>
                                <span id="plan-gastos" class="text-slate-200 font-medium">$ 0,00</span>
                            </div>
                            <div class="flex justify-between items-center pt-4 border-t border-slate-800">
                                <span class="text-slate-300 font-bold uppercase tracking-wider text-xs">Total del Plan</span>
                                <span id="plan-total" class="text-2xl font-black text-white">$ 0,00</span>
                            </div>
                            <div id="plan-fecha-container" class="mt-4 p-3 bg-slate-800/50 rounded flex items-center gap-3 hidden">
                                <span class="material-symbols-outlined text-slate-400">event_upcoming</span>
                                <div>
                                    <p class="text-[10px] text-slate-500 uppercase font-bold">Primer Vencimiento</p>
                                    <p id="plan-fecha-pago" class="text-sm font-semibold text-slate-200">-</p>
                                </div>
                            </div>
                        </div>
                        <!-- Sin datos -->
                        <div id="plan-resumen-vacio" class="text-center py-8 hidden">
                            <span class="material-symbols-outlined text-4xl text-slate-700">calculate</span>
                            <p class="text-sm text-slate-500 mt-2">Completá las condiciones para simular el plan.</p>
                        </div>
                    </section>
                </div>
            </div>

            <!-- Footer Actions -->
            <div class="flex flex-col md:flex-row items-center justify-between gap-4 pt-8 border-t border-slate-200 dark:border-slate-800 mt-8">
                <div class="flex gap-4 w-full md:w-auto">
                    @if (Model.VentaId.HasValue)
                    {
                        <a asp-action="Details" asp-controller="Venta" asp-route-id="@Model.VentaId"
                           class="flex-1 md:flex-none px-6 py-3 rounded-lg border-2 border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-300 font-bold hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors flex items-center justify-center gap-2 text-sm">
                            <span class="material-symbols-outlined text-[20px]">arrow_back</span> Volver a la Venta
                        </a>
                    }
                    else
                    {
                        <a asp-action="Index" asp-controller="Credito"
                           class="flex-1 md:flex-none px-6 py-3 rounded-lg border-2 border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-300 font-bold hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors flex items-center justify-center gap-2 text-sm">
                            <span class="material-symbols-outlined text-[20px]">arrow_back</span> Volver
                        </a>
                    }
                    <button type="button" id="btn-cancelar-credito"
                            class="flex-1 md:flex-none px-6 py-3 rounded-lg text-red-500 dark:text-red-400 font-bold hover:bg-red-500/10 transition-colors text-sm">
                        Cancelar
                    </button>
                </div>
                <button type="submit" id="btn-confirmar-credito"
                        class="w-full md:w-auto px-10 py-4 bg-primary hover:bg-primary/90 text-white font-black rounded-lg shadow-lg shadow-primary/20 transition-all flex items-center justify-center gap-3 uppercase tracking-widest text-sm">
                    Confirmar Crédito
                    <span class="material-symbols-outlined">verified_user</span>
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Cliente config data for JS -->
<script id="cliente-config-data" type="application/json">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(clienteConfig, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }))
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/configurar-venta-credito.js"></script>
}
