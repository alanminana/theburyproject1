@model List<CuotaViewModel>
@using TheBuryProject.Models.Enums
@{
    ViewData["Title"] = "Cuotas Vencidas";
    var returnUrl = ViewData["ReturnUrl"] as string;
    var cuotas = Model ?? new List<CuotaViewModel>();
    var total = cuotas.Count;
    var montoPendienteTotal = cuotas.Sum(c => c.SaldoPendiente);
    var montoBaseTotal = cuotas.Sum(c => Math.Max(0m, c.SaldoPendiente - c.MontoPunitorio));
    var punitoriosTotal = cuotas.Sum(c => c.MontoPunitorio);
    var criticas = cuotas.Count(c => c.DiasAtraso >= 10);
    var creditosAfectados = cuotas.Select(c => c.CreditoId).Distinct().Count();
    var clientesAfectados = cuotas
        .Select(c => c.ClienteNombre)
        .Where(nombre => !string.IsNullOrWhiteSpace(nombre))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Count();
    var volverHref = !string.IsNullOrWhiteSpace(returnUrl)
        ? returnUrl
        : Url.Action("Index", "Credito") ?? "/Credito";
}

@functions {
    private static string Iniciales(string? nombre)
    {
        if (string.IsNullOrWhiteSpace(nombre))
        {
            return "??";
        }

        var partes = nombre.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (partes.Length >= 2)
        {
            return $"{partes[0][0]}{partes[1][0]}".ToUpperInvariant();
        }

        return partes[0][..Math.Min(2, partes[0].Length)].ToUpperInvariant();
    }

    private static string EstadoChip(EstadoCuota estado) => estado switch
    {
        EstadoCuota.Vencida => "chip-bad",
        EstadoCuota.Parcial => "chip-warn",
        EstadoCuota.Pagada => "chip-ok",
        EstadoCuota.Cancelada => "chip-neutral",
        _ => "chip-neutral"
    };
}

@section Styles {
    <partial name="_CreditoModuleStyles" />
}

<main class="shell" style="padding-top:1.5rem;padding-bottom:3rem">
    <a href="@volverHref" class="inline-flex items-center gap-1.5 text-sm muted hover:text-white transition" style="text-decoration:none">
        <span class="material-symbols-outlined" style="font-size:18px">arrow_back</span>
        Volver a créditos
    </a>

    <div class="page-head" style="margin-top:.95rem">
        <div class="min-w-0">
            <h1 class="page-title" style="font-size:1.4rem">Cuotas vencidas</h1>
            <p class="page-sub" style="margin-top:.3rem">Listado operativo de cuotas en mora, ordenadas por días de atraso. Las críticas (+10 días) están resaltadas.</p>
        </div>
        <div class="head-actions">
            <button type="button" class="btn btn-soft" onclick="window.print()">
                <span class="material-symbols-outlined">download</span>
                Exportar
            </button>
        </div>
    </div>

    @if (TempData["Error"] is string errorMsg)
    {
        <div class="alert alert-bad" role="alert" style="margin-top:1rem">
            <span class="material-symbols-outlined">error</span>
            <span>@errorMsg</span>
        </div>
    }

    <div class="grid-kpi" style="margin-top:1.25rem;grid-template-columns:repeat(3,1fr)">
        <div class="kpi kpi--bad">
            <div class="kpi-label"><span class="material-symbols-outlined" style="font-size:15px">event_busy</span>Cuotas vencidas</div>
            <div class="kpi-value">@total</div>
            <div class="kpi-foot">en @creditosAfectados crédito@(creditosAfectados == 1 ? "" : "s") · @clientesAfectados cliente@(clientesAfectados == 1 ? "" : "s")</div>
        </div>
        <div class="kpi kpi--bad">
            <div class="kpi-label"><span class="material-symbols-outlined" style="font-size:15px">payments</span>Monto pendiente</div>
            <div class="kpi-value">@montoPendienteTotal.ToString("C0")</div>
            <div class="kpi-foot">capital + punitorios</div>
        </div>
        <div class="kpi kpi--warn">
            <div class="kpi-label"><span class="material-symbols-outlined" style="font-size:15px">priority_high</span>Críticas (+10 días)</div>
            <div class="kpi-value">@criticas</div>
            <div class="kpi-foot">requieren gestión inmediata</div>
        </div>
    </div>

    @if (!cuotas.Any())
    {
        <section class="card empty" style="margin-top:1.5rem">
            <div class="empty-ic"><span class="material-symbols-outlined">check_circle</span></div>
            <h3>Sin cuotas vencidas</h3>
            <p>La cartera no presenta cuotas con vencimiento superado al día de hoy.</p>
        </section>
    }
    else
    {
        <section class="card" style="margin-top:1.5rem;overflow:hidden">
            <div data-oc-scroll style="--oc-scroll-min-width: 62rem;">
                <p data-oc-scroll-hint hidden class="scroll-hint" style="padding:.85rem 1rem 0">
                    <span class="material-symbols-outlined" style="font-size:15px">swipe</span>
                    Deslizá para ver el detalle completo de mora y acciones.
                </p>
                <div data-oc-scroll-shell>
                    <div data-oc-scroll-fade="left" hidden></div>
                    <div data-oc-scroll-fade="right" hidden></div>
                    <div data-oc-scroll-region tabindex="0" role="region" aria-label="Tabla de cuotas vencidas" class="tbl-wrap">
                        <table data-oc-scroll-table class="tbl">
                            <thead>
                                <tr>
                                    <th>Atraso</th>
                                    <th>Cliente</th>
                                    <th>Crédito</th>
                                    <th>Cuota</th>
                                    <th>Vencimiento</th>
                                    <th style="text-align:right">Monto</th>
                                    <th style="text-align:right">Mora</th>
                                    <th style="text-align:right">Total</th>
                                    <th style="text-align:right">Acción</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var cuota in cuotas.OrderByDescending(c => c.DiasAtraso).ThenBy(c => c.FechaVencimiento))
                                {
                                    var esCritica = cuota.DiasAtraso >= 10;
                                    var montoBase = Math.Max(0m, cuota.SaldoPendiente - cuota.MontoPunitorio);
                                    var creditoNumero = string.IsNullOrWhiteSpace(cuota.CreditoNumero)
                                        ? $"CR-{cuota.CreditoId:D6}"
                                        : cuota.CreditoNumero;
                                    var clienteNombre = string.IsNullOrWhiteSpace(cuota.ClienteNombre)
                                        ? "Cliente sin nombre"
                                        : cuota.ClienteNombre;

                                    <tr style="@(esCritica ? "background:rgba(244,63,94,.05)" : null)">
                                        <td>
                                            <span class="dias-badge @(esCritica ? "bad" : "warn")">
                                                @cuota.DiasAtraso
                                                <span class="u">días</span>
                                            </span>
                                        </td>
                                        <td>
                                            <div class="flex items-center gap-2.5">
                                                <div class="avatar avatar-sm @(esCritica ? "avatar--slate" : "")">@Iniciales(clienteNombre)</div>
                                                <div class="font-medium text-white">@clienteNombre</div>
                                            </div>
                                        </td>
                                        <td>
                                            <a asp-action="Details" asp-route-id="@cuota.CreditoId" class="mono text-sm text-slate-300 hover:text-white" style="text-decoration:none">
                                                @creditoNumero
                                            </a>
                                        </td>
                                        <td>
                                            <div class="flex items-center gap-2">
                                                <span class="cuota-n venc">@cuota.NumeroCuota</span>
                                                <span class="chip @EstadoChip(cuota.Estado)">@cuota.EstadoTexto</span>
                                            </div>
                                        </td>
                                        <td>@cuota.FechaVencimiento.ToString("dd/MM/yyyy")</td>
                                        <td class="num" style="text-align:right">@montoBase.ToString("C0")</td>
                                        <td class="num" style="text-align:right;color:#fbbf24">@(cuota.MontoPunitorio > 0 ? cuota.MontoPunitorio.ToString("C0") : "—")</td>
                                        <td class="num" style="text-align:right;font-weight:600;color:#fff">@cuota.SaldoPendiente.ToString("C0")</td>
                                        <td style="text-align:right">
                                            <a asp-action="PagarCuota"
                                               asp-route-id="@cuota.CreditoId"
                                               asp-route-cuotaId="@cuota.Id"
                                               asp-route-returnUrl="@returnUrl"
                                               class="btn @(esCritica ? "btn-danger" : "btn-soft") btn-sm">
                                                Cobrar
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr style="background:rgba(15,23,42,.5)">
                                    <td colspan="5" style="padding:.75rem 1rem;font-weight:600;color:var(--muted)">Total en mora (@total cuota@(total == 1 ? "" : "s"))</td>
                                    <td class="num" style="text-align:right;padding:.75rem 1rem;color:#fff">@montoBaseTotal.ToString("C0")</td>
                                    <td class="num" style="text-align:right;color:#fbbf24">@punitoriosTotal.ToString("C0")</td>
                                    <td class="num" style="text-align:right;font-weight:700;color:#fb7185">@montoPendienteTotal.ToString("C0")</td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </section>
    }
</main>

@section Scripts {
    <script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
    <script src="~/js/shared-ui.js" asp-append-version="true"></script>
}
