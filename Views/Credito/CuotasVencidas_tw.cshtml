@model List<CuotaViewModel>
@using TheBuryProject.Models.Enums
@{
    ViewData["Title"] = "Cuotas Vencidas";
    var returnUrl = ViewData["ReturnUrl"] as string;
    var total = Model?.Count ?? 0;
    var montoPendienteTotal = Model?.Sum(c => c.SaldoPendiente) ?? 0m;
    var criticas = Model?.Count(c => c.DiasAtraso >= 10) ?? 0;
}

@section Styles {
    <partial name="_CreditoModuleStyles" />
}

@if (TempData["Error"] is string errorMsg)
{
    <div class="mb-4 flex items-center gap-3 rounded-lg border border-rose-500/20 bg-rose-500/10 p-4 text-rose-400">
        <span class="material-symbols-outlined">error</span>
        <p class="text-sm font-medium">@errorMsg</p>
    </div>
}

<div class="space-y-6">

    <section class="card-erp-panel-padded">
        <header class="flex flex-col gap-6 xl:flex-row xl:items-start xl:justify-between">
            <div class="max-w-3xl space-y-3">
                <span class="badge-erp badge-erp-danger">
                    <span class="material-symbols-outlined text-sm">warning</span>
                    Gestión de mora
                </span>
                <div class="space-y-2">
                    <h1 class="text-3xl font-black tracking-tight text-white sm:text-4xl">Cuotas Vencidas</h1>
                    <p class="max-w-2xl text-sm leading-relaxed text-slate-400 sm:text-base">
                        Seguimiento de cuotas con vencimiento superado. Accedé al crédito correspondiente para registrar el cobro o gestionar la mora.
                    </p>
                </div>
            </div>

            <div class="flex w-full flex-col gap-3 sm:flex-row xl:w-auto">
                <a asp-action="Index"
                   class="btn-erp-ghost w-full sm:w-auto sm:py-2.5 no-underline">
                    <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                    Volver a créditos
                </a>
            </div>
        </header>

        <div class="mt-6 grid grid-cols-2 gap-4 lg:grid-cols-3">
            <div class="rounded-xl border border-slate-800 bg-slate-950/40 px-4 py-4">
                <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-slate-400">Cuotas vencidas</p>
                <p class="mt-2 text-3xl font-black text-red-400">@total</p>
                <p class="mt-1 text-xs text-slate-400">en la cartera actual</p>
            </div>
            <div class="rounded-xl border border-slate-800 bg-slate-950/40 px-4 py-4">
                <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-slate-400">Saldo pendiente total</p>
                <p class="mt-2 text-3xl font-black text-white">@montoPendienteTotal.ToString("C")</p>
                <p class="mt-1 text-xs text-slate-400">incluye punitorios</p>
            </div>
            <div class="rounded-xl border border-red-500/20 bg-red-500/10 px-4 py-4 lg:col-span-1">
                <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-red-500">Cuotas críticas</p>
                <p class="mt-2 text-3xl font-black text-red-400">@criticas</p>
                <p class="mt-1 text-xs text-red-500">con 10 o más días de atraso</p>
            </div>
        </div>
    </section>

    @if (!Model?.Any() ?? true)
    {
        <section class="card-erp-panel p-12 text-center">
            <span class="material-symbols-outlined text-4xl text-emerald-500">check_circle</span>
            <h2 class="mt-3 text-lg font-bold text-white">Sin cuotas vencidas</h2>
            <p class="mt-1 text-sm text-slate-400">La cartera no presenta cuotas con vencimiento superado al día de hoy.</p>
        </section>
    }
    else
    {
        <section class="card-erp-panel">
            <div class="border-b border-slate-800 px-6 py-5">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-red-500">assignment_late</span>
                    <h2 class="text-lg font-bold text-white">Detalle de cuotas vencidas</h2>
                </div>
            </div>

            <div data-oc-scroll style="--oc-scroll-min-width: 52rem;">
                <p data-oc-scroll-hint hidden class="px-6 pt-3 text-xs font-medium text-slate-400 lg:hidden">
                    Deslizá para ver el detalle completo de vencimiento y saldo.
                </p>
                <div data-oc-scroll-shell>
                    <div data-oc-scroll-fade="left" hidden></div>
                    <div data-oc-scroll-fade="right" hidden></div>
                    <div data-oc-scroll-region tabindex="0" role="region" aria-label="Tabla de cuotas vencidas">
                        <table data-oc-scroll-table class="w-full text-left border-collapse text-sm">
                            <thead>
                                <tr class="border-b border-slate-800">
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-slate-500">Crédito</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-slate-500">Cliente</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-slate-500 text-center">Cuota</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-slate-500">Vencimiento</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-slate-500 text-right">Días atraso</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-slate-500 text-right">Saldo pendiente</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-slate-500 text-right">Punitorio</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-slate-500"></th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-800/50">
                                @foreach (var cuota in Model!)
                                {
                                    var esCritica = cuota.DiasAtraso >= 10;
                                    <tr class="transition-colors hover:bg-slate-800/40">
                                        <td class="px-4 py-3">
                                            <span class="font-mono text-xs font-bold text-primary">@cuota.CreditoNumero</span>
                                        </td>
                                        <td class="px-4 py-3">
                                            <span class="font-semibold text-white">@cuota.ClienteNombre</span>
                                        </td>
                                        <td class="px-4 py-3 text-center">
                                            <span class="inline-flex items-center justify-center rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-bold bg-slate-800 text-slate-300">
                                                #@cuota.NumeroCuota
                                            </span>
                                        </td>
                                        <td class="px-4 py-3 text-slate-400">
                                            @cuota.FechaVencimiento.ToString("dd/MM/yyyy")
                                        </td>
                                        <td class="px-4 py-3 text-right">
                                            <span class="inline-flex items-center justify-end gap-1 font-bold @(esCritica ? "text-red-400" : "text-orange-500 text-orange-400")">
                                                @if (esCritica)
                                                {
                                                    <span class="material-symbols-outlined text-sm">warning</span>
                                                }
                                                @cuota.DiasAtraso d
                                            </span>
                                        </td>
                                        <td class="px-4 py-3 text-right font-bold text-white">
                                            @cuota.SaldoPendiente.ToString("C")
                                        </td>
                                        <td class="px-4 py-3 text-right">
                                            @if (cuota.MontoPunitorio > 0)
                                            {
                                                <span class="font-medium text-orange-500 text-orange-400">@cuota.MontoPunitorio.ToString("C")</span>
                                            }
                                            else
                                            {
                                                <span class="text-slate-400">—</span>
                                            }
                                        </td>
                                        <td class="px-4 py-3 text-right">
                                            <a asp-action="PagarCuota" asp-route-id="@cuota.CreditoId" asp-route-cuotaId="@cuota.Id"
                                               class="inline-flex items-center gap-1 rounded-lg bg-primary/10 px-3 py-1.5 text-xs font-bold text-primary transition-colors hover:bg-primary/20 no-underline">
                                                <span class="material-symbols-outlined text-sm">payments</span>
                                                Pagar
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </section>
    }

</div>

@section Scripts {
    <script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
    <script src="~/js/shared-ui.js" asp-append-version="true"></script>
}
