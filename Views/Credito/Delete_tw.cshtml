@model CreditoViewModel
@using TheBuryProject.Models.Enums
@{
    ViewData["Title"] = $"Eliminar Crédito {Model.Numero}";

    var returnUrl = ViewData["ReturnUrl"] as string;
    var volverHref = !string.IsNullOrWhiteSpace(returnUrl)
        ? returnUrl
        : Url.Action("Details", "Credito", new { id = Model.Id }) ?? $"/Credito/Details/{Model.Id}";

    var creditoLabel = Model.Numero ?? $"Credito #{Model.Id}";
    var cuotasGeneradas = Model.Cuotas?.Count ?? 0;

    string estadoBg = Model.Estado switch
    {
        EstadoCredito.Solicitado => "chip-warn",
        EstadoCredito.Aprobado => "chip-info",
        EstadoCredito.Activo => "chip-ok",
        EstadoCredito.Generado => "chip-ok",
        EstadoCredito.Configurado => "chip-info",
        EstadoCredito.PendienteConfiguracion => "chip-warn",
        EstadoCredito.Rechazado => "chip-bad",
        EstadoCredito.Cancelado => "chip-bad",
        EstadoCredito.Finalizado => "chip-neutral",
        _ => "chip-neutral"
    };
}

<header class="topbar">
    <div class="shell topbar-inner">
        <div class="brand">
            <span class="brand-badge">
                <span class="material-symbols-outlined" style="color:#fff;font-size:18px" aria-hidden="true">credit_score</span>
            </span>
            Creditos
        </div>
        <nav class="breadcrumb" style="margin-left:.5rem" aria-label="Migas de pan">
            <span class="sep">/</span>
            <a asp-controller="Credito" asp-action="Index">Creditos</a>
            <span class="sep">/</span>
            <span style="color:#cbd5e1">Eliminar @creditoLabel</span>
        </nav>
        <div style="margin-left:auto" class="flex items-center gap-2">
            <span class="hide-mobile text-xs muted-2 mono">Casa Central</span>
            <div class="w-8 h-8 rounded-full bg-slate-700 grid place-items-center text-xs font-semibold text-slate-200" aria-hidden="true">LF</div>
        </div>
    </div>
</header>

<main class="shell" style="padding-top:1.5rem;padding-bottom:3rem;max-width:560px">
    <a href="@volverHref" class="inline-flex items-center gap-1.5 text-sm muted hover:text-white transition" style="text-decoration:none">
        <span class="material-symbols-outlined" style="font-size:18px" aria-hidden="true">arrow_back</span>
        Volver a creditos
    </a>

    @if (TempData["Error"] is string errorMsg)
    {
        <div class="alert alert-bad" style="margin-top:1rem" role="alert">
            <span class="material-symbols-outlined" aria-hidden="true">error</span>
            <span>@errorMsg</span>
        </div>
    }

    <div class="card card-pad" style="margin-top:1rem;border-color:rgba(244,63,94,.3)">
        <div class="flex items-start gap-3">
            <div class="w-11 h-11 rounded-xl grid place-items-center shrink-0" style="background:rgba(244,63,94,.12);border:1px solid rgba(244,63,94,.3)">
                <span class="material-symbols-outlined" style="color:#fb7185;font-size:24px" aria-hidden="true">delete_forever</span>
            </div>
            <div class="flex-1">
                <h1 class="text-lg font-semibold text-white">Eliminar credito <span class="mono">@creditoLabel</span></h1>
                <p class="text-sm muted mt-1">Esta accion elimina el credito de forma permanente. No se puede deshacer.</p>
            </div>
        </div>

        <div class="card-2" style="padding:1rem 1.1rem;border-radius:12px;margin-top:1.25rem">
            <dl class="kv">
                <div class="kv-row"><dt>Id</dt><dd class="mono">@Model.Id</dd></div>
                <div class="kv-row"><dt>N° de credito</dt><dd class="mono">@creditoLabel</dd></div>
                <div class="kv-row"><dt>Cliente</dt><dd>@(Model.ClienteNombre ?? "-")</dd></div>
                <div class="kv-row"><dt>Estado</dt><dd><span class="chip @estadoBg">@Model.Estado</span></dd></div>
                <div class="kv-row"><dt>Monto solicitado</dt><dd class="num">@Model.MontoSolicitado.ToString("C2")</dd></div>
                <div class="kv-row"><dt>Saldo pendiente</dt><dd class="num">@Model.SaldoPendiente.ToString("C2")</dd></div>
                <div class="kv-row"><dt>Cuotas generadas</dt><dd>@cuotasGeneradas / @Model.CantidadCuotas</dd></div>
                <div class="kv-row"><dt>Fecha solicitud</dt><dd>@Model.FechaSolicitud.ToString("dd/MM/yyyy")</dd></div>
                @if (!string.IsNullOrWhiteSpace(Model.Observaciones))
                {
                    <div class="kv-row"><dt>Observaciones</dt><dd>@Model.Observaciones</dd></div>
                }
            </dl>
        </div>

        <div class="alert alert-bad" style="margin-top:1rem">
            <span class="material-symbols-outlined" aria-hidden="true">warning</span>
            <div>Solo se pueden eliminar creditos sin cuotas pagadas. Si el credito tuviera pagos, usa <strong>Cancelar</strong> en lugar de eliminar.</div>
        </div>

        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" style="margin-top:1.25rem">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            @if (returnUrl != null)
            {
                <input type="hidden" name="returnUrl" value="@returnUrl" />
            }

            <div class="flex flex-col-reverse sm:flex-row justify-end gap-2">
                <a href="@volverHref" class="btn btn-ghost">Cancelar</a>
                <button type="submit" class="btn btn-danger">
                    <span class="material-symbols-outlined" aria-hidden="true">delete_forever</span>
                    Eliminar definitivamente
                </button>
            </div>
        </form>
    </div>
</main>

@section Styles {
    <partial name="_CreditoModuleStyles" />
}
