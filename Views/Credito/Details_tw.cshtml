@using TheBuryProject.Models.Enums
@model CreditoDetalleViewModel
@{
    ViewData["Title"] = "Detalle de Crédito";

    var cr = Model.Credito;
    var cuotas = cr.Cuotas ?? new List<CuotaViewModel>();
    var returnUrl = ViewData["ReturnUrl"] as string;
    var contratoVentaCredito = ViewBag.ContratoVentaCredito as ContratoVentaCreditoResumenViewModel;

    var creditoNumero = cr.Numero ?? $"CR-{cr.Id:D3}";
    var cuotasPagadas = cuotas.Count(c => c.Estado == EstadoCuota.Pagada);
    var cuotasVencidas = cuotas.Where(c => c.EstaVencida).ToList();
    var totalCuotas = cuotas.Count;
    var cuotasPendientes = cuotas.Count(c => c.Estado == EstadoCuota.Pendiente || c.Estado == EstadoCuota.Vencida || c.Estado == EstadoCuota.Parcial);
    var progresoPago = totalCuotas > 0 ? Math.Round((decimal)cuotasPagadas / totalCuotas * 100, 0) : 0;
    var volverHref = !string.IsNullOrWhiteSpace(returnUrl)
        ? returnUrl
        : Url.Action("Index", "Credito") ?? "/Credito";
    var puedeCobrar = cr.Estado == EstadoCredito.Activo || cr.Estado == EstadoCredito.Generado;
    var puedeCancelar = cr.Estado != EstadoCredito.Cancelado && cr.Estado != EstadoCredito.Finalizado && cr.Estado != EstadoCredito.Rechazado;
    var montoEnMora = cuotasVencidas.Sum(c => c.SaldoPendiente);
    var punitoriosEnMora = cuotasVencidas.Sum(c => c.MontoPunitorio);
    var saldoPendienteCuotas = cuotas
        .Where(c => c.Estado == EstadoCuota.Pendiente || c.Estado == EstadoCuota.Vencida || c.Estado == EstadoCuota.Parcial)
        .Sum(c => c.SaldoPendiente);
    var primeraMora = cuotasVencidas.OrderByDescending(c => c.DiasAtraso).FirstOrDefault();
    var montoOtorgado = cr.MontoAprobado > 0 ? cr.MontoAprobado : cr.MontoSolicitado;
    var cliente = Model.Cliente;
    var fuenteRestriccionCuotas = cr.FuenteRestriccionCuotasSnap;
    var esRestriccionProducto = string.Equals(fuenteRestriccionCuotas, "Producto", StringComparison.OrdinalIgnoreCase);
    var esRestriccionGlobal = string.Equals(fuenteRestriccionCuotas, "Global", StringComparison.OrdinalIgnoreCase);
    var restriccionCuotasLabel = esRestriccionProducto ? "Restringido por producto" : "Sin restricción por producto";

    string estadoChipClass;
    string estadoIcon;
    switch (cr.Estado)
    {
        case EstadoCredito.Activo:
        case EstadoCredito.Generado:
            estadoChipClass = cuotasVencidas.Any() ? "chip-bad" : "chip-ok";
            estadoIcon = cuotasVencidas.Any() ? "running_with_errors" : "check_circle";
            break;
        case EstadoCredito.Solicitado:
        case EstadoCredito.PendienteConfiguracion:
            estadoChipClass = "chip-warn";
            estadoIcon = "hourglass_top";
            break;
        case EstadoCredito.Aprobado:
        case EstadoCredito.Configurado:
            estadoChipClass = "chip-info";
            estadoIcon = "verified";
            break;
        case EstadoCredito.Rechazado:
        case EstadoCredito.Cancelado:
            estadoChipClass = "chip-bad";
            estadoIcon = "block";
            break;
        default:
            estadoChipClass = "chip-neutral";
            estadoIcon = "flag";
            break;
    }


    string Iniciales(string? nombre)
    {
        if (string.IsNullOrWhiteSpace(nombre))
        {
            return "?";
        }

        var partes = nombre.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return string.Concat(partes.Take(2).Select(p => char.ToUpperInvariant(p[0])));
    }

    string CuotaChip(EstadoCuota estado, bool estaVencida)
    {
        if (estaVencida)
        {
            return "chip-bad";
        }

        return estado switch
        {
            EstadoCuota.Pagada => "chip-ok",
            EstadoCuota.Parcial => "chip-warn",
            EstadoCuota.Cancelada => "chip-neutral",
            _ => "chip-neutral"
        };
    }
}

@section Styles {
    <partial name="_CreditoModuleStyles" />
}

<div data-credito-details>
    <main class="shell" style="padding-top:1.5rem;padding-bottom:3rem">
        <a href="@volverHref" class="inline-flex items-center gap-1.5 text-sm muted hover:text-white transition" style="text-decoration:none">
            <span class="material-symbols-outlined" style="font-size:18px">arrow_back</span>
            Volver a créditos
        </a>

        <div class="page-head" style="margin-top:.95rem">
            <div class="min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                    <h1 class="page-title" style="font-size:1.4rem">Crédito <span class="mono">@creditoNumero</span></h1>
                    <span class="chip @estadoChipClass"><span class="material-symbols-outlined">@estadoIcon</span>@cr.Estado</span>
                    @if (cuotasVencidas.Any())
                    {
                        <span class="chip chip-bad"><span class="material-symbols-outlined">error</span>@cuotasVencidas.Count cuota@(cuotasVencidas.Count == 1 ? "" : "s") vencida@(cuotasVencidas.Count == 1 ? "" : "s")</span>
                    }
                </div>
                <p class="page-sub" style="margin-top:.3rem">
                    Cliente
                    <a asp-controller="Cliente" asp-action="Details" asp-route-id="@cliente.Id" class="text-slate-300 hover:text-white" style="text-decoration:none">@cliente.NombreCompleto</a>
                    · DNI <span class="mono">@cliente.NumeroDocumento</span>
                    · Solicitado @cr.FechaSolicitud.ToString("dd/MM/yyyy")
                </p>
            </div>
            <div data-credito-header-actions class="head-actions">
                <button type="button" class="btn btn-ghost" onclick="window.print()"><span class="material-symbols-outlined">print</span>Imprimir</button>
                <a asp-action="Edit" asp-route-id="@cr.Id" class="btn btn-soft"><span class="material-symbols-outlined">edit</span>Editar</a>
                @if (cr.Estado == EstadoCredito.Solicitado)
                {
                    <button type="button" id="btn-aprobar" class="btn btn-success" data-credito-modal-action="open" data-credito-modal-target="aprobar"><span class="material-symbols-outlined">check_circle</span>Aprobar</button>
                    <button type="button" id="btn-rechazar" class="btn btn-danger" data-credito-modal-action="open" data-credito-modal-target="rechazar"><span class="material-symbols-outlined">block</span>Rechazar</button>
                }
                @if (puedeCobrar)
                {
                    <a asp-action="AdelantarCuota" asp-route-id="@cr.Id" class="btn btn-soft"><span class="material-symbols-outlined">fast_forward</span>Adelantar</a>
                    <a asp-action="PagarCuota" asp-route-id="@cr.Id" class="btn btn-primary"><span class="material-symbols-outlined">payments</span>Pagar cuota</a>
                }
            </div>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-ok" style="margin-top:1rem" role="status"><span class="material-symbols-outlined">check_circle</span><span>@TempData["Success"]</span></div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-bad" style="margin-top:1rem" role="alert"><span class="material-symbols-outlined">error</span><span>@TempData["Error"]</span></div>
        }
        @if (TempData["Warning"] != null)
        {
            <div class="alert alert-warn" style="margin-top:1rem" role="status"><span class="material-symbols-outlined">warning</span><span>@TempData["Warning"]</span></div>
        }

        <div class="grid-kpi" style="margin-top:1.5rem">
            <div class="kpi">
                <div class="kpi-label"><span class="material-symbols-outlined" style="font-size:15px">request_quote</span>Monto otorgado</div>
                <div class="kpi-value">$ @montoOtorgado.ToString("N0")</div>
                <div class="kpi-foot">capital · @cr.CantidadCuotas cuota@(cr.CantidadCuotas == 1 ? "" : "s")</div>
            </div>
            <div class="kpi kpi--accent">
                <div class="kpi-label"><span class="material-symbols-outlined" style="font-size:15px">account_balance_wallet</span>Saldo pendiente</div>
                <div class="kpi-value">$ @cr.SaldoPendiente.ToString("N0")</div>
                <div class="mt-2 bar"><div class="bar-fill is-accent" style="width:@progresoPago%"></div></div>
                <div class="kpi-foot">@progresoPago% pagado</div>
            </div>
            <div class="kpi">
                <div class="kpi-label"><span class="material-symbols-outlined" style="font-size:15px">checklist</span>Cuotas</div>
                <div class="kpi-value">@cuotasPagadas<span class="text-base muted-2 font-normal"> / @totalCuotas</span></div>
                <div class="kpi-foot">@cuotasPendientes pendiente@(cuotasPendientes == 1 ? "" : "s") · @cuotasVencidas.Count vencida@(cuotasVencidas.Count == 1 ? "" : "s")</div>
            </div>
            <div class="kpi @(cuotasVencidas.Any() ? "kpi--bad" : "kpi--ok")">
                <div class="kpi-label"><span class="material-symbols-outlined" style="font-size:15px">event_busy</span>En mora</div>
                <div class="kpi-value">$ @montoEnMora.ToString("N0")</div>
                <div class="kpi-foot">@(primeraMora != null ? $"cuota {primeraMora.NumeroCuota} · {primeraMora.DiasAtraso} días de atraso" : "sin mora activa")</div>
            </div>
        </div>

        @if (cuotasVencidas.Any())
        {
            <div class="apt-card is-no" style="margin-top:1.25rem">
                <div class="apt-ic"><span class="material-symbols-outlined">running_with_errors</span></div>
                <div class="flex-1 min-w-0">
                    <div class="font-semibold text-white">@cuotasVencidas.Count cuota@(cuotasVencidas.Count == 1 ? "" : "s") en mora</div>
                    <p class="text-sm muted mt-0.5">
                        Deuda vencida $ @montoEnMora.ToString("N2")
                        @if (punitoriosEnMora > 0)
                        {
                            <text> · punitorios $ @punitoriosEnMora.ToString("N2")</text>
                        }
                        . Registrá el pago para regularizar el crédito.
                    </p>
                </div>
                @if (puedeCobrar)
                {
                    <a asp-action="PagarCuota" asp-route-id="@cr.Id" class="btn btn-danger btn-sm shrink-0"><span class="material-symbols-outlined">payments</span>Pagar cuota vencida</a>
                }
            </div>
        }

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4" style="margin-top:1.25rem">
            <div class="lg:col-span-2 space-y-4">
                <section class="card" style="overflow:hidden">
                    <div class="card-pad" style="padding-bottom:.75rem">
                        <div class="flex items-center justify-between gap-3">
                            <h2 class="font-semibold text-white flex items-center gap-2"><span class="material-symbols-outlined" style="color:#f5c518;font-size:20px">calendar_month</span>Plan de cuotas</h2>
                            <div class="scroll-hint hide-mobile"><span class="material-symbols-outlined" style="font-size:15px">swipe</span>Deslizá</div>
                        </div>
                    </div>
                    @if (cuotas.Any())
                    {
                        <div data-oc-scroll style="--oc-scroll-min-width:74rem">
                            <p data-oc-scroll-hint hidden class="text-xs muted-2" style="padding:0 1.25rem .75rem">Deslizá la tabla para ver capital, punitorio y acciones de pago.</p>
                            <div data-oc-scroll-shell>
                                <div data-oc-scroll-fade="left" hidden></div>
                                <div data-oc-scroll-fade="right" hidden></div>
                                <div data-oc-scroll-region tabindex="0" role="region" aria-label="Plan de cuotas del crédito" class="tbl-wrap">
                                    <table data-oc-scroll-table class="tbl">
                                        <thead>
                                            <tr>
                                                <th>Cuota</th>
                                                <th>Vencimiento</th>
                                                <th style="text-align:right">Capital</th>
                                                <th style="text-align:right">Interés</th>
                                                <th style="text-align:right">Total</th>
                                                <th style="text-align:right">Mora</th>
                                                <th style="text-align:right">Pagado</th>
                                                <th>Estado</th>
                                                <th style="text-align:right">Acción</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var cuota in cuotas.OrderBy(c => c.NumeroCuota))
                                            {
                                                var estaVencida = cuota.EstaVencida;
                                                var cuotaNumeroClass = cuota.Estado == EstadoCuota.Pagada ? "ok" : estaVencida ? "venc" : "";
                                                <tr class="@(estaVencida ? "is-venc" : "")">
                                                    <td><span class="cuota-n @cuotaNumeroClass">@cuota.NumeroCuota</span></td>
                                                    <td>
                                                        @cuota.FechaVencimiento.ToString("dd/MM/yyyy")
                                                        @if (estaVencida)
                                                        {
                                                            <span class="chip chip-bad" style="margin-left:.3rem">+@cuota.DiasAtraso d</span>
                                                        }
                                                    </td>
                                                    <td class="num" style="text-align:right">$ @cuota.MontoCapital.ToString("N2")</td>
                                                    <td class="num" style="text-align:right">$ @cuota.MontoInteres.ToString("N2")</td>
                                                    <td class="num" style="text-align:right;font-weight:600;color:#fff">$ @cuota.MontoTotal.ToString("N2")</td>
                                                    <td class="num @(cuota.MontoPunitorio > 0 ? "" : "dash")" style="text-align:right;@(cuota.MontoPunitorio > 0 ? "color:#fbbf24" : "")">@(cuota.MontoPunitorio > 0 ? $"$ {cuota.MontoPunitorio:N2}" : "—")</td>
                                                    <td class="num @(cuota.MontoPagado > 0 ? "" : "dash")" style="text-align:right;@(cuota.MontoPagado > 0 ? "color:#34d399" : "")">
                                                        @(cuota.MontoPagado > 0 ? $"$ {cuota.MontoPagado:N2}" : "—")
                                                        @if (cuota.FechaPago.HasValue)
                                                        {
                                                            <span class="block text-xs muted-2">@cuota.FechaPago.Value.ToString("dd/MM/yyyy")</span>
                                                        }
                                                    </td>
                                                    <td><span class="chip @CuotaChip(cuota.Estado, estaVencida)">@(estaVencida && cuota.Estado == EstadoCuota.Pendiente ? "Vencida" : cuota.EstadoTexto)</span></td>
                                                    <td style="text-align:right">
                                                        @if (cuota.Estado == EstadoCuota.Pendiente || cuota.Estado == EstadoCuota.Vencida || cuota.Estado == EstadoCuota.Parcial)
                                                        {
                                                            <a asp-action="PagarCuota" asp-route-id="@cr.Id" asp-route-cuotaId="@cuota.Id" class="btn @(estaVencida ? "btn-danger" : "btn-soft") btn-sm">Pagar</a>
                                                        }
                                                        else if (cuota.Estado == EstadoCuota.Pagada && !string.IsNullOrEmpty(cuota.ComprobantePago))
                                                        {
                                                            <span class="text-xs muted-2" title="@cuota.ComprobantePago">Comprobante</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot>
                                            <tr style="background:rgba(15,23,42,.5)">
                                                <td colspan="4" style="padding:.7rem 1rem;font-weight:600;color:var(--muted)">Saldo pendiente (@cuotasPendientes cuota@(cuotasPendientes == 1 ? "" : "s"))</td>
                                                <td class="num" style="text-align:right;padding:.7rem 1rem;font-weight:600;color:#fff">$ @saldoPendienteCuotas.ToString("N2")</td>
                                                <td class="num" style="text-align:right;color:#fbbf24">$ @punitoriosEnMora.ToString("N2")</td>
                                                <td colspan="3"></td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="empty">
                            <div class="empty-ic"><span class="material-symbols-outlined">receipt_long</span></div>
                            <h3>Sin cuotas generadas aún</h3>
                            <p>El plan de cuotas aparecerá cuando el crédito esté activo o generado.</p>
                        </div>
                    }
                </section>
            </div>

            <aside class="space-y-4">
                <div class="card card-pad">
                    <h3 class="font-semibold text-white mb-3 flex items-center gap-2"><span class="material-symbols-outlined" style="color:#94a3b8;font-size:20px">person</span>Cliente</h3>
                    <div class="flex items-center gap-3">
                        <div class="avatar avatar-lg">@Iniciales(cliente.NombreCompleto)</div>
                        <div class="min-w-0">
                            <div class="font-medium text-white">@cliente.NombreCompleto</div>
                            <div class="text-xs muted-2 mono">DNI @cliente.NumeroDocumento</div>
                            <span class="chip chip-ok" style="margin-top:.4rem"><span class="material-symbols-outlined">verified</span>Cliente</span>
                        </div>
                    </div>
                    <dl class="kv mt-3">
                        @if (!string.IsNullOrEmpty(cliente.Telefono))
                        {
                            <div class="kv-row"><dt>Teléfono</dt><dd>@cliente.Telefono</dd></div>
                        }
                        @if (!string.IsNullOrEmpty(cliente.Email))
                        {
                            <div class="kv-row"><dt>Email</dt><dd>@cliente.Email</dd></div>
                        }
                        @if (cliente.Sueldo.HasValue)
                        {
                            <div class="kv-row"><dt>Ingreso declarado</dt><dd class="num">$ @cliente.Sueldo.Value.ToString("N2")</dd></div>
                        }
                        <div class="kv-row"><dt>Riesgo</dt><dd>@cliente.PuntajeRiesgo.ToString("N0") pts</dd></div>
                        @if (Model.CupoGlobalDisponible.HasValue && !Model.CupoGlobalConError)
                        {
                            <div class="kv-row"><dt>Crédito disponible</dt><dd class="num">$ @Model.CupoGlobalDisponible.Value.ToString("N2")</dd></div>
                        }
                    </dl>
                    <a asp-controller="Cliente" asp-action="Details" asp-route-id="@cliente.Id" class="btn btn-ghost btn-sm btn-block" style="margin-top:.9rem">Ver legajo del cliente<span class="material-symbols-outlined">chevron_right</span></a>
                </div>

                <div class="card card-pad">
                    <h3 class="font-semibold text-white mb-3 flex items-center gap-2"><span class="material-symbols-outlined" style="color:#f5c518;font-size:20px">savings</span>Resumen financiero</h3>
                    <div class="result-card" style="padding:.85rem 1rem">
                        <div class="result-label">Total a cobrar (capital + interés)</div>
                        <div class="result-value" style="font-size:1.5rem">$ @cr.TotalAPagar.ToString("N2")</div>
                    </div>
                    <dl class="kv mt-3">
                        <div class="kv-row"><dt>Monto solicitado</dt><dd class="num">$ @cr.MontoSolicitado.ToString("N2")</dd></div>
                        <div class="kv-row"><dt>Monto aprobado</dt><dd class="num">$ @cr.MontoAprobado.ToString("N2")</dd></div>
                        <div class="kv-row"><dt>Tasa mensual</dt><dd>@cr.TasaInteres.ToString("N2")%</dd></div>
                        <div class="kv-row"><dt>CFTEA</dt><dd>@cr.CFTEA.ToString("N2")%</dd></div>
                        <div class="kv-row"><dt>Monto por cuota</dt><dd class="num">$ @cr.MontoCuota.ToString("N2")</dd></div>
                        <div class="kv-row"><dt>Saldo pendiente</dt><dd class="num">$ @cr.SaldoPendiente.ToString("N2")</dd></div>
                    </dl>
                </div>

                @if (cr.FuenteRestriccionCuotasSnap != null || cr.CuotasMaximasPermitidas.HasValue || cr.MaxCuotasBaseSnap.HasValue)
                {
                    <div class="card card-pad" data-credito-restriccion-cuotas>
                        <h3 class="font-semibold text-white mb-3 flex items-center gap-2"><span class="material-symbols-outlined" style="color:#f5c518;font-size:20px">rule</span>Restricción de cuotas</h3>
                        <div class="doc-row">
                            <div class="doc-ic"><span class="material-symbols-outlined">@(esRestriccionProducto ? "inventory_2" : "settings")</span></div>
                            <div class="flex-1 min-w-0">
                                <div class="text-sm text-white">@restriccionCuotasLabel</div>
                                <div class="text-xs muted-2">
                                    Fuente snapshot:
                                    @if (esRestriccionProducto)
                                    {
                                        <span>"Producto"</span>
                                    }
                                    else if (esRestriccionGlobal)
                                    {
                                        <span>"Global"</span>
                                    }
                                    else
                                    {
                                        <span>@(fuenteRestriccionCuotas ?? "Sin fuente")</span>
                                    }
                                </div>
                            </div>
                        </div>
                        <dl class="kv mt-3">
                            @if (cr.MaxCuotasBaseSnap.HasValue)
                            {
                                <div class="kv-row"><dt>Máx. cuotas base</dt><dd>@cr.MaxCuotasBaseSnap.Value</dd></div>
                            }
                            @if (cr.CuotasMaximasPermitidas.HasValue)
                            {
                                <div class="kv-row"><dt>Máx. cuotas efectivo</dt><dd>@cr.CuotasMaximasPermitidas.Value</dd></div>
                            }
                            @if (cr.ProductoIdRestrictivoSnap.HasValue)
                            {
                                <div class="kv-row"><dt>ProductoIdRestrictivoSnap</dt><dd class="mono">snapshot #@cr.ProductoIdRestrictivoSnap.Value</dd></div>
                            }
                        </dl>
                    </div>
                }

                @if (contratoVentaCredito != null)
                {
                    <div class="card card-pad">
                        <h3 class="font-semibold text-white mb-3 flex items-center gap-2"><span class="material-symbols-outlined" style="color:#94a3b8;font-size:20px">receipt_long</span>Venta asociada</h3>
                        <div class="doc-row">
                            <div class="doc-ic"><span class="material-symbols-outlined">contract</span></div>
                            <div class="flex-1 min-w-0">
                                <div class="text-sm text-white">Contrato @contratoVentaCredito.NumeroContrato</div>
                                <div class="text-xs muted-2">Pagaré @contratoVentaCredito.NumeroPagare · @contratoVentaCredito.FechaGeneracionUtc.ToLocalTime().ToString("dd/MM/yyyy")</div>
                            </div>
                            <a asp-controller="ContratoVentaCredito" asp-action="Ver" asp-route-ventaId="@contratoVentaCredito.VentaId" target="_blank" rel="noopener" class="btn btn-ghost btn-sm" aria-label="Ver contrato"><span class="material-symbols-outlined">open_in_new</span></a>
                        </div>
                        <dl class="kv mt-3">
                            <div class="kv-row"><dt>Estado documento</dt><dd>@contratoVentaCredito.EstadoDocumento</dd></div>
                            <div class="kv-row"><dt>Usuario</dt><dd>@contratoVentaCredito.UsuarioGeneracion</dd></div>
                        </dl>
                    </div>
                }

                @if (Model.Garante != null)
                {
                    <div class="card card-pad">
                        <h3 class="font-semibold text-white mb-3 flex items-center gap-2"><span class="material-symbols-outlined" style="color:#94a3b8;font-size:20px">shield_person</span>Garante</h3>
                        <div class="flex items-center gap-3">
                            <div class="avatar avatar--slate">@Iniciales(Model.Garante.NombreCompleto)</div>
                            <div class="min-w-0">
                                <a asp-controller="Cliente" asp-action="Details" asp-route-id="@Model.Garante.Id" class="font-medium text-white" style="text-decoration:none">@Model.Garante.NombreCompleto</a>
                                <div class="text-xs muted-2 mono">DNI @Model.Garante.NumeroDocumento</div>
                            </div>
                        </div>
                    </div>
                }

                @if (Model.CupoGlobalConError || Model.CupoGlobalDisponible.HasValue)
                {
                    <div class="card card-pad">
                        <h3 class="font-semibold text-white mb-3 flex items-center gap-2"><span class="material-symbols-outlined" style="color:#f5c518;font-size:20px">account_balance_wallet</span>Cupo global</h3>
                        @if (Model.CupoGlobalConError)
                        {
                            <div class="alert alert-warn"><span class="material-symbols-outlined">warning</span><span>@(Model.CupoGlobalMensajeError ?? "No se pudo calcular el cupo")</span></div>
                        }
                        else
                        {
                            <div class="result-card is-ok">
                                <div class="result-label">Disponible</div>
                                <div class="result-value" style="font-size:1.5rem">$ @Model.CupoGlobalDisponible!.Value.ToString("N2")</div>
                            </div>
                            @if (!string.IsNullOrEmpty(Model.CupoGlobalOrigenLimite))
                            {
                                <p class="hint">Origen: @Model.CupoGlobalOrigenLimite</p>
                            }
                        }
                    </div>
                }

                @if (puedeCancelar)
                {
                    <div class="card card-pad" style="border-color:rgba(244,63,94,.25)">
                        <h3 class="font-semibold text-white mb-1">Zona sensible</h3>
                        <p class="text-sm muted mb-3">Cancelar el crédito anula las cuotas pendientes. Esta acción queda registrada en el historial.</p>
                        <button type="button" id="btn-cancelar" class="btn btn-ghost btn-sm btn-block" style="color:#fb7185;border-color:rgba(244,63,94,.3)" data-credito-modal-action="open" data-credito-modal-target="cancelar"><span class="material-symbols-outlined">cancel</span>Cancelar crédito</button>
                    </div>
                }
            </aside>
        </div>
    </main>
</div>

<div id="modal-aprobar" class="overlay hidden" data-credito-modal="aprobar" role="dialog" aria-modal="true" aria-labelledby="modal-aprobar-title">
    <div class="modal">
        <div class="modal-card card card-pad" style="max-width:460px">
            <div class="flex items-start gap-3">
                <div class="w-10 h-10 rounded-lg grid place-items-center shrink-0" style="background:rgba(16,185,129,.12);border:1px solid rgba(16,185,129,.3)"><span class="material-symbols-outlined" style="color:#34d399">check_circle</span></div>
                <div class="flex-1"><h3 id="modal-aprobar-title" class="font-semibold text-white">Aprobar crédito</h3><p class="text-sm muted mt-0.5">Se generará el plan de cuotas y el crédito pasará a estado activo.</p></div>
                <button type="button" class="btn btn-ghost btn-sm" data-credito-modal-action="close" aria-label="Cerrar"><span class="material-symbols-outlined">close</span></button>
            </div>
            <form asp-action="Aprobar" method="post" style="margin-top:1rem">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@cr.Id" />
                @if (!string.IsNullOrEmpty(returnUrl))
                {
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                }
                <div class="flex justify-end gap-2 mt-4 pt-4" style="border-top:1px solid var(--line)">
                    <button type="button" class="btn btn-ghost" data-credito-modal-action="close">Cancelar</button>
                    <button type="submit" class="btn btn-success"><span class="material-symbols-outlined">check</span>Aprobar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div id="modal-rechazar" class="overlay hidden" data-credito-modal="rechazar" role="dialog" aria-modal="true" aria-labelledby="modal-rechazar-title">
    <div class="modal">
        <div class="modal-card card card-pad" style="max-width:460px">
            <div class="flex items-start gap-3">
                <div class="w-10 h-10 rounded-lg grid place-items-center shrink-0" style="background:rgba(244,63,94,.12);border:1px solid rgba(244,63,94,.3)"><span class="material-symbols-outlined" style="color:#fb7185">block</span></div>
                <div class="flex-1"><h3 id="modal-rechazar-title" class="font-semibold text-white">Rechazar crédito</h3><p class="text-sm muted mt-0.5">El crédito quedará marcado como rechazado. Indicá el motivo.</p></div>
                <button type="button" class="btn btn-ghost btn-sm" data-credito-modal-action="close" aria-label="Cerrar"><span class="material-symbols-outlined">close</span></button>
            </div>
            <form asp-action="Rechazar" method="post" style="margin-top:1rem">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@cr.Id" />
                @if (!string.IsNullOrEmpty(returnUrl))
                {
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                }
                <label class="label">Motivo del rechazo <span class="req">*</span></label>
                <textarea class="field" name="motivo" placeholder="Ej. relación cuota/ingreso excedida..." required></textarea>
                <div class="flex justify-end gap-2 mt-4 pt-4" style="border-top:1px solid var(--line)">
                    <button type="button" class="btn btn-ghost" data-credito-modal-action="close">Cancelar</button>
                    <button type="submit" class="btn btn-danger"><span class="material-symbols-outlined">block</span>Rechazar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div id="modal-cancelar" class="overlay hidden" data-credito-modal="cancelar" role="dialog" aria-modal="true" aria-labelledby="modal-cancelar-title">
    <div class="modal">
        <div class="modal-card card card-pad" style="max-width:460px">
            <div class="flex items-start gap-3">
                <div class="w-10 h-10 rounded-lg grid place-items-center shrink-0" style="background:rgba(244,63,94,.12);border:1px solid rgba(244,63,94,.3)"><span class="material-symbols-outlined" style="color:#fb7185">cancel</span></div>
                <div class="flex-1"><h3 id="modal-cancelar-title" class="font-semibold text-white">Cancelar crédito @creditoNumero</h3><p class="text-sm muted mt-0.5">Se anularán las cuotas pendientes ($ @saldoPendienteCuotas.ToString("N2")). El historial se conserva.</p></div>
                <button type="button" class="btn btn-ghost btn-sm" data-credito-modal-action="close" aria-label="Cerrar"><span class="material-symbols-outlined">close</span></button>
            </div>
            <form asp-action="Cancelar" method="post" style="margin-top:1rem">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@cr.Id" />
                @if (!string.IsNullOrEmpty(returnUrl))
                {
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                }
                <label class="label">Motivo de cancelación <span class="req">*</span></label>
                <textarea class="field" name="motivo" placeholder="Ej. acuerdo de refinanciación..." required></textarea>
                <div class="flex justify-end gap-2 mt-4 pt-4" style="border-top:1px solid var(--line)">
                    <button type="button" class="btn btn-ghost" data-credito-modal-action="close">Volver</button>
                    <button type="submit" class="btn btn-danger"><span class="material-symbols-outlined">cancel</span>Confirmar cancelación</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
    <script src="~/js/credito-module.js" asp-append-version="true"></script>
    <script src="~/js/credito-details.js" asp-append-version="true"></script>
}
