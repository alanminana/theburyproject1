@using TheBuryProject.Models.Enums
@model CreditoDetalleViewModel
@{
    ViewData["Title"] = "Detalle de Crédito";
    var cr = Model.Credito;
    var ev = Model.Evaluacion;
    var cuotas = cr.Cuotas ?? new List<CuotaViewModel>();
    var returnUrl = ViewData["ReturnUrl"] as string;

    var cuotasPagadas = cuotas.Count(c => c.Estado == EstadoCuota.Pagada);
    var cuotasVencidas = cuotas.Where(c => c.EstaVencida).ToList();
    var totalCuotas = cuotas.Count;
    var progresoPago = totalCuotas > 0 ? Math.Round((decimal)cuotasPagadas / totalCuotas * 100, 0) : 0;

    // Estado badge
    string estadoBg;
    switch (cr.Estado)
    {
        case EstadoCredito.Activo:
        case EstadoCredito.Generado:
            estadoBg = cuotasVencidas.Any()
                ? "bg-red-100 dark:bg-red-500/20 text-red-700 dark:text-red-400"
                : "bg-emerald-100 dark:bg-emerald-500/20 text-emerald-700 dark:text-emerald-400";
            break;
        case EstadoCredito.Solicitado:
        case EstadoCredito.PendienteConfiguracion:
            estadoBg = "bg-orange-100 dark:bg-orange-500/20 text-orange-700 dark:text-orange-400";
            break;
        case EstadoCredito.Aprobado:
        case EstadoCredito.Configurado:
            estadoBg = "bg-blue-100 dark:bg-blue-500/20 text-blue-700 dark:text-blue-400";
            break;
        case EstadoCredito.Rechazado:
            estadoBg = "bg-red-100 dark:bg-red-500/20 text-red-700 dark:text-red-400";
            break;
        default:
            estadoBg = "bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300";
            break;
    }

    // Evaluación colores Tailwind (ColorSemaforo retorna success/warning/danger)
    string evalBg = "", evalBorder = "", evalText = "", evalIcon = "";
    if (ev != null)
    {
        switch (ev.ColorSemaforo)
        {
            case "success":
                evalBg = "bg-emerald-50 dark:bg-emerald-500/5";
                evalBorder = "border-emerald-200 dark:border-emerald-500/20";
                evalText = "text-emerald-700 dark:text-emerald-400";
                evalIcon = "check_circle";
                break;
            case "warning":
                evalBg = "bg-amber-50 dark:bg-amber-500/5";
                evalBorder = "border-amber-200 dark:border-amber-500/20";
                evalText = "text-amber-700 dark:text-amber-400";
                evalIcon = "warning";
                break;
            case "danger":
                evalBg = "bg-red-50 dark:bg-red-500/5";
                evalBorder = "border-red-200 dark:border-red-500/20";
                evalText = "text-red-700 dark:text-red-400";
                evalIcon = "cancel";
                break;
            default:
                evalBg = "bg-slate-50 dark:bg-slate-900/50";
                evalBorder = "border-slate-200 dark:border-slate-800";
                evalText = "text-slate-600 dark:text-slate-300";
                evalIcon = "help";
                break;
        }
    }
}

<div class="space-y-6">

    <!-- Header -->
    <div>
        <nav class="flex items-center gap-2 text-xs font-medium text-slate-500 dark:text-slate-400 mb-4">
            <a asp-controller="Home" asp-action="Index" class="hover:text-primary no-underline">Inicio</a>
            <span class="material-symbols-outlined text-[14px]">chevron_right</span>
            <a asp-controller="Credito" asp-action="Index" class="hover:text-primary no-underline">Créditos</a>
            <span class="material-symbols-outlined text-[14px]">chevron_right</span>
            <span class="text-slate-900 dark:text-slate-100">@(cr.Numero ?? $"CR-{cr.Id:D3}")</span>
        </nav>
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
            <div>
                <h2 class="text-3xl font-bold tracking-tight">Crédito @(cr.Numero ?? $"CR-{cr.Id:D3}")</h2>
                <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">
                    Cliente: <span class="font-semibold text-slate-700 dark:text-slate-200">@cr.ClienteNombre</span>
                    &mdash; Solicitado el @cr.FechaSolicitud.ToString("dd/MM/yyyy")
                </p>
            </div>
            <div class="flex flex-wrap gap-2">
                @if (cr.Estado == EstadoCredito.Solicitado)
                {
                    <button type="button" id="btn-aprobar"
                            class="px-4 py-2 rounded-lg bg-emerald-600 text-white text-sm font-bold hover:bg-emerald-700 shadow-lg shadow-emerald-600/20 transition-colors flex items-center gap-2">
                        <span class="material-symbols-outlined text-[18px]">check_circle</span> Aprobar
                    </button>
                    <button type="button" id="btn-rechazar"
                            class="px-4 py-2 rounded-lg bg-red-600 text-white text-sm font-bold hover:bg-red-700 shadow-lg shadow-red-600/20 transition-colors flex items-center gap-2">
                        <span class="material-symbols-outlined text-[18px]">cancel</span> Rechazar
                    </button>
                }
                @if (cr.Estado == EstadoCredito.Activo || cr.Estado == EstadoCredito.Generado)
                {
                    <a asp-action="PagarCuota" asp-route-id="@cr.Id"
                       class="px-4 py-2 rounded-lg bg-primary text-white text-sm font-bold hover:bg-blue-700 shadow-lg shadow-primary/20 no-underline transition-colors flex items-center gap-2">
                        <span class="material-symbols-outlined text-[18px]">payments</span> Pagar Cuota
                    </a>
                    <a asp-action="AdelantarCuota" asp-route-id="@cr.Id"
                       class="px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-sm font-medium text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-700 no-underline transition-colors flex items-center gap-2">
                        <span class="material-symbols-outlined text-[18px]">fast_forward</span> Adelantar
                    </a>
                }
                @if (cr.Estado != EstadoCredito.Cancelado && cr.Estado != EstadoCredito.Finalizado && cr.Estado != EstadoCredito.Rechazado)
                {
                    <button type="button" id="btn-cancelar"
                            class="px-4 py-2 rounded-lg border border-red-200 dark:border-red-500/30 bg-white dark:bg-slate-800 text-sm font-medium text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-500/10 transition-colors flex items-center gap-2">
                        <span class="material-symbols-outlined text-[18px]">block</span> Cancelar
                    </button>
                }
                <a asp-action="Index"
                   class="px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-sm font-medium text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-700 no-underline transition-colors flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">arrow_back</span> Volver
                </a>
            </div>
        </div>
    </div>

    <!-- TempData Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="rounded-xl border border-emerald-500/50 bg-emerald-50 dark:bg-emerald-500/10 p-4 flex items-center gap-3 text-emerald-700 dark:text-emerald-400">
            <span class="material-symbols-outlined">check_circle</span>
            <span class="text-sm font-medium">@TempData["Success"]</span>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="rounded-xl border border-red-500/50 bg-red-50 dark:bg-red-500/10 p-4 flex items-center gap-3 text-red-700 dark:text-red-400">
            <span class="material-symbols-outlined">error</span>
            <span class="text-sm font-medium">@TempData["Error"]</span>
        </div>
    }
    @if (TempData["Warning"] != null)
    {
        <div class="rounded-xl border border-amber-500/50 bg-amber-50 dark:bg-amber-500/10 p-4 flex items-center gap-3 text-amber-700 dark:text-amber-400">
            <span class="material-symbols-outlined">warning</span>
            <span class="text-sm font-medium">@TempData["Warning"]</span>
        </div>
    }

    <!-- Mora Alert -->
    @if (cuotasVencidas.Any())
    {
        <div class="rounded-xl border border-red-500/50 bg-red-50 dark:bg-red-500/10 p-5 flex items-start gap-4">
            <div class="bg-red-500 text-white rounded-full p-1 flex-shrink-0">
                <span class="material-symbols-outlined text-[24px]">priority_high</span>
            </div>
            <div class="flex-1">
                <h4 class="text-red-700 dark:text-red-400 font-bold text-lg">Cuotas en Mora</h4>
                <p class="text-red-600 dark:text-red-300 text-sm mt-1">
                    <span class="font-bold">@cuotasVencidas.Count cuota(s) vencida(s)</span> &mdash;
                    Deuda total mora: <span class="font-bold">$ @cuotasVencidas.Sum(c => c.SaldoPendiente).ToString("N2")</span>
                    @{ var maxDias = cuotasVencidas.Max(c => c.DiasAtraso); }
                    @if (maxDias > 0)
                    {
                        <text>&mdash; Máximo atraso: <span class="font-bold">@maxDias días</span></text>
                    }
                </p>
            </div>
            <a asp-action="PagarCuota" asp-route-id="@cr.Id"
               class="flex-shrink-0 px-4 py-2 rounded-lg bg-red-600 text-white text-sm font-bold hover:bg-red-700 no-underline transition-colors">
                Pagar Mora
            </a>
        </div>
    }

    <!-- Top Stats Cards -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Estado -->
        <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 p-5">
            <p class="text-[10px] font-bold uppercase text-slate-400 tracking-wider mb-2">Estado</p>
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold @estadoBg">
                @cr.Estado.ToString()
            </span>
            @if (cr.FechaAprobacion.HasValue)
            {
                <p class="text-[10px] text-slate-400 mt-2">Aprobado: @cr.FechaAprobacion.Value.ToString("dd/MM/yyyy")</p>
            }
        </div>

        <!-- Monto -->
        <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 p-5">
            <p class="text-[10px] font-bold uppercase text-slate-400 tracking-wider mb-2">Monto Total</p>
            <p class="text-2xl font-black text-slate-900 dark:text-white leading-none">$ @cr.TotalAPagar.ToString("N2")</p>
            <p class="text-[10px] text-slate-400 mt-2">Solicitado: $ @cr.MontoSolicitado.ToString("N2")</p>
        </div>

        <!-- Saldo -->
        <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 p-5">
            <p class="text-[10px] font-bold uppercase text-slate-400 tracking-wider mb-2">Saldo Pendiente</p>
            <p class="text-2xl font-black @(cr.SaldoPendiente > 0 ? "text-red-600 dark:text-red-400" : "text-emerald-600 dark:text-emerald-400") leading-none">
                $ @cr.SaldoPendiente.ToString("N2")
            </p>
            @if (totalCuotas > 0)
            {
                <p class="text-[10px] text-slate-400 mt-2">@cuotasPagadas / @totalCuotas cuotas pagadas</p>
            }
        </div>

        <!-- Progreso -->
        <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 p-5">
            <p class="text-[10px] font-bold uppercase text-slate-400 tracking-wider mb-2">Progreso</p>
            <p class="text-2xl font-black text-slate-900 dark:text-white leading-none">@progresoPago%</p>
            <div class="mt-2 h-2 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
                <div class="h-full bg-primary rounded-full transition-all" style="width: @(progresoPago)%"></div>
            </div>
        </div>
    </div>

    <!-- Main Grid: Info + Client -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- Credit Details (2 cols) -->
        <div class="lg:col-span-2 bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 p-6">
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-5 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">description</span>
                Información del Crédito
            </h3>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-y-5 gap-x-6">
                <div>
                    <p class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">Número</p>
                    <p class="text-sm font-semibold text-slate-900 dark:text-white mt-0.5">@(cr.Numero ?? $"CR-{cr.Id:D3}")</p>
                </div>
                <div>
                    <p class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">Monto Solicitado</p>
                    <p class="text-sm font-semibold text-slate-900 dark:text-white mt-0.5">$ @cr.MontoSolicitado.ToString("N2")</p>
                </div>
                <div>
                    <p class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">Monto Aprobado</p>
                    <p class="text-sm font-semibold text-slate-900 dark:text-white mt-0.5">$ @cr.MontoAprobado.ToString("N2")</p>
                </div>
                <div>
                    <p class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">Tasa Interés Mensual</p>
                    <p class="text-sm font-semibold text-slate-900 dark:text-white mt-0.5">@cr.TasaInteres.ToString("N2")%</p>
                </div>
                <div>
                    <p class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">CFTEA</p>
                    <p class="text-sm font-semibold text-slate-900 dark:text-white mt-0.5">@cr.CFTEA.ToString("N2")%</p>
                </div>
                <div>
                    <p class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">Cuotas</p>
                    <p class="text-sm font-semibold text-slate-900 dark:text-white mt-0.5">@cr.CantidadCuotas</p>
                </div>
                <div>
                    <p class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">Monto por Cuota</p>
                    <p class="text-sm font-semibold text-slate-900 dark:text-white mt-0.5">$ @cr.MontoCuota.ToString("N2")</p>
                </div>
                <div>
                    <p class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">Total a Pagar</p>
                    <p class="text-sm font-semibold text-slate-900 dark:text-white mt-0.5">$ @cr.TotalAPagar.ToString("N2")</p>
                </div>
                <div>
                    <p class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">Saldo Pendiente</p>
                    <p class="text-sm font-semibold @(cr.SaldoPendiente > 0 ? "text-red-600 dark:text-red-400" : "text-emerald-600 dark:text-emerald-400") mt-0.5">
                        $ @cr.SaldoPendiente.ToString("N2")
                    </p>
                </div>
                <div>
                    <p class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">Fecha Solicitud</p>
                    <p class="text-sm font-semibold text-slate-900 dark:text-white mt-0.5">@cr.FechaSolicitud.ToString("dd/MM/yyyy")</p>
                </div>
                @if (cr.FechaAprobacion.HasValue)
                {
                    <div>
                        <p class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">Fecha Aprobación</p>
                        <p class="text-sm font-semibold text-slate-900 dark:text-white mt-0.5">@cr.FechaAprobacion.Value.ToString("dd/MM/yyyy")</p>
                    </div>
                }
                @if (cr.FechaPrimeraCuota.HasValue)
                {
                    <div>
                        <p class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">Primera Cuota</p>
                        <p class="text-sm font-semibold text-slate-900 dark:text-white mt-0.5">@cr.FechaPrimeraCuota.Value.ToString("dd/MM/yyyy")</p>
                    </div>
                }
                @if (cr.FechaFinalizacion.HasValue)
                {
                    <div>
                        <p class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">Fecha Finalización</p>
                        <p class="text-sm font-semibold text-slate-900 dark:text-white mt-0.5">@cr.FechaFinalizacion.Value.ToString("dd/MM/yyyy")</p>
                    </div>
                }
                @if (!string.IsNullOrEmpty(cr.AprobadoPor))
                {
                    <div>
                        <p class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">Aprobado Por</p>
                        <p class="text-sm font-semibold text-slate-900 dark:text-white mt-0.5">@cr.AprobadoPor</p>
                    </div>
                }
                <div>
                    <p class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">Riesgo Inicial</p>
                    <p class="text-sm font-semibold text-slate-900 dark:text-white mt-0.5">@cr.PuntajeRiesgoInicial.ToString("N0") pts</p>
                </div>
                @if (cr.RequiereGarante)
                {
                    <div>
                        <p class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">Requiere Garante</p>
                        <p class="text-sm font-semibold text-amber-600 dark:text-amber-400 mt-0.5">Sí</p>
                    </div>
                }
            </div>
            @if (!string.IsNullOrEmpty(cr.Observaciones))
            {
                <div class="mt-5 pt-4 border-t border-slate-100 dark:border-slate-800">
                    <p class="text-[10px] font-bold uppercase text-slate-400 tracking-wider mb-1">Observaciones</p>
                    <p class="text-sm text-slate-600 dark:text-slate-300 leading-relaxed">@cr.Observaciones</p>
                </div>
            }
        </div>

        <!-- Right Sidebar: Client + Garante + Cupo -->
        <div class="space-y-4">
            <!-- Client Card -->
            <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 p-5">
                <h3 class="text-sm font-bold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary text-[18px]">person</span>
                    Cliente
                </h3>
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary to-blue-400 flex items-center justify-center text-white text-sm font-bold flex-shrink-0">
                        @(Model.Cliente.NombreCompleto.Length > 0 ? Model.Cliente.NombreCompleto[0].ToString().ToUpper() : "?")
                    </div>
                    <div>
                        <a asp-controller="Cliente" asp-action="Details" asp-route-id="@Model.Cliente.Id"
                           class="text-sm font-bold text-slate-900 dark:text-white hover:text-primary no-underline transition-colors">
                            @Model.Cliente.NombreCompleto
                        </a>
                        <p class="text-[10px] text-slate-400">DNI @Model.Cliente.NumeroDocumento</p>
                    </div>
                </div>
                <div class="space-y-2 text-xs">
                    @if (!string.IsNullOrEmpty(Model.Cliente.Telefono))
                    {
                        <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400">
                            <span class="material-symbols-outlined text-[14px]">phone</span>
                            @Model.Cliente.Telefono
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Cliente.Email))
                    {
                        <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400">
                            <span class="material-symbols-outlined text-[14px]">mail</span>
                            @Model.Cliente.Email
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Cliente.Domicilio))
                    {
                        <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400">
                            <span class="material-symbols-outlined text-[14px]">location_on</span>
                            @Model.Cliente.Domicilio
                        </div>
                    }
                    @if (Model.Cliente.Sueldo.HasValue)
                    {
                        <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400">
                            <span class="material-symbols-outlined text-[14px]">payments</span>
                            Sueldo: $ @Model.Cliente.Sueldo.Value.ToString("N2")
                        </div>
                    }
                    <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400">
                        <span class="material-symbols-outlined text-[14px]">speed</span>
                        Riesgo: @Model.Cliente.PuntajeRiesgo.ToString("N0") pts
                    </div>
                </div>
            </div>

            <!-- Garante Card -->
            @if (Model.Garante != null)
            {
                <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 p-5">
                    <h3 class="text-sm font-bold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
                        <span class="material-symbols-outlined text-amber-500 text-[18px]">shield_person</span>
                        Garante
                    </h3>
                    <div class="flex items-center gap-3 mb-3">
                        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center text-white text-sm font-bold flex-shrink-0">
                            @(Model.Garante.NombreCompleto.Length > 0 ? Model.Garante.NombreCompleto[0].ToString().ToUpper() : "?")
                        </div>
                        <div>
                            <a asp-controller="Cliente" asp-action="Details" asp-route-id="@Model.Garante.Id"
                               class="text-sm font-bold text-slate-900 dark:text-white hover:text-primary no-underline transition-colors">
                                @Model.Garante.NombreCompleto
                            </a>
                            <p class="text-[10px] text-slate-400">DNI @Model.Garante.NumeroDocumento</p>
                        </div>
                    </div>
                </div>
            }

            <!-- Cupo Global -->
            <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 p-5">
                <h3 class="text-sm font-bold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary text-[18px]">account_balance_wallet</span>
                    Cupo Global
                </h3>
                @if (Model.CupoGlobalConError)
                {
                    <div class="rounded-lg bg-amber-50 dark:bg-amber-500/10 border border-amber-200 dark:border-amber-500/20 p-3">
                        <p class="text-xs text-amber-700 dark:text-amber-400 font-medium flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">warning</span>
                            @(Model.CupoGlobalMensajeError ?? "No se pudo calcular el cupo")
                        </p>
                    </div>
                }
                else if (Model.CupoGlobalDisponible.HasValue)
                {
                    <p class="text-2xl font-black text-emerald-600 dark:text-emerald-400 leading-none">
                        $ @Model.CupoGlobalDisponible.Value.ToString("N2")
                    </p>
                    <p class="text-[10px] text-slate-400 mt-1">Disponible</p>
                    @if (!string.IsNullOrEmpty(Model.CupoGlobalOrigenLimite))
                    {
                        <p class="text-[10px] text-slate-400 mt-1">
                            Origen: <span class="font-medium">@Model.CupoGlobalOrigenLimite</span>
                        </p>
                    }
                }
                else
                {
                    <p class="text-xs text-slate-400">Sin información de cupo disponible.</p>
                }
            </div>
        </div>
    </div>

    <!-- Evaluación Crediticia -->
    @if (ev != null)
    {
        <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 p-6">
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-5 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">analytics</span>
                Evaluación Crediticia
            </h3>

            <!-- Result Banner -->
            <div class="@evalBg border @evalBorder rounded-xl p-4 mb-5 flex items-center gap-4">
                <span class="material-symbols-outlined text-3xl @evalText">@evalIcon</span>
                <div class="flex-1">
                    <p class="text-sm font-bold @evalText">@ev.ResultadoTexto</p>
                    <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">
                        Evaluado el @ev.FechaEvaluacion.ToString("dd/MM/yyyy HH:mm")
                    </p>
                </div>
                <div class="text-right">
                    <p class="text-2xl font-black @evalText leading-none">@ev.PuntajeFinal.ToString("N0")</p>
                    <p class="text-[10px] text-slate-400">/ 100 pts</p>
                </div>
            </div>

            <!-- Evaluation Metrics -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-5">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px] @(ev.TieneDocumentacionCompleta ? "text-emerald-500" : "text-red-500")">
                        @(ev.TieneDocumentacionCompleta ? "check_circle" : "cancel")
                    </span>
                    <span class="text-xs text-slate-600 dark:text-slate-300">Documentación</span>
                </div>
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px] @(ev.TieneIngresosSuficientes ? "text-emerald-500" : "text-red-500")">
                        @(ev.TieneIngresosSuficientes ? "check_circle" : "cancel")
                    </span>
                    <span class="text-xs text-slate-600 dark:text-slate-300">Ingresos</span>
                </div>
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px] @(ev.TieneBuenHistorial ? "text-emerald-500" : "text-red-500")">
                        @(ev.TieneBuenHistorial ? "check_circle" : "cancel")
                    </span>
                    <span class="text-xs text-slate-600 dark:text-slate-300">Historial</span>
                </div>
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px] @(ev.TieneGarante ? "text-emerald-500" : "text-slate-300 dark:text-slate-600")">
                        @(ev.TieneGarante ? "check_circle" : "remove_circle_outline")
                    </span>
                    <span class="text-xs text-slate-600 dark:text-slate-300">Garante</span>
                </div>
            </div>

            <!-- Additional Data -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-5 pt-4 border-t border-slate-100 dark:border-slate-800">
                @if (ev.SueldoCliente.HasValue)
                {
                    <div>
                        <p class="text-[10px] font-bold uppercase text-slate-400">Sueldo</p>
                        <p class="text-sm font-semibold text-slate-900 dark:text-white mt-0.5">$ @ev.SueldoCliente.Value.ToString("N2")</p>
                    </div>
                }
                @if (ev.RelacionCuotaIngreso.HasValue)
                {
                    <div>
                        <p class="text-[10px] font-bold uppercase text-slate-400">Relación Cuota/Ingreso</p>
                        <p class="text-sm font-semibold text-slate-900 dark:text-white mt-0.5">@ev.RelacionCuotaIngreso.Value.ToString("N1")%</p>
                    </div>
                }
                <div>
                    <p class="text-[10px] font-bold uppercase text-slate-400">Riesgo Cliente</p>
                    <p class="text-sm font-semibold text-slate-900 dark:text-white mt-0.5">@ev.PuntajeRiesgoCliente.ToString("N0") pts</p>
                </div>
                <div>
                    <p class="text-[10px] font-bold uppercase text-slate-400">Monto Evaluado</p>
                    <p class="text-sm font-semibold text-slate-900 dark:text-white mt-0.5">$ @ev.MontoSolicitado.ToString("N2")</p>
                </div>
            </div>

            <!-- Rules -->
            @if (ev.Reglas.Any())
            {
                <div class="pt-4 border-t border-slate-100 dark:border-slate-800">
                    <p class="text-xs font-bold uppercase text-slate-400 tracking-wider mb-3">Reglas Evaluadas</p>
                    <div class="space-y-2">
                        @foreach (var regla in ev.Reglas)
                        {
                            <div class="flex items-center gap-3 p-2 rounded-lg @(regla.Cumple ? "bg-emerald-50 dark:bg-emerald-500/5" : regla.EsCritica ? "bg-red-50 dark:bg-red-500/5" : "bg-amber-50 dark:bg-amber-500/5")">
                                <span class="material-symbols-outlined text-[16px] @(regla.Cumple ? "text-emerald-500" : regla.EsCritica ? "text-red-500" : "text-amber-500")">
                                    @(regla.Cumple ? "check_circle" : regla.EsCritica ? "cancel" : "warning")
                                </span>
                                <div class="flex-1 min-w-0">
                                    <p class="text-xs font-semibold text-slate-700 dark:text-slate-200">
                                        @regla.Nombre
                                        @if (regla.EsCritica && !regla.Cumple)
                                        {
                                            <span class="text-red-500 font-bold ml-1">(Crítica)</span>
                                        }
                                    </p>
                                    @if (!string.IsNullOrEmpty(regla.Detalle))
                                    {
                                        <p class="text-[10px] text-slate-400 truncate">@regla.Detalle</p>
                                    }
                                </div>
                                <span class="text-xs font-bold @(regla.Cumple ? "text-emerald-600" : "text-red-600") flex-shrink-0">
                                    @(regla.Peso > 0 ? "+" : "")@regla.Peso.ToString("N0") pts
                                </span>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Motivo/Observaciones -->
            @if (!string.IsNullOrEmpty(ev.Motivo) || !string.IsNullOrEmpty(ev.Observaciones))
            {
                <div class="mt-4 pt-4 border-t border-slate-100 dark:border-slate-800 space-y-3">
                    @if (!string.IsNullOrEmpty(ev.Motivo))
                    {
                        <div>
                            <p class="text-[10px] font-bold uppercase text-slate-400">Motivo</p>
                            <p class="text-sm text-slate-600 dark:text-slate-300 mt-0.5">@ev.Motivo</p>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(ev.Observaciones))
                    {
                        <div>
                            <p class="text-[10px] font-bold uppercase text-slate-400">Observaciones</p>
                            <p class="text-sm text-slate-600 dark:text-slate-300 mt-0.5">@ev.Observaciones</p>
                        </div>
                    }
                </div>
            }
        </div>
    }

    <!-- Cuotas Table -->
    @if (cuotas.Any())
    {
        <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 overflow-hidden">
            <div class="p-6 pb-4 flex items-center justify-between">
                <h3 class="text-lg font-bold text-slate-900 dark:text-white flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">receipt_long</span>
                    Plan de Cuotas
                    <span class="text-xs font-medium text-slate-400 ml-1">(@totalCuotas)</span>
                </h3>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-t border-slate-100 dark:border-slate-800 bg-slate-50 dark:bg-slate-800/50">
                            <th class="text-left px-6 py-3 text-[10px] font-bold uppercase text-slate-400 tracking-wider">#</th>
                            <th class="text-left px-6 py-3 text-[10px] font-bold uppercase text-slate-400 tracking-wider">Vencimiento</th>
                            <th class="text-right px-6 py-3 text-[10px] font-bold uppercase text-slate-400 tracking-wider">Capital</th>
                            <th class="text-right px-6 py-3 text-[10px] font-bold uppercase text-slate-400 tracking-wider">Interés</th>
                            <th class="text-right px-6 py-3 text-[10px] font-bold uppercase text-slate-400 tracking-wider">Total</th>
                            <th class="text-right px-6 py-3 text-[10px] font-bold uppercase text-slate-400 tracking-wider">Punitorio</th>
                            <th class="text-right px-6 py-3 text-[10px] font-bold uppercase text-slate-400 tracking-wider">Pagado</th>
                            <th class="text-center px-6 py-3 text-[10px] font-bold uppercase text-slate-400 tracking-wider">Estado</th>
                            <th class="text-center px-6 py-3 text-[10px] font-bold uppercase text-slate-400 tracking-wider">Acción</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                        @foreach (var cuota in cuotas.OrderBy(c => c.NumeroCuota))
                        {
                            var estaVencida = cuota.EstaVencida;
                            string cuotaBg, cuotaEstadoClase;

                            switch (cuota.Estado)
                            {
                                case EstadoCuota.Pagada:
                                    cuotaBg = "bg-emerald-50/50 dark:bg-emerald-500/5";
                                    cuotaEstadoClase = "bg-emerald-100 dark:bg-emerald-500/20 text-emerald-700 dark:text-emerald-400";
                                    break;
                                case EstadoCuota.Vencida:
                                    cuotaBg = "bg-red-50/50 dark:bg-red-500/5";
                                    cuotaEstadoClase = "bg-red-100 dark:bg-red-500/20 text-red-700 dark:text-red-400";
                                    break;
                                case EstadoCuota.Parcial:
                                    cuotaBg = "bg-amber-50/50 dark:bg-amber-500/5";
                                    cuotaEstadoClase = "bg-amber-100 dark:bg-amber-500/20 text-amber-700 dark:text-amber-400";
                                    break;
                                case EstadoCuota.Cancelada:
                                    cuotaBg = "bg-slate-50/50 dark:bg-slate-800/50";
                                    cuotaEstadoClase = "bg-slate-100 dark:bg-slate-800 text-slate-500";
                                    break;
                                default: // Pendiente
                                    cuotaBg = estaVencida ? "bg-red-50/50 dark:bg-red-500/5" : "";
                                    cuotaEstadoClase = estaVencida
                                        ? "bg-red-100 dark:bg-red-500/20 text-red-700 dark:text-red-400"
                                        : "bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300";
                                    break;
                            }

                            <tr class="@cuotaBg hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                                <td class="px-6 py-3 font-bold text-slate-700 dark:text-slate-200">@cuota.NumeroCuota</td>
                                <td class="px-6 py-3 text-slate-600 dark:text-slate-300">
                                    @cuota.FechaVencimiento.ToString("dd/MM/yyyy")
                                    @if (estaVencida)
                                    {
                                        <span class="block text-[10px] text-red-500 font-bold">@cuota.DiasAtraso días atraso</span>
                                    }
                                </td>
                                <td class="px-6 py-3 text-right tabular-nums text-slate-600 dark:text-slate-300">$ @cuota.MontoCapital.ToString("N2")</td>
                                <td class="px-6 py-3 text-right tabular-nums text-slate-600 dark:text-slate-300">$ @cuota.MontoInteres.ToString("N2")</td>
                                <td class="px-6 py-3 text-right tabular-nums font-semibold text-slate-900 dark:text-white">$ @cuota.MontoTotal.ToString("N2")</td>
                                <td class="px-6 py-3 text-right tabular-nums @(cuota.MontoPunitorio > 0 ? "text-red-600 dark:text-red-400 font-semibold" : "text-slate-400")">
                                    $ @cuota.MontoPunitorio.ToString("N2")
                                </td>
                                <td class="px-6 py-3 text-right tabular-nums @(cuota.MontoPagado > 0 ? "text-emerald-600 dark:text-emerald-400 font-semibold" : "text-slate-400")">
                                    $ @cuota.MontoPagado.ToString("N2")
                                    @if (cuota.FechaPago.HasValue)
                                    {
                                        <span class="block text-[10px] text-slate-400">@cuota.FechaPago.Value.ToString("dd/MM/yyyy")</span>
                                    }
                                </td>
                                <td class="px-6 py-3 text-center">
                                    <span class="inline-block px-2 py-0.5 rounded-full text-[10px] font-bold @cuotaEstadoClase">
                                        @(estaVencida && cuota.Estado == EstadoCuota.Pendiente ? "Vencida" : cuota.EstadoTexto)
                                    </span>
                                </td>
                                <td class="px-6 py-3 text-center">
                                    @if (cuota.Estado == EstadoCuota.Pendiente || cuota.Estado == EstadoCuota.Vencida || cuota.Estado == EstadoCuota.Parcial)
                                    {
                                        <a asp-action="PagarCuota" asp-route-id="@cr.Id" asp-route-cuotaId="@cuota.Id"
                                           class="inline-flex items-center gap-1 px-3 py-1 rounded-lg text-xs font-bold text-primary hover:bg-primary/10 transition-colors no-underline"
                                           title="Pagar esta cuota">
                                            <span class="material-symbols-outlined text-[14px]">payments</span> Pagar
                                        </a>
                                    }
                                    else if (cuota.Estado == EstadoCuota.Pagada && !string.IsNullOrEmpty(cuota.ComprobantePago))
                                    {
                                        <span class="text-[10px] text-slate-400" title="@cuota.ComprobantePago">
                                            <span class="material-symbols-outlined text-[14px] text-emerald-500">receipt</span>
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else if (cr.Estado == EstadoCredito.Activo || cr.Estado == EstadoCredito.Generado)
    {
        <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 p-12 text-center">
            <span class="material-symbols-outlined text-4xl text-slate-300 mb-2 block">receipt_long</span>
            <p class="text-sm font-bold text-slate-700 dark:text-slate-300">Sin cuotas generadas aún</p>
        </div>
    }
</div>

<!-- Modals: Aprobar / Rechazar / Cancelar -->

<!-- Modal Aprobar -->
<div id="modal-aprobar" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm">
    <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-2xl p-6 w-full max-w-md mx-4">
        <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Aprobar Crédito</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 mb-5">
            ¿Confirma la aprobación del crédito <span class="font-bold">@(cr.Numero ?? $"CR-{cr.Id:D3}")</span>
            por <span class="font-bold">$ @cr.MontoSolicitado.ToString("N2")</span>?
        </p>
        <form asp-action="Aprobar" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@cr.Id" />
            @if (!string.IsNullOrEmpty(returnUrl))
            {
                <input type="hidden" name="returnUrl" value="@returnUrl" />
            }
            <div class="flex justify-end gap-3">
                <button type="button" class="modal-close px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 text-sm font-medium text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
                    Cancelar
                </button>
                <button type="submit" class="px-4 py-2 rounded-lg bg-emerald-600 text-white text-sm font-bold hover:bg-emerald-700 transition-colors">
                    Confirmar Aprobación
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Modal Rechazar -->
<div id="modal-rechazar" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm">
    <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-2xl p-6 w-full max-w-md mx-4">
        <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Rechazar Crédito</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 mb-4">
            Indique el motivo del rechazo para <span class="font-bold">@(cr.Numero ?? $"CR-{cr.Id:D3}")</span>.
        </p>
        <form asp-action="Rechazar" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@cr.Id" />
            @if (!string.IsNullOrEmpty(returnUrl))
            {
                <input type="hidden" name="returnUrl" value="@returnUrl" />
            }
            <textarea name="motivo" rows="3" required
                      class="w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-sm text-slate-900 dark:text-white p-3 focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none resize-none mb-4"
                      placeholder="Motivo del rechazo..."></textarea>
            <div class="flex justify-end gap-3">
                <button type="button" class="modal-close px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 text-sm font-medium text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
                    Volver
                </button>
                <button type="submit" class="px-4 py-2 rounded-lg bg-red-600 text-white text-sm font-bold hover:bg-red-700 transition-colors">
                    Confirmar Rechazo
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Modal Cancelar -->
<div id="modal-cancelar" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm">
    <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-2xl p-6 w-full max-w-md mx-4">
        <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Cancelar Crédito</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 mb-4">
            Indique el motivo de cancelación para <span class="font-bold">@(cr.Numero ?? $"CR-{cr.Id:D3}")</span>.
        </p>
        <form asp-action="Cancelar" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@cr.Id" />
            @if (!string.IsNullOrEmpty(returnUrl))
            {
                <input type="hidden" name="returnUrl" value="@returnUrl" />
            }
            <textarea name="motivo" rows="3" required
                      class="w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-sm text-slate-900 dark:text-white p-3 focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none resize-none mb-4"
                      placeholder="Motivo de la cancelación..."></textarea>
            <div class="flex justify-end gap-3">
                <button type="button" class="modal-close px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 text-sm font-medium text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
                    Volver
                </button>
                <button type="submit" class="px-4 py-2 rounded-lg bg-red-600 text-white text-sm font-bold hover:bg-red-700 transition-colors">
                    Confirmar Cancelación
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/credito-details.js"></script>
}
