@model CreditoViewModel
@using TheBuryProject.Models.Enums
@{
    ViewData["Title"] = $"Editar Crédito {Model.Numero}";
    var returnUrl = ViewData["ReturnUrl"] as string;
    var volverHref = !string.IsNullOrWhiteSpace(returnUrl)
        ? returnUrl
        : Url.Action("Details", "Credito", new { id = Model.Id }) ?? $"/Credito/Details/{Model.Id}";
}

@if (TempData["Error"] is string errorMsg)
{
    <div class="mb-4 flex items-center gap-3 rounded-lg border border-rose-500/20 bg-rose-500/10 p-4 text-rose-400">
        <span class="material-symbols-outlined">error</span>
        <p class="text-sm font-medium">@errorMsg</p>
    </div>
}

<div class="mx-auto flex max-w-4xl flex-col gap-6">

    <header class="flex flex-wrap items-start justify-between gap-4">
        <div class="flex items-start gap-3">
            <a href="@volverHref"
               class="flex h-10 w-10 items-center justify-center rounded-lg bg-slate-800 text-slate-200 transition-colors hover:bg-slate-700 no-underline"
               aria-label="Volver al detalle del crédito">
                <span class="material-symbols-outlined text-sm">arrow_back</span>
            </a>
            <div class="flex flex-col gap-1">
                <span class="badge-erp badge-erp-warning">
                    <span class="material-symbols-outlined text-sm">edit</span>
                    Editar crédito
                </span>
                <h1 class="text-3xl font-black tracking-tight text-white">
                    @(Model.Numero ?? $"Crédito #{Model.Id}")
                </h1>
                <p class="max-w-2xl text-sm text-slate-400">
                    Solo se pueden editar créditos en estado <strong>Solicitado</strong>. Los cambios afectan los parámetros de la solicitud original.
                </p>
            </div>
        </div>
    </header>

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="flex flex-col gap-6">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        @if (returnUrl != null)
        {
            <input type="hidden" name="returnUrl" value="@returnUrl" />
        }

        <div asp-validation-summary="ModelOnly"
             class="text-sm text-red-500 bg-red-500/10 border border-red-500/20 rounded-lg p-3 empty:hidden"></div>

        <section class="rounded-xl border border-slate-800 bg-slate-900/50 shadow-sm">
            <div class="border-b border-slate-800 px-6 py-5">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary">person</span>
                    <h2 class="text-base font-bold text-white">Cliente</h2>
                </div>
            </div>
            <div class="grid gap-5 px-6 py-6 sm:grid-cols-2">

                <div class="sm:col-span-2">
                    <label asp-for="ClienteId" class="mb-1.5 block text-xs font-bold uppercase tracking-wider text-slate-400">
                        Cliente <span class="text-rose-500">*</span>
                    </label>
                    <select asp-for="ClienteId" asp-items="ViewBag.Clientes"
                            class="credito-input">
                        <option value="">— Seleccioná un cliente —</option>
                    </select>
                    <span asp-validation-for="ClienteId" class="mt-1 text-xs text-red-500"></span>
                </div>

                <div>
                    <label asp-for="RequiereGarante" class="mb-1.5 flex cursor-pointer items-center gap-2.5 text-sm font-medium text-slate-300">
                        <input asp-for="RequiereGarante" type="checkbox"
                               class="h-4 w-4 rounded border-slate-700 text-primary focus:ring-primary"
                               id="requiere-garante-toggle" />
                        Requiere garante
                    </label>
                </div>

                <div id="garante-field">
                    <label asp-for="GaranteId" class="mb-1.5 block text-xs font-bold uppercase tracking-wider text-slate-400">
                        Garante
                    </label>
                    <select asp-for="GaranteId" asp-items="ViewBag.Garantes"
                            class="credito-input">
                        <option value="">— Sin garante —</option>
                    </select>
                    <span asp-validation-for="GaranteId" class="mt-1 text-xs text-red-500"></span>
                </div>

            </div>
        </section>

        <section class="rounded-xl border border-slate-800 bg-slate-900/50 shadow-sm">
            <div class="border-b border-slate-800 px-6 py-5">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary">payments</span>
                    <h2 class="text-base font-bold text-white">Condiciones del crédito</h2>
                </div>
            </div>
            <div class="grid gap-5 px-6 py-6 sm:grid-cols-2">

                <div>
                    <label asp-for="MontoSolicitado" class="mb-1.5 block text-xs font-bold uppercase tracking-wider text-slate-400">
                        Monto solicitado <span class="text-rose-500">*</span>
                    </label>
                    <div class="relative">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-sm font-bold text-slate-400">$</span>
                        <input asp-for="MontoSolicitado"
                               type="number"
                               step="100"
                               min="1000"
                               class="credito-input pl-7"
                               placeholder="Ej: 50000" />
                    </div>
                    <span asp-validation-for="MontoSolicitado" class="mt-1 text-xs text-red-500"></span>
                </div>

                <div>
                    <label asp-for="TasaInteres" class="mb-1.5 block text-xs font-bold uppercase tracking-wider text-slate-400">
                        Tasa de interés mensual (%) <span class="text-rose-500">*</span>
                    </label>
                    <div class="relative">
                        <input asp-for="TasaInteres"
                               type="number"
                               step="0.01"
                               min="0"
                               max="100"
                               class="credito-input pr-8"
                               placeholder="Ej: 5" />
                        <span class="absolute right-3 top-1/2 -translate-y-1/2 text-sm font-bold text-slate-400">%</span>
                    </div>
                    <p class="mt-1 text-xs text-slate-400">Tasa mensual en porcentaje (ej: 5 = 5% mensual)</p>
                    <span asp-validation-for="TasaInteres" class="mt-1 text-xs text-red-500"></span>
                </div>

                <div>
                    <label asp-for="CantidadCuotas" class="mb-1.5 block text-xs font-bold uppercase tracking-wider text-slate-400">
                        Cantidad de cuotas
                    </label>
                    <input asp-for="CantidadCuotas"
                           type="number"
                           min="1"
                           max="60"
                           class="credito-input"
                           placeholder="Ej: 12" />
                    <p class="mt-1 text-xs text-slate-400">Orientativo. Las cuotas definitivas se configuran al vincular la venta.</p>
                    <span asp-validation-for="CantidadCuotas" class="mt-1 text-xs text-red-500"></span>
                </div>

                <div>
                    <label asp-for="FechaSolicitud" class="mb-1.5 block text-xs font-bold uppercase tracking-wider text-slate-400">
                        Fecha de solicitud
                    </label>
                    <input asp-for="FechaSolicitud"
                           type="date"
                           class="credito-input" />
                    <span asp-validation-for="FechaSolicitud" class="mt-1 text-xs text-red-500"></span>
                </div>

            </div>
        </section>

        <section class="rounded-xl border border-slate-800 bg-slate-900/50 shadow-sm">
            <div class="border-b border-slate-800 px-6 py-5">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary">note</span>
                    <h2 class="text-base font-bold text-white">Información adicional</h2>
                </div>
            </div>
            <div class="px-6 py-6">
                <label asp-for="Observaciones" class="mb-1.5 block text-xs font-bold uppercase tracking-wider text-slate-400">
                    Observaciones
                </label>
                <textarea asp-for="Observaciones"
                          rows="3"
                          class="credito-input"
                          placeholder="Notas internas sobre la solicitud..."></textarea>
                <span asp-validation-for="Observaciones" class="mt-1 text-xs text-red-500"></span>
            </div>
        </section>

        <div class="flex flex-col gap-3 sm:flex-row sm:justify-end">
            <a href="@volverHref"
               class="btn-erp-ghost h-11 no-underline">
                Cancelar
            </a>
            <button type="submit"
                    class="inline-flex h-11 items-center justify-center gap-2 rounded-xl bg-primary px-6 text-sm font-bold text-white shadow-lg shadow-primary/20 transition-colors hover:bg-primary/90">
                <span class="material-symbols-outlined text-[18px]">save</span>
                Guardar cambios
            </button>
        </div>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/shared-ui.js" asp-append-version="true"></script>
    <script src="~/js/credito-module.js" asp-append-version="true"></script>
    <script>TheBury.CreditoModule.initGaranteToggle();</script>
}
