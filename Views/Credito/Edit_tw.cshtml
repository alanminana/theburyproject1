@model CreditoViewModel
@using TheBuryProject.Models.Enums
@{
    ViewData["Title"] = $"Editar Credito {Model.Numero}";
    var returnUrl = ViewData["ReturnUrl"] as string;
    var volverHref = !string.IsNullOrWhiteSpace(returnUrl)
        ? returnUrl
        : Url.Action("Details", "Credito", new { id = Model.Id }) ?? $"/Credito/Details/{Model.Id}";
    var creditoLabel = Model.Numero ?? $"Credito #{Model.Id}";
}

<header class="topbar">
    <div class="shell topbar-inner">
        <div class="brand">
            <span class="brand-badge">
                <span class="material-symbols-outlined" style="color:#fff;font-size:18px" aria-hidden="true">credit_score</span>
            </span>
            Creditos
        </div>
        <nav class="breadcrumb" style="margin-left:.5rem" aria-label="Migas de pan">
            <span class="sep">/</span>
            <a asp-controller="Credito" asp-action="Index">Creditos</a>
            <span class="sep">/</span>
            <a asp-controller="Credito" asp-action="Details" asp-route-id="@Model.Id">@creditoLabel</a>
            <span class="sep">/</span>
            <span style="color:#cbd5e1">Editar</span>
        </nav>
        <div style="margin-left:auto" class="flex items-center gap-2">
            <span class="hide-mobile text-xs muted-2 mono">Casa Central</span>
            <div class="w-8 h-8 rounded-full bg-slate-700 grid place-items-center text-xs font-semibold text-slate-200" aria-hidden="true">LF</div>
        </div>
    </div>
</header>

<main class="shell" style="padding-top:1.5rem;padding-bottom:3rem;max-width:720px">
    <a href="@volverHref" class="inline-flex items-center gap-1.5 text-sm muted hover:text-white transition" style="text-decoration:none">
        <span class="material-symbols-outlined" style="font-size:18px" aria-hidden="true">arrow_back</span>
        Volver a creditos
    </a>

    <div class="page-head" style="margin-top:.95rem">
        <div class="min-w-0">
            <h1 class="page-title" style="font-size:1.4rem">Editar Credito <span class="mono">@creditoLabel</span></h1>
            <p class="page-sub" style="margin-top:.3rem">Modifica cliente, garante u observaciones. El plan de cuotas no se altera desde aca.</p>
        </div>
    </div>

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="space-y-4" style="margin-top:1.25rem">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        @if (returnUrl != null)
        {
            <input type="hidden" name="returnUrl" value="@returnUrl" />
        }

        <div asp-validation-summary="ModelOnly" class="alert alert-bad empty:hidden"></div>

        <section class="card card-pad">
            <div class="sec-head">
                <div class="sec-num">1</div>
                <div>
                    <div class="sec-title">Cliente</div>
                    <div class="sec-sub">Solo se listan clientes con aptitud crediticia vigente.</div>
                </div>
            </div>
            <label asp-for="ClienteId" class="label">Cliente <span class="req">*</span></label>
            <select asp-for="ClienteId" asp-items="ViewBag.Clientes" class="field" required>
                <option value="">Selecciona un cliente...</option>
            </select>
            <span asp-validation-for="ClienteId" class="err-text"></span>
            <p class="hint">El cliente no aparece? Verifica su aptitud en el modulo Clientes.</p>
        </section>

        <section class="card card-pad">
            <div class="sec-head">
                <div class="sec-num">2</div>
                <div>
                    <div class="sec-title">Garante</div>
                    <div class="sec-sub">Indica si la operacion requiere garante.</div>
                </div>
            </div>
            <label asp-for="RequiereGarante" class="radio-card" id="garante-toggle">
                <input asp-for="RequiereGarante" type="checkbox" class="sr-only" id="requiere-garante-toggle" />
                <span class="rc-dot" style="border-radius:6px"></span>
                <span class="flex-1">
                    <span class="rc-title">Requiere garante</span>
                    <span class="rc-sub">Activa si el monto o el puntaje exigen una garantia personal.</span>
                </span>
            </label>
            <span asp-validation-for="RequiereGarante" class="err-text"></span>

            <div id="garante-field" style="margin-top:.85rem">
                <label asp-for="GaranteId" class="label">Garante <span class="req">*</span></label>
                <select asp-for="GaranteId" asp-items="ViewBag.Garantes" class="field">
                    <option value="">Selecciona un garante...</option>
                </select>
                <span asp-validation-for="GaranteId" class="err-text"></span>
            </div>
        </section>

        <section class="card card-pad">
            <div class="sec-head">
                <div class="sec-num">3</div>
                <div>
                    <div class="sec-title">Condiciones del credito</div>
                    <div class="sec-sub">Campos funcionales de la solicitud original.</div>
                </div>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
                <div>
                    <label asp-for="MontoSolicitado" class="label">Monto solicitado <span class="req">*</span></label>
                    <div class="field-money">
                        <span class="cur">$</span>
                        <input asp-for="MontoSolicitado" type="number" step="100" min="1000" class="field" placeholder="Ej: 50000" />
                    </div>
                    <span asp-validation-for="MontoSolicitado" class="err-text"></span>
                </div>
                <div>
                    <label asp-for="TasaInteres" class="label">Tasa de interes mensual (%) <span class="req">*</span></label>
                    <input asp-for="TasaInteres" type="number" step="0.01" min="0" max="100" class="field" placeholder="Ej: 5" />
                    <p class="hint">Tasa mensual en porcentaje.</p>
                    <span asp-validation-for="TasaInteres" class="err-text"></span>
                </div>
                <div>
                    <label asp-for="CantidadCuotas" class="label">Cantidad de cuotas</label>
                    <input asp-for="CantidadCuotas" type="number" min="1" max="60" class="field" placeholder="Ej: 12" />
                    <span asp-validation-for="CantidadCuotas" class="err-text"></span>
                </div>
                <div>
                    <label asp-for="FechaSolicitud" class="label">Fecha de solicitud</label>
                    <input asp-for="FechaSolicitud" type="date" class="field" />
                    <span asp-validation-for="FechaSolicitud" class="err-text"></span>
                </div>
            </div>
        </section>

        <section class="card card-pad">
            <div class="sec-head">
                <div class="sec-num">4</div>
                <div>
                    <div class="sec-title">Informacion adicional</div>
                    <div class="sec-sub">Notas internas de la linea.</div>
                </div>
            </div>
            <label asp-for="Observaciones" class="label">Observaciones</label>
            <textarea asp-for="Observaciones" class="field" placeholder="Comentario interno (opcional)..."></textarea>
            <span asp-validation-for="Observaciones" class="err-text"></span>
        </section>

        <div class="flex flex-col-reverse sm:flex-row justify-end gap-2">
            <a href="@volverHref" class="btn btn-ghost">Cancelar</a>
            <button type="submit" class="btn btn-primary">
                <span class="material-symbols-outlined" aria-hidden="true">save</span>
                Guardar cambios
            </button>
        </div>
    </form>
</main>

@section Styles {
    <partial name="_CreditoModuleStyles" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/shared-ui.js" asp-append-version="true"></script>
    <script src="~/js/credito-module.js" asp-append-version="true"></script>
    <script>TheBury.CreditoModule.initGaranteToggle();</script>
}
