@using TheBuryProject.Models.Enums
@model List<CreditoClienteIndexViewModel>
@{
    ViewData["Title"] = "Gestión de Créditos";
    ViewData["MetaDescription"] = "Seguimiento de créditos, cuotas, moras y estado financiero de clientes en el ERP TheBuryProject.";
    var filter = ViewBag.Filter as CreditoFilterViewModel ?? new CreditoFilterViewModel();
    var clientes = Model ?? new List<CreditoClienteIndexViewModel>();
    var creditos = clientes.SelectMany(c => c.Creditos).ToList();
    var totalClientes = clientes.Count;
    var totalCreditos = creditos.Count;

    var creditosConMora = creditos
        .Where(c => c.Cuotas != null && c.Cuotas.Any(cu => cu.EstaVencida))
        .ToList();
    var totalMoras = creditosConMora.Sum(c => c.Cuotas?.Count(cu => cu.EstaVencida) ?? 0);
    var resumenMoras = creditosConMora
        .Select(credito =>
        {
            var cuotasVencidas = credito.Cuotas?
                .Where(cu => cu.EstaVencida)
                .OrderBy(cu => cu.FechaVencimiento)
                .ToList() ?? new List<CuotaViewModel>();

            var primeraCuotaVencida = cuotasVencidas.FirstOrDefault();
            var diasMaximosAtraso = cuotasVencidas.Any() ? cuotasVencidas.Max(cu => cu.DiasAtraso) : 0;
            var montoTotalMora = cuotasVencidas.Sum(cu => cu.SaldoPendiente);
            var esCritica = diasMaximosAtraso >= 10;

            return new
            {
                Credito = credito,
                CuotasVencidas = cuotasVencidas,
                PrimeraCuotaVencida = primeraCuotaVencida,
                DiasMaximosAtraso = diasMaximosAtraso,
                MontoTotalMora = montoTotalMora,
                EsCritica = esCritica
            };
        })
        .Where(item => item.PrimeraCuotaVencida != null)
        .OrderByDescending(item => item.EsCritica)
        .ThenByDescending(item => item.DiasMaximosAtraso)
        .ThenBy(item => item.PrimeraCuotaVencida!.FechaVencimiento)
        .ToList();
    var moraTotalAcumulada = resumenMoras.Sum(item => item.MontoTotalMora);
    var creditosCriticos = resumenMoras.Count(item => item.EsCritica);
    var puedeVerConfiguracionCredito = User.TienePermiso("configuraciones", "view");
}

@section Styles {
    <partial name="_CreditoModuleStyles" />
}

<div class="space-y-6">
    @if (totalMoras > 0)
    {
        <div class="toast-msg flex items-center gap-2 rounded-xl border border-red-500/20 bg-red-500/10 p-3 text-sm font-semibold text-red-400" role="alert">
            <span class="material-symbols-outlined text-lg">warning</span>
            @totalMoras cuota@(totalMoras == 1 ? "" : "s") en mora · @creditosCriticos crítico@(creditosCriticos == 1 ? "" : "s")
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="toast-msg flex items-center gap-2 rounded-xl border border-emerald-500/20 bg-emerald-500/10 p-3 text-sm font-semibold text-emerald-400" role="status">
            <span class="material-symbols-outlined text-lg">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="toast-msg flex items-center gap-2 rounded-xl border border-red-500/20 bg-red-500/10 p-3 text-sm font-semibold text-red-500" role="alert">
            <span class="material-symbols-outlined text-lg">error</span>
            @TempData["Error"]
        </div>
    }

    <section class="card-erp" style="padding:1rem 1.25rem;">
        <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <div>
                <h2 class="text-base font-bold text-white">Seguimiento operativo</h2>
                <p class="text-sm text-slate-400">Alterná entre cartera agrupada por cliente y mora operativa por crédito/cuota.</p>
            </div>
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
                @if (puedeVerConfiguracionCredito)
                {
                    <a asp-controller="ConfiguracionPago" asp-action="CreditoPersonal"
                       asp-route-returnUrl="@($"{Context.Request.Path}{Context.Request.QueryString}")"
                       class="btn-erp-secondary btn-sm no-underline sm:w-auto">
                        <span class="material-symbols-outlined text-sm">settings</span>
                        Global y perfiles
                    </a>
                }
                <nav class="flex overflow-x-auto" id="credito-tabs" aria-label="Secciones de créditos">
                    <button type="button"
                            data-credito-tab="creditos"
                            aria-pressed="true"
                            class="shrink-0 inline-flex items-center gap-2 px-5 py-3 text-sm font-bold border-b-2 border-primary text-primary bg-primary/10 transition-colors">
                        <span class="material-symbols-outlined text-lg">credit_card</span>
                        <span>Cartera por cliente</span>
                    </button>
                    <button type="button"
                            data-credito-tab="moras"
                            aria-pressed="false"
                            class="shrink-0 inline-flex items-center gap-2 px-5 py-3 text-sm font-bold border-b-2 border-transparent text-slate-400 hover:text-white hover:bg-white/5 transition-colors">
                        <span class="material-symbols-outlined text-lg">warning</span>
                        <span>Moras por crédito</span>
                        @if (totalMoras > 0)
                        {
                            <span class="rounded-full bg-red-500/10 px-2 py-0.5 text-[11px] font-bold text-red-500">@totalMoras</span>
                        }
                    </button>
                </nav>
            </div>
        </div>
    </section>

    @{
        var filtroCreditoActivo = !string.IsNullOrEmpty(filter.Cliente)
                               || filter.ClienteId.HasValue
                               || !string.IsNullOrEmpty(filter.Numero)
                               || filter.Estado.HasValue
                               || filter.FechaDesde.HasValue
                               || filter.FechaHasta.HasValue
                               || filter.MontoMinimo.HasValue
                               || filter.MontoMaximo.HasValue
                               || filter.SoloCuotasVencidas;
    }

    <div id="tab-creditos" class="space-y-6">
        <form id="filterForm" data-credito-filter-form method="get" asp-action="Index"
              class="border-b border-slate-800 bg-slate-900/30 px-4 py-4 rounded-xl border">
            @if (filter.ClienteId.HasValue)
            {
                <input type="hidden" name="ClienteId" value="@filter.ClienteId.Value" />
            }
            <div class="flex flex-wrap items-end gap-4">
                <div class="min-w-[220px] flex-1">
                    <label class="mb-1.5 block text-[10px] font-bold uppercase tracking-wider text-slate-400" for="credito-busqueda">Buscar</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-lg text-slate-400">search</span>
                        <input id="credito-busqueda" name="Cliente" value="@filter.Cliente" type="text"
                               aria-label="Buscar por cliente, DNI o número de crédito"
                               class="filter-input-erp pl-10"
                               placeholder="Cliente, DNI o N° de crédito..." />
                    </div>
                </div>
                <div class="w-44">
                    <label class="mb-1.5 block text-[10px] font-bold uppercase tracking-wider text-slate-400" for="credito-estado">Estado</label>
                    <select id="credito-estado" name="Estado" aria-label="Estado del crédito" class="filter-select-erp">
                        <option value="">Todos</option>
                        @foreach (var estado in Enum.GetValues<EstadoCredito>())
                        {
                            <option value="@((int)estado)" selected="@(filter.Estado.HasValue && filter.Estado.Value == estado ? "selected" : null)">@estado</option>
                        }
                    </select>
                </div>
                <div class="w-40">
                    <label class="mb-1.5 block text-[10px] font-bold uppercase tracking-wider text-slate-400" for="credito-fecha-desde">Desde</label>
                    <input id="credito-fecha-desde" name="FechaDesde" value="@filter.FechaDesde?.ToString("yyyy-MM-dd")" type="date"
                           aria-label="Fecha desde"
                           class="filter-input-erp" />
                </div>
                <div class="w-40">
                    <label class="mb-1.5 block text-[10px] font-bold uppercase tracking-wider text-slate-400" for="credito-fecha-hasta">Hasta</label>
                    <input id="credito-fecha-hasta" name="FechaHasta" value="@filter.FechaHasta?.ToString("yyyy-MM-dd")" type="date"
                           aria-label="Fecha hasta"
                           class="filter-input-erp" />
                </div>
                <div class="flex gap-2">
                    <button type="submit"
                            class="inline-flex h-9 items-center justify-center gap-2 rounded-lg bg-primary/10 px-3 text-sm font-bold text-primary-on-dark transition-colors hover:bg-primary hover:text-white"
                            title="Filtrar créditos">
                        <span class="material-symbols-outlined text-lg">filter_list</span>
                        <span>Filtrar</span>
                    </button>
                    @if (filtroCreditoActivo)
                    {
                        <a asp-action="Index"
                           class="inline-flex h-9 items-center justify-center rounded-lg bg-slate-800 px-3 text-slate-300 transition-colors hover:bg-slate-700 hover:text-white no-underline"
                           title="Limpiar filtros">
                            <span class="material-symbols-outlined text-lg">clear_all</span>
                        </a>
                    }
                </div>
            </div>
        </form>

        <div data-oc-scroll style="--oc-scroll-min-width: 76rem;" class="table-erp-wrapper">
            <div class="border-b border-slate-800 px-4 py-4 sm:px-6">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                    <div>
                        <h2 class="text-base font-bold text-white">Cartera filtrada por cliente</h2>
                        <p class="text-sm text-slate-400">Totales calculados sobre los créditos que coinciden con los filtros actuales.</p>
                    </div>
                    <span class="inline-flex items-center gap-2 self-start rounded-full bg-slate-800 px-3 py-1 text-xs font-semibold text-slate-300">
                        <span class="material-symbols-outlined text-sm">account_balance_wallet</span>
                        @totalClientes cliente@(totalClientes == 1 ? "" : "s") filtrado@(totalClientes == 1 ? "" : "s") · @totalCreditos crédito@(totalCreditos == 1 ? "" : "s") filtrado@(totalCreditos == 1 ? "" : "s")
                    </span>
                </div>
                <p data-oc-scroll-hint hidden class="mt-3 text-xs font-medium text-slate-400 lg:hidden">
                    Deslizá la tabla para ver documentos, saldos, vencimientos y acciones completas.
                </p>
            </div>

            <div data-oc-scroll-shell>
                <div data-oc-scroll-fade="left" hidden></div>
                <div data-oc-scroll-fade="right" hidden></div>
                <div data-oc-scroll-region tabindex="0" role="region" aria-label="Listado de clientes con créditos">
                    <table data-oc-scroll-table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="border-b border-slate-800 bg-slate-800/50">
                                <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Cliente</th>
                                <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Documento</th>
                                <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Créditos filtrados</th>
                                <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Saldo filtrado</th>
                                <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Cuotas vencidas</th>
                                <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Próximo vencimiento</th>
                                <th class="px-6 py-4 text-center text-xs font-bold uppercase tracking-wider text-slate-400">Estado</th>
                                <th class="px-6 py-4 text-right text-xs font-bold uppercase tracking-wider text-slate-400">Acciones</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-800">
                            @if (clientes.Any())
                            {
                                @foreach (var clienteGrupo in clientes)
                                {
                                    var clienteNombre = clienteGrupo.Cliente.NombreCompleto;
                                    if (string.IsNullOrWhiteSpace(clienteNombre))
                                    {
                                        clienteNombre = $"Cliente #{clienteGrupo.Cliente.Id}";
                                    }

                                    var initials = "??";
                                    var parts = clienteNombre.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                                    if (parts.Length >= 2)
                                    {
                                        initials = $"{parts[0][0]}{parts[1][0]}".ToUpper();
                                    }
                                    else if (parts.Length == 1)
                                    {
                                        initials = parts[0][..Math.Min(2, parts[0].Length)].ToUpper();
                                    }

                                    string badgeColor;
                                    switch (clienteGrupo.EstadoConsolidado)
                                    {
                                        case "Activo":
                                            badgeColor = "green";
                                            break;
                                        case "En mora":
                                        case "Rechazado":
                                            badgeColor = "red";
                                            break;
                                        case "Pendiente":
                                            badgeColor = "orange";
                                            break;
                                        case "Aprobado":
                                            badgeColor = "blue";
                                            break;
                                        default:
                                            badgeColor = "slate";
                                            break;
                                    }

                                    var creditosResumen = clienteGrupo.Creditos.Take(3).ToList();
                                    var vencimientoVencido = clienteGrupo.ProximoVencimiento.HasValue
                                        && clienteGrupo.ProximoVencimiento.Value.Date < DateTime.UtcNow.Date;

                                    <tr class="transition-colors hover:bg-slate-800/30">
                                        <td class="px-6 py-4">
                                            <div class="flex items-center gap-3">
                                                <div class="flex size-8 items-center justify-center rounded-full bg-slate-800 text-xs font-bold text-primary">@initials</div>
                                                <div class="flex flex-col">
                                                    <a asp-controller="Cliente" asp-action="Details" asp-route-id="@clienteGrupo.Cliente.Id"
                                                       class="text-sm font-semibold transition-colors hover:text-primary no-underline text-slate-100">
                                                        @clienteNombre
                                                    </a>
                                                    <span class="text-xs text-slate-400">Cliente #@clienteGrupo.Cliente.Id</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 text-sm font-medium text-slate-300">@clienteGrupo.Documento</td>
                                        <td class="px-6 py-4">
                                            <div class="flex flex-col gap-1">
                                                <span class="text-sm font-semibold text-white">
                                                    @clienteGrupo.CantidadCreditos crédito@(clienteGrupo.CantidadCreditos == 1 ? "" : "s") filtrado@(clienteGrupo.CantidadCreditos == 1 ? "" : "s")
                                                </span>
                                                <div class="flex flex-wrap gap-1">
                                                    @foreach (var credito in creditosResumen)
                                                    {
                                                        <a asp-action="Details" asp-route-id="@credito.Id"
                                                           class="rounded-full bg-slate-800 px-2 py-0.5 text-[11px] font-semibold text-slate-300 transition-colors hover:bg-primary/10 hover:text-primary no-underline"
                                                           title="Ver detalle de @(credito.Numero ?? $"CR-{credito.Id:D3}")">
                                                            @(credito.Numero ?? $"CR-{credito.Id:D3}")
                                                        </a>
                                                    }
                                                    @if (clienteGrupo.CantidadCreditos > creditosResumen.Count)
                                                    {
                                                        <span class="rounded-full bg-slate-800 px-2 py-0.5 text-[11px] font-semibold text-slate-400">
                                                            +@(clienteGrupo.CantidadCreditos - creditosResumen.Count)
                                                        </span>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 text-sm font-medium text-slate-300">
                                            <div class="flex flex-col">
                                                <span>$ @clienteGrupo.SaldoPendienteTotal.ToString("N0")</span>
                                                <span class="text-xs text-slate-400">Saldo pendiente filtrado</span>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <span class="text-sm font-bold @(clienteGrupo.CuotasVencidas > 0 ? "text-red-400" : "text-slate-300")">
                                                @clienteGrupo.CuotasVencidas
                                            </span>
                                        </td>
                                        <td class="px-6 py-4">
                                            @if (clienteGrupo.ProximoVencimiento.HasValue)
                                            {
                                                <div class="flex flex-col">
                                                    <span class="text-sm font-semibold @(vencimientoVencido ? "text-red-400" : "text-slate-300")">
                                                        @clienteGrupo.ProximoVencimiento.Value.ToString("dd/MM/yyyy")
                                                    </span>
                                                    <span class="text-xs text-slate-400">@(vencimientoVencido ? "Vencido" : "Pendiente")</span>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-sm text-slate-400">Sin vencimientos</span>
                                            }
                                        </td>
                                        <td class="px-6 py-4">
                                            <div class="flex justify-center">
                                                <span class="rounded-full bg-@(badgeColor)-500/10 px-3 py-1 text-[10px] font-bold uppercase tracking-wide text-@(badgeColor)-400">@clienteGrupo.EstadoConsolidado</span>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 text-right">
                                            <div class="flex justify-end gap-1">
                                                <button type="button"
                                                        class="row-action row-action--primary"
                                                        title="Gestionar cliente"
                                                        data-credito-cliente-panel-open
                                                        data-credito-cliente-id="@clienteGrupo.Cliente.Id"
                                                        aria-controls="credito-cliente-panel">
                                                    <span class="material-symbols-outlined">manage_accounts</span>
                                                    <span class="row-action__label">Gestionar</span>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" class="px-6 py-12 text-center text-slate-400">
                                        <span class="material-symbols-outlined mb-2 block text-4xl">credit_card_off</span>
                                        <p class="text-sm font-medium">No se encontraron créditos</p>
                                        <p class="mt-1 text-xs">Ajustá los filtros o creá un nuevo crédito desde un cliente.</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="flex flex-col gap-2 border-t border-slate-800 p-4 text-xs text-slate-400 sm:flex-row sm:items-center sm:justify-between">
                <p>Mostrando @totalClientes cliente@(totalClientes == 1 ? "" : "s") con @totalCreditos crédito@(totalCreditos == 1 ? "" : "s") en la cartera filtrada.</p>
                <p>Saldo, cuotas vencidas y vencimiento son totales del subconjunto filtrado, no el total histórico del cliente.</p>
            </div>
        </div>
    </div>

    <div id="tab-moras" class="hidden space-y-6">
        @if (resumenMoras.Any())
        {
            <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
                <div class="card-erp-metric">
                    <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Créditos en mora filtrados</p>
                    <p class="mt-2 text-3xl font-black text-white">@resumenMoras.Count</p>
                    <p class="mt-1 text-xs text-slate-400">Lista operativa por crédito/cuota, no agrupada por cliente.</p>
                </div>
                <div class="card-erp-metric-danger">
                    <p class="text-xs font-bold uppercase tracking-wider text-red-400">Casos Críticos</p>
                    <p class="mt-2 text-3xl font-black text-red-300">@creditosCriticos</p>
                    <p class="mt-1 text-xs text-red-400/70">Créditos con 10 o más días de atraso.</p>
                </div>
                <div class="card-erp-metric-warning">
                    <p class="text-xs font-bold uppercase tracking-wider text-amber-400">Deuda en mora filtrada</p>
                    <p class="mt-2 text-3xl font-black text-amber-300">$ @moraTotalAcumulada.ToString("N0")</p>
                    <p class="mt-1 text-xs text-amber-400/70">@totalMoras cuota(s) vencida(s) del subconjunto filtrado.</p>
                </div>
            </div>

            <div data-oc-scroll style="--oc-scroll-min-width: 72rem;" class="table-erp-wrapper">
                <div class="border-b border-slate-800 bg-slate-800/30 px-6 py-4">
                    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                        <div>
                            <h3 class="text-sm font-black text-white">Moras por crédito/cuota</h3>
                            <p class="mt-1 text-xs text-slate-400">Listado operativo filtrado por crédito con cuotas vencidas. No está agrupado por cliente; la agrupación vive en Cartera.</p>
                        </div>
                        <span class="inline-flex items-center gap-2 self-start rounded-full bg-red-500/10 px-3 py-1 text-xs font-semibold text-red-400">
                            <span class="material-symbols-outlined text-sm">schedule</span>
                            @totalMoras cuota@(totalMoras == 1 ? "" : "s") vencida@(totalMoras == 1 ? "" : "s")
                        </span>
                    </div>
                    <p data-oc-scroll-hint hidden class="mt-3 text-xs font-medium text-slate-400 lg:hidden">
                        Deslizá la tabla para revisar atrasos, deuda y acciones.
                    </p>
                </div>

                <div data-oc-scroll-shell>
                    <div data-oc-scroll-fade="left" hidden></div>
                    <div data-oc-scroll-fade="right" hidden></div>
                    <div data-oc-scroll-region tabindex="0" role="region" aria-label="Listado operativo de créditos en mora por cuota">
                        <table data-oc-scroll-table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="border-b border-slate-800 bg-slate-800/50">
                                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Cliente</th>
                                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Crédito</th>
                                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Cuotas Vencidas</th>
                                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Primera Mora</th>
                                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Máx. Atraso</th>
                                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Monto Adeudado</th>
                                    <th class="px-6 py-4 text-center text-xs font-bold uppercase tracking-wider text-slate-400">Prioridad</th>
                                    <th class="px-6 py-4 text-right text-xs font-bold uppercase tracking-wider text-slate-400">Acciones</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-800">
                                @foreach (var mora in resumenMoras)
                                {
                                    var credito = mora.Credito;
                                    var primeraCuota = mora.PrimeraCuotaVencida!;
                                    var cuotasVencidasTexto = mora.CuotasVencidas.Count == 1 ? "1 cuota" : $"{mora.CuotasVencidas.Count} cuotas";

                                    <tr class="transition-colors hover:bg-slate-800/30">
                                        <td class="px-6 py-4">
                                            <div class="flex flex-col">
                                                <span class="text-sm font-semibold text-white">@credito.ClienteNombre</span>
                                                <span class="text-xs text-slate-400">Saldo pendiente crédito: $ @credito.SaldoPendiente.ToString("N0")</span>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <div class="flex flex-col">
                                                <span class="text-sm font-semibold text-white">@(credito.Numero ?? $"CR-{credito.Id:D3}")</span>
                                                <span class="text-xs text-slate-400">ID interno #@credito.Id</span>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <div class="flex flex-col">
                                                <span class="text-sm font-semibold text-white">@cuotasVencidasTexto</span>
                                                <span class="text-xs text-slate-400">Primera pendiente: cuota #@primeraCuota.NumeroCuota</span>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <div class="flex flex-col">
                                                <span class="text-sm font-semibold text-white">@primeraCuota.FechaVencimiento.ToString("dd/MM/yyyy")</span>
                                                <span class="text-xs text-slate-400">@primeraCuota.DiasAtraso día(s) de atraso en esa cuota</span>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <span class="text-sm font-black @(mora.EsCritica ? "text-red-400" : "text-white")">
                                                @mora.DiasMaximosAtraso días
                                            </span>
                                        </td>
                                        <td class="px-6 py-4">
                                            <div class="flex flex-col">
                                                <span class="text-sm font-black @(mora.EsCritica ? "text-red-400" : "text-white")">
                                                    $ @mora.MontoTotalMora.ToString("N2")
                                                </span>
                                                <span class="text-xs text-slate-400">Incluye capital, interés y punitorio vencido</span>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <div class="flex justify-center">
                                                <span class="rounded-full px-3 py-1 text-[10px] font-bold uppercase tracking-wide @(mora.EsCritica ? "bg-red-500/10 text-red-400"
                                                    : "bg-amber-500/10 text-amber-400")">
                                                    @(mora.EsCritica ? "Crítica" : "Seguimiento")
                                                </span>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 text-right">
                                            <div class="flex justify-end gap-1">
                                                <a asp-action="PagarCuota" asp-route-id="@credito.Id"
                                                   class="row-action row-action--warning no-underline"
                                                   title="Registrar pago">
                                                    <span class="material-symbols-outlined">payments</span>
                                                    <span class="row-action__label">Pagar</span>
                                                </a>
                                                <a asp-action="Details" asp-route-id="@credito.Id"
                                                   class="row-action row-action--primary no-underline"
                                                   title="Ver detalle del crédito">
                                                    <span class="material-symbols-outlined">visibility</span>
                                                    <span class="row-action__label">Ver</span>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="rounded-2xl border border-slate-800 bg-slate-900 p-12 text-center">
                <span class="material-symbols-outlined mb-2 block text-4xl text-emerald-500">verified</span>
                <p class="text-sm font-bold text-slate-300">Sin moras detectadas</p>
                <p class="mt-1 text-xs text-slate-400">Todos los créditos están al día.</p>
            </div>
        }
    </div>
</div>

<div id="credito-cliente-panel"
     class="fixed inset-0 z-50 hidden"
     data-credito-cliente-panel
     aria-hidden="true">
    <div class="hidden" data-credito-antiforgery>
        @Html.AntiForgeryToken()
    </div>
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" data-credito-cliente-panel-close></div>
    <aside class="absolute right-0 top-0 h-full w-full max-w-6xl bg-[#161d2c] shadow-2xl flex flex-col credito-cliente-panel-slide-in"
           role="dialog"
           aria-modal="true"
           aria-labelledby="credito-cliente-panel-title">
        <div class="flex h-full min-h-0 flex-col" data-credito-cliente-panel-content></div>
    </aside>
</div>

@foreach (var clienteGrupo in clientes)
{
    var clienteNombrePanel = clienteGrupo.Cliente.NombreCompleto;
    if (string.IsNullOrWhiteSpace(clienteNombrePanel))
    {
        clienteNombrePanel = $"Cliente #{clienteGrupo.Cliente.Id}";
    }

    var proximoVencimientoTexto = clienteGrupo.ProximoVencimiento.HasValue
        ? clienteGrupo.ProximoVencimiento.Value.ToString("dd/MM/yyyy")
        : "Sin vencimientos";

    <template data-credito-cliente-panel-template="@clienteGrupo.Cliente.Id">
        <header class="flex shrink-0 flex-col gap-5 border-b border-slate-800 bg-[#161d2c]/80 px-6 py-5 backdrop-blur-sm">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                <div class="min-w-0">
                    <nav class="mb-1 flex items-center gap-2 text-xs font-medium text-slate-400">
                        <span>Créditos</span>
                        <span class="material-symbols-outlined text-xs">chevron_right</span>
                        <span class="text-slate-100">Gestión cliente</span>
                    </nav>
                    <h2 id="credito-cliente-panel-title" class="truncate text-2xl font-black tracking-tight text-slate-50">@clienteNombrePanel</h2>
                    <p class="mt-1 text-sm text-slate-400">Documento @clienteGrupo.Documento</p>
                </div>
                <button type="button"
                        class="inline-flex size-10 items-center justify-center rounded-lg border border-slate-700 text-slate-300 transition-colors hover:bg-slate-800 hover:text-white"
                        title="Cerrar panel"
                        data-credito-cliente-panel-close>
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <div class="grid grid-cols-2 gap-3 lg:grid-cols-4">
                <article class="rounded-lg border border-slate-800 bg-slate-900/70 p-4">
                    <p class="text-[11px] font-bold uppercase tracking-wider text-slate-400">Créditos filtrados</p>
                    <p class="mt-1 text-xl font-black text-white">@clienteGrupo.CantidadCreditos</p>
                </article>
                <article class="rounded-lg border border-slate-800 bg-slate-900/70 p-4">
                    <p class="text-[11px] font-bold uppercase tracking-wider text-slate-400">Saldo filtrado</p>
                    <p class="mt-1 text-xl font-black text-white">$ @clienteGrupo.SaldoPendienteTotal.ToString("N0")</p>
                </article>
                <article class="rounded-lg border border-slate-800 bg-slate-900/70 p-4">
                    <p class="text-[11px] font-bold uppercase tracking-wider text-slate-400">Cuotas vencidas</p>
                    <p class="mt-1 text-xl font-black @(clienteGrupo.CuotasVencidas > 0 ? "text-red-400" : "text-emerald-400")">@clienteGrupo.CuotasVencidas</p>
                </article>
                <article class="rounded-lg border border-slate-800 bg-slate-900/70 p-4">
                    <p class="text-[11px] font-bold uppercase tracking-wider text-slate-400">Próximo vencimiento</p>
                    <p class="mt-1 text-xl font-black text-white">@proximoVencimientoTexto</p>
                </article>
            </div>
        </header>

        <div class="flex-1 space-y-4 overflow-y-auto px-6 py-6" data-credito-cliente-panel-scroll>
            <div class="flex items-center justify-between gap-3">
                <div>
                    <h3 class="text-lg font-black text-white">Créditos del cliente</h3>
                    <p class="text-sm text-slate-400">Listado filtrado disponible en el índice actual.</p>
                </div>
                <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-bold text-primary-on-dark">
                    @clienteGrupo.Creditos.Count crédito@(clienteGrupo.Creditos.Count == 1 ? "" : "s")
                </span>
            </div>

            @foreach (var credito in clienteGrupo.Creditos)
            {
                var cuotasCredito = credito.Cuotas ?? new List<CuotaViewModel>();
                var cantidadCuotasCredito = cuotasCredito.Any() ? cuotasCredito.Count : credito.CantidadCuotas;
                var numeroCredito = credito.Numero ?? $"CR-{credito.Id:D3}";
                var estadoCreditoClass = "bg-slate-800 text-slate-300";

                switch (credito.Estado)
                {
                    case EstadoCredito.Activo:
                    case EstadoCredito.Generado:
                        estadoCreditoClass = "bg-emerald-500/10 text-emerald-400";
                        break;
                    case EstadoCredito.Finalizado:
                        estadoCreditoClass = "bg-sky-500/10 text-sky-400";
                        break;
                    case EstadoCredito.Rechazado:
                    case EstadoCredito.Cancelado:
                        estadoCreditoClass = "bg-red-500/10 text-red-400";
                        break;
                    case EstadoCredito.Solicitado:
                    case EstadoCredito.Aprobado:
                    case EstadoCredito.PendienteConfiguracion:
                    case EstadoCredito.Configurado:
                        estadoCreditoClass = "bg-amber-500/10 text-amber-400";
                        break;
                }

                <article class="rounded-xl border border-slate-800 bg-slate-900/60 p-4 shadow-lg shadow-black/10" data-credito-cliente-credit>
                    <div class="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
                        <div class="min-w-0">
                            <div class="flex flex-wrap items-center gap-2">
                                <h4 class="text-base font-black text-white">@numeroCredito</h4>
                                <span class="rounded-full px-2.5 py-1 text-[10px] font-bold uppercase tracking-wide @estadoCreditoClass">@credito.Estado</span>
                            </div>
                            <p class="mt-1 text-xs text-slate-400">Fecha alta @credito.FechaSolicitud.ToString("dd/MM/yyyy")</p>
                        </div>
                        <dl class="grid w-full grid-cols-2 gap-3 text-sm xl:w-auto xl:grid-cols-4">
                            <div class="rounded-lg bg-slate-950/50 p-3">
                                <dt class="text-[10px] font-bold uppercase tracking-wider text-slate-500">Monto original</dt>
                                <dd class="mt-1 font-bold text-white">$ @credito.MontoSolicitado.ToString("N0")</dd>
                            </div>
                            <div class="rounded-lg bg-slate-950/50 p-3">
                                <dt class="text-[10px] font-bold uppercase tracking-wider text-slate-500">Saldo pendiente</dt>
                                <dd class="mt-1 font-bold @(credito.SaldoPendiente > 0 ? "text-red-400" : "text-emerald-400")">$ @credito.SaldoPendiente.ToString("N0")</dd>
                            </div>
                            <div class="rounded-lg bg-slate-950/50 p-3">
                                <dt class="text-[10px] font-bold uppercase tracking-wider text-slate-500">Estado</dt>
                                <dd class="mt-1 font-bold text-white">@credito.Estado</dd>
                            </div>
                            <div class="rounded-lg bg-slate-950/50 p-3">
                                <dt class="text-[10px] font-bold uppercase tracking-wider text-slate-500">Cuotas</dt>
                                <dd class="mt-1 font-bold text-white">@cantidadCuotasCredito</dd>
                            </div>
                        </dl>
                    </div>

                    <div class="mt-4 flex flex-col gap-3 border-t border-slate-800 pt-4 sm:flex-row sm:items-center sm:justify-between">
                        <div class="text-sm text-slate-400">
                            @cantidadCuotasCredito cuota@(cantidadCuotasCredito == 1 ? "" : "s") registrada@(cantidadCuotasCredito == 1 ? "" : "s")
                        </div>
                        <button type="button"
                                class="inline-flex items-center justify-center gap-2 rounded-lg border border-slate-700 px-3 py-2 text-xs font-bold text-slate-300 transition-colors hover:bg-slate-800 hover:text-white"
                                data-credito-credit-toggle
                                data-credito-credit-expanded="false"
                                aria-expanded="false">
                            <span class="material-symbols-outlined text-base" data-credito-credit-toggle-icon>expand_more</span>
                            <span data-credito-credit-toggle-label>Ver cuotas</span>
                        </button>
                    </div>

                    <div class="mt-3 hidden overflow-hidden rounded-lg border border-slate-800" data-credito-cuotas-container></div>

                    <template data-credito-cuotas-template>
                        @if (cuotasCredito.Any())
                        {
                            <div class="max-h-80 overflow-y-auto">
                                <table class="w-full text-left text-sm">
                                    <thead class="sticky top-0 bg-slate-950 text-[11px] font-bold uppercase tracking-wider text-slate-500">
                                        <tr>
                                            <th class="w-12 px-4 py-3">
                                                <span class="sr-only">Seleccionar</span>
                                            </th>
                                            <th class="px-4 py-3">Cuota</th>
                                            <th class="px-4 py-3">Vencimiento</th>
                                            <th class="px-4 py-3 text-right">Saldo</th>
                                            <th class="px-4 py-3 text-right">Estado</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-800">
                                        @foreach (var cuota in cuotasCredito.OrderBy(c => c.NumeroCuota))
                                        {
                                            var estadoCuotaClass = cuota.Estado switch
                                            {
                                                EstadoCuota.Pagada => "bg-emerald-500/10 text-emerald-400",
                                                EstadoCuota.Vencida => "bg-red-500/10 text-red-400",
                                                EstadoCuota.Parcial => "bg-amber-500/10 text-amber-400",
                                                EstadoCuota.Cancelada => "bg-slate-700 text-slate-300",
                                                _ => "bg-slate-800 text-slate-300"
                                            };

                                            var cuotaSaldoPendiente = cuota.SaldoPendiente;
                                            var cuotaMora = cuota.MontoPunitorio > 0 ? cuota.MontoPunitorio : 0;
                                            var cuotaSubtotal = cuotaSaldoPendiente - cuotaMora;
                                            if (cuotaSubtotal < 0)
                                            {
                                                cuotaSubtotal = 0;
                                            }

                                            var cuotaPagable = cuota.Estado != EstadoCuota.Pagada
                                                && cuota.Estado != EstadoCuota.Cancelada
                                                && cuotaSaldoPendiente > 0;
                                            var cuotaRowClass = cuotaPagable
                                                ? "hover:bg-slate-800/40"
                                                : "opacity-60";

                                            <tr class="@cuotaRowClass" data-credito-cliente-cuota>
                                                <td class="px-4 py-3">
                                                    <input type="checkbox"
                                                           class="size-4 rounded border-slate-600 bg-slate-950 text-primary focus:ring-primary/40 disabled:cursor-not-allowed disabled:opacity-40"
                                                           data-credito-cuota-selector
                                                           data-credito-id="@credito.Id"
                                                           data-cuota-id="@cuota.Id"
                                                           data-cuota-subtotal="@cuotaSubtotal.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                           data-cuota-mora="@cuotaMora.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                           data-cuota-total="@cuotaSaldoPendiente.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                           aria-label="Seleccionar cuota #@cuota.NumeroCuota de @numeroCredito"
                                                           disabled="@(!cuotaPagable)" />
                                                </td>
                                                <td class="px-4 py-3 font-semibold text-white">#@cuota.NumeroCuota</td>
                                                <td class="px-4 py-3 text-slate-300">@cuota.FechaVencimiento.ToString("dd/MM/yyyy")</td>
                                                <td class="px-4 py-3 text-right font-semibold text-white">$ @cuotaSaldoPendiente.ToString("N2")</td>
                                                <td class="px-4 py-3 text-right">
                                                    <span class="rounded-full px-2.5 py-1 text-[10px] font-bold uppercase tracking-wide @estadoCuotaClass">@cuota.Estado</span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="px-4 py-6 text-sm text-slate-400">
                                Este crédito todavía no tiene cuotas cargadas en el índice.
                            </div>
                        }
                    </template>
                </article>
            }
        </div>

        <footer class="sticky bottom-0 z-10 shrink-0 border-t border-slate-800 bg-[#161d2c]/95 px-6 py-4 shadow-[0_-12px_30px_rgba(0,0,0,0.25)] backdrop-blur-sm" data-credito-pago-resumen>
            <div class="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">
                <div class="grid grid-cols-2 gap-3 md:grid-cols-5 xl:flex xl:items-center xl:gap-5">
                    <div>
                        <p class="text-[10px] font-bold uppercase tracking-wider text-slate-500">Cuotas seleccionadas</p>
                        <p class="mt-1 text-lg font-black text-white" data-credito-resumen-cuotas>0</p>
                    </div>
                    <div>
                        <p class="text-[10px] font-bold uppercase tracking-wider text-slate-500">Créditos involucrados</p>
                        <p class="mt-1 text-lg font-black text-white" data-credito-resumen-creditos>0</p>
                    </div>
                    <div>
                        <p class="text-[10px] font-bold uppercase tracking-wider text-slate-500">Subtotal</p>
                        <p class="mt-1 text-lg font-black text-white" data-credito-resumen-subtotal>$ 0,00</p>
                    </div>
                    <div>
                        <p class="text-[10px] font-bold uppercase tracking-wider text-slate-500">Mora total</p>
                        <p class="mt-1 text-lg font-black text-amber-400" data-credito-resumen-mora>$ 0,00</p>
                    </div>
                    <div>
                        <p class="text-[10px] font-bold uppercase tracking-wider text-slate-500">Total final</p>
                        <p class="mt-1 text-xl font-black text-primary-on-dark" data-credito-resumen-total>$ 0,00</p>
                    </div>
                </div>

                <div class="flex flex-col gap-2 sm:flex-row sm:items-end">
                    <div class="min-w-44">
                        <label for="credito-pago-medio-@clienteGrupo.Cliente.Id" class="mb-1 block text-[10px] font-bold uppercase tracking-wider text-slate-500">Medio de pago</label>
                        <select id="credito-pago-medio-@clienteGrupo.Cliente.Id"
                                class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-sm font-semibold text-white transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30 disabled:cursor-not-allowed disabled:opacity-60"
                                data-credito-medio-pago>
                            <option value="Efectivo">Efectivo</option>
                            <option value="Transferencia">Transferencia</option>
                            <option value="Tarjeta Débito">Tarjeta Débito</option>
                            <option value="Tarjeta Crédito">Tarjeta Crédito</option>
                            <option value="Cheque">Cheque</option>
                        </select>
                    </div>
                    <p class="hidden text-xs font-semibold text-amber-400" role="status" aria-live="polite" data-credito-pago-status data-credito-pago-pendiente></p>
                    <button type="button"
                            class="inline-flex items-center justify-center gap-2 rounded-lg bg-primary px-4 py-3 text-sm font-black text-white shadow-lg shadow-primary/20 transition-colors hover:bg-primary-dark disabled:cursor-not-allowed disabled:bg-slate-700 disabled:text-slate-400 disabled:shadow-none"
                            data-credito-registrar-pago-multiple
                            data-credito-pago-url="@Url.Action("RegistrarPagoMultiple", "Credito")"
                            disabled>
                        <span class="material-symbols-outlined text-base" data-credito-registrar-pago-icon>payments</span>
                        <span data-credito-registrar-pago-label>Registrar pago</span>
                    </button>
                </div>
            </div>
        </footer>
    </template>
}

@section Scripts {
    <script src="~/js/module-index.js" asp-append-version="true"></script>
    <script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
    <script src="~/js/credito-module.js" asp-append-version="true"></script>
    <script src="~/js/credito-index.js" asp-append-version="true"></script>
}
