@model PagarCuotaViewModel
@{
    ViewData["Title"] = "Registrar Pago de Cuota";
    var returnUrl = ViewData["ReturnUrl"] as string;
    var cuotasJson = Model.CuotasJson;
    var montoPagadoInvariant = Model.MontoPagado.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
    var totalAPagarInvariant = Model.TotalAPagar.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
    var volverHref = !string.IsNullOrWhiteSpace(returnUrl)
        ? returnUrl
        : Url.Action("Details", "Credito", new { id = Model.CreditoId }) ?? $"/Credito/Details/{Model.CreditoId}";
    var estadoBadgeClasses = Model.EstaVencida
        ? "chip chip-bad"
        : "chip chip-ok";
    var estadoTexto = Model.EstaVencida
        ? $"Vencida · {Model.DiasAtraso} días"
        : "Vigente";
}

@section Styles {
    <partial name="_CreditoModuleStyles" />
}

<div data-credito-pago>
    <main class="shell" style="padding-top:1.5rem;padding-bottom:3rem;max-width:1000px">
        <a href="@volverHref" class="inline-flex items-center gap-1.5 text-sm muted hover:text-white transition" style="text-decoration:none">
            <span class="material-symbols-outlined" style="font-size:18px">arrow_back</span>
            Volver al crédito
        </a>

        <div class="page-head" style="margin-top:.95rem">
            <div class="min-w-0">
                <h1 class="page-title" style="font-size:1.4rem">Registrar pago de cuota</h1>
                <p class="page-sub" style="margin-top:.3rem">
                    Crédito <span class="mono">@Model.NumeroCreditoTexto</span> · @Model.ClienteNombre · Total seleccionado
                    <span class="mono" data-credito-cuota-field="total-metric">@Model.TotalAPagar.ToString("C")</span>
                </p>
            </div>
        </div>

        <form id="pago-form"
              data-credito-pago-form
              asp-action="PagarCuota"
              method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 class="alert alert-bad empty:hidden"
                 style="margin-top:1.25rem"
                 role="alert"></div>

            <input type="hidden" asp-for="CreditoId" />
            <input type="hidden" asp-for="CuotaId" id="hdn-cuota-id" />
            <input type="hidden" asp-for="NumeroCuota" id="hdn-numero-cuota" />
            <input type="hidden" asp-for="MontoCuota" id="hdn-monto-cuota" />
            <input type="hidden" asp-for="MontoPunitorio" id="hdn-punitorio" />
            <input type="hidden" asp-for="TotalAPagar" id="hdn-total" />
            <input type="hidden" asp-for="ClienteNombre" />
            <input type="hidden" asp-for="NumeroCreditoTexto" />
            <input type="hidden" asp-for="FechaVencimiento" id="hdn-fecha-vto" />
            <input type="hidden" asp-for="EstaVencida" id="hdn-esta-vencida" />
            <input type="hidden" asp-for="DiasAtraso" id="hdn-dias-atraso" />
            @if (returnUrl != null)
            {
                <input type="hidden" name="returnUrl" value="@returnUrl" />
            }

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-4" style="margin-top:1.25rem">
                <div class="lg:col-span-2 space-y-4">
                    <section class="card card-pad">
                        <div class="sec-head">
                            <div class="sec-num">1</div>
                            <div>
                                <div class="sec-title">Cuota a pagar</div>
                                <div class="sec-sub">Seleccioná la cuota pendiente y confirmá los importes calculados.</div>
                            </div>
                        </div>

                        <label class="radio-card is-sel" for="select-cuota">
                            <span class="rc-dot"></span>
                            <span class="flex-1 min-w-0">
                                <span class="flex items-center justify-between gap-2">
                                    <span class="rc-title">
                                        Cuota <span data-credito-cuota-field="numero">@Model.NumeroCuota</span>
                                        <span class="text-xs muted-2 font-normal">
                                            · vence <span data-credito-cuota-field="vencimiento">@Model.FechaVencimiento.ToString("dd/MM/yyyy")</span>
                                        </span>
                                    </span>
                                    <span class="num font-semibold text-white" data-credito-cuota-field="total">@Model.TotalAPagar.ToString("C")</span>
                                </span>
                                <span class="rc-sub">
                                    <span data-credito-cuota-field="estado-badge" class="@estadoBadgeClasses">
                                        <span data-credito-cuota-field="estado">@estadoTexto</span>
                                    </span>
                                </span>
                            </span>
                        </label>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3" style="margin-top:1rem">
                            <div>
                                <label asp-for="CuotaId" class="label">Cuota seleccionada</label>
                                <select id="select-cuota"
                                        data-credito-cuota-select
                                        class="field">
                                    @foreach (var item in Model.Cuotas)
                                    {
                                        <option value="@item.Value" selected="@(item.Value == Model.CuotaId.ToString() ? "selected" : null)">@item.Text</option>
                                    }
                                </select>
                            </div>
                            <div>
                                <label asp-for="FechaPago" class="label">Fecha de pago <span class="req">*</span></label>
                                <input asp-for="FechaPago"
                                       type="date"
                                       class="field" />
                                <span asp-validation-for="FechaPago" class="err-text"></span>
                            </div>
                        </div>

                        <dl class="kv mt-3">
                            <div class="kv-row">
                                <dt>Monto cuota</dt>
                                <dd class="num" data-credito-cuota-field="monto-cuota">@Model.MontoCuota.ToString("C")</dd>
                            </div>
                            <div class="kv-row">
                                <dt>Punitorios / mora</dt>
                                <dd class="num" data-credito-cuota-field="punitorio" style="color:#fbbf24">@Model.MontoPunitorio.ToString("C")</dd>
                            </div>
                            <div class="kv-row">
                                <dt>Detalle de estado</dt>
                                <dd>
                                    <span data-credito-cuota-field="estado-summary">@(Model.EstaVencida ? "Vencida" : "Vigente")</span>
                                    · <span data-credito-cuota-field="estado-detail">@(Model.EstaVencida ? $"{Model.DiasAtraso} días de atraso" : "sin mora activa")</span>
                                </dd>
                            </div>
                        </dl>
                    </section>

                    <section class="card card-pad">
                        <div class="sec-head">
                            <div class="sec-num">2</div>
                            <div>
                                <div class="sec-title">Datos del pago</div>
                                <div class="sec-sub">Medio, comprobante y observaciones.</div>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                            <div>
                                <label asp-for="MedioPago" class="label">Medio de pago <span class="req">*</span></label>
                                <select asp-for="MedioPago"
                                        class="field"
                                        data-credito-cuota-field="medio">
                                    <option value="Efectivo">Efectivo</option>
                                    <option value="Transferencia">Transferencia</option>
                                    <option value="Tarjeta Débito">Tarjeta Débito</option>
                                    <option value="Tarjeta Crédito">Tarjeta Crédito</option>
                                    <option value="Cheque">Cheque</option>
                                </select>
                                <span asp-validation-for="MedioPago" class="err-text"></span>
                            </div>
                            <div>
                                <label asp-for="ComprobantePago" class="label">N° de comprobante</label>
                                <input asp-for="ComprobantePago"
                                       class="field mono"
                                       placeholder="Ej. 0001-00045821" />
                                <span asp-validation-for="ComprobantePago" class="err-text"></span>
                            </div>
                            <div>
                                <label asp-for="MontoPagado" class="label">Monto a pagar <span class="req">*</span></label>
                                <div class="field-money">
                                    <span class="cur">$</span>
                                    <input id="input-monto"
                                           data-credito-monto-input
                                           name="MontoPagado"
                                           type="text"
                                           inputmode="decimal"
                                           autocomplete="off"
                                           value="@montoPagadoInvariant"
                                           data-max="@totalAPagarInvariant"
                                           class="field mono"
                                           placeholder="0,00" />
                                </div>
                                <p id="monto-error" data-credito-monto-error class="hint hidden" style="color:#fb7185"></p>
                                <span asp-validation-for="MontoPagado" class="err-text"></span>
                            </div>
                            <div class="sm:col-span-2">
                                <label asp-for="Observaciones" class="label">Observaciones</label>
                                <textarea asp-for="Observaciones"
                                          class="field"
                                          placeholder="Comentario interno del pago (opcional)..."></textarea>
                                <span asp-validation-for="Observaciones" class="err-text"></span>
                            </div>
                        </div>
                    </section>
                </div>

                <aside>
                    <div class="card card-pad" style="position:sticky;top:76px">
                        <h3 class="font-semibold text-white mb-3 flex items-center gap-2">
                            <span class="material-symbols-outlined" style="color:#f5c518;font-size:20px">receipt</span>
                            Resumen del pago
                        </h3>
                        <div class="result-card is-ok">
                            <div class="result-label">Total a pagar</div>
                            <div class="result-value" id="r-total" data-credito-cuota-field="total-preview">@Model.TotalAPagar.ToString("C")</div>
                        </div>
                        <dl class="kv mt-3">
                            <div class="kv-row">
                                <dt>Cuota seleccionada</dt>
                                <dd id="r-count">#<span data-credito-cuota-field="numero-card">@Model.NumeroCuota</span></dd>
                            </div>
                            <div class="kv-row">
                                <dt>Monto ingresado</dt>
                                <dd class="num" id="r-sub" data-credito-cuota-field="monto-preview">@Model.MontoPagado.ToString("C")</dd>
                            </div>
                            <div class="kv-row hidden" id="row-recargo-medio" data-recargo-medio-row>
                                <dt>Recargo medio de pago <span id="recargo-medio-pct" class="mono"></span></dt>
                                <dd class="num" id="r-recargo-medio" data-recargo-medio-valor>$ 0,00</dd>
                            </div>
                            <div class="kv-row hidden" id="row-total-con-recargo" data-total-con-recargo-row>
                                <dt><strong>Total a cobrar</strong></dt>
                                <dd class="num" id="r-total-con-recargo" data-total-con-recargo-valor><strong>$ 0,00</strong></dd>
                            </div>
                            <div class="kv-row">
                                <dt>Vencimiento</dt>
                                <dd class="num" id="r-mora" data-credito-cuota-field="vencimiento-metric">@Model.FechaVencimiento.ToString("dd/MM")</dd>
                            </div>
                        </dl>
                        <button type="submit" class="btn btn-success btn-block btn-lg" id="btn-pagar" style="margin-top:1.1rem">
                            <span class="material-symbols-outlined">payments</span>
                            Registrar pago
                        </button>
                        <a href="@volverHref" class="btn btn-ghost btn-block btn-sm" style="margin-top:.5rem">Cancelar</a>
                        <p class="hint" style="text-align:center;margin-top:.6rem">El pago se imputa según vencimiento. La mora se calcula al día de hoy.</p>
                    </div>
                </aside>
            </div>
        </form>
    </main>
</div>

<script id="credito-cuotas-data" data-credito-json="cuotas" type="application/json">@Html.Raw(cuotasJson)</script>
<script id="credito-recargos-medio-data" type="application/json">@Html.Raw(Model.RecargosPorMedioJson)</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/credito-module.js" asp-append-version="true"></script>
    <script src="~/js/credito-pagar-cuota.js" asp-append-version="true"></script>
    <script>
        // Previsualización del recargo del medio de pago sobre el monto ingresado.
        // Solo informativo: el backend recalcula y es la autoridad al confirmar el cobro.
        (function () {
            'use strict';
            var recargos = {};
            try {
                recargos = JSON.parse(document.getElementById('credito-recargos-medio-data').textContent) || {};
            } catch (e) { recargos = {}; }

            var selMedio = document.querySelector('[data-credito-cuota-field="medio"]');
            var inputMonto = document.querySelector('[data-credito-monto-input]');
            var rowRecargo = document.querySelector('[data-recargo-medio-row]');
            var pctSpan = document.getElementById('recargo-medio-pct');
            var valRecargo = document.querySelector('[data-recargo-medio-valor]');
            var rowTotal = document.querySelector('[data-total-con-recargo-row]');
            var valTotal = document.querySelector('[data-total-con-recargo-valor]');

            function parseMonto(v) {
                if (!v) return 0;
                var n = parseFloat(String(v).replace(/\./g, '').replace(',', '.'));
                return isNaN(n) ? 0 : n;
            }
            function fmt(n) {
                return '$ ' + n.toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            }
            function actualizar() {
                if (!selMedio || !inputMonto) return;
                var pct = recargos[selMedio.value] || 0;
                var base = parseMonto(inputMonto.value);
                var recargo = pct === 0 ? 0 : Math.round(base * pct) / 100;
                if (pct !== 0 && base > 0) {
                    if (pctSpan) pctSpan.textContent = '(' + pct.toFixed(2).replace('.', ',') + '%)';
                    if (valRecargo) valRecargo.textContent = fmt(recargo);
                    if (valTotal) valTotal.innerHTML = '<strong>' + fmt(base + recargo) + '</strong>';
                    if (rowRecargo) rowRecargo.classList.remove('hidden');
                    if (rowTotal) rowTotal.classList.remove('hidden');
                } else {
                    if (rowRecargo) rowRecargo.classList.add('hidden');
                    if (rowTotal) rowTotal.classList.add('hidden');
                }
            }
            selMedio && selMedio.addEventListener('change', actualizar);
            inputMonto && inputMonto.addEventListener('input', actualizar);
            actualizar();
        })();
    </script>
}
