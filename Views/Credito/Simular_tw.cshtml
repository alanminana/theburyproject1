@model SimularCreditoViewModel
@{
    ViewData["Title"] = "Simulador de Crédito";
    var returnUrl = ViewData["ReturnUrl"] as string;
    var volverHref = !string.IsNullOrWhiteSpace(returnUrl)
        ? returnUrl
        : Url.Action("Index", "Credito") ?? "/Credito";
    var tieneResultado = Model.PlanPagos != null && Model.PlanPagos.Any();
    var tasaPorcentaje = Model.TasaInteresMensual * 100;
}

<header class="topbar">
    <div class="shell topbar-inner">
        <div class="brand">
            <span class="brand-badge">
                <span class="material-symbols-outlined" style="color:#fff;font-size:18px" aria-hidden="true">credit_score</span>
            </span>
            Creditos
        </div>
        <nav class="breadcrumb" style="margin-left:.5rem" aria-label="Migas de pan">
            <span class="sep">/</span>
            <a asp-controller="Credito" asp-action="Index">Creditos</a>
            <span class="sep">/</span>
            <span style="color:#cbd5e1">Simular</span>
        </nav>
        <div style="margin-left:auto" class="flex items-center gap-2">
            <span class="hide-mobile text-xs muted-2 mono">Casa Central</span>
            <div class="w-8 h-8 rounded-full bg-slate-700 grid place-items-center text-xs font-semibold text-slate-200" aria-hidden="true">LF</div>
        </div>
    </div>
</header>

<main class="shell" style="padding-top:1.5rem;padding-bottom:3rem">
    <a href="@volverHref" class="inline-flex items-center gap-1.5 text-sm muted hover:text-white transition" style="text-decoration:none">
        <span class="material-symbols-outlined" style="font-size:18px" aria-hidden="true">arrow_back</span>
        Volver a creditos
    </a>

    <div class="page-head" style="margin-top:.95rem">
        <div class="min-w-0">
            <h1 class="page-title" style="font-size:1.4rem">Simulador de credito</h1>
            <p class="page-sub" style="margin-top:.3rem">Calcula un plan de pagos orientativo por sistema frances (cuota fija). No genera ninguna operacion.</p>
        </div>
    </div>

    @if (TempData["Error"] is string errorMsg)
    {
        <div class="alert alert-bad" style="margin-top:1.25rem">
            <span class="material-symbols-outlined" aria-hidden="true">error</span>
            <span>@errorMsg</span>
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4" style="margin-top:1.25rem">
        <form asp-action="Simular" method="post" class="lg:col-span-1">
            <div class="card card-pad space-y-4">
                <h2 class="font-semibold text-white flex items-center gap-2">
                    <span class="material-symbols-outlined" style="color:#f5c518;font-size:20px" aria-hidden="true">tune</span>
                    Parametros
                </h2>

                @Html.AntiForgeryToken()
                @if (returnUrl != null)
                {
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                }

                <div asp-validation-summary="ModelOnly" class="alert alert-bad empty:hidden"></div>

                <div>
                    <label asp-for="MontoSolicitado" class="label">Monto solicitado <span class="req">*</span></label>
                    <div class="field-money">
                        <span class="cur">$</span>
                        <input asp-for="MontoSolicitado" type="number" min="1000" step="100" class="field mono" placeholder="Ej: 50000" />
                    </div>
                    <span asp-validation-for="MontoSolicitado" class="err-text"></span>
                </div>

                <div>
                    <label asp-for="TasaInteresMensual" class="label">Tasa de interes mensual <span class="req">*</span></label>
                    <div class="field-icon">
                        <span class="material-symbols-outlined" aria-hidden="true">percent</span>
                        <input asp-for="TasaInteresMensual" type="number" min="0" max="1" step="0.001" class="field mono" placeholder="Ej: 0.05" />
                    </div>
                    <p class="hint">Ingresa la tasa como decimal. Actual: @tasaPorcentaje.ToString("N2")% mensual.</p>
                    <span asp-validation-for="TasaInteresMensual" class="err-text"></span>
                </div>

                <div>
                    <label asp-for="CantidadCuotas" class="label">Cantidad de cuotas <span class="req">*</span></label>
                    <input asp-for="CantidadCuotas" type="number" min="1" max="60" class="field" placeholder="Ej: 12" />
                    <span asp-validation-for="CantidadCuotas" class="err-text"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-block">
                    <span class="material-symbols-outlined" aria-hidden="true">calculate</span>
                    Simular
                </button>
            </div>
        </form>

        <div class="lg:col-span-2 space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-2.5">
                <div class="kpi kpi--accent">
                    <div class="kpi-label">Cuota mensual</div>
                    <div class="kpi-value" style="font-size:1.4rem">@(tieneResultado ? Model.MontoCuota.ToString("C") : "$ 0")</div>
                </div>
                <div class="kpi">
                    <div class="kpi-label">Total a pagar</div>
                    <div class="kpi-value" style="font-size:1.4rem">@(tieneResultado ? Model.TotalAPagar.ToString("C") : "$ 0")</div>
                </div>
                <div class="kpi kpi--warn">
                    <div class="kpi-label">Interes total</div>
                    <div class="kpi-value" style="font-size:1.4rem">@(tieneResultado ? Model.TotalIntereses.ToString("C") : "$ 0")</div>
                </div>
            </div>

            <section class="card" style="overflow:hidden">
                <div class="card-pad flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between" style="padding-bottom:.6rem">
                    <h2 class="font-semibold text-white flex items-center gap-2">
                        <span class="material-symbols-outlined" style="color:#94a3b8;font-size:20px" aria-hidden="true">calendar_month</span>
                        Plan de cuotas
                    </h2>
                    @if (tieneResultado)
                    {
                        <span class="chip chip-info">CFTEA @Model.CFTEA.ToString("P2")</span>
                    }
                </div>
                <div class="tbl-wrap" style="max-height:420px;overflow-y:auto">
                    <table class="plan-tbl">
                        <thead>
                            <tr>
                                <th>Cuota</th>
                                <th>Capital</th>
                                <th>Interes</th>
                                <th>Cuota</th>
                                <th>Saldo</th>
                            </tr>
                        </thead>
                        @if (tieneResultado)
                        {
                            <tbody>
                                @foreach (var cuota in Model.PlanPagos!)
                                {
                                    <tr>
                                        <td>
                                            <span class="text-white" style="font-weight:600">#@cuota.NumeroCuota</span>
                                            <span class="block muted-2" style="font-size:.72rem">@cuota.FechaVencimiento.ToString("dd/MM/yyyy")</span>
                                        </td>
                                        <td>@cuota.MontoCapital.ToString("C")</td>
                                        <td>@cuota.MontoInteres.ToString("C")</td>
                                        <td class="text-white" style="font-weight:600">@cuota.MontoTotal.ToString("C")</td>
                                        <td>@cuota.SaldoCapital.ToString("C")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td>Totales</td>
                                    <td>@Model.MontoSolicitado.ToString("C")</td>
                                    <td>@Model.TotalIntereses.ToString("C")</td>
                                    <td>@Model.TotalAPagar.ToString("C")</td>
                                    <td>-</td>
                                </tr>
                            </tfoot>
                        }
                        else
                        {
                            <tbody>
                                <tr>
                                    <td colspan="5" class="muted" style="text-align:center;padding:2.2rem .9rem">
                                        Ingresa los parametros y ejecuta la simulacion para ver el plan de cuotas.
                                    </td>
                                </tr>
                            </tbody>
                        }
                    </table>
                </div>
            </section>
        </div>
    </div>
</main>

@section Styles {
    <partial name="_CreditoModuleStyles" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/shared-ui.js" asp-append-version="true"></script>
}
