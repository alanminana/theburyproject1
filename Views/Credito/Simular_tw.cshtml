@model SimularCreditoViewModel
@{
    ViewData["Title"] = "Simulador de Crédito";
    var returnUrl = ViewData["ReturnUrl"] as string;
    var volverHref = !string.IsNullOrWhiteSpace(returnUrl)
        ? returnUrl
        : Url.Action("Index", "Credito") ?? "/Credito";
    var tieneResultado = Model.PlanPagos != null && Model.PlanPagos.Any();
    var tasaPorcentaje = Model.TasaInteresMensual * 100;
}

@if (TempData["Error"] is string errorMsg)
{
    <div class="mb-4 flex items-center gap-3 rounded-lg border border-rose-500/20 bg-rose-500/10 p-4 text-rose-400">
        <span class="material-symbols-outlined">error</span>
        <p class="text-sm font-medium">@errorMsg</p>
    </div>
}

<div class="space-y-6">

    <section class="card-erp-panel-padded">
        <header class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <div class="space-y-2">
                <span class="badge-erp badge-erp-primary">
                    <span class="material-symbols-outlined text-sm">calculate</span>
                    Simulador
                </span>
                <h1 class="text-3xl font-black tracking-tight text-white sm:text-4xl">Simulador de Crédito</h1>
                <p class="max-w-2xl text-sm text-slate-400">
                    Calculá el plan de cuotas estimado antes de crear una línea de crédito. Los resultados son orientativos.
                </p>
            </div>
            <a href="@volverHref"
               class="btn-erp-ghost h-10 self-start no-underline">
                <span class="material-symbols-outlined text-[18px]">arrow_back</span>
                Volver
            </a>
        </header>
    </section>

    <div class="grid grid-cols-1 gap-6 xl:grid-cols-[380px_minmax(0,1fr)]">

        <section class="card-erp-panel-padded">
            <h2 class="text-base font-bold text-white">Parámetros de simulación</h2>
            <p class="mt-1 text-sm text-slate-400">Ingresá los datos del crédito para calcular el plan de cuotas.</p>

            <form asp-action="Simular" method="post" class="mt-5 flex flex-col gap-5">
                @Html.AntiForgeryToken()
                @if (returnUrl != null)
                {
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                }

                <div asp-validation-summary="ModelOnly"
                     class="text-sm text-red-500 bg-red-500/10 border border-red-500/20 rounded-lg p-3 empty:hidden"></div>

                <div>
                    <label asp-for="MontoSolicitado" class="mb-1.5 block text-xs font-bold uppercase tracking-wider text-slate-400">
                        Monto del crédito <span class="text-rose-500">*</span>
                    </label>
                    <div class="relative">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-sm font-bold text-slate-400">$</span>
                        <input asp-for="MontoSolicitado"
                               type="number"
                               step="100"
                               min="1000"
                               class="credito-input pl-7"
                               placeholder="Ej: 50000" />
                    </div>
                    <span asp-validation-for="MontoSolicitado" class="mt-1 text-xs text-red-500"></span>
                </div>

                <div>
                    <label asp-for="TasaInteresMensual" class="mb-1.5 block text-xs font-bold uppercase tracking-wider text-slate-400">
                        Tasa mensual (0 a 1) <span class="text-rose-500">*</span>
                    </label>
                    <div class="relative">
                        <input asp-for="TasaInteresMensual"
                               type="number"
                               step="0.001"
                               min="0"
                               max="1"
                               class="credito-input"
                               placeholder="Ej: 0.05 = 5%" />
                    </div>
                    <p class="mt-1 text-xs text-slate-400">Ejemplo: 0.05 equivale al 5% mensual</p>
                    <span asp-validation-for="TasaInteresMensual" class="mt-1 text-xs text-red-500"></span>
                </div>

                <div>
                    <label asp-for="CantidadCuotas" class="mb-1.5 block text-xs font-bold uppercase tracking-wider text-slate-400">
                        Cantidad de cuotas <span class="text-rose-500">*</span>
                    </label>
                    <input asp-for="CantidadCuotas"
                           type="number"
                           min="1"
                           max="60"
                           class="credito-input"
                           placeholder="Ej: 12" />
                    <span asp-validation-for="CantidadCuotas" class="mt-1 text-xs text-red-500"></span>
                </div>

                <button type="submit"
                        class="mt-2 inline-flex h-11 items-center justify-center gap-2 rounded-xl bg-primary px-5 text-sm font-bold text-white shadow-lg shadow-primary/20 transition-colors hover:bg-primary/90">
                    <span class="material-symbols-outlined text-[18px]">calculate</span>
                    Calcular simulación
                </button>
            </form>
        </section>

        <div class="space-y-6">
            @if (tieneResultado)
            {
                <section class="rounded-2xl border border-primary/20 bg-primary/10 p-6 shadow-sm">
                    <h2 class="flex items-center gap-2 text-base font-bold text-white">
                        <span class="material-symbols-outlined text-primary text-[20px]">assessment</span>
                        Resultado de la simulación
                    </h2>
                    <div class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-4">
                        <div class="card-erp-panel px-4 py-4">
                            <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-slate-400">Cuota estimada</p>
                            <p class="mt-2 text-xl font-black text-primary">@Model.MontoCuota.ToString("C")</p>
                        </div>
                        <div class="card-erp-panel px-4 py-4">
                            <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-slate-400">Total a pagar</p>
                            <p class="mt-2 text-xl font-black text-white">@Model.TotalAPagar.ToString("C")</p>
                        </div>
                        <div class="card-erp-panel px-4 py-4">
                            <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-slate-400">Total intereses</p>
                            <p class="mt-2 text-xl font-black text-orange-500 text-orange-400">@Model.TotalIntereses.ToString("C")</p>
                        </div>
                        <div class="card-erp-panel px-4 py-4">
                            <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-slate-400">CFTEA</p>
                            <p class="mt-2 text-xl font-black text-white">@Model.CFTEA.ToString("P2")</p>
                        </div>
                    </div>
                </section>

                <section class="card-erp-panel">
                    <div class="border-b border-slate-800 px-6 py-5">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary text-[20px]">table_rows</span>
                            <h2 class="text-base font-bold text-white">Plan de cuotas estimado</h2>
                        </div>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse text-sm">
                            <thead>
                                <tr class="border-b border-slate-800">
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-slate-500 text-center">#</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-slate-500">Vencimiento</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-slate-500 text-right">Capital</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-slate-500 text-right">Interés</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-slate-500 text-right">Total cuota</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-wider text-slate-500 text-right">Saldo capital</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-800/50">
                                @foreach (var cuota in Model.PlanPagos!)
                                {
                                    <tr class="transition-colors hover:bg-slate-800/40">
                                        <td class="px-4 py-2.5 text-center">
                                            <span class="inline-flex items-center justify-center rounded-full bg-slate-100 w-7 h-7 text-xs font-bold bg-slate-800 text-slate-300">
                                                @cuota.NumeroCuota
                                            </span>
                                        </td>
                                        <td class="px-4 py-2.5 text-slate-400">@cuota.FechaVencimiento.ToString("dd/MM/yyyy")</td>
                                        <td class="px-4 py-2.5 text-right text-white">@cuota.MontoCapital.ToString("C")</td>
                                        <td class="px-4 py-2.5 text-right text-orange-500 text-orange-400">@cuota.MontoInteres.ToString("C")</td>
                                        <td class="px-4 py-2.5 text-right font-bold text-primary">@cuota.MontoTotal.ToString("C")</td>
                                        <td class="px-4 py-2.5 text-right text-slate-400">@cuota.SaldoCapital.ToString("C")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </section>
            }
            else
            {
                <section class="rounded-2xl border border-dashed border-slate-700 bg-slate-900/30 p-12 text-center">
                    <span class="material-symbols-outlined text-4xl text-slate-600">calculate</span>
                    <h3 class="mt-3 text-base font-bold text-slate-400">Ingresá los parámetros para simular</h3>
                    <p class="mt-1 text-sm text-slate-400 text-slate-500">El plan de cuotas estimado aparecerá aquí una vez que ejecutes la simulación.</p>
                </section>
            }
        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/shared-ui.js" asp-append-version="true"></script>
}
