@using TheBuryProject.Models.Enums
@model TheBuryProject.ViewModels.CreditoClienteIndexViewModel

@{
    var clienteNombre = Model.Cliente.NombreCompleto;
    if (string.IsNullOrWhiteSpace(clienteNombre))
    {
        clienteNombre = $"Cliente #{Model.Cliente.Id}";
    }

    var proximoVencimientoTexto = Model.ProximoVencimiento.HasValue
        ? Model.ProximoVencimiento.Value.ToString("dd/MM/yyyy")
        : "Sin vencimientos";

    var initialsParts = clienteNombre.Split(' ', StringSplitOptions.RemoveEmptyEntries);
    var initials = initialsParts.Length >= 2
        ? $"{initialsParts[0][0]}{initialsParts[1][0]}".ToUpperInvariant()
        : initialsParts.Length == 1
            ? initialsParts[0][..Math.Min(2, initialsParts[0].Length)].ToUpperInvariant()
            : "??";
}

<div class="drawer-head">
    <div class="avatar">@initials</div>
    <div class="min-w-0 flex-1">
        <h2 class="font-semibold text-white" id="credito-cliente-panel-title-@Model.Cliente.Id">@clienteNombre</h2>
        <p class="text-xs muted-2">@Model.Documento · @Model.CantidadCreditos crédito@(Model.CantidadCreditos == 1 ? "" : "s") · próximo @proximoVencimientoTexto</p>
    </div>
    <button type="button" class="btn btn-ghost btn-sm" data-credito-cliente-panel-close aria-label="Cerrar">
        <span class="material-symbols-outlined">close</span>
    </button>
</div>

<div class="drawer-body" data-credito-cliente-panel-scroll>
    <div class="grid grid-cols-3 gap-2.5">
        <div class="minimetric">
            <div class="mm-label">Saldo total</div>
            <div class="mm-value num">@Model.SaldoPendienteTotal.ToString("C0")</div>
        </div>
        <div class="minimetric">
            <div class="mm-label">En mora</div>
            <div class="mm-value num" style="@(Model.CuotasVencidas > 0 ? "color:#fb7185" : "")">@Model.Creditos.SelectMany(c => c.Cuotas ?? new List<CuotaViewModel>()).Where(c => c.EstaVencida).Sum(c => c.SaldoPendiente).ToString("C0")</div>
        </div>
        <div class="minimetric">
            <div class="mm-label">Cuotas venc.</div>
            <div class="mm-value num" style="@(Model.CuotasVencidas > 0 ? "color:#fb7185" : "")">@Model.CuotasVencidas</div>
        </div>
    </div>

    <h3 class="text-sm font-semibold text-white" style="margin:1.25rem 0 .65rem">Créditos</h3>
    <div class="space-y-2">
        @foreach (var credito in Model.Creditos)
        {
            var cuotasCredito = credito.Cuotas ?? new List<CuotaViewModel>();
            var productosCredito = credito.ProductosAsociados ?? new List<CreditoProductoAsociadoViewModel>();
            var cantidadCuotasCredito = cuotasCredito.Any() ? cuotasCredito.Count : credito.CantidadCuotas;
            var numeroCredito = credito.Numero ?? $"CR-{credito.Id:D3}";
            var cuotasPagas = cuotasCredito.Count(c => c.Estado == EstadoCuota.Pagada);
            var productosResumen = productosCredito
                .Take(2)
                .Select(p => $"{(string.IsNullOrWhiteSpace(p.ProductoCodigo) ? "" : p.ProductoCodigo + " - ")}{p.ProductoNombre}{(p.Cantidad > 1 ? $" x{p.Cantidad}" : "")}")
                .ToList();
            var productosRestantes = productosCredito.Count - productosResumen.Count;
            var porcentaje = cantidadCuotasCredito > 0
                ? Math.Min(100, Math.Max(0, (int)Math.Round((decimal)cuotasPagas * 100 / cantidadCuotasCredito)))
                : 0;
            var estadoChipClass = credito.Estado switch
            {
                EstadoCredito.Activo or EstadoCredito.Generado => "chip-ok",
                EstadoCredito.Finalizado => "chip-info",
                EstadoCredito.Rechazado or EstadoCredito.Cancelado => "chip-bad",
                EstadoCredito.Solicitado or EstadoCredito.Aprobado or EstadoCredito.PendienteConfiguracion or EstadoCredito.Configurado => "chip-warn",
                _ => "chip-neutral"
            };
            var barClass = estadoChipClass switch
            {
                "chip-ok" => "is-ok",
                "chip-warn" => "is-warn",
                "chip-bad" => "is-bad",
                _ => "is-accent"
            };

            <article class="credit-item" data-credito-cliente-credit>
                <button class="credit-head" type="button" data-credito-credit-toggle data-credito-credit-expanded="false" aria-expanded="false">
                    <span class="material-symbols-outlined chev" data-credito-credit-toggle-icon>expand_more</span>
                    <span class="credit-main">
                        <span class="credit-no">@numeroCredito</span>
                        @if (productosResumen.Any())
                        {
                            <span class="credit-products" data-credito-productos>
                                <span class="material-symbols-outlined" aria-hidden="true">inventory_2</span>
                                <span class="credit-products__text">@string.Join(", ", productosResumen)</span>
                                @if (productosRestantes > 0)
                                {
                                    <span class="credit-products__more">+@productosRestantes</span>
                                }
                            </span>
                        }
                    </span>
                    <span class="chip @estadoChipClass">@credito.Estado</span>
                    <div class="credit-prog hide-mobile">
                        <div class="bar"><div class="bar-fill @barClass" style="width:@porcentaje%"></div></div>
                        <span class="pl">@cuotasPagas/@cantidadCuotasCredito</span>
                    </div>
                    <div class="credit-panel-amount">
                        <div class="num" style="font-weight:600;color:#fff">@credito.SaldoPendiente.ToString("C0")</div>
                        <div class="text-xs muted-2">saldo</div>
                    </div>
                    <span class="sr-only" data-credito-credit-toggle-label>Ver cuotas</span>
                </button>

                <div class="credit-cuotas hidden" data-credito-cuotas-container></div>

                <template data-credito-cuotas-template>
                    @if (cuotasCredito.Any())
                    {
                        <div class="tbl-wrap">
                            <table class="cuota-tbl">
                                <thead>
                                    <tr>
                                        <th class="c" style="width:36px"><span class="sr-only">Seleccionar</span></th>
                                        <th>Cuota</th>
                                        <th>Vencimiento</th>
                                        <th class="r">Saldo</th>
                                        <th class="r">Mora</th>
                                        <th class="c">Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var cuota in cuotasCredito.OrderBy(c => c.NumeroCuota))
                                    {
                                        var estadoCuotaClass = cuota.Estado switch
                                        {
                                            EstadoCuota.Pagada => "chip-ok",
                                            EstadoCuota.Vencida => "chip-bad",
                                            EstadoCuota.Parcial => "chip-warn",
                                            EstadoCuota.Cancelada => "chip-neutral",
                                            _ => "chip-neutral"
                                        };
                                        var cuotaSaldoPendiente = cuota.SaldoPendiente;
                                        var cuotaMora = cuota.MontoPunitorio > 0 ? cuota.MontoPunitorio : 0;
                                        var cuotaSubtotal = cuotaSaldoPendiente - cuotaMora;
                                        if (cuotaSubtotal < 0)
                                        {
                                            cuotaSubtotal = 0;
                                        }

                                        var cuotaPagable = cuota.Estado != EstadoCuota.Pagada
                                            && cuota.Estado != EstadoCuota.Cancelada
                                            && cuotaSaldoPendiente > 0;
                                        var cuotaRowClass = cuota.EstaVencida ? "is-venc" : "";

                                        <tr class="@cuotaRowClass" data-credito-cliente-cuota>
                                            <td class="c">
                                                <input type="checkbox"
                                                       class="chk"
                                                       data-credito-cuota-selector
                                                       data-credito-id="@credito.Id"
                                                       data-cuota-id="@cuota.Id"
                                                       data-cuota-subtotal="@cuotaSubtotal.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                       data-cuota-mora="@cuotaMora.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                       data-cuota-total="@cuotaSaldoPendiente.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                                       aria-label="Seleccionar cuota #@cuota.NumeroCuota de @numeroCredito"
                                                       disabled="@(!cuotaPagable)" />
                                            </td>
                                            <td><span class="cuota-n @(cuota.EstaVencida ? "venc" : "")">@cuota.NumeroCuota</span></td>
                                            <td>
                                                @cuota.FechaVencimiento.ToString("dd/MM/yyyy")
                                                @if (cuota.DiasAtraso > 0)
                                                {
                                                    <span class="chip @(cuota.DiasAtraso >= 10 ? "chip-bad" : "chip-warn")" style="margin-left:.4rem">+@cuota.DiasAtraso d</span>
                                                }
                                            </td>
                                            <td class="r num">@cuotaSaldoPendiente.ToString("C2")</td>
                                            <td class="r num" style="@(cuotaMora > 0 ? "color:#fbbf24" : "")">@(cuotaMora > 0 ? cuotaMora.ToString("C2") : "-")</td>
                                            <td class="c"><span class="chip @estadoCuotaClass">@cuota.Estado</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="px-3 py-4 text-center text-xs muted-2">Este crédito todavía no tiene cuotas registradas.</div>
                    }
                </template>
            </article>
        }
    </div>
</div>

<footer class="pay-foot" data-credito-pago-resumen>
    <div class="pay-grid">
        <div class="pay-resumen">
            <div class="pr">
                <div class="l">Cuotas</div>
                <div class="v" data-credito-resumen-cuotas>0</div>
            </div>
            <div class="pr">
                <div class="l">Créditos</div>
                <div class="v" data-credito-resumen-creditos>0</div>
            </div>
            <div class="pr">
                <div class="l">Subtotal</div>
                <div class="v" data-credito-resumen-subtotal>$ 0,00</div>
            </div>
            <div class="pr">
                <div class="l">Mora</div>
                <div class="v mora" data-credito-resumen-mora>$ 0,00</div>
            </div>
            <div class="pr">
                <div class="l">Total a pagar</div>
                <div class="v total" data-credito-resumen-total>$ 0,00</div>
            </div>
        </div>
        <div class="pay-actions">
            <div style="min-width:160px">
                <label class="label" for="credito-pago-medio-@Model.Cliente.Id">Medio de pago</label>
                <select class="field" id="credito-pago-medio-@Model.Cliente.Id" data-credito-medio-pago>
                    <option value="Efectivo">Efectivo</option>
                    <option value="Transferencia">Transferencia</option>
                    <option value="Tarjeta Débito">Tarjeta Débito</option>
                    <option value="Tarjeta Crédito">Tarjeta Crédito</option>
                    <option value="Cheque">Cheque</option>
                </select>
            </div>
            <button type="button"
                    class="btn btn-success"
                    data-credito-registrar-pago-multiple
                    data-credito-pago-url="@Url.Action("RegistrarPagoMultiple", "Credito")"
                    disabled>
                <span class="material-symbols-outlined" data-credito-registrar-pago-icon>payments</span>
                <span data-credito-registrar-pago-label>Registrar pago</span>
            </button>
        </div>
    </div>
    <p class="hint" role="status" aria-live="polite" data-credito-pago-status data-credito-pago-pendiente>Seleccioná una o más cuotas para registrar el pago.</p>
</footer>
