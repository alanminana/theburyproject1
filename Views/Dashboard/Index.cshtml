@model TheBuryProject.ViewModels.DashboardViewModel
@using TheBuryProject.ViewModels
@using TheBuryProject.Models.DTOs
@{
    ViewData["Title"] = "Dashboard";
    ViewData["MetaDescription"] = "Panel de control principal del ERP TheBuryProject con métricas de ventas, créditos y alertas operativas.";
    var cuotasVencidas = Model.CuotasVencidasLista ?? new List<CuotaVencidaDto>();
    var cuotasProximas = Model.CuotasProximasVencer ?? new List<CuotaProximaVencerDto>();
    var cuotasVencidasCount = cuotasVencidas.Count;
    var cuotasProximasCount = cuotasProximas.Count;
    var alertasStock = Model.AlertasStockRecientes ?? new List<StockAlertaDto>();
    var destacados = Model.ProductosDestacados ?? new List<ProductoDestacadoDto>();
    var actividad = Model.ActividadReciente ?? new List<ActividadRecienteDto>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard-module.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/horizontal-scroll-affordance.css" asp-append-version="true" />
}

<div class="space-y-6">



    <!-- Main + Sidebar -->
    <div class="dashboard-main-grid grid gap-6">

        <!-- Main column -->
        <div class="space-y-6">
  <!-- Productos destacados -->
                        <section class="card-erp-panel p-4 sm:p-5">
                            <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                                <div class="flex items-center gap-2">
                                    <span class="inline-flex items-center gap-1.5 rounded-full bg-amber-500/10 px-2.5 py-1 text-[11px] font-bold uppercase tracking-[0.18em] text-amber-500">
                                        <span class="material-symbols-outlined text-sm">star</span>
                                        Destacados
                                    </span>
                                    <h2 class="text-sm font-semibold text-slate-100 section-header-erp">Productos destacados</h2>
                                </div>
                                <a asp-controller="Catalogo" asp-action="Index" class="btn-erp-ghost btn-erp-sm no-underline">
                                    <span class="material-symbols-outlined text-[14px]">open_in_new</span>
                                    Ver catálogo
                                </a>
                            </div>
                            @if (destacados.Count == 0)
                            {
                                <div class="rounded-xl border border-slate-800 bg-slate-800/20 px-4 py-8 text-center">
                                    <span class="material-symbols-outlined text-2xl text-slate-500 block mb-1">star</span>
                                    <p class="text-sm text-slate-400">No hay productos destacados.</p>
                                    <p class="text-[11px] text-slate-500">Marcá productos como destacados desde el catálogo.</p>
                                </div>
                            }
                            else
                            {
                                <ul class="grid gap-x-6 sm:grid-cols-2">
                                    @foreach (var prod in destacados)
                                    {
                                        var stockTone = prod.StockActual <= 0 ? "text-red-500"
                                            : prod.StockActual <= prod.StockMinimo ? "text-orange-500"
                                            : "text-emerald-500";
                                        var stockTexto = prod.StockActual <= 0 ? "Sin stock"
                                            : prod.StockActual <= prod.StockMinimo ? "Stock bajo"
                                            : "En stock";
                                        <li class="flex items-center gap-3 border-b border-slate-800/70 py-2.5">
                                            <span class="material-symbols-outlined text-amber-500/80 text-[18px] shrink-0">star</span>
                                            <div class="min-w-0 flex-1">
                                                <p class="truncate text-sm font-bold text-slate-100">@prod.Nombre</p>
                                                <p class="text-[11px] text-slate-400">
                                                    <span class="font-semibold uppercase">@prod.Codigo</span>
                                                    <span class="mx-1.5 text-slate-600">·</span>
                                                    <span class="@stockTone font-semibold">@stockTexto</span>
                                                </p>
                                            </div>
                                            <span class="shrink-0 text-sm font-bold text-slate-100">@prod.PrecioVenta.ToString("C")</span>
                                        </li>
                                    }
                                </ul>
                            }
                        </section>
            <!-- Inventory Alerts -->
            <section class="card-erp-panel p-4 sm:p-5">
                <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <div class="flex items-center gap-2">
                        <span
                            class="inline-flex items-center gap-1.5 rounded-full bg-red-500/10 px-2.5 py-1 text-[11px] font-bold uppercase tracking-[0.18em] text-red-500">
                            <span class="material-symbols-outlined text-sm">warning</span>
                            Inventario
                        </span>
                        <h2 class="text-sm font-semibold text-slate-100 section-header-erp">Alertas de stock</h2>
                    </div>
                    <a asp-controller="AlertaStock" asp-action="Index" class="btn-erp-ghost btn-erp-sm no-underline">
                        <span class="material-symbols-outlined text-[14px]">open_in_new</span>
                        Ver alertas
                    </a>
                </div>
                <div data-oc-scroll style="--oc-scroll-min-width: 33.5rem;" class="card-erp-panel overflow-hidden">
                    <div class="border-b border-slate-800 px-4 py-3">
                        <p data-oc-scroll-hint hidden
                           class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-400">
                            Deslizá horizontalmente para ver el detalle completo.
                        </p>
                    </div>
                    <div class="relative">
                        <div data-oc-scroll-fade="left" hidden
                             class="pointer-events-none absolute inset-y-0 left-0 z-[1] w-8 bg-gradient-to-r from-slate-900 via-slate-900/95 to-transparent">
                        </div>
                        <div data-oc-scroll-fade="right" hidden
                             class="pointer-events-none absolute inset-y-0 right-0 z-[1] w-8 bg-gradient-to-l from-slate-900 via-slate-900/95 to-transparent">
                        </div>
                        <div data-oc-scroll-region tabindex="0" class="overflow-x-auto overscroll-x-contain">
                            <table class="min-w-[var(--oc-scroll-min-width)] w-full text-left border-collapse">
                                <thead>
                                    <tr
                                        class="bg-slate-800/50 text-slate-400 text-xs font-bold uppercase tracking-wider">
                                        <th class="px-6 py-3">SKU</th>
                                        <th class="px-6 py-3">Producto</th>
                                        <th class="px-6 py-3">Stock</th>
                                        <th class="px-6 py-3">Estado</th>
                                        <th class="px-6 py-3 text-right">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-800">
                                    @if (alertasStock.Count == 0)
                                    {
                                        <tr>
                                            <td colspan="5" class="px-6 py-8 text-center text-sm text-slate-400">
                                                <span
                                                class="material-symbols-outlined text-2xl text-emerald-500/70 block mb-1">inventory_2</span>
                                                No hay productos por debajo del stock mínimo.
                                            </td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var alerta in alertasStock)
                                        {
                                            var stockColor = alerta.Severidad == "bajo" ? "text-orange-500" : "text-red-500";
                                            var badgeClass = alerta.Severidad == "bajo"
                                                ? "bg-orange-500/10 text-orange-500 border border-orange-500/20"
                                                : "bg-red-500/10 text-red-500 border border-red-500/20";
                                            <tr class="hover:bg-slate-800/30 transition-colors">
                                                <td class="px-6 py-4 text-xs font-bold text-slate-500 uppercase">@alerta.Codigo
                                                </td>
                                                <td class="px-6 py-4 text-sm font-bold">@alerta.Nombre</td>
                                                <td class="px-6 py-4 text-sm font-bold @stockColor">
                                                    @alerta.StockActual.ToString("0.##")</td>
                                                    <td class="px-6 py-4">
                                                        <span
                                                        class="text-[10px] font-bold uppercase px-2 py-0.5 rounded @badgeClass">@alerta.SeveridadTexto</span>
                                                    </td>
                                                    <td class="px-6 py-4 text-right">
                                                        <a asp-controller="OrdenCompra" asp-action="Create"
                                                           asp-route-productoId="@alerta.ProductoId"
                                                           class="btn-erp-ghost btn-erp-sm no-underline"
                                                           title="Crear orden de compra para reponer">Reponer</a>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Payments Table -->
                <section class="card-erp-panel p-4 sm:p-5">
                    <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                        <div class="flex items-center gap-2">
                            <span
                                class="inline-flex items-center gap-1.5 rounded-full bg-primary/10 px-2.5 py-1 text-[11px] font-bold uppercase tracking-[0.18em] text-primary">
                                <span class="material-symbols-outlined text-sm">schedule</span>
                                Cobranzas
                            </span>
                            <h2 class="text-sm font-semibold text-slate-100 section-header-erp">Cuotas y pagos</h2>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="text-xs text-slate-400">@cuotasVencidasCount venc. / @cuotasProximasCount
                                próx.</span>
                                <div class="flex gap-1" data-dashboard-tabs>
                                    <button id="tabVencidas" type="button" data-dashboard-tab="vencidas"
                                            data-dashboard-tab-tone="danger" aria-pressed="true"
                                            class="px-3 py-1.5 text-xs font-semibold rounded-lg bg-red-500/10 text-red-500 border border-red-500/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50">Vencidas</button>
                                    <button id="tabProximas" type="button" data-dashboard-tab="proximas"
                                            data-dashboard-tab-tone="info" aria-pressed="false"
                                            class="px-3 py-1.5 text-xs font-semibold rounded-lg bg-slate-800 text-slate-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50">Próximas</button>
                                </div>
                            </div>
                        </div>
                        <div data-oc-scroll style="--oc-scroll-min-width: 47.25rem;" class="card-erp-panel overflow-hidden">
                            <div class="border-b border-slate-800 px-4 py-3">
                                <p data-oc-scroll-hint hidden
                                   class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-400">
                                    Deslizá horizontalmente para ver cliente, monto y estado completo.
                                </p>
                            </div>
                            <div class="relative">
                                <div data-oc-scroll-fade="left" hidden
                                     class="pointer-events-none absolute inset-y-0 left-0 z-[1] w-8 bg-gradient-to-r from-slate-900 via-slate-900/95 to-transparent">
                                </div>
                                <div data-oc-scroll-fade="right" hidden
                                     class="pointer-events-none absolute inset-y-0 right-0 z-[1] w-8 bg-gradient-to-l from-slate-900 via-slate-900/95 to-transparent">
                                </div>
                                <div data-oc-scroll-region tabindex="0" class="overflow-x-auto overscroll-x-contain">
                                    <table class="min-w-[var(--oc-scroll-min-width)] w-full text-left border-collapse">
                                        <thead>
                                            <tr
                                                class="bg-slate-800/50 text-slate-400 text-xs font-bold uppercase tracking-wider">
                                                <th class="px-6 py-4">Cliente</th>
                                                <th class="px-6 py-4">Concepto</th>
                                                <th class="px-6 py-4">Vencimiento</th>
                                                <th class="px-6 py-4">Monto</th>
                                                <th class="px-6 py-4">Estado</th>
                                                <th class="px-6 py-4 text-right">Acciones</th>
                                            </tr>
                                        </thead>
                                        <tbody id="tbodyVencidas" data-dashboard-tab-panel="vencidas"
                                               class="divide-y divide-slate-800">
                                            @foreach (var cuota in cuotasVencidas.Take(5))
                                            {
                                                var productos = cuota.ProductosAsociados ?? new List<CreditoProductoAsociadoViewModel>();
                                                var productosResumen = productos
                                                    .Take(2)
                                                    .Select(p => $"{(string.IsNullOrWhiteSpace(p.ProductoCodigo) ? "" : p.ProductoCodigo + " - ")}{p.ProductoNombre}{(p.Cantidad > 1 ? $" x{p.Cantidad}" : "")}")
                                                    .ToList();
                                                var productosRestantes = productos.Count - productosResumen.Count;
                                                <tr class="hover:bg-slate-800/30 transition-colors">
                                                    <td class="px-6 py-4">
                                                        <p class="font-bold text-sm">@cuota.ClienteNombre</p>
                                                        <p class="text-[11px] text-slate-400">ID: @cuota.ClienteId</p>
                                                    </td>
                                                    <td class="px-6 py-4">
                                                        <p class="text-sm text-slate-200">Cuota @cuota.NumeroCuota - @cuota.CreditoNumero</p>
                                                        @if (productosResumen.Any())
                                                        {
                                                            <p class="mt-1 flex min-w-0 items-center gap-1 text-[11px] text-slate-400" data-dashboard-productos>
                                                                <span class="material-symbols-outlined text-[14px] text-slate-500" aria-hidden="true">inventory_2</span>
                                                                <span class="max-w-[18rem] truncate">@string.Join(", ", productosResumen)</span>
                                                                @if (productosRestantes > 0)
                                                                {
                                                                    <span class="shrink-0 font-bold text-primary">+@productosRestantes</span>
                                                                }
                                                            </p>
                                                        }
                                                    </td>
                                                    <td class="px-6 py-4">
                                                        <span
                                                            class="text-xs font-semibold text-red-500 bg-red-500/10 px-2 py-0.5 rounded">Hace
                                                            @cuota.DiasVencidos d</span>
                                                        </td>
                                                        <td class="px-6 py-4 font-bold text-sm">@cuota.Monto.ToString("C")</td>
                                                        <td class="px-6 py-4">
                                                            <div class="flex items-center gap-1.5 text-red-500">
                                                                <span class="size-1.5 bg-red-500 rounded-full"></span>
                                                                <span class="text-xs font-bold">Vencido</span>
                                                            </div>
                                                        </td>
                                                        <td class="px-6 py-4 text-right">
                                                            <a asp-controller="Credito" asp-action="PagarCuota"
                                                               asp-route-id="@cuota.CreditoId" asp-route-cuotaId="@cuota.CuotaId"
                                                               class="row-action row-action--primary no-underline"
                                                               aria-label="Registrar pago">
                                                                <span class="material-symbols-outlined icon-erp-md">send_money</span>
                                                            </a>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                            <tbody id="tbodyProximas" data-dashboard-tab-panel="proximas"
                                                   class="divide-y divide-slate-800 hidden">
                                                @foreach (var cuota in cuotasProximas.Take(5))
                                                {
                                                    var productos = cuota.ProductosAsociados ?? new List<CreditoProductoAsociadoViewModel>();
                                                    var productosResumen = productos
                                                        .Take(2)
                                                        .Select(p => $"{(string.IsNullOrWhiteSpace(p.ProductoCodigo) ? "" : p.ProductoCodigo + " - ")}{p.ProductoNombre}{(p.Cantidad > 1 ? $" x{p.Cantidad}" : "")}")
                                                        .ToList();
                                                    var productosRestantes = productos.Count - productosResumen.Count;
                                                    <tr class="hover:bg-slate-800/30 transition-colors">
                                                        <td class="px-6 py-4">
                                                            <p class="font-bold text-sm">@cuota.ClienteNombre</p>
                                                            <p class="text-[11px] text-slate-400">ID: @cuota.ClienteId</p>
                                                        </td>
                                                        <td class="px-6 py-4">
                                                            <p class="text-sm text-slate-200">Cuota @cuota.NumeroCuota - @cuota.CreditoNumero</p>
                                                            @if (productosResumen.Any())
                                                            {
                                                                <p class="mt-1 flex min-w-0 items-center gap-1 text-[11px] text-slate-400" data-dashboard-productos>
                                                                    <span class="material-symbols-outlined text-[14px] text-slate-500" aria-hidden="true">inventory_2</span>
                                                                    <span class="max-w-[18rem] truncate">@string.Join(", ", productosResumen)</span>
                                                                    @if (productosRestantes > 0)
                                                                    {
                                                                        <span class="shrink-0 font-bold text-primary">+@productosRestantes</span>
                                                                    }
                                                                </p>
                                                            }
                                                        </td>
                                                        <td class="px-6 py-4">
                                                            <span
                                                            class="text-xs font-semibold text-slate-400 bg-slate-800 px-2 py-0.5 rounded">@cuota.FechaVencimiento.ToString("dd MMM")</span>
                                                        </td>
                                                        <td class="px-6 py-4 font-bold text-sm">@cuota.Monto.ToString("C")</td>
                                                        <td class="px-6 py-4">
                                                            @if (cuota.DiasParaVencer <= 1)
                                                            {
                                                                <div class="flex items-center gap-1.5 text-orange-500">
                                                                    <span class="size-1.5 bg-orange-500 rounded-full"></span>
                                                                    <span class="text-xs font-bold">Por Vencer</span>
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                <div class="flex items-center gap-1.5 text-blue-500">
                                                                    <span class="size-1.5 bg-blue-500 rounded-full"></span>
                                                                    <span class="text-xs font-bold">Programado</span>
                                                                </div>
                                                            }
                                                        </td>
                                                        <td class="px-6 py-4 text-right">
                                                            <a asp-controller="Credito" asp-action="Details"
                                                               asp-route-id="@cuota.CreditoId"
                                                               class="row-action row-action--primary no-underline"
                                                               aria-label="Ver detalle del crédito">
                                                                <span class="material-symbols-outlined icon-erp-md">visibility</span>
                                                            </a>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </section>

                    </div>

                    <!-- Right Sidebar -->
                    <aside class="dashboard-sidebar space-y-4">

                        <!-- Quick Access -->
                        <section class="card-erp-panel p-4">
                            <div class="mb-3 flex items-center gap-2">
                                <span class="material-symbols-outlined text-primary text-[18px]">bolt</span>
                                <h2 class="text-xs font-bold uppercase tracking-wide text-slate-300">Accesos rápidos</h2>
                            </div>
                            <div class="grid grid-cols-2 gap-2">
                                <a asp-controller="Venta" asp-action="Create"
                                   class="flex flex-col items-center justify-center gap-1.5 rounded-xl border border-slate-800 bg-slate-800/30 py-4 px-2 text-center transition-colors hover:border-primary/60 hover:bg-slate-800/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 no-underline text-inherit">
                                    <span class="material-symbols-outlined text-primary text-2xl">add_shopping_cart</span>
                                    <span class="text-[11px] font-bold uppercase text-slate-300">Nueva Venta</span>
                                </a>
                                <a asp-controller="Cliente" asp-action="Create"
                                   class="flex flex-col items-center justify-center gap-1.5 rounded-xl border border-slate-800 bg-slate-800/30 py-4 px-2 text-center transition-colors hover:border-primary/60 hover:bg-slate-800/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 no-underline text-inherit">
                                    <span class="material-symbols-outlined text-primary text-2xl">person_add</span>
                                    <span class="text-[11px] font-bold uppercase text-slate-300">Nuevo Cliente</span>
                                </a>
                                <a asp-controller="Reporte" asp-action="Index"
                                   class="flex flex-col items-center justify-center gap-1.5 rounded-xl border border-slate-800 bg-slate-800/30 py-4 px-2 text-center transition-colors hover:border-primary/60 hover:bg-slate-800/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 no-underline text-inherit">
                                    <span class="material-symbols-outlined text-primary text-2xl">receipt_long</span>
                                    <span class="text-[11px] font-bold uppercase text-slate-300">Reportes</span>
                                </a>
                                <a asp-controller="Catalogo" asp-action="Index"
                                   class="flex flex-col items-center justify-center gap-1.5 rounded-xl border border-slate-800 bg-slate-800/30 py-4 px-2 text-center transition-colors hover:border-primary/60 hover:bg-slate-800/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 no-underline text-inherit">
                                    <span class="material-symbols-outlined text-primary text-2xl">box_edit</span>
                                    <span class="text-[11px] font-bold uppercase text-slate-300">Catálogo</span>
                                </a>
                                <a asp-controller="Caja" asp-action="Index"
                                   class="flex flex-col items-center justify-center gap-1.5 rounded-xl border border-slate-800 bg-slate-800/30 py-4 px-2 text-center transition-colors hover:border-primary/60 hover:bg-slate-800/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 no-underline text-inherit">
                                    <span class="material-symbols-outlined text-primary text-2xl">point_of_sale</span>
                                    <span class="text-[11px] font-bold uppercase text-slate-300">Caja</span>
                                </a>
                                <a asp-controller="Credito" asp-action="Index"
                                   class="flex flex-col items-center justify-center gap-1.5 rounded-xl border border-slate-800 bg-slate-800/30 py-4 px-2 text-center transition-colors hover:border-primary/60 hover:bg-slate-800/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 no-underline text-inherit">
                                    <span class="material-symbols-outlined text-primary text-2xl">credit_card</span>
                                    <span class="text-[11px] font-bold uppercase text-slate-300">Créditos</span>
                                </a>
                            </div>
                        </section>

                            <!-- Quick Notes -->
                            <section data-dashboard-notes class="card-erp-panel p-4">
                                <div class="mb-3 flex items-center justify-between">
                                    <div class="flex items-center gap-2">
                                        <span class="material-symbols-outlined text-primary text-[18px]">note_stack</span>
                                        <h2 class="text-xs font-bold uppercase tracking-wide text-slate-300">Notas rápidas</h2>
                                    </div>
                                    <button type="button" data-dashboard-action="save-note" class="btn-erp-ghost btn-erp-sm"
                                            title="Guardar nota">
                                        <span class="material-symbols-outlined icon-erp-sm">add</span>
                                        Guardar
                                    </button>
                                </div>
                                <div class="rounded-xl border border-primary/20 bg-primary/5 p-3">
                                    <textarea id="notaTextarea" data-dashboard-note-input
                                              class="w-full h-20 bg-transparent border-none resize-none focus:ring-0 text-sm text-slate-300 placeholder:text-slate-500"
                                              placeholder="Escribí un recordatorio..."></textarea>
                                    <div class="flex items-center justify-between border-t border-primary/10 pt-2 mt-1">
                                        <span id="notaStatus" data-dashboard-note-status class="text-[10px] text-slate-400"></span>
                                        <button type="button" data-dashboard-action="save-note" class="btn-erp-primary btn-erp-sm">
                                            <span class="material-symbols-outlined icon-erp-sm">save</span>
                                            Guardar
                                        </button>
                                    </div>
                                </div>
                                <div id="notasLista" data-dashboard-note-list class="mt-3 space-y-1.5 max-h-40 overflow-y-auto"></div>
                            </section>

                        <!-- Actividad reciente -->
                        <section class="card-erp-panel p-4">
                            <div class="mb-3 flex items-center gap-2">
                                <span class="material-symbols-outlined text-primary text-[18px]">monitoring</span>
                                <h2 class="text-xs font-bold uppercase tracking-wide text-slate-300">Actividad reciente</h2>
                            </div>
                            <div class="space-y-3 max-h-80 overflow-y-auto">
                                @if (actividad.Count == 0)
                                {
                                    <p class="text-xs text-slate-400">Sin actividad reciente todavía.</p>
                                }
                                else
                                {
                                    @foreach (var item in actividad)
                                    {
                                        var bulletColor = item.Color == "primary" ? "bg-primary"
                                            : item.Color == "orange" ? "bg-orange-500"
                                            : "bg-emerald-500";
                                        <div class="flex gap-2.5">
                                            <div class="mt-1.5 size-1.5 shrink-0 rounded-full @bulletColor"></div>
                                            <div>
                                                <p class="text-xs text-slate-200"><span class="font-semibold">@item.Titulo</span>
                                                    @item.Detalle</p>
                                                <p class="text-[10px] text-slate-400">@item.TiempoRelativo</p>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </section>

        </aside>

    </div>
</div>
@section Scripts {
                    <script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
                    <script src="~/js/dashboard-index.js" asp-append-version="true"></script>
                }
