@model TheBuryProject.ViewModels.DashboardViewModel
@using TheBuryProject.ViewModels
@{
    ViewData["Title"] = "Dashboard";
    ViewData["MetaDescription"] = "Panel de control principal del ERP TheBuryProject con métricas de ventas, créditos y alertas operativas.";
    var cuotasVencidas = Model.CuotasVencidasLista ?? new List<CuotaVencidaDto>();
    var cuotasProximas = Model.CuotasProximasVencer ?? new List<CuotaProximaVencerDto>();
    var cuotasVencidasCount = cuotasVencidas.Count;
    var cuotasProximasCount = cuotasProximas.Count;
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard-module.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/horizontal-scroll-affordance.css" asp-append-version="true" />
}

<div class="space-y-6">

    <!-- Hero -->
    <section class="hero-erp overflow-hidden" style="background:radial-gradient(circle at top left, rgba(14,165,233,0.14), transparent 32%), #1a202c;">
        <div class="space-y-3">
            <span class="badge-erp badge-erp-primary">
                <span class="material-symbols-outlined text-sm">space_dashboard</span>
                Dashboard
            </span>
            <h1 class="text-3xl font-black tracking-tight text-slate-100 sm:text-4xl">Centro operativo del día</h1>
        </div>
        <div class="dashboard-hero-metrics mt-5 grid grid-cols-2 gap-3">
            <article class="card-erp-metric-success">
                <div class="flex items-start justify-between gap-3">
                    <div>
                        <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-emerald-400">Ventas totales</p>
                        <p class="mt-2 text-2xl font-black text-emerald-300">@Model.VentasTotalesMes.ToString("C")</p>
                    </div>
                    <span class="badge-erp badge-erp-success">mes</span>
                </div>
            </article>
            <article class="card-erp-metric-warning">
                <div class="flex items-start justify-between gap-3">
                    <div>
                        <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-amber-400">Operaciones</p>
                        <p class="mt-2 text-2xl font-black text-amber-300">@Model.CantidadVentasMes</p>
                    </div>
                    <span class="badge-erp badge-erp-warning">@Model.CuotasVencidasTotal pend.</span>
                </div>
            </article>
            <article class="card-erp-metric-info">
                <div class="flex items-start justify-between gap-3">
                    <div>
                        <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-sky-400">Créditos activos</p>
                        <p class="mt-2 text-2xl font-black text-sky-300">@Model.CreditosActivos</p>
                    </div>
                    <span class="badge-erp badge-erp-info">30 días</span>
                </div>
            </article>
            <article class="card-erp-metric">
                <div class="flex items-start justify-between gap-3">
                    <div>
                        <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-slate-400">Cuotas en vista</p>
                        <p class="mt-2 text-2xl font-black text-white">@((cuotasVencidasCount + cuotasProximasCount).ToString("N0"))</p>
                    </div>
                    <span class="badge-erp badge-erp-neutral">total</span>
                </div>
                <p class="mt-1 text-xs text-slate-400">@cuotasVencidasCount venc. · @cuotasProximasCount próx.</p>
            </article>
        </div>
    </section>

    <!-- Main + Sidebar -->
    <div class="dashboard-main-grid grid gap-6">

        <!-- Main column -->
        <div class="space-y-6">

            <!-- Inventory Alerts -->
            <section class="card-erp-panel p-4 sm:p-5">
                <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <div class="flex items-center gap-2">
                        <span class="inline-flex items-center gap-1.5 rounded-full bg-red-500/10 px-2.5 py-1 text-[11px] font-bold uppercase tracking-[0.18em] text-red-500">
                            <span class="material-symbols-outlined text-sm">warning</span>
                            Inventario
                        </span>
                        <h2 class="text-sm font-semibold text-slate-100 section-header-erp">Alertas de stock</h2>
                    </div>
                    <a asp-controller="AlertaStock" asp-action="Index" class="btn-erp-ghost btn-erp-sm no-underline">
                        <span class="material-symbols-outlined text-[14px]">open_in_new</span>
                        Ver alertas
                    </a>
                </div>
                <div data-oc-scroll style="--oc-scroll-min-width: 33.5rem;" class="card-erp-panel overflow-hidden">
                    <div class="border-b border-slate-800 px-4 py-3">
                        <p data-oc-scroll-hint hidden class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-400">
                            Deslizá horizontalmente para ver el detalle completo.
                        </p>
                    </div>
                    <div class="relative">
                        <div data-oc-scroll-fade="left" hidden class="pointer-events-none absolute inset-y-0 left-0 z-[1] w-8 bg-gradient-to-r from-slate-900 via-slate-900/95 to-transparent"></div>
                        <div data-oc-scroll-fade="right" hidden class="pointer-events-none absolute inset-y-0 right-0 z-[1] w-8 bg-gradient-to-l from-slate-900 via-slate-900/95 to-transparent"></div>
                        <div data-oc-scroll-region tabindex="0" class="overflow-x-auto overscroll-x-contain">
                            <table class="min-w-[var(--oc-scroll-min-width)] w-full text-left border-collapse">
                                <thead>
                                    <tr class="bg-slate-800/50 text-slate-400 text-xs font-bold uppercase tracking-wider">
                                        <th class="px-6 py-3">SKU</th>
                                        <th class="px-6 py-3">Producto</th>
                                        <th class="px-6 py-3">Stock</th>
                                        <th class="px-6 py-3">Estado</th>
                                        <th class="px-6 py-3 text-right">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-800">
                                    <tr class="hover:bg-slate-800/30 transition-colors">
                                        <td class="px-6 py-4 text-xs font-bold text-slate-500 uppercase">BP-1022</td>
                                        <td class="px-6 py-4 text-sm font-bold">Cubierta 205/55 R16</td>
                                        <td class="px-6 py-4 text-sm font-bold text-red-500">2</td>
                                        <td class="px-6 py-4">
                                            <span class="text-[10px] font-bold uppercase px-2 py-0.5 rounded bg-red-500/10 text-red-500 border border-red-500/20">Stock crítico</span>
                                        </td>
                                        <td class="px-6 py-4 text-right">
                                            <button class="inline-flex items-center justify-center rounded-xl px-3 py-2 text-xs font-semibold text-primary transition-colors hover:bg-primary/10">Reponer</button>
                                        </td>
                                    </tr>
                                    <tr class="hover:bg-slate-800/30 transition-colors">
                                        <td class="px-6 py-4 text-xs font-bold text-slate-500 uppercase">BP-5044</td>
                                        <td class="px-6 py-4 text-sm font-bold">Amortiguador Trasero</td>
                                        <td class="px-6 py-4 text-sm font-bold text-orange-500">5</td>
                                        <td class="px-6 py-4">
                                            <span class="text-[10px] font-bold uppercase px-2 py-0.5 rounded bg-orange-500/10 text-orange-500 border border-orange-500/20">Reponer pronto</span>
                                        </td>
                                        <td class="px-6 py-4 text-right">
                                            <button class="inline-flex items-center justify-center rounded-xl px-3 py-2 text-xs font-semibold text-primary transition-colors hover:bg-primary/10">Reponer</button>
                                        </td>
                                    </tr>
                                    <tr class="hover:bg-slate-800/30 transition-colors">
                                        <td class="px-6 py-4 text-xs font-bold text-slate-500 uppercase">BP-9012</td>
                                        <td class="px-6 py-4 text-sm font-bold">Batería Moura 12V 75Ah</td>
                                        <td class="px-6 py-4 text-sm font-bold text-orange-500">3</td>
                                        <td class="px-6 py-4">
                                            <span class="text-[10px] font-bold uppercase px-2 py-0.5 rounded bg-orange-500/10 text-orange-500 border border-orange-500/20">Reponer pronto</span>
                                        </td>
                                        <td class="px-6 py-4 text-right">
                                            <button class="inline-flex items-center justify-center rounded-xl px-3 py-2 text-xs font-semibold text-primary transition-colors hover:bg-primary/10">Reponer</button>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Payments Table -->
            <section class="card-erp-panel p-4 sm:p-5">
                <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <div class="flex items-center gap-2">
                        <span class="inline-flex items-center gap-1.5 rounded-full bg-primary/10 px-2.5 py-1 text-[11px] font-bold uppercase tracking-[0.18em] text-primary">
                            <span class="material-symbols-outlined text-sm">schedule</span>
                            Cobranzas
                        </span>
                        <h2 class="text-sm font-semibold text-slate-100 section-header-erp">Cuotas y pagos</h2>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="text-xs text-slate-400">@cuotasVencidasCount venc. / @cuotasProximasCount próx.</span>
                        <div class="flex gap-1" data-dashboard-tabs>
                            <button id="tabVencidas" type="button" data-dashboard-tab="vencidas" data-dashboard-tab-tone="danger" aria-pressed="true"
                                    class="px-3 py-1.5 text-xs font-semibold rounded-lg bg-red-500/10 text-red-500 border border-red-500/20">Vencidas</button>
                            <button id="tabProximas" type="button" data-dashboard-tab="proximas" data-dashboard-tab-tone="info" aria-pressed="false"
                                    class="px-3 py-1.5 text-xs font-semibold rounded-lg bg-slate-800 text-slate-400">Próximas</button>
                        </div>
                    </div>
                </div>
                <div data-oc-scroll style="--oc-scroll-min-width: 47.25rem;" class="card-erp-panel overflow-hidden">
                    <div class="border-b border-slate-800 px-4 py-3">
                        <p data-oc-scroll-hint hidden class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-400">
                            Deslizá horizontalmente para ver cliente, monto y estado completo.
                        </p>
                    </div>
                    <div class="relative">
                        <div data-oc-scroll-fade="left" hidden class="pointer-events-none absolute inset-y-0 left-0 z-[1] w-8 bg-gradient-to-r from-slate-900 via-slate-900/95 to-transparent"></div>
                        <div data-oc-scroll-fade="right" hidden class="pointer-events-none absolute inset-y-0 right-0 z-[1] w-8 bg-gradient-to-l from-slate-900 via-slate-900/95 to-transparent"></div>
                        <div data-oc-scroll-region tabindex="0" class="overflow-x-auto overscroll-x-contain">
                            <table class="min-w-[var(--oc-scroll-min-width)] w-full text-left border-collapse">
                                <thead>
                                    <tr class="bg-slate-800/50 text-slate-400 text-xs font-bold uppercase tracking-wider">
                                        <th class="px-6 py-4">Cliente</th>
                                        <th class="px-6 py-4">Concepto</th>
                                        <th class="px-6 py-4">Vencimiento</th>
                                        <th class="px-6 py-4">Monto</th>
                                        <th class="px-6 py-4">Estado</th>
                                        <th class="px-6 py-4 text-right">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody id="tbodyVencidas" data-dashboard-tab-panel="vencidas" class="divide-y divide-slate-800">
                                    @foreach (var cuota in cuotasVencidas.Take(5))
                                    {
                                        <tr class="hover:bg-slate-800/30 transition-colors">
                                            <td class="px-6 py-4">
                                                <p class="font-bold text-sm">@cuota.ClienteNombre</p>
                                                <p class="text-[10px] text-slate-400">ID: @cuota.ClienteId</p>
                                            </td>
                                            <td class="px-6 py-4 text-sm">Cuota @cuota.NumeroCuota</td>
                                            <td class="px-6 py-4">
                                                <span class="text-xs font-semibold text-red-500 bg-red-500/10 px-2 py-0.5 rounded">Hace @cuota.DiasVencidos d</span>
                                            </td>
                                            <td class="px-6 py-4 font-bold text-sm">@cuota.Monto.ToString("C")</td>
                                            <td class="px-6 py-4">
                                                <div class="flex items-center gap-1.5 text-red-500">
                                                    <span class="size-1.5 bg-red-500 rounded-full"></span>
                                                    <span class="text-xs font-bold">Vencido</span>
                                                </div>
                                            </td>
                                            <td class="px-6 py-4 text-right">
                                                <a asp-controller="Credito" asp-action="PagarCuota"
                                                   asp-route-id="@cuota.CreditoId" asp-route-cuotaId="@cuota.CuotaId"
                                                   class="inline-flex items-center gap-1.5 rounded-xl px-2.5 py-2 text-sm font-semibold text-primary transition-colors hover:bg-primary/10 sm:justify-end no-underline">
                                                    <span class="material-symbols-outlined text-xl">send_money</span>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tbody id="tbodyProximas" data-dashboard-tab-panel="proximas" class="divide-y divide-slate-800 hidden">
                                    @foreach (var cuota in cuotasProximas.Take(5))
                                    {
                                        <tr class="hover:bg-slate-800/30 transition-colors">
                                            <td class="px-6 py-4">
                                                <p class="font-bold text-sm">@cuota.ClienteNombre</p>
                                                <p class="text-[10px] text-slate-400">ID: @cuota.ClienteId</p>
                                            </td>
                                            <td class="px-6 py-4 text-sm">Cuota @cuota.NumeroCuota - @cuota.CreditoNumero</td>
                                            <td class="px-6 py-4">
                                                <span class="text-xs font-semibold text-slate-500 bg-slate-800 px-2 py-0.5 rounded">@cuota.FechaVencimiento.ToString("dd MMM")</span>
                                            </td>
                                            <td class="px-6 py-4 font-bold text-sm">@cuota.Monto.ToString("C")</td>
                                            <td class="px-6 py-4">
                                                @if (cuota.DiasParaVencer <= 1)
                                                {
                                                    <div class="flex items-center gap-1.5 text-orange-500">
                                                        <span class="size-1.5 bg-orange-500 rounded-full"></span>
                                                        <span class="text-xs font-bold">Por Vencer</span>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="flex items-center gap-1.5 text-blue-500">
                                                        <span class="size-1.5 bg-blue-500 rounded-full"></span>
                                                        <span class="text-xs font-bold">Programado</span>
                                                    </div>
                                                }
                                            </td>
                                            <td class="px-6 py-4 text-right">
                                                <button type="button" class="inline-flex items-center gap-1.5 rounded-xl px-2.5 py-2 text-sm font-semibold text-primary transition-colors hover:bg-primary/10 sm:justify-end">
                                                    <span class="material-symbols-outlined text-xl">visibility</span>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </section>

        </div>

        <!-- Right Sidebar -->
        <aside class="dashboard-sidebar space-y-4">

            <!-- Quick Access -->
            <section class="card-erp-panel p-4">
                <div class="mb-3 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary text-[18px]">bolt</span>
                    <h2 class="text-xs font-bold uppercase tracking-wide text-slate-300">Accesos rápidos</h2>
                </div>
                <div class="grid grid-cols-2 gap-2">
                    <a asp-controller="Venta" asp-action="Create"
                       class="flex flex-col items-center justify-center gap-1.5 rounded-xl border border-slate-800 bg-slate-800/30 py-4 px-2 text-center transition-colors group hover:border-primary/60 hover:bg-slate-800/60 no-underline text-inherit">
                        <span class="material-symbols-outlined text-primary text-2xl group-hover:scale-110 transition-transform">add_shopping_cart</span>
                        <span class="text-[11px] font-bold uppercase text-slate-300">Nueva Venta</span>
                    </a>
                    <a asp-controller="Cliente" asp-action="Create"
                       class="flex flex-col items-center justify-center gap-1.5 rounded-xl border border-slate-800 bg-slate-800/30 py-4 px-2 text-center transition-colors group hover:border-primary/60 hover:bg-slate-800/60 no-underline text-inherit">
                        <span class="material-symbols-outlined text-primary text-2xl group-hover:scale-110 transition-transform">person_add</span>
                        <span class="text-[11px] font-bold uppercase text-slate-300">Nuevo Cliente</span>
                    </a>
                    <a asp-controller="Reporte" asp-action="Index"
                       class="flex flex-col items-center justify-center gap-1.5 rounded-xl border border-slate-800 bg-slate-800/30 py-4 px-2 text-center transition-colors group hover:border-primary/60 hover:bg-slate-800/60 no-underline text-inherit">
                        <span class="material-symbols-outlined text-primary text-2xl group-hover:scale-110 transition-transform">receipt_long</span>
                        <span class="text-[11px] font-bold uppercase text-slate-300">Reportes</span>
                    </a>
                    <a asp-controller="Catalogo" asp-action="Index"
                       class="flex flex-col items-center justify-center gap-1.5 rounded-xl border border-slate-800 bg-slate-800/30 py-4 px-2 text-center transition-colors group hover:border-primary/60 hover:bg-slate-800/60 no-underline text-inherit">
                        <span class="material-symbols-outlined text-primary text-2xl group-hover:scale-110 transition-transform">box_edit</span>
                        <span class="text-[11px] font-bold uppercase text-slate-300">Catálogo</span>
                    </a>
                    <a asp-controller="Caja" asp-action="Index"
                       class="flex flex-col items-center justify-center gap-1.5 rounded-xl border border-slate-800 bg-slate-800/30 py-4 px-2 text-center transition-colors group hover:border-primary/60 hover:bg-slate-800/60 no-underline text-inherit">
                        <span class="material-symbols-outlined text-primary text-2xl group-hover:scale-110 transition-transform">point_of_sale</span>
                        <span class="text-[11px] font-bold uppercase text-slate-300">Caja</span>
                    </a>
                    <a asp-controller="Credito" asp-action="Index"
                       class="flex flex-col items-center justify-center gap-1.5 rounded-xl border border-slate-800 bg-slate-800/30 py-4 px-2 text-center transition-colors group hover:border-primary/60 hover:bg-slate-800/60 no-underline text-inherit">
                        <span class="material-symbols-outlined text-primary text-2xl group-hover:scale-110 transition-transform">credit_card</span>
                        <span class="text-[11px] font-bold uppercase text-slate-300">Créditos</span>
                    </a>
                </div>
            </section>

            <!-- Activity Feed -->
            <section class="card-erp-panel p-4">
                <div class="mb-3 flex items-center justify-between">
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary text-[18px]">monitoring</span>
                        <h2 class="text-xs font-bold uppercase tracking-wide text-slate-300">Actividad reciente</h2>
                    </div>
                </div>
                <div class="space-y-3">
                    <div class="flex gap-2.5">
                        <div class="mt-1.5 size-1.5 shrink-0 rounded-full bg-emerald-500"></div>
                        <div>
                            <p class="text-xs text-slate-200"><span class="font-semibold">Venta registrada</span> #8821 por $12.500</p>
                            <p class="text-[10px] text-slate-400">Hace 15 minutos</p>
                        </div>
                    </div>
                    <div class="flex gap-2.5">
                        <div class="mt-1.5 size-1.5 shrink-0 rounded-full bg-primary"></div>
                        <div>
                            <p class="text-xs text-slate-200"><span class="font-semibold">Cliente nuevo</span> Marcos Solari</p>
                            <p class="text-[10px] text-slate-400">Hace 2 horas</p>
                        </div>
                    </div>
                    <div class="flex gap-2.5">
                        <div class="mt-1.5 size-1.5 shrink-0 rounded-full bg-orange-500"></div>
                        <div>
                            <p class="text-xs text-slate-200"><span class="font-semibold">Stock bajo</span> Batería Moura SKU-9012</p>
                            <p class="text-[10px] text-slate-400">Hace 4 horas</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Quick Notes -->
            <section data-dashboard-notes class="card-erp-panel p-4">
                <div class="mb-3 flex items-center justify-between">
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary text-[18px]">note_stack</span>
                        <h2 class="text-xs font-bold uppercase tracking-wide text-slate-300">Notas rápidas</h2>
                    </div>
                    <button type="button" data-dashboard-action="save-note"
                            class="inline-flex items-center gap-1 rounded-lg bg-primary/10 px-2.5 py-1 text-xs font-semibold text-primary hover:bg-primary/20 transition-colors"
                            title="Guardar nota">
                        <span class="material-symbols-outlined text-[14px]">add</span>
                        Guardar
                    </button>
                </div>
                <div class="rounded-xl border border-primary/20 bg-primary/5 p-3">
                    <textarea id="notaTextarea" data-dashboard-note-input
                              class="w-full h-20 bg-transparent border-none resize-none focus:ring-0 text-sm text-slate-300 placeholder:text-slate-500"
                              placeholder="Escribí un recordatorio..."></textarea>
                    <div class="flex items-center justify-between border-t border-primary/10 pt-2 mt-1">
                        <span id="notaStatus" data-dashboard-note-status class="text-[10px] text-slate-400"></span>
                        <button type="button" data-dashboard-action="save-note"
                                class="inline-flex items-center gap-1 rounded-lg bg-primary px-3 py-1.5 text-xs font-semibold text-white hover:bg-primary/90 transition-colors">
                            <span class="material-symbols-outlined text-[14px]">save</span>
                            Guardar
                        </button>
                    </div>
                </div>
                <div id="notasLista" data-dashboard-note-list class="mt-3 space-y-1.5 max-h-40 overflow-y-auto"></div>
            </section>

        </aside>

    </div>
</div>

@section Scripts {
<script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
<script src="~/js/dashboard-index.js" asp-append-version="true"></script>
}
