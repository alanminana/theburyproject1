@using TheBuryProject.Models.Enums
@model DocumentoClienteFilterViewModel
@{
    ViewData["Title"] = "Documentación de Clientes";
    ViewData["MetaDescription"] = "Gestión de documentos adjuntos de clientes: DNI, recibos, contratos y archivos en el ERP TheBuryProject.";
    var returnUrl = ViewData["ReturnUrl"] as string;
    var returnToVentaId = Model.ReturnToVentaId;
    var documentos = Model.Documentos?.ToList() ?? new List<DocumentoClienteViewModel>();
    var totalEnPagina = documentos.Count;
    var pendientes = documentos.Count(d => d.Estado == EstadoDocumento.Pendiente);
    var verificados = documentos.Count(d => d.Estado == EstadoDocumento.Verificado);
    var vencidos = documentos.Count(d => d.Estado == EstadoDocumento.Vencido);
}

@section Styles {
    <partial name="_DocumentoClienteModuleStyles" />
}

<div class="space-y-6">
    @if (Model.ClienteId.HasValue)
    {
        <a asp-controller="Cliente" asp-action="Details" asp-route-id="@Model.ClienteId"
           class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-400 hover:text-white transition-colors no-underline">
            <span class="material-symbols-outlined text-[18px]">arrow_back</span>
            Volver al Cliente
        </a>
    }
    else if (!string.IsNullOrWhiteSpace(returnUrl))
    {
        <a href="@returnUrl"
           class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-400 hover:text-white transition-colors no-underline">
            <span class="material-symbols-outlined text-[18px]">arrow_back</span>
            Volver
        </a>
    }

    <form id="filterForm" data-documento-filter-form method="get" asp-action="Index">
        <input type="hidden" name="ReturnToVentaId" value="@returnToVentaId" />
        <div class="filter-panel-erp">
            <div class="mb-4 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <h2 class="text-base font-bold text-white">Filtros y estado</h2>
                    <p class="text-sm text-slate-400">Acotá el legajo por cliente, tipo y estado para resolver validaciones más rápido.</p>
                </div>
                <span class="inline-flex items-center gap-2 rounded-full bg-slate-800 px-3 py-1 text-xs font-semibold text-slate-300">
                    <span class="material-symbols-outlined text-sm">tune</span>
                    @Model.TotalResultados resultado@(Model.TotalResultados == 1 ? "" : "s")
                </span>
            </div>

            <div class="grid grid-cols-1 gap-4 md:grid-cols-12">
                <div class="md:col-span-3">
                    <label class="mb-2 block text-xs font-bold uppercase tracking-wider text-slate-400">Cliente</label>
                    <select name="ClienteId" id="clienteFilter"
                            aria-label="Filtrar por cliente"
                            class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white transition-colors focus:border-primary focus:ring-2 focus:ring-primary/50">
                        <option value="">Todos los clientes</option>
                        @if (ViewBag.Clientes != null)
                        {
                            @foreach (var c in (SelectList)ViewBag.Clientes)
                            {
                                <option value="@c.Value" selected="@(Model.ClienteId?.ToString() == c.Value ? "selected" : null)">@c.Text</option>
                            }
                        }
                    </select>
                </div>

                <div class="md:col-span-3">
                    <label class="mb-2 block text-xs font-bold uppercase tracking-wider text-slate-400">Tipo de documento</label>
                    <select name="TipoDocumento"
                            aria-label="Tipo de documento"
                            class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white transition-colors focus:border-primary focus:ring-2 focus:ring-primary/50">
                        <option value="">Todos los tipos</option>
                        @if (ViewBag.TiposDocumento != null)
                        {
                            @foreach (var tipo in (SelectList)ViewBag.TiposDocumento)
                            {
                                <option value="@tipo.Value" selected="@(Model.TipoDocumento?.ToString() == tipo.Value ? "selected" : null)">@tipo.Text</option>
                            }
                        }
                    </select>
                </div>

                <div class="md:col-span-2">
                    <label class="mb-2 block text-xs font-bold uppercase tracking-wider text-slate-400">Estado</label>
                    <select name="Estado"
                            aria-label="Estado del documento"
                            class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white transition-colors focus:border-primary focus:ring-2 focus:ring-primary/50">
                        <option value="">Todos los estados</option>
                        @if (ViewBag.Estados != null)
                        {
                            @foreach (var e in (SelectList)ViewBag.Estados)
                            {
                                <option value="@e.Value" selected="@(((int?)Model.Estado)?.ToString() == e.Value ? "selected" : null)">@e.Text</option>
                            }
                        }
                    </select>
                </div>

                <div class="flex flex-col gap-2 rounded-xl border border-slate-700 bg-slate-950/40 px-4 py-3 md:col-span-2">
                    <label class="inline-flex cursor-pointer items-center gap-2 text-sm text-slate-300">
                        <input type="checkbox" name="SoloPendientes" value="true"
                               checked="@(Model.SoloPendientes ? "checked" : null)"
                               class="rounded border-slate-600 text-primary focus:ring-primary/50" />
                        Pendientes
                    </label>
                    <label class="inline-flex cursor-pointer items-center gap-2 text-sm text-slate-300">
                        <input type="checkbox" name="SoloVencidos" value="true"
                               checked="@(Model.SoloVencidos ? "checked" : null)"
                               class="rounded border-slate-600 text-primary focus:ring-primary/50" />
                        Vencidos
                    </label>
                </div>

                <div class="documento-index-filter-actions flex items-end gap-2 md:col-span-2">
                    <button type="submit"
                            class="inline-flex h-10 flex-1 items-center justify-center rounded-xl bg-primary px-6 text-sm font-bold text-white transition-colors hover:bg-primary/90">
                        Buscar
                    </button>
                    <a asp-action="Index"
                       id="btnLimpiar"
                       class="inline-flex h-10 items-center justify-center rounded-xl border border-slate-700 px-3 text-slate-400 transition-colors hover:bg-slate-800 no-underline"
                       title="Limpiar filtros">
                        <span class="material-symbols-outlined">filter_alt_off</span>
                    </a>
                </div>
            </div>
        </div>
    </form>

    @if (TempData["Success"] != null)
    {
        <div class="toast-msg flex items-center gap-2 rounded-xl border border-emerald-500/20 bg-emerald-500/10 p-3 text-sm font-semibold text-emerald-400" role="status">
            <span class="material-symbols-outlined text-lg">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Warning"] != null)
    {
        <div class="toast-msg flex items-center gap-2 rounded-xl border border-amber-500/20 bg-amber-500/10 p-3 text-sm font-semibold text-amber-400" role="status">
            <span class="material-symbols-outlined text-lg">warning</span>
            @TempData["Warning"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="toast-msg flex items-center gap-2 rounded-xl border border-red-500/20 bg-red-500/10 p-3 text-sm font-semibold text-red-500" role="alert">
            <span class="material-symbols-outlined text-lg">error</span>
            @TempData["Error"]
        </div>
    }

    @if (ViewBag.DocumentacionPendiente != null)
    {
        var docPendiente = ViewBag.DocumentacionPendiente as List<string>;
        if (docPendiente != null && docPendiente.Any())
        {
            <div class="rounded-xl border border-amber-500/20 bg-amber-500/10 p-4 text-amber-400">
                <p class="mb-2 flex items-center gap-2 text-sm font-bold">
                    <span class="material-symbols-outlined text-lg">fact_check</span>
                    Documentación obligatoria faltante para crédito
                </p>
                <ul class="ml-6 list-disc space-y-1 text-sm">
                    @foreach (var doc in docPendiente)
                    {
                        <li>@doc</li>
                    }
                </ul>
            </div>
        }
    }

    <div data-oc-scroll style="--oc-scroll-min-width: 69rem;" class="card-erp-panel overflow-hidden">
        <div class="border-b px-4 py-4 border-slate-800 sm:px-6">
            <div class="flex flex-wrap items-center gap-3">
                <h2 class="text-base font-bold text-white flex-1">Legajo documental</h2>
                <span class="inline-flex items-center gap-2 rounded-full bg-slate-800 px-3 py-1 text-xs font-semibold text-slate-300">
                    <span class="material-symbols-outlined text-sm">inventory_2</span>
                    @totalEnPagina en página
                </span>
                <button type="button" id="btn-abrir-upload-modal" class="btn-erp-primary btn-sm">
                    <span class="material-symbols-outlined text-[18px]">cloud_upload</span>
                    Subir Documento
                </button>
            </div>
            <p data-oc-scroll-hint hidden class="documento-index-scroll-hint mt-3 text-xs font-medium text-slate-400">
                Deslizá la tabla para ver fechas, estados y acciones completas.
            </p>
        </div>

        <div data-oc-scroll-shell>
            <div data-oc-scroll-fade="left" hidden></div>
            <div data-oc-scroll-fade="right" hidden></div>
            <div data-oc-scroll-region tabindex="0" role="region" aria-label="Listado de documentos de clientes">
                <table data-oc-scroll-table class="w-full border-collapse text-left">
                    <thead>
                        <tr class="border-b border-slate-800 bg-slate-800/50">
                            <th class="px-6 py-4 text-[11px] font-bold uppercase tracking-wider text-slate-500">Documento</th>
                            <th class="px-6 py-4 text-[11px] font-bold uppercase tracking-wider text-slate-500">Cliente</th>
                            <th class="px-6 py-4 text-[11px] font-bold uppercase tracking-wider text-slate-500">Archivo</th>
                            <th class="px-6 py-4 text-[11px] font-bold uppercase tracking-wider text-slate-500">Fecha Subida</th>
                            <th class="px-6 py-4 text-[11px] font-bold uppercase tracking-wider text-slate-500">Vencimiento</th>
                            <th class="px-6 py-4 text-[11px] font-bold uppercase tracking-wider text-slate-500">Estado</th>
                            <th class="px-6 py-4 text-right text-[11px] font-bold uppercase tracking-wider text-slate-500">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-800">
                        @if (documentos.Any())
                        {
                            @foreach (var doc in documentos)
                            {
                                var estadoClasses = doc.Estado switch
                                {
                                    EstadoDocumento.Verificado => "bg-emerald-500/20 text-emerald-400",
                                    EstadoDocumento.Rechazado => "bg-red-500/20 text-red-400",
                                    EstadoDocumento.Vencido => "bg-orange-500/20 text-orange-400",
                                    _ => "bg-amber-500/20 text-amber-400"
                                };
                                var estadoIcon = doc.Estado switch
                                {
                                    EstadoDocumento.Verificado => "check_circle",
                                    EstadoDocumento.Rechazado => "cancel",
                                    EstadoDocumento.Vencido => "schedule",
                                    _ => "pending"
                                };
                                var deleteLabel = $"el documento {doc.TipoDocumentoNombre} de {(doc.ClienteNombre ?? "cliente")}";

                                <tr class="transition-colors hover:/50 hover:bg-slate-800/30">
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 text-primary">
                                                <span class="material-symbols-outlined">description</span>
                                            </div>
                                            <span class="text-sm font-bold text-white">@doc.TipoDocumentoNombre</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-slate-400">
                                        @(doc.ClienteNombre ?? "—")
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="flex flex-col">
                                            <span class="max-w-[220px] truncate text-sm text-white" title="@doc.NombreArchivo">@doc.NombreArchivo</span>
                                            <span class="text-xs text-slate-500">@doc.TamanoFormateado</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-slate-400">
                                        @doc.FechaSubida.ToString("dd/MM/yyyy HH:mm")
                                    </td>
                                    <td class="px-6 py-4 text-sm text-slate-400">
                                        @(doc.FechaVencimiento?.ToString("dd/MM/yyyy") ?? "—")
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-xs font-bold @estadoClasses">
                                            <span class="material-symbols-outlined text-[14px]">@estadoIcon</span>
                                            @doc.EstadoNombre
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <div class="flex justify-end gap-2">
                                            <a asp-action="Details" asp-route-id="@doc.Id"
                                               asp-route-returnUrl="@Url.Action("Index", new { clienteId = Model.ClienteId, returnToVentaId = returnToVentaId })"
                                               class="documento-index-row-action row-action row-action--primary no-underline"
                                               title="Ver detalle"
                                               aria-label="Ver detalle de @doc.TipoDocumentoNombre">
                                                <span class="material-symbols-outlined text-lg">visibility</span>
                                                <span class="documento-index-row-action-label text-xs font-semibold sm:hidden">Ver</span>
                                            </a>
                                            <a asp-action="Descargar" asp-route-id="@doc.Id"
                                               class="documento-index-row-action row-action row-action--primary no-underline"
                                               title="Descargar"
                                               aria-label="Descargar @doc.TipoDocumentoNombre">
                                                <span class="material-symbols-outlined text-lg">download</span>
                                                <span class="documento-index-row-action-label text-xs font-semibold sm:hidden">Descargar</span>
                                            </a>
                                            @if (doc.Estado == EstadoDocumento.Pendiente)
                                            {
                                                <form asp-action="Verificar" asp-route-id="@doc.Id"
                                                      asp-route-returnUrl="@Url.Action("Index", new { clienteId = Model.ClienteId, returnToVentaId = returnToVentaId })"
                                                      method="post" class="inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit"
                                                            class="documento-index-row-action inline-flex items-center justify-center gap-1.5 rounded-lg px-2.5 py-1.5 text-slate-500 transition-colors hover:bg-emerald-100 hover:text-emerald-600 text-slate-400 hover:bg-emerald-500/20 sm:h-10 sm:w-10 sm:px-0 sm:py-0"
                                                            title="Verificar documento"
                                                            aria-label="Verificar @doc.TipoDocumentoNombre">
                                                        <span class="material-symbols-outlined text-lg">task_alt</span>
                                                        <span class="documento-index-row-action-label text-xs font-semibold sm:hidden">Verificar</span>
                                                    </button>
                                                </form>
                                            }
                                            <button type="button"
                                                    class="documento-index-row-action row-action row-action--warning"
                                                    title="Reemplazar"
                                                    aria-label="Reemplazar @doc.TipoDocumentoNombre"
                                                    data-documento-replace
                                                    data-documento-replace-id="@doc.Id"
                                                    data-documento-replace-nombre="@doc.NombreArchivo">
                                                <span class="material-symbols-outlined text-lg">swap_horiz</span>
                                                <span class="documento-index-row-action-label text-xs font-semibold sm:hidden">Reemplazar</span>
                                            </button>
                                            <form asp-action="Delete" asp-route-id="@doc.Id"
                                                  asp-route-returnUrl="@Url.Action("Index", new { clienteId = Model.ClienteId, returnToVentaId = returnToVentaId })"
                                                  method="post"
                                                  class="inline"
                                                  data-documento-delete-form
                                                  data-documento-label="@deleteLabel">
                                                @Html.AntiForgeryToken()
                                                <button type="submit"
                                                        class="documento-index-row-action inline-flex items-center justify-center gap-1.5 rounded-lg px-2.5 py-1.5 text-slate-500 transition-colors hover:bg-red-100 hover:text-red-500 text-slate-400 hover:bg-red-500/20 sm:h-10 sm:w-10 sm:px-0 sm:py-0"
                                                        title="Eliminar"
                                                        aria-label="Eliminar @doc.TipoDocumentoNombre">
                                                    <span class="material-symbols-outlined text-lg">delete</span>
                                                    <span class="documento-index-row-action-label text-xs font-semibold sm:hidden">Eliminar</span>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="px-6 py-16 text-center">
                                    <div class="flex flex-col items-center gap-3">
                                        <span class="material-symbols-outlined text-5xl text-slate-300 text-slate-600">folder_open</span>
                                        <p class="text-sm font-medium text-slate-500">No se encontraron documentos</p>
                                        <button type="button" data-documento-open-upload
                                                class="mt-2 inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-bold text-white transition-colors hover:bg-blue-700">
                                            <span class="material-symbols-outlined text-lg">cloud_upload</span>
                                            Subir Documento
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="flex flex-col gap-3 border-t px-4 py-4 border-slate-800 sm:flex-row sm:items-center sm:justify-between sm:px-6">
                <p class="text-sm text-slate-400">
                    Mostrando <span class="font-bold text-white">@((Model.PageNumber - 1) * Model.PageSize + 1)</span>
                    a <span class="font-bold text-white">@Math.Min(Model.PageNumber * Model.PageSize, Model.TotalResultados)</span>
                    de <span class="font-bold text-white">@Model.TotalResultados</span>
                </p>
                <div class="flex flex-wrap items-center gap-1">
                    @if (Model.HasPreviousPage)
                    {
                        <a asp-action="Index"
                           asp-route-PageNumber="@(Model.PageNumber - 1)"
                           asp-route-ClienteId="@Model.ClienteId"
                           asp-route-TipoDocumento="@Model.TipoDocumento"
                           asp-route-Estado="@Model.Estado"
                           asp-route-SoloPendientes="@Model.SoloPendientes"
                           asp-route-SoloVencidos="@Model.SoloVencidos"
                           asp-route-ReturnToVentaId="@returnToVentaId"
                           class="rounded-lg p-2 text-slate-400 transition-colors hover:bg-slate-800 no-underline"
                           aria-label="Página anterior">
                            <span class="material-symbols-outlined">chevron_left</span>
                        </a>
                    }
                    @for (var i = 1; i <= Model.TotalPages; i++)
                    {
                        var isActive = i == Model.PageNumber;
                        <a asp-action="Index"
                           asp-route-PageNumber="@i"
                           asp-route-ClienteId="@Model.ClienteId"
                           asp-route-TipoDocumento="@Model.TipoDocumento"
                           asp-route-Estado="@Model.Estado"
                           asp-route-SoloPendientes="@Model.SoloPendientes"
                           asp-route-SoloVencidos="@Model.SoloVencidos"
                           asp-route-ReturnToVentaId="@returnToVentaId"
                           class="flex h-9 w-9 items-center justify-center rounded-lg text-sm font-bold transition-colors no-underline @(isActive ? "bg-primary text-white" : "text-slate-400 hover:bg-slate-800")">
                            @i
                        </a>
                    }
                    @if (Model.HasNextPage)
                    {
                        <a asp-action="Index"
                           asp-route-PageNumber="@(Model.PageNumber + 1)"
                           asp-route-ClienteId="@Model.ClienteId"
                           asp-route-TipoDocumento="@Model.TipoDocumento"
                           asp-route-Estado="@Model.Estado"
                           asp-route-SoloPendientes="@Model.SoloPendientes"
                           asp-route-SoloVencidos="@Model.SoloVencidos"
                           asp-route-ReturnToVentaId="@returnToVentaId"
                           class="rounded-lg p-2 text-slate-400 transition-colors hover:bg-slate-800 no-underline"
                           aria-label="Página siguiente">
                            <span class="material-symbols-outlined">chevron_right</span>
                        </a>
                    }
                </div>
            </div>
        }
    </div>
</div>

<!-- Modal: Subir Documento -->
<div id="modal-upload-documento" class="fixed inset-0 z-50 hidden items-center justify-center p-4 sm:p-6">
    <div class="absolute inset-0 bg-slate-900/80 backdrop-blur-sm" id="modal-upload-backdrop"></div>
    <div class="relative w-full max-w-2xl max-h-[90vh] flex flex-col overflow-hidden bg-[#111827] rounded-xl shadow-2xl border border-slate-800">

        <!-- Header -->
        <header class="flex items-center justify-between border-b border-slate-800 px-6 py-4 shrink-0">
            <div>
                <div class="flex items-center gap-2 text-xs font-medium text-slate-400 mb-1">
                    <span>Documentación</span>
                    <span class="material-symbols-outlined text-sm">chevron_right</span>
                    <span class="text-primary" id="modal-upload-titulo-breadcrumb">Subir</span>
                </div>
                <h2 class="text-xl font-bold text-white" id="modal-upload-titulo">Subir Documento</h2>
            </div>
            <button type="button" id="btn-cerrar-upload-modal" class="p-2 hover:bg-slate-800 rounded-full transition-colors text-slate-400 hover:text-white">
                <span class="material-symbols-outlined">close</span>
            </button>
        </header>

        <!-- Form -->
        <form asp-action="Upload" method="post" enctype="multipart/form-data"
              id="form-upload-modal"
              data-documento-upload-form
              data-documento-initial-tipo=""
              class="flex flex-col flex-1 overflow-hidden">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnToDetails" value="true" />
            <input type="hidden" name="returnUrl" value="@Url.Action("Index", new { clienteId = Model.ClienteId, returnToVentaId = returnToVentaId })" />
            <input type="hidden" id="modal-upload-returnToVentaId" name="ReturnToVentaId" value="@returnToVentaId" />
            <input type="hidden" id="modal-upload-replaceId" name="DocumentoAReemplazarId" value="" />
            <input type="hidden" id="modal-upload-reemplazar" name="ReemplazarExistente" value="false" />

            <div class="flex-1 overflow-y-auto p-6 space-y-5">

                <!-- Validation summary -->
                <div id="modal-upload-validation" class="hidden bg-red-500/10 border border-red-500/20 rounded-lg p-4 flex gap-3">
                    <span class="material-symbols-outlined text-red-500 shrink-0">error</span>
                    <div>
                        <p class="text-sm font-bold text-red-400">Errores de validación</p>
                        <p id="modal-upload-validation-text" class="text-xs text-red-400/80 mt-1"></p>
                    </div>
                </div>

                <!-- Reemplazo aviso -->
                <div id="modal-upload-reemplazo-aviso" class="hidden rounded-lg border border-amber-500/20 bg-amber-500/10 p-3 flex items-center gap-2 text-amber-400 text-sm">
                    <span class="material-symbols-outlined shrink-0">swap_horiz</span>
                    <span>Se reemplazará: <strong id="modal-upload-reemplazo-nombre"></strong></span>
                </div>

                <!-- Cliente -->
                <div>
                    <label class="mb-1.5 block text-sm font-bold text-slate-300">Cliente</label>
                    @if (Model.ClienteId.HasValue)
                    {
                        var clienteNombreModal = (ViewBag.Clientes as SelectList)
                            ?.FirstOrDefault(i => i.Value == Model.ClienteId.Value.ToString())?.Text
                            ?? "Cliente seleccionado";
                        <div class="flex items-center gap-3 rounded-lg border px-4 py-3 border-slate-700 bg-slate-800">
                            <span class="material-symbols-outlined text-slate-400">person</span>
                            <span class="text-sm font-medium text-white">@clienteNombreModal</span>
                        </div>
                        <input type="hidden" name="ClienteId" value="@Model.ClienteId" />
                    }
                    else
                    {
                        <select name="ClienteId" id="modal-upload-clienteId"
                                class="w-full rounded-lg border px-4 py-2.5 text-sm border-slate-700 bg-slate-800 text-white focus:border-primary focus:ring-2 focus:ring-primary/50 outline-none transition-colors">
                            <option value="">— Seleccionar cliente —</option>
                            @if (ViewBag.Clientes is SelectList clientes)
                            {
                                @foreach (SelectListItem item in clientes)
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        </select>
                    }
                </div>

                <!-- Tipo Documento -->
                <div>
                    <label class="mb-1.5 block text-sm font-bold text-slate-300">Tipo de Documento</label>
                    <select name="TipoDocumento" id="modal-upload-tipoDocumento"
                            class="w-full rounded-lg border px-4 py-2.5 text-sm border-slate-700 bg-slate-800 text-white focus:border-primary focus:ring-2 focus:ring-primary/50 outline-none transition-colors">
                        <option value="">— Seleccionar tipo —</option>
                        @if (ViewBag.TiposDocumento is SelectList tipos)
                        {
                            @foreach (SelectListItem item in tipos)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        }
                    </select>
                </div>

                <!-- Archivo -->
                <div>
                    <label class="mb-1.5 block text-sm font-bold text-slate-300">Archivo</label>
                    <div id="modal-dropZone"
                         class="relative rounded-xl border-2 border-dashed border-slate-600 p-8 text-center transition-colors hover:border-primary/50 cursor-pointer">
                        <input name="Archivo" type="file" id="modal-archivoInput"
                               accept=".pdf,.jpg,.jpeg,.png"
                               class="absolute inset-0 h-full w-full cursor-pointer opacity-0" />
                        <div id="modal-dropZoneContent">
                            <span class="material-symbols-outlined mb-2 text-4xl text-slate-400">cloud_upload</span>
                            <p class="text-sm font-semibold text-slate-300">Arrastrá o hacé clic para seleccionar</p>
                            <p class="mt-1 text-xs text-slate-400">PDF, JPG, PNG — Máx. 5 MB</p>
                        </div>
                        <div id="modal-filePreview" class="hidden">
                            <span class="material-symbols-outlined mb-2 text-4xl text-emerald-500">description</span>
                            <p id="modal-fileName" class="text-sm font-semibold text-white"></p>
                            <p id="modal-fileSize" class="mt-1 text-xs text-slate-400"></p>
                        </div>
                    </div>
                </div>

                <!-- Fecha Vencimiento -->
                <div>
                    <label class="mb-1.5 block text-sm font-bold text-slate-300">Fecha de Vencimiento <span class="font-normal text-slate-500">(opcional)</span></label>
                    <input name="FechaVencimiento" type="date"
                           class="w-full rounded-lg border px-4 py-2.5 text-sm border-slate-700 bg-slate-800 text-white focus:border-primary focus:ring-2 focus:ring-primary/50 outline-none transition-colors" />
                </div>

                <!-- Observaciones -->
                <div>
                    <label class="mb-1.5 block text-sm font-bold text-slate-300">Observaciones <span class="font-normal text-slate-500">(opcional)</span></label>
                    <textarea name="Observaciones" rows="2"
                              class="w-full resize-none rounded-lg border px-4 py-2.5 text-sm border-slate-700 bg-slate-800 text-white focus:border-primary focus:ring-2 focus:ring-primary/50 outline-none transition-colors"
                              placeholder="Notas sobre el documento..."></textarea>
                </div>
            </div>

            <!-- Footer -->
            <footer class="shrink-0 flex items-center justify-end gap-3 border-t border-slate-800 bg-slate-900/50 px-6 py-4">
                <button type="button" id="btn-cancelar-upload-modal"
                        class="px-5 py-2.5 text-sm font-semibold text-slate-400 hover:text-white transition-colors">
                    Cancelar
                </button>
                <button type="submit" id="btn-submit-upload-modal"
                        class="inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-2.5 text-sm font-bold text-white shadow-lg shadow-primary/20 hover:bg-primary/90 transition-colors">
                    <span class="material-symbols-outlined text-lg">cloud_upload</span>
                    <span id="btn-submit-upload-label">Subir Documento</span>
                </button>
            </footer>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
    <script src="~/js/documento-module.js" asp-append-version="true"></script>
    <script src="~/js/documento-index.js" asp-append-version="true"></script>
    <script src="~/js/documento-upload-modal.js" asp-append-version="true"></script>
}
