@using TheBuryProject.Models.Entities
@using TheBuryProject.Modules.MercadoLibre.Entities
@model MercadoLibrePriceBatchRequest
@{
    ViewData["Title"] = "Nuevo aumento masivo ML";
    var categorias = ViewBag.Categorias as IEnumerable<Categoria> ?? Enumerable.Empty<Categoria>();
    var marcas = ViewBag.Marcas as IEnumerable<Marca> ?? Enumerable.Empty<Marca>();
    var noHayPublicacionesVinculadas = ViewBag.NoHayPublicacionesVinculadas as bool? ?? false;
}

<div class="erp-page-shell erp-compact">

    <partial name="_MercadoLibreNav" />

    <nav class="text-sm text-slate-400 mb-3" aria-label="Ruta">
        <a asp-action="Aumentos" class="hover:text-amber-300">Aumentos</a>
        <span class="mx-1 text-slate-600">/</span>
        <span class="text-slate-300">Nuevo aumento</span>
    </nav>

    <div class="ml-head">
        <div class="ml-head__main">
            <h1 class="ml-head__title">
                <span class="material-symbols-outlined" aria-hidden="true">trending_up</span>
                Nuevo aumento masivo
            </h1>
            <p class="ml-head__subtitle">
                El lote se crea como <span class="font-bold text-sky-300">simulación con preview</span>; nada se envía a ML en este paso.
            </p>
        </div>
    </div>

    <form asp-action="AumentoSimular" method="post" class="pb-24">
        @Html.AntiForgeryToken()

        <div class="grid grid-cols-1 gap-6 xl:grid-cols-2">
            <div class="card-erp-panel p-6">
                <h2 class="text-base font-bold text-white mb-4">Definición</h2>

                <div class="space-y-4">
                    <div>
                        <label asp-for="Nombre" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Nombre del lote</label>
                        <input asp-for="Nombre" class="input-erp w-full" placeholder="Ej: Aumento 10% electro junio" />
                        <span asp-validation-for="Nombre" class="text-xs text-rose-400"></span>
                    </div>

                    <div>
                        <label asp-for="Origen" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Origen del precio nuevo</label>
                        <select asp-for="Origen" class="select-erp w-full">
                            <option value="@MercadoLibrePriceBatchOrigen.PorcentajeSobrePrecioMl">Porcentaje sobre el precio ML actual (no usa precios internos)</option>
                            <option value="@MercadoLibrePriceBatchOrigen.DesdePrecioErp">Desde precio ERP + ajuste canal + ajuste extra</option>
                        </select>
                    </div>

                    <div>
                        <label asp-for="ValorAjustePorcentaje" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Ajuste (%)</label>
                        <input asp-for="ValorAjustePorcentaje" type="number" step="0.01" class="input-erp w-full" />
                        <span asp-validation-for="ValorAjustePorcentaje" class="text-xs text-rose-400"></span>
                        <p class="text-xs text-slate-500 mt-1">
                            Con "% sobre precio ML": el aumento directo. Con "desde precio ERP": ajuste extra sobre el precio de canal calculado.
                        </p>
                    </div>
                </div>
            </div>

            <div class="card-erp-panel p-6">
                <h2 class="text-base font-bold text-white mb-4">Filtros</h2>

                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                    <div>
                        <label asp-for="CategoriaId" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Categoría</label>
                        <select asp-for="CategoriaId" class="select-erp w-full">
                            <option value="">Todas</option>
                            @foreach (var categoria in categorias)
                            {
                                <option value="@categoria.Id">@categoria.Nombre</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label asp-for="MarcaId" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Marca</label>
                        <select asp-for="MarcaId" class="select-erp w-full">
                            <option value="">Todas</option>
                            @foreach (var marca in marcas)
                            {
                                <option value="@marca.Id">@marca.Nombre</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label asp-for="Estado" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Estado en ML</label>
                        <select asp-for="Estado" class="select-erp w-full">
                            <option value="">Activas y pausadas</option>
                            <option value="active">Solo activas</option>
                            <option value="paused">Solo pausadas</option>
                        </select>
                    </div>
                    <div class="grid grid-cols-2 gap-2">
                        <div>
                            <label asp-for="PrecioDesde" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Precio desde</label>
                            <input asp-for="PrecioDesde" type="number" step="0.01" class="input-erp w-full" />
                        </div>
                        <div>
                            <label asp-for="PrecioHasta" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Precio hasta</label>
                            <input asp-for="PrecioHasta" type="number" step="0.01" class="input-erp w-full" />
                        </div>
                    </div>
                </div>

                <div class="space-y-2 mt-4">
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input asp-for="SoloVinculadas" type="checkbox" />
                        <span class="text-sm text-white">Solo publicaciones vinculadas a producto</span>
                    </label>
                    @if (noHayPublicacionesVinculadas)
                    {
                        <p class="text-xs text-amber-300">
                            No hay publicaciones vinculadas. Desmarcá el filtro solo para previsualizar; no podrás aplicar cambios reales sobre publicaciones sin vincular.
                        </p>
                    }
                    else
                    {
                        <p class="text-xs text-slate-500">
                            Las publicaciones sin producto vinculado pueden previsualizarse, pero se omiten en cualquier envío real.
                        </p>
                    }
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input asp-for="SoloConStock" type="checkbox" />
                        <span class="text-sm text-white">Solo publicaciones con stock ML</span>
                    </label>
                </div>
            </div>
        </div>

        <div class="flex justify-end gap-2 mt-6">
            <a asp-action="Aumentos" class="btn-erp-secondary">Cancelar</a>
            <button type="submit" class="btn-erp-primary">
                <span class="material-symbols-outlined text-sm">science</span>
                Simular lote
            </button>
        </div>
    </form>
</div>
