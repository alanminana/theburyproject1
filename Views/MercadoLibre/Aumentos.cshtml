@using TheBuryProject.Modules.MercadoLibre.Entities
@model List<MercadoLibrePriceBatchListViewModel>
@{
    ViewData["Title"] = "Aumentos masivos Mercado Libre";
}

<div class="erp-page-shell erp-compact">

    @if (TempData["Success"] != null)
    {
        <div class="alert-erp alert-erp-success toast-msg" role="status">
            <span class="material-symbols-outlined">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-erp alert-erp-error toast-msg" role="alert">
            <span class="material-symbols-outlined">error</span>
            @TempData["Error"]
        </div>
    }

    <partial name="_MercadoLibreNav" />

    <div class="ml-head">
        <div class="ml-head__main">
            <h1 class="ml-head__title">
                <span class="material-symbols-outlined" aria-hidden="true">trending_up</span>
                Aumentos masivos
            </h1>
            <p class="ml-head__subtitle">
                Cambios de precio por lote con preview, snapshot y rollback. No tocan precios internos del ERP.
            </p>
        </div>
        <div class="ml-actions">
            <span class="ml-actions__label">Acciones</span>
            <a asp-action="AumentoNuevo" class="btn-erp-primary btn-sm">
                <span class="material-symbols-outlined text-sm">add</span>
                Nuevo aumento
            </a>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="card-erp-panel p-8 text-center">
            <span class="material-symbols-outlined text-5xl text-slate-600 mb-3 block" aria-hidden="true">trending_up</span>
            <h2 class="text-lg font-bold text-white mb-2">Sin lotes de aumento</h2>
            <p class="text-sm text-slate-400">Creá un lote: siempre arranca como simulación con preview.</p>
        </div>
    }
    else
    {
        <div class="card-erp-panel overflow-hidden">
            <div class="overflow-x-auto">
                <table class="erp-table w-full">
                    <thead>
                        <tr>
                            <th>Lote</th>
                            <th>Origen</th>
                            <th class="text-right">Ajuste</th>
                            <th class="text-right">Publicaciones</th>
                            <th class="text-right">Items</th>
                            <th class="text-right">Errores</th>
                            <th>Estado</th>
                            <th>Solicitado</th>
                            <th class="text-right">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var batch in Model)
                        {
                            <tr>
                                <td class="font-semibold text-white">@batch.Nombre</td>
                                <td class="text-xs text-slate-300">
                                    @(batch.Origen == MercadoLibrePriceBatchOrigen.DesdePrecioErp ? "Desde precio ERP" : "% sobre precio ML")
                                </td>
                                <td class="text-right font-mono text-white">@batch.ValorAjustePorcentaje.ToString("+0.##;-0.##;0")%</td>
                                <td class="text-right font-mono text-white">@batch.CantidadPublicaciones</td>
                                <td class="text-right font-mono text-white">@batch.CantidadItems</td>
                                <td class="text-right font-mono @(batch.CantidadErrores > 0 ? "text-rose-400" : "text-slate-400")">
                                    @batch.CantidadErrores
                                </td>
                                <td>
                                    @switch (batch.Estado)
                                    {
                                        case MercadoLibrePriceBatchEstado.Simulado:
                                            <span class="text-xs font-bold text-sky-400">Simulado</span>
                                            break;
                                        case MercadoLibrePriceBatchEstado.Aplicado:
                                            <span class="text-xs font-bold @(batch.AplicadoEnSimulacion ? "text-sky-400" : "text-emerald-400")">
                                                @(batch.AplicadoEnSimulacion ? "Aplicado en simulación" : "Aplicado")
                                            </span>
                                            break;
                                        case MercadoLibrePriceBatchEstado.AplicadoParcial:
                                            <span class="text-xs font-bold text-amber-400">Aplicado parcial</span>
                                            break;
                                        case MercadoLibrePriceBatchEstado.Revertido:
                                            <span class="text-xs font-bold text-slate-400">Revertido</span>
                                            break;
                                        default:
                                            <span class="text-xs text-slate-500">Cancelado</span>
                                            break;
                                    }
                                </td>
                                <td class="text-xs text-slate-400">
                                    @batch.SolicitadoPor · @batch.FechaSolicitud.ToLocalTime().ToString("dd/MM HH:mm")
                                </td>
                                <td class="text-right">
                                    <a asp-action="Aumento" asp-route-id="@batch.Id" class="btn-erp-icon" title="Ver lote">
                                        <span class="material-symbols-outlined text-lg">visibility</span>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
