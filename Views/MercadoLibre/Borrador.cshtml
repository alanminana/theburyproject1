@using TheBuryProject.Modules.MercadoLibre.Entities
@model MercadoLibreBorradorEditViewModel
@{
    ViewData["Title"] = $"Borrador: {Model.Titulo}";
}

<div class="erp-page-shell erp-compact">

    @if (TempData["Success"] != null)
    {
        <div class="alert-erp alert-erp-success toast-msg" role="status">
            <span class="material-symbols-outlined">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Info"] != null)
    {
        <div class="alert-erp border border-sky-500/30 bg-sky-500/10 text-sky-200 toast-msg" role="status">
            <span class="material-symbols-outlined">info</span>
            @TempData["Info"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-erp alert-erp-error toast-msg" role="alert">
            <span class="material-symbols-outlined">error</span>
            @TempData["Error"]
        </div>
    }

    <partial name="_MercadoLibreNav" />

    <nav class="text-sm text-slate-400 mb-3" aria-label="Ruta">
        <a asp-action="Borradores" class="hover:text-amber-300">Borradores</a>
        <span class="mx-1 text-slate-600">/</span>
        <span class="text-slate-300">@Model.Titulo</span>
    </nav>

    <div class="ml-head">
        <div class="ml-head__main">
            <h1 class="ml-head__title">
                <span class="material-symbols-outlined" aria-hidden="true">draft</span>
                Borrador de publicación
            </h1>
            <p class="ml-head__subtitle">
                Producto: <span class="font-semibold text-white">@Model.ProductoCodigo — @Model.ProductoNombre</span>
                · precio ERP @Model.ProductoPrecioVenta.ToString("N2")
                · stock ERP @Model.ProductoStockActual.ToString("N0")
            </p>
        </div>
    </div>

    <!-- Flujo guiado: pasos · estado · acciones -->
    <div class="card-erp-panel p-4 mb-6">
        @{
            var estaPublicado = Model.Estado == MercadoLibreBorradorEstado.Publicado;
            var estaValidado = Model.Estado == MercadoLibreBorradorEstado.Validado;
            var datosMinimosOk = !string.IsNullOrWhiteSpace(Model.Titulo) && Model.Precio > 0 && !string.IsNullOrWhiteSpace(Model.CategoryIdMl);
            var pasoActual = estaPublicado ? 4 : (estaValidado ? 3 : (datosMinimosOk ? 2 : 1));

            // Campos marcados por ML en el último rechazo (línea machine-readable CAMPOS_ERROR).
            var camposError = new List<string>();
            string[] erroresLineas = System.Array.Empty<string>();
            if (!string.IsNullOrEmpty(Model.ErroresValidacion))
            {
                erroresLineas = Model.ErroresValidacion.Split('\n', StringSplitOptions.RemoveEmptyEntries);
                var lineaCampos = erroresLineas.FirstOrDefault(l => l.StartsWith("CAMPOS_ERROR:"));
                if (lineaCampos is not null)
                {
                    camposError = lineaCampos["CAMPOS_ERROR:".Length..]
                        .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                        .ToList();
                }
            }

            // El único requisito para usar el botón principal es estar validado: por
            // defecto SIMULA. La publicación real se decide con el checkbox «Publicación REAL».
            var pasos = new (string Icono, string Texto)[]
            {
                ("edit", "Datos"),
                ("fact_check", "Validar"),
                ("rocket_launch", "Simular / Publicar")
            };
        }

        @if (estaPublicado)
        {
            <p class="text-sm text-emerald-400 font-bold">
                Publicado como @Model.PublicadoItemId el @Model.FechaPublicadoUtc?.ToLocalTime().ToString("dd/MM HH:mm").
                <span class="text-slate-400 font-normal">Recordá cargar imágenes desde Mercado Libre.</span>
            </p>
        }
        else
        {
            <ol class="ml-steps" aria-label="Pasos para publicar">
                @for (var i = 0; i < pasos.Length; i++)
                {
                    var n = i + 1;
                    var clasePaso = n < pasoActual ? "is-done" : (n == pasoActual ? "is-current" : "is-todo");
                    <li class="ml-step @clasePaso">
                        <span class="ml-step__dot">
                            @if (n < pasoActual)
                            {
                                <span class="material-symbols-outlined" aria-hidden="true">check</span>
                            }
                            else
                            {
                                <span>@n</span>
                            }
                        </span>
                        <span class="ml-step__label">
                            <span class="material-symbols-outlined" aria-hidden="true">@pasos[i].Icono</span>
                            @pasos[i].Texto
                        </span>
                    </li>
                }
            </ol>

            <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between mt-4"
                 id="ml-publish-flow"
                 data-permitir="@(Model.PermitirPublicacionDesdeErp ? "1" : "0")"
                 data-cuenta="@(Model.CuentaConectada ? "1" : "0")"
                 data-validado="@(estaValidado ? "1" : "0")">
                <div class="min-w-0">
                    @if (estaValidado)
                    {
                        <p class="text-sm font-bold text-sky-300" data-ml-status>
                            Validado — listo para simular. No se enviará nada a Mercado Libre.
                        </p>
                    }
                    else
                    {
                        <p class="text-sm font-bold text-slate-300" data-ml-status>Borrador en edición — completá los datos y validalo.</p>
                    }
                    <p class="text-xs mt-1 text-slate-400" data-ml-hint>
                        El botón simula por defecto. Marcá «Publicación REAL» solo para enviar a Mercado Libre.
                    </p>
                </div>

                @if (User.TienePermiso("mercadolibre", "sync"))
                {
                    <div class="flex flex-wrap gap-2 items-end shrink-0">
                        <form asp-action="BorradorValidar" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn-erp-secondary btn-sm" disabled="@(Model.PuedeValidar ? null : "disabled")">
                                <span class="material-symbols-outlined text-sm">fact_check</span>
                                Validar
                            </button>
                        </form>

                        <form asp-action="BorradorPublicar" method="post" class="ml-publish-form" id="ml-publish-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            @if (estaValidado)
                            {
                                <label class="ml-real-check">
                                    <input type="checkbox" name="confirmarReal" value="true" data-ml-real />
                                    <span class="ml-real-check__text">
                                        <span>Publicación <span class="ml-real-check__flag">REAL</span></span>
                                        <span class="ml-real-check__hint">Marcá esto solo si querés enviar la publicación a Mercado Libre.</span>
                                    </span>
                                </label>
                            }
                            <button type="submit" class="btn-erp-primary btn-sm" id="ml-publish-btn"
                                    disabled="@(Model.PuedeSimular ? null : "disabled")">
                                <span class="material-symbols-outlined text-sm" data-ml-btn-icon>science</span>
                                <span data-ml-btn-text>Simular publicación</span>
                            </button>
                        </form>

                        <form asp-action="BorradorDescartar" method="post"
                              onsubmit="return confirm('¿Descartar el borrador? Si no se publicó en ML, solo se oculta localmente; no se borra nada de Mercado Libre.');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn-erp-ghost btn-sm text-slate-400" disabled="@(Model.PuedeDescartar ? null : "disabled")">
                                Descartar
                            </button>
                        </form>
                    </div>
                }
            </div>

            <p class="ml-field-error-msg mt-2" data-ml-block hidden></p>

            @if (!estaValidado)
            {
                <div class="ml-blockers mt-3">
                    <p class="ml-blockers__title">
                        <span class="material-symbols-outlined text-sm">checklist</span>
                        Para simular o publicar falta:
                    </p>
                    <ul class="ml-blockers__list">
                        <li>Validá el borrador con el botón «Validar». Cada vez que editás y guardás, hay que volver a validar.</li>
                    </ul>
                </div>
            }
        }

        @if (erroresLineas.Length > 0)
        {
            <div class="ml-error-summary mt-3" data-ml-campos-error="@string.Join(",", camposError)">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">
                    Última validación / respuesta de ML (@Model.FechaValidacionUtc?.ToLocalTime().ToString("dd/MM HH:mm"))
                </p>
                <ul class="space-y-0.5">
                    @foreach (var linea in erroresLineas.Where(l => !l.StartsWith("CAMPOS_ERROR:")))
                    {
                        <li class="text-xs @(linea.StartsWith("ERROR") ? "text-rose-400" : "text-amber-300")">@linea</li>
                    }
                </ul>
            </div>
        }
        @if (Model.PublicadoEnSimulacion && !string.IsNullOrWhiteSpace(Model.PayloadSimuladoJson))
        {
            <div class="mt-3 border-t border-slate-700 pt-3">
                <p class="text-xs font-bold uppercase tracking-wider text-sky-300 mb-1">
                    Simulacion local (@Model.FechaSimulacionUtc?.ToLocalTime().ToString("dd/MM HH:mm"))
                </p>
                <p class="text-xs text-slate-400 mb-2">No se llamo a Mercado Libre ni se creo publicacion real.</p>
                <div class="overflow-x-auto rounded border border-slate-700 bg-slate-950/70 p-3">
                    <pre class="text-xs text-slate-300 whitespace-pre-wrap">@Model.PayloadSimuladoJson</pre>
                </div>
            </div>
        }
    </div>

    <!-- Formulario -->
    @if (Model.PuedeEditar && User.TienePermiso("mercadolibre", "sync"))
    {
        <form asp-action="BorradorActualizar" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ProductoId" />

            <div class="grid grid-cols-1 gap-6 xl:grid-cols-2">
                <div class="card-erp-panel p-6">
                    <h2 class="text-base font-bold text-white mb-4">Contenido</h2>

                    <div class="space-y-4">
                        <div data-ml-field="title">
                            <label asp-for="Titulo" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Título (máx. 60)</label>
                            <input asp-for="Titulo" maxlength="60" class="input-erp w-full" />
                            <span asp-validation-for="Titulo" class="text-xs text-rose-400"></span>
                        </div>

                        <div>
                            <label asp-for="Descripcion" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Descripción (texto plano)</label>
                            <textarea asp-for="Descripcion" rows="6" class="input-erp w-full"></textarea>
                        </div>

                        <div>
                            <label asp-for="Garantia" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Garantía (informativo)</label>
                            <input asp-for="Garantia" class="input-erp w-full" placeholder="Ej: Garantía oficial 12 meses" />
                        </div>
                    </div>
                </div>

                <div class="card-erp-panel p-6">
                    <h2 class="text-base font-bold text-white mb-4">Oferta</h2>

                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                        <div data-ml-field="price">
                            <label asp-for="Precio" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Precio</label>
                            <input asp-for="Precio" type="number" step="0.01" class="input-erp w-full" />
                            <span asp-validation-for="Precio" class="text-xs text-rose-400"></span>
                        </div>
                        <div data-ml-field="available_quantity">
                            <label asp-for="Stock" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Stock a publicar</label>
                            <input asp-for="Stock" type="number" step="1" min="0" class="input-erp w-full" />
                            <span asp-validation-for="Stock" class="text-xs text-rose-400"></span>
                            <p class="text-xs text-slate-500 mt-1">Podés bajarlo respecto del stock ERP, pero no superarlo. No modifica el inventario.</p>
                        </div>
                        <div class="sm:col-span-2"
                             data-ml-field="category_id"
                             id="ml-categoria-picker"
                             data-url-sugerencias="@Url.Action("CategoriaSugerencias")"
                             data-url-hijos="@Url.Action("CategoriaHijos")"
                             data-url-resolver="@Url.Action("CategoriaResolver")">
                            <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Categoría ML</label>

                            <input type="hidden" asp-for="CategoryIdMl" />
                            <input type="hidden" asp-for="CategoryNombre" />
                            <input type="hidden" asp-for="CategoryPathFromRoot" />
                            <input type="hidden" asp-for="CategoryEsHoja" />

                            <div data-rol="seleccion" class="rounded border border-slate-700 bg-slate-950/60 px-3 py-2 text-sm"></div>

                            <div class="flex flex-wrap items-center gap-2 mt-2">
                                <button type="button" data-rol="sugerir" class="btn-erp-secondary btn-sm text-xs">
                                    <span class="material-symbols-outlined text-sm">auto_awesome</span>
                                    Sugerir por título
                                </button>
                                <button type="button" data-rol="arbol" class="btn-erp-ghost btn-sm text-xs">
                                    <span class="material-symbols-outlined text-sm">account_tree</span>
                                    Navegar árbol
                                </button>
                            </div>

                            <div class="flex items-center gap-2 mt-2">
                                <input type="text" data-rol="buscar" class="input-erp w-full" placeholder="Buscar categoría por texto (ej: zapatillas running)" />
                                <button type="button" data-rol="buscar-btn" class="btn-erp-secondary btn-sm shrink-0">Buscar</button>
                            </div>

                            <ul data-rol="resultados" class="mt-2 max-h-56 overflow-y-auto"></ul>
                            <p data-rol="estado" class="text-xs mt-1 text-slate-400"></p>
                            <span asp-validation-for="CategoryIdMl" class="text-xs text-rose-400"></span>
                            <p class="text-xs text-slate-500 mt-1">Solo se puede publicar en categorías <b>hoja</b>. El navegado del árbol requiere una cuenta ML conectada; el predictor funciona siempre.</p>
                        </div>
                        <div data-ml-field="condition">
                            <label asp-for="Condicion" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Condición</label>
                            <select asp-for="Condicion" class="select-erp w-full">
                                <option value="new">Nuevo</option>
                                <option value="used">Usado</option>
                            </select>
                        </div>
                        <div data-ml-field="listing_type_id">
                            <label asp-for="ListingTypeId" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Tipo de publicación</label>
                            <select asp-for="ListingTypeId" class="select-erp w-full" data-ml-listing-type>
                                <option value="gold_special">Clásica (gold_special)</option>
                                <option value="gold_pro">Premium (gold_pro)</option>
                                <option value="free">Gratuita (free)</option>
                            </select>
                        </div>

                        <div class="sm:col-span-2" data-ml-field="pictures" id="ml-imagenes">
                            <label asp-for="ImagenesUrls" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">
                                Imágenes para Mercado Libre
                            </label>
                            <textarea asp-for="ImagenesUrls" rows="3" class="input-erp w-full"
                                      placeholder="Una URL por línea (https://...)" data-ml-img-input></textarea>
                            <p class="text-xs text-slate-500 mt-1">
                                Pegá una URL <b>http/https</b> por línea. Mercado Libre exige al menos una imagen para publicación
                                gratuita [free]; con otros tipos es opcional pero recomendado.
                            </p>
                            <p class="ml-img-note mt-2" data-ml-img-note hidden>
                                <span class="material-symbols-outlined text-sm" aria-hidden="true">warning</span>
                                <span data-ml-img-note-text></span>
                            </p>
                            <div class="ml-img-preview mt-2" data-ml-img-preview hidden></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="flex justify-end gap-2 mt-6">
                <button type="submit" class="btn-erp-primary">
                    <span class="material-symbols-outlined text-sm">save</span>
                    Guardar borrador
                </button>
            </div>
        </form>
    }
    else
    {
        <div class="card-erp-panel p-6">
            <h2 class="text-base font-bold text-white mb-4">Contenido</h2>
            <dl class="grid grid-cols-1 gap-3 sm:grid-cols-2 text-sm">
                <div><dt class="text-xs uppercase text-slate-400">Título</dt><dd class="text-white">@Model.Titulo</dd></div>
                <div><dt class="text-xs uppercase text-slate-400">Precio</dt><dd class="font-mono text-white">@Model.Precio.ToString("N2")</dd></div>
                <div>
                    <dt class="text-xs uppercase text-slate-400">Categoría ML</dt>
                    <dd class="text-white">
                        @(Model.CategoryNombre ?? "—")
                        <span class="font-mono text-xs text-slate-400">@(Model.CategoryIdMl is null ? "" : $"({Model.CategoryIdMl})")</span>
                        @if (!string.IsNullOrWhiteSpace(Model.CategoryPathFromRoot))
                        {
                            <div class="text-xs text-slate-400">@Model.CategoryPathFromRoot</div>
                        }
                    </dd>
                </div>
                <div><dt class="text-xs uppercase text-slate-400">Stock</dt><dd class="font-mono text-white">@Model.Stock</dd></div>
                <div><dt class="text-xs uppercase text-slate-400">Condición</dt><dd class="text-white">@Model.Condicion · @Model.ListingTypeId</dd></div>
                <div class="sm:col-span-2"><dt class="text-xs uppercase text-slate-400">Descripción</dt><dd class="text-slate-300 whitespace-pre-line">@(Model.Descripcion ?? "—")</dd></div>
                <div class="sm:col-span-2">
                    <dt class="text-xs uppercase text-slate-400">Imágenes</dt>
                    <dd class="text-slate-300">
                        @if (Model.Imagenes.Count == 0)
                        {
                            <span class="text-slate-500">Sin imágenes</span>
                        }
                        else
                        {
                            <div class="ml-img-preview mt-1">
                                @foreach (var url in Model.Imagenes)
                                {
                                    <a href="@url" target="_blank" rel="noopener" class="ml-img-thumb" title="@url">
                                        <img src="@url" alt="Imagen de la publicación" loading="lazy" />
                                    </a>
                                }
                            </div>
                        }
                    </dd>
                </div>
            </dl>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/mercadolibre-categoria-picker.js" asp-append-version="true"></script>
    <script>
        // Flujo de publicación: el checkbox "Publicación REAL" decide simular vs publicar.
        (function () {
            var flow = document.getElementById('ml-publish-flow');
            if (!flow) return;

            var real = flow.querySelector('[data-ml-real]');
            var btn = document.getElementById('ml-publish-btn');
            var btnText = flow.querySelector('[data-ml-btn-text]');
            var btnIcon = flow.querySelector('[data-ml-btn-icon]');
            var status = flow.querySelector('[data-ml-status]');
            var hint = flow.querySelector('[data-ml-hint]');
            var stepLabel = document.querySelector('[data-ml-step3]');
            var block = document.querySelector('[data-ml-block]');
            var form = document.getElementById('ml-publish-form');

            var permitir = flow.getAttribute('data-permitir') === '1';
            var cuenta = flow.getAttribute('data-cuenta') === '1';
            var validado = flow.getAttribute('data-validado') === '1';

            function setBlock(msg) {
                if (!block) return;
                if (msg) { block.textContent = msg; block.hidden = false; }
                else { block.textContent = ''; block.hidden = true; }
            }

            function apply() {
                if (!btn || !validado) return;
                var quiereReal = real && real.checked;

                if (!quiereReal) {
                    if (btnText) btnText.textContent = 'Simular publicación';
                    if (btnIcon) btnIcon.textContent = 'science';
                    if (stepLabel) stepLabel.textContent = 'Simular';
                    if (status) status.textContent = 'Listo para simular. No se enviará nada a Mercado Libre.';
                    if (hint) hint.textContent = 'El botón simula por defecto. Marcá «Publicación REAL» solo para enviar a Mercado Libre.';
                    btn.disabled = false;
                    setBlock('');
                    return;
                }

                // Quiere publicación real.
                if (stepLabel) stepLabel.textContent = 'Publicar';
                if (!permitir) {
                    if (btnText) btnText.textContent = 'Publicar en Mercado Libre';
                    if (btnIcon) btnIcon.textContent = 'public';
                    btn.disabled = true;
                    if (status) status.textContent = 'Publicación real bloqueada.';
                    setBlock('La publicación real está deshabilitada en Configuración.');
                    return;
                }
                if (!cuenta) {
                    if (btnText) btnText.textContent = 'Publicar en Mercado Libre';
                    if (btnIcon) btnIcon.textContent = 'public';
                    btn.disabled = true;
                    if (status) status.textContent = 'Falta cuenta conectada.';
                    setBlock('Conectá una cuenta de Mercado Libre (Configuración → Cuenta) para publicar de verdad.');
                    return;
                }
                if (btnText) btnText.textContent = 'Publicar en Mercado Libre';
                if (btnIcon) btnIcon.textContent = 'publish';
                btn.disabled = false;
                if (status) status.textContent = 'Publicación real: se enviará a Mercado Libre tras confirmar.';
                if (hint) hint.textContent = 'Vas a crear la publicación en Mercado Libre. Revisá los datos antes de confirmar.';
                setBlock('');
            }

            if (real) real.addEventListener('change', apply);
            if (form) {
                form.addEventListener('submit', function (e) {
                    var quiereReal = real && real.checked;
                    var msg = quiereReal
                        ? '¿Publicar este borrador REALMENTE en Mercado Libre?'
                        : '¿Simular este borrador localmente? No llama a Mercado Libre.';
                    if (!window.confirm(msg)) { e.preventDefault(); }
                });
            }
            apply();
        })();

        // Marca los campos involucrados en el último rechazo de ML.
        (function () {
            var summary = document.querySelector('[data-ml-campos-error]');
            if (!summary) return;
            var tokens = (summary.getAttribute('data-ml-campos-error') || '')
                .split(',').map(function (t) { return t.trim(); }).filter(Boolean);
            tokens.forEach(function (token) {
                var field = document.querySelector('[data-ml-field="' + token + '"]');
                if (field) field.classList.add('ml-field-error');
            });
        })();

        // Imágenes: preview en vivo + aviso cuando el tipo "free" no tiene imágenes.
        (function () {
            var input = document.querySelector('[data-ml-img-input]');
            if (!input) return;
            var preview = document.querySelector('[data-ml-img-preview]');
            var note = document.querySelector('[data-ml-img-note]');
            var noteText = document.querySelector('[data-ml-img-note-text]');
            var listingType = document.querySelector('[data-ml-listing-type]');

            function parseUrls() {
                return (input.value || '')
                    .split(/\r?\n/)
                    .map(function (s) { return s.trim(); })
                    .filter(Boolean);
            }
            function esValida(u) { return /^https?:\/\//i.test(u); }

            function render() {
                var urls = parseUrls();
                // Preview
                if (preview) {
                    preview.innerHTML = '';
                    urls.forEach(function (u) {
                        if (!esValida(u)) return;
                        var a = document.createElement('a');
                        a.href = u; a.target = '_blank'; a.rel = 'noopener';
                        a.className = 'ml-img-thumb'; a.title = u;
                        var img = document.createElement('img');
                        img.src = u; img.alt = 'Imagen de la publicación'; img.loading = 'lazy';
                        a.appendChild(img); preview.appendChild(a);
                    });
                    preview.hidden = preview.children.length === 0;
                }
                // Aviso por campo
                var invalidas = urls.filter(function (u) { return !esValida(u); });
                var esFree = listingType && (listingType.value || '').toLowerCase() === 'free';
                var msg = '';
                if (invalidas.length > 0) {
                    msg = invalidas.length + ' URL inválida(s): usá direcciones http o https completas.';
                } else if (esFree && urls.length === 0) {
                    msg = 'Mercado Libre exige imágenes para publicación gratuita [free]. Agregá al menos una o cambiá el tipo de publicación.';
                }
                if (note && noteText) {
                    if (msg) { noteText.textContent = msg; note.hidden = false; }
                    else { noteText.textContent = ''; note.hidden = true; }
                }
            }

            input.addEventListener('input', render);
            if (listingType) listingType.addEventListener('change', render);
            render();
        })();
    </script>
}
