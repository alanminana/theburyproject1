@using TheBuryProject.Modules.MercadoLibre.Entities
@model List<MercadoLibreBorradorListViewModel>
@{
    ViewData["Title"] = "Borradores de publicación";
    var productosJson = ViewBag.ProductosPickerJson as string ?? "[]";
    var permitirPublicacion = ViewBag.PermitirPublicacion as bool? ?? false;
    var cuentaConectada = ViewBag.CuentaConectada as bool? ?? false;
}

<div class="erp-page-shell erp-compact">

    @if (TempData["Success"] != null)
    {
        <div class="alert-erp alert-erp-success toast-msg" role="status">
            <span class="material-symbols-outlined">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Info"] != null)
    {
        <div class="alert-erp border border-sky-500/30 bg-sky-500/10 text-sky-200 toast-msg" role="status">
            <span class="material-symbols-outlined">info</span>
            @TempData["Info"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-erp alert-erp-error toast-msg" role="alert">
            <span class="material-symbols-outlined">error</span>
            @TempData["Error"]
        </div>
    }

    <partial name="_MercadoLibreNav" />

    <div class="ml-head">
        <div class="ml-head__main">
            <h1 class="ml-head__title">
                <span class="material-symbols-outlined" aria-hidden="true">draft</span>
                Borradores de publicación
            </h1>
            <p class="ml-head__subtitle">
                Producto ERP → borrador → validación → publicar. Por defecto cada borrador se
                <b>simula</b>; para enviarlo a ML hay que marcar «Publicación REAL» en el borrador.
            </p>
        </div>
    </div>

    <div class="ml-status-strip">
        <span class="ml-status-chip ml-status-chip--sim">
            <span class="material-symbols-outlined" aria-hidden="true">science</span>
            Por defecto los borradores se simulan: no llaman a Mercado Libre.
        </span>
        @if (permitirPublicacion)
        {
            <span class="ml-status-chip ml-status-chip--ok">
                <span class="material-symbols-outlined" aria-hidden="true">public</span>
                Publicación real disponible: marcá «Publicación REAL» en el borrador para enviar a ML.
            </span>
        }
        else
        {
            <span class="ml-status-chip ml-status-chip--warn">
                <span class="material-symbols-outlined" aria-hidden="true">lock</span>
                Publicación real bloqueada — habilitala en
                <a asp-action="Configuracion">Configuración</a>.
            </span>
        }
    </div>

    @if (User.TienePermiso("mercadolibre", "sync"))
    {
        <!-- Crear borrador desde producto -->
        <div class="card-erp-panel p-4 mb-6">
            <form asp-action="BorradorCrear" method="post" class="flex flex-wrap items-end gap-3" id="ml-borrador-form">
                @Html.AntiForgeryToken()
                <div class="grow max-w-md">
                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1" for="ml-borrador-picker">
                        Crear borrador desde producto ERP
                    </label>
                    <input type="text" list="ml-productos-datalist" id="ml-borrador-picker"
                           class="input-erp w-full" placeholder="Código o nombre del producto..."
                           aria-label="Buscar producto para publicar" />
                    <input type="hidden" name="productoId" id="ml-borrador-producto-id" value="" />
                </div>
                <button type="submit" class="btn-erp-primary btn-sm" id="ml-borrador-submit" disabled>
                    <span class="material-symbols-outlined text-sm">draft</span>
                    Crear borrador
                </button>
            </form>
            <datalist id="ml-productos-datalist"></datalist>
        </div>
    }

    @if (Model.Count == 0)
    {
        <div class="card-erp-panel p-8 text-center">
            <span class="material-symbols-outlined text-5xl text-slate-600 mb-3 block" aria-hidden="true">draft</span>
            <h2 class="text-lg font-bold text-white mb-2">No hay borradores</h2>
            <p class="text-sm text-slate-400">Elegí un producto del ERP para preparar su publicación.</p>
        </div>
    }
    else
    {
        <div class="card-erp-panel overflow-hidden">
            <div class="overflow-x-auto">
                <table class="erp-table w-full">
                    <thead>
                        <tr>
                            <th>Borrador</th>
                            <th>Producto</th>
                            <th class="text-right">Precio</th>
                            <th class="text-right">Stock</th>
                            <th>Categoria</th>
                            <th>Estado</th>
                            <th>Validado</th>
                            <th>Simulado</th>
                            <th>Creado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var borrador in Model)
                        {
                            <tr>
                                <td>
                                    <a asp-action="Borrador" asp-route-id="@borrador.Id"
                                       class="font-semibold text-white hover:text-amber-300 no-underline truncate block max-w-[280px]"
                                       title="@borrador.Titulo">@borrador.Titulo</a>
                                </td>
                                <td>
                                    <p class="text-sm text-white">@borrador.ProductoCodigo</p>
                                    <p class="text-xs text-slate-400 truncate max-w-[200px]" title="@borrador.ProductoNombre">@borrador.ProductoNombre</p>
                                </td>
                                <td class="text-right font-mono text-white">@borrador.Precio.ToString("N2")</td>
                                <td class="text-right font-mono text-white">@borrador.Stock</td>
                                <td class="font-mono text-xs text-slate-300">@(borrador.CategoryIdMl ?? "-")</td>
                                <td>
                                    @switch (borrador.Estado)
                                    {
                                        case MercadoLibreBorradorEstado.Borrador:
                                            <span class="inline-flex items-center rounded-full bg-slate-500/10 border border-slate-500/30 px-2 py-0.5 text-[11px] font-bold text-slate-300">borrador</span>
                                            break;
                                        case MercadoLibreBorradorEstado.Validado:
                                            <span class="inline-flex items-center rounded-full bg-sky-500/10 border border-sky-500/30 px-2 py-0.5 text-[11px] font-bold text-sky-400">validado</span>
                                            break;
                                        case MercadoLibreBorradorEstado.Publicado:
                                            <span class="inline-flex items-center rounded-full bg-emerald-500/10 border border-emerald-500/30 px-2 py-0.5 text-[11px] font-bold text-emerald-400">
                                                publicado @(borrador.PublicadoItemId is null ? "" : $"· {borrador.PublicadoItemId}")
                                            </span>
                                            break;
                                        default:
                                            <span class="text-xs text-slate-500">@borrador.Estado</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    @if (borrador.FueValidado)
                                    {
                                        <span class="text-xs text-sky-300">@borrador.FechaValidacionUtc?.ToLocalTime().ToString("dd/MM HH:mm")</span>
                                    }
                                    else
                                    {
                                        <span class="text-xs text-slate-500">pendiente</span>
                                    }
                                </td>
                                <td>
                                    @if (borrador.PublicadoEnSimulacion)
                                    {
                                        <span class="inline-flex items-center rounded-full bg-sky-500/10 border border-sky-500/30 px-2 py-0.5 text-[11px] font-bold text-sky-300">
                                            simulado @(borrador.FechaSimulacionUtc?.ToLocalTime().ToString("dd/MM HH:mm"))
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-xs text-slate-500">no</span>
                                    }
                                </td>
                                <td class="text-xs text-slate-400">@borrador.CreatedAt.ToLocalTime().ToString("dd/MM/yy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        (function () {
            'use strict';

            var productos = @Html.Raw(productosJson);
            var datalist = document.getElementById('ml-productos-datalist');
            var picker = document.getElementById('ml-borrador-picker');
            var hidden = document.getElementById('ml-borrador-producto-id');
            var submit = document.getElementById('ml-borrador-submit');

            if (!datalist || !picker) return;

            productos.forEach(function (p) {
                var option = document.createElement('option');
                option.value = p.codigo + ' - ' + p.nombre;
                datalist.appendChild(option);
            });

            picker.addEventListener('input', function () {
                var match = productos.find(function (p) {
                    return (p.codigo + ' - ' + p.nombre) === picker.value;
                });

                hidden.value = match ? match.id : '';
                submit.disabled = !match;
            });
        })();
    </script>
}
