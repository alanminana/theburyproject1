@using TheBuryProject.Modules.MercadoLibre.Entities
@model MercadoLibreConfiguracionViewModel
@{
    ViewData["Title"] = "Configuración Mercado Libre";
    ViewData["MetaDescription"] = "Configuración operativa del canal Mercado Libre: precios, stock, órdenes y caja.";
    var clientes = ViewBag.Clientes as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new();
}

<div class="erp-page-shell">

    @if (TempData["Success"] != null)
    {
        <div class="alert-erp alert-erp-success toast-msg" role="status">
            <span class="material-symbols-outlined">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-erp alert-erp-error toast-msg" role="alert">
            <span class="material-symbols-outlined">error</span>
            @TempData["Error"]
        </div>
    }

    <partial name="_MercadoLibreNav" />

    <nav class="ml-crumb" aria-label="Ruta">
        <span>Mercado Libre</span>
        <span class="ml-crumb__sep" aria-hidden="true">/</span>
        <span class="ml-crumb__current">Configuración</span>
    </nav>

    <!-- Header -->
    <div class="ml-head">
        <div class="ml-head__main">
            <h1 class="ml-head__title">
                <span class="material-symbols-outlined" aria-hidden="true">settings</span>
                Configuración Mercado Libre
            </h1>
            <p class="ml-head__subtitle">
                Conexión, reglas de publicación, sincronización y operación automática.
            </p>
        </div>
    </div>

    <!-- Estado de seguridad: publicación real -->
    <div class="ml-publish-mode-card @(Model.PermitirPublicacionDesdeErp ? "is-on" : "is-off")"
         data-ml-publish-card role="status">
        <span class="ml-publish-mode-card__icon material-symbols-outlined" aria-hidden="true"
              data-ml-publish-icon>@(Model.PermitirPublicacionDesdeErp ? "public" : "lock")</span>
        <div class="ml-publish-mode-card__body">
            <p class="ml-publish-mode-card__title">
                Publicación real:
                <span data-ml-publish-state>@(Model.PermitirPublicacionDesdeErp ? "Permitida" : "Bloqueada")</span>
            </p>
            <p class="ml-publish-mode-card__desc">
                Aunque esté permitida, cada borrador requiere marcar <b>Publicación REAL</b> antes de
                enviarse a Mercado Libre. Sin ese check, el borrador solo se simula.
            </p>
        </div>
    </div>

    <form asp-action="Configuracion" method="post">
        @Html.AntiForgeryToken()

        <div class="mlc-card" data-mlc-tabs>

            <p class="mlc-card__eyebrow">Secciones de configuración</p>

            <!-- Pestañas (navegación secundaria, dentro de la card) -->
            <div class="mlc-tabs ml-tabs-secondary" role="tablist" aria-label="Secciones de configuración">
                <button type="button" class="mlc-tab is-active" role="tab"
                        id="mlc-tab-cuenta" data-mlc-tab="cuenta"
                        aria-selected="true" aria-controls="mlc-panel-cuenta">
                    <span class="material-symbols-outlined" aria-hidden="true">account_circle</span>
                    Cuenta
                </button>
                <button type="button" class="mlc-tab" role="tab" tabindex="-1"
                        id="mlc-tab-precios" data-mlc-tab="precios"
                        aria-selected="false" aria-controls="mlc-panel-precios">
                    <span class="material-symbols-outlined" aria-hidden="true">sell</span>
                    Precios y stock
                </button>
                <button type="button" class="mlc-tab" role="tab" tabindex="-1"
                        id="mlc-tab-auto" data-mlc-tab="auto"
                        aria-selected="false" aria-controls="mlc-panel-auto">
                    <span class="material-symbols-outlined" aria-hidden="true">smart_toy</span>
                    Automatización
                </button>
            </div>

            <!-- Panel: Cuenta y referencias -->
            <section class="mlc-panel is-active" role="tabpanel"
                     id="mlc-panel-cuenta" data-mlc-panel="cuenta" aria-labelledby="mlc-tab-cuenta">
                <p class="mlc-panel__sub">Cuenta, lista de precios y cliente interno usados para sincronizar y crear ventas.</p>

                <div class="mlc-grid">
                    <div class="mlc-field">
                        <label asp-for="AccountId" class="mlc-label">Cuenta Mercado Libre</label>
                        <select asp-for="AccountId" class="select-erp select-erp-sm">
                            <option value="">— Sin cuenta —</option>
                            @foreach (var (id, nombre) in Model.CuentasDisponibles)
                            {
                                <option value="@id" selected="@(Model.AccountId == id ? "selected" : null)">@nombre</option>
                            }
                        </select>
                        <p class="mlc-hint">Cuenta usada para sincronizar y procesar órdenes.</p>
                    </div>

                    <div class="mlc-field">
                        <label asp-for="ListaPrecioId" class="mlc-label">Lista de precios para ML</label>
                        <select asp-for="ListaPrecioId" class="select-erp select-erp-sm">
                            <option value="">— Precio base del producto —</option>
                            @foreach (var (id, nombre) in Model.ListasPreciosDisponibles)
                            {
                                <option value="@id" selected="@(Model.ListaPrecioId == id ? "selected" : null)">@nombre</option>
                            }
                        </select>
                        <p class="mlc-hint">El precio ML parte de esta lista; sin lista usa el precio de venta base.</p>
                    </div>

                    <div class="mlc-field">
                        <label asp-for="SucursalId" class="mlc-label">Sucursal / depósito de referencia</label>
                        <select asp-for="SucursalId" class="select-erp select-erp-sm">
                            <option value="">— Sin sucursal —</option>
                            @foreach (var (id, nombre) in Model.SucursalesDisponibles)
                            {
                                <option value="@id" selected="@(Model.SucursalId == id ? "selected" : null)">@nombre</option>
                            }
                        </select>
                        <p class="mlc-hint">Informativo: el stock del ERP es global, sin stock por depósito.</p>
                    </div>

                    <div class="mlc-field mlc-field--full">
                        <label asp-for="ClienteMercadoLibreId" class="mlc-label">Cliente interno para ventas ML</label>
                        <select asp-for="ClienteMercadoLibreId" class="select-erp select-erp-sm" asp-items="clientes">
                            <option value="">— Seleccionar cliente —</option>
                        </select>
                        <p class="mlc-hint">
                            Las ventas creadas desde órdenes ML se imputan a este cliente
                            (ej: un cliente "Mercado Libre" genérico). Obligatorio para crear ventas.
                        </p>
                    </div>
                </div>
            </section>

            <!-- Panel: Precio del canal + stock -->
            <section class="mlc-panel" role="tabpanel"
                     id="mlc-panel-precios" data-mlc-panel="precios" aria-labelledby="mlc-tab-precios">
                <p class="mlc-panel__sub">Cómo se calcula el precio publicado y de dónde sale el stock que empuja el sync.</p>

                <div class="mlc-grid">
                    <div class="mlc-field">
                        <label asp-for="AjusteCanalPorcentaje" class="mlc-label">Ajuste de canal (%)</label>
                        <input asp-for="AjusteCanalPorcentaje" type="number" step="0.01" class="input-erp input-erp-sm" />
                        <span asp-validation-for="AjusteCanalPorcentaje" class="mlc-error"></span>
                        <p class="mlc-hint">Se suma al precio ERP (ej: 10 = +10% para absorber comisión).</p>
                    </div>
                    <div class="mlc-field">
                        <label asp-for="ComisionEstimadaPorcentaje" class="mlc-label">Comisión ML estimada (%)</label>
                        <input asp-for="ComisionEstimadaPorcentaje" type="number" step="0.01" class="input-erp input-erp-sm" />
                        <span asp-validation-for="ComisionEstimadaPorcentaje" class="mlc-error"></span>
                        <p class="mlc-hint">Usada en neto estimado y calculadora cuando no se consulta la API.</p>
                    </div>
                    <div class="mlc-field">
                        <label asp-for="CostoEnvioEstimado" class="mlc-label">Costo de envío estimado ($)</label>
                        <input asp-for="CostoEnvioEstimado" type="number" step="0.01" class="input-erp input-erp-sm" />
                        <span asp-validation-for="CostoEnvioEstimado" class="mlc-error"></span>
                    </div>
                    <div class="mlc-field">
                        <label asp-for="MargenMinimoPorcentaje" class="mlc-label">Margen mínimo (%)</label>
                        <input asp-for="MargenMinimoPorcentaje" type="number" step="0.01" class="input-erp input-erp-sm" />
                        <span asp-validation-for="MargenMinimoPorcentaje" class="mlc-error"></span>
                        <p class="mlc-hint">Los push de precio advierten si quedan por debajo. Vacío = sin control.</p>
                    </div>
                    <div class="mlc-field">
                        <label asp-for="ReglaRedondeo" class="mlc-label">Regla de redondeo</label>
                        <select asp-for="ReglaRedondeo" class="select-erp select-erp-sm">
                            <option value="ninguno">Sin redondeo</option>
                            <option value="decena">A la decena ($1.234 → $1.230)</option>
                            <option value="centena">A la centena ($1.234 → $1.200)</option>
                            <option value="mil">Al mil ($1.234 → $1.000)</option>
                        </select>
                    </div>

                    <div class="mlc-field mlc-field--full">
                        <label asp-for="OrigenStock" class="mlc-label">Origen del stock publicado</label>
                        <select asp-for="OrigenStock" class="select-erp select-erp-sm">
                            <option value="@MercadoLibreOrigenStock.StockLogicoProducto">Stock lógico del producto (StockActual)</option>
                            <option value="@MercadoLibreOrigenStock.StockFisicoDisponible">Stock físico (unidades EnStock registradas)</option>
                            <option value="" disabled>Unidad física específica — solo por publicación</option>
                            <option value="" disabled>Depósito/sucursal — no disponible (el ERP no maneja stock por sucursal)</option>
                        </select>
                        <p class="mlc-hint">
                            Define cuánto stock empuja el sync a ML y cómo se asignan unidades físicas en las ventas ML.
                            Cada publicación puede sobreescribirlo en su detalle.
                        </p>
                    </div>

                    <div class="mlc-field mlc-field--full">
                        <label asp-for="PoliticaDevolucion" class="mlc-label">Política ante devoluciones</label>
                        <select asp-for="PoliticaDevolucion" class="select-erp select-erp-sm">
                            <option value="@MercadoLibrePoliticaDevolucion.PendienteRevision">Pendiente de revisión (recomendado)</option>
                            <option value="@MercadoLibrePoliticaDevolucion.SugerirReingreso">Sugerir reingreso de stock</option>
                            <option value="@MercadoLibrePoliticaDevolucion.SugerirNoReingreso">Sugerir no reingresar</option>
                        </select>
                        <p class="mlc-hint">El stock nunca se reingresa sin decisión manual.</p>
                    </div>
                </div>
            </section>

            <!-- Panel: Publicación + Automatización -->
            <section class="mlc-panel" role="tabpanel"
                     id="mlc-panel-auto" data-mlc-panel="auto" aria-labelledby="mlc-tab-auto">
                <p class="mlc-panel__sub">Permiso maestro de publicación y qué pasos hace el sistema solo al recibir órdenes y cambios.</p>

                <p class="mlc-section-title">Publicación</p>
                <div class="mlc-toggles">
                    <label class="mlc-toggle mlc-toggle--master">
                        <input asp-for="PermitirPublicacionDesdeErp" type="checkbox" data-ml-permitir />
                        <span class="mlc-toggle__body">
                            <span class="mlc-toggle__title">Permitir publicar desde el ERP</span>
                            <span class="mlc-toggle__desc">
                                Habilita la posibilidad de publicar real. Si está apagado, los borradores
                                solo se simulan. Aun habilitado, cada borrador exige marcar
                                «Publicación REAL» antes de enviarse a Mercado Libre.
                            </span>
                        </span>
                    </label>
                </div>

                <p class="mlc-section-title">Automatización</p>
                <div class="mlc-warning" role="note">
                    <span class="material-symbols-outlined" aria-hidden="true">warning</span>
                    <span>Estas acciones pueden afectar datos reales si están habilitadas. Revisalas antes de usar en producción.</span>
                </div>

                <div class="mlc-toggles">
                    <label class="mlc-toggle">
                        <input asp-for="ImportacionAutomaticaOrdenes" type="checkbox" />
                        <span class="mlc-toggle__body">
                            <span class="mlc-toggle__title">Importar órdenes automáticamente</span>
                            <span class="mlc-toggle__desc">Al recibir webhooks orders_v2 se importa la orden completa (sin crear venta).</span>
                        </span>
                    </label>

                    <label class="mlc-toggle">
                        <input asp-for="CrearVentaAutomatica" type="checkbox" />
                        <span class="mlc-toggle__body">
                            <span class="mlc-toggle__title">Crear venta interna automáticamente</span>
                            <span class="mlc-toggle__desc">
                                Con la orden paga y todos los ítems vinculados, crea la Venta y descuenta stock.
                                Requiere cliente ML configurado.
                            </span>
                        </span>
                    </label>

                    <label class="mlc-toggle">
                        <input asp-for="SyncAutomaticaStock" type="checkbox" />
                        <span class="mlc-toggle__body">
                            <span class="mlc-toggle__title">Sync stock ERP → ML</span>
                            <span class="mlc-toggle__desc">Empuja stock a ML cuando cambia en el ERP (publicaciones vinculadas).</span>
                        </span>
                    </label>

                    <label class="mlc-toggle">
                        <input asp-for="SyncAutomaticaPrecio" type="checkbox" />
                        <span class="mlc-toggle__body">
                            <span class="mlc-toggle__title">Sync precio ERP → ML</span>
                            <span class="mlc-toggle__desc">Empuja el precio de canal calculado cuando cambia el precio ERP.</span>
                        </span>
                    </label>
                </div>
            </section>
        </div>

        <div class="mlc-actions">
            <a asp-action="Index" class="btn-erp-secondary">Cancelar</a>
            <button type="submit" class="btn-erp-primary">
                <span class="material-symbols-outlined text-sm">save</span>
                Guardar configuración
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        (function () {
            var root = document.querySelector('[data-mlc-tabs]');
            if (!root) return;
            var tabs = Array.prototype.slice.call(root.querySelectorAll('.mlc-tab'));
            var panels = Array.prototype.slice.call(root.querySelectorAll('.mlc-panel'));

            function activate(id, focus) {
                tabs.forEach(function (t) {
                    var on = t.getAttribute('data-mlc-tab') === id;
                    t.classList.toggle('is-active', on);
                    t.setAttribute('aria-selected', on ? 'true' : 'false');
                    t.tabIndex = on ? 0 : -1;
                    if (on && focus) t.focus();
                });
                panels.forEach(function (p) {
                    p.classList.toggle('is-active', p.getAttribute('data-mlc-panel') === id);
                });
            }

            tabs.forEach(function (t) {
                t.addEventListener('click', function () { activate(t.getAttribute('data-mlc-tab')); });
            });

            root.querySelector('.mlc-tabs').addEventListener('keydown', function (e) {
                if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
                var i = tabs.findIndex(function (t) { return t.classList.contains('is-active'); });
                if (i < 0) return;
                var n = e.key === 'ArrowRight' ? (i + 1) % tabs.length : (i - 1 + tabs.length) % tabs.length;
                activate(tabs[n].getAttribute('data-mlc-tab'), true);
                e.preventDefault();
            });

            // Tras un postback con error de validación, abrir la pestaña que lo contiene.
            var invalid = root.querySelector('.input-validation-error, .field-validation-error');
            if (invalid) {
                var panel = invalid.closest('.mlc-panel');
                if (panel) activate(panel.getAttribute('data-mlc-panel'));
            }
        })();

        // La card de estado de seguridad refleja en vivo el permiso maestro.
        (function () {
            var toggle = document.querySelector('[data-ml-permitir]');
            var card = document.querySelector('[data-ml-publish-card]');
            if (!toggle || !card) return;
            var state = card.querySelector('[data-ml-publish-state]');
            var icon = card.querySelector('[data-ml-publish-icon]');
            function sync() {
                var on = toggle.checked;
                card.classList.toggle('is-on', on);
                card.classList.toggle('is-off', !on);
                if (state) state.textContent = on ? 'Permitida' : 'Bloqueada';
                if (icon) icon.textContent = on ? 'public' : 'lock';
            }
            toggle.addEventListener('change', sync);
            sync();
        })();
    </script>
}
