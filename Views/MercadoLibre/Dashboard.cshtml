@using TheBuryProject.Modules.MercadoLibre.ViewModels
@model MercadoLibreDashboardViewModel
@{
    ViewData["Title"] = "Mercado Libre · Panel operativo";

    string AlertClass(MercadoLibreAlertaSeveridad s) => s switch
    {
        MercadoLibreAlertaSeveridad.Critical => "critical",
        MercadoLibreAlertaSeveridad.Error => "error",
        MercadoLibreAlertaSeveridad.Warning => "warning",
        _ => "info"
    };
    string AlertIcon(MercadoLibreAlertaSeveridad s) => s switch
    {
        MercadoLibreAlertaSeveridad.Critical => "gpp_maybe",
        MercadoLibreAlertaSeveridad.Error => "error",
        MercadoLibreAlertaSeveridad.Warning => "warning",
        _ => "info"
    };
    string Accent(int n, string when) => n > 0 ? when : "muted";
}

@section Styles {
    <link rel="stylesheet" href="~/css/mercadolibre-dashboard.css" asp-append-version="true" />
}

<div class="erp-page-shell erp-page-shell-xl erp-compact ml-dash">

    @if (TempData["Success"] != null)
    {
        <div class="alert-erp alert-erp-success toast-msg" role="status">
            <span class="material-symbols-outlined">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-erp alert-erp-error toast-msg" role="alert">
            <span class="material-symbols-outlined">error</span>
            @TempData["Error"]
        </div>
    }

    <partial name="_MercadoLibreNav" />

    <!-- Header -->
    <div class="ml-head">
        <div class="ml-head__main">
            <h1 class="ml-head__title">
                <span class="material-symbols-outlined" aria-hidden="true">storefront</span>
                Panel operativo
            </h1>
            <p class="ml-head__subtitle">
                Centro de operación del canal. Datos locales del ERP ·
                generado @Model.GeneradoUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
            </p>
        </div>
    </div>

    <!-- Estado conexión + simulación -->
    <div class="card-erp-panel p-4 mb-5">
        <div class="ml-dash-status">
            <div class="ml-dash-status__item">
                <span class="ml-dash-status__label">Cuenta</span>
                <span class="ml-dash-status__value">
                    @if (Model.Conexion.CuentaConectada)
                    {
                        <span class="ml-dash-badge ml-dash-badge--ok">
                            <span class="material-symbols-outlined text-[14px]">check_circle</span>
                            @Model.Conexion.Nickname
                        </span>
                    }
                    else
                    {
                        <span class="ml-dash-badge ml-dash-badge--off">Sin cuenta conectada</span>
                    }
                </span>
            </div>
            @if (Model.Conexion.CuentaConectada)
            {
                <div class="ml-dash-status__item">
                    <span class="ml-dash-status__label">User ID · Site</span>
                    <span class="ml-dash-status__value font-mono">@Model.Conexion.MeliUserId · @Model.Conexion.SiteId</span>
                </div>
            }
            <div class="ml-dash-status__item">
                <span class="ml-dash-status__label">Modo</span>
                <span class="ml-dash-status__value">
                    @if (Model.Conexion.ModoSimulacion)
                    {
                        <span class="ml-dash-badge ml-dash-badge--sim">
                            <span class="material-symbols-outlined text-[14px]">science</span>
                            Simulación
                        </span>
                    }
                    else
                    {
                        <span class="ml-dash-badge ml-dash-badge--real">
                            <span class="material-symbols-outlined text-[14px]">bolt</span>
                            Real
                        </span>
                    }
                </span>
            </div>
            <div class="ml-dash-status__item">
                <span class="ml-dash-status__label">Última importación</span>
                <span class="ml-dash-status__value">
                    @(Model.Conexion.UltimaImportacionUtc?.ToLocalTime().ToString("dd/MM HH:mm") ?? "—")
                </span>
            </div>
            <div class="ml-dash-status__item">
                <span class="ml-dash-status__label">Último sync</span>
                <span class="ml-dash-status__value">
                    @(Model.Conexion.UltimoSyncUtc?.ToLocalTime().ToString("dd/MM HH:mm") ?? "—")
                </span>
            </div>
            <div class="ml-dash-status__item">
                <span class="ml-dash-status__label">Último error API/sync</span>
                <span class="ml-dash-status__value">
                    @if (Model.Conexion.UltimoErrorUtc.HasValue)
                    {
                        <span class="text-rose-300" title="@Model.Conexion.UltimoErrorDetalle">
                            @Model.Conexion.UltimoErrorUtc.Value.ToLocalTime().ToString("dd/MM HH:mm")
                        </span>
                    }
                    else
                    {
                        <span class="text-emerald-300">sin errores</span>
                    }
                </span>
            </div>
        </div>
    </div>

    <!-- Nivel 2 · Bandeja de trabajo: sólo lo que requiere acción -->
    <div class="mb-5">
        <h2 class="text-sm font-bold text-white mb-2 flex items-center gap-2">
            <span class="material-symbols-outlined text-amber-400 text-lg">notifications_active</span>
            Bandeja de trabajo
            @if (Model.TieneAlertas)
            {
                <span class="ml-dash-alert__count">@Model.Alertas.Count</span>
            }
        </h2>
        @if (Model.TieneAlertas)
        {
            <div class="ml-dash-alerts">
                @foreach (var a in Model.Alertas)
                {
                    <div class="ml-dash-alert ml-dash-alert--@AlertClass(a.Severidad)">
                        <div class="ml-dash-alert__head">
                            <span class="ml-dash-alert__title">
                                <span class="material-symbols-outlined text-[16px]">@AlertIcon(a.Severidad)</span>
                                @a.Titulo
                            </span>
                            @if (a.Contador > 0)
                            {
                                <span class="ml-dash-alert__count">@a.Contador</span>
                            }
                        </div>
                        <p class="ml-dash-alert__desc">@a.Descripcion</p>
                        @if (!string.IsNullOrEmpty(a.LinkAccion))
                        {
                            <a class="ml-dash-alert__link" asp-action="@a.LinkAccion" asp-route-filtro="@a.LinkFiltro">
                                @a.LinkTexto →
                            </a>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="ml-inbox__empty">
                <span class="material-symbols-outlined">task_alt</span>
                Todo al día · no hay pendientes que requieran acción.
            </div>
        }
    </div>

    <!-- Nivel 3 · Resumen por áreas (máx 3 números por card) -->
    @{
        var atTotal = Model.Preguntas.Total + Model.Mensajes.Total;
        var atPend = Model.Preguntas.Pendientes + Model.Mensajes.RecibidosPendientes;
        var atError = Model.Preguntas.ConError + Model.Mensajes.ConError;
    }
    <div class="ml-cards mb-2">

        <a class="ml-card" asp-action="Listings">
            <span class="ml-card__head"><span class="material-symbols-outlined">inventory_2</span> Publicaciones</span>
            <div class="ml-card__nums">
                <div class="ml-card__num"><div class="ml-card__num-value">@Model.Publicaciones.Total</div><div class="ml-card__num-label">Total</div></div>
                <div class="ml-card__num"><div class="ml-card__num-value ml-card__num-value--good">@Model.Publicaciones.Activas</div><div class="ml-card__num-label">Activas</div></div>
                <div class="ml-card__num"><div class="ml-card__num-value ml-card__num-value--@Accent(Model.Publicaciones.SinVincular, "warn")">@Model.Publicaciones.SinVincular</div><div class="ml-card__num-label">Sin vincular</div></div>
            </div>
        </a>

        <a class="ml-card" asp-action="Ordenes">
            <span class="ml-card__head"><span class="material-symbols-outlined">receipt_long</span> Órdenes</span>
            <div class="ml-card__nums">
                <div class="ml-card__num"><div class="ml-card__num-value">@Model.Ordenes.Total</div><div class="ml-card__num-label">Total</div></div>
                <div class="ml-card__num"><div class="ml-card__num-value ml-card__num-value--@Accent(Model.Ordenes.Pendientes, "warn")">@Model.Ordenes.Pendientes</div><div class="ml-card__num-label">Pendientes</div></div>
                <div class="ml-card__num"><div class="ml-card__num-value ml-card__num-value--@Accent(Model.Ordenes.ConError, "bad")">@Model.Ordenes.ConError</div><div class="ml-card__num-label">Con error</div></div>
            </div>
        </a>

        <a class="ml-card" asp-action="Preguntas">
            <span class="ml-card__head"><span class="material-symbols-outlined">forum</span> Atención</span>
            <div class="ml-card__nums">
                <div class="ml-card__num"><div class="ml-card__num-value">@atTotal</div><div class="ml-card__num-label">Total</div></div>
                <div class="ml-card__num"><div class="ml-card__num-value ml-card__num-value--@Accent(atPend, "warn")">@atPend</div><div class="ml-card__num-label">Sin responder</div></div>
                <div class="ml-card__num"><div class="ml-card__num-value ml-card__num-value--@Accent(atError, "bad")">@atError</div><div class="ml-card__num-label">Con error</div></div>
            </div>
        </a>

        <a class="ml-card" asp-action="Listings" asp-route-filtro="vinculadas">
            <span class="ml-card__head"><span class="material-symbols-outlined">compare_arrows</span> Stock / precio</span>
            <div class="ml-card__nums">
                <div class="ml-card__num"><div class="ml-card__num-value">@Model.StockPrecio.PublicacionesVinculadas</div><div class="ml-card__num-label">Vinculadas</div></div>
                <div class="ml-card__num"><div class="ml-card__num-value ml-card__num-value--@Accent(Model.StockPrecio.ConDiferenciaStock, "warn")">@Model.StockPrecio.ConDiferenciaStock</div><div class="ml-card__num-label">Dif. stock</div></div>
                <div class="ml-card__num"><div class="ml-card__num-value ml-card__num-value--@Accent(Model.StockPrecio.UltimosSyncFallidos, "bad")">@Model.StockPrecio.UltimosSyncFallidos</div><div class="ml-card__num-label">Sync error</div></div>
            </div>
        </a>

        <a class="ml-card" asp-action="Ordenes" asp-route-filtro="venta-creada">
            <span class="ml-card__head"><span class="material-symbols-outlined">account_balance_wallet</span> Liquidaciones</span>
            <div class="ml-card__nums">
                <div class="ml-card__num"><div class="ml-card__num-value ml-card__num-value--@Accent(Model.Liquidaciones.Pendientes, "warn")">@Model.Liquidaciones.Pendientes</div><div class="ml-card__num-label">Pendientes</div></div>
                <div class="ml-card__num"><div class="ml-card__num-value ml-card__num-value--good">@Model.Liquidaciones.Liquidadas</div><div class="ml-card__num-label">Liquidadas</div></div>
            </div>
        </a>

        <a class="ml-card" asp-action="Ordenes">
            <span class="ml-card__head"><span class="material-symbols-outlined">local_shipping</span> Envíos</span>
            <div class="ml-card__nums">
                <div class="ml-card__num"><div class="ml-card__num-value">@Model.Envios.Pendientes</div><div class="ml-card__num-label">Pendientes</div></div>
                <div class="ml-card__num"><div class="ml-card__num-value ml-card__num-value--@Accent(Model.Envios.Demorados, "warn")">@Model.Envios.Demorados</div><div class="ml-card__num-label">Demorados</div></div>
                <div class="ml-card__num"><div class="ml-card__num-value ml-card__num-value--@Accent(Model.Envios.SinTracking, "warn")">@Model.Envios.SinTracking</div><div class="ml-card__num-label">Sin tracking</div></div>
            </div>
        </a>

        <a class="ml-card" asp-action="Ordenes" asp-route-filtro="devoluciones">
            <span class="ml-card__head"><span class="material-symbols-outlined">gavel</span> Reclamos</span>
            <div class="ml-card__nums">
                <div class="ml-card__num"><div class="ml-card__num-value ml-card__num-value--@Accent(Model.Reclamos.Abiertos, "warn")">@Model.Reclamos.Abiertos</div><div class="ml-card__num-label">Abiertos</div></div>
                <div class="ml-card__num"><div class="ml-card__num-value ml-card__num-value--@Accent(Model.Reclamos.PendientesRevision, "warn")">@Model.Reclamos.PendientesRevision</div><div class="ml-card__num-label">Pend. revisión</div></div>
                <div class="ml-card__num"><div class="ml-card__num-value ml-card__num-value--good">@Model.Reclamos.Resueltos</div><div class="ml-card__num-label">Resueltos</div></div>
            </div>
        </a>

    </div>

    <!-- Diagnóstico avanzado (colapsable): KPIs granulares + historiales -->
    <details class="ml-advanced">
        <summary>
            <span class="material-symbols-outlined">tune</span>
            Diagnóstico avanzado · KPIs detallados, webhooks, sync e historiales
            <span class="material-symbols-outlined ml-advanced__chevron">expand_more</span>
        </summary>
        <div class="ml-advanced__body">

    <!-- Secciones KPI -->
    <div class="ml-dash-sections mb-5">

        <!-- Publicaciones -->
        <section class="ml-dash-section">
            <div class="ml-dash-section__head">
                <h2 class="ml-dash-section__title">
                    <span class="material-symbols-outlined text-amber-400 text-lg">inventory_2</span>
                    Publicaciones
                </h2>
                <a class="ml-dash-section__link" asp-action="Listings">Ver todas →</a>
            </div>
            <div class="ml-dash-kpis">
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value">@Model.Publicaciones.Total</div><div class="ml-dash-kpi__label">Total</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--good">@Model.Publicaciones.Activas</div><div class="ml-dash-kpi__label">Activas</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value">@Model.Publicaciones.Pausadas</div><div class="ml-dash-kpi__label">Pausadas</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value">@Model.Publicaciones.Finalizadas</div><div class="ml-dash-kpi__label">Finalizadas</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value">@Model.Publicaciones.ConVariaciones</div><div class="ml-dash-kpi__label">Con variac.</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--@Accent(Model.Publicaciones.SinVincular, "warn")">@Model.Publicaciones.SinVincular</div><div class="ml-dash-kpi__label">Sin vincular</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--@Accent(Model.Publicaciones.SinStock, "warn")">@Model.Publicaciones.SinStock</div><div class="ml-dash-kpi__label">Sin stock</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--@Accent(Model.Publicaciones.ConError, "bad")">@Model.Publicaciones.ConError</div><div class="ml-dash-kpi__label">Con error</div></div>
            </div>
        </section>

        <!-- Stock y precio -->
        <section class="ml-dash-section">
            <div class="ml-dash-section__head">
                <h2 class="ml-dash-section__title">
                    <span class="material-symbols-outlined text-amber-400 text-lg">compare_arrows</span>
                    Stock y precio
                </h2>
                <a class="ml-dash-section__link" asp-action="Listings" asp-route-filtro="vinculadas">Vinculadas →</a>
            </div>
            <div class="ml-dash-kpis">
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value">@Model.StockPrecio.PublicacionesVinculadas</div><div class="ml-dash-kpi__label">Vinculadas</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--@Accent(Model.StockPrecio.ConDiferenciaStock, "warn")">@Model.StockPrecio.ConDiferenciaStock</div><div class="ml-dash-kpi__label">Dif. stock</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--@Accent(Model.StockPrecio.StockMlMayorErp, "bad")">@Model.StockPrecio.StockMlMayorErp</div><div class="ml-dash-kpi__label">ML &gt; ERP</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--@Accent(Model.StockPrecio.StockErpMayorMl, "warn")">@Model.StockPrecio.StockErpMayorMl</div><div class="ml-dash-kpi__label">ERP &gt; ML</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--@Accent(Model.StockPrecio.ConDiferenciaPrecio, "warn")">@Model.StockPrecio.ConDiferenciaPrecio</div><div class="ml-dash-kpi__label">Dif. precio</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--good">@Model.StockPrecio.UltimosSyncOk</div><div class="ml-dash-kpi__label">Sync OK</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--@Accent(Model.StockPrecio.UltimosSyncFallidos, "bad")">@Model.StockPrecio.UltimosSyncFallidos</div><div class="ml-dash-kpi__label">Sync error</div></div>
            </div>
        </section>

        <!-- Órdenes y ventas -->
        <section class="ml-dash-section">
            <div class="ml-dash-section__head">
                <h2 class="ml-dash-section__title">
                    <span class="material-symbols-outlined text-amber-400 text-lg">receipt_long</span>
                    Órdenes y ventas
                </h2>
                <a class="ml-dash-section__link" asp-action="Ordenes">Ver órdenes →</a>
            </div>
            <div class="ml-dash-kpis">
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value">@Model.Ordenes.Total</div><div class="ml-dash-kpi__label">Total</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value">@Model.Ordenes.Pendientes</div><div class="ml-dash-kpi__label">Pendientes</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--good">@Model.Ordenes.VentasCreadas</div><div class="ml-dash-kpi__label">Ventas</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--@Accent(Model.Ordenes.PendientesUnidad, "warn")">@Model.Ordenes.PendientesUnidad</div><div class="ml-dash-kpi__label">Pend. unidad</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--@Accent(Model.Ordenes.ConError, "bad")">@Model.Ordenes.ConError</div><div class="ml-dash-kpi__label">Con error</div></div>
            </div>
            <dl class="mt-1">
                <div class="ml-dash-line"><dt>Ventas 24h / 7d / 30d</dt><dd>@Model.Ordenes.Ventas24h / @Model.Ordenes.Ventas7d / @Model.Ordenes.Ventas30d</dd></div>
                <div class="ml-dash-line"><dt>Monto bruto vendido</dt><dd>@Model.Ordenes.MontoBrutoTotal.ToString("N2")</dd></div>
            </dl>
        </section>

        <!-- Liquidaciones -->
        <section class="ml-dash-section">
            <div class="ml-dash-section__head">
                <h2 class="ml-dash-section__title">
                    <span class="material-symbols-outlined text-amber-400 text-lg">account_balance_wallet</span>
                    Liquidaciones
                </h2>
                <a class="ml-dash-section__link" asp-action="Ordenes" asp-route-filtro="venta-creada">Pendientes →</a>
            </div>
            <div class="ml-dash-kpis">
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--@Accent(Model.Liquidaciones.Pendientes, "warn")">@Model.Liquidaciones.Pendientes</div><div class="ml-dash-kpi__label">Pendientes</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--good">@Model.Liquidaciones.Liquidadas</div><div class="ml-dash-kpi__label">Liquidadas</div></div>
            </div>
            <dl class="mt-1">
                <div class="ml-dash-line"><dt>Neto estimado pendiente</dt><dd>@Model.Liquidaciones.NetoEstimadoPendiente.ToString("N2")</dd></div>
                <div class="ml-dash-line"><dt>Neto real acreditado</dt><dd>@Model.Liquidaciones.NetoRealAcreditado.ToString("N2")</dd></div>
                <div class="ml-dash-line">
                    <dt>Diferencia est. vs real</dt>
                    <dd class="@(Model.Liquidaciones.DiferenciaEstimadoVsReal < 0 ? "is-bad" : "is-good")">@Model.Liquidaciones.DiferenciaEstimadoVsReal.ToString("N2")</dd>
                </div>
            </dl>
        </section>

        <!-- Envíos -->
        <section class="ml-dash-section">
            <div class="ml-dash-section__head">
                <h2 class="ml-dash-section__title">
                    <span class="material-symbols-outlined text-amber-400 text-lg">local_shipping</span>
                    Envíos
                </h2>
                <a class="ml-dash-section__link" asp-action="Ordenes">Ver envíos →</a>
            </div>
            <div class="ml-dash-kpis">
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value">@Model.Envios.Pendientes</div><div class="ml-dash-kpi__label">Pendientes</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value">@Model.Envios.ListosParaDespachar</div><div class="ml-dash-kpi__label">Listos</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value">@Model.Envios.EnCamino</div><div class="ml-dash-kpi__label">En camino</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--good">@Model.Envios.Entregados</div><div class="ml-dash-kpi__label">Entregados</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--@Accent(Model.Envios.Demorados, "warn")">@Model.Envios.Demorados</div><div class="ml-dash-kpi__label">Demorados</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value">@Model.Envios.Cancelados</div><div class="ml-dash-kpi__label">Cancelados</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value">@Model.Envios.ConTracking</div><div class="ml-dash-kpi__label">Con tracking</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--@Accent(Model.Envios.SinTracking, "warn")">@Model.Envios.SinTracking</div><div class="ml-dash-kpi__label">Sin tracking</div></div>
            </div>
        </section>

        <!-- Reclamos / devoluciones -->
        <section class="ml-dash-section">
            <div class="ml-dash-section__head">
                <h2 class="ml-dash-section__title">
                    <span class="material-symbols-outlined text-amber-400 text-lg">gavel</span>
                    Reclamos y devoluciones
                </h2>
                <a class="ml-dash-section__link" asp-action="Ordenes" asp-route-filtro="devoluciones">Ver casos →</a>
            </div>
            <div class="ml-dash-kpis">
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--@Accent(Model.Reclamos.Abiertos, "warn")">@Model.Reclamos.Abiertos</div><div class="ml-dash-kpi__label">Abiertos</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--@Accent(Model.Reclamos.PendientesRevision, "warn")">@Model.Reclamos.PendientesRevision</div><div class="ml-dash-kpi__label">Pend. revisión</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--good">@Model.Reclamos.Resueltos</div><div class="ml-dash-kpi__label">Resueltos</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value">@Model.Reclamos.ReingresosStock</div><div class="ml-dash-kpi__label">Reingresos</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value">@Model.Reclamos.Danados</div><div class="ml-dash-kpi__label">Dañados</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value">@Model.Reclamos.Mermas</div><div class="ml-dash-kpi__label">Mermas</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value">@Model.Reclamos.Garantias</div><div class="ml-dash-kpi__label">Garantías</div></div>
            </div>
        </section>

        <!-- Aumentos masivos -->
        <section class="ml-dash-section">
            <div class="ml-dash-section__head">
                <h2 class="ml-dash-section__title">
                    <span class="material-symbols-outlined text-amber-400 text-lg">trending_up</span>
                    Aumentos masivos
                </h2>
                <a class="ml-dash-section__link" asp-action="Aumentos">Ver lotes →</a>
            </div>
            <div class="ml-dash-kpis">
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value">@Model.Aumentos.Total</div><div class="ml-dash-kpi__label">Total</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value">@Model.Aumentos.Simulados</div><div class="ml-dash-kpi__label">Simulados</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--good">@Model.Aumentos.Aplicados</div><div class="ml-dash-kpi__label">Aplicados</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value">@Model.Aumentos.Revertidos</div><div class="ml-dash-kpi__label">Revertidos</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value">@Model.Aumentos.Cancelados</div><div class="ml-dash-kpi__label">Cancelados</div></div>
            </div>
        </section>

        <!-- Webhooks -->
        <section class="ml-dash-section">
            <div class="ml-dash-section__head">
                <h2 class="ml-dash-section__title">
                    <span class="material-symbols-outlined text-amber-400 text-lg">webhook</span>
                    Webhooks y background
                </h2>
            </div>
            <div class="ml-dash-kpis">
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value">@Model.Webhooks.Recibidos</div><div class="ml-dash-kpi__label">Recibidos</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--good">@Model.Webhooks.Procesados</div><div class="ml-dash-kpi__label">Procesados</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--@Accent(Model.Webhooks.Pendientes, "warn")">@Model.Webhooks.Pendientes</div><div class="ml-dash-kpi__label">Pendientes</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--@Accent(Model.Webhooks.ConError, "bad")">@Model.Webhooks.ConError</div><div class="ml-dash-kpi__label">Con error</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--@Accent(Model.Webhooks.ReintentosAgotados, "bad")">@Model.Webhooks.ReintentosAgotados</div><div class="ml-dash-kpi__label">Reint. agot.</div></div>
            </div>
            <dl class="mt-1">
                <div class="ml-dash-line"><dt>items / orders / shipments / claims / preg-msg</dt><dd>@Model.Webhooks.TopicItems / @Model.Webhooks.TopicOrders / @Model.Webhooks.TopicShipments / @Model.Webhooks.TopicClaims / @Model.Webhooks.TopicPreguntas</dd></div>
            </dl>
        </section>

        <!-- Preguntas preventa -->
        <section class="ml-dash-section">
            <div class="ml-dash-section__head">
                <h2 class="ml-dash-section__title">
                    <span class="material-symbols-outlined text-amber-400 text-lg">help</span>
                    Preguntas preventa
                </h2>
                <a class="ml-dash-section__link" asp-action="Preguntas">Ver preguntas →</a>
            </div>
            <div class="ml-dash-kpis">
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value">@Model.Preguntas.Total</div><div class="ml-dash-kpi__label">Total</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--@Accent(Model.Preguntas.Pendientes, "warn")">@Model.Preguntas.Pendientes</div><div class="ml-dash-kpi__label">Pendientes</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--good">@Model.Preguntas.Respondidas</div><div class="ml-dash-kpi__label">Respondidas</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--@Accent(Model.Preguntas.ConError, "bad")">@Model.Preguntas.ConError</div><div class="ml-dash-kpi__label">Con error</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value">@Model.Preguntas.Simuladas</div><div class="ml-dash-kpi__label">Simuladas</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--@Accent(Model.Preguntas.SinPublicacion, "warn")">@Model.Preguntas.SinPublicacion</div><div class="ml-dash-kpi__label">Sin public.</div></div>
            </div>
        </section>

        <!-- Mensajes postventa -->
        <section class="ml-dash-section">
            <div class="ml-dash-section__head">
                <h2 class="ml-dash-section__title">
                    <span class="material-symbols-outlined text-amber-400 text-lg">forum</span>
                    Mensajes postventa
                </h2>
                <a class="ml-dash-section__link" asp-action="Mensajes">Ver mensajes →</a>
            </div>
            <div class="ml-dash-kpis">
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value">@Model.Mensajes.Total</div><div class="ml-dash-kpi__label">Total</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--@Accent(Model.Mensajes.RecibidosPendientes, "warn")">@Model.Mensajes.RecibidosPendientes</div><div class="ml-dash-kpi__label">Sin responder</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--good">@Model.Mensajes.Enviados</div><div class="ml-dash-kpi__label">Enviados</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--@Accent(Model.Mensajes.ConError, "bad")">@Model.Mensajes.ConError</div><div class="ml-dash-kpi__label">Con error</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value">@Model.Mensajes.Simulados</div><div class="ml-dash-kpi__label">Simulados</div></div>
                <div class="ml-dash-kpi"><div class="ml-dash-kpi__value ml-dash-kpi__value--@Accent(Model.Mensajes.SinOrden, "warn")">@Model.Mensajes.SinOrden</div><div class="ml-dash-kpi__label">Sin orden</div></div>
            </div>
        </section>

    </div>

    <!-- Listas recientes -->
    <div class="ml-dash-recent">

        <!-- Últimas órdenes -->
        <section class="ml-dash-section">
            <div class="ml-dash-section__head">
                <h2 class="ml-dash-section__title">
                    <span class="material-symbols-outlined text-amber-400 text-lg">history</span>
                    Últimas órdenes
                </h2>
                <a class="ml-dash-section__link" asp-action="Ordenes">Ver todas →</a>
            </div>
            @if (Model.UltimasOrdenes.Count == 0)
            {
                <p class="text-sm text-slate-500">Sin órdenes registradas.</p>
            }
            else
            {
                <div class="ml-dash-table-wrap">
                    <table class="ml-dash-table">
                        <thead>
                            <tr>
                                <th>Orden ML</th>
                                <th>Estado</th>
                                <th>Envío</th>
                                <th class="is-num">Total</th>
                                <th>Fecha</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var o in Model.UltimasOrdenes)
                            {
                                <tr>
                                    <td>
                                        <a asp-action="Orden" asp-route-id="@o.Id" class="font-mono text-slate-200 no-underline hover:text-amber-300">@o.MeliOrderId</a>
                                    </td>
                                    <td><span class="ml-dash-pill @(o.TieneVenta ? "ml-dash-pill--good" : "")">@o.EstadoInterno</span></td>
                                    <td>@o.EstadoEnvio</td>
                                    <td class="is-num">@o.TotalAmount.ToString("N0")</td>
                                    <td>@o.FechaCreacionUtc.ToLocalTime().ToString("dd/MM HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <!-- Últimos aumentos -->
        <section class="ml-dash-section">
            <div class="ml-dash-section__head">
                <h2 class="ml-dash-section__title">
                    <span class="material-symbols-outlined text-amber-400 text-lg">trending_up</span>
                    Últimos aumentos
                </h2>
                <a class="ml-dash-section__link" asp-action="Aumentos">Ver lotes →</a>
            </div>
            @if (Model.UltimosAumentos.Count == 0)
            {
                <p class="text-sm text-slate-500">Sin lotes registrados.</p>
            }
            else
            {
                <div class="ml-dash-table-wrap">
                    <table class="ml-dash-table">
                        <thead>
                            <tr>
                                <th>Lote</th>
                                <th>Estado</th>
                                <th class="is-num">Pubs.</th>
                                <th>Fecha</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var b in Model.UltimosAumentos)
                            {
                                <tr>
                                    <td>
                                        <a asp-action="Aumento" asp-route-id="@b.Id" class="text-slate-200 no-underline hover:text-amber-300">@b.Nombre</a>
                                        @if (b.AplicadoEnSimulacion)
                                        {
                                            <span class="ml-dash-pill ml-dash-pill--warn">sim</span>
                                        }
                                    </td>
                                    <td>@b.Estado</td>
                                    <td class="is-num">@b.CantidadPublicaciones</td>
                                    <td>@b.FechaSolicitud.ToLocalTime().ToString("dd/MM HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <!-- Últimos webhooks -->
        <section class="ml-dash-section">
            <div class="ml-dash-section__head">
                <h2 class="ml-dash-section__title">
                    <span class="material-symbols-outlined text-amber-400 text-lg">webhook</span>
                    Últimos webhooks
                </h2>
            </div>
            @if (Model.UltimosWebhooks.Count == 0)
            {
                <p class="text-sm text-slate-500">Sin eventos recibidos.</p>
            }
            else
            {
                <div class="ml-dash-table-wrap">
                    <table class="ml-dash-table">
                        <thead>
                            <tr>
                                <th>Topic</th>
                                <th>Estado</th>
                                <th class="is-num">Intentos</th>
                                <th>Recibido</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var w in Model.UltimosWebhooks)
                            {
                                <tr>
                                    <td class="font-mono">@w.Topic</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(w.Error))
                                        {
                                            <span class="ml-dash-pill ml-dash-pill--bad" title="@w.Error">error</span>
                                        }
                                        else if (w.Procesado)
                                        {
                                            <span class="ml-dash-pill ml-dash-pill--good">procesado</span>
                                        }
                                        else
                                        {
                                            <span class="ml-dash-pill ml-dash-pill--warn">pendiente</span>
                                        }
                                    </td>
                                    <td class="is-num">@w.Intentos</td>
                                    <td>@w.RecibidoUtc.ToLocalTime().ToString("dd/MM HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <!-- Últimas sincronizaciones -->
        <section class="ml-dash-section">
            <div class="ml-dash-section__head">
                <h2 class="ml-dash-section__title">
                    <span class="material-symbols-outlined text-amber-400 text-lg">sync</span>
                    Últimas sincronizaciones
                </h2>
            </div>
            @if (Model.UltimosLogs.Count == 0)
            {
                <p class="text-sm text-slate-500">Sin actividad registrada.</p>
            }
            else
            {
                <div class="ml-dash-table-wrap">
                    <table class="ml-dash-table">
                        <thead>
                            <tr>
                                <th>Operación</th>
                                <th>Resultado</th>
                                <th>Fecha</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var l in Model.UltimosLogs)
                            {
                                <tr>
                                    <td title="@l.Detalle">@l.Operacion</td>
                                    <td>
                                        @if (l.Exito)
                                        {
                                            <span class="ml-dash-pill ml-dash-pill--good">ok</span>
                                        }
                                        else
                                        {
                                            <span class="ml-dash-pill ml-dash-pill--bad">error</span>
                                        }
                                    </td>
                                    <td>@l.Fecha.ToLocalTime().ToString("dd/MM HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

    </div>
        </div>
    </details>
</div>
