@model MercadoLibreConexionViewModel
@{
    ViewData["Title"] = "Mercado Libre";
    ViewData["MetaDescription"] = "Conexión y administración de la cuenta de Mercado Libre del ERP.";
}

<div class="erp-page-shell erp-compact">

    @if (TempData["Success"] != null)
    {
        <div class="alert-erp alert-erp-success toast-msg" role="status">
            <span class="material-symbols-outlined">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-erp alert-erp-error toast-msg" role="alert">
            <span class="material-symbols-outlined">error</span>
            @TempData["Error"]
        </div>
    }

    <partial name="_MercadoLibreNav" />

    <!-- Header: conexión / administración de cuenta -->
    <div class="ml-head">
        <div class="ml-head__main">
            <h1 class="ml-head__title">
                <span class="material-symbols-outlined" aria-hidden="true">link</span>
                Conexión Mercado Libre
            </h1>
            <p class="ml-head__subtitle">
                Conexión de cuenta, importación y administración de publicaciones existentes.
            </p>
        </div>
    </div>

    @if (!Model.ModuloConfigurado)
    {
        <div class="card-erp-panel p-6 mb-6 border border-amber-500/30">
            <div class="flex items-start gap-3">
                <span class="material-symbols-outlined text-amber-400 text-2xl" aria-hidden="true">warning</span>
                <div>
                    <h2 class="text-base font-bold text-white mb-1">Módulo sin configurar</h2>
                    <p class="text-sm text-slate-300">
                        Faltan credenciales. Configurar <code class="text-amber-300">MercadoLibre:ClientId</code>,
                        <code class="text-amber-300">MercadoLibre:ClientSecret</code> y
                        <code class="text-amber-300">MercadoLibre:RedirectUri</code> en UserSecrets o variables de entorno.
                    </p>
                    <p class="text-xs text-slate-400 mt-2">
                        La Redirect URI debe coincidir exactamente con la registrada en Mercado Libre Developers
                        (ej: <span class="font-mono">https://&lt;tu-ngrok&gt;.ngrok-free.app/MercadoLibre/OAuthCallback</span>).
                    </p>
                </div>
            </div>
        </div>
    }

    @if (!Model.HayCuentaConectada)
    {
        <div class="card-erp-panel p-8 text-center">
            <span class="material-symbols-outlined text-5xl text-slate-600 mb-3 block" aria-hidden="true">link_off</span>
            <h2 class="text-lg font-bold text-white mb-2">Sin cuenta conectada</h2>
            <p class="text-sm text-slate-400 mb-6">
                Conectá tu cuenta de vendedor para importar publicaciones, sincronizar stock y precios.
            </p>
            <form asp-action="Conectar" method="post" class="inline-block">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-erp-primary" disabled="@(Model.ModuloConfigurado ? null : "disabled")">
                    <span class="material-symbols-outlined text-sm">link</span>
                    Conectar Mercado Libre
                </button>
            </form>
        </div>
    }

    @foreach (var cuenta in Model.Cuentas.Where(c => c.Activa))
    {
        <div class="card-erp-panel p-6 mb-4">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                <div class="flex items-center gap-4">
                    <div class="flex items-center justify-center w-12 h-12 rounded-full bg-amber-500/15">
                        <span class="material-symbols-outlined text-amber-400" aria-hidden="true">person</span>
                    </div>
                    <div>
                        <h2 class="text-lg font-bold text-white">@cuenta.Nickname</h2>
                        <p class="text-xs text-slate-400 font-mono">
                            user_id @cuenta.MeliUserId · site @cuenta.SiteId
                        </p>
                    </div>
                    @if (cuenta.UltimaPruebaConexionOk == true)
                    {
                        <span class="inline-flex items-center gap-1 rounded-full bg-emerald-500/10 border border-emerald-500/30 px-3 py-1 text-[11px] font-bold text-emerald-400">
                            <span class="material-symbols-outlined text-[14px]">check_circle</span>
                            Conectada
                        </span>
                    }
                    else if (cuenta.UltimaPruebaConexionOk == false)
                    {
                        <span class="inline-flex items-center gap-1 rounded-full bg-rose-500/10 border border-rose-500/30 px-3 py-1 text-[11px] font-bold text-rose-400">
                            <span class="material-symbols-outlined text-[14px]">error</span>
                            Falló la última prueba
                        </span>
                    }
                </div>

                <div class="flex flex-wrap gap-2">
                    <form asp-action="ProbarConexion" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@cuenta.Id" />
                        <button type="submit" class="btn-erp-secondary btn-sm">
                            <span class="material-symbols-outlined text-sm">network_check</span>
                            Probar conexión
                        </button>
                    </form>
                    <form asp-controller="MercadoLibre" asp-action="ImportarListings" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="accountId" value="@cuenta.Id" />
                        <button type="submit" class="btn-erp-secondary btn-sm">
                            <span class="material-symbols-outlined text-sm">cloud_download</span>
                            Importar publicaciones
                        </button>
                    </form>
                    <form asp-action="Desconectar" method="post"
                          onsubmit="return confirm('¿Desconectar la cuenta @cuenta.Nickname? Se eliminarán los tokens guardados.');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@cuenta.Id" />
                        <button type="submit" class="btn-erp-ghost btn-sm text-rose-400">
                            <span class="material-symbols-outlined text-sm">link_off</span>
                            Desconectar
                        </button>
                    </form>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4 mt-5 sm:grid-cols-4">
                <div class="rounded-lg bg-slate-800/40 p-3">
                    <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Token expira</p>
                    <p class="text-sm font-semibold text-white mt-1">
                        @cuenta.AccessTokenExpiresAtUtc.ToLocalTime().ToString("dd/MM HH:mm")
                    </p>
                </div>
                <div class="rounded-lg bg-slate-800/40 p-3">
                    <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Última prueba</p>
                    <p class="text-sm font-semibold text-white mt-1">
                        @(cuenta.UltimaPruebaConexionUtc?.ToLocalTime().ToString("dd/MM HH:mm") ?? "—")
                    </p>
                </div>
                <div class="rounded-lg bg-slate-800/40 p-3">
                    <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Última importación</p>
                    <p class="text-sm font-semibold text-white mt-1">
                        @(cuenta.UltimaImportacionListingsUtc?.ToLocalTime().ToString("dd/MM HH:mm") ?? "—")
                    </p>
                </div>
                <div class="rounded-lg bg-slate-800/40 p-3">
                    <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Refresh automático</p>
                    <p class="text-sm font-semibold text-emerald-400 mt-1">Activo</p>
                </div>
            </div>
        </div>
    }
</div>
