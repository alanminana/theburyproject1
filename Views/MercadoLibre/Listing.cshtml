@using TheBuryProject.Modules.MercadoLibre.Entities
@model MercadoLibreListingDetalleViewModel
@{
    ViewData["Title"] = $"Publicación {Model.ItemId}";
    var productosJson = ViewBag.ProductosPickerJson as string ?? "[]";
}

<div class="erp-page-shell erp-compact">

    @if (TempData["Success"] != null)
    {
        <div class="alert-erp alert-erp-success toast-msg" role="status">
            <span class="material-symbols-outlined">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Info"] != null)
    {
        <div class="alert-erp border border-sky-500/30 bg-sky-500/10 text-sky-200 toast-msg" role="status">
            <span class="material-symbols-outlined">info</span>
            @TempData["Info"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-erp alert-erp-error toast-msg" role="alert">
            <span class="material-symbols-outlined">error</span>
            @TempData["Error"]
        </div>
    }

    <partial name="_MercadoLibreNav" />

    <nav class="text-sm text-slate-400 mb-3" aria-label="Ruta">
        <a asp-action="Listings" class="hover:text-amber-300">Publicaciones</a>
        <span class="mx-1 text-slate-600">/</span>
        <span class="text-slate-300 font-mono">@Model.ItemId</span>
    </nav>

    <!-- Header: detalle de publicación + acciones propias -->
    <div class="ml-head">
        <div class="ml-head__main min-w-0">
            <h1 class="text-xl font-black text-white truncate" title="@Model.Titulo">@Model.Titulo</h1>
            <p class="text-sm text-slate-400 mt-1 font-mono">
                @Model.ItemId · @Model.CategoryId · @Model.ListingTypeId · @Model.Condition
                @if (Model.EstaActiva)
                {
                    <span class="ml-2 inline-flex items-center rounded-full bg-emerald-500/10 border border-emerald-500/30 px-2 py-0.5 text-[11px] font-bold text-emerald-400">activa</span>
                }
                else if (Model.EstaPausada)
                {
                    <span class="ml-2 inline-flex items-center rounded-full bg-amber-500/10 border border-amber-500/30 px-2 py-0.5 text-[11px] font-bold text-amber-400">pausada</span>
                }
                else
                {
                    <span class="ml-2 inline-flex items-center rounded-full bg-slate-500/10 border border-slate-500/30 px-2 py-0.5 text-[11px] font-bold text-slate-400">@Model.Status</span>
                }
                @if (!string.IsNullOrEmpty(Model.SubStatus))
                {
                    <span class="text-amber-400 text-xs">(@Model.SubStatus)</span>
                }
            </p>
        </div>
        @if (!string.IsNullOrEmpty(Model.Permalink))
        {
            <div class="ml-actions">
                <a href="@Model.Permalink" target="_blank" rel="noopener noreferrer" class="btn-erp-secondary btn-sm">
                    <span class="material-symbols-outlined text-sm">open_in_new</span>
                    Ver en ML
                </a>
            </div>
        }
    </div>

    @if (Model.ModoSimulacion)
    {
        <div class="ml-sim-note" role="status">
            <span class="material-symbols-outlined" aria-hidden="true">science</span>
            <span><span class="font-bold">Modo simulación:</span> las acciones de esta página se registran pero no se envían a Mercado Libre.</span>
        </div>
    }

    <div class="grid grid-cols-1 gap-6 xl:grid-cols-2">

        <!-- Edición -->
        <div class="card-erp-panel p-6">
            <h2 class="text-base font-bold text-white mb-4 flex items-center gap-2">
                <span class="material-symbols-outlined text-amber-400 text-xl" aria-hidden="true">edit</span>
                Editar publicación
            </h2>

            <form asp-action="ListingEditar" method="post"
                  onsubmit="return confirm('¿Aplicar los cambios a la publicación?');">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />

                <div class="space-y-4">
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1" for="titulo">Título</label>
                        <input type="text" name="titulo" id="titulo" class="input-erp w-full" maxlength="300" value="@Model.Titulo" />
                        <p class="text-xs text-slate-500 mt-1">ML puede rechazar cambios de título en publicaciones con ventas.</p>
                    </div>

                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1" for="precio">Precio (@Model.CurrencyId)</label>
                            <input type="number" step="0.01" min="0.01" name="precio" id="precio" class="input-erp w-full" value="@Model.Precio.ToString("0.##")" />
                        </div>
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1" for="stock">Stock</label>
                            <input type="number" min="0" name="stock" id="stock" class="input-erp w-full" value="@Model.AvailableQuantity"
                                   disabled="@(Model.Variaciones.Count > 1 ? "disabled" : null)" />
                            @if (Model.Variaciones.Count > 1)
                            {
                                <p class="text-xs text-amber-400 mt-1">Varias variaciones: editar stock en ML.</p>
                            }
                        </div>
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1" for="sellerSku">SKU</label>
                            <input type="text" name="sellerSku" id="sellerSku" class="input-erp w-full" maxlength="100" value="@Model.SellerSku" />
                        </div>
                    </div>

                    <div class="flex items-center justify-between gap-3">
                        @if (!Model.ModoSimulacion)
                        {
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="checkbox" name="confirmarReal" value="true" />
                                <span class="text-sm text-white">Confirmo envío <span class="text-rose-400 font-bold">REAL</span></span>
                            </label>
                        }
                        else
                        {
                            <span class="text-xs text-sky-300">Se aplicará en simulación.</span>
                        }
                        <button type="submit" class="btn-erp-primary">
                            <span class="material-symbols-outlined text-sm">save</span>
                            Aplicar cambios
                        </button>
                    </div>
                </div>
            </form>

            <!-- Estado -->
            <h3 class="text-sm font-bold text-white mt-6 mb-3">Estado de la publicación</h3>
            <div class="flex flex-wrap gap-2">
                @if (!Model.EstaFinalizada)
                {
                    @if (Model.EstaActiva)
                    {
                        <form asp-action="ListingCambiarEstado" method="post"
                              onsubmit="return confirm('¿Pausar la publicación en Mercado Libre?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="accion" value="pausar" />
                            <input type="hidden" name="confirmarReal" value="true" />
                            <button type="submit" class="btn-erp-secondary btn-sm">
                                <span class="material-symbols-outlined text-sm">pause</span>
                                Pausar
                            </button>
                        </form>
                    }
                    @if (Model.EstaPausada)
                    {
                        <form asp-action="ListingCambiarEstado" method="post"
                              onsubmit="return confirm('¿Reactivar la publicación?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="accion" value="reactivar" />
                            <input type="hidden" name="confirmarReal" value="true" />
                            <button type="submit" class="btn-erp-secondary btn-sm">
                                <span class="material-symbols-outlined text-sm">play_arrow</span>
                                Reactivar
                            </button>
                        </form>
                    }
                    <form asp-action="ListingCambiarEstado" method="post"
                          onsubmit="return confirm('FINALIZAR es IRREVERSIBLE en Mercado Libre: la publicación no podrá reactivarse. ¿Continuar?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="accion" value="finalizar" />
                        <input type="hidden" name="confirmarReal" value="true" />
                        <button type="submit" class="btn-erp-ghost btn-sm text-rose-400">
                            <span class="material-symbols-outlined text-sm">stop_circle</span>
                            Finalizar (irreversible)
                        </button>
                    </form>
                }
                else
                {
                    <p class="text-sm text-slate-500">Publicación finalizada: Mercado Libre no permite reactivarla.</p>
                }
            </div>

            <!-- Descripción -->
            <h3 class="text-sm font-bold text-white mt-6 mb-3">Descripción</h3>
            @if (!Model.DescripcionConsultada)
            {
                <p class="text-xs text-amber-400 mb-2">No se pudo consultar la descripción actual en ML.</p>
            }
            <form asp-action="ListingEditarDescripcion" method="post"
                  onsubmit="return confirm('¿Reemplazar la descripción de la publicación?');">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <textarea name="descripcion" rows="6" class="input-erp w-full font-mono text-sm"
                          placeholder="Descripción en texto plano...">@Model.Descripcion</textarea>
                <div class="flex items-center justify-between gap-3 mt-2">
                    @if (!Model.ModoSimulacion)
                    {
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input type="checkbox" name="confirmarReal" value="true" />
                            <span class="text-sm text-white">Confirmo envío <span class="text-rose-400 font-bold">REAL</span></span>
                        </label>
                    }
                    else
                    {
                        <span class="text-xs text-sky-300">Se aplicará en simulación.</span>
                    }
                    <button type="submit" class="btn-erp-secondary btn-sm">
                        <span class="material-symbols-outlined text-sm">description</span>
                        Guardar descripción
                    </button>
                </div>
            </form>
        </div>

        <div class="space-y-6">

            <!-- Datos ML vs ERP -->
            <div class="card-erp-panel p-6">
                <h2 class="text-base font-bold text-white mb-4 flex items-center gap-2">
                    <span class="material-symbols-outlined text-amber-400 text-xl" aria-hidden="true">compare_arrows</span>
                    Mercado Libre vs ERP
                </h2>

                <div class="grid grid-cols-2 gap-3">
                    <div class="rounded-lg bg-slate-800/40 p-3">
                        <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Precio ML</p>
                        <p class="text-sm font-mono font-semibold text-white mt-1">@Model.Precio.ToString("N2")</p>
                    </div>
                    <div class="rounded-lg bg-slate-800/40 p-3">
                        <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Stock ML</p>
                        <p class="text-sm font-mono font-semibold text-white mt-1">@Model.AvailableQuantity (vendidos: @Model.SoldQuantity)</p>
                    </div>
                    @if (Model.Vinculada)
                    {
                        <div class="rounded-lg bg-slate-800/40 p-3">
                            <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Producto ERP</p>
                            <p class="text-sm font-semibold text-white mt-1">@Model.ProductoCodigo</p>
                            <p class="text-xs text-slate-400 truncate">@Model.ProductoNombre</p>
                        </div>
                        <div class="rounded-lg bg-slate-800/40 p-3">
                            <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Stock / precio ERP</p>
                            <p class="text-sm font-mono font-semibold text-white mt-1">
                                @Model.ProductoStockActual?.ToString("N0") · @Model.ProductoPrecioVenta?.ToString("N2")
                            </p>
                        </div>
                    }
                    else
                    {
                        <div class="rounded-lg bg-amber-500/10 border border-amber-500/30 p-3 col-span-2 space-y-2">
                            <p class="text-xs text-amber-300 font-semibold">Sin producto vinculado</p>
                            @if (User.TienePermiso("mercadolibre", "link"))
                            {
                                <form asp-action="Vincular" method="post" class="flex flex-wrap items-center gap-2 ml-listing-link-form" data-listing-id="@Model.Id">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="listingId" value="@Model.Id" />
                                    <input type="hidden" name="productoId" value="" class="ml-producto-id" />
                                    <input type="text" list="ml-productos-datalist"
                                           class="filter-input-erp ml-producto-picker w-48"
                                           placeholder="Código o nombre..."
                                           aria-label="Buscar producto para vincular" />
                                    <button type="submit" class="btn-erp-secondary btn-sm" disabled>
                                        <span class="material-symbols-outlined text-sm">link</span>
                                        Vincular
                                    </button>
                                    <a asp-action="ListingCrearProducto" asp-route-id="@Model.Id"
                                       class="btn-erp-ghost btn-sm"
                                       title="Crear un producto interno con los datos de esta publicación y vincularlo">
                                        <span class="material-symbols-outlined text-sm">add_box</span>
                                        Crear producto
                                    </a>
                                </form>
                            }
                            else
                            {
                                <p class="text-xs text-slate-400">Vincular desde <a asp-action="Listings" class="underline">Publicaciones</a>.</p>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Origen de stock (Checkpoint 4) -->
            @if (Model.Vinculada)
            {
                <div class="card-erp-panel p-6">
                    <h2 class="text-base font-bold text-white mb-4 flex items-center gap-2">
                        <span class="material-symbols-outlined text-amber-400 text-xl" aria-hidden="true">warehouse</span>
                        Origen del stock publicado
                    </h2>

                    <p class="text-sm text-slate-300 mb-1">
                        Origen efectivo: <span class="font-bold text-white">@Model.OrigenStockEfectivo</span>
                        @if (Model.OrigenStockOverride is null)
                        {
                            <span class="text-xs text-slate-500">(global)</span>
                        }
                        else
                        {
                            <span class="text-xs text-amber-300">(override de esta publicación)</span>
                        }
                    </p>
                    <p class="text-sm text-slate-300 mb-3">
                        Stock publicable según origen:
                        <span class="font-mono font-bold text-white">@(Model.StockDisponibleSegunOrigen?.ToString() ?? "—")</span>
                    </p>
                    @if (!string.IsNullOrEmpty(Model.AdvertenciaStock))
                    {
                        <p class="text-xs text-amber-400 mb-3 flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">warning</span>
                            @Model.AdvertenciaStock
                        </p>
                    }

                    @if (User.TienePermiso("mercadolibre", "sync"))
                    {
                        <form asp-action="ListingOrigenStock" method="post" class="space-y-2" id="ml-origen-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
                                <select name="origen" class="select-erp w-full" id="ml-origen-select" aria-label="Origen de stock">
                                    @{
                                        var sel = Model.OrigenStockOverride;
                                    }
                                    <option value="" selected="@(sel is null ? "selected" : null)">Usar origen global (@Model.OrigenStockGlobal)</option>
                                    <option value="@MercadoLibreOrigenStock.StockLogicoProducto" selected="@(sel == MercadoLibreOrigenStock.StockLogicoProducto ? "selected" : null)">Stock lógico del producto</option>
                                    <option value="@MercadoLibreOrigenStock.StockFisicoDisponible" selected="@(sel == MercadoLibreOrigenStock.StockFisicoDisponible ? "selected" : null)">Stock físico (unidades EnStock)</option>
                                    <option value="@MercadoLibreOrigenStock.UnidadFisicaEspecifica" selected="@(sel == MercadoLibreOrigenStock.UnidadFisicaEspecifica ? "selected" : null)">Unidad física específica (stock 1)</option>
                                    <option value="" disabled>Depósito/sucursal — no disponible (el ERP no maneja stock por sucursal)</option>
                                </select>
                                <select name="productoUnidadId" class="select-erp w-full" id="ml-origen-unidad" aria-label="Unidad física">
                                    <option value="">— unidad física —</option>
                                    @foreach (var unidad in Model.UnidadesDisponibles)
                                    {
                                        <option value="@unidad.Id" selected="@(Model.ProductoUnidadId == unidad.Id ? "selected" : null)">@unidad.Etiqueta</option>
                                    }
                                </select>
                            </div>
                            <button type="submit" class="btn-erp-secondary btn-sm">
                                <span class="material-symbols-outlined text-sm">save</span>
                                Guardar origen
                            </button>
                            <p class="text-[10px] text-slate-500">
                                El origen define cuánto stock empuja el sync y cómo se asignan unidades al crear ventas ML.
                                "Unidad específica" exige elegir la unidad.
                            </p>
                        </form>
                    }
                </div>
            }

            <!-- Calculadora (Fase G) -->
            @if (Model.Desglose is not null)
            {
                var d = Model.Desglose;
                <div class="card-erp-panel p-6 @(d.DebajoDelMargenMinimo ? "border border-rose-500/30" : null)">
                    <h2 class="text-base font-bold text-white mb-4 flex items-center gap-2">
                        <span class="material-symbols-outlined text-amber-400 text-xl" aria-hidden="true">calculate</span>
                        Calculadora precio canal
                    </h2>

                    <dl class="space-y-1 text-sm font-mono">
                        <div class="flex justify-between"><dt class="text-slate-400">Costo producto</dt><dd class="text-white">@d.Costo.ToString("N2")</dd></div>
                        <div class="flex justify-between"><dt class="text-slate-400">Precio ERP (lista canal)</dt><dd class="text-white">@d.PrecioErp.ToString("N2")</dd></div>
                        <div class="flex justify-between"><dt class="text-slate-400">Ajuste canal (@d.AjusteCanalPorcentaje.ToString("0.##")%) + redondeo</dt><dd class="text-emerald-400 font-bold">@d.PrecioCanal.ToString("N2")</dd></div>
                        <div class="flex justify-between"><dt class="text-slate-400">Comisión ML est. (@d.ComisionPorcentaje.ToString("0.##")%)</dt><dd class="text-rose-300">−@d.ComisionMonto.ToString("N2")</dd></div>
                        <div class="flex justify-between"><dt class="text-slate-400">Envío estimado</dt><dd class="text-rose-300">−@d.EnvioEstimado.ToString("N2")</dd></div>
                        <div class="flex justify-between border-t border-slate-700 pt-1 mt-1"><dt class="text-slate-300 font-bold">Neto estimado</dt><dd class="text-white font-bold">@d.NetoEstimado.ToString("N2")</dd></div>
                        <div class="flex justify-between"><dt class="text-slate-400">Ganancia est. (neto − costo)</dt>
                            <dd class="@(d.GananciaEstimada >= 0 ? "text-emerald-400" : "text-rose-400") font-bold">@d.GananciaEstimada.ToString("N2")</dd></div>
                        @if (d.RentabilidadPorcentaje.HasValue)
                        {
                            <div class="flex justify-between"><dt class="text-slate-400">Rentabilidad sobre costo</dt>
                                <dd class="@(d.RentabilidadPorcentaje >= 0 ? "text-emerald-400" : "text-rose-400")">@d.RentabilidadPorcentaje.Value.ToString("0.##")%</dd></div>
                        }
                    </dl>

                    @if (d.DebajoDelMargenMinimo)
                    {
                        <p class="text-xs text-rose-400 mt-3 flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">warning</span>
                            El margen queda por debajo del mínimo configurado.
                        </p>
                    }
                    <p class="text-[10px] text-slate-500 mt-3">
                        Valores estimados según configuración del canal. La comisión real la define Mercado Libre por categoría/tipo de publicación.
                    </p>
                </div>
            }

            <!-- Variaciones -->
            @if (Model.Variaciones.Count > 0)
            {
                <div class="card-erp-panel p-6">
                    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between mb-4">
                        <h2 class="text-base font-bold text-white flex items-center gap-2">
                            <span class="material-symbols-outlined text-amber-400 text-xl" aria-hidden="true">style</span>
                            Variaciones (@Model.Variaciones.Count)
                        </h2>
                        @if (User.TienePermiso("mercadolibre", "sync"))
                        {
                            <form asp-action="SyncPreview" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="listingIds" value="@Model.Id" />
                                <input type="hidden" name="tipo" value="StockYPrecio" />
                                <button type="submit" class="btn-erp-secondary btn-sm">
                                    <span class="material-symbols-outlined text-sm">sync</span>
                                    Preview por variación
                                </button>
                            </form>
                        }
                    </div>
                    <div class="overflow-x-auto">
                        <table class="erp-table w-full">
                            <thead>
                                <tr>
                                    <th>Variación</th>
                                    <th>Atributos</th>
                                    <th class="text-right">ML</th>
                                    <th>Producto</th>
                                    <th>Origen stock</th>
                                    <th class="text-right">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var variacion in Model.Variaciones)
                                {
                                    <tr>
                                        <td>
                                            <p class="font-mono text-xs text-white">@variacion.VariationId</p>
                                            <p class="font-mono text-[10px] text-slate-500">@(variacion.SellerSku ?? "SKU —")</p>
                                        </td>
                                        <td class="text-sm text-slate-300">@(variacion.Atributos ?? "—")</td>
                                        <td class="text-right font-mono text-white">
                                            <p>@variacion.Precio.ToString("N2")</p>
                                            <p class="text-xs text-slate-400">stock @variacion.AvailableQuantity</p>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(variacion.ProductoCodigo))
                                            {
                                                <p class="text-sm font-semibold text-white">@variacion.ProductoCodigo</p>
                                                <p class="text-xs text-slate-400 truncate max-w-[180px]">@variacion.ProductoNombre</p>
                                                @if (variacion.UsaProductoDePublicacion)
                                                {
                                                    <p class="text-[10px] text-sky-300">fallback de publicación</p>
                                                }
                                            }
                                            else
                                            {
                                                <p class="text-xs text-amber-400">Sin producto resoluble</p>
                                            }
                                        </td>
                                        <td>
                                            <p class="text-xs text-white">@variacion.OrigenStockEfectivo</p>
                                            <p class="text-[10px] text-slate-500">
                                                stock publicable: @(variacion.StockDisponibleSegunOrigen?.ToString() ?? "—")
                                            </p>
                                            @if (!string.IsNullOrEmpty(variacion.AdvertenciaStock))
                                            {
                                                <p class="text-[10px] @(variacion.RequiereVinculoParaStock ? "text-rose-400" : "text-amber-400")">@variacion.AdvertenciaStock</p>
                                            }
                                        </td>
                                        <td>
                                            @if (User.TienePermiso("mercadolibre", "sync"))
                                            {
                                                <form asp-action="ListingVariacionVinculo" method="post"
                                                      class="ml-variation-link-form flex flex-col gap-2 items-stretch"
                                                      data-variation-id="@variacion.VariationId">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@Model.Id" />
                                                    <input type="hidden" name="variationId" value="@variacion.VariationId" />
                                                    <input type="hidden" name="productoId" value="@(variacion.ProductoId?.ToString() ?? "")" class="ml-producto-id" />
                                                    <input type="text" list="ml-productos-datalist"
                                                           class="filter-input-erp ml-producto-picker w-56"
                                                           value="@(variacion.ProductoId.HasValue ? $"{variacion.ProductoCodigo} - {variacion.ProductoNombre}" : "")"
                                                           placeholder="Producto explícito o fallback"
                                                           aria-label="Producto para variación @variacion.VariationId" />
                                                    <select name="origen" class="select-erp w-56" aria-label="Origen de stock de variación @variacion.VariationId">
                                                        @{
                                                            var selVar = variacion.OrigenStockOverride;
                                                        }
                                                        <option value="" selected="@(selVar is null ? "selected" : null)">Usar origen efectivo de publicación</option>
                                                        <option value="@MercadoLibreOrigenStock.StockLogicoProducto" selected="@(selVar == MercadoLibreOrigenStock.StockLogicoProducto ? "selected" : null)">Stock lógico del producto</option>
                                                        <option value="@MercadoLibreOrigenStock.StockFisicoDisponible" selected="@(selVar == MercadoLibreOrigenStock.StockFisicoDisponible ? "selected" : null)">Stock físico disponible</option>
                                                        <option value="@MercadoLibreOrigenStock.UnidadFisicaEspecifica" selected="@(selVar == MercadoLibreOrigenStock.UnidadFisicaEspecifica ? "selected" : null)">Unidad física específica</option>
                                                        <option value="" disabled>Depósito/sucursal — no disponible</option>
                                                    </select>
                                                    <select name="productoUnidadId" class="select-erp w-56" aria-label="Unidad física de variación @variacion.VariationId">
                                                        <option value="">— unidad física —</option>
                                                        @foreach (var unidad in variacion.UnidadesDisponibles)
                                                        {
                                                            <option value="@unidad.Id" selected="@(variacion.ProductoUnidadId == unidad.Id ? "selected" : null)">@unidad.Etiqueta</option>
                                                        }
                                                    </select>
                                                    <button type="submit" class="btn-erp-secondary btn-sm justify-center">
                                                        <span class="material-symbols-outlined text-sm">save</span>
                                                        Guardar
                                                    </button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <!-- Log -->
            <div class="card-erp-panel p-6">
                <h2 class="text-base font-bold text-white mb-4 flex items-center gap-2">
                    <span class="material-symbols-outlined text-amber-400 text-xl" aria-hidden="true">history</span>
                    Últimas sincronizaciones
                </h2>
                @if (Model.UltimosLogs.Count == 0)
                {
                    <p class="text-sm text-slate-500">Sin actividad registrada.</p>
                }
                else
                {
                    <div class="space-y-2">
                        @foreach (var log in Model.UltimosLogs)
                        {
                            <div class="rounded-lg bg-slate-800/40 p-2 flex items-start gap-2">
                                <span class="material-symbols-outlined text-sm @(log.Exito ? "text-emerald-400" : "text-rose-400")">
                                    @(log.Exito ? "check_circle" : "error")
                                </span>
                                <div class="min-w-0">
                                    <p class="text-xs font-bold text-white">
                                        @log.Operacion
                                        <span class="text-slate-500 font-normal">· @log.Fecha.ToLocalTime().ToString("dd/MM HH:mm")</span>
                                    </p>
                                    <p class="text-xs text-slate-400 break-words">@log.Detalle</p>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    @{
        var preguntas = ViewBag.Preguntas as List<TheBuryProject.Modules.MercadoLibre.Entities.MercadoLibreQuestion> ?? new();
        var puedeSimularPregunta = ViewBag.PuedeSimularPregunta as bool? ?? false;
        var modoSimulacionPreguntas = ViewBag.ModoSimulacionPreguntas as bool? ?? true;
    }

    <!-- Preguntas de la publicación (Fase 16) -->
    <div class="card-erp-panel p-5 mt-6">
        <div class="flex items-center justify-between mb-3">
            <h2 class="text-lg font-bold text-white flex items-center gap-2">
                <span class="material-symbols-outlined text-amber-400" aria-hidden="true">help</span>
                Preguntas preventa
                <span class="text-sm font-normal text-slate-500">(@preguntas.Count)</span>
            </h2>
            <a asp-action="Preguntas" class="btn-erp-ghost btn-sm">Ver todas</a>
        </div>

        @if (puedeSimularPregunta)
        {
            <form asp-action="PreguntaSimular" method="post" class="mb-4 flex flex-col gap-2 sm:flex-row">
                @Html.AntiForgeryToken()
                <input type="hidden" name="listingId" value="@Model.Id" />
                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                <input type="text" name="texto" maxlength="2000" required class="input-erp flex-1"
                       placeholder="Texto de una pregunta de prueba (QA)..." />
                <button type="submit" class="btn-erp-secondary btn-sm">
                    <span class="material-symbols-outlined text-sm">science</span>
                    Simular pregunta
                </button>
            </form>
        }

        @if (preguntas.Count == 0)
        {
            <p class="text-sm text-slate-400">Sin preguntas para esta publicación.</p>
        }
        else
        {
            <div class="flex flex-col gap-2">
                @foreach (var p in preguntas)
                {
                    <div class="rounded-lg border border-slate-700/60 bg-slate-800/40 p-3">
                        <div class="flex items-center justify-between mb-1">
                            <span class="text-[10px] text-slate-500">@p.FechaPreguntaUtc.ToLocalTime().ToString("dd/MM HH:mm")</span>
                            <span class="flex items-center gap-1">
                                @if (p.Estado == TheBuryProject.Modules.MercadoLibre.Entities.MercadoLibreQuestionEstado.Respondida)
                                {
                                    <span class="text-[11px] font-bold text-emerald-400">Respondida</span>
                                }
                                else if (p.Estado == TheBuryProject.Modules.MercadoLibre.Entities.MercadoLibreQuestionEstado.Error)
                                {
                                    <span class="text-[11px] font-bold text-rose-400">Error</span>
                                }
                                else
                                {
                                    <span class="text-[11px] font-bold text-amber-400">Pendiente</span>
                                }
                                @if (p.EsSimulada)
                                {
                                    <span class="inline-flex items-center rounded-full border border-sky-500/30 bg-sky-500/10 px-1.5 py-0.5 text-[9px] font-bold text-sky-300">sim</span>
                                }
                            </span>
                        </div>
                        <p class="text-sm text-slate-100">@p.TextoPregunta</p>
                        @if (!string.IsNullOrEmpty(p.RespuestaTexto))
                        {
                            <p class="text-xs text-emerald-200 mt-1 pl-2 border-l-2 border-emerald-700/50">@p.RespuestaTexto</p>
                        }
                        <div class="mt-2 text-right">
                            <a asp-action="Pregunta" asp-route-id="@p.Id" class="text-xs font-semibold text-sky-300 hover:underline">
                                @(p.Estado == TheBuryProject.Modules.MercadoLibre.Entities.MercadoLibreQuestionEstado.Pendiente ? "Responder" : "Ver")
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <datalist id="ml-productos-datalist"></datalist>
</div>

@section Scripts {
    <script>
        (function () {
            'use strict';

            var productos = @Html.Raw(productosJson);
            var datalist = document.getElementById('ml-productos-datalist');

            if (datalist) {
                productos.forEach(function (p) {
                    var option = document.createElement('option');
                    option.value = p.codigo + ' - ' + p.nombre;
                    option.dataset.id = p.id;
                    datalist.appendChild(option);
                });
            }

            document.querySelectorAll('.ml-listing-link-form').forEach(function (form) {
                var picker = form.querySelector('.ml-producto-picker');
                var hidden = form.querySelector('.ml-producto-id');
                var submit = form.querySelector('button[type="submit"]');

                if (!picker || !hidden || !submit) return;

                picker.addEventListener('input', function () {
                    var match = productos.find(function (p) {
                        return (p.codigo + ' - ' + p.nombre) === picker.value;
                    });

                    hidden.value = match ? match.id : '';
                    submit.disabled = !match;
                });

                form.addEventListener('submit', function (e) {
                    if (!hidden.value) e.preventDefault();
                });
            });

            document.querySelectorAll('.ml-variation-link-form').forEach(function (form) {
                var picker = form.querySelector('.ml-producto-picker');
                var hidden = form.querySelector('.ml-producto-id');

                if (!picker || !hidden) return;

                picker.addEventListener('input', function () {
                    var match = productos.find(function (p) {
                        return (p.codigo + ' - ' + p.nombre) === picker.value;
                    });

                    hidden.value = match ? match.id : '';
                });
            });
        })();
    </script>
}
