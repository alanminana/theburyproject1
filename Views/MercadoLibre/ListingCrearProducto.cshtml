@using TheBuryProject.Models.Entities
@model MercadoLibreCrearProductoViewModel
@{
    ViewData["Title"] = "Crear producto desde publicación";
    var categorias = ViewBag.Categorias as IEnumerable<Categoria> ?? Enumerable.Empty<Categoria>();
    var marcas = ViewBag.Marcas as IEnumerable<Marca> ?? Enumerable.Empty<Marca>();
}

<div class="erp-page-shell erp-compact">

    @if (TempData["Error"] != null)
    {
        <div class="alert-erp alert-erp-error toast-msg" role="alert">
            <span class="material-symbols-outlined">error</span>
            @TempData["Error"]
        </div>
    }

    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between mb-6">
        <div>
            <h1 class="text-2xl font-black text-white flex items-center gap-2">
                <span class="material-symbols-outlined text-3xl text-amber-400" aria-hidden="true">add_box</span>
                Crear producto desde publicación
            </h1>
            <p class="text-sm text-slate-400 mt-1">
                Crea un Producto interno con los datos de la publicación y lo deja vinculado.
                <span class="font-bold text-sky-300">No modifica nada en Mercado Libre.</span>
            </p>
        </div>
        <a asp-action="Listings" class="btn-erp-ghost btn-sm">
            <span class="material-symbols-outlined text-sm">arrow_back</span>
            Publicaciones
        </a>
    </div>

    <!-- Publicación de origen -->
    <div class="card-erp-panel p-4 mb-6">
        <p class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Publicación de origen</p>
        <p class="text-sm font-semibold text-white">@Model.ListingTitulo</p>
        <p class="text-xs text-slate-400 font-mono mt-0.5">
            @Model.ListingItemId · precio ML @Model.ListingPrecio.ToString("N2") · stock ML @Model.ListingStock
            @if (!string.IsNullOrEmpty(Model.ListingSku))
            {
                <span>· SKU @Model.ListingSku</span>
            }
            @if (!string.IsNullOrEmpty(Model.ListingCondicion))
            {
                <span>· @Model.ListingCondicion</span>
            }
        </p>
        @if (!string.IsNullOrEmpty(Model.ListingPermalink))
        {
            <a href="@Model.ListingPermalink" target="_blank" rel="noopener noreferrer"
               class="text-xs text-amber-300 hover:text-amber-200 inline-flex items-center gap-1 mt-1">
                <span class="material-symbols-outlined text-[14px]">open_in_new</span>
                Ver en Mercado Libre
            </a>
        }
    </div>

    <form asp-action="ListingCrearProducto" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ListingId" />
        <input type="hidden" asp-for="ListingItemId" />
        <input type="hidden" asp-for="ListingTitulo" />
        <input type="hidden" asp-for="ListingPrecio" />
        <input type="hidden" asp-for="ListingStock" />
        <input type="hidden" asp-for="ListingSku" />
        <input type="hidden" asp-for="ListingCondicion" />
        <input type="hidden" asp-for="ListingPermalink" />

        <div class="grid grid-cols-1 gap-6 xl:grid-cols-2">
            <div class="card-erp-panel p-6">
                <h2 class="text-base font-bold text-white mb-4">Identificación</h2>

                <div class="space-y-4">
                    <div>
                        <label asp-for="Codigo" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Código interno</label>
                        <input asp-for="Codigo" class="input-erp w-full" />
                        <span asp-validation-for="Codigo" class="text-xs text-rose-400"></span>
                    </div>

                    <div>
                        <label asp-for="Nombre" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Nombre</label>
                        <input asp-for="Nombre" class="input-erp w-full" />
                        <span asp-validation-for="Nombre" class="text-xs text-rose-400"></span>
                    </div>

                    <div>
                        <label asp-for="Descripcion" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Descripción (opcional)</label>
                        <textarea asp-for="Descripcion" rows="3" class="input-erp w-full"></textarea>
                        <span asp-validation-for="Descripcion" class="text-xs text-rose-400"></span>
                    </div>

                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                        <div>
                            <label asp-for="CategoriaId" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Categoría</label>
                            <select asp-for="CategoriaId" class="select-erp w-full">
                                <option value="">Elegir...</option>
                                @foreach (var categoria in categorias)
                                {
                                    <option value="@categoria.Id">@categoria.Nombre</option>
                                }
                            </select>
                            <span asp-validation-for="CategoriaId" class="text-xs text-rose-400"></span>
                        </div>
                        <div>
                            <label asp-for="MarcaId" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Marca</label>
                            <select asp-for="MarcaId" class="select-erp w-full">
                                <option value="">Elegir...</option>
                                @foreach (var marca in marcas)
                                {
                                    <option value="@marca.Id">@marca.Nombre</option>
                                }
                            </select>
                            <span asp-validation-for="MarcaId" class="text-xs text-rose-400"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card-erp-panel p-6">
                <h2 class="text-base font-bold text-white mb-4">Precios y stock</h2>

                <div class="space-y-4">
                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                        <div>
                            <label asp-for="PrecioCompra" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Precio de costo</label>
                            <input asp-for="PrecioCompra" type="number" step="0.01" class="input-erp w-full" />
                            <span asp-validation-for="PrecioCompra" class="text-xs text-rose-400"></span>
                        </div>
                        <div>
                            <label asp-for="PrecioVenta" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Precio de venta</label>
                            <input asp-for="PrecioVenta" type="number" step="0.01" class="input-erp w-full" />
                            <span asp-validation-for="PrecioVenta" class="text-xs text-rose-400"></span>
                            <p class="text-xs text-slate-500 mt-1">Prellenado con el precio ML; ajustalo si tu precio interno difiere.</p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                        <div>
                            <label asp-for="PorcentajeIVA" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">IVA (%)</label>
                            <input asp-for="PorcentajeIVA" type="number" step="0.5" class="input-erp w-full" />
                            <span asp-validation-for="PorcentajeIVA" class="text-xs text-rose-400"></span>
                        </div>
                        <div>
                            <label asp-for="StockInicial" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Stock inicial</label>
                            <input asp-for="StockInicial" type="number" step="1" class="input-erp w-full" />
                            <span asp-validation-for="StockInicial" class="text-xs text-rose-400"></span>
                            <p class="text-xs text-slate-500 mt-1">
                                Genera un movimiento de stock "Stock inicial" en el kardex. Poné 0 si vas a cargarlo por compras.
                            </p>
                        </div>
                    </div>

                    <label class="flex items-center gap-2 cursor-pointer">
                        <input asp-for="RequiereNumeroSerie" type="checkbox" />
                        <span class="text-sm text-white">Producto trazable (requiere unidad física / número de serie para vender)</span>
                    </label>
                </div>
            </div>
        </div>

        <div class="flex justify-end gap-2 mt-6">
            <a asp-action="Listings" class="btn-erp-secondary">Cancelar</a>
            <button type="submit" class="btn-erp-primary">
                <span class="material-symbols-outlined text-sm">add_box</span>
                Crear producto y vincular
            </button>
        </div>
    </form>
</div>
