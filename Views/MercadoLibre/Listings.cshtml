@model List<MercadoLibreListingViewModel>
@{
    ViewData["Title"] = "Publicaciones Mercado Libre";
    var filtro = ViewBag.Filtro as string;
    var productosJson = ViewBag.ProductosPickerJson as string ?? "[]";
    var vinculadas = Model.Count(l => l.Vinculada);
    var sinVincular = Model.Count - vinculadas;
}

<div class="erp-page-shell erp-page-shell-xl erp-compact">

    @if (TempData["Success"] != null)
    {
        <div class="alert-erp alert-erp-success toast-msg" role="status">
            <span class="material-symbols-outlined">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-erp alert-erp-error toast-msg" role="alert">
            <span class="material-symbols-outlined">error</span>
            @TempData["Error"]
        </div>
    }

    <!-- Header -->
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between mb-6">
        <div>
            <h1 class="text-2xl font-black text-white flex items-center gap-2">
                <span class="material-symbols-outlined text-3xl text-amber-400" aria-hidden="true">list_alt</span>
                Publicaciones
            </h1>
            <p class="text-sm text-slate-400 mt-1">
                @Model.Count publicaciones importadas · @vinculadas vinculadas · @sinVincular sin vincular
            </p>
        </div>
        <div class="flex gap-2">
            @if (User.TienePermiso("mercadolibre", "sync"))
            {
                <a asp-action="Borradores" class="btn-erp-secondary btn-sm"
                   title="Crear publicaciones nuevas desde productos del ERP (borrador + validación)">
                    <span class="material-symbols-outlined text-sm">draft</span>
                    Publicar desde ERP
                </a>
                <a asp-action="Aumentos" class="btn-erp-secondary btn-sm">
                    <span class="material-symbols-outlined text-sm">trending_up</span>
                    Aumentos masivos
                </a>
            }
            <a asp-action="Index" class="btn-erp-ghost btn-sm">
                <span class="material-symbols-outlined text-sm">arrow_back</span>
                Conexión
            </a>
        </div>
    </div>

    <!-- Filtro vinculación + sync -->
    <div class="flex flex-wrap items-center gap-2 mb-4">
        <a asp-action="Listings" class="btn-sm @(string.IsNullOrEmpty(filtro) ? "btn-erp-primary" : "btn-erp-ghost")">Todas</a>
        <a asp-action="Listings" asp-route-filtro="vinculadas" class="btn-sm @(filtro == "vinculadas" ? "btn-erp-primary" : "btn-erp-ghost")">Vinculadas</a>
        <a asp-action="Listings" asp-route-filtro="sin-vincular" class="btn-sm @(filtro == "sin-vincular" ? "btn-erp-primary" : "btn-erp-ghost")">Sin vincular</a>
        <a asp-action="Listings" asp-route-filtro="con-variaciones" class="btn-sm @(filtro == "con-variaciones" ? "btn-erp-primary" : "btn-erp-ghost")">Con variaciones</a>
        <a asp-action="Listings" asp-route-filtro="con-error" class="btn-sm @(filtro == "con-error" ? "btn-erp-primary" : "btn-erp-ghost")">
            <span class="material-symbols-outlined text-xs text-rose-400">error</span>
            Con error
        </a>

        @if (User.TienePermiso("mercadolibre", "sync"))
        {
            <form id="ml-sync-form" asp-action="SyncPreview" method="post"
                  class="flex items-center gap-2 ml-auto">
                @Html.AntiForgeryToken()
                <select name="tipo" class="select-erp" aria-label="Qué sincronizar">
                    <option value="StockYPrecio">Stock y precio</option>
                    <option value="Stock">Solo stock</option>
                    <option value="Precio">Solo precio</option>
                </select>
                <button type="submit" class="btn-erp-secondary btn-sm" id="ml-sync-submit" disabled
                        title="Previsualizar qué se enviaría a Mercado Libre (no aplica nada todavía)">
                    <span class="material-symbols-outlined text-sm">sync</span>
                    Previsualizar sync (<span id="ml-sync-count">0</span>)
                </button>
            </form>
        }
    </div>

    @if (Model.Count == 0)
    {
        <div class="card-erp-panel p-8 text-center">
            <span class="material-symbols-outlined text-5xl text-slate-600 mb-3 block" aria-hidden="true">inventory_2</span>
            <h2 class="text-lg font-bold text-white mb-2">No hay publicaciones importadas</h2>
            <p class="text-sm text-slate-400">
                Usá "Importar publicaciones" desde la pantalla de conexión para traer las publicaciones existentes del vendedor.
            </p>
        </div>
    }
    else
    {
        <div class="card-erp-panel overflow-hidden">
            <div class="overflow-x-auto">
                <table class="erp-table w-full">
                    <thead>
                        <tr>
                            <th class="w-8">
                                <input type="checkbox" id="ml-sync-select-all" aria-label="Seleccionar todas las vinculadas" />
                            </th>
                            <th>Publicación</th>
                            <th>Estado</th>
                            <th class="text-right">Precio ML</th>
                            <th class="text-right">Stock ML</th>
                            <th>SKU</th>
                            <th>Producto vinculado</th>
                            <th class="text-right">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var listing in Model)
                        {
                            <tr>
                                <td>
                                    @if (listing.Vinculada)
                                    {
                                        <input type="checkbox" name="listingIds" value="@listing.Id" form="ml-sync-form"
                                               class="ml-sync-check" aria-label="Seleccionar @listing.ItemId para sincronizar" />
                                    }
                                </td>
                                <td>
                                    <div class="max-w-xs">
                                        <a asp-action="Listing" asp-route-id="@listing.Id"
                                           class="font-semibold text-white truncate block hover:text-amber-300 no-underline"
                                           title="@listing.Titulo">@listing.Titulo</a>
                                        <p class="text-xs text-slate-400 font-mono">
                                            @listing.ItemId
                                            @if (listing.TieneVariaciones)
                                            {
                                                <span class="ml-1 text-amber-400">· @listing.CantidadVariaciones variaciones</span>
                                            }
                                        </p>
                                    </div>
                                </td>
                                <td>
                                    @if (listing.Status == "active")
                                    {
                                        <span class="inline-flex items-center rounded-full bg-emerald-500/10 border border-emerald-500/30 px-2 py-0.5 text-[11px] font-bold text-emerald-400">activa</span>
                                    }
                                    else if (listing.Status == "paused")
                                    {
                                        <span class="inline-flex items-center rounded-full bg-amber-500/10 border border-amber-500/30 px-2 py-0.5 text-[11px] font-bold text-amber-400">pausada</span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center rounded-full bg-slate-500/10 border border-slate-500/30 px-2 py-0.5 text-[11px] font-bold text-slate-400">@listing.Status</span>
                                    }
                                    @if (!string.IsNullOrEmpty(listing.SubStatus))
                                    {
                                        <p class="text-[10px] text-slate-500 mt-0.5">@listing.SubStatus</p>
                                    }
                                </td>
                                <td class="text-right font-mono text-white">
                                    @listing.Precio.ToString("N2") <span class="text-[10px] text-slate-400">@listing.CurrencyId</span>
                                </td>
                                <td class="text-right font-mono text-white">@listing.AvailableQuantity</td>
                                <td class="font-mono text-xs text-slate-300">@(listing.SellerSku ?? "—")</td>
                                <td>
                                    @if (listing.Vinculada)
                                    {
                                        <p class="text-sm font-semibold text-white">@listing.ProductoCodigo</p>
                                        <p class="text-xs text-slate-400 truncate max-w-[180px]" title="@listing.ProductoNombre">@listing.ProductoNombre</p>
                                        <p class="text-[10px] text-slate-500 font-mono">
                                            stock ERP: @(listing.ProductoStockActual?.ToString("N0") ?? "—") ·
                                            precio ERP: @(listing.ProductoPrecioVenta?.ToString("N2") ?? "—")
                                        </p>
                                    }
                                    else if (listing.ProductoSugeridoId.HasValue)
                                    {
                                        <form asp-action="Vincular" method="post" class="flex items-center gap-2">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="listingId" value="@listing.Id" />
                                            <input type="hidden" name="productoId" value="@listing.ProductoSugeridoId" />
                                            <span class="text-xs text-amber-300" title="Coincidencia por SKU">
                                                Sugerido: @listing.ProductoSugeridoNombre
                                            </span>
                                            <button type="submit" class="btn-erp-secondary btn-sm">
                                                <span class="material-symbols-outlined text-sm">link</span>
                                                Vincular
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <div class="flex items-center gap-2 flex-wrap">
                                            <form asp-action="Vincular" method="post" class="flex items-center gap-2 ml-listing-link-form" data-listing-id="@listing.Id">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="listingId" value="@listing.Id" />
                                                <input type="hidden" name="productoId" value="" class="ml-producto-id" />
                                                <input type="text" list="ml-productos-datalist"
                                                       class="filter-input-erp ml-producto-picker w-44"
                                                       placeholder="Código o nombre..."
                                                       aria-label="Buscar producto para vincular" />
                                                <button type="submit" class="btn-erp-secondary btn-sm" disabled>
                                                    <span class="material-symbols-outlined text-sm">link</span>
                                                    Vincular
                                                </button>
                                            </form>
                                            @if (User.TienePermiso("mercadolibre", "link"))
                                            {
                                                <a asp-action="ListingCrearProducto" asp-route-id="@listing.Id"
                                                   class="btn-erp-ghost btn-sm"
                                                   title="Crear un producto interno con los datos de esta publicación y vincularlo">
                                                    <span class="material-symbols-outlined text-sm">add_box</span>
                                                    Crear producto
                                                </a>
                                            }
                                        </div>
                                    }
                                </td>
                                <td class="text-right">
                                    <div class="flex items-center justify-end gap-1">
                                        @if (!string.IsNullOrEmpty(listing.Permalink))
                                        {
                                            <a href="@listing.Permalink" target="_blank" rel="noopener noreferrer"
                                               class="btn-erp-icon" title="Ver en Mercado Libre">
                                                <span class="material-symbols-outlined text-lg">open_in_new</span>
                                            </a>
                                        }
                                        @if (listing.Vinculada)
                                        {
                                            <form asp-action="Desvincular" method="post"
                                                  onsubmit="return confirm('¿Desvincular esta publicación del producto?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="listingId" value="@listing.Id" />
                                                <button type="submit" class="btn-erp-icon" title="Desvincular producto">
                                                    <span class="material-symbols-outlined text-lg text-rose-400">link_off</span>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <datalist id="ml-productos-datalist"></datalist>
    }
</div>

@section Scripts {
    <script>
        (function () {
            'use strict';

            var productos = @Html.Raw(productosJson);
            var datalist = document.getElementById('ml-productos-datalist');

            if (datalist) {
                productos.forEach(function (p) {
                    var option = document.createElement('option');
                    option.value = p.codigo + ' - ' + p.nombre;
                    option.dataset.id = p.id;
                    datalist.appendChild(option);
                });
            }

            document.querySelectorAll('.ml-listing-link-form').forEach(function (form) {
                var picker = form.querySelector('.ml-producto-picker');
                var hidden = form.querySelector('.ml-producto-id');
                var submit = form.querySelector('button[type="submit"]');

                picker.addEventListener('input', function () {
                    var match = productos.find(function (p) {
                        return (p.codigo + ' - ' + p.nombre) === picker.value;
                    });

                    hidden.value = match ? match.id : '';
                    submit.disabled = !match;
                });

                form.addEventListener('submit', function (e) {
                    if (!hidden.value) {
                        e.preventDefault();
                    }
                });
            });

            // Selección para sync masivo
            var syncChecks = Array.prototype.slice.call(document.querySelectorAll('.ml-sync-check'));
            var syncSubmit = document.getElementById('ml-sync-submit');
            var syncCount = document.getElementById('ml-sync-count');
            var selectAll = document.getElementById('ml-sync-select-all');

            function refreshSyncState() {
                var seleccionadas = syncChecks.filter(function (c) { return c.checked; }).length;
                if (syncCount) syncCount.textContent = seleccionadas;
                if (syncSubmit) syncSubmit.disabled = seleccionadas === 0;
            }

            syncChecks.forEach(function (c) { c.addEventListener('change', refreshSyncState); });

            if (selectAll) {
                selectAll.addEventListener('change', function () {
                    syncChecks.forEach(function (c) { c.checked = selectAll.checked; });
                    refreshSyncState();
                });
            }
        })();
    </script>
}
