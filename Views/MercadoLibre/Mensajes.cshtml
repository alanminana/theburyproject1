@using TheBuryProject.Modules.MercadoLibre.Entities
@model List<MercadoLibreMessage>
@{
    ViewData["Title"] = "Mensajes Mercado Libre";
    var filtro = ViewBag.Filtro as string;
    var modoSimulacion = ViewBag.ModoSimulacion as bool? ?? true;
}

<div class="erp-page-shell erp-page-shell-xl erp-compact">

    @if (TempData["Success"] != null)
    {
        <div class="alert-erp alert-erp-success toast-msg" role="status">
            <span class="material-symbols-outlined">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-erp alert-erp-error toast-msg" role="alert">
            <span class="material-symbols-outlined">error</span>
            @TempData["Error"]
        </div>
    }

    <partial name="_MercadoLibreNav" />

    <!-- Header: Atención (respuesta manual) -->
    <div class="ml-head">
        <div class="ml-head__main">
            <h1 class="ml-head__title">
                <span class="material-symbols-outlined" aria-hidden="true">forum</span>
                Atención · Mensajes
            </h1>
            <p class="ml-head__subtitle">
                @Model.Count mensajes · la respuesta es siempre manual.
                @if (modoSimulacion)
                {
                    <span class="text-sky-300 font-semibold">Modo simulación: los mensajes no se envían a Mercado Libre.</span>
                }
            </p>
        </div>
    </div>

    <!-- Sub-toggle de Atención -->
    <div class="flex flex-wrap gap-2 mb-4">
        <a asp-action="Preguntas" class="btn-sm btn-erp-ghost">
            <span class="material-symbols-outlined text-sm">help</span> Preguntas
        </a>
        <a asp-action="Mensajes" class="btn-sm btn-erp-primary">
            <span class="material-symbols-outlined text-sm">forum</span> Mensajes
        </a>
    </div>

    <!-- Filtros -->
    <div class="flex flex-wrap gap-2 mb-4">
        <a asp-action="Mensajes" class="btn-sm @(string.IsNullOrEmpty(filtro) ? "btn-erp-primary" : "btn-erp-ghost")">Todos</a>
        <a asp-action="Mensajes" asp-route-filtro="recibidos" class="btn-sm @(filtro == "recibidos" ? "btn-erp-primary" : "btn-erp-ghost")">Recibidos</a>
        <a asp-action="Mensajes" asp-route-filtro="enviados" class="btn-sm @(filtro == "enviados" ? "btn-erp-primary" : "btn-erp-ghost")">Enviados</a>
        <a asp-action="Mensajes" asp-route-filtro="simulados" class="btn-sm @(filtro == "simulados" ? "btn-erp-primary" : "btn-erp-ghost")">Simulados</a>
        <a asp-action="Mensajes" asp-route-filtro="con-error" class="btn-sm @(filtro == "con-error" ? "btn-erp-primary" : "btn-erp-ghost")">Con error</a>
        <a asp-action="Mensajes" asp-route-filtro="sin-vincular" class="btn-sm @(filtro == "sin-vincular" ? "btn-erp-primary" : "btn-erp-ghost")">Sin orden</a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="card-erp-panel p-8 text-center">
            <span class="material-symbols-outlined text-5xl text-slate-600 mb-3 block" aria-hidden="true">forum</span>
            <h2 class="text-lg font-bold text-white mb-2">Sin mensajes</h2>
            <p class="text-sm text-slate-400">
                Los mensajes llegan por webhook. En modo simulación podés generar uno de prueba desde el detalle de una orden.
            </p>
        </div>
    }
    else
    {
        <div class="card-erp-panel overflow-hidden">
            <div class="overflow-x-auto">
                <table class="erp-table w-full">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Dirección</th>
                            <th>Orden</th>
                            <th>Mensaje</th>
                            <th>Estado</th>
                            <th class="text-right">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in Model)
                        {
                            <tr>
                                <td class="text-sm text-slate-300 whitespace-nowrap">@m.FechaMensajeUtc.ToLocalTime().ToString("dd/MM HH:mm")</td>
                                <td>
                                    @if (m.Direccion == MercadoLibreMessageDireccion.Saliente)
                                    {
                                        <span class="inline-flex items-center gap-1 text-xs font-bold text-emerald-300">
                                            <span class="material-symbols-outlined text-sm">north_east</span> Saliente
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1 text-xs font-bold text-sky-300">
                                            <span class="material-symbols-outlined text-sm">south_west</span> Entrante
                                        </span>
                                    }
                                </td>
                                <td class="text-sm">
                                    @if (m.OrderId.HasValue)
                                    {
                                        <a asp-action="Orden" asp-route-id="@m.OrderId" class="font-mono text-sky-300 hover:underline">#@m.MeliOrderId</a>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center rounded-full border border-amber-500/30 bg-amber-500/10 px-2 py-0.5 text-[10px] font-bold text-amber-300">sin orden</span>
                                    }
                                </td>
                                <td class="max-w-[380px]">
                                    <p class="text-sm text-slate-200 line-clamp-2">@m.Texto</p>
                                </td>
                                <td>
                                    @switch (m.Estado)
                                    {
                                        case MercadoLibreMessageEstado.Enviado:
                                            <span class="text-xs font-bold text-emerald-400">Enviado</span>
                                            break;
                                        case MercadoLibreMessageEstado.Error:
                                            <span class="text-xs font-bold text-rose-400" title="@m.ErrorProcesamiento">Error</span>
                                            break;
                                        default:
                                            <span class="text-xs font-bold text-sky-400">Recibido</span>
                                            break;
                                    }
                                    @if (m.EsSimulado)
                                    {
                                        <span class="ml-1 inline-flex items-center rounded-full border border-sky-500/30 bg-sky-500/10 px-2 py-0.5 text-[10px] font-bold text-sky-300">simulado</span>
                                    }
                                </td>
                                <td class="text-right">
                                    @if (m.OrderId.HasValue)
                                    {
                                        <a asp-action="Orden" asp-route-id="@m.OrderId" class="btn-erp-icon" title="Ver conversación en la orden">
                                            <span class="material-symbols-outlined text-lg">open_in_new</span>
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
