@using TheBuryProject.Modules.MercadoLibre.Entities
@model MercadoLibreOrderDetalleViewModel
@{
    ViewData["Title"] = $"Orden ML #{Model.MeliOrderId}";
    var puedeSimularEnvio = ViewBag.PuedeSimularEnvio as bool? ?? false;
    var puedeSimularClaim = ViewBag.PuedeSimularClaim as bool? ?? false;
}

<div class="erp-page-shell erp-compact">

    @if (TempData["Success"] != null)
    {
        <div class="alert-erp alert-erp-success toast-msg" role="status">
            <span class="material-symbols-outlined">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-erp alert-erp-error toast-msg" role="alert">
            <span class="material-symbols-outlined">error</span>
            @TempData["Error"]
        </div>
    }

    <partial name="_MercadoLibreNav" />

    <nav class="text-sm text-slate-400 mb-3" aria-label="Ruta">
        <a asp-action="Ordenes" class="hover:text-amber-300">Órdenes</a>
        <span class="mx-1 text-slate-600">/</span>
        <span class="text-slate-300">#@Model.MeliOrderId</span>
    </nav>

    <!-- Header -->
    <div class="ml-head">
        <div class="ml-head__main">
            <h1 class="ml-head__title">
                <span class="material-symbols-outlined" aria-hidden="true">receipt_long</span>
                Orden #@Model.MeliOrderId
                @if (Model.EsSimuladaQa)
                {
                    <span class="inline-flex items-center rounded-full border border-sky-500/30 bg-sky-500/10 px-2 py-0.5 text-xs font-bold text-sky-300">QA simulada</span>
                }
                else if (Model.EsSimuladaOperativa)
                {
                    <span class="inline-flex items-center rounded-full border border-emerald-500/30 bg-emerald-500/10 px-2 py-0.5 text-xs font-bold text-emerald-300">Operativa simulada local</span>
                }
            </h1>
            <p class="ml-head__subtitle">
                @Model.FechaCreacionUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ·
                comprador @(Model.BuyerNickname ?? "—") · status ML: @Model.Status
            </p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorProcesamiento))
    {
        <div class="card-erp-panel p-4 mb-6 border border-rose-500/30">
            <div class="flex items-start gap-3">
                <span class="material-symbols-outlined text-rose-400" aria-hidden="true">error</span>
                <p class="text-sm text-slate-300">@Model.ErrorProcesamiento</p>
            </div>
        </div>
    }

    @if (Model.EsSimuladaQa)
    {
        <div class="card-erp-panel p-4 mb-6 border border-sky-500/30">
            <div class="flex items-start gap-3">
                <span class="material-symbols-outlined text-sky-300" aria-hidden="true">science</span>
                <div>
                    <p class="text-sm font-bold text-sky-300">Orden QA simulada local.</p>
                    <p class="text-xs text-slate-400 mt-1">
                        No se llamÃ³ a Mercado Libre. Crear venta interna queda bloqueado para no descontar stock real.
                    </p>
                </div>
            </div>
        </div>
    }
    else if (Model.EsSimuladaOperativa)
    {
        <div class="card-erp-panel p-4 mb-6 border border-emerald-500/30">
            <div class="flex items-start gap-3">
                <span class="material-symbols-outlined text-emerald-300" aria-hidden="true">verified</span>
                <div>
                    <p class="text-sm font-bold text-emerald-300">Orden operativa simulada local.</p>
                    <p class="text-xs text-slate-400 mt-1">
                        No se llamo a Mercado Libre. Permite probar venta interna, stock ERP y liquidacion simulada local en ModoSimulacion.
                    </p>
                </div>
            </div>
        </div>
    }

    <div class="grid grid-cols-1 gap-6 xl:grid-cols-2">

        <!-- Ítems -->
        <div class="card-erp-panel p-6">
            <h2 class="text-base font-bold text-white mb-4 flex items-center gap-2">
                <span class="material-symbols-outlined text-amber-400 text-xl" aria-hidden="true">inventory_2</span>
                Ítems (@Model.Items.Count)
            </h2>

            <div class="space-y-3">
                @foreach (var item in Model.Items)
                {
                    <div class="rounded-lg bg-slate-800/40 p-3 flex items-start justify-between gap-3">
                        <div class="min-w-0">
                            <p class="text-sm font-semibold text-white truncate" title="@item.Titulo">@item.Titulo</p>
                            <p class="text-xs text-slate-400 font-mono">
                                @item.ItemId
                                @if (item.VariationId.HasValue)
                                {
                                    <span>· var @item.VariationId</span>
                                }
                                @if (!string.IsNullOrEmpty(item.SellerSku))
                                {
                                    <span>· SKU @item.SellerSku</span>
                                }
                            </p>
                            @if (item.Vinculado)
                            {
                                <p class="text-xs text-emerald-400 mt-1">
                                    Producto: @item.ProductoCodigo @(item.ProductoNombre is null ? "" : $"— {item.ProductoNombre}")
                                </p>
                            }
                            else
                            {
                                <p class="text-xs text-amber-400 mt-1">
                                    Sin producto vinculado —
                                    <a asp-action="Listings" asp-route-filtro="sin-vincular" class="underline">vincular publicación</a>
                                </p>
                            }

                            @if (item.UnidadesAsignadasDetalle.Count > 0)
                            {
                                <p class="text-xs text-sky-300 mt-1">
                                    Unidades: @string.Join(", ", item.UnidadesAsignadasDetalle.Select(u => u.Etiqueta))
                                </p>
                            }

                            @if (item.RequiereUnidadFisica && Model.PuedeAsignarUnidades)
                            {
                                <form asp-action="OrdenAsignarUnidades" method="post" class="mt-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <input type="hidden" name="orderItemId" value="@item.Id" />
                                    @if (item.UnidadesDisponibles.Count == 0)
                                    {
                                        <p class="text-xs text-rose-400">
                                            Producto trazable sin unidades físicas EnStock: registrá unidades antes de crear la venta.
                                        </p>
                                    }
                                    else
                                    {
                                        <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
                                            <select name="unidadIds" multiple size="@Math.Min(item.UnidadesDisponibles.Count, 4)"
                                                    class="select-erp flex-1 text-xs"
                                                    aria-label="Unidades físicas para esta línea (elegí @item.Cantidad)">
                                                @foreach (var unidad in item.UnidadesDisponibles)
                                                {
                                                    <option value="@unidad.Id" selected="@(item.UnidadesAsignadasDetalle.Any(a => a.Id == unidad.Id) ? "selected" : null)">
                                                        @unidad.Etiqueta
                                                    </option>
                                                }
                                            </select>
                                            <button type="submit" class="btn-erp-secondary btn-sm shrink-0">
                                                <span class="material-symbols-outlined text-sm">qr_code_2</span>
                                                Asignar (@item.Cantidad)
                                            </button>
                                        </div>
                                        <p class="text-[10px] text-slate-500 mt-1">
                                            Elegí exactamente @item.Cantidad unidad(es). Si no asignás, el sistema usa FIFO al crear la venta.
                                        </p>
                                    }
                                </form>
                            }
                        </div>
                        <div class="text-right shrink-0">
                            <p class="text-sm font-mono text-white">@item.Cantidad × @item.PrecioUnitario.ToString("N2")</p>
                            @if (item.SaleFee is > 0)
                            {
                                <p class="text-[10px] text-slate-400">comisión @((item.SaleFee.Value * item.Cantidad).ToString("N2"))</p>
                            }
                        </div>
                    </div>
                }
            </div>

            @if (Model.PuedeCrearVenta)
            {
                <form asp-action="OrdenCrearVenta" method="post" class="mt-4"
                      onsubmit="return confirm('¿Crear la venta interna y descontar stock? Esta acción descuenta stock real del ERP.');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn-erp-primary w-full">
                        <span class="material-symbols-outlined text-sm">point_of_sale</span>
                        Crear venta interna y descontar stock
                    </button>
                </form>
            }
            else if (Model.EsSimuladaQa)
            {
                <div class="mt-4 rounded-lg bg-sky-500/10 border border-sky-500/30 p-3">
                    <p class="text-sm text-sky-300 font-semibold flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">lock</span>
                        Venta interna bloqueada para QA: no descuenta stock real.
                    </p>
                </div>
            }
            @if (Model.VentaId.HasValue)
            {
                <div class="mt-4 rounded-lg bg-emerald-500/10 border border-emerald-500/30 p-3">
                    <p class="text-sm text-emerald-300 font-semibold flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">check_circle</span>
                        Venta interna: <a asp-controller="Venta" asp-action="Details" asp-route-id="@Model.VentaId"
                                          class="font-mono underline">@Model.VentaNumero</a>
                    </p>
                </div>
            }
            @if (Model.EstadoInterno == MercadoLibreOrderEstadoInterno.Importada && Model.VentaId is null)
            {
                <form asp-action="OrdenIgnorar" method="post" class="mt-2"
                      onsubmit="return confirm('¿Marcar esta orden como ignorada (no se procesará)?');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn-erp-ghost btn-sm w-full text-slate-400">
                        No procesar esta orden
                    </button>
                </form>
            }
        </div>

        <!-- Liquidación (Fase D) -->
        <div class="card-erp-panel p-6">
            <h2 class="text-base font-bold text-white mb-4 flex items-center gap-2">
                <span class="material-symbols-outlined text-amber-400 text-xl" aria-hidden="true">account_balance</span>
                Liquidación
            </h2>

            <div class="grid grid-cols-2 gap-3 mb-4">
                <div class="rounded-lg bg-slate-800/40 p-3">
                    <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Bruto (total ML)</p>
                    <p class="text-sm font-mono font-semibold text-white mt-1">@Model.TotalAmount.ToString("N2")</p>
                </div>
                <div class="rounded-lg bg-slate-800/40 p-3">
                    <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Comisión ML</p>
                    <p class="text-sm font-mono font-semibold text-rose-300 mt-1">@(Model.MontoComision?.ToString("N2") ?? "—")</p>
                </div>
                <div class="rounded-lg bg-slate-800/40 p-3">
                    <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Envío (estimado)</p>
                    <p class="text-sm font-mono font-semibold text-rose-300 mt-1">@(Model.MontoEnvio?.ToString("N2") ?? "—")</p>
                </div>
                <div class="rounded-lg bg-slate-800/40 p-3">
                    <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Neto estimado</p>
                    <p class="text-sm font-mono font-semibold text-emerald-400 mt-1">@(Model.NetoEstimado?.ToString("N2") ?? "—")</p>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-3 mb-4">
                <div class="rounded-lg bg-slate-800/40 p-3">
                    <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Otros costos</p>
                    <p class="text-sm font-mono font-semibold text-slate-200 mt-1">@Model.MontoOtrosCostos.ToString("N2")</p>
                </div>
                <div class="rounded-lg bg-slate-800/40 p-3">
                    <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Estado liquidacion</p>
                    <p class="text-sm font-semibold text-white mt-1">@Model.EstadoLiquidacion</p>
                </div>
            </div>

            @if (Model.EstadoInterno == MercadoLibreOrderEstadoInterno.Liquidada)
            {
                <div class="rounded-lg bg-sky-500/10 border border-sky-500/30 p-4">
                    <p class="text-sm font-semibold text-sky-300 flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">check_circle</span>
                        Liquidada el @Model.FechaLiquidacionUtc?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                    </p>
                    <p class="text-sm text-slate-300 mt-2 font-mono">
                        Neto real acreditado: <span class="font-bold text-white">@Model.NetoReal?.ToString("N2")</span>
                        @if (Model.DiferenciaLiquidacion.HasValue)
                        {
                            <span class="@(Model.DiferenciaLiquidacion >= 0 ? "text-emerald-400" : "text-rose-400")">
                                (diferencia vs estimado: @Model.DiferenciaLiquidacion.Value.ToString("N2"))
                            </span>
                        }
                    </p>
                    @if (Model.MovimientoCajaId.HasValue)
                    {
                        <p class="text-xs text-slate-400 mt-2 font-mono">
                            MovimientoCajaId: @Model.MovimientoCajaId
                            @if (Model.EsLiquidacionSimulada)
                            {
                                <span class="ml-2 text-emerald-300">simulacion local</span>
                            }
                        </p>
                    }
                </div>
            }
            else if (Model.EsSimuladaOperativa && !Model.ModoSimulacion && Model.VentaId.HasValue)
            {
                <p class="text-sm text-slate-500">
                    Liquidacion bloqueada para orden operativa simulada local.
                </p>
            }
            else if (Model.PuedeLiquidar)
            {
                <form asp-action="OrdenLiquidar" method="post" class="rounded-lg bg-slate-800/40 p-4"
                      onsubmit="return confirm('¿Registrar la liquidación como ingreso de caja? Requiere caja abierta.');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1" for="netoReal">
                        Neto real acreditado por MercadoPago ($)
                    </label>
                    <div class="flex gap-2">
                        <input type="number" step="0.01" min="0.01" name="netoReal" id="netoReal" required
                               class="input-erp flex-1" value="@(Model.NetoEstimado?.ToString("0.##"))" />
                        <button type="submit" class="btn-erp-primary">
                            <span class="material-symbols-outlined text-sm">account_balance_wallet</span>
                            Registrar en caja
                        </button>
                    </div>
                    <p class="text-xs text-slate-500 mt-2">
                        Se registra como ingreso con concepto "Liquidación Mercado Libre" en la caja abierta del usuario.
                        La diferencia contra el neto estimado queda guardada.
                    </p>
                    @if (Model.EsSimuladaOperativa)
                    {
                        <p class="text-xs text-emerald-300 mt-2">
                            ModoSimulacion activo: el movimiento queda marcado como simulacion local.
                        </p>
                    }
                </form>
            }
            else
            {
                <p class="text-sm text-slate-500">
                    La liquidación se habilita cuando la orden tiene venta interna creada.
                </p>
            }

            <!-- Envío (Fase H) -->
            <h2 class="text-base font-bold text-white mt-6 mb-3 flex items-center gap-2">
                <span class="material-symbols-outlined text-amber-400 text-xl" aria-hidden="true">assignment_return</span>
                Reclamos / Devoluciones ML
            </h2>

            @if (puedeSimularClaim)
            {
                <form asp-action="OrdenSimularClaim" method="post" class="mt-4 rounded-lg border border-sky-500/20 bg-sky-500/10 p-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <label class="mb-2 block text-xs font-bold uppercase tracking-wider text-sky-200" for="tipo-claim">
                        Simular reclamo/devolucion
                    </label>
                    <div class="grid gap-2 sm:grid-cols-[180px_1fr_auto]">
                        <select id="tipo-claim" name="tipo" class="select-erp">
                            <option value="@MercadoLibreClaimTipo.Devolucion">Devolucion</option>
                            <option value="@MercadoLibreClaimTipo.Reclamo">Reclamo</option>
                            <option value="@MercadoLibreClaimTipo.Garantia">Garantia</option>
                            <option value="@MercadoLibreClaimTipo.Cancelacion">Cancelacion</option>
                        </select>
                        <input type="text" name="motivo" class="input-erp" maxlength="500"
                               placeholder="Motivo QA local" />
                        <button type="submit" class="btn-erp-secondary">
                            <span class="material-symbols-outlined text-sm">science</span>
                            Simular
                        </button>
                    </div>
                    <p class="mt-2 text-xs text-slate-400">
                        Accion local: no llama a Mercado Libre, queda pendiente y no mueve stock ni caja.
                    </p>
                </form>
            }

            @if (Model.Claims.Count > 0)
            {
                <div class="mt-4 space-y-3">
                    @foreach (var claim in Model.Claims)
                    {
                        <div class="rounded-lg border @(claim.Pendiente ? "border-amber-500/30 bg-amber-500/10" : "border-slate-700 bg-slate-800/40") p-4">
                            <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                                <div>
                                    <p class="text-sm font-semibold text-white">
                                        @claim.Tipo - @claim.Estado
                                        @if (claim.EsSimuladoLocal)
                                        {
                                            <span class="ml-2 inline-flex items-center rounded-full border border-sky-500/30 bg-sky-500/10 px-2 py-0.5 text-[10px] font-bold text-sky-300">QA local</span>
                                        }
                                    </p>
                                    <p class="mt-1 text-xs text-slate-400 font-mono">
                                        @(claim.MercadoLibreClaimId ?? $"local-{claim.Id}") - @claim.FechaCreacionUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                    </p>
                                </div>
                                @if (claim.Pendiente)
                                {
                                    <span class="inline-flex w-fit items-center rounded-full border border-amber-500/30 bg-amber-500/10 px-2 py-0.5 text-[11px] font-bold text-amber-300">
                                        pendiente revision
                                    </span>
                                }
                            </div>

                            <div class="mt-3 grid gap-2 text-xs text-slate-300 sm:grid-cols-2">
                                <div><span class="text-slate-500">Motivo:</span> @(claim.Motivo ?? "sin dato")</div>
                                <div><span class="text-slate-500">Stock:</span> @claim.AccionStock</div>
                                <div><span class="text-slate-500">Economia:</span> @claim.AccionEconomica</div>
                                <div><span class="text-slate-500">MovimientoStockId:</span> @(claim.MovimientoStockId?.ToString() ?? "sin movimiento")</div>
                                <div><span class="text-slate-500">MovimientoCajaId:</span> @(claim.MovimientoCajaId?.ToString() ?? "sin movimiento")</div>
                                <div><span class="text-slate-500">Resuelto:</span> @(claim.FechaResolucionUtc?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "pendiente")</div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(claim.ResolucionManual))
                            {
                                <p class="mt-2 text-xs text-slate-300">@claim.ResolucionManual</p>
                            }
                            @if (!string.IsNullOrWhiteSpace(claim.Observaciones))
                            {
                                <p class="mt-1 text-xs text-slate-500">@claim.Observaciones</p>
                            }

                            @if (claim.Pendiente)
                            {
                                <form asp-action="OrdenResolverClaim" method="post" class="mt-4"
                                      onsubmit="return confirm('Confirmar resolucion manual? Solo Reingresar stock crea entrada de stock. Caja no se mueve automaticamente.');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <input type="hidden" name="claimId" value="@claim.Id" />
                                    <div class="grid gap-2 lg:grid-cols-2">
                                        <select name="accionStock" class="select-erp" aria-label="Accion sobre stock">
                                            <option value="@MercadoLibreClaimAccionStock.NoReingresar">No reingresar stock</option>
                                            <option value="@MercadoLibreClaimAccionStock.ReingresarStock">Reingresar stock</option>
                                            <option value="@MercadoLibreClaimAccionStock.Danado">Danado / no disponible</option>
                                            <option value="@MercadoLibreClaimAccionStock.Garantia">Garantia / revision</option>
                                            <option value="@MercadoLibreClaimAccionStock.Merma">Merma</option>
                                        </select>
                                        <select name="accionEconomica" class="select-erp" aria-label="Accion economica">
                                            <option value="@MercadoLibreClaimAccionEconomica.SinImpacto">Sin impacto economico</option>
                                            <option value="@MercadoLibreClaimAccionEconomica.DevolucionPendiente">Devolucion pendiente</option>
                                            <option value="@MercadoLibreClaimAccionEconomica.DevolucionRegistrada">Devolucion registrada fuera de caja ERP</option>
                                        </select>
                                    </div>
                                    <input type="text" name="resolucionManual" class="input-erp w-full mt-2" maxlength="500"
                                           placeholder="Resolucion manual" />
                                    <textarea name="observaciones" class="input-erp w-full mt-2 min-h-[76px]" maxlength="1000"
                                              placeholder="Observaciones operativas"></textarea>
                                    <button type="submit" class="btn-erp-primary mt-2">
                                        <span class="material-symbols-outlined text-sm">task_alt</span>
                                        Resolver
                                    </button>
                                </form>
                            }
                        </div>
                    }
                </div>
            }

            <h2 class="text-base font-bold text-white mt-6 mb-3 flex items-center gap-2">
                <span class="material-symbols-outlined text-amber-400 text-xl" aria-hidden="true">local_shipping</span>
                Envío
            </h2>

            @if (Model.EnvioRequiereAtencion)
            {
                <div class="mb-3 rounded-lg border border-rose-500/30 bg-rose-500/10 p-3 text-sm text-rose-200">
                    <span class="material-symbols-outlined align-middle text-base">warning</span>
                    Estado logistico con atencion requerida: @Model.EstadoEnvioInterno.
                    No se revierte stock ni se liquida caja automaticamente.
                </div>
            }

            @if (Model.ShipmentId.HasValue)
            {
                <div class="rounded-lg bg-slate-800/40 p-3 flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                    <div class="min-w-0 flex-1">
                        <p class="text-sm text-white font-mono">
                            #@Model.ShipmentId · @(Model.ShipmentStatus ?? "sin consultar")
                            @if (!string.IsNullOrEmpty(Model.ShipmentSubStatus))
                            {
                                <span class="text-slate-400">(@Model.ShipmentSubStatus)</span>
                            }
                        </p>
                        @if (!string.IsNullOrEmpty(Model.TrackingNumber))
                        {
                            <p class="text-xs text-slate-400 font-mono mt-1">tracking: @Model.TrackingNumber</p>
                        }
                        <div class="mt-3 grid gap-2 text-xs text-slate-300 sm:grid-cols-2">
                            <div><span class="text-slate-500">Estado interno:</span> <span class="font-semibold text-white">@Model.EstadoEnvioInterno</span></div>
                            <div><span class="text-slate-500">Metodo/carrier:</span> @(Model.TrackingMethod ?? "sin dato")</div>
                            <div><span class="text-slate-500">Modo:</span> @(Model.ShippingMode ?? "sin dato")</div>
                            <div><span class="text-slate-500">Tipo:</span> @(Model.ShippingType ?? "sin dato")</div>
                            <div><span class="text-slate-500">Costo envio:</span> @(Model.MontoEnvio?.ToString("N2") ?? "sin dato")</div>
                            <div><span class="text-slate-500">Actualizado:</span> @(Model.FechaUltimaActualizacionEnvioUtc?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "sin dato")</div>
                            <div><span class="text-slate-500">Despacho:</span> @(Model.FechaDespachoUtc?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "sin dato")</div>
                            <div><span class="text-slate-500">Entrega:</span> @(Model.FechaEntregadoUtc?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "sin dato")</div>
                        </div>
                    </div>
                    <form asp-action="OrdenActualizarEnvio" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn-erp-secondary btn-sm">
                            <span class="material-symbols-outlined text-sm">refresh</span>
                            Actualizar
                        </button>
                    </form>
                </div>
            }
            else
            {
                <p class="text-sm text-slate-500">La orden no tiene envío asociado.</p>
            }

            <!-- Devolución (Fase H) -->
            @if (puedeSimularEnvio)
            {
                <form asp-action="OrdenSimularEnvio" method="post" class="mt-3 rounded-lg border border-sky-500/20 bg-sky-500/10 p-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <label class="mb-2 block text-xs font-bold uppercase tracking-wider text-sky-200" for="escenario-envio">
                        Simular estado de envio
                    </label>
                    <div class="flex flex-col gap-2 sm:flex-row">
                        <select id="escenario-envio" name="escenario" class="select-erp flex-1">
                            <option value="pendiente">Pendiente</option>
                            <option value="listo">Listo para despachar</option>
                            <option value="despachado">Despachado / en camino</option>
                            <option value="entregado">Entregado</option>
                            <option value="cancelado">Cancelado</option>
                            <option value="demorado">Demorado</option>
                            <option value="desconocido">Desconocido</option>
                        </select>
                        <button type="submit" class="btn-erp-secondary">
                            <span class="material-symbols-outlined text-sm">science</span>
                            Simular envio
                        </button>
                    </div>
                    <p class="mt-2 text-xs text-slate-400">
                        Accion local de QA: no llama a Mercado Libre, no crea venta, no mueve stock y no toca caja.
                    </p>
                </form>
            }

            <h2 class="text-base font-bold text-white mt-6 mb-3 flex items-center gap-2">
                <span class="material-symbols-outlined text-amber-400 text-xl" aria-hidden="true">assignment_return</span>
                Devolución
            </h2>

            @if (Model.DevolucionEstado == MercadoLibreDevolucionEstado.Ninguna)
            {
                <p class="text-sm text-slate-500">Sin devolución registrada.</p>
            }
            else if (Model.Claims.Count == 0 && Model.DevolucionEstado == MercadoLibreDevolucionEstado.PendienteRevision)
            {
                <div class="rounded-lg bg-amber-500/10 border border-amber-500/30 p-4">
                    <p class="text-sm font-semibold text-amber-300 mb-3 flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">warning</span>
                        Pendiente de revisión — el stock NO se reingresó automáticamente.
                    </p>
                    <form asp-action="OrdenDevolucion" method="post"
                          onsubmit="return confirm('¿Confirmar la decisión sobre esta devolución?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="flex flex-col gap-2 sm:flex-row">
                            <select name="decision" class="select-erp flex-1" aria-label="Decisión de devolución">
                                <option value="@MercadoLibreDevolucionEstado.StockReingresado">Reingresar stock (producto OK)</option>
                                <option value="@MercadoLibreDevolucionEstado.Danado">Producto dañado (no reingresa)</option>
                                <option value="@MercadoLibreDevolucionEstado.Garantia">Pasa a garantía</option>
                                <option value="@MercadoLibreDevolucionEstado.Merma">Merma</option>
                                <option value="@MercadoLibreDevolucionEstado.NoReingresa">No reingresar</option>
                            </select>
                            <button type="submit" class="btn-erp-primary">Resolver</button>
                        </div>
                        <input type="text" name="nota" class="input-erp w-full mt-2" maxlength="500"
                               placeholder="Nota (opcional): estado del producto, motivo..." />
                    </form>
                </div>
            }
            else if (Model.Claims.Count == 0)
            {
                <div class="rounded-lg bg-slate-800/40 p-3">
                    <p class="text-sm text-white">Resuelta: <span class="font-bold">@Model.DevolucionEstado</span></p>
                    @if (!string.IsNullOrEmpty(Model.DevolucionNota))
                    {
                        <p class="text-xs text-slate-400 mt-1">@Model.DevolucionNota</p>
                    }
                </div>
            }
        </div>
    </div>

    @{
        var mensajes = ViewBag.Mensajes as List<TheBuryProject.Modules.MercadoLibre.Entities.MercadoLibreMessage> ?? new();
        var puedeSimularMensaje = ViewBag.PuedeSimularMensaje as bool? ?? false;
        var modoSimulacionMensajes = ViewBag.ModoSimulacionMensajes as bool? ?? true;
        // Conversación real solo si la orden no es simulada local y el modo es real.
        var ordenSimuladaLocal = Model.EsSimuladaQa || Model.EsSimuladaOperativa;
        var mensajeEsSimulado = modoSimulacionMensajes || ordenSimuladaLocal;
        var labelBotonMensaje = mensajeEsSimulado ? "Simular respuesta" : "Responder en Mercado Libre";
    }

    <!-- Conversación postventa (Fase 16) -->
    <div class="card-erp-panel p-5 mt-6">
        <div class="flex items-center justify-between mb-3">
            <h2 class="text-lg font-bold text-white flex items-center gap-2">
                <span class="material-symbols-outlined text-amber-400" aria-hidden="true">forum</span>
                Mensajes postventa
            </h2>
            <a asp-action="Mensajes" class="btn-erp-ghost btn-sm">Ver todos</a>
        </div>

        @if (mensajes.Count == 0)
        {
            <p class="text-sm text-slate-400">Sin mensajes para esta orden.</p>
        }
        else
        {
            <div class="flex flex-col gap-2 mb-4">
                @foreach (var m in mensajes)
                {
                    var saliente = m.Direccion == TheBuryProject.Modules.MercadoLibre.Entities.MercadoLibreMessageDireccion.Saliente;
                    <div class="rounded-lg border p-3 @(saliente ? "border-emerald-700/40 bg-emerald-900/15 sm:ml-10" : "border-slate-700/60 bg-slate-800/40 sm:mr-10")">
                        <div class="flex items-center justify-between mb-1">
                            <span class="text-[11px] font-bold uppercase tracking-wide @(saliente ? "text-emerald-400" : "text-sky-400")">
                                @(saliente ? "Vendedor" : "Comprador")
                            </span>
                            <span class="text-[10px] text-slate-500">
                                @m.FechaMensajeUtc.ToLocalTime().ToString("dd/MM HH:mm")
                                @if (m.EsSimulado)
                                {
                                    <span class="ml-1 text-sky-300 font-bold">· simulado</span>
                                }
                            </span>
                        </div>
                        <p class="text-sm text-slate-100 whitespace-pre-wrap">@m.Texto</p>
                    </div>
                }
            </div>
        }

        @if (puedeSimularMensaje)
        {
            <form asp-action="MensajeSimular" method="post" class="mb-3 flex flex-col gap-2 sm:flex-row">
                @Html.AntiForgeryToken()
                <input type="hidden" name="orderId" value="@Model.Id" />
                <input type="text" name="texto" maxlength="2000" required class="input-erp flex-1"
                       placeholder="Texto de un mensaje entrante de prueba (QA)..." />
                <button type="submit" class="btn-erp-secondary btn-sm">
                    <span class="material-symbols-outlined text-sm">science</span>
                    Simular mensaje entrante
                </button>
            </form>
        }

        <div class="rounded-lg border border-slate-700/60 bg-slate-800/30 p-3">
            <p class="text-sm font-bold text-white mb-1">Responder</p>
            @if (mensajeEsSimulado)
            {
                <p class="text-xs text-sky-300 mb-2">
                    <span class="material-symbols-outlined text-sm align-middle">info</span>
                    El mensaje se guardará localmente y <strong>no se enviará a Mercado Libre</strong>.
                </p>
            }
            else
            {
                <p class="text-xs text-amber-300 mb-2">
                    <span class="material-symbols-outlined text-sm align-middle">warning</span>
                    Modo real: el mensaje se enviará a Mercado Libre tras confirmar.
                </p>
            }
            @{
                var onsubmitMensaje = mensajeEsSimulado
                    ? ""
                    : "return confirm('Enviar este mensaje REAL a Mercado Libre? Es visible para el comprador.');";
            }
            <form asp-action="MensajeResponder" method="post" onsubmit="@onsubmitMensaje">
                @Html.AntiForgeryToken()
                <input type="hidden" name="orderId" value="@Model.Id" />
                @if (!mensajeEsSimulado)
                {
                    <input type="hidden" name="confirmarReal" value="true" />
                }
                <textarea name="texto" rows="3" maxlength="2000" required class="input-erp w-full"
                          placeholder="Escribí la respuesta para el comprador..."></textarea>
                <div class="flex justify-end mt-2">
                    <button type="submit" class="btn-erp-primary btn-sm">
                        <span class="material-symbols-outlined text-sm">@(mensajeEsSimulado ? "science" : "send")</span>
                        @labelBotonMensaje
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
