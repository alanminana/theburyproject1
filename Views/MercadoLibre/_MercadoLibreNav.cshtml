@*
    Subnav unificado del módulo Mercado Libre.
    Navegación interna consistente entre las 17 vistas. Reemplaza la botonera
    ad-hoc que cada página armaba en su header (destinos inconsistentes).
    - Estado activo derivado del action de la ruta (no requiere variable por vista).
    - Permiso-aware: cada link respeta el permiso que exige su GET.
    - Responsive: scroll horizontal interno en mobile, sin overflow global.
    NO incluye acciones de página: esas van en su propio bloque "Acciones".
*@
@{
    var mlAction = (ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty);

    string MlArea(string action) => action switch
    {
        "Dashboard" => "panel",
        "Index" or "Conectar" or "OAuthCallback" => "conexion",
        "Configuracion" => "config",
        "Listings" or "Listing" or "ListingCrearProducto" or "SyncPreview" => "publicaciones",
        "Ordenes" or "Orden" => "ordenes",
        "Preguntas" or "Pregunta" or "Mensajes" => "atencion",
        "Aumentos" or "Aumento" or "AumentoNuevo" => "aumentos",
        "Borradores" or "Borrador" => "borradores",
        _ => string.Empty
    };

    var mlActive = MlArea(mlAction);
    string MlOn(string area) => mlActive == area ? "ml-subnav__link is-active" : "ml-subnav__link";
    string? MlAria(string area) => mlActive == area ? "page" : null;
}

<link rel="stylesheet" href="~/css/mercadolibre-module.css" asp-append-version="true" />

<nav class="ml-subnav" aria-label="Navegación Mercado Libre">
    <div class="ml-subnav__group ml-subnav__group--main">
        <a asp-action="Dashboard" class="@MlOn("panel")" aria-current="@MlAria("panel")">
            <span class="material-symbols-outlined" aria-hidden="true">dashboard</span>
            <span>Panel</span>
        </a>
        <a asp-action="Listings" class="@MlOn("publicaciones")" aria-current="@MlAria("publicaciones")">
            <span class="material-symbols-outlined" aria-hidden="true">list_alt</span>
            <span>Publicaciones</span>
        </a>
        @if (User.TienePermiso("mercadolibre", "orders"))
        {
            <a asp-action="Ordenes" class="@MlOn("ordenes")" aria-current="@MlAria("ordenes")">
                <span class="material-symbols-outlined" aria-hidden="true">receipt_long</span>
                <span>Órdenes</span>
            </a>
            <a asp-action="Preguntas" class="@MlOn("atencion")" aria-current="@MlAria("atencion")">
                <span class="material-symbols-outlined" aria-hidden="true">forum</span>
                <span>Atención</span>
            </a>
        }
        @if (User.TienePermiso("mercadolibre", "sync"))
        {
            <a asp-action="Aumentos" class="@MlOn("aumentos")" aria-current="@MlAria("aumentos")">
                <span class="material-symbols-outlined" aria-hidden="true">trending_up</span>
                <span>Aumentos</span>
            </a>
        }
        <a asp-action="Borradores" class="@MlOn("borradores")" aria-current="@MlAria("borradores")">
            <span class="material-symbols-outlined" aria-hidden="true">draft</span>
            <span>Borradores</span>
        </a>
    </div>

    <div class="ml-subnav__group ml-subnav__group--admin">
        <a asp-action="Index" class="@MlOn("conexion")" aria-current="@MlAria("conexion")">
            <span class="material-symbols-outlined" aria-hidden="true">link</span>
            <span>Conexión</span>
        </a>
        @if (User.TienePermiso("mercadolibre", "config"))
        {
            <a asp-action="Configuracion" class="@MlOn("config")" aria-current="@MlAria("config")">
                <span class="material-symbols-outlined" aria-hidden="true">settings</span>
                <span>Configuración</span>
            </a>
        }
    </div>
</nav>
