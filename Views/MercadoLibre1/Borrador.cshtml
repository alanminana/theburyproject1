@using TheBuryProject.Models.Entities
@model MercadoLibreBorradorEditViewModel
@{
    ViewData["Title"] = $"Borrador: {Model.Titulo}";
    var estaPublicado = Model.Estado == MercadoLibreBorradorEstado.Publicado;
    var estaValidado = Model.Estado == MercadoLibreBorradorEstado.Validado;
    var datosMinimosOk = !string.IsNullOrWhiteSpace(Model.Titulo) && Model.Precio > 0 && !string.IsNullOrWhiteSpace(Model.CategoryIdMl);
    var pasoActual = estaPublicado ? 4 : (estaValidado ? 3 : (datosMinimosOk ? 2 : 1));

    var camposError = new List<string>();
    string[] erroresLineas = System.Array.Empty<string>();
    if (!string.IsNullOrEmpty(Model.ErroresValidacion))
    {
        erroresLineas = Model.ErroresValidacion.Split('\n', StringSplitOptions.RemoveEmptyEntries);
        var lineaCampos = erroresLineas.FirstOrDefault(l => l.StartsWith("CAMPOS_ERROR:"));
        if (lineaCampos is not null)
        {
            camposError = lineaCampos["CAMPOS_ERROR:".Length..].Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
        }
    }
    var atributosError = new List<string>();
    var lineaAttrs = erroresLineas.FirstOrDefault(l => l.StartsWith("ATRIBUTOS_ERROR:"));
    if (lineaAttrs is not null)
    {
        atributosError = lineaAttrs["ATRIBUTOS_ERROR:".Length..].Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
    }
    var pasos = new[] { "Datos", "Validar", "Simular / Publicar" };
}

@section Styles {
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <link rel="stylesheet" href="~/css/mercadolibre1-compat.css" asp-append-version="true" />
}

<!-- ============ CREAR / BORRADOR ============ -->
<div class="crumb">
    <a asp-action="Borradores"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"></path></svg>Borradores</a>
    <span class="sep">/</span><span class="cur">@Model.Titulo</span>
</div>
<div class="phead">
    <div>
        <h1><span class="gi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 3h7l5 5v13a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z"></path><path d="M13 3v6h6"></path></svg></span>Borrador de publicación</h1>
        <div class="sub">Producto: <b style="color:var(--ink)">@Model.ProductoCodigo — @Model.ProductoNombre</b> · precio ERP @Model.ProductoPrecioVenta.ToString("N2") · stock ERP @Model.ProductoStockActual.ToString("N0")</div>
    </div>
</div>

<!-- Flujo guiado -->
<div class="card" style="margin-bottom:16px"><div class="cardpad">
    @if (estaPublicado)
    {
        <div class="okpill" style="font-size:14px"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"></path></svg>Publicado como @Model.PublicadoItemId el @Model.FechaPublicadoUtc?.ToLocalTime().ToString("dd/MM HH:mm")</div>
    }
    else
    {
        <div style="display:flex;gap:10px;align-items:center;margin-bottom:14px">
            @for (var i = 0; i < pasos.Length; i++)
            {
                var n = i + 1;
                var done = n < pasoActual; var cur = n == pasoActual;
                var bg = done ? "var(--green-soft)" : cur ? "var(--gold-soft)" : "var(--panel-2)";
                var col = done ? "var(--green)" : cur ? "var(--gold)" : "var(--faint)";
                <div style="display:flex;align-items:center;gap:8px">
                    <span style="width:26px;height:26px;border-radius:50%;display:grid;place-items:center;background:@bg;color:@col;font-weight:700;font-size:12px;font-family:var(--mono)">@(done ? "✓" : n.ToString())</span>
                    <span style="font-weight:600;font-size:13px;color:@(cur ? "var(--ink)" : "var(--muted)")">@pasos[i]</span>
                    @if (i < pasos.Length - 1)
                    {
                        <span style="width:24px;height:1px;background:var(--line)"></span>
                    }
                </div>
            }
        </div>

        <div id="ml-publish-flow" data-permitir="@(Model.PermitirPublicacionDesdeErp ? "1" : "0")" data-cuenta="@(Model.CuentaConectada ? "1" : "0")" data-validado="@(estaValidado ? "1" : "0")" style="display:flex;gap:12px;align-items:flex-start;justify-content:space-between;flex-wrap:wrap">
            <div style="min-width:0;flex:1">
                <p style="font-weight:600;font-size:13.5px;color:@(estaValidado ? "var(--blue)" : "var(--muted)")" data-ml-status>@(estaValidado ? "Validado — listo para simular. No se enviará nada a Mercado Libre." : "Borrador en edición — completá los datos y validalo.")</p>
                <p class="hint" data-ml-hint style="margin-top:3px">El botón simula por defecto. Marcá «Publicación REAL» solo para enviar a Mercado Libre.</p>
            </div>
            @if (User.TienePermiso("mercadolibre", "sync"))
            {
                <div style="display:flex;gap:9px;align-items:flex-end;flex-wrap:wrap">
                    <form asp-action="BorradorValidar" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn sm" disabled="@(Model.PuedeValidar ? null : "disabled")"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg>Validar</button>
                    </form>
                    <form asp-action="BorradorPublicar" method="post" id="ml-publish-form" style="display:flex;gap:9px;align-items:flex-end">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        @if (estaValidado)
                        {
                            <label class="ml-real-check"><input type="checkbox" name="confirmarReal" value="true" data-ml-real /><span class="ml-real-check__text"><span>Publicación <span class="ml-real-check__flag">REAL</span></span><span class="ml-real-check__hint">Marcá esto solo si querés enviar a Mercado Libre.</span></span></label>
                        }
                        <button type="submit" class="btn primary" id="ml-publish-btn" disabled="@(Model.PuedeSimular ? null : "disabled")"><span class="material-symbols-outlined" data-ml-btn-icon style="font-size:16px">science</span><span data-ml-btn-text>Simular publicación</span></button>
                    </form>
                    <form asp-action="BorradorDescartar" method="post" onsubmit="return confirm('¿Descartar el borrador? Si no se publicó en ML, solo se oculta localmente.');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn ghost" disabled="@(Model.PuedeDescartar ? null : "disabled")" style="color:var(--red)">Descartar</button>
                    </form>
                </div>
            }
        </div>
        <p class="ml-field-error-msg" data-ml-block hidden style="margin-top:8px"></p>

        @if (!estaValidado)
        {
            <div class="tray warn" style="margin-top:12px;margin-bottom:0"><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 11l3 3L22 4"></path><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg></span><b>Validá el borrador</b><span>— cada vez que editás y guardás, hay que volver a validar.</span></div>
        }
    }

    @if (erroresLineas.Length > 0)
    {
        <div class="card" style="margin-top:12px" data-ml-campos-error="@string.Join(",", camposError)"><div class="cardpad">
            <div style="font-size:10.5px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--faint);margin-bottom:6px">Última validación / respuesta de ML (@Model.FechaValidacionUtc?.ToLocalTime().ToString("dd/MM HH:mm"))</div>
            @foreach (var linea in erroresLineas.Where(l => !l.StartsWith("CAMPOS_ERROR:") && !l.StartsWith("ATRIBUTOS_ERROR:")))
            {
                <div style="font-size:12px;color:@(linea.StartsWith("ERROR") ? "var(--red)" : "var(--amber)")">@linea</div>
            }
        </div></div>
    }
</div></div>

<!-- Formulario -->
@if (Model.PuedeEditar && User.TienePermiso("mercadolibre", "sync"))
{
    <form asp-action="BorradorActualizar" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ProductoId" />

        <div class="card"><div class="cardpad">
            <div class="subsec" style="cursor:default"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="16" rx="2"></rect><path d="M3 9h18M8 4v16"></path></svg>Datos de la publicación</div>
            <div class="formgrid">
                <div class="field full" data-ml-field="title">
                    <label asp-for="Titulo">Título <span class="req">*</span></label>
                    <input asp-for="Titulo" maxlength="60" />
                    <span asp-validation-for="Titulo" style="color:var(--red);font-size:11.5px"></span>
                </div>
                <div class="field full" data-ml-field="category_id" id="ml-categoria-picker"
                     data-url-sugerencias="@Url.Action("CategoriaSugerencias")"
                     data-url-hijos="@Url.Action("CategoriaHijos")"
                     data-url-resolver="@Url.Action("CategoriaResolver")">
                    <label>Categoría ML <span class="req">*</span></label>
                    <input type="hidden" asp-for="CategoryIdMl" />
                    <input type="hidden" asp-for="CategoryNombre" />
                    <input type="hidden" asp-for="CategoryPathFromRoot" />
                    <input type="hidden" asp-for="CategoryEsHoja" />
                    <div data-rol="seleccion" class="catpath"></div>
                    <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:8px">
                        <button type="button" data-rol="sugerir" class="btn sm">Sugerir por título</button>
                        <button type="button" data-rol="arbol" class="btn sm ghost">Navegar árbol</button>
                    </div>
                    <div style="display:flex;gap:8px;margin-top:8px">
                        <input type="text" data-rol="buscar" placeholder="Buscar categoría por texto" />
                        <button type="button" data-rol="buscar-btn" class="btn sm">Buscar</button>
                    </div>
                    <ul data-rol="resultados" style="margin-top:8px;max-height:220px;overflow-y:auto;list-style:none"></ul>
                    <p data-rol="estado" class="hint"></p>
                    <span asp-validation-for="CategoryIdMl" style="color:var(--red);font-size:11.5px"></span>
                    <span class="hint">Solo se puede publicar en categorías hoja.</span>
                </div>
                <div class="field" data-ml-field="condition">
                    <label asp-for="Condicion">Condición</label>
                    <select asp-for="Condicion"><option value="new">Nuevo</option><option value="used">Usado</option></select>
                </div>
                <div class="field" data-ml-field="listing_type_id">
                    <label asp-for="ListingTypeId">Tipo de publicación</label>
                    <select asp-for="ListingTypeId" data-ml-listing-type><option value="gold_special">Clásica</option><option value="gold_pro">Premium</option><option value="free">Gratuita</option></select>
                </div>
            </div>
        </div></div>

        <div class="card"><div class="cardpad">
            <div class="subsec" style="cursor:default"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7l4-4 4 4M7 3v8M21 17l-4 4-4-4M17 21v-8"></path></svg>Precio y stock</div>
            <div class="formgrid">
                <div class="field" data-ml-field="price">
                    <label asp-for="Precio">Precio <span class="req">*</span></label>
                    <div class="suffix"><input asp-for="Precio" type="number" step="0.01" /><span class="u">ARS</span></div>
                    <span asp-validation-for="Precio" style="color:var(--red);font-size:11.5px"></span>
                </div>
                <div class="field" data-ml-field="available_quantity">
                    <label asp-for="Stock">Stock a publicar <span class="req">*</span></label>
                    <input asp-for="Stock" type="number" step="1" min="0" />
                    <span asp-validation-for="Stock" style="color:var(--red);font-size:11.5px"></span>
                    <span class="hint">Podés bajarlo respecto del stock ERP, pero no superarlo. No modifica el inventario.</span>
                </div>
            </div>
        </div></div>

        @{
            var atributosInicial = Model.AtributosRequeridos.Select(a => new
            {
                attributeId = a.AttributeId, name = a.Name, valueType = a.ValueType,
                esBloqueante = a.EsBloqueante, esRecomendado = a.EsRecomendado, hint = a.Hint, tooltip = a.Tooltip,
                valueMaxLength = a.ValueMaxLength, defaultUnit = a.DefaultUnit, multivalued = a.Multivalued,
                values = a.Values.Select(v => new { id = v.Id, name = v.Name }),
                allowedUnits = a.AllowedUnits.Select(u => new { id = u.Id, name = u.Name }),
                valueId = Model.Atributos.FirstOrDefault(x => x.Id == a.AttributeId)?.ValueId,
                valueName = Model.Atributos.FirstOrDefault(x => x.Id == a.AttributeId)?.ValueName
            });
            var atributosInicialJson = System.Text.Json.JsonSerializer.Serialize(atributosInicial);
        }
        <div class="card"><div class="cardpad">
            <div class="subsec" style="cursor:default"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 5h16M4 12h16M4 19h10"></path></svg>Atributos de categoría</div>
            <div id="ml-atributos" data-url-atributos="@Url.Action("CategoriaAtributos")" data-catalogo-importado="@(Model.CatalogoImportado ? "true" : "false")" data-atributos-error="@string.Join(",", atributosError)">
                <div data-rol="atributos-contenedor" style="display:flex;flex-direction:column;gap:12px"></div>
                <p data-rol="atributos-estado" class="hint" style="margin-top:6px"></p>
                <script type="application/json" data-ml-attrs-initial>@Html.Raw(atributosInicialJson)</script>
            </div>
        </div></div>

        <div class="card"><div class="cardpad">
            <div class="subsec" style="cursor:default"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><path d="M21 15l-5-5L5 21"></path></svg>Imágenes</div>
            <div data-ml-field="pictures" id="ml-imagenes" data-url-subir="@Url.Action("BorradorSubirImagen")" data-borrador-id="@Model.Id">
                <div style="display:flex;flex-wrap:wrap;align-items:center;gap:8px">
                    <label class="btn sm" style="cursor:pointer"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"></path></svg>Seleccionar imágenes<input type="file" accept="image/png,image/jpeg" multiple class="hidden" data-ml-img-file /></label>
                    <span class="hint" data-ml-img-status aria-live="polite"></span>
                </div>
                <div class="ml-img-preview" data-ml-img-preview hidden style="margin-top:10px"></div>
                <span class="hint" style="display:block;margin-top:10px">Subí imágenes (JPG/PNG, máx. 5 MB). ML exige al menos una para publicación gratuita [free].</span>
                <details style="margin-top:8px">
                    <summary class="hint" style="cursor:pointer">Pegar URLs manualmente (avanzado)</summary>
                    <textarea asp-for="ImagenesUrls" rows="3" placeholder="Una URL http/https por línea" data-ml-img-input style="margin-top:8px"></textarea>
                </details>
                <p class="ml-img-note" data-ml-img-note hidden style="margin-top:8px"><span class="material-symbols-outlined" style="font-size:14px">warning</span><span data-ml-img-note-text></span></p>
            </div>
        </div></div>

        <div class="card"><div class="cardpad">
            <div class="subsec" style="cursor:default"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h10"></path></svg>Descripción</div>
            <div class="field full"><textarea asp-for="Descripcion" rows="5"></textarea></div>
            <div class="field full" style="margin-top:14px"><label asp-for="Garantia">Garantía (informativo)</label><input asp-for="Garantia" placeholder="Ej: Garantía oficial 12 meses" /></div>
        </div></div>

        <div style="display:flex;justify-content:flex-end;gap:9px;margin-top:18px">
            <button type="submit" class="btn primary"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2zM17 21v-8H7v8M7 3v5h8"></path></svg>Guardar borrador</button>
        </div>
    </form>
}
else
{
    <div class="card"><div class="cardpad">
        <div class="subsec" style="cursor:default">Contenido</div>
        <div class="strip" style="margin:0;border-radius:11px">
            <div class="cell"><span class="lbl">Título</span><span class="val">@Model.Titulo</span></div>
            <div class="cell"><span class="lbl">Precio</span><span class="val mono">@Model.Precio.ToString("N2")</span></div>
            <div class="cell"><span class="lbl">Stock</span><span class="val mono">@Model.Stock</span></div>
            <div class="cell"><span class="lbl">Categoría</span><span class="val">@(Model.CategoryNombre ?? "—")</span></div>
            <div class="cell"><span class="lbl">Condición</span><span class="val">@Model.Condicion · @Model.ListingTypeId</span></div>
        </div>
        @if (Model.Imagenes.Count > 0)
        {
            <div class="imgslots" style="margin-top:16px">
                @foreach (var url in Model.Imagenes)
                {
                    <div class="imgslot filled" style="overflow:hidden"><img src="@url" alt="Imagen" loading="lazy" style="width:100%;height:100%;object-fit:cover" /></div>
                }
            </div>
        }
    </div></div>
}

@section Scripts {
    <script src="~/js/mercadolibre-categoria-picker.js" asp-append-version="true"></script>
    <script src="~/js/mercadolibre-borrador-atributos.js" asp-append-version="true"></script>
    <script>
        (function () {
            var flow = document.getElementById('ml-publish-flow');
            if (!flow) return;
            var real = flow.querySelector('[data-ml-real]');
            var btn = document.getElementById('ml-publish-btn');
            var btnText = flow.querySelector('[data-ml-btn-text]');
            var btnIcon = flow.querySelector('[data-ml-btn-icon]');
            var status = flow.querySelector('[data-ml-status]');
            var hint = flow.querySelector('[data-ml-hint]');
            var block = document.querySelector('[data-ml-block]');
            var form = document.getElementById('ml-publish-form');
            var permitir = flow.getAttribute('data-permitir') === '1';
            var cuenta = flow.getAttribute('data-cuenta') === '1';
            var validado = flow.getAttribute('data-validado') === '1';
            function setBlock(msg) { if (!block) return; if (msg) { block.textContent = msg; block.hidden = false; } else { block.textContent = ''; block.hidden = true; } }
            function apply() {
                if (!btn || !validado) return;
                var quiereReal = real && real.checked;
                if (!quiereReal) {
                    if (btnText) btnText.textContent = 'Simular publicación';
                    if (btnIcon) btnIcon.textContent = 'science';
                    if (status) status.textContent = 'Listo para simular. No se enviará nada a Mercado Libre.';
                    btn.disabled = false; setBlock(''); return;
                }
                if (!permitir) { if (btnText) btnText.textContent = 'Publicar en Mercado Libre'; if (btnIcon) btnIcon.textContent = 'public'; btn.disabled = true; if (status) status.textContent = 'Publicación real bloqueada.'; setBlock('La publicación real está deshabilitada en Configuración.'); return; }
                if (!cuenta) { if (btnText) btnText.textContent = 'Publicar en Mercado Libre'; if (btnIcon) btnIcon.textContent = 'public'; btn.disabled = true; if (status) status.textContent = 'Falta cuenta conectada.'; setBlock('Conectá una cuenta de Mercado Libre para publicar de verdad.'); return; }
                if (btnText) btnText.textContent = 'Publicar en Mercado Libre'; if (btnIcon) btnIcon.textContent = 'publish'; btn.disabled = false; if (status) status.textContent = 'Publicación real: se enviará a Mercado Libre tras confirmar.'; setBlock('');
            }
            if (real) real.addEventListener('change', apply);
            if (form) { form.addEventListener('submit', function (e) { var quiereReal = real && real.checked; var msg = quiereReal ? '¿Publicar este borrador REALMENTE en Mercado Libre?' : '¿Simular este borrador localmente? No llama a Mercado Libre.'; if (!window.confirm(msg)) { e.preventDefault(); } }); }
            apply();
        })();
        (function () {
            var summary = document.querySelector('[data-ml-campos-error]');
            if (!summary) return;
            (summary.getAttribute('data-ml-campos-error') || '').split(',').map(function (t) { return t.trim(); }).filter(Boolean).forEach(function (token) {
                var field = document.querySelector('[data-ml-field="' + token + '"]'); if (field) field.classList.add('ml-field-error');
            });
        })();
        (function () {
            var input = document.querySelector('[data-ml-img-input]');
            if (!input) return;
            var contenedor = document.getElementById('ml-imagenes');
            var preview = document.querySelector('[data-ml-img-preview]');
            var note = document.querySelector('[data-ml-img-note]');
            var noteText = document.querySelector('[data-ml-img-note-text]');
            var listingType = document.querySelector('[data-ml-listing-type]');
            var fileInput = document.querySelector('[data-ml-img-file]');
            var status = document.querySelector('[data-ml-img-status]');
            var urlSubir = contenedor ? contenedor.getAttribute('data-url-subir') : null;
            var borradorId = contenedor ? contenedor.getAttribute('data-borrador-id') : null;
            var tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
            function parseUrls() { return (input.value || '').split(/\r?\n/).map(function (s) { return s.trim(); }).filter(Boolean); }
            function setUrls(urls) { input.value = urls.join('\n'); render(); }
            function addUrl(u) { var urls = parseUrls(); if (urls.indexOf(u) === -1) { urls.push(u); setUrls(urls); } }
            function removeUrl(u) { setUrls(parseUrls().filter(function (x) { return x !== u; })); }
            function esValida(u) { return /^https?:\/\//i.test(u); }
            function render() {
                var urls = parseUrls();
                if (preview) {
                    preview.innerHTML = '';
                    urls.forEach(function (u) {
                        if (!esValida(u)) return;
                        var wrap = document.createElement('div'); wrap.className = 'ml-img-thumb'; wrap.title = u;
                        var img = document.createElement('img'); img.src = u; img.alt = 'Imagen'; img.loading = 'lazy';
                        var btn = document.createElement('button'); btn.type = 'button'; btn.className = 'ml-img-remove'; btn.setAttribute('aria-label', 'Quitar imagen'); btn.textContent = '×';
                        btn.addEventListener('click', function () { removeUrl(u); });
                        wrap.appendChild(img); wrap.appendChild(btn); preview.appendChild(wrap);
                    });
                    preview.hidden = preview.children.length === 0;
                }
                var invalidas = urls.filter(function (u) { return !esValida(u); });
                var esFree = listingType && (listingType.value || '').toLowerCase() === 'free';
                var msg = '';
                if (invalidas.length > 0) { msg = invalidas.length + ' URL inválida(s): usá http o https completas.'; }
                else if (esFree && urls.length === 0) { msg = 'Mercado Libre exige imágenes para publicación gratuita [free].'; }
                if (note && noteText) { if (msg) { noteText.textContent = msg; note.hidden = false; } else { noteText.textContent = ''; note.hidden = true; } }
            }
            async function subir(file) {
                var fd = new FormData(); fd.append('id', borradorId || ''); fd.append('archivo', file);
                if (tokenEl) fd.append('__RequestVerificationToken', tokenEl.value);
                var resp = await fetch(urlSubir, { method: 'POST', body: fd, headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                if (!resp.ok) throw new Error('HTTP ' + resp.status);
                return await resp.json();
            }
            async function onFiles(files) {
                if (!urlSubir || !files || !files.length) return;
                var total = files.length, ok = 0, errores = [];
                if (fileInput) fileInput.disabled = true;
                for (var i = 0; i < files.length; i++) {
                    if (status) status.textContent = 'Subiendo ' + (i + 1) + ' de ' + total + '…';
                    try { var r = await subir(files[i]); if (r && r.ok && r.url) { addUrl(r.url); ok++; } else { errores.push((files[i].name || 'archivo') + ': ' + ((r && r.error) || 'error')); } }
                    catch (e) { errores.push((files[i].name || 'archivo') + ': no se pudo subir'); }
                }
                if (fileInput) { fileInput.disabled = false; fileInput.value = ''; }
                if (errores.length) { if (status) status.textContent = ok + ' subida(s), ' + errores.length + ' con error.'; if (note && noteText) { noteText.textContent = errores.join(' · '); note.hidden = false; } }
                else if (status) { status.textContent = ok + ' imagen(es) agregada(s).'; }
            }
            if (fileInput) fileInput.addEventListener('change', function () { onFiles(this.files); });
            input.addEventListener('input', render);
            if (listingType) listingType.addEventListener('change', render);
            render();
        })();
    </script>
}
