@using TheBuryProject.Modules.MercadoLibre.Entities
@model MercadoLibreListingDetalleViewModel
@{
    ViewData["Title"] = $"Publicación {Model.ItemId}";
    var productosJson = ViewBag.ProductosPickerJson as string ?? "[]";
    var preguntas = ViewBag.Preguntas as List<TheBuryProject.Modules.MercadoLibre.Entities.MercadoLibreQuestion> ?? new();
    var puedeSimularPregunta = ViewBag.PuedeSimularPregunta as bool? ?? false;

    string TipoAmigable(string? t) => t switch { "gold_pro" => "Premium", "gold_special" => "Clásica", "gold" => "Oro", "free" => "Gratuita", _ => t ?? "—" };
    string CondicionAmigable(string? c) => c switch { "new" => "Nuevo", "used" => "Usado", "not_specified" => "Sin especificar", _ => c ?? "—" };
    var estadoStag = Model.EstaActiva ? "active" : Model.EstaPausada ? "paused" : "inactive";
    var estadoLabel = Model.EstaActiva ? "active" : Model.EstaPausada ? "paused" : Model.EstaFinalizada ? "closed" : Model.Status;
}

@section Styles {
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <link rel="stylesheet" href="~/css/mercadolibre1-compat.css" asp-append-version="true" />
}

<!-- ============ LISTING (detalle publicación) ============ -->
<div class="crumb">
    <a asp-action="Listings"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"></path></svg>Publicaciones</a>
    <span class="sep">/</span><span class="cur">@Model.ItemId</span>
</div>
<div class="phead">
    <div>
        <h1><span class="gi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="16" rx="2"></rect><path d="M3 9h18M8 4v16"></path></svg></span>@Model.Titulo</h1>
        <div class="sub" style="display:flex;gap:10px;align-items:center;margin-top:6px;flex-wrap:wrap">
            <span style="font-family:var(--mono);color:var(--blue)">@Model.ItemId</span>
            <span class="stag @estadoStag">@estadoLabel</span>
            <span style="color:var(--faint)">@CondicionAmigable(Model.Condition) · @TipoAmigable(Model.ListingTypeId)</span>
            @if (Model.Vinculada)
            {
                <span class="okpill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"></path></svg>Vinculada</span>
            }
        </div>
    </div>
    @if (!string.IsNullOrEmpty(Model.Permalink))
    {
        <div class="acts">
            <a href="@Model.Permalink" target="_blank" rel="noopener noreferrer" class="btn ghost"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 3h7v7M21 3l-9 9M21 14v5a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5"></path></svg>Abrir en ML</a>
        </div>
    }
</div>

@if (Model.ModoSimulacion)
{
    <div class="tray warn" style="margin-bottom:18px"><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 3h6M10 3v6L5 19a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1l-5-10V3"></path></svg></span><b>Modo simulación</b><span>— lo que hagas acá se registra pero no se envía a Mercado Libre.</span></div>
}

<div class="subtabs" id="liTabs">
    <button type="button" class="subtab active" data-li="resumen">Resumen</button>
    <button type="button" class="subtab" data-li="editar">Editar</button>
    <button type="button" class="subtab" data-li="fotos">Fotos</button>
    <button type="button" class="subtab" data-li="stock">Stock y producto</button>
    <button type="button" class="subtab" data-li="preg">Preguntas @if (preguntas.Count > 0){<span style="opacity:.6">· @preguntas.Count</span>}</button>
    <button type="button" class="subtab" data-li="act">Actividad</button>
</div>

<!-- resumen -->
<div data-li-panel="resumen">
    <div class="tiles">
        <div class="tile"><div class="tl">Precio ML</div><div class="tv">@Model.CurrencyId @Model.Precio.ToString("N2")</div></div>
        <div class="tile"><div class="tl">Stock ML</div><div class="tv">@Model.AvailableQuantity</div></div>
        <div class="tile"><div class="tl">Stock ERP</div><div class="tv green">@(Model.ProductoStockActual?.ToString("N0") ?? "—")</div></div>
        <div class="tile"><div class="tl">Vendidos</div><div class="tv blue">@Model.SoldQuantity</div></div>
    </div>
    <div class="crearwrap">
        <div class="card"><div class="cardpad">
            <div class="subsec" style="cursor:default"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"></circle><path d="M12 8v4M12 16h.01"></path></svg>Datos de la publicación</div>
            <div class="strip" style="margin:0;border-radius:11px">
                <div class="cell"><span class="lbl">Tipo</span><span class="val">@TipoAmigable(Model.ListingTypeId)</span></div>
                <div class="cell"><span class="lbl">Condición</span><span class="val">@CondicionAmigable(Model.Condition)</span></div>
                <div class="cell"><span class="lbl">SKU</span><span class="val mono">@(Model.SellerSku ?? "—")</span></div>
                <div class="cell"><span class="lbl">Producto ERP</span><span class="val">@(Model.Vinculada ? Model.ProductoCodigo : "—")</span></div>
            </div>
            <p class="mlc-section-title" style="margin-top:16px;font-weight:600;font-size:13px;color:var(--muted)">Estado de la publicación</p>
            @if (!Model.EstaFinalizada)
            {
                <div style="display:flex;flex-wrap:wrap;gap:9px;margin-top:6px">
                    @if (Model.EstaActiva)
                    {
                        <form asp-action="ListingCambiarEstado" method="post" onsubmit="return confirm('¿Pausar la publicación en Mercado Libre?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" /><input type="hidden" name="accion" value="pausar" /><input type="hidden" name="confirmarReal" value="true" />
                            <button type="submit" class="btn sm">Pausar publicación</button>
                        </form>
                    }
                    @if (Model.EstaPausada)
                    {
                        <form asp-action="ListingCambiarEstado" method="post" onsubmit="return confirm('¿Reactivar la publicación?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" /><input type="hidden" name="accion" value="reactivar" /><input type="hidden" name="confirmarReal" value="true" />
                            <button type="submit" class="btn sm">Reactivar publicación</button>
                        </form>
                    }
                    <form asp-action="ListingCambiarEstado" method="post" onsubmit="return confirm('FINALIZAR es IRREVERSIBLE en Mercado Libre. ¿Continuar?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" /><input type="hidden" name="accion" value="finalizar" /><input type="hidden" name="confirmarReal" value="true" />
                        <button type="submit" class="btn sm ghost" style="color:var(--red)">Finalizar (irreversible)</button>
                    </form>
                </div>
            }
            else
            {
                <p class="hint">Publicación finalizada: Mercado Libre no permite reactivarla.</p>
            }
        </div></div>

        <div class="rail">
            @if (Model.Desglose is not null)
            {
                var d = Model.Desglose;
                <div class="railcard"><div class="rh">Rentabilidad estimada @if (d.DebajoDelMargenMinimo){<span class="chip bad"><span class="dot"></span>Bajo margen</span>}</div><div class="rb">
                    <div class="totrow"><span class="l">Costo del producto</span><span class="v">@d.Costo.ToString("N2")</span></div>
                    <div class="totrow"><span class="l">Precio ERP</span><span class="v">@d.PrecioErp.ToString("N2")</span></div>
                    <div class="totrow"><span class="l">Precio ML (+@d.AjusteCanalPorcentaje.ToString("0.##")%)</span><span class="v green">@d.PrecioCanal.ToString("N2")</span></div>
                    <div class="totrow"><span class="l">Comisión ML (@d.ComisionPorcentaje.ToString("0.##")%)</span><span class="v red">−@d.ComisionMonto.ToString("N2")</span></div>
                    <div class="totrow"><span class="l">Envío estimado</span><span class="v red">−@d.EnvioEstimado.ToString("N2")</span></div>
                    <div class="totrow big"><span class="l">Neto estimado</span><span class="v">@d.NetoEstimado.ToString("N2")</span></div>
                    <div class="totrow"><span class="l">Ganancia estimada</span><span class="v @(d.GananciaEstimada >= 0 ? "green" : "red")">@d.GananciaEstimada.ToString("N2")</span></div>
                </div></div>
            }
        </div>
    </div>
</div>

<!-- editar -->
<div data-li-panel="editar" class="hide">
    <div class="card"><div class="cardpad">
        <div class="subsec" style="cursor:default"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"></path></svg>Editar publicación</div>
        <form asp-action="ListingEditar" method="post" onsubmit="return confirm('¿Aplicar los cambios a la publicación?');">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="formgrid">
                <div class="field full"><label for="titulo">Título</label><input type="text" name="titulo" id="titulo" maxlength="300" value="@Model.Titulo" /></div>
                <div class="field"><label for="precio">Precio (@Model.CurrencyId)</label><div class="suffix"><input type="number" step="0.01" min="0.01" name="precio" id="precio" value="@Model.Precio.ToString("0.##")" /><span class="u">@Model.CurrencyId</span></div></div>
                <div class="field"><label for="stock">Stock</label><input type="number" min="0" name="stock" id="stock" value="@Model.AvailableQuantity" disabled="@(Model.Variaciones.Count > 1 ? "disabled" : null)" />@if (Model.Variaciones.Count > 1){<span class="hint">Varias variaciones: el stock se edita por variación en Stock.</span>}</div>
                <div class="field"><label for="sellerSku">SKU interno</label><input type="text" name="sellerSku" id="sellerSku" maxlength="100" value="@Model.SellerSku" /></div>
            </div>
            <div style="display:flex;align-items:center;justify-content:flex-end;gap:12px;margin-top:16px">
                @if (!Model.ModoSimulacion)
                {
                    <label class="warnpill" style="cursor:pointer"><input type="checkbox" class="cbx" name="confirmarReal" value="true" style="width:16px;height:16px">Envío REAL</label>
                }
                else
                {
                    <span class="hint" style="color:var(--blue)">Se aplicará en simulación.</span>
                }
                <button type="submit" class="btn primary">Guardar cambios</button>
            </div>
        </form>
    </div></div>

    <div class="card"><div class="cardpad">
        <div class="subsec" style="cursor:default"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 5h16M7 12h10M10 19h4"></path></svg>Categoría</div>
        <p class="hint" style="margin-bottom:10px">Categoría actual: <span style="font-family:var(--mono);color:var(--ink)">@(string.IsNullOrWhiteSpace(Model.CategoryId) ? "sin categoría" : Model.CategoryId)</span>. Solo se publica en categorías hoja.</p>
        <form asp-action="ListingEditarCategoria" method="post" onsubmit="return confirm('¿Cambiar la categoría de la publicación en Mercado Libre?');">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" id="Titulo" value="@Model.Titulo" />
            <div id="ml-categoria-picker" data-ml-field="category_id" data-url-sugerencias="@Url.Action("CategoriaSugerencias")" data-url-hijos="@Url.Action("CategoriaHijos")" data-url-resolver="@Url.Action("CategoriaResolver")">
                <input type="hidden" id="CategoryIdMl" name="categoryId" value="@Model.CategoryId" />
                <input type="hidden" id="CategoryNombre" /><input type="hidden" id="CategoryPathFromRoot" /><input type="hidden" id="CategoryEsHoja" />
                <div data-rol="seleccion" class="catpath"></div>
                <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:8px">
                    <button type="button" data-rol="sugerir" class="btn sm">Sugerir por título</button>
                    <button type="button" data-rol="arbol" class="btn sm ghost">Navegar árbol</button>
                </div>
                <div style="display:flex;gap:8px;margin-top:8px">
                    <input type="text" data-rol="buscar" placeholder="Buscar categoría por texto" />
                    <button type="button" data-rol="buscar-btn" class="btn sm">Buscar</button>
                </div>
                <ul data-rol="resultados" style="margin-top:8px;max-height:220px;overflow-y:auto;list-style:none"></ul>
                <p data-rol="estado" class="hint"></p>
            </div>
            <div style="display:flex;align-items:center;justify-content:flex-end;gap:12px;margin-top:14px">
                @if (!Model.ModoSimulacion)
                {
                    <label class="warnpill" style="cursor:pointer"><input type="checkbox" class="cbx" name="confirmarReal" value="true" style="width:16px;height:16px">Envío REAL</label>
                }
                else { <span class="hint" style="color:var(--blue)">Se aplicará en simulación.</span> }
                <button type="submit" class="btn">Guardar categoría</button>
            </div>
        </form>
    </div></div>

    <div class="card"><div class="cardpad">
        <div class="subsec" style="cursor:default"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h10"></path></svg>Descripción</div>
        @if (!Model.DescripcionConsultada)
        {
            <p class="hint" style="color:var(--amber);margin-bottom:8px">No se pudo consultar la descripción actual en Mercado Libre.</p>
        }
        <form asp-action="ListingEditarDescripcion" method="post" onsubmit="return confirm('¿Reemplazar la descripción de la publicación?');">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="field full"><textarea name="descripcion" rows="6" placeholder="Descripción en texto plano...">@Model.Descripcion</textarea></div>
            <div style="display:flex;align-items:center;justify-content:flex-end;gap:12px;margin-top:14px">
                @if (!Model.ModoSimulacion)
                {
                    <label class="warnpill" style="cursor:pointer"><input type="checkbox" class="cbx" name="confirmarReal" value="true" style="width:16px;height:16px">Envío REAL</label>
                }
                else { <span class="hint" style="color:var(--blue)">Se aplicará en simulación.</span> }
                <button type="submit" class="btn">Guardar descripción</button>
            </div>
        </form>
    </div></div>
</div>

<!-- fotos -->
<div data-li-panel="fotos" class="hide">
    <div class="card"><div class="cardpad">
        <div class="subsec" style="cursor:default"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><path d="M21 15l-5-5L5 21"></path></svg>Fotos actuales</div>
        @if (!Model.ImagenesConsultadas)
        {
            <p class="hint" style="color:var(--amber)">No se pudieron consultar las imágenes actuales en Mercado Libre.</p>
        }
        else if (Model.ImagenesActuales.Any())
        {
            <div class="imgslots">
                @foreach (var img in Model.ImagenesActuales)
                {
                    <div class="imgslot filled" style="overflow:hidden"><img src="@img" alt="Imagen" loading="lazy" style="width:100%;height:100%;object-fit:cover" /></div>
                }
            </div>
        }
        else
        {
            <p class="hint">La publicación no tiene imágenes en Mercado Libre.</p>
        }

        <div class="subsec" style="cursor:default;margin-top:18px"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"></path></svg>Reemplazar fotos</div>
        <form asp-action="ListingEditarImagenes" method="post" data-ml-listing-img data-url-subir="@Url.Action("ListingSubirImagen")" onsubmit="return confirm('¿Reemplazar TODAS las imágenes de la publicación en Mercado Libre?');">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px">
                <label class="btn sm" style="cursor:pointer"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"></path></svg>Subir imágenes<input type="file" accept="image/png,image/jpeg" multiple class="hidden" data-ml-listing-file /></label>
                <span class="hint" data-ml-listing-status></span>
            </div>
            <div class="field full"><textarea name="imagenesUrls" rows="4" placeholder="Una URL por línea (http/https públicas)..." data-ml-listing-urls style="font-family:var(--mono);font-size:12.5px"></textarea></div>
            <p class="hint" style="margin-top:6px">ML descarga las imágenes desde estas URLs: deben ser públicas (no localhost) y reemplazan a todas las actuales.</p>
            <div style="display:flex;align-items:center;justify-content:flex-end;gap:12px;margin-top:14px">
                @if (!Model.ModoSimulacion)
                {
                    <label class="warnpill" style="cursor:pointer"><input type="checkbox" class="cbx" name="confirmarReal" value="true" style="width:16px;height:16px">Envío REAL</label>
                }
                else { <span class="hint" style="color:var(--blue)">Se aplicará en simulación.</span> }
                <button type="submit" class="btn">Aplicar fotos</button>
            </div>
        </form>
        <script>
            (function () {
                var form = document.querySelector('[data-ml-listing-img]');
                if (!form) return;
                var fileInput = form.querySelector('[data-ml-listing-file]');
                var urls = form.querySelector('[data-ml-listing-urls]');
                var status = form.querySelector('[data-ml-listing-status]');
                var urlSubir = form.getAttribute('data-url-subir');
                var token = form.querySelector('input[name="__RequestVerificationToken"]');
                function addUrl(u) { var a = urls.value.split(/\r?\n/).map(function (s) { return s.trim(); }).filter(Boolean); if (a.indexOf(u) === -1) a.push(u); urls.value = a.join('\n'); }
                async function subir(file) { var fd = new FormData(); fd.append('archivo', file); if (token) fd.append('__RequestVerificationToken', token.value); var resp = await fetch(urlSubir, { method: 'POST', body: fd, headers: { 'X-Requested-With': 'XMLHttpRequest' } }); return resp.json(); }
                fileInput.addEventListener('change', async function () {
                    var files = Array.prototype.slice.call(fileInput.files || []); if (!files.length) return;
                    fileInput.disabled = true; var ok = 0, err = 0;
                    for (var i = 0; i < files.length; i++) { status.textContent = 'Subiendo ' + (i + 1) + '/' + files.length + '...'; try { var r = await subir(files[i]); if (r && r.ok && r.url) { addUrl(r.url); ok++; } else { err++; } } catch (e) { err++; } }
                    status.textContent = ok + ' subida(s)' + (err ? ', ' + err + ' con error' : '') + '.'; fileInput.value = ''; fileInput.disabled = false;
                });
            })();
        </script>
    </div></div>
</div>

<!-- stock y producto -->
<div data-li-panel="stock" class="hide">
    <div class="card"><div class="cardpad">
        <div class="subsec" style="cursor:default"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 7l-8-4-8 4 8 4 8-4zM4 7v10l8 4 8-4V7"></path></svg>Producto de tu sistema</div>
        @if (Model.Vinculada)
        {
            <div class="strip" style="margin:0;border-radius:11px">
                <div class="cell"><span class="lbl">Producto</span><span class="val">@Model.ProductoCodigo</span></div>
                <div class="cell"><span class="lbl">Nombre</span><span class="val">@Model.ProductoNombre</span></div>
                <div class="cell"><span class="lbl">Stock ERP</span><span class="val mono">@(Model.ProductoStockActual?.ToString("N0") ?? "—")</span></div>
                <div class="cell"><span class="lbl">Precio ERP</span><span class="val mono">@(Model.ProductoPrecioVenta?.ToString("N2") ?? "—")</span></div>
            </div>
        }
        else
        {
            <div class="tray warn" style="margin:0">
                <span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 9v4M12 17h.01"></path><circle cx="12" cy="12" r="9"></circle></svg></span>
                <b>Sin producto vinculado</b>
                @if (User.TienePermiso("mercadolibre", "link"))
                {
                    <form asp-action="Vincular" method="post" class="ml-listing-link-form" data-listing-id="@Model.Id" style="display:flex;align-items:center;gap:8px;margin-left:auto;flex-wrap:wrap">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="listingId" value="@Model.Id" />
                        <input type="hidden" name="productoId" value="" class="ml-producto-id" />
                        <input type="text" list="ml-productos-datalist" class="ml-producto-picker" placeholder="Código o nombre..." style="background:var(--bg);border:1px solid var(--line-3);border-radius:9px;padding:7px 10px;color:var(--ink);font-size:12.5px;width:180px" />
                        <button type="submit" class="btn sm" disabled>Vincular</button>
                        <a asp-action="ListingCrearProducto" asp-route-id="@Model.Id" class="btn sm ghost">Crear producto</a>
                    </form>
                }
            </div>
        }

        @if (Model.Vinculada && User.TienePermiso("mercadolibre", "sync"))
        {
            <div class="subsec" style="cursor:default;margin-top:18px"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7l4-4 4 4M7 3v8M21 17l-4 4-4-4M17 21v-8"></path></svg>Origen del stock publicado</div>
            <p class="hint" style="margin-bottom:10px">Origen actual: <b style="color:var(--ink)">@Model.OrigenStockEfectivo</b> · stock publicable: <b style="color:var(--ink);font-family:var(--mono)">@(Model.StockDisponibleSegunOrigen?.ToString() ?? "—")</b></p>
            @if (!string.IsNullOrEmpty(Model.AdvertenciaStock))
            {
                <div class="warnpill" style="margin-bottom:10px"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v4M12 17h.01M10.3 3.9 1.8 18h20.4z"></path></svg>@Model.AdvertenciaStock</div>
            }
            <form asp-action="ListingOrigenStock" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="formgrid">
                    <div class="field"><label>Origen de stock</label>
                        <select name="origen">
                            <option value="" selected="@(Model.OrigenStockOverride is null ? "selected" : null)">Usar origen global (@Model.OrigenStockGlobal)</option>
                            <option value="@MercadoLibreOrigenStock.StockLogicoProducto" selected="@(Model.OrigenStockOverride == MercadoLibreOrigenStock.StockLogicoProducto ? "selected" : null)">Stock lógico del producto</option>
                            <option value="@MercadoLibreOrigenStock.StockFisicoDisponible" selected="@(Model.OrigenStockOverride == MercadoLibreOrigenStock.StockFisicoDisponible ? "selected" : null)">Stock físico (unidades EnStock)</option>
                            <option value="@MercadoLibreOrigenStock.UnidadFisicaEspecifica" selected="@(Model.OrigenStockOverride == MercadoLibreOrigenStock.UnidadFisicaEspecifica ? "selected" : null)">Unidad física específica (stock 1)</option>
                        </select>
                    </div>
                    <div class="field"><label>Unidad física</label>
                        <select name="productoUnidadId">
                            <option value="">— unidad física —</option>
                            @foreach (var unidad in Model.UnidadesDisponibles)
                            {
                                <option value="@unidad.Id" selected="@(Model.ProductoUnidadId == unidad.Id ? "selected" : null)">@unidad.Etiqueta</option>
                            }
                        </select>
                    </div>
                </div>
                <button type="submit" class="btn sm" style="margin-top:12px">Guardar origen</button>
            </form>
        }
    </div></div>

    @if (Model.Variaciones.Count > 0)
    {
        <div class="card">
            <div class="card-h"><span class="t">Variaciones (@Model.Variaciones.Count)</span>
                @if (User.TienePermiso("mercadolibre", "sync"))
                {
                    <form asp-action="SyncPreview" method="post"><input type="hidden" name="listingIds" value="@Model.Id" /><input type="hidden" name="tipo" value="StockYPrecio" />@Html.AntiForgeryToken()<button type="submit" class="btn sm">Previsualizar por variación</button></form>
                }
            </div>
            <table class="tbl">
                <thead><tr><th>Variación</th><th>Atributos</th><th class="num">ML</th><th>Producto</th><th>Origen stock</th></tr></thead>
                <tbody>
                    @foreach (var v in Model.Variaciones)
                    {
                        <tr>
                            <td><div class="prod"><span class="pt" style="font-family:var(--mono);font-size:12px">@v.VariationId</span><span class="pm">@(v.SellerSku ?? "SKU —")</span></div></td>
                            <td style="color:var(--muted)">@(v.Atributos ?? "—")</td>
                            <td class="num">@v.Precio.ToString("N2")<div class="le" style="font-size:11px;color:var(--faint)">stock @v.AvailableQuantity</div></td>
                            <td>@if (!string.IsNullOrWhiteSpace(v.ProductoCodigo)){<span style="font-family:var(--mono);color:var(--blue)">@v.ProductoCodigo</span>}else{<span class="warnpill">Sin resolver</span>}</td>
                            <td><span style="font-size:12px">@v.OrigenStockEfectivo</span><div class="le" style="font-size:10.5px;color:var(--faint)">publicable: @(v.StockDisponibleSegunOrigen?.ToString() ?? "—")</div></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- preguntas -->
<div data-li-panel="preg" class="hide">
    <div class="card">
        <div class="card-h"><span class="t">Preguntas de esta publicación (@preguntas.Count)</span>
            @if (puedeSimularPregunta)
            {
                <form asp-action="PreguntaSimular" method="post" style="display:flex;gap:8px">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="listingId" value="@Model.Id" />
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                    <input type="text" name="texto" maxlength="2000" required placeholder="Pregunta de prueba (QA)..." style="background:var(--bg);border:1px solid var(--line-3);border-radius:9px;padding:7px 10px;color:var(--ink);font-size:12.5px;width:240px" />
                    <button type="submit" class="btn sm">Simular pregunta</button>
                </form>
            }
        </div>
        @if (preguntas.Count == 0)
        {
            <div class="empty"><b>Sin preguntas</b><p>Todavía no hay preguntas para esta publicación.</p></div>
        }
        else
        {
            <table class="tbl">
                <thead><tr><th>Fecha</th><th>Pregunta</th><th>Estado</th><th style="text-align:right">Acciones</th></tr></thead>
                <tbody>
                    @foreach (var p in preguntas)
                    {
                        <tr>
                            <td style="color:var(--muted);white-space:nowrap">@p.FechaPreguntaUtc.ToLocalTime().ToString("dd/MM HH:mm")</td>
                            <td style="max-width:420px">@p.TextoPregunta@if (!string.IsNullOrEmpty(p.RespuestaTexto)){<div class="le" style="font-size:12px;color:var(--green);margin-top:4px;border-left:2px solid rgba(55,211,153,.4);padding-left:8px">@p.RespuestaTexto</div>}</td>
                            <td>
                                @if (p.Estado == MercadoLibreQuestionEstado.Respondida){<span class="chip ok"><span class="dot"></span>Respondida</span>}
                                else if (p.Estado == MercadoLibreQuestionEstado.Error){<span class="chip bad"><span class="dot"></span>Error</span>}
                                else {<span class="chip warn"><span class="dot"></span>Pendiente</span>}
                                @if (p.EsSimulada){<span class="chip info" style="margin-left:4px"><span class="dot"></span>sim</span>}
                            </td>
                            <td style="text-align:right">
                                @if (p.Estado == MercadoLibreQuestionEstado.Pendiente)
                                {
                                    <a asp-action="Pregunta" asp-route-id="@p.Id" class="btn sm primary"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 17l-5-5 5-5M4 12h11a5 5 0 0 1 0 10h-1"></path></svg>Responder</a>
                                }
                                else
                                {
                                    <a asp-action="Pregunta" asp-route-id="@p.Id" class="btn sm">Ver</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<!-- actividad -->
<div data-li-panel="act" class="hide">
    <div class="card"><div class="cardpad">
        @if (Model.UltimosLogs.Count == 0)
        {
            <div class="empty"><b>Sin actividad registrada</b></div>
        }
        else
        {
            <div class="timeline">
                @foreach (var log in Model.UltimosLogs)
                {
                    <div class="tline @(log.Exito ? "green" : "amber")">
                        <div class="tdot"><span class="d">@if (log.Exito){<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"></path></svg>}else{<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v4M12 17h.01"></path><circle cx="12" cy="12" r="9"></circle></svg>}</span></div>
                        <div class="tbody"><b>@log.Operacion</b><div class="tm">@log.Detalle</div><div class="tt">@log.Fecha.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div></div>
                    </div>
                }
            </div>
        }
    </div></div>
</div>

<datalist id="ml-productos-datalist"></datalist>

@section Scripts {
    <script src="~/js/mercadolibre-categoria-picker.js" asp-append-version="true"></script>
    <script>
        (function () {
            'use strict';
            var productos = @Html.Raw(productosJson);
            var datalist = document.getElementById('ml-productos-datalist');
            if (datalist) {
                productos.forEach(function (p) { var o = document.createElement('option'); o.value = p.codigo + ' - ' + p.nombre; o.dataset.id = p.id; datalist.appendChild(o); });
            }
            document.querySelectorAll('.ml-listing-link-form').forEach(function (form) {
                var picker = form.querySelector('.ml-producto-picker'); var hidden = form.querySelector('.ml-producto-id'); var submit = form.querySelector('button[type="submit"]');
                if (!picker || !hidden || !submit) return;
                picker.addEventListener('input', function () { var m = productos.find(function (p) { return (p.codigo + ' - ' + p.nombre) === picker.value; }); hidden.value = m ? m.id : ''; submit.disabled = !m; });
                form.addEventListener('submit', function (e) { if (!hidden.value) e.preventDefault(); });
            });
        })();
    </script>
}
