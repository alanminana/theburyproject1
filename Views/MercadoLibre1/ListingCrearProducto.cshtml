@using TheBuryProject.Models.Entities
@model MercadoLibreCrearProductoViewModel
@{
    ViewData["Title"] = "Crear producto desde publicación";
    var categorias = ViewBag.Categorias as IEnumerable<Categoria> ?? Enumerable.Empty<Categoria>();
    var marcas = ViewBag.Marcas as IEnumerable<Marca> ?? Enumerable.Empty<Marca>();
}

<!-- ============ CREAR PRODUCTO DESDE PUBLICACIÓN ============ -->
<div class="crumb">
    <a asp-action="Listings"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"></path></svg>Publicaciones</a>
    <span class="sep">/</span><span class="cur">Crear producto</span>
</div>
<div class="phead">
    <div>
        <h1><span class="gi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"></rect><path d="M12 8v8M8 12h8"></path></svg></span>Crear producto desde publicación</h1>
        <div class="sub">Crea un Producto interno con los datos de la publicación y lo deja vinculado. <b style="color:var(--blue)">No modifica nada en Mercado Libre.</b></div>
    </div>
</div>

<div class="picker" style="margin-bottom:18px">
    <span class="thumb"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="16" rx="2"></rect><path d="M3 9h18M8 4v16"></path></svg></span>
    <div class="pinfo">
        <b>@Model.ListingTitulo</b>
        <small>@Model.ListingItemId · precio ML @Model.ListingPrecio.ToString("N2") · stock ML @Model.ListingStock@(string.IsNullOrEmpty(Model.ListingSku) ? "" : " · SKU " + Model.ListingSku)</small>
    </div>
    @if (!string.IsNullOrEmpty(Model.ListingPermalink))
    {
        <a href="@Model.ListingPermalink" target="_blank" rel="noopener noreferrer" class="btn sm"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 3h7v7M21 3l-9 9M21 14v5a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5"></path></svg>Ver en ML</a>
    }
</div>

<form asp-action="ListingCrearProducto" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ListingId" />
    <input type="hidden" asp-for="ListingItemId" />
    <input type="hidden" asp-for="ListingTitulo" />
    <input type="hidden" asp-for="ListingPrecio" />
    <input type="hidden" asp-for="ListingStock" />
    <input type="hidden" asp-for="ListingSku" />
    <input type="hidden" asp-for="ListingCondicion" />
    <input type="hidden" asp-for="ListingPermalink" />

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:22px;align-items:start">
        <div class="card"><div class="cardpad">
            <div class="subsec" style="cursor:default">Identificación</div>
            <div class="formgrid" style="grid-template-columns:1fr">
                <div class="field full"><label asp-for="Codigo">Código interno</label><input asp-for="Codigo" /><span asp-validation-for="Codigo" style="color:var(--red);font-size:11.5px"></span></div>
                <div class="field full"><label asp-for="Nombre">Nombre</label><input asp-for="Nombre" /><span asp-validation-for="Nombre" style="color:var(--red);font-size:11.5px"></span></div>
                <div class="field full"><label asp-for="Descripcion">Descripción (opcional)</label><textarea asp-for="Descripcion" rows="3"></textarea></div>
                <div class="field"><label asp-for="CategoriaId">Categoría</label>
                    <select asp-for="CategoriaId"><option value="">Elegir...</option>@foreach (var c in categorias){<option value="@c.Id">@c.Nombre</option>}</select>
                    <span asp-validation-for="CategoriaId" style="color:var(--red);font-size:11.5px"></span>
                </div>
                <div class="field"><label asp-for="MarcaId">Marca</label>
                    <select asp-for="MarcaId"><option value="">Elegir...</option>@foreach (var m in marcas){<option value="@m.Id">@m.Nombre</option>}</select>
                    <span asp-validation-for="MarcaId" style="color:var(--red);font-size:11.5px"></span>
                </div>
            </div>
        </div></div>

        <div class="card"><div class="cardpad">
            <div class="subsec" style="cursor:default">Precios y stock</div>
            <div class="formgrid">
                <div class="field"><label asp-for="PrecioCompra">Precio de costo</label><div class="suffix"><input asp-for="PrecioCompra" type="number" step="0.01" /><span class="u">ARS</span></div><span asp-validation-for="PrecioCompra" style="color:var(--red);font-size:11.5px"></span></div>
                <div class="field"><label asp-for="PrecioVenta">Precio de venta</label><div class="suffix"><input asp-for="PrecioVenta" type="number" step="0.01" /><span class="u">ARS</span></div><span class="hint">Prellenado con el precio ML; ajustalo si difiere.</span><span asp-validation-for="PrecioVenta" style="color:var(--red);font-size:11.5px"></span></div>
                <div class="field"><label asp-for="PorcentajeIVA">IVA <span class="req">%</span></label><div class="suffix"><input asp-for="PorcentajeIVA" type="number" step="0.5" /><span class="u">%</span></div><span asp-validation-for="PorcentajeIVA" style="color:var(--red);font-size:11.5px"></span></div>
                <div class="field"><label asp-for="StockInicial">Stock inicial</label><input asp-for="StockInicial" type="number" step="1" /><span class="hint">Genera un movimiento "Stock inicial" en el kardex. Poné 0 si lo cargás por compras.</span><span asp-validation-for="StockInicial" style="color:var(--red);font-size:11.5px"></span></div>
                <div class="field full">
                    <label class="checkline" style="background:none;border:0;padding:0;cursor:pointer"><input asp-for="RequiereNumeroSerie" class="cbx" type="checkbox"><span><b style="color:var(--ink)">Producto trazable</b><div class="cm">Requiere unidad física / número de serie para vender.</div></span></label>
                </div>
            </div>
        </div></div>
    </div>

    <div style="display:flex;justify-content:flex-end;gap:9px;margin-top:18px">
        <a asp-action="Listings" class="btn ghost">Cancelar</a>
        <button type="submit" class="btn primary"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"></rect><path d="M12 8v8M8 12h8"></path></svg>Crear producto y vincular</button>
    </div>
</form>
