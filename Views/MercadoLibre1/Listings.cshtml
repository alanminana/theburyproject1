@model List<MercadoLibreListingViewModel>
@{
    ViewData["Title"] = "Publicaciones Mercado Libre";
    var filtro = ViewBag.Filtro as string;
    var productosJson = ViewBag.ProductosPickerJson as string ?? "[]";
    var vinculadas = Model.Count(l => l.Vinculada);
    var sinVincular = Model.Count - vinculadas;
    var conVariaciones = Model.Count(l => l.TieneVariaciones);
    var canSync = User.TienePermiso("mercadolibre", "sync");
    string FChip(string f) => filtro == f || (string.IsNullOrEmpty(filtro) && f == "") ? "fchip on" : "fchip";
}

<!-- ============ PUBLICACIONES ============ -->
<div class="phead">
    <div>
        <h1><span class="gi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="16" rx="2"></rect><path d="M3 9h18M8 4v16"></path></svg></span>Publicaciones</h1>
        <div class="sub">@Model.Count importadas · @vinculadas vinculadas · @sinVincular sin vincular</div>
    </div>
    @if (canSync)
    {
        <div class="acts">
            <span class="actlbl">Acciones</span>
            <a class="btn primary" asp-action="Borradores"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"></path></svg>Crear publicación</a>
            <a class="btn" asp-action="Aumentos"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 17l6-6 4 4 8-8M21 7v5M21 7h-5"></path></svg>Aumentos masivos</a>
        </div>
    }
</div>

<form id="ml-sync-form" asp-action="SyncPreview" method="post">
    @Html.AntiForgeryToken()

    <div class="filters">
        <a asp-action="Listings" class="@FChip("")">Todas <span class="cnt">@Model.Count</span></a>
        <a asp-action="Listings" asp-route-filtro="vinculadas" class="@FChip("vinculadas")">Vinculadas <span class="cnt">@vinculadas</span></a>
        <a asp-action="Listings" asp-route-filtro="sin-vincular" class="@FChip("sin-vincular")">Sin vincular <span class="cnt">@sinVincular</span></a>
        <a asp-action="Listings" asp-route-filtro="con-variaciones" class="@FChip("con-variaciones")">Con variaciones <span class="cnt">@conVariaciones</span></a>
        <a asp-action="Listings" asp-route-filtro="con-error" class="fchip bad-f@(filtro == "con-error" ? " on" : "")"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"></circle><path d="M12 8v4M12 16h.01"></path></svg>Con error</a>
        @if (canSync)
        {
            <div class="fspacer"></div>
            <select name="tipo" class="select" aria-label="Qué sincronizar">
                <option value="StockYPrecio">Sync: Stock y precio</option>
                <option value="Stock">Sync: Solo stock</option>
                <option value="Precio">Sync: Solo precio</option>
            </select>
            <button class="btn primary" id="syncPrev" type="submit" disabled><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 0 1 15-6.7L21 8M21 3v5h-5M21 12a9 9 0 0 1-15 6.7L3 16M3 21v-5h5"></path></svg>Previsualizar sync (<span id="selCnt">0</span>)</button>
        }
    </div>

    @if (Model.Count == 0)
    {
        <div class="card">
            <div class="empty">
                <span class="eic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="16" rx="2"></rect><path d="M3 9h18M8 4v16"></path></svg></span>
                <b>No hay publicaciones importadas</b>
                <p>Usá "Importar publicaciones" desde la pantalla de conexión para traer las publicaciones existentes del vendedor.</p>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            @if (canSync)
            {
                <div class="selbar hide" id="selbar">
                    <span class="cnt"><span id="selCnt2">0</span> seleccionadas</span>
                    <div class="sp"></div>
                    <button class="btn sm primary" type="submit">Previsualizar sync</button>
                </div>
            }
            <table class="tbl">
                <thead><tr>
                    <th class="ck"><input type="checkbox" class="cbx" id="ckAll"></th>
                    <th>Publicación</th><th>Estado</th><th class="num">Precio ML</th><th class="num">Stock ML</th>
                    <th>SKU</th><th>Producto vinculado</th><th style="text-align:right">Acciones</th>
                </tr></thead>
                <tbody>
                    @foreach (var listing in Model)
                    {
                        <tr>
                            <td class="ck">
                                @if (listing.Vinculada && canSync)
                                {
                                    <input type="checkbox" class="cbx rowck" name="listingIds" value="@listing.Id" aria-label="Seleccionar @listing.ItemId" />
                                }
                            </td>
                            <td>
                                <div class="prod">
                                    <a class="pt" asp-action="Listing" asp-route-id="@listing.Id" style="text-decoration:none;color:inherit" title="@listing.Titulo">@listing.Titulo</a>
                                    <span class="pm">@listing.ItemId@(listing.TieneVariaciones ? $" · {listing.CantidadVariaciones} variaciones" : "")</span>
                                </div>
                            </td>
                            <td>
                                @if (listing.Status == "active")
                                {
                                    <span class="stag active">activa</span>
                                }
                                else if (listing.Status == "paused")
                                {
                                    <span class="stag paused">pausada</span>
                                }
                                else
                                {
                                    <span class="stag inactive">@listing.Status</span>
                                }
                                @if (!string.IsNullOrEmpty(listing.SubStatus))
                                {
                                    <div class="le" style="font-family:var(--mono);font-size:10.5px;color:var(--faint);margin-top:3px">@listing.SubStatus</div>
                                }
                            </td>
                            <td class="num">@listing.Precio.ToString("N2") <small>@listing.CurrencyId</small></td>
                            <td class="num">@listing.AvailableQuantity</td>
                            <td><span style="font-family:var(--mono);font-size:12px;color:var(--muted)">@(listing.SellerSku ?? "—")</span></td>
                            <td>
                                @if (listing.Vinculada)
                                {
                                    <div class="link">
                                        <span class="lc">@listing.ProductoCodigo</span>
                                        <span class="ld">@listing.ProductoNombre</span>
                                        <span class="le">stock ERP @(listing.ProductoStockActual?.ToString("N0") ?? "—") · precio ERP @(listing.ProductoPrecioVenta?.ToString("N2") ?? "—")</span>
                                    </div>
                                }
                                else if (listing.ProductoSugeridoId.HasValue)
                                {
                                    <form asp-action="Vincular" method="post" style="display:flex;align-items:center;gap:8px">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="listingId" value="@listing.Id" />
                                        <input type="hidden" name="productoId" value="@listing.ProductoSugeridoId" />
                                        <span class="warnpill" title="Coincidencia por SKU">Sugerido: @listing.ProductoSugeridoNombre</span>
                                        <button type="submit" class="btn sm">Vincular</button>
                                    </form>
                                }
                                else
                                {
                                    <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
                                        <form asp-action="Vincular" method="post" class="ml-listing-link-form" data-listing-id="@listing.Id" style="display:flex;align-items:center;gap:8px">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="listingId" value="@listing.Id" />
                                            <input type="hidden" name="productoId" value="" class="ml-producto-id" />
                                            <input type="text" list="ml-productos-datalist" class="ml-producto-picker" placeholder="Código o nombre..." style="background:var(--bg);border:1px solid var(--line-3);border-radius:9px;padding:7px 10px;color:var(--ink);font-size:12.5px;width:170px" aria-label="Buscar producto para vincular" />
                                            <button type="submit" class="btn sm" disabled>Vincular</button>
                                        </form>
                                        @if (User.TienePermiso("mercadolibre", "link"))
                                        {
                                            <a asp-action="ListingCrearProducto" asp-route-id="@listing.Id" class="btn sm ghost" title="Crear producto interno y vincularlo">Crear producto</a>
                                        }
                                    </div>
                                }
                            </td>
                            <td>
                                <div class="rowacts">
                                    @if (!string.IsNullOrEmpty(listing.Permalink))
                                    {
                                        <a href="@listing.Permalink" target="_blank" rel="noopener noreferrer" class="iconbtn go" title="Ver en Mercado Libre"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 3h7v7M21 3l-9 9M21 14v5a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5"></path></svg></a>
                                    }
                                    <a asp-action="Listing" asp-route-id="@listing.Id" class="iconbtn" title="Abrir detalle / editar"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"></path></svg></a>
                                    @if (listing.Vinculada)
                                    {
                                        <button type="button" class="iconbtn danger" title="Desvincular producto" onclick="this.closest('tr').querySelector('.ml-unlink-form').requestSubmit()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 17H7a5 5 0 0 1 0-10h2M15 7h2a5 5 0 0 1 0 10h-2M8 12h8M4 4l16 16"></path></svg></button>
                                        <form asp-action="Desvincular" method="post" class="ml-unlink-form" onsubmit="return confirm('¿Desvincular esta publicación del producto?');" style="display:none">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="listingId" value="@listing.Id" />
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <datalist id="ml-productos-datalist"></datalist>
    }
</form>

@section Scripts {
    <script>
        (function () {
            'use strict';
            var productos = @Html.Raw(productosJson);
            var datalist = document.getElementById('ml-productos-datalist');
            if (datalist) {
                productos.forEach(function (p) {
                    var option = document.createElement('option');
                    option.value = p.codigo + ' - ' + p.nombre;
                    option.dataset.id = p.id;
                    datalist.appendChild(option);
                });
            }
            document.querySelectorAll('.ml-listing-link-form').forEach(function (form) {
                var picker = form.querySelector('.ml-producto-picker');
                var hidden = form.querySelector('.ml-producto-id');
                var submit = form.querySelector('button[type="submit"]');
                picker.addEventListener('input', function () {
                    var match = productos.find(function (p) { return (p.codigo + ' - ' + p.nombre) === picker.value; });
                    hidden.value = match ? match.id : '';
                    submit.disabled = !match;
                });
                form.addEventListener('submit', function (e) { if (!hidden.value) { e.preventDefault(); } });
            });
        })();
    </script>
}
