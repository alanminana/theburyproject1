@model MercadoLibreSyncPreviewViewModel
@{
    ViewData["Title"] = "Previsualizar sincronización";
}

<!-- ============ SYNCPREVIEW ============ -->
<div class="crumb">
    <a asp-action="Listings"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"></path></svg>Publicaciones</a>
    <span class="sep">/</span><span class="cur">Previsualizar sincronización</span>
</div>
<div class="phead">
    <div>
        <h1><span class="gi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 0 1 15-6.7L21 8M21 3v5h-5M21 12a9 9 0 0 1-15 6.7L3 16M3 21v-5h5"></path></svg></span>Previsualizar sincronización</h1>
        <div class="sub">Tipo: <b>@Model.Tipo</b> · @Model.TotalConCambios con cambios · @Model.TotalExcluidas excluidas · @Model.TotalAdvertencias con advertencias · revisá antes de aplicar a ML</div>
    </div>
</div>

@if (Model.ModoSimulacion)
{
    <div class="tray warn" style="margin-bottom:18px">
        <span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 3h6M10 3v6L5 19a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1l-5-10V3"></path></svg></span>
        <b>Modo simulación activo</b><span>— al aplicar, los cambios se registran en el log pero no se envían a Mercado Libre.</span>
    </div>
}

<div class="card">
    <table class="tbl">
        <thead><tr><th>Publicación</th><th>Variación</th><th>Producto</th><th class="num">Stock (ML → nuevo)</th><th class="num">Precio (ML → nuevo)</th><th>Advertencias</th></tr></thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr style="@(item.Excluida ? "opacity:.5" : null)">
                    <td>
                        <div class="prod">
                            <span class="pt" title="@item.Titulo">@item.Titulo</span>
                            <span class="pm">@item.ItemId · @item.Status@(item.TieneVariaciones ? $" · {item.CantidadVariaciones} var." : "")</span>
                        </div>
                    </td>
                    <td>
                        @if (item.VariationId.HasValue)
                        {
                            <div style="font-family:var(--mono);font-size:12px">@item.VariationId</div>
                            <div class="le" style="font-size:11px;color:var(--muted)">@(item.VariationAtributos ?? "—")</div>
                        }
                        else
                        {
                            <span style="color:var(--faint)">—</span>
                        }
                    </td>
                    <td>
                        <span style="font-family:var(--mono);color:var(--blue)">@(item.ProductoCodigo ?? "—")</span>
                        <div class="le" style="font-size:11px;color:var(--muted)">@item.ProductoNombre</div>
                    </td>
                    <td class="num">
                        @if (item.CambiaStock)
                        {
                            <span class="chg"><span class="old">@item.StockMl</span><svg class="arr" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"></path></svg><span class="new">@item.StockObjetivo</span></span>
                        }
                        else if (item.StockObjetivo.HasValue)
                        {
                            <span style="color:var(--faint)">@item.StockMl (sin cambio)</span>
                        }
                        else
                        {
                            <span style="color:var(--faint)">—</span>
                        }
                    </td>
                    <td class="num">
                        @if (item.CambiaPrecio)
                        {
                            <span class="chg"><span class="old">@item.PrecioMl.ToString("N2")</span><svg class="arr" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"></path></svg><span class="new up">@item.PrecioObjetivo?.ToString("N2")</span></span>
                        }
                        else if (item.PrecioObjetivo.HasValue)
                        {
                            <span style="color:var(--faint)">@item.PrecioMl.ToString("N2") (sin cambio)</span>
                        }
                        else
                        {
                            <span style="color:var(--faint)">—</span>
                        }
                    </td>
                    <td>
                        @if (item.Excluida)
                        {
                            <div class="warnpill" style="color:var(--red)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"></circle><path d="M15 9l-6 6M9 9l6 6"></path></svg>@item.MotivoExclusion</div>
                        }
                        @if (item.Advertencias != null && item.Advertencias.Any())
                        {
                            foreach (var advertencia in item.Advertencias)
                            {
                                <div class="warnpill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v4M12 17h.01M10.3 3.9 1.8 18h20.4z"></path></svg>@advertencia</div>
                            }
                        }
                        else if (!item.Excluida)
                        {
                            <span class="okpill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"></path></svg>Sin advertencias</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalConCambios > 0)
    {
        <form asp-action="SyncAplicar" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="tipo" value="@Model.Tipo" />
            @foreach (var item in Model.Items.Where(i => !i.Excluida && i.TieneCambios))
            {
                <input type="hidden" name="listingIds" value="@item.ListingId" />
            }
            <div style="display:flex;align-items:center;gap:16px;padding:16px 18px;border-top:1px solid var(--line-2)">
                <span style="color:var(--muted);font-size:13px">@Model.TotalExcluidas excluidas · @Model.TotalConCambios a sincronizar</span>
                <div style="flex:1"></div>
                @if (!Model.ModoSimulacion)
                {
                    <label class="checkline" style="margin:0"><input type="checkbox" class="cbx" name="confirmarReal" value="true"><span><b>Confirmar aplicación real</b><div class="cm">Aplica los cambios en Mercado Libre.</div></span></label>
                }
                <button type="submit" class="btn primary"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"></path></svg>@(Model.ModoSimulacion ? "Simular sync" : "Aplicar sync")</button>
            </div>
        </form>
    }
    else
    {
        <div style="padding:16px 18px;border-top:1px solid var(--line-2);color:var(--muted);font-size:13px">No hay cambios para sincronizar: ML ya está alineado con el ERP.</div>
    }
</div>
