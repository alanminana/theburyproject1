@*
    Sub-layout del módulo Mercado Libre.
    Anida en el shell GLOBAL del sistema (_Layout): la barra lateral SIEMPRE
    es la barra general (Dashboard, Ventas, ... Mercado Libre, ...). Acá sólo
    se renderiza la navegación interna del canal como TABS (vista fija; sin el
    selector Tabs/Lateral), una barra compacta de cuenta y las bandejas
    TempData. El look del canal se obtiene de mercadolibre1-module.css (clases
    semánticas .phead/.card/.tbl/... que usan las vistas) cargado sólo en estas
    páginas para no colisionar con el CSS legacy del resto del sistema.
*@
@{
    Layout = "_Layout";
    var mlAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;

    string MlArea(string action) => action switch
    {
        "Dashboard" => "panel",
        "Listings" or "Listing" or "ListingCrearProducto" or "SyncPreview" => "publicaciones",
        "Ordenes" or "Orden" => "ordenes",
        "Preguntas" or "Pregunta" or "Mensajes" => "atencion",
        "Aumentos" or "Aumento" or "AumentoNuevo" => "aumentos",
        "Borradores" or "Borrador" => "borradores",
        "Index" or "Conectar" or "OAuthCallback" => "conexion",
        "Configuracion" => "configuracion",
        _ => string.Empty
    };
    var active = MlArea(mlAction);

    // Íconos (paths) tomados del standalone.
    var icon = new Dictionary<string, string>
    {
        ["panel"] = "<rect x=\"3\" y=\"3\" width=\"7\" height=\"7\" rx=\"1\"/><rect x=\"14\" y=\"3\" width=\"7\" height=\"7\" rx=\"1\"/><rect x=\"3\" y=\"14\" width=\"7\" height=\"7\" rx=\"1\"/><rect x=\"14\" y=\"14\" width=\"7\" height=\"7\" rx=\"1\"/>",
        ["pub"] = "<rect x=\"3\" y=\"4\" width=\"18\" height=\"16\" rx=\"2\"/><path d=\"M3 9h18M8 4v16\"/>",
        ["ord"] = "<path d=\"M6 2h9l5 5v13a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1z\"/><path d=\"M9 13h6M9 17h6\"/>",
        ["att"] = "<path d=\"M21 11.5a8.4 8.4 0 0 1-9 8.4L3 21l1.1-3.6A8.4 8.4 0 1 1 21 11.5z\"/>",
        ["aum"] = "<path d=\"M3 17l6-6 4 4 8-8M21 7v5M21 7h-5\"/>",
        ["bor"] = "<path d=\"M7 3h7l5 5v13a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z\"/><path d=\"M13 3v6h6\"/>",
        ["conn"] = "<path d=\"M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1\"/><path d=\"M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1\"/>",
        ["cfg"] = "<circle cx=\"12\" cy=\"12\" r=\"3\"/><path d=\"M19.4 15a1.6 1.6 0 0 0 .3 1.8l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1.6 1.6 0 0 0-2.7 1.1V21a2 2 0 1 1-4 0v-.1A1.6 1.6 0 0 0 7 19.4a1.6 1.6 0 0 0-1.8.3l-.1.1a2 2 0 1 1-2.8-2.8l.1-.1a1.6 1.6 0 0 0-1.1-2.7H1a2 2 0 1 1 0-4h.1A1.6 1.6 0 0 0 2.6 7a1.6 1.6 0 0 0-.3-1.8l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1a1.6 1.6 0 0 0 1.8.3H7a1.6 1.6 0 0 0 1-1.5V1a2 2 0 1 1 4 0v.1a1.6 1.6 0 0 0 2.7 1.1l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1.6 1.6 0 0 0-.3 1.8V7a1.6 1.6 0 0 0 1.5 1H21a2 2 0 1 1 0 4h-.1a1.6 1.6 0 0 0-1.5 1z\"/>"
    };
    string Svg(string key) => $"<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">{icon[key]}</svg>";

    var canOrders = User.TienePermiso("mercadolibre", "orders");
    var canSync = User.TienePermiso("mercadolibre", "sync");
    var canConfig = User.TienePermiso("mercadolibre", "config");

    var mainNav = new List<(string Id, string Label, string Action, string Icon, bool Show)>
    {
        ("panel",         "Panel",          "Dashboard",   "panel", true),
        ("publicaciones", "Publicaciones",  "Listings",    "pub",   true),
        ("ordenes",       "Órdenes",        "Ordenes",     "ord",   canOrders),
        ("atencion",      "Atención",       "Preguntas",   "att",   canOrders),
        ("aumentos",      "Aumentos",       "Aumentos",    "aum",   canSync),
        ("borradores",    "Borradores",     "Borradores",  "bor",   true),
    };
    var utilNav = new List<(string Id, string Label, string Action, string Icon, bool Show)>
    {
        ("conexion",      "Conexión",       "Index",         "conn", true),
        ("configuracion", "Configuración",  "Configuracion", "cfg",  canConfig),
    };

    string LinkClass(string baseCls, string id) => active == id ? $"{baseCls} active" : baseCls;

    var cuentaConectada = ViewData["MlCuenta"] != null;
}

@section Styles {
    <link rel="stylesheet" href="~/css/mercadolibre1-module.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
}

<div class="ml-canvas">
    <nav class="ml-subnav" aria-label="Navegación Mercado Libre">
        <div class="tabs" id="tabs">
            @foreach (var n in mainNav.Where(x => x.Show))
            {
                <a asp-action="@n.Action" class="@LinkClass("tab", n.Id)">@Html.Raw(Svg(n.Icon))@n.Label</a>
            }
            <span class="tab-sep"></span>
            @foreach (var n in utilNav.Where(x => x.Show))
            {
                <a asp-action="@n.Action" class="@LinkClass("tab util", n.Id)">@Html.Raw(Svg(n.Icon))@n.Label</a>
            }
        </div>
    </nav>

    <div class="ml-account">
        <span class="acc"><span class="dot @(cuentaConectada ? "" : "off")"></span>@(ViewData["MlCuenta"] ?? "Canal Mercado Libre")</span>
        @if (ViewData["MlUserId"] != null)
        {
            <span class="sep"></span>
            <span class="id">@ViewData["MlUserId"]</span>
        }
        @if (ViewData["MlUltimoSync"] != null)
        {
            <span class="sep"></span>
            <span>@ViewData["MlUltimoSync"]</span>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="tray" style="margin-bottom:18px">
            <span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"></path></svg></span>
            <b>@TempData["Success"]</b>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="tray warn" style="margin-bottom:18px">
            <span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 9v4M12 17h.01M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0z"></path></svg></span>
            <b>@TempData["Error"]</b>
        </div>
    }

    @RenderBody()
</div>

@section Scripts {
    <script src="~/js/mercadolibre1-module.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
}
