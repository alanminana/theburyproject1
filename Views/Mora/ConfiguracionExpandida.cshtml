@model TheBuryProject.ViewModels.Mora.ConfiguracionMoraExpandidaViewModel
@{
    ViewData["Title"] = "Configuración de mora";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="space-y-8">
    <section class="card-erp-panel-padded">
        <header class="flex flex-col gap-6 xl:flex-row xl:items-start xl:justify-between">
            <div class="max-w-3xl space-y-4">
                <nav aria-label="Breadcrumb" class="flex text-sm font-medium text-slate-400">
                    <ol class="inline-flex flex-wrap items-center gap-y-1">
                        <li><a asp-controller="Home" asp-action="Index" class="hover:text-primary no-underline">Inicio</a></li>
                        <li><span class="mx-2 text-slate-400">/</span></li>
                        <li><a asp-controller="Mora" asp-action="Index" class="hover:text-primary no-underline">Mora</a></li>
                        <li><span class="mx-2 text-slate-400">/</span></li>
                        <li class="text-slate-100">Configuración</li>
                    </ol>
                </nav>
                <div class="space-y-3">
                    <span class="badge-erp badge-erp-primary">
                        <span class="material-symbols-outlined text-sm">tune</span>
                        Cobranzas
                    </span>
                    <div class="space-y-2">
                        <h1 class="text-3xl font-black tracking-tight text-white sm:text-4xl">Configuración de mora</h1>
                        <p class="max-w-2xl text-sm leading-relaxed text-slate-400 sm:text-base">
                            Ajusta la automatización del proceso de mora, los días de gracia y el impacto sobre el puntaje del cliente.
                        </p>
                    </div>
                </div>
            </div>

            <div class="flex w-full flex-col gap-3 sm:flex-row xl:w-auto xl:justify-end">
                <a asp-controller="Mora" asp-action="Index" class="btn-erp-ghost w-full sm:w-auto sm:py-2.5 no-underline">
                    <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                    Volver
                </a>
            </div>
        </header>
    </section>

    @if (TempData["Success"] != null)
    {
        <div class="flex items-center gap-3 rounded-xl border border-emerald-500/20 bg-emerald-500/10 p-4 text-sm font-semibold text-emerald-400" role="status">
            <span class="material-symbols-outlined">check_circle</span>
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="flex items-center gap-3 rounded-xl border border-rose-500/20 bg-rose-500/10 p-4 text-sm font-semibold text-rose-400" role="alert">
            <span class="material-symbols-outlined">error</span>
            @TempData["Error"]
        </div>
    }

    <form asp-action="GuardarConfiguracionExpandida" asp-controller="Mora" method="post" class="space-y-8">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="RowVersion" />
        @if (!string.IsNullOrEmpty(returnUrl))
        {
            <input type="hidden" name="returnUrl" value="@returnUrl" />
        }

        <div asp-validation-summary="All" class="rounded-xl border border-rose-500/20 bg-rose-500/10 p-4 text-sm font-semibold text-rose-400 empty:hidden"></div>

        <!-- ============ Automatización ============ -->
        <section class="card-erp-panel-padded">
            <div class="mb-6 flex items-center gap-2 border-b border-slate-800 pb-3">
                <span class="material-symbols-outlined text-primary">schedule</span>
                <h2 class="text-xl font-bold text-white">Automatización</h2>
            </div>

            <div class="space-y-4">
                <label class="flex items-start gap-3">
                    <input asp-for="ProcesoAutomaticoActivo" type="checkbox"
                           class="mt-0.5 size-5 shrink-0 rounded border-2 border-slate-700 bg-slate-800 text-primary focus:ring-primary" />
                    <span class="flex flex-col">
                        <span class="text-sm font-semibold text-slate-200">Proceso automático de mora activo</span>
                        <span class="text-xs text-slate-500">Habilita la ejecución programada del cálculo y las alertas de mora.</span>
                    </span>
                </label>

                <label class="flex items-start gap-3">
                    <input asp-for="ActualizarMoraAutomaticamente" type="checkbox"
                           class="mt-0.5 size-5 shrink-0 rounded border-2 border-slate-700 bg-slate-800 text-primary focus:ring-primary" />
                    <span class="flex flex-col">
                        <span class="text-sm font-semibold text-slate-200">Actualizar la mora diariamente</span>
                        <span class="text-xs text-slate-500">Recalcula el monto de mora acumulada cada día del proceso.</span>
                    </span>
                </label>

                <label class="flex items-start gap-3">
                    <input asp-for="CambiarEstadoCuotaAuto" type="checkbox"
                           class="mt-0.5 size-5 shrink-0 rounded border-2 border-slate-700 bg-slate-800 text-primary focus:ring-primary" />
                    <span class="flex flex-col">
                        <span class="text-sm font-semibold text-slate-200">Cambiar el estado de la cuota automáticamente</span>
                        <span class="text-xs text-slate-500">Marca la cuota como vencida cuando corresponde. No afecta el puntaje del cliente.</span>
                    </span>
                </label>

                <div class="flex max-w-xs flex-col gap-1.5">
                    <label asp-for="HoraEjecucionDiaria" class="text-sm font-semibold text-slate-300"></label>
                    <input asp-for="HoraEjecucionDiaria" type="time"
                           class="h-12 w-full rounded-lg border-2 border-slate-700 bg-slate-800 px-4 text-white focus:border-primary focus:ring-0" />
                    <span asp-validation-for="HoraEjecucionDiaria" class="text-xs text-red-500"></span>
                </div>
            </div>
        </section>

        <!-- ============ Días y vencimiento ============ -->
        <section class="card-erp-panel-padded">
            <div class="mb-6 flex items-center gap-2 border-b border-slate-800 pb-3">
                <span class="material-symbols-outlined text-primary">event</span>
                <h2 class="text-xl font-bold text-white">Días y vencimiento</h2>
            </div>

            <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                <div class="flex flex-col gap-1.5">
                    <label asp-for="DiasGracia" class="text-sm font-semibold text-slate-300"></label>
                    <input asp-for="DiasGracia" type="number" min="0" max="90"
                           class="h-12 w-full rounded-lg border-2 border-slate-700 bg-slate-800 px-4 text-white focus:border-primary focus:ring-0" />
                    <span asp-validation-for="DiasGracia" class="text-xs text-red-500"></span>
                    <p class="text-xs text-slate-500">Días después del vencimiento antes de aplicar mora. 0 aplica desde el primer día.</p>
                </div>

                <div class="flex flex-col gap-1.5">
                    <label asp-for="TasaMoraBase" class="text-sm font-semibold text-slate-300"></label>
                    <div class="relative">
                        <input asp-for="TasaMoraBase" type="number" step="any" min="0" max="100"
                               class="h-12 w-full rounded-lg border-2 border-slate-700 bg-slate-800 px-4 pr-10 text-white focus:border-primary focus:ring-0" />
                        <span class="pointer-events-none absolute inset-y-0 right-4 flex items-center text-sm font-bold text-slate-400">%</span>
                    </div>
                    <span asp-validation-for="TasaMoraBase" class="text-xs text-red-500"></span>
                    <p class="text-xs text-slate-500">Tasa base de mora. Vacío o 0 no calcula mora.</p>
                </div>
            </div>
        </section>

        <!-- ============ Alertas ============ -->
        <section class="card-erp-panel-padded">
            <div class="mb-6 flex items-center gap-2 border-b border-slate-800 pb-3">
                <span class="material-symbols-outlined text-primary">notifications_active</span>
                <h2 class="text-xl font-bold text-white">Alertas</h2>
            </div>

            <div class="space-y-4">
                <label class="flex items-start gap-3">
                    <input asp-for="AlertasPreventivasActivas" type="checkbox"
                           class="mt-0.5 size-5 shrink-0 rounded border-2 border-slate-700 bg-slate-800 text-primary focus:ring-primary" />
                    <span class="flex flex-col">
                        <span class="text-sm font-semibold text-slate-200">Alertas preventivas activas</span>
                        <span class="text-xs text-slate-500">Genera alertas antes del vencimiento de las cuotas.</span>
                    </span>
                </label>

                <div class="flex max-w-xs flex-col gap-1.5">
                    <label asp-for="DiasAntesAlertaPreventiva" class="text-sm font-semibold text-slate-300"></label>
                    <input asp-for="DiasAntesAlertaPreventiva" type="number" min="1" max="30"
                           class="h-12 w-full rounded-lg border-2 border-slate-700 bg-slate-800 px-4 text-white focus:border-primary focus:ring-0" />
                    <span asp-validation-for="DiasAntesAlertaPreventiva" class="text-xs text-red-500"></span>
                </div>
            </div>
        </section>

        <!-- ============ Score por mora ============ -->
        <section class="card-erp-panel-padded">
            <div class="mb-6 flex items-center gap-2 border-b border-slate-800 pb-3">
                <span class="material-symbols-outlined text-primary">trending_down</span>
                <h2 class="text-xl font-bold text-white">Puntaje por mora</h2>
            </div>

            <div class="space-y-6">
                <label class="flex items-start gap-3 rounded-xl border border-slate-800 bg-slate-900/40 p-4">
                    <input asp-for="ImpactarScorePorMora" type="checkbox"
                           class="mt-0.5 size-5 shrink-0 rounded border-2 border-slate-700 bg-slate-800 text-primary focus:ring-primary" />
                    <span class="flex flex-col gap-1">
                        <span class="text-sm font-semibold text-slate-100">Impactar puntaje por mora después de días de gracia</span>
                        <span class="text-xs leading-relaxed text-slate-400">
                            Si está activo, el proceso automático puede recalcular el PuntajeCliente cuando el cliente supere los días de gracia por mora. Los cambios se auditan en el historial de puntaje.
                        </span>
                    </span>
                </label>

                <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                    <div class="flex flex-col gap-1.5">
                        <label asp-for="PuntosRestarPorCuotaVencida" class="text-sm font-semibold text-slate-300"></label>
                        <input asp-for="PuntosRestarPorCuotaVencida" type="number" min="0" max="1000"
                               class="h-12 w-full rounded-lg border-2 border-slate-700 bg-slate-800 px-4 text-white focus:border-primary focus:ring-0" />
                        <span asp-validation-for="PuntosRestarPorCuotaVencida" class="text-xs text-red-500"></span>
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label asp-for="PuntosRestarPorDiaMora" class="text-sm font-semibold text-slate-300"></label>
                        <input asp-for="PuntosRestarPorDiaMora" type="number" step="any" min="0" max="1000"
                               class="h-12 w-full rounded-lg border-2 border-slate-700 bg-slate-800 px-4 text-white focus:border-primary focus:ring-0" />
                        <span asp-validation-for="PuntosRestarPorDiaMora" class="text-xs text-red-500"></span>
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label asp-for="PuntosMaximosARestar" class="text-sm font-semibold text-slate-300"></label>
                        <input asp-for="PuntosMaximosARestar" type="number" min="0" max="1000"
                               class="h-12 w-full rounded-lg border-2 border-slate-700 bg-slate-800 px-4 text-white focus:border-primary focus:ring-0" />
                        <span asp-validation-for="PuntosMaximosARestar" class="text-xs text-red-500"></span>
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label asp-for="PorcentajeRecuperacionScore" class="text-sm font-semibold text-slate-300"></label>
                        <div class="relative">
                            <input asp-for="PorcentajeRecuperacionScore" type="number" step="any" min="0" max="100"
                                   class="h-12 w-full rounded-lg border-2 border-slate-700 bg-slate-800 px-4 pr-10 text-white focus:border-primary focus:ring-0" />
                            <span class="pointer-events-none absolute inset-y-0 right-4 flex items-center text-sm font-bold text-slate-400">%</span>
                        </div>
                        <span asp-validation-for="PorcentajeRecuperacionScore" class="text-xs text-red-500"></span>
                    </div>
                </div>

                <label class="flex items-start gap-3">
                    <input asp-for="RecuperarScoreAlPagar" type="checkbox"
                           class="mt-0.5 size-5 shrink-0 rounded border-2 border-slate-700 bg-slate-800 text-primary focus:ring-primary" />
                    <span class="flex flex-col">
                        <span class="text-sm font-semibold text-slate-200">Recuperar puntaje al pagar</span>
                        <span class="text-xs text-slate-500">Devuelve parte del puntaje perdido cuando el cliente regulariza la deuda.</span>
                    </span>
                </label>
            </div>
        </section>

        <div class="flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
            <a asp-controller="Mora" asp-action="Index" class="btn-erp-ghost w-full sm:w-auto sm:py-2.5 no-underline">Cancelar</a>
            <button type="submit" class="btn-erp-primary w-full sm:w-auto sm:py-2.5">
                <span class="material-symbols-outlined text-[20px]">save</span>
                Guardar configuración
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
