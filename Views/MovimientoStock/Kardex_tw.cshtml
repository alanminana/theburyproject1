@model IEnumerable<TheBuryProject.ViewModels.MovimientoStockViewModel>
@using TheBuryProject.Models.Enums
@{
    var producto = ViewBag.Producto as TheBuryProject.Models.Entities.Producto;
    ViewData["Title"] = producto != null ? $"Kardex — {producto.Nombre}" : "Kardex de Movimientos";
    var movimientos = Model?.ToList() ?? new List<TheBuryProject.ViewModels.MovimientoStockViewModel>();
    var entradas = movimientos.Where(m => m.Tipo == TipoMovimiento.Entrada).Sum(m => m.Cantidad);
    var salidas  = movimientos.Where(m => m.Tipo == TipoMovimiento.Salida).Sum(m => Math.Abs(m.Cantidad));
    var ajustes  = movimientos.Count(m => m.Tipo == TipoMovimiento.Ajuste);

    string TipoBadgeCls(TipoMovimiento t) => t switch
    {
        TipoMovimiento.Entrada => "bg-emerald-500/10 text-emerald-400 border border-emerald-500/20",
        TipoMovimiento.Salida  => "bg-rose-500/10 text-rose-400 border border-rose-500/20",
        TipoMovimiento.Ajuste  => "bg-amber-500/10 text-amber-400 border border-amber-500/20",
        _ => "bg-slate-500/10 text-slate-400 border border-slate-700"
    };

    string SignoColor(TipoMovimiento tipo, decimal stockAnterior, decimal stockNuevo) => tipo switch
    {
        TipoMovimiento.Entrada => "text-emerald-400 font-bold",
        TipoMovimiento.Salida  => "text-rose-400 font-bold",
        TipoMovimiento.Ajuste  => stockNuevo > stockAnterior ? "text-emerald-400 font-bold"
                                : stockNuevo < stockAnterior ? "text-rose-400 font-bold"
                                : "text-slate-400 font-bold",
        _                      => "text-slate-400 font-bold"
    };

    string Signo(TipoMovimiento tipo, decimal stockAnterior, decimal stockNuevo) => tipo switch
    {
        TipoMovimiento.Entrada => "+",
        TipoMovimiento.Salida  => "-",
        TipoMovimiento.Ajuste  => stockNuevo > stockAnterior ? "+"
                                : stockNuevo < stockAnterior ? "-"
                                : "",
        _                      => ""
    };

    string FormatMoney(decimal v) =>
        v.ToString("C", new System.Globalization.CultureInfo("es-AR"));
}

<div class="space-y-6">

    @if (TempData["Success"] != null)
    {
        <div class="flex items-center gap-3 rounded-xl border border-emerald-500/20 bg-emerald-500/10 p-4 text-sm font-semibold text-emerald-400">
            <span class="material-symbols-outlined">check_circle</span>@TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="flex items-center gap-3 rounded-xl border border-red-500/20 bg-red-500/10 p-4 text-sm font-semibold text-red-400">
            <span class="material-symbols-outlined">error</span>@TempData["Error"]
        </div>
    }

    <!-- Header -->
    <div class="flex flex-wrap items-start justify-between gap-4">
        <div class="flex items-start gap-3">
            <a asp-controller="Catalogo" asp-action="Index"
               class="mt-1 text-slate-400 hover:text-slate-200 transition-colors"
               title="Volver al catálogo">
                <span class="material-symbols-outlined">arrow_back</span>
            </a>
            <div>
                <h1 class="text-2xl font-bold text-white flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">receipt_long</span>
                    Kardex de movimientos
                </h1>
                @if (producto != null)
                {
                    <p class="text-slate-400 text-sm mt-0.5">
                        <span class="font-semibold text-slate-300">@producto.Nombre</span>
                        <span class="mx-2 text-slate-600">·</span>
                        <span class="font-mono text-xs tracking-wider text-slate-500">@producto.Codigo</span>
                    </p>
                }
            </div>
        </div>
        @if (producto != null)
        {
            <a asp-controller="MovimientoStock" asp-action="Create" asp-route-productoId="@producto.Id"
               class="inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-bold text-white hover:bg-primary/90 transition-colors">
                <span class="material-symbols-outlined text-base">add</span>
                Registrar ajuste
            </a>
        }
    </div>

    <!-- Banner: producto eliminado (soft delete) — solo visible si el controller setea ViewBag.ProductoEliminado -->
    @if (ViewBag.ProductoEliminado == true)
    {
        <div class="flex items-start gap-3 rounded-xl border border-slate-500/30 bg-slate-500/10 px-5 py-3">
            <span class="material-symbols-outlined text-slate-400 mt-0.5 shrink-0">archive</span>
            <p class="text-sm text-slate-400">
                Producto eliminado — se muestra el historial de movimientos en modo solo lectura.
            </p>
        </div>
    }
    else if (producto != null && !producto.Activo)
    {
        <div class="flex items-start gap-3 rounded-xl border border-slate-500/30 bg-slate-500/10 px-5 py-3">
            <span class="material-symbols-outlined text-slate-400 mt-0.5 shrink-0">visibility_off</span>
            <p class="text-sm text-slate-400">
                Producto inactivo — historial disponible en modo solo lectura.
            </p>
        </div>
    }

    <!-- Banner: historial por SKU -->
    <div class="flex items-start gap-3 rounded-xl border border-amber-500/20 bg-amber-500/5 px-5 py-3">
        <span class="material-symbols-outlined text-amber-400 mt-0.5 shrink-0">info</span>
        <p class="text-sm text-amber-300/80">
            Este historial muestra movimientos por SKU/producto. No identifica unidades físicas individuales ni trazabilidad serial.
        </p>
    </div>

    <!-- Stats -->
    @if (producto != null)
    {
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-5">
                <p class="text-xs font-medium text-slate-400 uppercase tracking-wide mb-1">Stock actual</p>
                <p class="text-2xl font-bold text-white">@producto.StockActual.ToString("N0") <span class="text-sm font-normal text-slate-400">uds</span></p>
            </div>
            <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-5">
                <p class="text-xs font-medium text-slate-400 uppercase tracking-wide mb-1">Entradas</p>
                <p class="text-2xl font-bold text-emerald-400">@entradas.ToString("N0")</p>
            </div>
            <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-5">
                <p class="text-xs font-medium text-slate-400 uppercase tracking-wide mb-1">Salidas</p>
                <p class="text-2xl font-bold text-rose-400">@salidas.ToString("N0")</p>
            </div>
            <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-5">
                <p class="text-xs font-medium text-slate-400 uppercase tracking-wide mb-1">Ajustes</p>
                <p class="text-2xl font-bold text-amber-400">@ajustes</p>
            </div>
        </div>
    }

    <!-- Tabla -->
    <div class="table-erp-wrapper overflow-x-auto rounded-xl border border-slate-800 bg-slate-900/50">
        <div class="border-b border-slate-800 px-5 py-4 flex items-center justify-between gap-4">
            <div>
                <h2 class="text-base font-bold text-white">Historial de movimientos</h2>
                <p class="text-sm text-slate-400">@movimientos.Count movimiento@(movimientos.Count != 1 ? "s" : "") registrado@(movimientos.Count != 1 ? "s" : "")</p>
            </div>
        </div>

        @if (!movimientos.Any())
        {
            <div class="flex flex-col items-center gap-3 py-20 text-center opacity-50">
                <span class="material-symbols-outlined text-5xl text-slate-500">swap_vert</span>
                <p class="text-slate-400 font-semibold">Sin movimientos registrados para este producto</p>
            </div>
        }
        else
        {
            <table class="min-w-[1100px] w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-slate-800 bg-slate-800/30">
                        <th class="px-4 py-3 text-xs font-bold text-slate-400 uppercase tracking-wide">Fecha / Hora</th>
                        <th class="px-4 py-3 text-xs font-bold text-slate-400 uppercase tracking-wide">Tipo</th>
                        <th class="px-4 py-3 text-xs font-bold text-slate-400 uppercase tracking-wide">Cantidad</th>
                        <th class="px-4 py-3 text-xs font-bold text-slate-400 uppercase tracking-wide">Costo unitario</th>
                        <th class="px-4 py-3 text-xs font-bold text-slate-400 uppercase tracking-wide">Costo total</th>
                        <th class="px-4 py-3 text-xs font-bold text-slate-400 uppercase tracking-wide cursor-help" title="Origen usado para valuar el costo del movimiento.">Fuente costo</th>
                        <th class="px-4 py-3 text-xs font-bold text-slate-400 uppercase tracking-wide">Motivo</th>
                        <th class="px-4 py-3 text-xs font-bold text-slate-400 uppercase tracking-wide">Referencia</th>
                        <th class="px-4 py-3 text-xs font-bold text-slate-400 uppercase tracking-wide">Saldo post.</th>
                        <th class="px-4 py-3 text-xs font-bold text-slate-400 uppercase tracking-wide">Usuario</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800">
                    @foreach (var m in movimientos.OrderByDescending(x => x.Fecha))
                    {
                        <tr class="hover:bg-slate-800/20 transition-colors">
                            <td class="px-4 py-3">
                                <div class="flex flex-col">
                                    <span class="text-sm font-medium text-slate-200">@m.Fecha.ToString("dd MMM yyyy")</span>
                                    <span class="text-xs text-slate-500">@m.Fecha.ToString("HH:mm:ss")</span>
                                </div>
                            </td>
                            <td class="px-4 py-3">
                                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-bold @TipoBadgeCls(m.Tipo)">
                                    @m.Tipo.ToString()
                                </span>
                            </td>
                            <td class="px-4 py-3">
                                <span class="text-sm @SignoColor(m.Tipo, m.StockAnterior, m.StockNuevo)">@Signo(m.Tipo, m.StockAnterior, m.StockNuevo)@Math.Abs(m.Cantidad).ToString("N0")</span>
                            </td>
                            <td class="px-4 py-3">
                                <span class="text-sm text-slate-400">@FormatMoney(m.CostoUnitarioAlMomento)</span>
                            </td>
                            <td class="px-4 py-3">
                                <span class="text-sm font-semibold text-slate-200">@FormatMoney(m.CostoTotalAlMomento)</span>
                            </td>
                            <td class="px-4 py-3">
                                <span class="inline-flex items-center rounded-full bg-slate-800 px-2 py-0.5 text-xs font-semibold text-slate-300">
                                    @{
                                        var fuenteLabel = m.FuenteCosto switch
                                        {
                                            "VentaDetalleSnapshot" => "Venta",
                                            "OrdenCompraDetalle"   => "Orden de compra",
                                            "ProductoActual"       => "Costo actual",
                                            "AjusteManual"         => "Ajuste manual",
                                            "Legacy"               => "Histórico migrado",
                                            _                      => "No informado"
                                        };
                                    }
                                    @fuenteLabel
                                </span>
                            </td>
                            <td class="px-4 py-3 max-w-[180px]">
                                @if (string.IsNullOrWhiteSpace(m.Motivo))
                                {
                                    <span class="text-sm italic text-slate-500">Sin motivo registrado</span>
                                }
                                else
                                {
                                    <span class="text-sm text-slate-300 block truncate" title="@m.Motivo">@m.Motivo</span>
                                }
                            </td>
                            <td class="px-4 py-3">
                                <span class="text-sm text-slate-400">@(m.Referencia ?? "—")</span>
                            </td>
                            <td class="px-4 py-3">
                                <span class="text-sm font-bold text-slate-200">@m.StockNuevo.ToString("N0") uds</span>
                            </td>
                            <td class="px-4 py-3">
                                <span class="text-sm text-slate-400">@(m.CreatedBy ?? "—")</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

</div>
