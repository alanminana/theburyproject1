@model TheBuryProject.ViewModels.OrdenCompraViewModel
@using TheBuryProject.Models.Enums
@using System.Text.Json
@{
    ViewData["Title"] = "Nueva Orden de Compra";
    var proveedores = ViewBag.Proveedores as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var jsonOptions = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var productosJson = ViewBag.ProductosJson != null
        ? JsonSerializer.Serialize(ViewBag.ProductosJson, jsonOptions)
        : "[]";
    var proveedoresJson = ViewBag.ProveedoresJson != null
        ? JsonSerializer.Serialize(ViewBag.ProveedoresJson, jsonOptions)
        : "[]";
    var detallesJson = Model?.Detalles != null && Model.Detalles.Any()
        ? JsonSerializer.Serialize(
            Model.Detalles.Select(d => new
            {
                d.ProductoId,
                ProductoNombre = d.ProductoNombre ?? string.Empty,
                ProductoCodigo = d.ProductoCodigo ?? string.Empty,
                d.Cantidad,
                d.PrecioUnitario,
                d.Subtotal
            }),
            jsonOptions)
        : "[]";
    var descuentoInicial = Model?.Descuento.ToString("F2", System.Globalization.CultureInfo.InvariantCulture) ?? "0.00";
}

@section Styles {
    <partial name="_OrdenCompraModuleStyles" />
}

<!-- Validation Errors -->
@if (!ViewData.ModelState.IsValid)
{
    <div id="banner-errores" class="flex flex-1 flex-col items-start justify-between gap-3 rounded-xl border border-red-500/30 bg-red-500/10 p-4 sm:flex-row sm:items-center mb-4">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-red-500" aria-hidden="true">error</span>
            <div class="flex flex-col gap-1">
                <p class="text-white text-sm font-bold leading-tight">Corrige los errores antes de continuar</p>
                <div class="text-slate-400 text-sm font-normal">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p>@error.ErrorMessage</p>
                    }
                </div>
            </div>
        </div>
        <button type="button" data-dismiss-target="banner-errores"
                class="text-sm font-bold leading-normal flex items-center gap-2 text-white opacity-70 hover:opacity-100">
            Cerrar
            <span class="material-symbols-outlined text-[20px]" aria-hidden="true">close</span>
        </button>
    </div>
}

<!-- Header compacto -->
<div class="oc-head mb-4">
    <div class="oc-head__title">
        <nav class="flex items-center gap-2 text-xs font-medium text-slate-400">
            <a asp-controller="OrdenCompra" asp-action="Index" class="hover:text-primary no-underline">Órdenes de Compra</a>
            <span class="material-symbols-outlined text-[14px]" aria-hidden="true">chevron_right</span>
            <span class="text-slate-100">Nueva Orden</span>
        </nav>
        <h1 class="mt-1 text-lg font-bold tracking-tight text-white">Nueva Orden de Compra</h1>
    </div>
    <div class="oc-head__actions">
        <a asp-action="Index" class="btn-erp-secondary btn-sm no-underline">
            <span class="material-symbols-outlined text-[18px]" aria-hidden="true">arrow_back</span>
            Volver al listado
        </a>
    </div>
</div>

<form asp-action="Create" method="post" id="form-orden">
    @Html.AntiForgeryToken()

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
        <!-- Left Column: Form Details -->
        <div class="lg:col-span-2 flex flex-col gap-4">
            <!-- Datos Generales Card -->
            <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-4 shadow-sm">
                <h2 class="text-white text-base font-bold mb-3 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary text-[20px]" aria-hidden="true">description</span>
                    Datos Generales
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    <label class="flex flex-col gap-1.5">
                        <span class="text-slate-300 text-sm font-medium">Número de Orden</span>
                        <input type="text" asp-for="Numero" readonly
                               class="rounded-lg border border-slate-700 bg-slate-800 text-slate-500 cursor-not-allowed h-10 px-3 focus:ring-0" />
                    </label>
                    <label class="flex flex-col gap-1.5">
                        <span class="text-slate-300 text-sm font-medium">Proveedor</span>
                        <select asp-for="ProveedorId"
                                class="rounded-lg border border-slate-700 bg-slate-800 text-white h-10 px-3 focus:border-primary focus:ring-1 focus:ring-primary outline-none">
                            <option value="">Seleccione un proveedor</option>
                            @if (proveedores != null)
                            {
                                @foreach (var p in proveedores)
                                {
                                    <option value="@p.Value" selected="@p.Selected">@p.Text</option>
                                }
                            }
                        </select>
                    </label>
                    <label class="flex flex-col gap-1.5">
                        <span class="text-slate-300 text-sm font-medium">Fecha Emisión</span>
                        <input type="date" asp-for="FechaEmision"
                               class="rounded-lg border border-slate-700 bg-slate-800 text-white h-10 px-3 focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                    </label>
                    <label class="flex flex-col gap-1.5">
                        <span class="text-slate-300 text-sm font-medium">Fecha Entrega Estimada</span>
                        <input type="date" asp-for="FechaEntregaEstimada"
                               class="rounded-lg border border-slate-700 bg-slate-800 text-white h-10 px-3 focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                    </label>
                    <label class="flex flex-col gap-1.5">
                        <span class="text-slate-300 text-sm font-medium">Estado</span>
                        <select asp-for="Estado"
                                class="rounded-lg border border-slate-700 bg-slate-800 text-white h-10 px-3 focus:border-primary focus:ring-1 focus:ring-primary outline-none">
                            <option value="@((int)EstadoOrdenCompra.Borrador)">Borrador</option>
                            <option value="@((int)EstadoOrdenCompra.Enviada)">Enviada</option>
                            <option value="@((int)EstadoOrdenCompra.Confirmada)">Confirmada</option>
                            <option value="@((int)EstadoOrdenCompra.Cancelada)">Cancelada</option>
                        </select>
                    </label>
                    <label class="flex flex-col gap-1.5">
                        <span class="text-slate-300 text-sm font-medium">Observaciones</span>
                        <textarea asp-for="Observaciones" rows="1"
                                  class="rounded-lg border border-slate-700 bg-slate-800 text-white px-3 py-2 min-h-10 focus:border-primary focus:ring-1 focus:ring-primary outline-none resize-y"
                                  placeholder="Notas adicionales sobre la orden..."></textarea>
                    </label>
                </div>
            </div>

            <!-- Productos Card -->
            <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-4 shadow-sm">
                <h2 class="text-white text-base font-bold mb-3 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary text-[20px]" aria-hidden="true">inventory_2</span>
                    Productos
                </h2>
                <div id="ordencompra-feedback" class="ordencompra-feedback" data-variant="warning" role="status" aria-live="polite" hidden>
                    <span class="material-symbols-outlined text-[20px]" data-feedback-icon aria-hidden="true">warning</span>
                    <div class="min-w-0 flex-1">
                        <p class="text-sm font-bold leading-tight" data-feedback-title>Revisá este paso</p>
                        <p class="text-sm opacity-90" data-feedback-message></p>
                    </div>
                    <button type="button" class="ordencompra-feedback__dismiss" data-feedback-close aria-label="Cerrar mensaje">
                        <span class="material-symbols-outlined text-[18px]" aria-hidden="true">close</span>
                    </button>
                </div>
                <!-- Search and Add Bar -->
                <div class="ordencompra-product-toolbar">
                    <label class="flex flex-col gap-1.5 ordencompra-product-toolbar__search">
                        <span class="text-slate-300 text-xs font-semibold uppercase">Buscar Producto</span>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]" aria-hidden="true">search</span>
                            <input type="text" id="inp-buscar-producto"
                                   aria-controls="dropdown-productos"
                                   aria-expanded="false"
                                   aria-autocomplete="list"
                                   class="w-full rounded-lg border border-slate-700 bg-slate-900 text-white h-10 pl-10 pr-4 focus:border-primary focus:ring-1 focus:ring-primary outline-none"
                                   placeholder="Código o nombre..." autocomplete="off" />
                            <!-- Dropdown de resultados -->
                            <div id="dropdown-productos" role="listbox" class="absolute z-30 left-0 right-0 top-full mt-1 bg-slate-800 border border-slate-700 rounded-lg shadow-xl max-h-48 overflow-y-auto hidden"></div>
                        </div>
                    </label>
                    <label class="flex flex-col gap-1.5 ordencompra-product-toolbar__field">
                        <span class="text-slate-300 text-xs font-semibold uppercase">Cant.</span>
                        <input type="number" id="inp-cantidad" min="1" step="1" value="1"
                               class="rounded-lg border border-slate-700 bg-slate-900 text-white h-10 px-3 focus:border-primary focus:ring-1 focus:ring-primary outline-none text-center" />
                    </label>
                    <label class="flex flex-col gap-1.5 ordencompra-product-toolbar__field">
                        <span class="text-slate-300 text-xs font-semibold uppercase">Precio</span>
                        <input type="number" id="inp-precio" step="0.01" placeholder="0.00"
                               class="rounded-lg border border-slate-700 bg-slate-900 text-white h-10 px-3 focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                    </label>
                    <button type="button" id="btn-agregar"
                            aria-label="Agregar producto a la orden"
                            class="ordencompra-add-button bg-primary text-white rounded-lg flex items-center justify-center hover:bg-primary/90 transition-colors shadow-lg shadow-primary/20">
                        <span class="material-symbols-outlined" aria-hidden="true">add</span>
                        <span class="text-sm font-bold">Agregar producto</span>
                    </button>
                </div>
                <!-- Table of Products -->
                <div class="ordencompra-product-table-shell"
                     data-oc-scroll
                     style="--oc-scroll-min-width: 42rem; --oc-scrollbar-gutter: stable both-edges; --oc-scroll-fade-bottom: 0.5rem;">
                    <div data-oc-scroll-hint class="ordencompra-scroll-hint" hidden>
                        <span class="material-symbols-outlined text-[18px]" aria-hidden="true">swipe</span>
                        <span id="ordencompra-scroll-hint-text">Deslizá la tabla para revisar cantidades, precios y quitar productos.</span>
                    </div>
                    <div class="ordencompra-product-scroll-shell" data-oc-scroll-shell>
                        <div data-oc-scroll-fade="left" aria-hidden="true" hidden></div>
                        <div data-oc-scroll-fade="right" aria-hidden="true" hidden></div>
                        <div data-oc-scroll-region class="ordencompra-product-scroll" tabindex="0" role="region" aria-label="Productos agregados a la orden" aria-describedby="ordencompra-scroll-hint-text">
                            <table data-oc-scroll-table class="w-full text-left border-collapse">
                                <thead>
                            <tr class="border-b border-slate-800">
                                <th class="text-slate-400 font-semibold text-sm">Producto</th>
                                <th class="text-slate-400 font-semibold text-sm text-center">Cantidad</th>
                                <th class="text-slate-400 font-semibold text-sm text-right">Precio Unit.</th>
                                <th class="text-slate-400 font-semibold text-sm text-right">Subtotal</th>
                                <th class="text-slate-400 font-semibold text-sm text-center w-16"></th>
                            </tr>
                                </thead>
                                <tbody id="tabla-productos" class="divide-y divide-slate-800/50">
                                    <!-- Empty State (visible when no products) -->
                                    <tr id="empty-state">
                                        <td colspan="5" class="text-center">
                                            <div class="flex flex-col items-center gap-2 opacity-40">
                                                <span class="material-symbols-outlined text-4xl" aria-hidden="true">inventory</span>
                                                <p class="text-slate-400 text-base">No hay productos agregados</p>
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Totals & Actions -->
        <div class="flex flex-col gap-4">
            <div class="ordencompra-summary-card rounded-xl border border-slate-800 bg-slate-900/50 p-4 shadow-sm">
                <h2 class="text-white text-base font-bold mb-2">Resumen de Totales</h2>
                <p class="ordencompra-summary-meta">
                    Los precios unitarios ya incluyen IVA; el IVA se muestra desglosado sin sumarse al total.
                </p>
                <div class="space-y-3 ordencompra-summary-totals">
                    <label class="flex flex-col gap-1.5 pb-3 border-b border-slate-800">
                        <span class="text-slate-300 text-sm font-medium">Aplicar Descuento ($)</span>
                        <input type="number" id="inp-descuento" step="0.01" placeholder="0.00" value="@descuentoInicial"
                               class="rounded-lg border border-slate-700 bg-slate-800 text-white h-10 px-3 focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                    </label>
                    <div class="flex justify-between items-center text-slate-400 text-sm">
                        <span>Subtotal</span>
                        <span class="font-semibold text-white" id="lbl-subtotal">$0.00</span>
                    </div>
                    <div class="flex justify-between items-center text-slate-400 text-sm">
                        <span>Descuento</span>
                        <span class="font-semibold text-red-500" id="lbl-descuento">-$0.00</span>
                    </div>
                    <div class="flex justify-between items-center text-slate-400 text-sm">
                        <span>IVA incluido</span>
                        <span class="font-semibold text-white" id="lbl-iva">$0.00</span>
                    </div>
                    <div class="pt-3 border-t border-slate-700">
                        <div class="flex justify-between items-end">
                            <span class="text-white font-bold text-base">Total</span>
                            <span class="text-primary font-black text-2xl" id="lbl-total">$0.00</span>
                        </div>
                    </div>
                </div>
                <!-- Form Actions -->
                <div class="ordencompra-summary-actions">
                    <button type="submit"
                            class="w-full bg-primary text-white font-bold h-11 rounded-xl shadow-lg shadow-primary/30 hover:bg-primary/90 transition-all flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-[20px]" aria-hidden="true">save</span>
                        Guardar Orden
                    </button>
                    <a asp-action="Index"
                       class="w-full py-2 text-center text-slate-400 font-medium hover:text-white transition-colors no-underline block">
                        Cancelar
                    </a>
                </div>
                <!-- Hidden fields for totals -->
                <input type="hidden" asp-for="Subtotal" id="hdn-subtotal" />
                <input type="hidden" asp-for="Descuento" id="hdn-descuento" />
                <input type="hidden" asp-for="Iva" id="hdn-iva" />
                <input type="hidden" asp-for="Total" id="hdn-total" />
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
    <script id="ordencompra-productos-data" type="application/json">@Html.Raw(productosJson)</script>
    <script id="ordencompra-proveedores-data" type="application/json">@Html.Raw(proveedoresJson)</script>
    <script id="ordencompra-detalles-data" type="application/json">@Html.Raw(detallesJson)</script>
    <script src="~/js/ordencompra-form.js" asp-append-version="true"></script>
}
