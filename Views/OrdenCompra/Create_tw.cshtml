@model TheBuryProject.ViewModels.OrdenCompraViewModel
@using TheBuryProject.Models.Enums
@using System.Text.Json
@{
    ViewData["Title"] = "Nueva Orden de Compra";
    var proveedores = ViewBag.Proveedores as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var jsonOptions = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var productosJson = ViewBag.ProductosJson != null
        ? JsonSerializer.Serialize(ViewBag.ProductosJson, jsonOptions)
        : "[]";
    var detallesJson = Model?.Detalles != null && Model.Detalles.Any()
        ? JsonSerializer.Serialize(
            Model.Detalles.Select(d => new
            {
                d.ProductoId,
                ProductoNombre = d.ProductoNombre ?? string.Empty,
                ProductoCodigo = d.ProductoCodigo ?? string.Empty,
                d.Cantidad,
                d.PrecioUnitario,
                d.Subtotal
            }),
            jsonOptions)
        : "[]";
    var descuentoInicial = Model?.Descuento.ToString("F2", System.Globalization.CultureInfo.InvariantCulture) ?? "0.00";
}

@section Styles {
    <link rel="stylesheet" href="~/css/horizontal-scroll-affordance.css" asp-append-version="true" />
    <style>
        .ordencompra-feedback[hidden] {
            display: none !important;
        }

        .ordencompra-feedback {
            display: flex;
            align-items: flex-start;
            gap: 0.75rem;
            margin-bottom: 1.25rem;
            padding: 1rem;
            border: 1px solid transparent;
            border-radius: 1rem;
            transition: opacity 0.2s ease, transform 0.2s ease;
        }

        .ordencompra-feedback[data-variant="error"] {
            background: rgb(239 68 68 / 0.10);
            border-color: rgb(239 68 68 / 0.25);
            color: rgb(185 28 28);
        }

        .ordencompra-feedback[data-variant="warning"] {
            background: rgb(245 158 11 / 0.10);
            border-color: rgb(245 158 11 / 0.25);
            color: rgb(180 83 9);
        }

        .ordencompra-feedback[data-variant="success"] {
            background: rgb(16 185 129 / 0.10);
            border-color: rgb(16 185 129 / 0.25);
            color: rgb(4 120 87);
        }

        html.dark .ordencompra-feedback[data-variant="error"] {
            color: rgb(248 113 113);
        }

        html.dark .ordencompra-feedback[data-variant="warning"] {
            color: rgb(252 211 77);
        }

        html.dark .ordencompra-feedback[data-variant="success"] {
            color: rgb(110 231 183);
        }

        .ordencompra-feedback__dismiss {
            margin-left: auto;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 2rem;
            height: 2rem;
            border-radius: 9999px;
            color: inherit;
            background: transparent;
            border: 0;
            cursor: pointer;
            opacity: 0.7;
            transition: opacity 0.2s ease, background 0.2s ease;
        }

        .ordencompra-feedback__dismiss:hover,
        .ordencompra-feedback__dismiss:focus-visible {
            opacity: 1;
            background: rgb(15 23 42 / 0.06);
            outline: none;
        }

        html.dark .ordencompra-feedback__dismiss:hover,
        html.dark .ordencompra-feedback__dismiss:focus-visible {
            background: rgb(255 255 255 / 0.08);
        }

        .ordencompra-product-toolbar {
            display: grid;
            grid-template-columns: minmax(0, 1fr);
            gap: 1rem;
            margin-bottom: 1.5rem;
            padding: 1rem;
            border: 1px solid rgb(226 232 240);
            border-radius: 1rem;
            background: rgb(248 250 252);
        }

        html.dark .ordencompra-product-toolbar {
            border-color: rgb(51 65 85);
            background: rgb(30 41 59 / 0.45);
        }

        .ordencompra-product-toolbar__search {
            min-width: 0;
        }

        .ordencompra-product-toolbar__field {
            width: 100%;
        }

        .ordencompra-add-button {
            width: 100%;
            min-height: 2.75rem;
            padding-inline: 1rem;
            gap: 0.5rem;
        }

        .ordencompra-product-table-shell {
            border: 1px solid rgb(226 232 240);
            border-radius: 1rem;
            background: rgb(248 250 252 / 0.6);
            overflow: hidden;
        }

        html.dark .ordencompra-product-table-shell {
            border-color: rgb(30 41 59);
            background: rgb(15 23 42 / 0.35);
        }

        .ordencompra-scroll-hint {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.875rem 1rem;
            border-bottom: 1px solid rgb(226 232 240);
            color: rgb(71 85 105);
            background: rgb(241 245 249);
            font-size: 0.8125rem;
            font-weight: 600;
        }

        html.dark .ordencompra-scroll-hint {
            border-bottom-color: rgb(30 41 59);
            color: rgb(148 163 184);
            background: rgb(15 23 42 / 0.65);
        }

        .ordencompra-product-scroll {
            padding-bottom: 0.5rem;
        }

        .ordencompra-summary-card {
            position: static;
        }

        .ordencompra-summary-meta {
            margin-bottom: 1.25rem;
            color: rgb(100 116 139);
            font-size: 0.875rem;
            line-height: 1.5;
        }

        html.dark .ordencompra-summary-meta {
            color: rgb(148 163 184);
        }

        .ordencompra-summary-totals {
            border: 1px solid rgb(226 232 240);
            border-radius: 1rem;
            padding: 1rem;
            background: rgb(248 250 252 / 0.75);
        }

        html.dark .ordencompra-summary-totals {
            border-color: rgb(30 41 59);
            background: rgb(15 23 42 / 0.35);
        }

        .ordencompra-summary-actions {
            margin-top: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        @@media (min-width: 768px) {
            .ordencompra-product-toolbar {
                grid-template-columns: minmax(0, 1fr) minmax(6rem, 7rem) minmax(8rem, 9rem) auto;
                align-items: end;
            }

            .ordencompra-add-button {
                width: auto;
                min-width: 12rem;
                justify-content: center;
            }
        }

        @@media (min-width: 1280px) {
            .ordencompra-summary-card {
                position: sticky;
                top: 1.5rem;
            }
        }
    </style>
}

<!-- Validation Errors -->
@if (!ViewData.ModelState.IsValid)
{
    <div id="banner-errores" class="flex flex-1 flex-col items-start justify-between gap-4 rounded-xl border border-red-500/30 bg-red-500/10 p-5 sm:flex-row sm:items-center mb-6">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-red-500">error</span>
            <div class="flex flex-col gap-1">
                <p class="text-slate-900 dark:text-white text-base font-bold leading-tight">Corrige los errores antes de continuar</p>
                <div class="text-slate-600 dark:text-slate-400 text-sm font-normal">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p>@error.ErrorMessage</p>
                    }
                </div>
            </div>
        </div>
        <button type="button" data-dismiss-target="banner-errores"
                class="text-sm font-bold leading-normal flex items-center gap-2 text-slate-900 dark:text-white opacity-70 hover:opacity-100">
            Cerrar
            <span class="material-symbols-outlined text-[20px]">close</span>
        </button>
    </div>
}

<!-- Header -->
<div class="flex flex-wrap justify-between items-center gap-4 mb-6">
    <div class="flex flex-col gap-1">
        <span class="text-primary font-bold tracking-wider text-xs uppercase">TheBuryProject</span>
        <h1 class="text-slate-900 dark:text-white text-4xl font-black leading-tight tracking-tight">Nueva Orden de Compra</h1>
    </div>
    <a asp-action="Index"
       class="flex min-w-[84px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-10 px-4 bg-slate-200 dark:bg-slate-800 text-slate-700 dark:text-white text-sm font-bold leading-normal transition-colors hover:bg-slate-300 dark:hover:bg-slate-700 no-underline">
        <span class="truncate">Volver al listado</span>
    </a>
</div>

<form asp-action="Create" method="post" id="form-orden">
    @Html.AntiForgeryToken()

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Column: Form Details -->
        <div class="lg:col-span-2 flex flex-col gap-6">
            <!-- Datos Generales Card -->
            <div class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/50 p-6 shadow-sm">
                <h2 class="text-slate-900 dark:text-white text-xl font-bold mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">description</span>
                    Datos Generales
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <label class="flex flex-col gap-2">
                        <span class="text-slate-700 dark:text-slate-300 text-sm font-medium">Número de Orden</span>
                        <input type="text" asp-for="Numero" readonly
                               class="rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-100 dark:bg-slate-800 text-slate-500 cursor-not-allowed h-12 px-4 focus:ring-0" />
                    </label>
                    <label class="flex flex-col gap-2">
                        <span class="text-slate-700 dark:text-slate-300 text-sm font-medium">Proveedor</span>
                        <select asp-for="ProveedorId"
                                class="rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white h-12 px-4 focus:border-primary focus:ring-1 focus:ring-primary outline-none">
                            <option value="">Seleccione un proveedor</option>
                            @if (proveedores != null)
                            {
                                @foreach (var p in proveedores)
                                {
                                    <option value="@p.Value" selected="@p.Selected">@p.Text</option>
                                }
                            }
                        </select>
                    </label>
                    <label class="flex flex-col gap-2">
                        <span class="text-slate-700 dark:text-slate-300 text-sm font-medium">Fecha Emisión</span>
                        <input type="date" asp-for="FechaEmision"
                               class="rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white h-12 px-4 focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                    </label>
                    <label class="flex flex-col gap-2">
                        <span class="text-slate-700 dark:text-slate-300 text-sm font-medium">Fecha Entrega Estimada</span>
                        <input type="date" asp-for="FechaEntregaEstimada"
                               class="rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white h-12 px-4 focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                    </label>
                    <label class="flex flex-col gap-2 md:col-span-2">
                        <span class="text-slate-700 dark:text-slate-300 text-sm font-medium">Estado</span>
                        <select asp-for="Estado"
                                class="rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white h-12 px-4 focus:border-primary focus:ring-1 focus:ring-primary outline-none">
                            <option value="@((int)EstadoOrdenCompra.Borrador)">Borrador</option>
                            <option value="@((int)EstadoOrdenCompra.Enviada)">Enviada</option>
                            <option value="@((int)EstadoOrdenCompra.Confirmada)">Confirmada</option>
                            <option value="@((int)EstadoOrdenCompra.Cancelada)">Cancelada</option>
                        </select>
                    </label>
                    <label class="flex flex-col gap-2 md:col-span-2">
                        <span class="text-slate-700 dark:text-slate-300 text-sm font-medium">Observaciones</span>
                        <textarea asp-for="Observaciones" rows="3"
                                  class="rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white p-4 focus:border-primary focus:ring-1 focus:ring-primary outline-none resize-none"
                                  placeholder="Notas adicionales sobre la orden..."></textarea>
                    </label>
                </div>
            </div>

            <!-- Productos Card -->
            <div class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/50 p-6 shadow-sm">
                <h2 class="text-slate-900 dark:text-white text-xl font-bold mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">inventory_2</span>
                    Productos
                </h2>
                <p class="text-sm text-slate-500 dark:text-slate-400 mb-5">
                    Buscá un producto, ajustá cantidad y precio, y agregalo a la orden. En pantallas chicas la tabla se desplaza horizontalmente.
                </p>
                <div id="ordencompra-feedback" class="ordencompra-feedback" data-variant="warning" role="status" aria-live="polite" hidden>
                    <span class="material-symbols-outlined text-[20px]" data-feedback-icon>warning</span>
                    <div class="min-w-0 flex-1">
                        <p class="text-sm font-bold leading-tight" data-feedback-title>Revisá este paso</p>
                        <p class="text-sm opacity-90" data-feedback-message></p>
                    </div>
                    <button type="button" class="ordencompra-feedback__dismiss" data-feedback-close aria-label="Cerrar mensaje">
                        <span class="material-symbols-outlined text-[18px]">close</span>
                    </button>
                </div>
                <!-- Search and Add Bar -->
                <div class="ordencompra-product-toolbar">
                    <label class="flex flex-col gap-2 ordencompra-product-toolbar__search">
                        <span class="text-slate-700 dark:text-slate-300 text-xs font-semibold uppercase">Buscar Producto</span>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                            <input type="text" id="inp-buscar-producto"
                                   aria-controls="dropdown-productos"
                                   aria-expanded="false"
                                   aria-autocomplete="list"
                                   class="w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white h-11 pl-10 pr-4 focus:border-primary focus:ring-1 focus:ring-primary outline-none"
                                   placeholder="Código o nombre..." autocomplete="off" />
                            <!-- Dropdown de resultados -->
                            <div id="dropdown-productos" role="listbox" class="absolute z-30 left-0 right-0 top-full mt-1 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg shadow-xl max-h-48 overflow-y-auto hidden"></div>
                        </div>
                    </label>
                    <label class="flex flex-col gap-2 ordencompra-product-toolbar__field">
                        <span class="text-slate-700 dark:text-slate-300 text-xs font-semibold uppercase">Cant.</span>
                        <input type="number" id="inp-cantidad" min="1" step="1" value="1"
                               class="rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white h-11 px-3 focus:border-primary focus:ring-1 focus:ring-primary outline-none text-center" />
                    </label>
                    <label class="flex flex-col gap-2 ordencompra-product-toolbar__field">
                        <span class="text-slate-700 dark:text-slate-300 text-xs font-semibold uppercase">Precio</span>
                        <input type="number" id="inp-precio" step="0.01" placeholder="0.00"
                               class="rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white h-11 px-3 focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                    </label>
                    <button type="button" id="btn-agregar"
                            aria-label="Agregar producto a la orden"
                            class="ordencompra-add-button bg-primary text-white rounded-lg flex items-center justify-center hover:bg-primary/90 transition-colors shadow-lg shadow-primary/20">
                        <span class="material-symbols-outlined">add</span>
                        <span class="text-sm font-bold">Agregar producto</span>
                    </button>
                </div>
                <!-- Table of Products -->
                <div class="ordencompra-product-table-shell"
                     data-oc-scroll
                     style="--oc-scroll-min-width: 42rem; --oc-scrollbar-gutter: stable both-edges; --oc-scroll-fade-bottom: 0.5rem;">
                    <div data-oc-scroll-hint class="ordencompra-scroll-hint" hidden>
                        <span class="material-symbols-outlined text-[18px]">swipe</span>
                        <span id="ordencompra-scroll-hint-text">Deslizá la tabla para revisar cantidades, precios y quitar productos.</span>
                    </div>
                    <div class="ordencompra-product-scroll-shell" data-oc-scroll-shell>
                        <div data-oc-scroll-fade="left" aria-hidden="true" hidden></div>
                        <div data-oc-scroll-fade="right" aria-hidden="true" hidden></div>
                        <div data-oc-scroll-region class="ordencompra-product-scroll" tabindex="0" role="region" aria-label="Productos agregados a la orden" aria-describedby="ordencompra-scroll-hint-text">
                            <table data-oc-scroll-table class="w-full text-left border-collapse">
                                <thead>
                            <tr class="border-b border-slate-200 dark:border-slate-800">
                                <th class="py-4 px-2 text-slate-500 dark:text-slate-400 font-semibold text-sm">Producto</th>
                                <th class="py-4 px-2 text-slate-500 dark:text-slate-400 font-semibold text-sm text-center">Cantidad</th>
                                <th class="py-4 px-2 text-slate-500 dark:text-slate-400 font-semibold text-sm text-right">Precio Unit.</th>
                                <th class="py-4 px-2 text-slate-500 dark:text-slate-400 font-semibold text-sm text-right">Subtotal</th>
                                <th class="py-4 px-2 text-slate-500 dark:text-slate-400 font-semibold text-sm text-center w-16"></th>
                            </tr>
                                </thead>
                                <tbody id="tabla-productos" class="divide-y divide-slate-100 dark:divide-slate-800/50">
                                    <!-- Empty State (visible when no products) -->
                                    <tr id="empty-state">
                                        <td colspan="5" class="py-12 text-center">
                                            <div class="flex flex-col items-center gap-2 opacity-40">
                                                <span class="material-symbols-outlined text-4xl">inventory</span>
                                                <p class="text-slate-500 dark:text-slate-400 text-base">No hay productos agregados</p>
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Totals & Actions -->
        <div class="flex flex-col gap-6">
            <div class="ordencompra-summary-card rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/50 p-6 shadow-sm">
                <h2 class="text-slate-900 dark:text-white text-lg font-bold mb-6">Resumen de Totales</h2>
                <p class="ordencompra-summary-meta">
                    Los importes se recalculan automáticamente cuando agregás productos o ajustás el descuento.
                </p>
                <div class="space-y-4 ordencompra-summary-totals">
                    <label class="flex flex-col gap-2 pb-4 border-b border-slate-100 dark:border-slate-800">
                        <span class="text-slate-700 dark:text-slate-300 text-sm font-medium">Aplicar Descuento ($)</span>
                        <input type="number" id="inp-descuento" step="0.01" placeholder="0.00" value="@descuentoInicial"
                               class="rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white h-11 px-4 focus:border-primary focus:ring-1 focus:ring-primary outline-none" />
                    </label>
                    <div class="flex justify-between items-center text-slate-600 dark:text-slate-400 text-sm">
                        <span>Subtotal</span>
                        <span class="font-semibold text-slate-900 dark:text-white" id="lbl-subtotal">$0.00</span>
                    </div>
                    <div class="flex justify-between items-center text-slate-600 dark:text-slate-400 text-sm">
                        <span>Descuento</span>
                        <span class="font-semibold text-red-500" id="lbl-descuento">-$0.00</span>
                    </div>
                    <div class="flex justify-between items-center text-slate-600 dark:text-slate-400 text-sm">
                        <span>IVA (21%)</span>
                        <span class="font-semibold text-slate-900 dark:text-white" id="lbl-iva">$0.00</span>
                    </div>
                    <div class="pt-4 border-t border-slate-200 dark:border-slate-700 mt-4">
                        <div class="flex justify-between items-end">
                            <span class="text-slate-900 dark:text-white font-bold text-lg">Total</span>
                            <span class="text-primary font-black text-3xl" id="lbl-total">$0.00</span>
                        </div>
                    </div>
                </div>
                <!-- Form Actions -->
                <div class="ordencompra-summary-actions">
                    <button type="submit"
                            class="w-full bg-primary text-white font-bold py-4 rounded-xl shadow-lg shadow-primary/30 hover:bg-primary/90 transition-all flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-[20px]">save</span>
                        Guardar Orden
                    </button>
                    <a asp-action="Index"
                       class="w-full py-3 text-center text-slate-500 dark:text-slate-400 font-medium hover:text-slate-900 dark:hover:text-white transition-colors no-underline block">
                        Cancelar
                    </a>
                </div>
                <!-- Hidden fields for totals -->
                <input type="hidden" asp-for="Subtotal" id="hdn-subtotal" />
                <input type="hidden" asp-for="Descuento" id="hdn-descuento" />
                <input type="hidden" asp-for="Iva" id="hdn-iva" />
                <input type="hidden" asp-for="Total" id="hdn-total" />
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
    <script id="ordencompra-productos-data" type="application/json">@Html.Raw(productosJson)</script>
    <script id="ordencompra-detalles-data" type="application/json">@Html.Raw(detallesJson)</script>
    <script src="~/js/ordencompra-form.js" asp-append-version="true"></script>
}
