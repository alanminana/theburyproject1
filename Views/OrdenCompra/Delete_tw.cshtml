@model TheBuryProject.ViewModels.OrdenCompraViewModel
@using TheBuryProject.Models.Enums
@{
    ViewData["Title"] = $"Eliminar {Model.Numero}";

    var estadoBadgeClass = OrdenCompraUiHelper.EstadoBadgeClass(Model.Estado);
    var estadoNombre = OrdenCompraUiHelper.EstadoNombre(Model.Estado);
}

@if (TempData["Error"] is string errorMsg)
{
    <div class="mb-4 flex items-center gap-3 rounded-lg border border-rose-500/20 bg-rose-500/10 p-4 text-rose-400">
        <span class="material-symbols-outlined">error</span>
        <p class="text-sm font-medium">@errorMsg</p>
    </div>
}

<div class="mx-auto flex max-w-4xl flex-col gap-6">
    <header class="flex flex-wrap items-start justify-between gap-4">
        <div class="flex items-start gap-3">
            <a asp-action="Details"
               asp-route-id="@Model.Id"
               class="flex h-10 w-10 items-center justify-center rounded-lg bg-slate-100 transition-colors hover:bg-slate-200 bg-slate-800 text-slate-200 hover:bg-slate-700 no-underline"
               aria-label="Volver al detalle de la orden">
                <span class="material-symbols-outlined text-sm">arrow_back</span>
            </a>
            <div class="flex flex-col gap-1">
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-rose-500">Zona de riesgo</p>
                <h1 class="text-3xl font-black tracking-tight text-white">Eliminar Orden de Compra</h1>
                <p class="max-w-2xl text-sm text-slate-400">
                    Revisá la información antes de confirmar. Esta operación elimina la orden y sus detalles activos del circuito operativo.
                </p>
            </div>
        </div>
        <span class="@estadoBadgeClass">@estadoNombre</span>
    </header>

    <section class="rounded-xl border border-rose-900/40 bg-rose-950/20 p-5">
        <div class="flex items-start gap-3">
            <span class="material-symbols-outlined mt-0.5 text-rose-500">warning</span>
            <div class="space-y-1">
                <p class="text-sm font-bold text-rose-300">¿Confirmás la eliminación de esta orden?</p>
                <p class="text-sm text-rose-700/80 text-rose-300/80">
                    No vas a poder seguir operándola desde el módulo. Si la orden tiene restricciones de negocio, el sistema va a bloquear la operación.
                </p>
            </div>
        </div>
    </section>

    <section class="grid gap-6 lg:grid-cols-[minmax(0,1.65fr)_minmax(18rem,1fr)]">
        <div class="overflow-hidden rounded-xl border shadow-sm border-slate-800 bg-slate-900/50">
            <div class="border-b px-6 py-5 border-slate-800">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary">description</span>
                    <h2 class="text-lg font-bold text-white">Resumen de la orden</h2>
                </div>
            </div>
            <div class="grid gap-5 px-6 py-6 sm:grid-cols-2">
                <div class="space-y-1">
                    <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Número</p>
                    <p class="font-mono text-lg font-bold text-white">@Model.Numero</p>
                </div>
                <div class="space-y-1">
                    <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Proveedor</p>
                    <p class="font-semibold text-white">@(Model.ProveedorNombre ?? "—")</p>
                </div>
                <div class="space-y-1">
                    <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Fecha de emisión</p>
                    <p class="font-medium text-white">@Model.FechaEmision.ToString("dd/MM/yyyy")</p>
                </div>
                <div class="space-y-1">
                    <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Entrega estimada</p>
                    <p class="font-medium text-white">@(Model.FechaEntregaEstimada?.ToString("dd/MM/yyyy") ?? "No definida")</p>
                </div>
                <div class="space-y-1">
                    <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Items</p>
                    <p class="font-semibold text-white">@Model.TotalItems</p>
                </div>
                <div class="space-y-1">
                    <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Total</p>
                    <p class="text-xl font-black text-rose-400">$@Model.Total.ToString("N2")</p>
                </div>
                <div class="space-y-1 sm:col-span-2">
                    <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Observaciones</p>
                    <p class="text-sm text-slate-300">@(string.IsNullOrWhiteSpace(Model.Observaciones) ? "Sin observaciones registradas." : Model.Observaciones)</p>
                </div>
            </div>
        </div>

        <aside class="rounded-xl border p-5 border-slate-800 bg-slate-900/70">
            <h2 class="text-base font-bold text-white">Antes de confirmar</h2>
            <ul class="mt-4 space-y-3 text-sm text-slate-300">
                <li class="flex items-start gap-2">
                    <span class="material-symbols-outlined mt-0.5 text-base text-slate-400">check_circle</span>
                    <span>La orden dejará de aparecer en el listado operativo.</span>
                </li>
                <li class="flex items-start gap-2">
                    <span class="material-symbols-outlined mt-0.5 text-base text-slate-400">check_circle</span>
                    <span>Los detalles activos asociados también se marcarán como eliminados.</span>
                </li>
                <li class="flex items-start gap-2">
                    <span class="material-symbols-outlined mt-0.5 text-base text-slate-400">info</span>
                    <span>Si existen cheques asociados u otra restricción de negocio, el sistema cancelará la eliminación.</span>
                </li>
            </ul>

            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-6 flex flex-col gap-3">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <button type="submit"
                        class="inline-flex h-11 items-center justify-center gap-2 rounded-lg bg-rose-600 px-4 text-sm font-bold text-white shadow-lg shadow-rose-600/20 transition-colors hover:bg-rose-700">
                    <span class="material-symbols-outlined text-lg">delete</span>
                    Confirmar eliminación
                </button>

                <a asp-action="Details"
                   asp-route-id="@Model.Id"
                   class="inline-flex h-11 items-center justify-center rounded-lg border border-slate-300 px-4 text-sm font-semibold text-slate-600 transition-colors hover:bg-slate-100 border-slate-700 text-slate-300 hover:bg-slate-800 no-underline">
                    Volver al detalle
                </a>
            </form>
        </aside>
    </section>
</div>
