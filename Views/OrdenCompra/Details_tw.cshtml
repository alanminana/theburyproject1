@model TheBuryProject.ViewModels.OrdenCompraViewModel
@using TheBuryProject.Models.Enums
@{
    ViewData["Title"] = $"Orden {Model.Numero}";

    var estadoBadge = Model.Estado switch
    {
        EstadoOrdenCompra.Borrador   => ("bg-slate-500/20 text-slate-600 dark:text-slate-400 border-slate-500/30", "Borrador"),
        EstadoOrdenCompra.Enviada     => ("bg-blue-500/20 text-blue-600 dark:text-blue-400 border-blue-500/30",    "Enviada"),
        EstadoOrdenCompra.Confirmada  => ("bg-green-500/20 text-green-600 dark:text-green-400 border-green-500/30", "Confirmada"),
        EstadoOrdenCompra.EnTransito  => ("bg-amber-500/20 text-amber-600 dark:text-amber-400 border-amber-500/30", "En Tránsito"),
        EstadoOrdenCompra.Recibida    => ("bg-emerald-500/20 text-emerald-600 dark:text-emerald-400 border-emerald-500/30", "Recibida"),
        EstadoOrdenCompra.Cancelada   => ("bg-red-500/20 text-red-600 dark:text-red-400 border-red-500/30",       "Cancelada"),
        _ => ("bg-slate-500/20 text-slate-600 border-slate-500/30", Model.Estado.ToString())
    };

    var puedeCambiarEstado = Model.Estado != EstadoOrdenCompra.Recibida && Model.Estado != EstadoOrdenCompra.Cancelada;
    var puedeRecepcionar = Model.Estado == EstadoOrdenCompra.Confirmada || Model.Estado == EstadoOrdenCompra.EnTransito;
    var totalUnidades = Model.Detalles.Sum(d => d.Cantidad);
    var totalRecibidas = Model.Detalles.Sum(d => Math.Min(d.CantidadRecibida, d.Cantidad));
    var totalPendientes = Model.Detalles.Sum(d => Math.Max(d.Cantidad - d.CantidadRecibida, 0));
    var porcentajeRecepcion = totalUnidades > 0
        ? (int)Math.Round((double)totalRecibidas / totalUnidades * 100d, MidpointRounding.AwayFromZero)
        : 0;
    var hayPendientes = Model.Detalles.Any(d => d.CantidadRecibida < d.Cantidad);

    var estadoOptions = new[]
    {
        (EstadoOrdenCompra.Borrador,   "Borrador"),
        (EstadoOrdenCompra.Enviada,    "Enviada"),
        (EstadoOrdenCompra.Confirmada, "Confirmada"),
        (EstadoOrdenCompra.EnTransito, "En Tránsito"),
        (EstadoOrdenCompra.Recibida,   "Recibida"),
        (EstadoOrdenCompra.Cancelada,  "Cancelada"),
    };
}

<!-- Alerts -->
@if (TempData["Success"] is string successMsg)
{
    <div id="toast-success" role="status" aria-live="polite" class="flex items-center gap-3 p-4 rounded-lg bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 dark:text-emerald-400 mb-2">
        <span class="material-symbols-outlined">check_circle</span>
        <p class="text-sm font-medium">@successMsg</p>
    </div>
}
@if (TempData["Error"] is string errorMsg)
{
    <div id="toast-error" role="alert" class="flex items-center gap-3 p-4 rounded-lg bg-rose-500/10 border border-rose-500/20 text-rose-600 dark:text-rose-400 mb-2">
        <span class="material-symbols-outlined">error</span>
        <p class="text-sm font-medium">@errorMsg</p>
    </div>
}

<!-- Hero -->
<section class="mb-6 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900/50 sm:p-6">
    <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
        <div class="flex flex-col gap-3">
            <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400 text-xs font-medium uppercase tracking-wider">
                <a asp-action="Index" class="hover:text-primary no-underline transition-colors">Ordenes de Compra</a>
                <span class="material-symbols-outlined text-xs">chevron_right</span>
                <span class="text-primary">@Model.Numero</span>
            </div>
            <div class="flex flex-col gap-2">
                <h1 class="text-slate-900 dark:text-slate-100 text-3xl font-black tracking-tight">Detalle de Orden de Compra</h1>
                <p class="max-w-3xl text-sm text-slate-500 dark:text-slate-400">
                    Seguimiento completo de la orden, su estado operativo y el avance de recepción de los productos asociados.
                </p>
            </div>
        </div>

        <div class="ocd-header-actions">
            <a asp-action="Index"
               class="ocd-header-action flex items-center justify-center gap-2 rounded-xl border border-slate-200 bg-slate-100 text-slate-700 text-sm font-bold transition-colors hover:bg-slate-200 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700 no-underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/40 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:focus-visible:ring-offset-slate-900">
                <span class="material-symbols-outlined text-sm">arrow_back</span>
                Volver
            </a>
            <span class="ocd-header-action inline-flex items-center justify-center gap-2 rounded-xl border border-slate-200 bg-slate-100 text-slate-500 text-sm font-bold opacity-70 cursor-not-allowed dark:border-slate-700 dark:bg-slate-800 dark:text-slate-400"
                  aria-disabled="true"
                  aria-label="Editar no disponible"
                  title="La edición de órdenes de compra todavía no está disponible">
                <span class="material-symbols-outlined text-sm">edit</span>
                Editar
            </span>
            @if (puedeRecepcionar)
            {
                <a asp-action="Recepcionar" asp-route-id="@Model.Id"
                   class="ocd-header-action flex items-center justify-center gap-2 rounded-xl bg-primary text-white text-sm font-bold transition-colors hover:bg-primary/90 shadow-lg shadow-primary/20 no-underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/40 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:focus-visible:ring-offset-slate-900">
                    <span class="material-symbols-outlined text-sm">inventory_2</span>
                    Recepcionar
                </a>
            }
        </div>
    </div>

    <div class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
        <article class="ocd-stat-card">
            <span class="ocd-stat-label">Estado actual</span>
            <div class="mt-2">
                <span class="inline-flex items-center rounded-full border px-3 py-1 text-xs font-bold uppercase tracking-wide @estadoBadge.Item1">
                    @estadoBadge.Item2
                </span>
            </div>
        </article>
        <article class="ocd-stat-card">
            <span class="ocd-stat-label">Productos</span>
            <p class="mt-2 text-2xl font-black leading-none text-slate-900 dark:text-white">@Model.Detalles.Count</p>
            <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">@totalUnidades unidad(es) solicitada(s)</p>
        </article>
        <article class="ocd-stat-card">
            <span class="ocd-stat-label">Recepción</span>
            <p class="mt-2 text-2xl font-black leading-none text-slate-900 dark:text-white">@porcentajeRecepcion%</p>
            <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">@totalPendientes unidad(es) pendiente(s)</p>
        </article>
        <article class="ocd-stat-card ocd-stat-card--accent">
            <span class="ocd-stat-label">Total ordenado</span>
            <p class="mt-2 text-2xl font-black leading-none text-primary">$ @Model.Total.ToString("N2")</p>
            <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">Incluye impuestos y descuentos aplicados</p>
        </article>
    </div>
</section>

<!-- Info Grid -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
    <!-- General Info Card -->
    <div class="lg:col-span-2 flex flex-col bg-white dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-xl overflow-hidden">
        <div class="border-b border-slate-200 p-6 dark:border-slate-800">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                <div class="flex items-center gap-3">
                    <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-primary/10 text-primary">
                        <span class="material-symbols-outlined">info</span>
                    </div>
                    <div>
                        <h2 class="text-lg font-bold text-slate-900 dark:text-white">Información General</h2>
                        <p class="text-sm text-slate-500 dark:text-slate-400">Datos clave de identificación, proveedor y fechas operativas.</p>
                    </div>
                </div>
                <span class="inline-flex w-fit items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide @estadoBadge.Item1 border">
                    @estadoBadge.Item2
                </span>
            </div>
        </div>
        <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-y-6 gap-x-12">
            <div class="space-y-1">
                <p class="text-slate-500 dark:text-slate-400 text-xs font-semibold uppercase">Número de Orden</p>
                <p class="text-slate-900 dark:text-slate-100 font-mono font-bold text-lg">@Model.Numero</p>
            </div>
            <div class="space-y-1">
                <p class="text-slate-500 dark:text-slate-400 text-xs font-semibold uppercase">Proveedor</p>
                <p class="text-slate-900 dark:text-slate-100 font-bold">@(Model.ProveedorNombre ?? "—")</p>
            </div>
            <div class="space-y-1">
                <p class="text-slate-500 dark:text-slate-400 text-xs font-semibold uppercase">Fecha de Emisión</p>
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm text-slate-400">calendar_today</span>
                    <p class="text-slate-900 dark:text-slate-100 font-medium">@Model.FechaEmision.ToString("dd/MM/yyyy")</p>
                </div>
            </div>
            <div class="space-y-1">
                <p class="text-slate-500 dark:text-slate-400 text-xs font-semibold uppercase">Entrega Estimada</p>
                @if (Model.FechaEntregaEstimada.HasValue)
                {
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm text-primary">local_shipping</span>
                        <p class="text-slate-900 dark:text-slate-100 font-medium">@Model.FechaEntregaEstimada.Value.ToString("dd/MM/yyyy")</p>
                    </div>
                }
                else
                {
                    <p class="text-slate-400 italic">No definida</p>
                }
            </div>
            <div class="space-y-1">
                <p class="text-slate-500 dark:text-slate-400 text-xs font-semibold uppercase">Fecha de Recepción</p>
                @if (Model.FechaRecepcion.HasValue)
                {
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm text-emerald-500">check_circle</span>
                        <p class="text-emerald-600 dark:text-emerald-400 font-medium">@Model.FechaRecepcion.Value.ToString("dd/MM/yyyy")</p>
                    </div>
                }
                else
                {
                    <p class="text-slate-400 italic">Pendiente</p>
                }
            </div>
            <div class="space-y-1">
                <p class="text-slate-500 dark:text-slate-400 text-xs font-semibold uppercase">Observaciones</p>
                @if (!string.IsNullOrWhiteSpace(Model.Observaciones))
                {
                    <p class="text-slate-600 dark:text-slate-300 text-sm">@Model.Observaciones</p>
                }
                else
                {
                    <p class="text-slate-400 italic text-sm">Sin observaciones</p>
                }
            </div>
        </div>
    </div>

    <!-- Status Update Panel -->
    <aside class="flex h-fit flex-col bg-white dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-xl p-6 gap-6 lg:sticky lg:top-24">
        <div class="flex items-center gap-3">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-primary/10 text-primary">
                <span class="material-symbols-outlined">sync</span>
            </div>
            <div>
                <h2 class="text-lg font-bold text-slate-900 dark:text-white">Cambiar Estado</h2>
                <p class="text-sm text-slate-500 dark:text-slate-400">Actualizá el ciclo operativo de la orden con confirmación previa.</p>
            </div>
        </div>
        @if (puedeCambiarEstado)
        {
            <form asp-action="CambiarEstado" method="post" id="form-cambiar-estado" class="flex flex-col gap-4">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="flex flex-col gap-2">
                    <label for="select-estado" class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Seleccionar Nuevo Estado</label>
                    <div class="relative">
                        <select name="nuevoEstado" id="select-estado"
                                aria-describedby="estado-ayuda"
                                class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg h-11 text-sm appearance-none px-4 focus:ring-primary focus:border-primary text-slate-900 dark:text-white">
                            @foreach (var opt in estadoOptions)
                            {
                                <option value="@((int)opt.Item1)" selected="@(opt.Item1 == Model.Estado)">@opt.Item2</option>
                            }
                        </select>
                        <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">expand_more</span>
                    </div>
                </div>
                <button type="submit" id="btn-cambiar-estado"
                        class="inline-flex w-full items-center justify-center gap-2 bg-primary/10 text-primary border border-primary/20 font-bold h-11 rounded-lg hover:bg-primary hover:text-white transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/40 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:focus-visible:ring-offset-slate-900">
                    <span class="material-symbols-outlined text-sm">published_with_changes</span>
                    Actualizar Estado
                </button>
                <p id="estado-ayuda" class="text-xs text-slate-500 dark:text-slate-400">
                    Antes de enviar, el sistema te va a pedir confirmación de este cambio.
                </p>
                <hr class="border-slate-200 dark:border-slate-800" />
                <div class="flex items-start gap-3 p-3 rounded-lg bg-blue-500/5 border border-blue-500/10">
                    <span class="material-symbols-outlined text-blue-500">help</span>
                    <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">
                        El cambio de estado notificará automáticamente al proveedor @(Model.ProveedorNombre ?? "").
                    </p>
                </div>
            </form>
        }
        else
        {
            <div class="flex items-center gap-3 p-4 rounded-lg bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700">
                <span class="material-symbols-outlined text-slate-400">lock</span>
                <p class="text-sm text-slate-500 dark:text-slate-400">
                    Esta orden está <strong>@estadoBadge.Item2</strong> y no permite cambios de estado.
                </p>
            </div>
        }
    </aside>
</div>

<!-- Products Table Section -->
<section class="mb-6 flex flex-col overflow-hidden rounded-xl border border-slate-200 bg-white dark:border-slate-800 dark:bg-slate-900/50"
         data-oc-scroll
         style="--oc-scroll-min-width: 44rem; --oc-scroll-fade-light: rgba(248, 250, 252, 0.98); --oc-scroll-fade-dark: rgba(15, 23, 42, 0.95);">
    <div class="p-6 border-b border-slate-200 dark:border-slate-800 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary">list_alt</span>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white">Productos en la Orden</h3>
        </div>
        <div class="flex flex-wrap items-center gap-2">
            <span class="inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-slate-100 px-3 py-1 text-xs font-bold uppercase tracking-wide text-slate-600 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-300">
                <span class="material-symbols-outlined text-sm">inventory</span>
                @Model.Detalles.Count producto(s)
            </span>
            @if (hayPendientes)
            {
                <div class="flex items-center gap-2 px-3 py-1 rounded-lg bg-primary/10 text-primary border border-primary/20">
                    <span class="material-symbols-outlined text-sm">pending_actions</span>
                    <span class="text-xs font-bold uppercase">@totalPendientes unidad(es) pendiente(s)</span>
                </div>
            }
            else if (Model.Detalles.Any())
            {
                <div class="flex items-center gap-2 px-3 py-1 rounded-lg bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-500/20">
                    <span class="material-symbols-outlined text-sm">check_circle</span>
                    <span class="text-xs font-bold uppercase">Recepción Completa</span>
                </div>
            }
        </div>
    </div>
    <div data-oc-scroll-hint
         class="mx-6 mt-4 flex items-center justify-between gap-3 rounded-lg border border-slate-200 bg-slate-100/80 px-3 py-2 text-xs text-slate-600 dark:border-slate-700 dark:bg-slate-800/60 dark:text-slate-300 lg:hidden"
         hidden>
        <div class="flex items-center gap-2 font-semibold">
            <span class="material-symbols-outlined text-base text-primary" aria-hidden="true">swipe</span>
            <span id="ordencompra-details-scroll-hint">Deslizá la tabla para ver todos los importes</span>
        </div>
        <span class="rounded-full bg-white/90 px-2 py-1 text-[11px] font-bold uppercase tracking-wide text-slate-500 dark:bg-slate-900/80 dark:text-slate-400">
            Scroll horizontal
        </span>
    </div>
    <div class="relative px-0 pb-0 pt-4 sm:pt-5" data-oc-scroll-shell>
        <div data-oc-scroll-fade="left"
             class="pointer-events-none absolute inset-y-4 left-0 z-10 w-5"
             hidden></div>
        <div data-oc-scroll-fade="right"
             class="pointer-events-none absolute inset-y-4 right-0 z-10 w-8"
             hidden></div>
        <div data-oc-scroll-region
             class="overflow-x-auto focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/40 focus-visible:ring-offset-2 focus-visible:ring-offset-slate-50 dark:focus-visible:ring-offset-background-dark"
             role="region"
             aria-label="Detalle de productos de la orden"
             aria-describedby="ordencompra-details-scroll-hint"
             tabindex="0">
            <table data-oc-scroll-table class="ocd-products-table w-full text-left border-collapse">
                <caption class="ocd-visually-hidden">Productos incluidos en la orden de compra y estado de recepción.</caption>
                <thead>
                    <tr class="bg-slate-50 dark:bg-slate-800/50">
                        <th scope="col" class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider border-b border-slate-200 dark:border-slate-800">Producto</th>
                        <th scope="col" class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider border-b border-slate-200 dark:border-slate-800 text-center">Cantidad</th>
                        <th scope="col" class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider border-b border-slate-200 dark:border-slate-800 text-center">Recibida</th>
                        <th scope="col" class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider border-b border-slate-200 dark:border-slate-800 text-right">Precio Unitario</th>
                        <th scope="col" class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider border-b border-slate-200 dark:border-slate-800 text-right">Subtotal</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 dark:divide-slate-800">
                    @if (Model.Detalles.Any())
                    {
                        @foreach (var d in Model.Detalles)
                        {
                            <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-colors">
                                <td>
                                    <div class="flex items-center gap-3">
                                        <div class="size-10 rounded-lg bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-400 shrink-0">
                                            <span class="material-symbols-outlined">image</span>
                                        </div>
                                        <div>
                                            <p class="font-bold text-slate-900 dark:text-slate-100">@d.ProductoNombre</p>
                                            @if (!string.IsNullOrEmpty(d.ProductoCodigo))
                                            {
                                                <p class="text-xs text-primary font-mono">SKU: @d.ProductoCodigo</p>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center font-medium text-slate-900 dark:text-white">@d.Cantidad</td>
                                <td class="text-center">
                                    @if (d.CantidadRecibida >= d.Cantidad && d.Cantidad > 0)
                                    {
                                        <span class="px-2 py-1 rounded bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400 text-xs font-bold">@d.CantidadRecibida</span>
                                    }
                                    else if (d.CantidadRecibida > 0)
                                    {
                                        <span class="px-2 py-1 rounded bg-amber-100 dark:bg-amber-900/30 text-amber-600 dark:text-amber-400 text-xs font-bold">@d.CantidadRecibida</span>
                                    }
                                    else
                                    {
                                        <span class="px-2 py-1 rounded bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 text-xs font-bold">@d.CantidadRecibida</span>
                                    }
                                </td>
                                <td class="text-right font-medium text-slate-700 dark:text-slate-300">$ @d.PrecioUnitario.ToString("N2")</td>
                                <td class="text-right font-bold text-slate-900 dark:text-white">$ @d.Subtotal.ToString("N2")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-16 text-center">
                                <div class="flex flex-col items-center gap-2 text-slate-400">
                                    <span class="material-symbols-outlined text-3xl">inbox</span>
                                    <p class="text-sm font-medium">No hay productos en esta orden</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (Model.Detalles.Any())
    {
        <div class="border-t border-slate-200 bg-slate-50/80 p-4 dark:border-slate-800 dark:bg-slate-800/30 sm:p-6">
            <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
                <div class="ocd-total-card">
                    <span class="ocd-total-label">Subtotal</span>
                    <p class="ocd-total-value">$ @Model.Subtotal.ToString("N2")</p>
                </div>
                @if (Model.Descuento > 0)
                {
                    <div class="ocd-total-card">
                        <span class="ocd-total-label">Descuento</span>
                        <p class="text-lg font-black text-rose-500">- $ @Model.Descuento.ToString("N2")</p>
                    </div>
                }
                @if (Model.Iva > 0)
                {
                    <div class="ocd-total-card">
                        <span class="ocd-total-label">IVA</span>
                        <p class="ocd-total-value">$ @Model.Iva.ToString("N2")</p>
                    </div>
                }
                <div class="ocd-total-card ocd-total-card--accent">
                    <span class="ocd-total-label">Total final</span>
                    <p class="text-2xl font-black leading-none text-primary">$ @Model.Total.ToString("N2")</p>
                </div>
            </div>
        </div>
    }
</section>

<!-- Audit Trail / Footer Info -->
<footer class="rounded-xl border border-slate-200 bg-slate-50 p-4 dark:border-slate-800 dark:bg-slate-900/40 sm:p-5">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
            <div class="inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 text-xs text-slate-500 dark:border-slate-800 dark:bg-slate-900/70 dark:text-slate-400">
                <span class="material-symbols-outlined text-sm">history</span>
                <span>Orden emitida el @Model.FechaEmision.ToString("dd/MM/yyyy")</span>
            </div>
            <div class="inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 text-xs text-slate-500 dark:border-slate-800 dark:bg-slate-900/70 dark:text-slate-400">
                <span class="material-symbols-outlined text-sm">monitoring</span>
                <span>@totalRecibidas de @totalUnidades unidad(es) recepcionadas</span>
            </div>
        </div>
        <button type="button"
                id="btn-imprimir-orden"
                class="inline-flex items-center justify-center gap-2 rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-bold text-slate-700 transition-colors hover:bg-slate-100 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/40 focus-visible:ring-offset-2 focus-visible:ring-offset-slate-50 dark:focus-visible:ring-offset-background-dark">
            <span class="material-symbols-outlined text-base">print</span>
            Imprimir orden
        </button>
    </div>
</footer>

@section Styles {
    <link rel="stylesheet" href="~/css/horizontal-scroll-affordance.css" asp-append-version="true" />
    <style>
        .ocd-header-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            width: 100%;
        }

        .ocd-header-action {
            flex: 1 1 10rem;
            min-height: 2.75rem;
            padding: 0.75rem 1rem;
        }

        .ocd-stat-card {
            border: 1px solid rgb(226 232 240 / 1);
            border-radius: 1rem;
            background: rgb(248 250 252 / 0.86);
            padding: 1rem;
        }

        .dark .ocd-stat-card {
            border-color: rgb(30 41 59 / 1);
            background: rgb(15 23 42 / 0.55);
        }

        .ocd-stat-card--accent {
            background: linear-gradient(135deg, rgb(239 246 255 / 0.95), rgb(248 250 252 / 0.96));
        }

        .dark .ocd-stat-card--accent {
            background: linear-gradient(135deg, rgb(15 23 42 / 0.92), rgb(30 41 59 / 0.82));
        }

        .ocd-stat-label,
        .ocd-total-label {
            font-size: 0.72rem;
            font-weight: 800;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: rgb(100 116 139 / 1);
        }

        .dark .ocd-stat-label,
        .dark .ocd-total-label {
            color: rgb(148 163 184 / 1);
        }

        .ocd-products-table th,
        .ocd-products-table td {
            padding: 1rem;
        }

        .ocd-total-card {
            border: 1px solid rgb(226 232 240 / 1);
            border-radius: 0.875rem;
            background: rgb(255 255 255 / 0.88);
            padding: 1rem;
        }

        .dark .ocd-total-card {
            border-color: rgb(30 41 59 / 1);
            background: rgb(15 23 42 / 0.5);
        }

        .ocd-total-card--accent {
            background: linear-gradient(135deg, rgb(239 246 255 / 0.95), rgb(248 250 252 / 0.96));
        }

        .dark .ocd-total-card--accent {
            background: linear-gradient(135deg, rgb(15 23 42 / 0.92), rgb(30 41 59 / 0.82));
        }

        .ocd-total-value {
            margin-top: 0.5rem;
            font-size: 1.125rem;
            font-weight: 900;
            line-height: 1.1;
            color: rgb(15 23 42 / 1);
        }

        .dark .ocd-total-value {
            color: rgb(248 250 252 / 1);
        }

        .ocd-visually-hidden {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            white-space: nowrap;
            border: 0;
        }

        @@media (min-width: 768px) {
            .ocd-header-actions {
                width: auto;
                justify-content: flex-end;
            }

            .ocd-header-action {
                flex: 0 0 auto;
            }

            .ocd-products-table th,
            .ocd-products-table td {
                padding: 1.25rem 1.5rem;
            }
        }

        @@media (min-width: 1024px) {
            [data-oc-scroll-hint] {
                display: none !important;
            }
        }
    </style>
}

@section Scripts {
    <script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
    <script src="~/js/ordencompra-details.js" asp-append-version="true"></script>
}
