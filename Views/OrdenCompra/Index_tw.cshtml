@model TheBuryProject.ViewModels.OrdenCompraFilterViewModel
@using TheBuryProject.Models.Enums
@{
    ViewData["Title"] = "Órdenes de Compra";
    ViewData["MetaDescription"] = "Gestión de órdenes de compra a proveedores, seguimiento de estados y recepción de mercadería.";
    var ordenes = (ViewBag.Ordenes as IEnumerable<TheBuryProject.ViewModels.OrdenCompraViewModel>
                   ?? Enumerable.Empty<TheBuryProject.ViewModels.OrdenCompraViewModel>()).ToList();
    var proveedores = ViewBag.Proveedores as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    int totalOrdenes = ViewBag.TotalOrdenes ?? 0;
    decimal totalValorizado = ViewBag.TotalValorizado ?? 0m;
    var orderBy = string.IsNullOrWhiteSpace(Model.OrderBy)
        ? "fechaemision"
        : Model.OrderBy.Trim().ToLowerInvariant();
}


@{
    var filtroOCActivo = !string.IsNullOrEmpty(Model.SearchTerm)
                      || Model.ProveedorId.HasValue
                      || Model.Estado.HasValue
                      || Model.FechaDesde.HasValue
                      || Model.FechaHasta.HasValue;
    var filtroOCExpanded = filtroOCActivo ? "true" : "false";
    var filtroOCHidden   = filtroOCActivo ? "false" : "true";
}

<!-- Filters -->
<form asp-action="Index" method="get" id="form-filtros">
    <div class="filter-panel-erp mb-6">
        <div class="flex items-center gap-3">
            <button type="button"
                    id="btn-toggle-filtros"
                    data-expanded="@filtroOCExpanded"
                    aria-expanded="@filtroOCExpanded"
                    aria-controls="filtros-body"
                    class="flex flex-1 items-center justify-between gap-3 text-left">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary text-[18px]">filter_alt</span>
                    <div>
                        <p class="text-xs font-bold uppercase tracking-[0.18em] text-primary">Filtros</p>
                        <p class="text-sm text-slate-400">Buscá por nº de orden, proveedor, estado o rango de fechas.</p>
                    </div>
                </div>
                <div class="flex shrink-0 items-center gap-2">
                    <span class="badge-erp badge-erp-neutral">@totalOrdenes resultado@(totalOrdenes == 1 ? "" : "s")</span>
                    <span class="material-symbols-outlined filter-panel-erp__toggle-icon text-slate-400">expand_more</span>
                </div>
            </button>
            <a asp-action="Create" class="btn-erp-primary btn-sm no-underline shrink-0">
                <span class="material-symbols-outlined text-[18px]">add_circle</span>
                Nueva Orden
            </a>
        </div>

        <div id="filtros-body" class="filter-panel-erp__body" data-hidden="@filtroOCHidden">
        <!-- Fila 1: búsqueda + proveedor + estado -->
        <div class="grid grid-cols-1 gap-4 pt-4 md:grid-cols-12">
            <div class="md:col-span-5">
                <label class="mb-2 block text-xs font-bold uppercase tracking-wider text-slate-400">Búsqueda rápida</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">search</span>
                    <input type="text" name="SearchTerm" value="@Model.SearchTerm"
                           aria-label="Buscar por Nº de orden o referencia"
                           class="w-full rounded-lg border border-slate-700 bg-slate-900 py-2 pl-10 pr-4 text-sm text-white placeholder:text-slate-500 transition-colors focus:border-primary focus:ring-2 focus:ring-primary/50"
                           placeholder="Nº de orden o referencia..." />
                </div>
            </div>
            <div class="md:col-span-4">
                <label class="mb-2 block text-xs font-bold uppercase tracking-wider text-slate-400">Proveedor</label>
                <select name="ProveedorId"
                        aria-label="Proveedor"
                        class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white transition-colors focus:border-primary focus:ring-2 focus:ring-primary/50">
                    <option value="">Todos</option>
                    @if (proveedores != null)
                    {
                        @foreach (var p in proveedores)
                        {
                            <option value="@p.Value" selected="@(p.Value == Model.ProveedorId?.ToString())">@p.Text</option>
                        }
                    }
                </select>
            </div>
            <div class="md:col-span-3">
                <label class="mb-2 block text-xs font-bold uppercase tracking-wider text-slate-400">Estado</label>
                <select name="Estado"
                        aria-label="Estado de orden"
                        class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white transition-colors focus:border-primary focus:ring-2 focus:ring-primary/50">
                    <option value="">Cualquier estado</option>
                    <option value="@EstadoOrdenCompra.Borrador" selected="@(Model.Estado == EstadoOrdenCompra.Borrador)">Borrador</option>
                    <option value="@EstadoOrdenCompra.Enviada" selected="@(Model.Estado == EstadoOrdenCompra.Enviada)">Enviada</option>
                    <option value="@EstadoOrdenCompra.Confirmada" selected="@(Model.Estado == EstadoOrdenCompra.Confirmada)">Confirmada</option>
                    <option value="@EstadoOrdenCompra.EnTransito" selected="@(Model.Estado == EstadoOrdenCompra.EnTransito)">En tránsito</option>
                    <option value="@EstadoOrdenCompra.Recibida" selected="@(Model.Estado == EstadoOrdenCompra.Recibida)">Recibida</option>
                    <option value="@EstadoOrdenCompra.Cancelada" selected="@(Model.Estado == EstadoOrdenCompra.Cancelada)">Cancelada</option>
                </select>
            </div>
        </div>
        <!-- Fila 2: ordenar + dirección + fechas + botones -->
        <div class="mt-4 grid grid-cols-1 gap-4 border-t border-slate-800 pt-4 md:grid-cols-12">
            <div class="md:col-span-3">
                <label class="mb-2 block text-xs font-bold uppercase tracking-wider text-slate-400">Ordenar por</label>
                <select name="OrderBy"
                        aria-label="Ordenar por"
                        class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white transition-colors focus:border-primary focus:ring-2 focus:ring-primary/50">
                    <option value="fechaemision" selected="@(orderBy == "fechaemision")">Fecha Emisión</option>
                    <option value="numero" selected="@(orderBy == "numero")">Nº Orden</option>
                    <option value="proveedor" selected="@(orderBy == "proveedor")">Proveedor</option>
                    <option value="estado" selected="@(orderBy == "estado")">Estado</option>
                    <option value="total" selected="@(orderBy == "total")">Total</option>
                </select>
            </div>
            <div class="md:col-span-2">
                <label class="mb-2 block text-xs font-bold uppercase tracking-wider text-slate-400">Dirección</label>
                <select name="OrderDirection"
                        aria-label="Dirección de orden"
                        class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white transition-colors focus:border-primary focus:ring-2 focus:ring-primary/50">
                    <option value="desc" selected="@(Model.OrderDirection == "desc")">Descendente</option>
                    <option value="asc" selected="@(Model.OrderDirection == "asc")">Ascendente</option>
                </select>
            </div>
            <div class="md:col-span-2">
                <label class="mb-2 block text-xs font-bold uppercase tracking-wider text-slate-400">Desde</label>
                <input type="date" name="FechaDesde" value="@Model.FechaDesde?.ToString("yyyy-MM-dd")"
                       aria-label="Fecha desde"
                       class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white transition-colors focus:border-primary focus:ring-2 focus:ring-primary/50" />
            </div>
            <div class="md:col-span-2">
                <label class="mb-2 block text-xs font-bold uppercase tracking-wider text-slate-400">Hasta</label>
                <input type="date" name="FechaHasta" value="@Model.FechaHasta?.ToString("yyyy-MM-dd")"
                       aria-label="Fecha hasta"
                       class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white transition-colors focus:border-primary focus:ring-2 focus:ring-primary/50" />
            </div>
            <div class="flex items-end gap-2 md:col-span-3">
                <button type="submit" class="inline-flex h-10 flex-1 items-center justify-center rounded-xl bg-primary px-6 text-sm font-bold text-white transition-colors hover:bg-primary/90">Buscar</button>
                <a asp-action="Index" class="inline-flex h-10 items-center justify-center rounded-xl border border-slate-700 px-3 text-slate-400 transition-colors hover:bg-slate-800 no-underline" title="Limpiar filtros">
                    <span class="material-symbols-outlined">filter_alt_off</span>
                </a>
            </div>
        </div>
        </div>@* /filtros-body *@
    </div>
</form>

<!-- Table -->
<section class="mb-6"
         data-oc-scroll
         style="--oc-scroll-min-width: 860px; --oc-scroll-fade-light: rgba(248, 250, 252, 0.98); --oc-scroll-fade-dark: rgba(15, 23, 42, 0.95);">
    <div data-oc-scroll-hint
         class="mb-3 flex items-center justify-between gap-3 rounded-lg border bg-slate-100/80 px-3 py-2 text-xs text-slate-600 border-slate-700 bg-slate-800/60 text-slate-300 lg:hidden"
         hidden>
        <div class="flex items-center gap-2 font-semibold">
            <span class="material-symbols-outlined text-base text-primary" aria-hidden="true">swipe</span>
            <span id="ordencompra-scroll-hint-text">Deslizá la tabla para ver más columnas</span>
        </div>
        <span class="rounded-full px-2 py-1 text-[11px] font-bold uppercase tracking-wide text-slate-500 bg-slate-900/80 text-slate-400">
            Scroll horizontal
        </span>
    </div>

    <div class="relative" data-oc-scroll-shell>
        <div data-oc-scroll-fade="left"
             class="pointer-events-none absolute inset-y-0 left-0 z-10 w-5"
             hidden></div>
        <div data-oc-scroll-fade="right"
             class="pointer-events-none absolute inset-y-0 right-0 z-10 w-8"
             hidden></div>

        <div data-oc-scroll-region
             class="table-erp-wrapper focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/40 focus-visible:ring-offset-2 focus-visible:ring-offset-background-dark"
             role="region"
             aria-label="Tabla de órdenes de compra"
             aria-describedby="ordencompra-scroll-hint-text"
             tabindex="0">
    <table data-oc-scroll-table class="w-full text-left border-collapse">
        <thead>
            <tr class="border-b border-slate-800">
                <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400 whitespace-nowrap">Número</th>
                <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400 whitespace-nowrap">Proveedor</th>
                <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400 whitespace-nowrap">Fecha Emisión</th>
                <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400 whitespace-nowrap">Fecha Entrega</th>
                <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400 whitespace-nowrap">Estado</th>
                <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400 whitespace-nowrap">Items</th>
                <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400 whitespace-nowrap">Total</th>
                <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400 text-right whitespace-nowrap">Acciones</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-800">
            @if (ordenes.Any())
            {
                @foreach (var o in ordenes)
                {
                    var puedeRecepcionar = o.Estado == EstadoOrdenCompra.Confirmada || o.Estado == EstadoOrdenCompra.EnTransito;
                    var puedeEliminar = o.Estado != EstadoOrdenCompra.Recibida && o.Estado != EstadoOrdenCompra.EnTransito;

                    <tr class="hover:bg-slate-800/50 transition-colors">
                        <td class="px-6 py-4 font-bold text-primary">@o.Numero</td>
                        <td class="px-6 py-4 font-medium">@o.ProveedorNombre</td>
                        <td class="px-6 py-4 text-slate-400">@o.FechaEmision.ToString("dd MMM yyyy")</td>
                        <td class="px-6 py-4 text-slate-400">@(o.FechaEntregaEstimada?.ToString("dd MMM yyyy") ?? "--")</td>
                        <td class="px-6 py-4">
                            <span class="@OrdenCompraUiHelper.EstadoBadgeClass(o.Estado)">
                                @OrdenCompraUiHelper.EstadoNombre(o.Estado)
                            </span>
                        </td>
                        <td class="px-6 py-4">@o.TotalItems</td>
                        <td class="px-6 py-4 font-bold">$@o.Total.ToString("N2")</td>
                        <td class="px-6 py-4 text-right whitespace-nowrap">
                            <div class="flex flex-nowrap justify-end gap-1">
                                <a asp-action="Details" asp-route-id="@o.Id"
                                   class="row-action row-action--primary no-underline"
                                   aria-label="Ver detalle de la orden"
                                   title="Ver detalle">
                                    <span class="material-symbols-outlined" aria-hidden="true">visibility</span>
                                    <span class="row-action__label">Ver</span>
                                </a>
                                <button type="button" disabled
                                        class="row-action row-action--disabled"
                                        aria-label="Editar no disponible"
                                        title="La edición de órdenes de compra todavía no está disponible">
                                    <span class="material-symbols-outlined" aria-hidden="true">edit</span>
                                    <span class="row-action__label">Editar</span>
                                </button>
                                @if (puedeRecepcionar)
                                {
                                    <a asp-action="Recepcionar" asp-route-id="@o.Id"
                                       class="row-action row-action--warning no-underline"
                                       aria-label="Recepcionar mercadería"
                                       title="Recepcionar mercadería">
                                        <span class="material-symbols-outlined" aria-hidden="true">local_shipping</span>
                                        <span class="row-action__label">Recibir</span>
                                    </a>
                                }
                                else
                                {
                                    <button type="button" disabled
                                            class="row-action row-action--disabled"
                                            aria-label="Recepción no disponible"
                                            title="Solo se puede recepcionar en estado Confirmada o En tránsito">
                                        <span class="material-symbols-outlined" aria-hidden="true">local_shipping</span>
                                        <span class="row-action__label">Recibir</span>
                                    </button>
                                }
                                @if (puedeEliminar)
                                {
                                    <a asp-action="Delete" asp-route-id="@o.Id"
                                       class="row-action row-action--danger no-underline"
                                       aria-label="Eliminar orden"
                                       title="Eliminar">
                                        <span class="material-symbols-outlined" aria-hidden="true">delete</span>
                                        <span class="row-action__label">Eliminar</span>
                                    </a>
                                }
                                else
                                {
                                    <button type="button" disabled
                                            class="row-action row-action--disabled"
                                            aria-label="Eliminar no disponible"
                                            title="No se puede eliminar una orden en tránsito o recibida">
                                        <span class="material-symbols-outlined" aria-hidden="true">delete</span>
                                        <span class="row-action__label">Eliminar</span>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>

    <!-- Empty State -->
    @if (!ordenes.Any())
    {
        <div class="flex flex-col items-center justify-center py-20 px-6 text-center">
            <div class="w-16 h-16 bg-slate-800 rounded-full flex items-center justify-center mb-4">
                <span class="material-symbols-outlined text-slate-400 text-3xl">search_off</span>
            </div>
            <h3 class="text-lg font-bold text-white">No se encontraron órdenes</h3>
            <p class="text-slate-400 max-w-xs mt-1">No se encontraron órdenes de compra que coincidan con los filtros aplicados.</p>
            <a asp-action="Index" class="mt-6 text-primary font-semibold hover:underline flex items-center gap-1 no-underline">
                <span class="material-symbols-outlined text-[18px]">filter_alt_off</span>
                Limpiar filtros
            </a>
        </div>
    }
</div>
    </div>
</section>

<!-- Footer -->
<footer class="mt-6 rounded-xl border bg-slate-100 border-slate-800 bg-slate-900/80 p-4 sm:p-5">
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
            <div class="rounded-lg border px-4 py-3 border-slate-800 bg-slate-900/70">
                <span class="text-xs font-bold uppercase tracking-wider text-slate-400">Total Órdenes</span>
                <p class="mt-1 text-2xl font-black leading-none text-white">@totalOrdenes.ToString("N0")</p>
            </div>
            <div class="rounded-lg border px-4 py-3 border-slate-800 bg-slate-900/70">
                <span class="text-xs font-bold uppercase tracking-wider text-slate-400">Total Valorizado</span>
                <p class="mt-1 text-2xl font-black leading-none text-primary">$@totalValorizado.ToString("N2")</p>
            </div>
        </div>
        <div class="flex items-center justify-between gap-2 rounded-lg border border-dashed border-slate-300 px-4 py-3 text-sm text-slate-500 border-slate-700 text-slate-400 lg:min-w-[220px] lg:justify-center">
            <span>Mostrando</span>
            <span class="font-semibold text-white">@ordenes.Count</span>
            <span>órdenes</span>
        </div>
    </div>
</footer>

@if (TempData["Error"] != null)
{
    <div id="toast-error" class="fixed bottom-6 right-6 z-50 flex items-center gap-3 px-5 py-3 rounded-lg bg-red-600 text-white shadow-xl text-sm font-semibold animate-fade-in">
        <span class="material-symbols-outlined text-lg">error</span>
        @TempData["Error"]
    </div>
}
@if (TempData["Success"] != null)
{
    <div id="toast-success" class="fixed bottom-6 right-6 z-50 flex items-center gap-3 px-5 py-3 rounded-lg bg-emerald-600 text-white shadow-xl text-sm font-semibold animate-fade-in">
        <span class="material-symbols-outlined text-lg">check_circle</span>
        @TempData["Success"]
    </div>
}

@section Styles {
    <partial name="_OrdenCompraModuleStyles" />
}

@section Scripts {
    <script src="~/js/module-index.js" asp-append-version="true"></script>
    <script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
    <script src="~/js/ordencompra-index.js" asp-append-version="true"></script>
}
