@model TheBuryProject.ViewModels.OrdenCompraViewModel
@using TheBuryProject.Models.Enums
@{
    ViewData["Title"] = $"Recepcionar - {Model.Numero}";

    var estadoBadgeClass = OrdenCompraUiHelper.EstadoBadgeClass(Model.Estado);
    var estadoNombre = OrdenCompraUiHelper.EstadoNombre(Model.Estado);

    var totalUnidades = Model.Detalles.Sum(d => d.Cantidad);
    var totalRecibidas = Model.Detalles.Sum(d => Math.Min(d.CantidadRecibida, d.Cantidad));
    var totalPendiente = Model.Detalles.Sum(d => Math.Max(d.Cantidad - d.CantidadRecibida, 0));
    var productosConPendiente = Model.Detalles.Count(d => d.CantidadRecibida < d.Cantidad);
    var porcentajeRecepcion = totalUnidades > 0
        ? (int)Math.Round((double)totalRecibidas / totalUnidades * 100d, MidpointRounding.AwayFromZero)
        : 0;
}

@if (TempData["Success"] is string successMsg)
{
    <div id="toast-success" role="status" aria-live="polite" class="mb-3 flex items-center gap-3 rounded-lg border border-emerald-500/20 bg-emerald-500/10 p-3 text-emerald-400">
        <span class="material-symbols-outlined">check_circle</span>
        <p class="text-sm font-medium">@successMsg</p>
    </div>
}
@if (TempData["Error"] is string errorMsg)
{
    <div id="toast-error" role="alert" class="mb-3 flex items-center gap-3 rounded-lg border border-rose-500/20 bg-rose-500/10 p-3 text-rose-400">
        <span class="material-symbols-outlined">error</span>
        <p class="text-sm font-medium">@errorMsg</p>
    </div>
}

<!-- Header compacto: breadcrumb + título + estado + acciones + meta + stats -->
<section class="card-erp-panel p-4 mb-4">
    <div class="oc-head">
        <div class="oc-head__title">
            <nav class="flex items-center gap-2 text-xs font-medium uppercase tracking-wider text-slate-400">
                <a asp-action="Index" class="hover:text-primary no-underline transition-colors">Ordenes de Compra</a>
                <span class="material-symbols-outlined text-xs" aria-hidden="true">chevron_right</span>
                <a asp-action="Details" asp-route-id="@Model.Id" class="hover:text-primary no-underline transition-colors">@Model.Numero</a>
                <span class="material-symbols-outlined text-xs" aria-hidden="true">chevron_right</span>
                <span class="text-primary">Recepcionar</span>
            </nav>
            <div class="mt-1 flex flex-wrap items-center gap-x-3 gap-y-1">
                <h1 class="text-lg font-bold tracking-tight text-white">Recepcionar Mercadería</h1>
                <span class="@estadoBadgeClass">@estadoNombre</span>
            </div>
        </div>
        <div class="oc-head__actions">
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn-erp-secondary btn-sm no-underline">
                <span class="material-symbols-outlined text-sm" aria-hidden="true">arrow_back</span>
                Volver al detalle
            </a>
            <span class="btn-erp-ghost btn-sm opacity-60 cursor-not-allowed"
                  aria-disabled="true"
                  title="La edición de órdenes de compra todavía no está disponible">
                <span class="material-symbols-outlined text-sm" aria-hidden="true">edit</span>
                Editar
            </span>
        </div>
    </div>

    <dl class="oc-meta mt-3">
        <div>
            <dt>Proveedor</dt>
            <dd>@(Model.ProveedorNombre ?? "—")</dd>
        </div>
        <div>
            <dt>Fecha de emisión</dt>
            <dd>@Model.FechaEmision.ToString("dd/MM/yyyy")</dd>
        </div>
        <div>
            <dt>Unidades pedidas</dt>
            <dd>@totalUnidades</dd>
        </div>
        <div>
            <dt>Recepción actual</dt>
            <dd>@totalRecibidas / @totalUnidades</dd>
        </div>
    </dl>

    <div class="oc-stat-strip mt-3" style="--oc-stats: 3;">
        <div class="oc-stat">
            <span class="oc-stat__label">Productos pendientes</span>
            <p class="oc-stat__value">@productosConPendiente</p>
            <p class="oc-stat__sub">de @Model.Detalles.Count producto(s) en la orden</p>
        </div>
        <div class="oc-stat">
            <span class="oc-stat__label">Unidades pendientes</span>
            <p class="oc-stat__value">@totalPendiente</p>
            <p class="oc-stat__sub">@totalRecibidas de @totalUnidades ya recepcionadas</p>
        </div>
        <div class="oc-stat">
            <span class="oc-stat__label">Recepción acumulada</span>
            <p class="oc-stat__value oc-stat__value--accent">@porcentajeRecepcion%</p>
            <p class="oc-stat__sub">avance sobre las unidades solicitadas</p>
        </div>
    </div>

    <div class="mt-3 flex items-start gap-2 rounded-lg border border-primary/20 bg-primary/5 px-3 py-2 text-xs text-slate-300">
        <span class="material-symbols-outlined text-primary text-base" aria-hidden="true">info</span>
        <p>
            Cargá únicamente las unidades que efectivamente ingresaron.
            <span class="font-semibold text-white">Esta acción actualiza el stock inmediatamente</span> para cada producto recepcionado.
        </p>
    </div>
</section>

<form asp-action="Recepcionar" method="post" id="form-recepcionar" class="grid grid-cols-1 gap-4 lg:grid-cols-3">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id" />
    <input type="hidden" name="rowVersion" value="@(Model.RowVersion != null ? Convert.ToBase64String(Model.RowVersion) : "")" />

    <div class="lg:col-span-2">
        <section class="card-erp-panel flex flex-col overflow-hidden"
                 data-oc-scroll
                 style="--oc-scroll-min-width: 40rem; --oc-scroll-fade-light: rgba(248, 250, 252, 0.98); --oc-scroll-fade-dark: rgba(15, 23, 42, 0.95);">
            <div class="px-4 py-3 border-b border-slate-800 flex flex-wrap items-center justify-between gap-2">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary" aria-hidden="true">inventory_2</span>
                    <h2 class="text-base font-bold text-white">Productos a recepcionar</h2>
                </div>
                <div class="flex flex-wrap items-center gap-2">
                    <span class="inline-flex items-center gap-1.5 rounded-lg border px-2.5 py-1 text-xs font-bold uppercase tracking-wide border-slate-700 bg-slate-800 text-slate-300">
                        <span class="material-symbols-outlined text-sm" aria-hidden="true">list_alt</span>
                        @Model.Detalles.Count producto(s)
                    </span>
                    <span class="inline-flex items-center gap-1.5 rounded-lg border border-primary/20 bg-primary/10 px-2.5 py-1 text-xs font-bold uppercase tracking-wide text-primary">
                        <span class="material-symbols-outlined text-sm" aria-hidden="true">pending_actions</span>
                        @productosConPendiente con pendiente
                    </span>
                </div>
            </div>

            <div data-oc-scroll-hint
                 class="mx-4 mt-3 flex items-center justify-between gap-3 rounded-lg border px-3 py-2 text-xs border-slate-700 bg-slate-800/60 text-slate-300 lg:hidden"
                 hidden>
                <div class="flex items-center gap-2 font-semibold">
                    <span class="material-symbols-outlined text-base text-primary" aria-hidden="true">swipe</span>
                    <span id="ordencompra-recepcionar-scroll-hint">Deslizá la tabla para revisar cantidades y estados</span>
                </div>
                <span class="rounded-full bg-slate-800 px-2 py-1 text-[11px] font-bold uppercase tracking-wide text-slate-400">
                    Scroll horizontal
                </span>
            </div>

            <div class="relative" data-oc-scroll-shell>
                <div data-oc-scroll-fade="left" class="pointer-events-none absolute inset-y-0 left-0 z-10 w-5" hidden></div>
                <div data-oc-scroll-fade="right" class="pointer-events-none absolute inset-y-0 right-0 z-10 w-8" hidden></div>

                <div data-oc-scroll-region
                     class="overflow-x-auto focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/40 focus-visible:ring-offset-2 focus-visible:ring-offset-slate-50 dark:focus-visible:ring-offset-background-dark"
                     role="region"
                     aria-label="Tabla de recepción de productos"
                     aria-describedby="ordencompra-recepcionar-scroll-hint"
                     tabindex="0">
                    <table data-oc-scroll-table class="ocr-products-table w-full text-left border-collapse">
                        <caption class="oc-visually-hidden">Productos de la orden y cantidad a recepcionar por cada uno.</caption>
                        <thead>
                            <tr class="bg-slate-800/50 border-b border-slate-800">
                                <th scope="col" class="text-xs font-bold uppercase tracking-wider text-slate-400">Producto</th>
                                <th scope="col" class="text-xs font-bold uppercase tracking-wider text-slate-400 text-center">Solicitada</th>
                                <th scope="col" class="text-xs font-bold uppercase tracking-wider text-slate-400 text-center">Recibida</th>
                                <th scope="col" class="text-xs font-bold uppercase tracking-wider text-slate-400 text-center">Pendiente</th>
                                <th scope="col" class="text-xs font-bold uppercase tracking-wider text-slate-400 text-center">Estado</th>
                                <th scope="col" class="text-xs font-bold uppercase tracking-wider text-slate-400 text-right">A Recepcionar</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-800">
                            @for (int i = 0; i < Model.Detalles.Count; i++)
                            {
                                var d = Model.Detalles[i];
                                var pendiente = Math.Max(d.Cantidad - d.CantidadRecibida, 0);
                                var completo = pendiente <= 0;

                                <tr class="hover:bg-slate-800/30 transition-colors">
                                    <td>
                                        <input type="hidden" name="detalles[@i].DetalleId" value="@d.Id" />
                                        <input type="hidden" name="detalles[@i].ProductoId" value="@d.ProductoId" />
                                        <p class="text-sm font-bold text-white">@d.ProductoNombre</p>
                                        @if (!string.IsNullOrEmpty(d.ProductoCodigo))
                                        {
                                            <span class="text-xs text-slate-500">SKU: @d.ProductoCodigo</span>
                                        }
                                    </td>
                                    <td class="text-center text-sm font-medium text-white">@d.Cantidad</td>
                                    <td class="text-center text-sm font-medium text-white">@d.CantidadRecibida</td>
                                    <td class="text-center text-sm font-medium @(completo ? "text-emerald-500" : "text-amber-500")">@pendiente</td>
                                    <td class="text-center">
                                        @if (completo)
                                        {
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-emerald-500/10 text-emerald-500 border border-emerald-500/20">
                                                Completo
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-amber-500/10 text-amber-500 border border-amber-500/20">
                                                Pendiente
                                            </span>
                                        }
                                    </td>
                                    <td class="text-right w-28">
                                        @if (completo)
                                        {
                                            <input type="number"
                                                   name="detalles[@i].CantidadARecepcionar"
                                                   value="0"
                                                   disabled
                                                   aria-label="Cantidad a recepcionar de @d.ProductoNombre no disponible"
                                                   class="w-full rounded-lg border px-3 py-1.5 text-right text-sm text-slate-400 cursor-not-allowed border-slate-800 bg-slate-900/50" />
                                        }
                                        else
                                        {
                                            <input type="number"
                                                   name="detalles[@i].CantidadARecepcionar"
                                                   value="0"
                                                   min="0"
                                                   max="@pendiente"
                                                   inputmode="numeric"
                                                   data-pendiente="@pendiente"
                                                   aria-label="Cantidad a recepcionar de @d.ProductoNombre"
                                                   class="input-recepcion w-full rounded-lg border px-3 py-1.5 text-right text-sm focus:border-primary focus:ring-2 focus:ring-primary/40 border-slate-700 bg-slate-800 text-white" />
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    </div>

    <aside class="lg:sticky lg:top-4 flex h-fit flex-col gap-4">
        <section id="recepcionar-summary"
                 data-total-pendiente="@totalPendiente"
                 class="card-erp-panel p-4">
            <h2 class="text-base font-bold text-white flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-[20px]" aria-hidden="true">fact_check</span>
                Resumen de Recepción
            </h2>

            <div class="oc-stat-strip mt-3" style="--oc-stats: 3;">
                <div class="oc-stat">
                    <span class="oc-stat__label">Con carga</span>
                    <p id="lbl-productos-seleccionados" class="oc-stat__value">0</p>
                    <p class="oc-stat__sub">productos</p>
                </div>
                <div class="oc-stat">
                    <span class="oc-stat__label">A ingresar</span>
                    <p id="lbl-ingresar" class="oc-stat__value oc-stat__value--accent">0</p>
                    <p class="oc-stat__sub">unidades</p>
                </div>
                <div class="oc-stat">
                    <span class="oc-stat__label">Restante</span>
                    <p id="lbl-pendientes" data-initial="@totalPendiente" class="oc-stat__value">@totalPendiente</p>
                    <p class="oc-stat__sub">pendientes</p>
                </div>
            </div>

            <div class="mt-3 rounded-xl border border-slate-800 bg-slate-800/40 p-3">
                <div class="flex items-center justify-between gap-3">
                    <span class="text-xs font-bold uppercase tracking-[0.14em] text-slate-400">Avance de esta recepción</span>
                    <span id="recepcionar-progress-text" class="text-sm font-bold text-white">0%</span>
                </div>
                <div class="mt-2 h-2 overflow-hidden rounded-full bg-slate-800">
                    <div id="recepcionar-progress-bar" class="h-full rounded-full bg-primary transition-all duration-200" style="width: 0%;"></div>
                </div>
            </div>

            <div id="recepcionar-feedback"
                 class="mt-3 hidden items-start gap-3 rounded-lg border px-4 py-3 text-sm"
                 hidden
                 role="alert"
                 aria-live="polite">
                <span id="recepcionar-feedback-icon" class="material-symbols-outlined text-base" aria-hidden="true">error</span>
                <p id="recepcionar-feedback-text" class="font-medium"></p>
            </div>

            <div class="mt-4 flex flex-col gap-2">
                <button type="submit" id="btn-confirmar"
                        class="inline-flex h-11 items-center justify-center gap-2 rounded-lg bg-primary px-4 text-sm font-bold text-white shadow-lg shadow-primary/30 transition-all hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/40 focus-visible:ring-offset-2 focus-visible:ring-offset-slate-900">
                    <span class="material-symbols-outlined text-lg" aria-hidden="true">check_circle</span>
                    Confirmar Recepción
                </button>
                <a asp-action="Details" asp-route-id="@Model.Id"
                   class="inline-flex h-10 items-center justify-center rounded-lg border px-4 text-sm font-bold transition-colors border-slate-700 text-slate-300 hover:bg-slate-800 no-underline">
                    Cancelar Operación
                </a>
            </div>

            <p class="mt-3 text-xs leading-relaxed text-slate-400">
                Si ingresás menos unidades que las pendientes, la orden queda disponible para futuras recepciones.
            </p>
        </section>
    </aside>
</form>

@section Styles {
    <partial name="_OrdenCompraModuleStyles" />
}

@section Scripts {
    <script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
    <script src="~/js/ordencompra-recepcionar.js" asp-append-version="true"></script>
}
