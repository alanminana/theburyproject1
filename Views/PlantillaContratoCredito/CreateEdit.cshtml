  "COMPRADOR_NOMBRE": "Martín Alberto Gómez", "COMPRADOR_DNI": "28.456.789", "COMPRADOR_CUIL": "20-28456789-3", "COMPRADOR_DOMICILIO": "Lavalle 567", "COMPRADOR_LOCALIDAD": "Palpalá", "COMPRADOR_TELEFONO": "388-4-555123",
