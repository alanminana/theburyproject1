@model ProductoUnidadHistorialViewModel
@using TheBuryProject.Models.Enums

@{
    ViewData["Title"] = $"Historial - {Model.CodigoInternoUnidad}";

    string BadgeCss(EstadoUnidad e) => e switch
    {
        EstadoUnidad.EnStock      => "border-emerald-500/30 bg-emerald-500/10 text-emerald-300",
        EstadoUnidad.Vendida      => "border-sky-500/30 bg-sky-500/10 text-sky-300",
        EstadoUnidad.Entregada    => "border-blue-500/30 bg-blue-500/10 text-blue-300",
        EstadoUnidad.Devuelta     => "border-amber-500/30 bg-amber-500/10 text-amber-300",
        EstadoUnidad.EnReparacion => "border-purple-500/30 bg-purple-500/10 text-purple-300",
        EstadoUnidad.Faltante     => "border-red-500/30 bg-red-500/10 text-red-300",
        EstadoUnidad.Baja         => "border-slate-600/30 bg-slate-600/10 text-slate-400",
        EstadoUnidad.Anulada      => "border-slate-600/30 bg-slate-600/10 text-slate-400",
        EstadoUnidad.Reservada    => "border-orange-500/30 bg-orange-500/10 text-orange-300",
        _                         => "border-slate-600/30 bg-slate-600/10 text-slate-400"
    };

    string EstadoLabel(EstadoUnidad e) => e switch
    {
        EstadoUnidad.EnStock      => "En stock",
        EstadoUnidad.Vendida      => "Vendida",
        EstadoUnidad.Entregada    => "Entregada",
        EstadoUnidad.Devuelta     => "Devuelta",
        EstadoUnidad.EnReparacion => "En reparación",
        EstadoUnidad.Faltante     => "Faltante",
        EstadoUnidad.Baja         => "Baja",
        EstadoUnidad.Anulada      => "Anulada",
        EstadoUnidad.Reservada    => "Reservada",
        _                         => e.ToString()
    };
}

<div class="space-y-6">
    <section class="rounded-lg border border-slate-800 bg-slate-950/60 p-5">
        <a asp-controller="Producto" asp-action="Unidades" asp-route-productoId="@Model.ProductoId"
           class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-400 transition-colors hover:text-white">
            <span class="material-symbols-outlined text-base">arrow_back</span>
            Volver a unidades
        </a>
        <div class="mt-3 flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
            <div>
                <h1 class="text-2xl font-black text-white">@Model.CodigoInternoUnidad</h1>
                <p class="mt-1 text-sm text-slate-400">
                    @Model.ProductoCodigo - @Model.ProductoNombre
                    @if (!string.IsNullOrWhiteSpace(Model.NumeroSerie))
                    {
                        <span>/ Serie @Model.NumeroSerie</span>
                    }
                </p>
            </div>
            <span class="inline-flex w-fit items-center rounded-full border px-3 py-1 text-sm font-bold @BadgeCss(Model.EstadoActual)">
                @EstadoLabel(Model.EstadoActual)
            </span>
        </div>
    </section>

    <section class="overflow-hidden rounded-lg border border-slate-800 bg-slate-950">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-800">
                <thead class="bg-slate-900/70">
                    <tr>
                        <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">Fecha</th>
                        <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">De</th>
                        <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">A</th>
                        <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">Motivo</th>
                        <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">Origen</th>
                        <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">Usuario</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800">
                    @if (Model.Movimientos.Any())
                    {
                        @foreach (var movimiento in Model.Movimientos)
                        {
                            <tr class="hover:bg-white/5">
                                <td class="px-4 py-3 text-sm text-slate-300">@movimiento.FechaCambio.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="px-4 py-3">
                                    <span class="inline-flex items-center rounded-full border px-2 py-0.5 text-xs font-bold @BadgeCss(movimiento.EstadoAnterior)">
                                        @EstadoLabel(movimiento.EstadoAnterior)
                                    </span>
                                </td>
                                <td class="px-4 py-3">
                                    <div class="flex items-center gap-1.5">
                                        <span class="text-xs text-slate-600">→</span>
                                        <span class="inline-flex items-center rounded-full border px-2 py-0.5 text-xs font-bold @BadgeCss(movimiento.EstadoNuevo)">
                                            @EstadoLabel(movimiento.EstadoNuevo)
                                        </span>
                                    </div>
                                </td>
                                <td class="px-4 py-3 text-sm text-slate-300">@movimiento.Motivo</td>
                                <td class="px-4 py-3 text-sm text-slate-300">@(movimiento.OrigenReferencia ?? "-")</td>
                                <td class="px-4 py-3 text-sm text-slate-300">@(movimiento.UsuarioResponsable ?? "-")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="px-4 py-10 text-center text-sm text-slate-400">
                                Esta unidad no tiene movimientos registrados.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>
