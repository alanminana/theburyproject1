@model ProductoUnidadesViewModel
@using TheBuryProject.Models.Enums

@{
    ViewData["Title"] = $"Unidades - {Model.Nombre}";
    var estados = Enum.GetValues<EstadoUnidad>();

    var conciliacion = Model.Conciliacion;
    var diferenciaTexto = conciliacion.DiferenciaStockVsUnidadesEnStock > 0
        ? $"+{conciliacion.DiferenciaStockVsUnidadesEnStock:G29}"
        : conciliacion.DiferenciaStockVsUnidadesEnStock.ToString("G29");
    var diferenciaPositiva = conciliacion.DiferenciaStockVsUnidadesEnStock > 0;
    var diferenciaNegativa = conciliacion.DiferenciaStockVsUnidadesEnStock < 0;
    var puedeAjustarStockAgregado = conciliacion.RequiereNumeroSerie && conciliacion.HayDiferencia;
    var stockNoTrazado = Model.StockActual - (decimal)conciliacion.UnidadesEnStock;
    var altaComunBloqueada = (decimal)conciliacion.UnidadesEnStock >= Model.StockActual;
    var ajusteAbsoluto = Math.Abs(conciliacion.DiferenciaStockVsUnidadesEnStock);
    var textoAjuste = diferenciaPositiva
        ? $"Reducir stock agregado en {ajusteAbsoluto:G29}"
        : $"Aumentar stock agregado en {ajusteAbsoluto:G29}";
    var hayDesgloseVisible = conciliacion.UnidadesVendidas > 0
        || conciliacion.UnidadesFaltantes > 0
        || conciliacion.UnidadesBaja > 0
        || conciliacion.UnidadesDevueltas > 0
        || conciliacion.UnidadesReservadas > 0
        || conciliacion.UnidadesEnReparacion > 0;

    // Badge helpers locales — no modifica _EstadoUnidadBadge (usado en 3 vistas mas)
    Func<EstadoUnidad, string> BChipClass = e => e switch {
        EstadoUnidad.EnStock      => "pu-chip pu-chip-stock",
        EstadoUnidad.Vendida      => "pu-chip pu-chip-sold",
        EstadoUnidad.Entregada    => "pu-chip pu-chip-sold",
        EstadoUnidad.Faltante     => "pu-chip pu-chip-missing",
        EstadoUnidad.Baja         => "pu-chip pu-chip-baja",
        EstadoUnidad.Anulada      => "pu-chip pu-chip-baja",
        EstadoUnidad.Reservada    => "pu-chip pu-chip-reserved",
        EstadoUnidad.EnReparacion => "pu-chip pu-chip-repair",
        EstadoUnidad.Devuelta     => "pu-chip pu-chip-return",
        _                         => "pu-chip pu-chip-neutral"
    };
    Func<EstadoUnidad, string> BChipLabel = e => e switch {
        EstadoUnidad.EnStock      => "En Stock",
        EstadoUnidad.Vendida      => "Vendida",
        EstadoUnidad.Entregada    => "Entregada",
        EstadoUnidad.Faltante     => "Faltante",
        EstadoUnidad.Baja         => "Baja",
        EstadoUnidad.Anulada      => "Anulada",
        EstadoUnidad.Reservada    => "Reservada",
        EstadoUnidad.EnReparacion => "En Reparacion",
        EstadoUnidad.Devuelta     => "Devuelta",
        _                         => e.ToString()
    };
    Func<EstadoUnidad, string> EstadoOpcionLabel = e => e switch {
        EstadoUnidad.EnStock      => "En Stock",
        EstadoUnidad.Vendida      => "Vendida",
        EstadoUnidad.Entregada    => "Entregada",
        EstadoUnidad.Faltante     => "Faltante",
        EstadoUnidad.Baja         => "Baja",
        EstadoUnidad.Anulada      => "Anulada",
        EstadoUnidad.Reservada    => "Reservada",
        EstadoUnidad.EnReparacion => "En Reparacion",
        EstadoUnidad.Devuelta     => "Devuelta",
        _                         => e.ToString()
    };

    // Estado inicial del radio de disponibilidad
    var dispoFilter = Model.Filtros.SoloDisponibles ? "disponibles"
                    : Model.Filtros.SoloVendidas    ? "vendidas"
                    : "todas";
}

<style>
/* pu = product-units: namespaced design system — paridad visual con standalone */
.pu-page .pu-card {
  background: #111827;
  border: 1px solid #1f2937;
  border-radius: 12px;
}
.pu-page .pu-card-header {
  background: rgba(11,18,32,.4);
  border: 1px solid #1e293b;
  border-radius: 12px;
}
/* Chips de estado */
.pu-page .pu-chip {
  display: inline-flex; align-items: center; gap: .35rem;
  padding: .25rem .55rem; border-radius: 999px;
  font-size: .75rem; font-weight: 500; border: 1px solid transparent;
}
.pu-page .pu-chip-neutral  { background: #1e293b; color: #e2e8f0; border-color: #334155; }
.pu-page .pu-chip-stock    { background: rgba(16,185,129,.10); color: #34d399; border-color: rgba(16,185,129,.25); }
.pu-page .pu-chip-sold     { background: rgba(245,197,24,.10);  color: #f5c518; border-color: rgba(245,197,24,.25); }
.pu-page .pu-chip-missing  { background: rgba(245,158,11,.10);  color: #fbbf24; border-color: rgba(245,158,11,.25); }
.pu-page .pu-chip-baja     { background: rgba(148,163,184,.10); color: #94a3b8; border-color: rgba(148,163,184,.25); }
.pu-page .pu-chip-reserved { background: rgba(168,85,247,.10);  color: #c084fc; border-color: rgba(168,85,247,.25); }
.pu-page .pu-chip-repair   { background: rgba(244,114,182,.10); color: #f472b6; border-color: rgba(244,114,182,.25); }
.pu-page .pu-chip-return   { background: rgba(20,184,166,.10);  color: #2dd4bf; border-color: rgba(20,184,166,.25); }
/* Inputs */
.pu-page .pu-field {
  background: #0f172a; border: 1px solid #243044; color: #e2e8f0;
  border-radius: 8px; padding: .55rem .75rem; width: 100%; font-size: .875rem;
  outline: none;
}
.pu-page .pu-field:focus { border-color: #f5c518; box-shadow: 0 0 0 3px rgba(245,197,24,.2); }
.pu-page .pu-field::placeholder { color: #475569; }
.pu-page textarea.pu-field { min-height: 84px; resize: vertical; }
.pu-page select.pu-field { cursor: pointer; }
.pu-page .pu-label { display: block; font-size: .78rem; font-weight: 500; color: #94a3b8; margin-bottom: .35rem; }
/* Botones */
.pu-page .pu-btn {
  display: inline-flex; align-items: center; justify-content: center; gap: .4rem;
  padding: .55rem .95rem; border-radius: 8px; font-size: .875rem; font-weight: 500;
  transition: all .15s; min-height: 40px; cursor: pointer; border: 1px solid transparent;
  text-decoration: none; white-space: nowrap;
}
.pu-page .pu-btn:disabled { opacity: .5; cursor: not-allowed; }
.pu-page .pu-btn-primary { background: #f5c518; color: #15110a; border-color: #f5c518; }
.pu-page .pu-btn-primary:hover:not(:disabled) { background: #e0b40f; border-color: #e0b40f; }
.pu-page .pu-btn-ghost   { background: transparent; color: #cbd5e1; border-color: #334155; }
.pu-page .pu-btn-ghost:hover   { background: #1e293b; color: #fff; }
.pu-page .pu-btn-soft    { background: #1e293b; color: #e2e8f0; border-color: #334155; }
.pu-page .pu-btn-soft:hover    { background: #273549; }
.pu-page .pu-btn-success { background: #16a34a; color: #fff; border-color: #16a34a; }
.pu-page .pu-btn-success:hover:not(:disabled) { background: #15803d; }
/* Amber solido — igual que standalone */
.pu-page .pu-btn-amber   { background: #d97706; color: #fff; border-color: #d97706; }
.pu-page .pu-btn-amber:hover:not(:disabled) { background: #b45309; border-color: #b45309; }
/* Danger solido — igual que standalone */
.pu-page .pu-btn-danger  { background: #dc2626; color: #fff; border-color: #dc2626; }
.pu-page .pu-btn-danger:hover:not(:disabled)  { background: #b91c1c; border-color: #b91c1c; }
.pu-page .pu-btn-sm { padding: .375rem .625rem; font-size: .75rem; min-height: 32px; }
/* Truncate observaciones — 240px igual que standalone */
.pu-page .pu-truncate { max-width: 240px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
/* Tab activo */
.pu-page .tab-btn-active { color: #f8fafc !important; border-bottom-color: #f5c518 !important; }
/* Modal */
@@keyframes puFadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
.pu-modal-card { animation: puFadeIn .18s ease; }
/* Opcion de resolucion */
.pu-reso-opt { transition: border-color .15s; }
.pu-reso-opt:hover:not(.pu-disabled) { border-color: #334155; }
</style>

<div class="pu-page space-y-5">

    @* SYSTEM BANNER *@
    @if (TempData["Success"] != null)
    {
        <div class="rounded-lg border border-emerald-500/30 bg-emerald-600/15 px-4 py-2.5 flex items-center gap-3">
            <span class="material-symbols-outlined text-emerald-400" style="font-size:20px">check_circle</span>
            <span class="flex-1 text-sm font-medium text-emerald-300">@TempData["Success"]</span>
            <button type="button" onclick="this.closest('div').remove()" class="p-1 rounded-lg hover:bg-emerald-600/20" aria-label="Cerrar notificacion">
                <span class="material-symbols-outlined text-emerald-300" style="font-size:20px">close</span>
            </button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="rounded-lg border border-red-500/30 bg-red-600/15 px-4 py-2.5 flex items-center gap-3">
            <span class="material-symbols-outlined text-red-400" style="font-size:20px">error</span>
            <span class="flex-1 text-sm font-medium text-red-300">@TempData["Error"]</span>
            <button type="button" onclick="this.closest('div').remove()" class="p-1 rounded-lg hover:bg-red-600/20" aria-label="Cerrar notificacion">
                <span class="material-symbols-outlined text-red-300" style="font-size:20px">close</span>
            </button>
        </div>
    }

    @* PRODUCT HEADER *@
    <header class="pu-card-header px-4 sm:px-5 py-5">
        <a asp-controller="Catalogo" asp-action="Index" class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-slate-200 transition-colors">
            <span class="material-symbols-outlined" style="font-size:18px">arrow_back</span>
            Volver al catalogo
        </a>
        <div class="mt-3 flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4">
            <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                    <h1 class="text-xl sm:text-2xl font-semibold text-white">@Model.Nombre</h1>
                    <span class="font-mono text-xs px-2 py-0.5 rounded-md bg-slate-800 text-slate-300 border border-slate-700">@Model.Codigo</span>
                </div>
                <div class="mt-2 flex flex-wrap items-center gap-2">
                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-medium @(Model.RequiereNumeroSerie ? "bg-blue-500/10 text-blue-300 border border-blue-500/30" : "bg-amber-500/10 text-amber-300 border border-amber-500/30")">
                        <span class="material-symbols-outlined" style="font-size:14px">@(Model.RequiereNumeroSerie ? "verified" : "warning")</span>
                        @(Model.RequiereNumeroSerie ? "Requiere seleccion de unidad en venta" : "No requiere seleccion de unidad")
                    </span>
                    @if (conciliacion.HayDiferencia)
                    {
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-medium bg-amber-500/10 text-amber-300 border border-amber-500/30">
                            <span class="material-symbols-outlined" style="font-size:14px">warning</span>
                            Con diferencia
                        </span>
                    }
                </div>
            </div>
            <div class="flex flex-wrap gap-2 shrink-0">
                <a asp-controller="MovimientoStock" asp-action="Kardex" asp-route-id="@Model.ProductoId"
                   class="pu-btn pu-btn-ghost">
                    <span class="material-symbols-outlined" style="font-size:18px">receipt_long</span>
                    Ver Kardex
                </a>
                <button type="button" onclick="activateTab('conciliar')"
                        class="pu-btn pu-btn-soft">
                    <span class="material-symbols-outlined" style="font-size:18px">balance</span>
                    Conciliar stock
                </button>
                @if (altaComunBloqueada)
                {
                    <button type="button" onclick="activateTab('agregar')"
                            class="pu-btn pu-btn-soft" title="Stock completo — usá Conciliación para agregar unidades adicionales">
                        <span class="material-symbols-outlined" style="font-size:18px">block</span>
                        Stock completo
                    </button>
                }
                else
                {
                    <button type="button" onclick="activateTab('agregar')"
                            class="pu-btn pu-btn-primary">
                        <span class="material-symbols-outlined" style="font-size:18px">add</span>
                        Agregar unidades
                    </button>
                }
            </div>
        </div>

        @* Summary cards *@
        <div class="mt-5 grid grid-cols-2 lg:grid-cols-4 gap-3">
            <div class="pu-card p-4">
                <div class="text-xs uppercase tracking-wide text-slate-500 font-medium">Stock del producto</div>
                <div class="mt-1 text-2xl font-semibold text-white">@Model.StockActual.ToString("G29")</div>
                <div class="mt-0.5 text-xs text-slate-500">Valor logico</div>
            </div>
            <div class="pu-card p-4">
                <div class="text-xs uppercase tracking-wide text-slate-500 font-medium">Unidades disponibles</div>
                <div class="mt-1 text-2xl font-semibold text-emerald-400">@conciliacion.UnidadesEnStock</div>
                <div class="mt-0.5 text-xs text-slate-500">En estado "En Stock"</div>
            </div>
            <div class="pu-card p-4 @(stockNoTrazado > 0 ? "!border-blue-500/40 !bg-blue-500/5" : diferenciaNegativa ? "!border-amber-500/40 !bg-amber-500/5" : "")">
                <div class="text-xs uppercase tracking-wide @(stockNoTrazado > 0 ? "text-blue-300/80" : diferenciaNegativa ? "text-amber-300/80" : "text-slate-500") font-medium">Stock no trazado</div>
                <div class="mt-1 text-2xl font-semibold @(stockNoTrazado > 0 ? "text-blue-300" : diferenciaNegativa ? "text-amber-300" : "text-emerald-400")">@stockNoTrazado.ToString("G29")</div>
                <div class="mt-0.5 text-xs @(stockNoTrazado > 0 ? "text-blue-200/70" : diferenciaNegativa ? "text-amber-200/70" : "text-slate-500")">
                    @(stockNoTrazado > 0 ? "Sin identificar individualmente" : diferenciaNegativa ? "Fisicas > stock" : "Trazabilidad completa")
                </div>
            </div>
            <div class="pu-card p-4">
                <div class="text-xs uppercase tracking-wide text-slate-500 font-medium">Unidades registradas</div>
                <div class="mt-1 text-2xl font-semibold text-white">@conciliacion.TotalUnidadesRegistradas</div>
                <div class="mt-0.5 text-xs text-slate-500">Total fisicas, todos los estados</div>
            </div>
        </div>
    </header>

    @* TABS — z-30 igual que standalone *@
    <nav class="sticky top-0 z-30 border-b border-slate-800 bg-slate-950/95 backdrop-blur" role="tablist" aria-label="Modos de unidades">
        <div class="flex gap-1 overflow-x-auto" style="-ms-overflow-style:none;scrollbar-width:none;">
            <button type="button" id="tab-ver" role="tab" data-tab-target="ver" aria-controls="ver" aria-selected="true" tabindex="0"
                    class="tab-btn shrink-0 px-4 py-3 text-sm font-medium text-white border-b-2 border-blue-500 transition-colors whitespace-nowrap">
                Ver unidades
            </button>
            <button type="button" id="tab-agregar" role="tab" data-tab-target="agregar" aria-controls="agregar" aria-selected="false" tabindex="-1"
                    class="tab-btn shrink-0 px-4 py-3 text-sm font-medium text-slate-400 hover:text-white border-b-2 border-transparent transition-colors whitespace-nowrap">
                Agregar unidades
            </button>
            <button type="button" id="tab-conciliar" role="tab" data-tab-target="conciliar" aria-controls="conciliar" aria-selected="false" tabindex="-1"
                    class="tab-btn shrink-0 px-4 py-3 text-sm font-medium text-slate-400 hover:text-white border-b-2 border-transparent transition-colors whitespace-nowrap">
                Conciliar stock
            </button>
            <button type="button" id="tab-trazabilidad" role="tab" data-tab-target="trazabilidad" aria-controls="trazabilidad" aria-selected="false" tabindex="-1"
                    class="tab-btn shrink-0 px-4 py-3 text-sm font-medium text-slate-400 hover:text-white border-b-2 border-transparent transition-colors whitespace-nowrap">
                Trazabilidad
            </button>
        </div>
    </nav>

    @* ================================================================
       PANEL: VER UNIDADES
       ================================================================ *@
    <section id="ver" role="tabpanel" data-tab-panel="ver" aria-labelledby="tab-ver" class="space-y-5">
        <div>
            <h2 class="text-lg font-semibold text-white">Listado operativo</h2>
            <p class="text-sm text-slate-400">Cada fila es una unidad fisica individual con su propia trazabilidad.</p>
        </div>

        @* Estado chips *@
        <div class="flex flex-wrap gap-2">
            <span class="pu-chip pu-chip-neutral">Mostrando: <strong class="ml-1">@Model.Unidades.Count</strong></span>
            @foreach (var r in Model.ResumenEstados)
            {
                var estadoStr = r.Estado.ToString();
                var chipClass = estadoStr switch {
                    "EnStock"      => "pu-chip pu-chip-stock",
                    "Vendida"      => "pu-chip pu-chip-sold",
                    "Faltante"     => "pu-chip pu-chip-missing",
                    "Baja"         => "pu-chip pu-chip-baja",
                    "Devuelta"     => "pu-chip pu-chip-return",
                    "Reservada"    => "pu-chip pu-chip-reserved",
                    "EnReparacion" => "pu-chip pu-chip-repair",
                    _              => "pu-chip pu-chip-neutral"
                };
                <span class="@chipClass">@BChipLabel(r.Estado) <strong class="ml-1">@r.Cantidad</strong></span>
            }
        </div>

        @* Filter form — 12 columnas igual que standalone *@
        <form method="get" asp-controller="Producto" asp-action="Unidades" asp-route-productoId="@Model.ProductoId"
              class="pu-card p-4" id="filter-form">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-3">
                <div class="md:col-span-4">
                    <label class="pu-label" for="f-texto">Buscar Unidad / Serie</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-500" style="font-size:18px">search</span>
                        <input id="f-texto" type="search" name="texto" value="@Model.Filtros.Texto"
                               class="pu-field pl-9"
                               placeholder="UNI-000142, SN-9988..." />
                    </div>
                </div>
                <div class="md:col-span-3">
                    <label class="pu-label" for="f-estado">Estado</label>
                    <select id="f-estado" name="estado" class="pu-field">
                        <option value="">Todos</option>
                        @foreach (var estado in estados)
                        {
                            <option value="@estado" selected="@(Model.Filtros.Estado == estado)">@EstadoOpcionLabel(estado)</option>
                        }
                    </select>
                </div>
                <div class="md:col-span-3">
                    <span class="pu-label">Disponibilidad</span>
                    <div class="flex flex-wrap gap-3 pt-1.5">
                        <label class="inline-flex items-center gap-1.5 text-sm text-slate-300 cursor-pointer">
                            <input type="radio" class="accent-blue-500" value="todas"
                                   @(dispoFilter == "todas" ? "checked" : "")
                                   onchange="puDispoChange('todas')" />
                            Todas
                        </label>
                        <label class="inline-flex items-center gap-1.5 text-sm text-slate-300 cursor-pointer">
                            <input type="radio" class="accent-blue-500" value="disponibles"
                                   @(dispoFilter == "disponibles" ? "checked" : "")
                                   onchange="puDispoChange('disponibles')" />
                            Disponibles
                        </label>
                        <label class="inline-flex items-center gap-1.5 text-sm text-slate-300 cursor-pointer">
                            <input type="radio" class="accent-blue-500" value="vendidas"
                                   @(dispoFilter == "vendidas" ? "checked" : "")
                                   onchange="puDispoChange('vendidas')" />
                            Vendidas
                        </label>
                    </div>
                    @* Checkboxes reales del backend — controlados por radios via JS *@
                    <input type="checkbox" id="filter-soloDisponibles" name="soloDisponibles" value="true"
                           style="display:none"
                           checked="@Model.Filtros.SoloDisponibles"
                           disabled="@(!Model.Filtros.SoloDisponibles)" />
                    <input type="checkbox" id="filter-soloVendidas" name="soloVendidas" value="true"
                           style="display:none"
                           checked="@Model.Filtros.SoloVendidas"
                           disabled="@(!Model.Filtros.SoloVendidas)" />
                </div>
                <div class="md:col-span-2">
                    <span class="pu-label">Otros</span>
                    <label class="inline-flex items-center gap-1.5 text-sm text-slate-300 cursor-pointer pt-1.5">
                        <input type="checkbox" name="soloSinNumeroSerie" value="true"
                               checked="@Model.Filtros.SoloSinNumeroSerie"
                               class="rounded border-slate-600 accent-blue-500" />
                        Sin nro. serie
                    </label>
                </div>
            </div>
            <div class="mt-4 flex justify-end gap-2">
                <a asp-controller="Producto" asp-action="Unidades" asp-route-productoId="@Model.ProductoId"
                   class="pu-btn pu-btn-ghost">
                    <span class="material-symbols-outlined" style="font-size:18px">backspace</span>
                    Limpiar
                </a>
                <button type="submit" class="pu-btn pu-btn-primary">
                    <span class="material-symbols-outlined" style="font-size:18px">filter_alt</span>
                    Filtrar
                </button>
            </div>
        </form>

        @* Unit list *@
        <div id="listado-unidades" class="pu-card overflow-hidden">
            @* Mobile *@
            <div class="space-y-3 p-3 md:hidden">
                @if (Model.Unidades.Any())
                {
                    @foreach (var unidad in Model.Unidades)
                    {
                        var _hasMobileActions = unidad.PuedeMarcarFaltante || unidad.PuedeDarBaja || unidad.PuedeReintegrarAStock || unidad.PuedeFinalizarReparacion;
                        var _mCode = unidad.CodigoInternoUnidad.Replace("'", "\\'");
                        var _mSerial = (unidad.NumeroSerie ?? "—").Replace("'", "\\'");
                        var _mLabel = BChipLabel(unidad.Estado);
                        var _mChipClass = BChipClass(unidad.Estado);
                        var _mActionsJson = new System.Text.StringBuilder("[");
                        if (unidad.PuedeReintegrarAStock) _mActionsJson.Append("{value:'reintegrar',label:'Reintegrar a stock'},");
                        if (unidad.PuedeDarBaja) _mActionsJson.Append("{value:'baja',label:'Dar de baja'},");
                        if (unidad.PuedeMarcarFaltante) _mActionsJson.Append("{value:'faltante',label:'Marcar faltante'},");
                        if (unidad.PuedeFinalizarReparacion) _mActionsJson.Append("{value:'reparacion',label:'Finalizar reparacion'},");
                        var _mActStr = _mActionsJson.ToString().TrimEnd(',') + "]";
                        <article class="pu-card p-4 space-y-3">
                            <div class="flex items-start justify-between gap-3">
                                <div>
                                    <span class="@BChipClass(unidad.Estado)">@BChipLabel(unidad.Estado)</span>
                                    <p class="mt-2 break-all font-mono text-sm text-white">@unidad.CodigoInternoUnidad</p>
                                    @if (unidad.NumeroSerie != null)
                                    {
                                        <p class="font-mono text-xs text-slate-400">@unidad.NumeroSerie</p>
                                    }
                                </div>
                            </div>
                            <dl class="grid grid-cols-2 gap-x-4 gap-y-2 text-xs">
                                @if (unidad.UbicacionActual != null)
                                {
                                    <div>
                                        <dt class="text-slate-500">Ubicacion</dt>
                                        <dd class="mt-0.5 text-slate-200">@unidad.UbicacionActual</dd>
                                    </div>
                                }
                                <div>
                                    <dt class="text-slate-500">Ingreso</dt>
                                    <dd class="mt-0.5 text-slate-200">@unidad.FechaIngreso.ToLocalTime().ToString("dd/MM/yy")</dd>
                                </div>
                                @if (unidad.ClienteAsociado != null)
                                {
                                    <div class="col-span-2">
                                        <dt class="text-slate-500">Cliente / Venta</dt>
                                        <dd class="mt-0.5 text-slate-200">
                                            @unidad.ClienteAsociado
                                            @if (unidad.VentaDetalleId.HasValue)
                                            {
                                                <span class="text-slate-400"> &middot; #@unidad.VentaDetalleId</span>
                                            }
                                        </dd>
                                    </div>
                                }
                            </dl>
                            @if (unidad.Observaciones != null)
                            {
                                <details class="group">
                                    <summary class="cursor-pointer text-xs text-blue-300 flex items-center gap-1">
                                        <span class="material-symbols-outlined" style="font-size:16px">expand_more</span>
                                        Ver mas detalles
                                    </summary>
                                    <div class="mt-2 text-xs text-slate-400 border-t border-slate-800 pt-2">
                                        <p><span class="text-slate-500">Observaciones:</span> @unidad.Observaciones</p>
                                    </div>
                                </details>
                            }
                            <div class="grid grid-cols-2 gap-2">
                                <a asp-controller="Producto" asp-action="UnidadHistorial" asp-route-unidadId="@unidad.Id"
                                   class="pu-btn pu-btn-ghost pu-btn-sm justify-center">
                                    <span class="material-symbols-outlined" style="font-size:16px">history</span>
                                    Historial
                                </a>
                                @if (_hasMobileActions)
                                {
                                    <button type="button"
                                            onclick="puOpenManage('@unidad.Id','@_mCode','@_mSerial','@_mLabel','@_mChipClass',@_mActStr)"
                                            class="pu-btn pu-btn-soft pu-btn-sm justify-center">
                                        <span class="material-symbols-outlined" style="font-size:16px">settings</span>
                                        Gestionar
                                    </button>
                                }
                            </div>
                        </article>
                    }
                }
                else
                {
                    <div class="pu-card p-8 text-center">
                        <div class="mx-auto w-12 h-12 rounded-full bg-slate-800 flex items-center justify-center">
                            <span class="material-symbols-outlined text-slate-400">search_off</span>
                        </div>
                        <h3 class="mt-3 text-white font-medium">Sin resultados</h3>
                        <p class="mt-1 text-sm text-slate-400">No hay unidades fisicas para los filtros seleccionados.</p>
                        <div class="mt-4 flex justify-center gap-2">
                            <a asp-controller="Producto" asp-action="Unidades" asp-route-productoId="@Model.ProductoId"
                               class="pu-btn pu-btn-ghost">
                                Limpiar filtros
                            </a>
                            <button type="button" onclick="activateTab('agregar')"
                                    class="pu-btn pu-btn-primary">
                                Agregar unidad
                            </button>
                        </div>
                    </div>
                }
            </div>

            @* Desktop *@
            <div class="hidden md:block overflow-x-auto">
                @if (Model.Unidades.Any())
                {
                    <table class="w-full text-sm">
                        <thead class="bg-slate-900/60 text-slate-400 text-xs uppercase tracking-wide">
                            <tr>
                                <th scope="col" class="px-4 py-3 text-left font-medium">Unidad</th>
                                <th scope="col" class="px-4 py-3 text-left font-medium">Serie</th>
                                <th scope="col" class="px-4 py-3 text-left font-medium">Estado</th>
                                <th scope="col" class="px-4 py-3 text-left font-medium">Ubicacion</th>
                                <th scope="col" class="px-4 py-3 text-left font-medium">Ingreso</th>
                                <th scope="col" class="px-4 py-3 text-left font-medium">Cliente / Venta</th>
                                <th scope="col" class="px-4 py-3 text-left font-medium">Observaciones</th>
                                <th scope="col" class="px-4 py-3 text-right font-medium">Acciones</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-800">
                            @foreach (var unidad in Model.Unidades)
                            {
                                var _hasActions = unidad.PuedeMarcarFaltante || unidad.PuedeDarBaja || unidad.PuedeReintegrarAStock || unidad.PuedeFinalizarReparacion;
                                var _dCode = unidad.CodigoInternoUnidad.Replace("'", "\\'");
                                var _dSerial = (unidad.NumeroSerie ?? "—").Replace("'", "\\'");
                                var _dLabel = BChipLabel(unidad.Estado);
                                var _dChipClass = BChipClass(unidad.Estado);
                                var _dActionsJson = new System.Text.StringBuilder("[");
                                if (unidad.PuedeReintegrarAStock) _dActionsJson.Append("{value:'reintegrar',label:'Reintegrar a stock'},");
                                if (unidad.PuedeDarBaja) _dActionsJson.Append("{value:'baja',label:'Dar de baja'},");
                                if (unidad.PuedeMarcarFaltante) _dActionsJson.Append("{value:'faltante',label:'Marcar faltante'},");
                                if (unidad.PuedeFinalizarReparacion) _dActionsJson.Append("{value:'reparacion',label:'Finalizar reparacion'},");
                                var _dActStr = _dActionsJson.ToString().TrimEnd(',') + "]";
                                <tr class="hover:bg-slate-900/40">
                                    <td class="px-4 py-3 font-mono text-sm text-slate-200">@unidad.CodigoInternoUnidad</td>
                                    <td class="px-4 py-3 font-mono text-sm text-slate-400">@(unidad.NumeroSerie ?? "—")</td>
                                    <td class="px-4 py-3">
                                        <span class="@BChipClass(unidad.Estado)">@BChipLabel(unidad.Estado)</span>
                                    </td>
                                    <td class="px-4 py-3 text-sm text-slate-300">@(unidad.UbicacionActual ?? "—")</td>
                                    <td class="px-4 py-3 text-sm text-slate-400">@unidad.FechaIngreso.ToLocalTime().ToString("dd/MM/yyyy")</td>
                                    <td class="px-4 py-3 text-sm text-slate-300">
                                        @if (unidad.ClienteAsociado != null || unidad.VentaDetalleId.HasValue)
                                        {
                                            <span>@(unidad.ClienteAsociado ?? "")</span>
                                            @if (unidad.VentaDetalleId.HasValue)
                                            {
                                                <span class="text-slate-400"> &middot; #@unidad.VentaDetalleId</span>
                                            }
                                            @if (unidad.FechaVenta.HasValue)
                                            {
                                                <span class="block text-xs text-slate-500">@unidad.FechaVenta.Value.ToLocalTime().ToString("dd/MM/yyyy")</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-slate-500">&mdash;</span>
                                        }
                                    </td>
                                    <td class="px-4 py-3 text-sm text-slate-400">
                                        @if (unidad.Observaciones != null)
                                        {
                                            <div class="pu-truncate" title="@unidad.Observaciones">@unidad.Observaciones</div>
                                        }
                                        else
                                        {
                                            <span class="text-slate-500">&mdash;</span>
                                        }
                                    </td>
                                    <td class="px-4 py-3 text-right">
                                        <div class="flex justify-end gap-1">
                                            <a asp-controller="Producto" asp-action="UnidadHistorial" asp-route-unidadId="@unidad.Id"
                                               class="pu-btn pu-btn-ghost pu-btn-sm">
                                                <span class="material-symbols-outlined" style="font-size:16px">history</span>
                                                Historial
                                            </a>
                                            @if (_hasActions)
                                            {
                                                <button type="button"
                                                        onclick="puOpenManage('@unidad.Id','@_dCode','@_dSerial','@_dLabel','@_dChipClass',@_dActStr)"
                                                        class="pu-btn pu-btn-soft pu-btn-sm">
                                                    <span class="material-symbols-outlined" style="font-size:16px">settings</span>
                                                    Gestionar
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="px-4 py-12 text-center">
                        <div class="mx-auto w-12 h-12 rounded-full bg-slate-800 flex items-center justify-center">
                            <span class="material-symbols-outlined text-slate-400">search_off</span>
                        </div>
                        <h3 class="mt-3 text-white font-medium">Sin resultados</h3>
                        <p class="mt-1 text-sm text-slate-400 max-w-md mx-auto">No encontramos unidades con estos filtros.</p>
                        <div class="mt-4 flex justify-center gap-2">
                            <a asp-controller="Producto" asp-action="Unidades" asp-route-productoId="@Model.ProductoId"
                               class="pu-btn pu-btn-ghost">
                                Limpiar filtros
                            </a>
                            <button type="button" onclick="activateTab('agregar')"
                                    class="pu-btn pu-btn-primary">
                                Agregar unidad
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    @* ================================================================
       PANEL: AGREGAR UNIDADES
       ================================================================ *@
    <section id="agregar" role="tabpanel" data-tab-panel="agregar" aria-labelledby="tab-agregar" class="space-y-5" hidden>
        <div>
            <h2 class="text-lg font-semibold text-white">Agregar unidades</h2>
            <p class="text-sm text-slate-400">Registrar identificadores fisicos para unidades ya existentes en el inventario.</p>
        </div>

        @if (altaComunBloqueada)
        {
            <div class="rounded-lg border border-amber-500/40 bg-amber-500/5 px-4 py-4 flex gap-3">
                <span class="material-symbols-outlined text-amber-300 shrink-0">block</span>
                <div>
                    @if (Model.StockActual <= 0)
                    {
                        <p class="text-sm font-semibold text-amber-200">Alta bloqueada: stock lógico es 0</p>
                        <p class="mt-1 text-sm text-amber-100/80">El stock lógico es 0. No hay unidades para registrar. Registrá una entrada en Kardex primero o usá Conciliación.</p>
                    }
                    else
                    {
                        <p class="text-sm font-semibold text-amber-200">Alta bloqueada: todas las unidades ya fueron registradas</p>
                        <p class="mt-1 text-sm text-amber-100/80">No podés agregar más unidades físicas porque ya registraste todas las unidades disponibles según el stock lógico (@conciliacion.UnidadesEnStock de @Model.StockActual.ToString("G29")). Usá Conciliación si encontraste una unidad adicional.</p>
                    }
                    <div class="mt-3">
                        <button type="button" onclick="activateTab('conciliar')"
                                class="pu-btn pu-btn-amber pu-btn-sm">
                            <span class="material-symbols-outlined" style="font-size:16px">balance</span>
                            Ir a Conciliación
                        </button>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="rounded-lg border border-blue-500/30 bg-blue-500/5 px-4 py-3 flex gap-3">
                <span class="material-symbols-outlined text-blue-300 shrink-0">info</span>
                <p class="text-sm text-blue-100/90">
                    Crear unidades fisicas no modifica el stock del producto ni genera movimientos de Kardex. Esta accion solo registra identificadores para el seguimiento de unidades ya existentes en el inventario.
                </p>
            </div>
        }

        <div class="grid gap-4 lg:grid-cols-2" style="@(altaComunBloqueada ? "opacity:0.45;pointer-events:none" : "")">
            @* Alta individual *@
            <div class="pu-card p-5">
                <div class="flex items-center gap-2 mb-1">
                    <span class="material-symbols-outlined text-slate-400">person_add</span>
                    <h3 class="font-semibold text-white">Alta individual</h3>
                </div>
                <p class="text-xs text-slate-400 mb-4">Cargar una unidad fisica a la vez. El codigo interno se genera automaticamente. La unidad se creara en estado EnStock.</p>

                <form method="post" asp-controller="Producto" asp-action="CrearUnidad">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="CrearUnidad.ProductoId" value="@Model.ProductoId" />
                    <div asp-validation-summary="ModelOnly" class="mb-3 text-sm font-semibold text-red-300"></div>
                    <div class="space-y-3">
                        <div>
                            <label class="pu-label" for="ind-serie">Numero de serie <span class="font-normal text-slate-600">(Opcional)</span></label>
                            <input id="ind-serie" asp-for="CrearUnidad.NumeroSerie" maxlength="100"
                                   class="pu-field"
                                   placeholder="Ej. SN-9988234B" />
                            <span asp-validation-for="CrearUnidad.NumeroSerie" class="mt-1 block text-xs font-semibold text-red-300"></span>
                        </div>
                        <div>
                            <label class="pu-label" for="ind-ubic">Ubicacion actual</label>
                            <input id="ind-ubic" asp-for="CrearUnidad.UbicacionActual" maxlength="200"
                                   class="pu-field"
                                   placeholder="Opcional" />
                            <span asp-validation-for="CrearUnidad.UbicacionActual" class="mt-1 block text-xs font-semibold text-red-300"></span>
                        </div>
                        <div>
                            <label class="pu-label" for="ind-obs">Observaciones</label>
                            <textarea id="ind-obs" asp-for="CrearUnidad.Observaciones" maxlength="500" rows="3"
                                      class="pu-field"
                                      placeholder="Notas internas, condicion, etc."></textarea>
                            <span asp-validation-for="CrearUnidad.Observaciones" class="mt-1 block text-xs font-semibold text-red-300"></span>
                        </div>
                    </div>
                    <div class="mt-4 flex justify-end">
                        <button type="submit" class="pu-btn pu-btn-primary" disabled="@altaComunBloqueada">
                            <span class="material-symbols-outlined" style="font-size:18px">add</span>
                            Agregar unidad
                        </button>
                    </div>
                </form>
            </div>

            @* Carga masiva *@
            <div class="pu-card p-5">
                <div class="flex items-center gap-2 mb-1">
                    <span class="material-symbols-outlined text-slate-400">stacks</span>
                    <h3 class="font-semibold text-white">Carga masiva</h3>
                </div>
                <p class="text-xs text-slate-400 mb-4">Cargar varias unidades a la vez. Funciona en dos pasos: prepara y previsualizas antes de confirmar.</p>

                <form id="form-carga-masiva-unidades" method="post" asp-controller="Producto" asp-action="CrearUnidadesMasivas">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="CargaMasiva.ProductoId" value="@Model.ProductoId" />

                    <div class="space-y-3">
                        <div class="grid gap-3 sm:grid-cols-2">
                            <div>
                                <label class="pu-label" for="bulk-qty">Cantidad sin serie</label>
                                <input id="bulk-qty" asp-for="CargaMasiva.CantidadSinSerie" min="0" max="200" type="number"
                                       class="pu-field" />
                                <span asp-validation-for="CargaMasiva.CantidadSinSerie" class="mt-1 block text-xs font-semibold text-red-300"></span>
                            </div>
                            <div>
                                <label class="pu-label" for="bulk-ubic">Ubicacion global</label>
                                <input id="bulk-ubic" asp-for="CargaMasiva.UbicacionActual" maxlength="200"
                                       class="pu-field"
                                       placeholder="Opcional" />
                                <span asp-validation-for="CargaMasiva.UbicacionActual" class="mt-1 block text-xs font-semibold text-red-300"></span>
                            </div>
                        </div>
                        <div>
                            <label class="pu-label" for="bulk-series">Series multiples (una por linea)</label>
                            <textarea id="bulk-series" asp-for="CargaMasiva.NumerosSerieTexto" rows="5" maxlength="12000"
                                      class="pu-field font-mono text-xs"
                                      placeholder="Una serie por linea"></textarea>
                            <p class="mt-1 text-xs text-slate-500">Las unidades sin serie se cargaran como "Sin serie".</p>
                            <span asp-validation-for="CargaMasiva.NumerosSerieTexto" class="mt-1 block text-xs font-semibold text-red-300"></span>
                        </div>
                        <div>
                            <label class="pu-label" for="bulk-obs">Observaciones</label>
                            <textarea id="bulk-obs" asp-for="CargaMasiva.Observaciones" rows="2" maxlength="500"
                                      class="pu-field"
                                      placeholder="Opcional"></textarea>
                            <span asp-validation-for="CargaMasiva.Observaciones" class="mt-1 block text-xs font-semibold text-red-300"></span>
                        </div>
                        <div class="flex justify-end">
                            <button type="submit" name="CargaMasiva.Confirmar" value="false"
                                    class="pu-btn pu-btn-primary" disabled="@altaComunBloqueada">
                                <span class="material-symbols-outlined" style="font-size:18px">visibility</span>
                                Previsualizar
                            </button>
                        </div>
                    </div>

                    @if (Model.CargaMasiva.PreviewListo && Model.CargaMasiva.Preview.Any())
                    {
                        <div class="mt-5 space-y-3">
                            <div class="rounded-lg border border-emerald-500/30 bg-emerald-500/5 px-4 py-2.5">
                                <p class="text-xs font-bold uppercase tracking-wider text-emerald-300">Preview listo</p>
                                <p class="mt-0.5 text-sm font-semibold text-white">@Model.CargaMasiva.TotalUnidades unidades &mdash; todas en estado EnStock</p>
                            </div>
                            <div class="grid grid-cols-3 gap-2">
                                <div class="rounded-lg bg-slate-800/60 border border-slate-700 p-2.5 text-center">
                                    <div class="text-xs text-slate-400">Total</div>
                                    <div class="text-lg font-semibold text-white">@Model.CargaMasiva.TotalUnidades</div>
                                </div>
                                <div class="rounded-lg bg-slate-800/60 border border-slate-700 p-2.5 text-center">
                                    <div class="text-xs text-slate-400">Con serie</div>
                                    <div class="text-lg font-semibold text-emerald-400">@Model.CargaMasiva.Preview.Count(p => p.NumeroSerie != null)</div>
                                </div>
                                <div class="rounded-lg bg-slate-800/60 border border-slate-700 p-2.5 text-center">
                                    <div class="text-xs text-slate-400">Sin serie</div>
                                    <div class="text-lg font-semibold text-amber-300">@Model.CargaMasiva.Preview.Count(p => p.NumeroSerie == null)</div>
                                </div>
                            </div>
                            <div class="rounded-lg border border-slate-800 overflow-hidden max-h-64 overflow-y-auto">
                                <table class="w-full text-sm">
                                    <thead class="bg-slate-900/70 sticky top-0">
                                        <tr>
                                            <th scope="col" class="px-3 py-2 text-left text-xs font-medium text-slate-400 w-10">#</th>
                                            <th scope="col" class="px-3 py-2 text-left text-xs font-medium text-slate-400">Serie</th>
                                            <th scope="col" class="px-3 py-2 text-left text-xs font-medium text-slate-400">Estado inicial</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-800 text-xs">
                                        @foreach (var item in Model.CargaMasiva.Preview)
                                        {
                                            <tr>
                                                <td class="px-3 py-2 text-slate-500">@item.Orden</td>
                                                <td class="px-3 py-2 font-mono @(item.NumeroSerie != null ? "text-slate-200" : "text-slate-500 italic")">
                                                    @(item.NumeroSerie ?? "(Sin serie)")
                                                </td>
                                                <td class="px-3 py-2">
                                                    <span class="pu-chip pu-chip-stock">En Stock</span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            <div class="flex flex-col-reverse sm:flex-row justify-end gap-2">
                                <a asp-controller="Producto" asp-action="Unidades" asp-route-productoId="@Model.ProductoId"
                                   class="pu-btn pu-btn-ghost justify-center">
                                    <span class="material-symbols-outlined" style="font-size:18px">edit</span>
                                    Volver a editar
                                </a>
                                <button type="submit" name="CargaMasiva.Confirmar" value="true"
                                        class="pu-btn pu-btn-success justify-center">
                                    <span class="material-symbols-outlined" style="font-size:18px">check</span>
                                    Confirmar carga
                                </button>
                            </div>
                        </div>
                    }
                </form>
            </div>
        </div>
    </section>

    @* ================================================================
       PANEL: CONCILIAR STOCK
       ================================================================ *@
    <section id="conciliar" role="tabpanel" data-tab-panel="conciliar" aria-labelledby="tab-conciliar" class="space-y-5" hidden>
        <div>
            <h2 class="text-lg font-semibold text-white">Conciliar stock</h2>
            <p class="text-sm text-slate-400">Comparacion entre stock del producto y unidades fisicas disponibles (estado En Stock).</p>
        </div>

        @if (conciliacion.HayDiferencia)
        {
            <div class="rounded-lg border border-amber-500/40 bg-amber-500/5 px-4 py-3 flex gap-3">
                <span class="material-symbols-outlined text-amber-300 shrink-0">warning</span>
                <p class="text-sm text-amber-100/90">
                    @if (diferenciaPositiva)
                    {
                        <text>El stock del producto es mayor que las unidades fisicas disponibles. Puede representar stock sin identificar o stock inflado. No se realizo ningun ajuste automatico.</text>
                    }
                    else
                    {
                        <text>Hay mas unidades fisicas disponibles que stock registrado. Conviene revisar el recuento antes de ajustar. No se realizo ningun ajuste automatico.</text>
                    }
                </p>
            </div>
        }
        else if (!Model.RequiereNumeroSerie)
        {
            <div class="rounded-lg border border-amber-500/30 bg-amber-500/5 px-4 py-3 flex gap-3">
                <span class="material-symbols-outlined text-amber-300 shrink-0">info</span>
                <p class="text-sm text-amber-100/90">Sin trazabilidad individual. Las unidades cargadas son solo trazabilidad operativa opcional.</p>
            </div>
        }
        else
        {
            <div class="rounded-lg border border-emerald-500/30 bg-emerald-500/5 px-4 py-3 flex gap-3">
                <span class="material-symbols-outlined text-emerald-300 shrink-0">check_circle</span>
                <p class="text-sm text-emerald-100/90">Conciliado: el stock del producto coincide con las unidades fisicas disponibles.</p>
            </div>
        }

        <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
            <div class="pu-card p-4">
                <div class="text-xs uppercase tracking-wide text-slate-500 font-medium">Stock del producto</div>
                <div class="mt-1 text-2xl font-semibold text-white">@conciliacion.StockActual.ToString("G29")</div>
            </div>
            <div class="pu-card p-4">
                <div class="text-xs uppercase tracking-wide text-slate-500 font-medium">Unidades disponibles</div>
                <div class="mt-1 text-2xl font-semibold text-emerald-400">@conciliacion.UnidadesEnStock</div>
            </div>
            <div class="pu-card p-4 @(conciliacion.HayDiferencia ? "!border-amber-500/40 !bg-amber-500/5" : "!border-emerald-500/30 !bg-emerald-500/5")">
                <div class="text-xs uppercase tracking-wide text-slate-500 font-medium">Diferencia</div>
                <div class="mt-1 text-2xl font-semibold @(conciliacion.HayDiferencia ? "text-amber-300" : "text-emerald-300")">@diferenciaTexto</div>
            </div>
            <div class="pu-card p-4">
                <div class="text-xs uppercase tracking-wide text-slate-500 font-medium">Unidades registradas</div>
                <div class="mt-1 text-2xl font-semibold text-white">@conciliacion.TotalUnidadesRegistradas</div>
            </div>
        </div>

        @if (hayDesgloseVisible)
        {
            <div class="pu-card p-4">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-3">Desglose por estado</p>
                <div class="grid gap-3 sm:grid-cols-3 lg:grid-cols-6">
                    <div class="pu-card p-3 text-center">
                        <p class="text-xs text-slate-500">Vendidas</p>
                        <p class="mt-1 text-xl font-semibold text-white">@conciliacion.UnidadesVendidas</p>
                    </div>
                    <div class="pu-card p-3 text-center">
                        <p class="text-xs text-slate-500">Faltantes</p>
                        <p class="mt-1 text-xl font-semibold text-white">@conciliacion.UnidadesFaltantes</p>
                    </div>
                    <div class="pu-card p-3 text-center">
                        <p class="text-xs text-slate-500">Baja</p>
                        <p class="mt-1 text-xl font-semibold text-white">@conciliacion.UnidadesBaja</p>
                    </div>
                    <div class="pu-card p-3 text-center">
                        <p class="text-xs text-slate-500">Devueltas</p>
                        <p class="mt-1 text-xl font-semibold text-white">@conciliacion.UnidadesDevueltas</p>
                    </div>
                    <div class="pu-card p-3 text-center">
                        <p class="text-xs text-slate-500">Reservadas</p>
                        <p class="mt-1 text-xl font-semibold text-white">@conciliacion.UnidadesReservadas</p>
                    </div>
                    <div class="pu-card p-3 text-center">
                        <p class="text-xs text-slate-500">En reparacion</p>
                        <p class="mt-1 text-xl font-semibold text-white">@conciliacion.UnidadesEnReparacion</p>
                    </div>
                </div>
            </div>
        }

        <div class="flex flex-wrap gap-x-6 gap-y-1 text-xs text-slate-500">
            <span>Ultimo movimiento stock: @(conciliacion.UltimoMovimientoStockFecha?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Sin movimientos")</span>
            <span>Ultimo movimiento unidad: @(conciliacion.UltimoMovimientoUnidadFecha?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Sin movimientos")</span>
        </div>

        @* Opciones de Resolucion — estructura visual del standalone *@
        <div class="pu-card p-5">
            <h3 class="font-semibold text-white">Opciones de Resolucion</h3>
            <p class="text-xs text-slate-400 mt-0.5">Elegí como queres tratar la diferencia detectada.</p>

            <div class="mt-4 space-y-2.5">

                @* Opcion 1 *@
                <label class="pu-reso-opt flex gap-3 items-start rounded-lg border border-slate-800 p-4 cursor-pointer"
                       onclick="puSelectResolution(1)">
                    <input type="radio" name="reso" value="1" class="mt-1 accent-blue-500" checked />
                    <div class="flex-1">
                        <div class="font-medium text-white">Mantener diferencia visible</div>
                        <p class="text-sm text-slate-400 mt-0.5">No realizar cambios en stock ni en unidades fisicas por ahora.</p>
                    </div>
                </label>

                @* Opcion 2 *@
                <label class="pu-reso-opt flex gap-3 items-start rounded-lg border border-slate-800 p-4 cursor-pointer"
                       onclick="puSelectResolution(2)">
                    <input type="radio" name="reso" value="2" class="mt-1 accent-blue-500" />
                    <div class="flex-1">
                        <div class="font-medium text-white flex items-center gap-2">
                            Crear unidades fisicas faltantes
                            <span class="text-xs px-2 py-0.5 rounded-md bg-blue-500/10 text-blue-300 border border-blue-500/30">Recomendado</span>
                        </div>
                        <p class="text-sm text-slate-400 mt-0.5">Ir a la pestana de agregar unidades para registrar fisicamente el stock no identificado.</p>
                        <button type="button" class="mt-2 pu-btn pu-btn-primary pu-btn-sm"
                                onclick="event.stopPropagation(); activateTab('agregar')">
                            <span class="material-symbols-outlined" style="font-size:16px">arrow_forward</span>
                            Ir a Agregar unidades
                        </button>
                    </div>
                </label>

                @* Opcion 3 — ajuste de stock (puede estar disabled) *@
                @{
                    var opt3Disabled = !puedeAjustarStockAgregado;
                    var opt3Label = diferenciaNegativa ? "Ajustar stock a unidades fisicas" : "Ajustar stock hacia abajo";
                    var opt3Desc  = diferenciaNegativa
                        ? $"Aumentar el stock al nivel de las {conciliacion.UnidadesEnStock} unidades fisicas disponibles. Generara movimiento en Kardex."
                        : $"Igualar el stock del producto a las {conciliacion.UnidadesEnStock} unidades fisicas disponibles. Generara movimiento en Kardex.";
                }
                <label class="pu-reso-opt flex gap-3 items-start rounded-lg border border-slate-800 p-4 @(opt3Disabled ? "opacity-50" : "cursor-pointer")"
                       @(opt3Disabled ? "" : "onclick=\"puSelectResolution(3)\"")>
                    <input type="radio" name="reso" value="3" class="mt-1 accent-blue-500" @(opt3Disabled ? "disabled" : "") />
                    <div class="flex-1">
                        <div class="font-medium text-white">@opt3Label</div>
                        <p class="text-sm text-slate-400 mt-0.5">@opt3Desc</p>
                        @if (opt3Disabled)
                        {
                            <p class="mt-1 text-xs text-slate-500">
                                @(!conciliacion.RequiereNumeroSerie ? "No disponible: el producto no usa trazabilidad individual." : "No disponible: no hay diferencia activa.")
                            </p>
                        }
                    </div>
                </label>
            </div>

            @* Panel de ajuste — visible cuando se selecciona opcion 3 *@
            <div id="adjust-panel" class="hidden mt-5 rounded-lg border border-amber-500/40 bg-amber-500/5 p-4">
                <h4 class="font-semibold text-amber-200 flex items-center gap-2">
                    <span class="material-symbols-outlined" style="font-size:20px">play_arrow</span>
                    Ejecutar Ajuste
                </h4>
                <p class="text-xs text-amber-100/80 mt-1">
                    Stock @conciliacion.StockActual.ToString("G29") &rarr; @conciliacion.UnidadesEnStock. Esta accion quedara registrada en Kardex.
                </p>
                @if (puedeAjustarStockAgregado)
                {
                    @if (diferenciaPositiva)
                    {
                        <form method="post" asp-controller="Producto" asp-action="AjustarStockAgregadoHaciaAbajo" class="mt-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ProductoId" value="@conciliacion.ProductoId" />
                            <div>
                                <label class="pu-label" style="color:rgba(251,191,36,.8);">Motivo <span class="text-red-400">*</span></label>
                                <textarea name="Motivo" maxlength="500" required rows="2"
                                          class="pu-field" style="border-color:rgba(245,158,11,.4);"
                                          placeholder="Ej. Recuento fisico confirma stock inflado"></textarea>
                            </div>
                            <div class="mt-3 flex justify-end">
                                <button type="submit" class="pu-btn pu-btn-amber">
                                    <span class="material-symbols-outlined" style="font-size:18px">south</span>
                                    Ajustar stock hacia abajo
                                </button>
                            </div>
                        </form>
                    }
                    else if (diferenciaNegativa)
                    {
                        <form method="post" asp-controller="Producto" asp-action="AjustarStockAgregadoAUnidadesFisicas" class="mt-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ProductoId" value="@conciliacion.ProductoId" />
                            <div>
                                <label class="pu-label" style="color:rgba(251,191,36,.8);">Motivo <span class="text-red-400">*</span></label>
                                <textarea name="Motivo" maxlength="500" required rows="2"
                                          class="pu-field" style="border-color:rgba(245,158,11,.4);"
                                          placeholder="Ej. Recuento fisico confirma unidades disponibles"></textarea>
                            </div>
                            <div class="mt-3 flex justify-end">
                                <button type="submit" class="pu-btn pu-btn-amber">
                                    <span class="material-symbols-outlined" style="font-size:18px">north</span>
                                    Ajustar stock a unidades fisicas
                                </button>
                            </div>
                        </form>
                    }
                }
            </div>
        </div>
    </section>

    @* ================================================================
       PANEL: TRAZABILIDAD
       ================================================================ *@
    <section id="trazabilidad" role="tabpanel" data-tab-panel="trazabilidad" aria-labelledby="tab-trazabilidad" class="space-y-5" hidden>
        <div>
            <h2 class="text-lg font-semibold text-white">Trazabilidad</h2>
            <p class="text-sm text-slate-400">Configura si este producto requiere identificar una unidad fisica especifica al vender.</p>
        </div>

        @{
            var puedeDesactivar = Model.RequiereNumeroSerie && Model.Conciliacion.TotalUnidadesActivas == 0;
            var bloqueadaConUnidades = Model.RequiereNumeroSerie && Model.Conciliacion.TotalUnidadesActivas > 0;
        }

        @if (Model.RequiereNumeroSerie)
        {
            <div class="pu-card p-5">
                <div class="flex items-start gap-3">
                    <div class="w-10 h-10 rounded-lg bg-emerald-500/10 border border-emerald-500/30 flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined text-emerald-400">verified</span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2">
                            <h3 class="text-lg font-semibold text-white">Trazabilidad Activada</h3>
                            <span class="text-xs px-2 py-0.5 rounded-md bg-emerald-500/10 text-emerald-300 border border-emerald-500/30">ON</span>
                        </div>
                        <p class="text-sm text-slate-300 mt-1">Este producto requiere seleccionar una unidad fisica al vender.</p>
                    </div>
                </div>

                @if (bloqueadaConUnidades)
                {
                    <div class="mt-4 rounded-lg border border-amber-500/40 bg-amber-500/5 p-3 flex gap-2.5">
                        <span class="material-symbols-outlined text-amber-300 shrink-0" style="font-size:20px">warning</span>
                        <div class="text-sm text-amber-100/90">
                            No se puede desactivar todavia. Existen <strong>@Model.Conciliacion.TotalUnidadesActivas unidad@(Model.Conciliacion.TotalUnidadesActivas != 1 ? "es" : "") activa@(Model.Conciliacion.TotalUnidadesActivas != 1 ? "s" : "")</strong>.
                            Primero tenes que revisar, vender, dar de baja o resolver esas unidades.
                            <div class="mt-1.5">
                                <button type="button" onclick="activateTab('ver')" class="text-amber-300 underline underline-offset-2 hover:text-amber-200 text-sm">
                                    Ver unidades activas &rarr;
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="mt-4 flex flex-wrap gap-2 items-center">
                        <span class="pu-btn pu-btn-ghost opacity-50 cursor-not-allowed" aria-disabled="true">
                            <span class="material-symbols-outlined" style="font-size:18px">power_off</span>
                            Desactivar trazabilidad
                        </span>
                    </div>
                }
                else if (puedeDesactivar)
                {
                    <div class="mt-4 flex flex-wrap gap-2 items-center">
                        <form method="post" asp-controller="Producto" asp-action="DesactivarTrazabilidad" asp-route-productoId="@Model.ProductoId">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="pu-btn pu-btn-ghost">
                                <span class="material-symbols-outlined" style="font-size:18px">power_off</span>
                                Desactivar trazabilidad
                            </button>
                        </form>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="pu-card p-5">
                <div class="flex items-start gap-3">
                    <div class="w-10 h-10 rounded-lg bg-slate-800 border border-slate-700 flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined text-slate-400">block</span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2">
                            <h3 class="text-lg font-semibold text-white">Trazabilidad Desactivada</h3>
                            <span class="text-xs px-2 py-0.5 rounded-md bg-slate-700/40 text-slate-300 border border-slate-700">OFF</span>
                        </div>
                        <p class="text-sm text-slate-300 mt-1">Este producto no requiere seleccionar una unidad fisica al vender.</p>
                    </div>
                </div>
                <div class="mt-4 flex flex-wrap gap-2 items-center">
                    <form method="post" asp-controller="Producto" asp-action="ActivarTrazabilidad" asp-route-productoId="@Model.ProductoId">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="pu-btn pu-btn-primary">
                            <span class="material-symbols-outlined" style="font-size:18px">power_settings_new</span>
                            Activar trazabilidad
                        </button>
                    </form>
                </div>
            </div>
        }
    </section>

    @* ================================================================
       FORMULARIOS REALES OCULTOS — usados por modal gestionar
       Preservan contratos POST exactos sin cambiar backend
       ================================================================ *@
    <div class="hidden" aria-hidden="true" id="pu-real-forms">
        @foreach (var unidad in Model.Unidades)
        {
            @if (unidad.PuedeMarcarFaltante)
            {
                <form id="rmf-faltante-@unidad.Id" method="post" asp-controller="Producto" asp-action="MarcarUnidadFaltante">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ProductoUnidadId" value="@unidad.Id" />
                    <input type="hidden" name="Motivo" value="" />
                </form>
            }
            @if (unidad.PuedeReintegrarAStock)
            {
                <form id="rmf-reintegrar-@unidad.Id" method="post" asp-controller="Producto" asp-action="ReintegrarUnidadAStock">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ProductoUnidadId" value="@unidad.Id" />
                    <input type="hidden" name="Motivo" value="" />
                </form>
            }
            @if (unidad.PuedeDarBaja)
            {
                <form id="rmf-baja-@unidad.Id" method="post" asp-controller="Producto" asp-action="DarUnidadBaja">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ProductoUnidadId" value="@unidad.Id" />
                    <input type="hidden" name="Motivo" value="" />
                </form>
            }
            @if (unidad.PuedeFinalizarReparacion)
            {
                <form id="rmf-reparacion-@unidad.Id" method="post" asp-controller="Producto" asp-action="FinalizarReparacionUnidad">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ProductoUnidadId" value="@unidad.Id" />
                    <input type="hidden" name="EstadoDestino" value="" />
                    <input type="hidden" name="Motivo" value="" />
                </form>
            }
        }
    </div>

    @* ================================================================
       MODAL: GESTIONAR UNIDAD — replica estructura standalone
       Un solo overlay, JS conecta con formularios reales ocultos
       ================================================================ *@
    <div id="modal-manage"
         class="hidden fixed inset-0 z-50 bg-black/60 backdrop-blur-sm overflow-y-auto"
         onclick="if(event.target===this)puCloseModal('modal-manage')"
         role="dialog" aria-modal="true" aria-labelledby="manage-title">
        <div class="min-h-full flex items-center justify-center p-4">
            <div class="pu-modal-card pu-card w-full max-w-md p-5">
                <div class="flex items-start justify-between gap-3">
                    <div>
                        <h3 id="manage-title" class="text-lg font-semibold text-white">Gestionar Unidad</h3>
                        <p class="text-xs text-slate-400 mt-0.5">Aplicar cambio de estado a esta unidad.</p>
                    </div>
                    <button type="button" onclick="puCloseModal('modal-manage')" aria-label="Cerrar modal"
                            class="p-1.5 rounded hover:bg-slate-800">
                        <span class="material-symbols-outlined text-slate-400">close</span>
                    </button>
                </div>

                <dl class="mt-4 grid grid-cols-3 gap-3 rounded-lg bg-slate-900/60 border border-slate-800 p-3 text-xs">
                    <div>
                        <dt class="text-slate-500">Codigo</dt>
                        <dd class="font-mono text-white mt-0.5" id="manage-code">&mdash;</dd>
                    </div>
                    <div>
                        <dt class="text-slate-500">Serie</dt>
                        <dd class="font-mono text-slate-200 mt-0.5" id="manage-serial">&mdash;</dd>
                    </div>
                    <div>
                        <dt class="text-slate-500">Estado actual</dt>
                        <dd class="mt-0.5"><span id="manage-current-state" class="pu-chip pu-chip-neutral">&mdash;</span></dd>
                    </div>
                </dl>

                <div class="mt-4 space-y-3">
                    <div>
                        <label for="manage-action" class="pu-label">Accion a ejecutar</label>
                        <select id="manage-action" class="pu-field" onchange="puUpdateManageAction()"></select>
                    </div>
                    <div id="manage-destino-wrap" class="hidden">
                        <label for="manage-destino" class="pu-label">Destino de la reparacion</label>
                        <select id="manage-destino" class="pu-field">
                            <option value="EnStock">Reintegrar a stock</option>
                            <option value="Baja">Dar de baja (no reparable)</option>
                            <option value="Devuelta">Marcar como devuelta</option>
                        </select>
                    </div>
                    <div>
                        <label for="manage-motivo" class="pu-label">Motivo <span class="text-red-400">*</span></label>
                        <textarea id="manage-motivo" rows="3" class="pu-field"
                                  placeholder="Detalle de la accion, evidencia, contexto..."></textarea>
                        <p id="manage-motivo-error" class="hidden mt-1 text-xs text-red-300">Motivo obligatorio.</p>
                    </div>
                    <div id="manage-aviso-kardex" class="hidden rounded-lg border border-amber-500/30 bg-amber-500/10 px-3 py-2 flex items-start gap-2">
                        <span class="material-symbols-outlined text-amber-400 shrink-0 mt-0.5" style="font-size:18px">info</span>
                        <p class="text-[11px] text-amber-200">Esta acción cambia el estado físico de la unidad, pero <strong>no ajusta el stock lógico ni genera Kardex</strong>. Si corresponde, usá la sección Conciliación para alinear el stock.</p>
                    </div>
                </div>

                <div class="mt-5 flex flex-col-reverse sm:flex-row justify-end gap-2">
                    <button type="button" class="pu-btn pu-btn-ghost" onclick="puCloseModal('modal-manage')">Cancelar</button>
                    <button type="button" id="manage-confirm-btn" class="pu-btn pu-btn-success" onclick="puConfirmManage()">
                        <span class="material-symbols-outlined" style="font-size:18px" id="manage-confirm-icon">undo</span>
                        <span id="manage-confirm-label">Reintegrar a stock</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
<script>
(function () {
    'use strict';

    // ============================================================
    // TABS
    // ============================================================
    var ACTIVE_CLS   = 'tab-btn shrink-0 px-4 py-3 text-sm font-medium text-white border-b-2 border-blue-500 transition-colors whitespace-nowrap';
    var INACTIVE_CLS = 'tab-btn shrink-0 px-4 py-3 text-sm font-medium text-slate-400 hover:text-white border-b-2 border-transparent transition-colors whitespace-nowrap';

    var panelByHash = {
        'ver':                        'ver',
        'agregar':                    'agregar',
        'conciliar':                  'conciliar',
        'trazabilidad':               'trazabilidad',
        'listado-unidades':           'ver',
        'form-carga-masiva-unidades': 'agregar',
        'adjust-panel':               'conciliar'
    };

    var tablist = document.querySelector('[role="tablist"][aria-label="Modos de unidades"]');
    if (!tablist) return;
    var tabs   = Array.from(tablist.querySelectorAll('[role="tab"][data-tab-target]'));
    var panels = Array.from(document.querySelectorAll('[data-tab-panel]'));

    function normalizeHash(hash) {
        return (hash || '').replace(/^#/, '');
    }

    function panelIdFromHash(hash) {
        var requested = normalizeHash(hash);
        return panelByHash[requested] || 'ver';
    }

    function setActivePanel(panelId) {
        panels.forEach(function (panel) {
            panel.hidden = panel.getAttribute('data-tab-panel') !== panelId;
        });
        tabs.forEach(function (tab) {
            var selected = tab.getAttribute('data-tab-target') === panelId;
            tab.setAttribute('aria-selected', selected ? 'true' : 'false');
            tab.setAttribute('tabindex', selected ? '0' : '-1');
            tab.className = selected ? ACTIVE_CLS : INACTIVE_CLS;
        });
    }

    function updateHash(hash) {
        if (!hash || location.hash === hash) return;
        history.replaceState(null, '', hash);
    }

    function activateFromHash(hash, shouldUpdateHash) {
        var targetPanelId = panelIdFromHash(hash);
        setActivePanel(targetPanelId);
        if (shouldUpdateHash) updateHash(hash || '#' + targetPanelId);
    }

    activateFromHash(location.hash, false);

    tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
            activateFromHash('#' + tab.getAttribute('data-tab-target'), true);
        });
        tab.addEventListener('keydown', function (event) {
            if (event.key !== 'ArrowLeft' && event.key !== 'ArrowRight') return;
            event.preventDefault();
            var idx = tabs.indexOf(tab);
            var dir = event.key === 'ArrowRight' ? 1 : -1;
            var next = tabs[(idx + dir + tabs.length) % tabs.length];
            next.focus();
            activateFromHash('#' + next.getAttribute('data-tab-target'), true);
        });
    });

    document.addEventListener('click', function (event) {
        var link = event.target.closest('a[href^="#"]');
        if (!link) return;
        var hash = link.getAttribute('href');
        if (!panelByHash[normalizeHash(hash)]) return;
        event.preventDefault();
        activateFromHash(hash, true);
    });

    window.addEventListener('hashchange', function () {
        activateFromHash(location.hash, false);
    });

    window.activateTab = function (name) {
        activateFromHash('#' + name, true);
        window.scrollTo({ top: 0, behavior: 'smooth' });
    };

    // ============================================================
    // MODAL HELPERS
    // ============================================================
    window.puOpenModal = function (id) {
        document.getElementById(id).classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    };
    window.puCloseModal = function (id) {
        document.getElementById(id).classList.add('hidden');
        document.body.style.overflow = '';
    };

    // Escape cierra modal-manage
    document.addEventListener('keydown', function (e) {
        if (e.key !== 'Escape') return;
        var m = document.getElementById('modal-manage');
        if (m && !m.classList.contains('hidden')) puCloseModal('modal-manage');
    });

    // ============================================================
    // MODAL: GESTIONAR UNIDAD
    // ============================================================
    var _manageUnidadId = null;

    var ACTION_CFG = {
        reintegrar: { label: 'Reintegrar a stock',   icon: 'undo',         cls: 'pu-btn pu-btn-success' },
        baja:       { label: 'Dar de baja',           icon: 'block',        cls: 'pu-btn pu-btn-danger'  },
        faltante:   { label: 'Marcar faltante',       icon: 'help',         cls: 'pu-btn pu-btn-amber'   },
        reparacion: { label: 'Finalizar reparacion',  icon: 'build_circle', cls: 'pu-btn pu-btn-primary'  }
    };

    window.puOpenManage = function (unidadId, code, serial, stateLabel, chipClass, actions) {
        _manageUnidadId = unidadId;
        document.getElementById('manage-code').textContent   = code;
        document.getElementById('manage-serial').textContent = serial;

        var stChip = document.getElementById('manage-current-state');
        stChip.textContent = stateLabel;
        stChip.className   = chipClass;

        var select = document.getElementById('manage-action');
        select.innerHTML = '';
        actions.forEach(function (a) {
            var opt = document.createElement('option');
            opt.value = a.value; opt.textContent = a.label;
            select.appendChild(opt);
        });

        document.getElementById('manage-motivo').value = '';
        document.getElementById('manage-motivo-error').classList.add('hidden');

        puUpdateManageAction();
        puOpenModal('modal-manage');
    };

    window.puUpdateManageAction = function () {
        var v   = document.getElementById('manage-action').value;
        var cfg = ACTION_CFG[v] || { label: 'Confirmar', icon: 'check', cls: 'pu-btn pu-btn-primary' };
        document.getElementById('manage-confirm-btn').className     = cfg.cls;
        document.getElementById('manage-confirm-label').textContent = cfg.label;
        document.getElementById('manage-confirm-icon').textContent  = cfg.icon;
        document.getElementById('manage-destino-wrap').classList.toggle('hidden', v !== 'reparacion');
        var avisoKardex = document.getElementById('manage-aviso-kardex');
        if (avisoKardex) avisoKardex.classList.toggle('hidden', v !== 'faltante' && v !== 'baja');
    };

    window.puConfirmManage = function () {
        var motivo = (document.getElementById('manage-motivo').value || '').trim();
        if (!motivo) {
            document.getElementById('manage-motivo-error').classList.remove('hidden');
            return;
        }
        document.getElementById('manage-motivo-error').classList.add('hidden');

        var action = document.getElementById('manage-action').value;
        var form   = document.getElementById('rmf-' + action + '-' + _manageUnidadId);
        if (!form) return;

        form.querySelector('[name="Motivo"]').value = motivo;
        if (action === 'reparacion') {
            form.querySelector('[name="EstadoDestino"]').value =
                document.getElementById('manage-destino').value;
        }
        form.submit();
    };

    // ============================================================
    // CONCILIAR: seleccion de opciones
    // ============================================================
    window.puSelectResolution = function (n) {
        document.querySelectorAll('input[name="reso"]').forEach(function (r) {
            if (!r.disabled) r.checked = (parseInt(r.value, 10) === n);
        });
        var panel = document.getElementById('adjust-panel');
        if (panel) panel.classList.toggle('hidden', n !== 3);
    };

    // ============================================================
    // FILTROS: radio disponibilidad <-> checkboxes backend
    // ============================================================
    window.puDispoChange = function (selected) {
        var cbDispo   = document.getElementById('filter-soloDisponibles');
        var cbVendidas = document.getElementById('filter-soloVendidas');
        if (!cbDispo || !cbVendidas) return;
        cbDispo.disabled    = (selected !== 'disponibles');
        cbDispo.checked     = (selected === 'disponibles');
        cbVendidas.disabled = (selected !== 'vendidas');
        cbVendidas.checked  = (selected === 'vendidas');
    };

}());
</script>
}
