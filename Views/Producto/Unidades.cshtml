@model ProductoUnidadesViewModel
@using TheBuryProject.Models.Enums

@{
    ViewData["Title"] = $"Unidades - {Model.Nombre}";
    var estados = Enum.GetValues<EstadoUnidad>();
    var conciliacion = Model.Conciliacion;
    var diferenciaCss = conciliacion.HayDiferencia
        ? "border-amber-500/30 bg-amber-500/10 text-amber-200"
        : "border-emerald-500/30 bg-emerald-500/10 text-emerald-200";
    var diferenciaTexto = conciliacion.DiferenciaStockVsUnidadesEnStock > 0
        ? $"+{conciliacion.DiferenciaStockVsUnidadesEnStock:G29}"
        : conciliacion.DiferenciaStockVsUnidadesEnStock.ToString("G29");
}

<div class="space-y-6">
    @if (TempData["Success"] != null)
    {
        <div class="rounded-lg border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-sm font-semibold text-emerald-200">
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm font-semibold text-red-200">
            @TempData["Error"]
        </div>
    }

    <section class="rounded-lg border border-slate-800 bg-slate-950/60 p-5">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div>
                <a asp-controller="Catalogo" asp-action="Index" class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-400 transition-colors hover:text-white">
                    <span class="material-symbols-outlined text-base">arrow_back</span>
                    Volver al Catalogo
                </a>
                <h1 class="mt-3 text-2xl font-black text-white">@Model.Nombre</h1>
                <div class="mt-2 flex flex-wrap items-center gap-2 text-sm text-slate-400">
                    <span class="font-mono">@Model.Codigo</span>
                    <span class="text-slate-700">/</span>
                    <span>Stock agregado: <strong class="text-slate-200">@Model.StockActual.ToString("G29")</strong></span>
                    <span class="inline-flex items-center rounded-full border px-2 py-0.5 text-xs font-bold @(Model.RequiereNumeroSerie ? "border-emerald-500/30 bg-emerald-500/10 text-emerald-300" : "border-amber-500/30 bg-amber-500/10 text-amber-300")">
                        @(Model.RequiereNumeroSerie ? "Trazabilidad individual requerida" : "No requiere trazabilidad individual")
                    </span>
                </div>
                @if (!Model.RequiereNumeroSerie)
                {
                    <p class="mt-3 max-w-3xl text-sm text-amber-200">
                        Este producto no exige seleccion de unidad fisica en venta. Si tiene unidades cargadas, se muestran solo como trazabilidad operativa.
                    </p>
                }
            </div>
            <div class="flex flex-wrap gap-2">
                <a asp-controller="MovimientoStock" asp-action="Kardex" asp-route-id="@Model.ProductoId"
                   class="inline-flex items-center gap-1.5 rounded-lg border border-slate-700 px-3 py-2 text-sm font-bold text-slate-200 transition-colors hover:bg-slate-800">
                    <span class="material-symbols-outlined text-base">receipt_long</span>
                    Ver kardex SKU
                </a>
            </div>
        </div>
    </section>

    <section class="rounded-lg border border-slate-800 bg-slate-950/60 p-5">
        <div class="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
            <div>
                <div class="flex flex-wrap items-center gap-2">
                    <h2 class="text-base font-black text-white">Conciliacion stock vs unidades fisicas</h2>
                    <span class="inline-flex items-center rounded-full border px-2 py-0.5 text-xs font-bold @diferenciaCss">
                        @(conciliacion.HayDiferencia ? "Diferencia detectada" : "Conciliado")
                    </span>
                </div>
                <p class="mt-2 max-w-4xl text-sm text-slate-400">
                    Este panel compara el stock agregado del SKU contra las unidades fisicas disponibles. No realiza ajustes automaticamente.
                </p>
                @if (!conciliacion.RequiereNumeroSerie)
                {
                    <p class="mt-2 max-w-4xl text-sm text-amber-200">
                        Este producto no requiere trazabilidad individual. Las unidades cargadas son trazabilidad operativa opcional.
                    </p>
                }
            </div>
            <div class="flex flex-wrap gap-2">
                <a asp-controller="MovimientoStock" asp-action="Kardex" asp-route-id="@Model.ProductoId"
                   class="inline-flex items-center gap-1.5 rounded-lg border border-slate-700 px-3 py-2 text-sm font-bold text-slate-200 transition-colors hover:bg-slate-800">
                    <span class="material-symbols-outlined text-base">receipt_long</span>
                    Ver Kardex SKU
                </a>
                <a href="#listado-unidades"
                   class="inline-flex items-center gap-1.5 rounded-lg border border-slate-700 px-3 py-2 text-sm font-bold text-slate-200 transition-colors hover:bg-slate-800">
                    <span class="material-symbols-outlined text-base">list_alt</span>
                    Ver historial/listado de unidades
                </a>
                <span aria-disabled="true"
                      class="inline-flex cursor-not-allowed items-center gap-1.5 rounded-lg border border-slate-800 px-3 py-2 text-sm font-bold text-slate-500">
                    <span class="material-symbols-outlined text-base">pending_actions</span>
                    Ajuste asistido pendiente de proxima fase
                </span>
            </div>
        </div>

        <div class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
            <div class="rounded-lg border border-slate-800 bg-slate-950 p-4">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Stock agregado actual</p>
                <p class="mt-1 text-2xl font-black text-white">@conciliacion.StockActual.ToString("G29")</p>
            </div>
            <div class="rounded-lg border border-slate-800 bg-slate-950 p-4">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Unidades fisicas EnStock</p>
                <p class="mt-1 text-2xl font-black text-white">@conciliacion.UnidadesEnStock</p>
            </div>
            <div class="rounded-lg border border-slate-800 bg-slate-950 p-4">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Diferencia</p>
                <p class="mt-1 text-2xl font-black @(conciliacion.HayDiferencia ? "text-amber-200" : "text-emerald-200")">@diferenciaTexto</p>
            </div>
            <div class="rounded-lg border border-slate-800 bg-slate-950 p-4">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Total unidades activas</p>
                <p class="mt-1 text-2xl font-black text-white">@conciliacion.TotalUnidadesActivas</p>
            </div>
        </div>

        <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6">
            <div class="rounded-lg border border-slate-800 bg-slate-950 p-3">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Vendidas</p>
                <p class="mt-1 text-xl font-black text-white">@conciliacion.UnidadesVendidas</p>
            </div>
            <div class="rounded-lg border border-slate-800 bg-slate-950 p-3">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Faltantes</p>
                <p class="mt-1 text-xl font-black text-white">@conciliacion.UnidadesFaltantes</p>
            </div>
            <div class="rounded-lg border border-slate-800 bg-slate-950 p-3">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Baja</p>
                <p class="mt-1 text-xl font-black text-white">@conciliacion.UnidadesBaja</p>
            </div>
            <div class="rounded-lg border border-slate-800 bg-slate-950 p-3">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Devueltas</p>
                <p class="mt-1 text-xl font-black text-white">@conciliacion.UnidadesDevueltas</p>
            </div>
            <div class="rounded-lg border border-slate-800 bg-slate-950 p-3">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Reservadas</p>
                <p class="mt-1 text-xl font-black text-white">@conciliacion.UnidadesReservadas</p>
            </div>
            <div class="rounded-lg border border-slate-800 bg-slate-950 p-3">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">En reparacion</p>
                <p class="mt-1 text-xl font-black text-white">@conciliacion.UnidadesEnReparacion</p>
            </div>
        </div>

        <div class="mt-4 flex flex-wrap gap-x-6 gap-y-1 text-xs text-slate-500">
            <span>Ultimo movimiento stock: @(conciliacion.UltimoMovimientoStockFecha?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Sin movimientos")</span>
            <span>Ultimo movimiento unidad: @(conciliacion.UltimoMovimientoUnidadFecha?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Sin movimientos")</span>
        </div>
    </section>

    <section class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-lg border border-slate-800 bg-slate-950 p-4">
            <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Unidades listadas</p>
            <p class="mt-1 text-2xl font-black text-white">@Model.Unidades.Count</p>
        </div>
        @foreach (var resumen in Model.ResumenEstados)
        {
            <div class="rounded-lg border border-slate-800 bg-slate-950 p-4">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">@resumen.Estado</p>
                <p class="mt-1 text-2xl font-black text-white">@resumen.Cantidad</p>
            </div>
        }
    </section>

    <section class="rounded-lg border border-slate-800 bg-slate-950/60 p-4">
        <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
            <div>
                <h2 class="text-base font-black text-white">Agregar unidad</h2>
                <p class="mt-1 text-sm text-slate-400">El codigo interno se genera automaticamente. El numero de serie es opcional. La unidad se creara en estado EnStock.</p>
                <p class="mt-1 text-xs text-amber-200">Crear una unidad fisica no ajusta el stock agregado. El stock agregado sigue bajo MovimientoStockService.</p>
            </div>
        </div>

        <form method="post" asp-controller="Producto" asp-action="CrearUnidad" class="mt-4">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="CrearUnidad.ProductoId" value="@Model.ProductoId" />
            <div asp-validation-summary="ModelOnly" class="mb-3 text-sm font-semibold text-red-300"></div>

            <div class="grid gap-3 lg:grid-cols-[1fr_1fr_1.4fr_auto] lg:items-start">
                <label class="block">
                    <span class="text-xs font-bold uppercase tracking-wider text-slate-500">Numero de serie</span>
                    <input asp-for="CrearUnidad.NumeroSerie" maxlength="100"
                           class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white outline-none transition-colors focus:border-primary"
                           placeholder="Opcional" />
                    <span asp-validation-for="CrearUnidad.NumeroSerie" class="mt-1 block text-xs font-semibold text-red-300"></span>
                </label>
                <label class="block">
                    <span class="text-xs font-bold uppercase tracking-wider text-slate-500">Ubicacion actual</span>
                    <input asp-for="CrearUnidad.UbicacionActual" maxlength="200"
                           class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white outline-none transition-colors focus:border-primary"
                           placeholder="Opcional" />
                    <span asp-validation-for="CrearUnidad.UbicacionActual" class="mt-1 block text-xs font-semibold text-red-300"></span>
                </label>
                <label class="block">
                    <span class="text-xs font-bold uppercase tracking-wider text-slate-500">Observaciones</span>
                    <input asp-for="CrearUnidad.Observaciones" maxlength="500"
                           class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white outline-none transition-colors focus:border-primary"
                           placeholder="Opcional" />
                    <span asp-validation-for="CrearUnidad.Observaciones" class="mt-1 block text-xs font-semibold text-red-300"></span>
                </label>
                <button type="submit" class="inline-flex min-h-[38px] items-center justify-center gap-1.5 rounded-lg bg-primary px-4 py-2 text-sm font-bold text-white transition-colors hover:bg-primary/90 lg:mt-5">
                    <span class="material-symbols-outlined text-base">add_circle</span>
                    Agregar unidad
                </button>
            </div>
        </form>
    </section>

    <section class="rounded-lg border border-slate-800 bg-slate-950/60 p-4">
        <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
            <div>
                <h2 class="text-base font-black text-white">Carga masiva de unidades</h2>
                <p class="mt-1 text-sm text-slate-400">Genera varias unidades sin serie o pega una serie por linea. Primero se muestra una previsualizacion para confirmar.</p>
                <p class="mt-1 text-xs text-amber-200">La carga masiva no ajusta el stock agregado y no crea movimientos de stock SKU.</p>
            </div>
        </div>

        <form method="post" asp-controller="Producto" asp-action="CrearUnidadesMasivas" class="mt-4">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="CargaMasiva.ProductoId" value="@Model.ProductoId" />

            <div class="grid gap-3 lg:grid-cols-[0.7fr_1.3fr_1fr_1.2fr] lg:items-start">
                <label class="block">
                    <span class="text-xs font-bold uppercase tracking-wider text-slate-500">Cantidad sin serie</span>
                    <input asp-for="CargaMasiva.CantidadSinSerie" min="0" max="200" type="number"
                           class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white outline-none transition-colors focus:border-primary" />
                    <span asp-validation-for="CargaMasiva.CantidadSinSerie" class="mt-1 block text-xs font-semibold text-red-300"></span>
                </label>
                <label class="block">
                    <span class="text-xs font-bold uppercase tracking-wider text-slate-500">Numeros de serie</span>
                    <textarea asp-for="CargaMasiva.NumerosSerieTexto" rows="5" maxlength="12000"
                              class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white outline-none transition-colors focus:border-primary"
                              placeholder="Una serie por linea"></textarea>
                    <span asp-validation-for="CargaMasiva.NumerosSerieTexto" class="mt-1 block text-xs font-semibold text-red-300"></span>
                </label>
                <label class="block">
                    <span class="text-xs font-bold uppercase tracking-wider text-slate-500">Ubicacion actual</span>
                    <input asp-for="CargaMasiva.UbicacionActual" maxlength="200"
                           class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white outline-none transition-colors focus:border-primary"
                           placeholder="Opcional" />
                    <span asp-validation-for="CargaMasiva.UbicacionActual" class="mt-1 block text-xs font-semibold text-red-300"></span>
                </label>
                <label class="block">
                    <span class="text-xs font-bold uppercase tracking-wider text-slate-500">Observaciones</span>
                    <textarea asp-for="CargaMasiva.Observaciones" rows="5" maxlength="500"
                              class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white outline-none transition-colors focus:border-primary"
                              placeholder="Opcional"></textarea>
                    <span asp-validation-for="CargaMasiva.Observaciones" class="mt-1 block text-xs font-semibold text-red-300"></span>
                </label>
            </div>

            <div class="mt-4 flex flex-wrap gap-2">
                <button type="submit" name="CargaMasiva.Confirmar" value="false"
                        class="inline-flex items-center gap-1.5 rounded-lg bg-primary px-4 py-2 text-sm font-bold text-white transition-colors hover:bg-primary/90">
                    <span class="material-symbols-outlined text-base">visibility</span>
                    Previsualizar
                </button>
                @if (Model.CargaMasiva.PreviewListo && Model.CargaMasiva.Preview.Any())
                {
                    <button type="submit" name="CargaMasiva.Confirmar" value="true"
                            class="inline-flex items-center gap-1.5 rounded-lg border border-emerald-500/40 bg-emerald-500/10 px-4 py-2 text-sm font-bold text-emerald-200 transition-colors hover:bg-emerald-500/20">
                        <span class="material-symbols-outlined text-base">done_all</span>
                        Confirmar carga
                    </button>
                }
            </div>

            @if (Model.CargaMasiva.PreviewListo && Model.CargaMasiva.Preview.Any())
            {
                <div class="mt-4 overflow-hidden rounded-lg border border-slate-800 bg-slate-950">
                    <div class="border-b border-slate-800 px-4 py-3">
                        <p class="text-sm font-bold text-white">Preview de carga: @Model.CargaMasiva.TotalUnidades unidades</p>
                        <p class="mt-1 text-xs text-slate-400">Todas se crearan en estado EnStock con codigo interno automatico.</p>
                    </div>
                    <div class="max-h-72 overflow-y-auto">
                        <table class="min-w-full divide-y divide-slate-800">
                            <thead class="bg-slate-900/70">
                                <tr>
                                    <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">#</th>
                                    <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">Serie</th>
                                    <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">Estado inicial</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-800">
                                @foreach (var item in Model.CargaMasiva.Preview)
                                {
                                    <tr>
                                        <td class="px-4 py-2 text-sm text-slate-300">@item.Orden</td>
                                        <td class="px-4 py-2 text-sm text-slate-300">@(item.NumeroSerie ?? "Sin numero de serie")</td>
                                        <td class="px-4 py-2 text-sm text-slate-200">@EstadoUnidad.EnStock</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </form>
    </section>

    <form method="get" asp-controller="Producto" asp-action="Unidades" asp-route-productoId="@Model.ProductoId"
          class="rounded-lg border border-slate-800 bg-slate-950/60 p-4">
        <div class="grid gap-3 lg:grid-cols-[1.2fr_1fr_auto] lg:items-end">
            <label class="block">
                <span class="text-xs font-bold uppercase tracking-wider text-slate-500">Codigo interno o serie</span>
                <input type="search" name="texto" value="@Model.Filtros.Texto"
                       class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white outline-none transition-colors focus:border-primary"
                       placeholder="Buscar unidad..." />
            </label>
            <label class="block">
                <span class="text-xs font-bold uppercase tracking-wider text-slate-500">Estado</span>
                <select name="estado" class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white outline-none transition-colors focus:border-primary">
                    <option value="">Todos</option>
                    @foreach (var estado in estados)
                    {
                        <option value="@estado" selected="@(Model.Filtros.Estado == estado)">@estado</option>
                    }
                </select>
            </label>
            <div class="flex flex-wrap gap-2">
                <button type="submit" class="inline-flex items-center gap-1.5 rounded-lg bg-primary px-4 py-2 text-sm font-bold text-white transition-colors hover:bg-primary/90">
                    <span class="material-symbols-outlined text-base">filter_alt</span>
                    Filtrar
                </button>
                <a asp-controller="Producto" asp-action="Unidades" asp-route-productoId="@Model.ProductoId"
                   class="inline-flex items-center gap-1.5 rounded-lg border border-slate-700 px-4 py-2 text-sm font-bold text-slate-300 transition-colors hover:bg-slate-800">
                    Limpiar
                </a>
            </div>
        </div>
        <div class="mt-3 flex flex-wrap gap-4 text-sm text-slate-300">
            <label class="inline-flex items-center gap-2">
                <input type="checkbox" name="soloDisponibles" value="true" checked="@Model.Filtros.SoloDisponibles" class="rounded border-slate-600 text-primary focus:ring-primary" />
                Solo disponibles
            </label>
            <label class="inline-flex items-center gap-2">
                <input type="checkbox" name="soloVendidas" value="true" checked="@Model.Filtros.SoloVendidas" class="rounded border-slate-600 text-primary focus:ring-primary" />
                Solo vendidas
            </label>
            <label class="inline-flex items-center gap-2">
                <input type="checkbox" name="soloSinNumeroSerie" value="true" checked="@Model.Filtros.SoloSinNumeroSerie" class="rounded border-slate-600 text-primary focus:ring-primary" />
                Sin numero de serie
            </label>
        </div>
    </form>

    <section id="listado-unidades" class="overflow-hidden rounded-lg border border-slate-800 bg-slate-950">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-800">
                <thead class="bg-slate-900/70">
                    <tr>
                        <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">Unidad</th>
                        <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">Serie</th>
                        <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">Estado</th>
                        <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">Ubicacion</th>
                        <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">Ingreso</th>
                        <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">Cliente</th>
                        <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">Venta</th>
                        <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">Observaciones</th>
                        <th class="px-4 py-3 text-right text-xs font-bold uppercase tracking-wider text-slate-400">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800">
                    @if (Model.Unidades.Any())
                    {
                        @foreach (var unidad in Model.Unidades)
                        {
                            <tr class="hover:bg-white/5">
                                <td class="px-4 py-3 font-mono text-sm text-white">@unidad.CodigoInternoUnidad</td>
                                <td class="px-4 py-3 text-sm text-slate-300">@(unidad.NumeroSerie ?? "-")</td>
                                <td class="px-4 py-3 text-sm text-slate-200">@unidad.Estado</td>
                                <td class="px-4 py-3 text-sm text-slate-300">@(unidad.UbicacionActual ?? "-")</td>
                                <td class="px-4 py-3 text-sm text-slate-300">@unidad.FechaIngreso.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="px-4 py-3 text-sm text-slate-300">@(unidad.ClienteAsociado ?? "-")</td>
                                <td class="px-4 py-3 text-sm text-slate-300">
                                    @if (unidad.VentaDetalleId.HasValue)
                                    {
                                        <span>Detalle #@unidad.VentaDetalleId</span>
                                        @if (unidad.FechaVenta.HasValue)
                                        {
                                            <span class="block text-xs text-slate-500">@unidad.FechaVenta.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                        }
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                                <td class="max-w-xs px-4 py-3 text-sm text-slate-300">@(unidad.Observaciones ?? "-")</td>
                                <td class="px-4 py-3 text-right">
                                    <div class="flex min-w-[18rem] flex-col items-stretch gap-2">
                                        <a asp-controller="Producto" asp-action="UnidadHistorial" asp-route-unidadId="@unidad.Id"
                                           class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-slate-700 px-2.5 py-1.5 text-xs font-bold text-slate-200 transition-colors hover:bg-slate-800">
                                            <span class="material-symbols-outlined text-base">history</span>
                                            Ver historial
                                        </a>

                                        @if (unidad.PuedeMarcarFaltante || unidad.PuedeDarBaja || unidad.PuedeReintegrarAStock)
                                        {
                                            <div class="grid gap-2">
                                                @if (unidad.PuedeMarcarFaltante)
                                                {
                                                    <form method="post" asp-controller="Producto" asp-action="MarcarUnidadFaltante" class="grid gap-1">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="ProductoUnidadId" value="@unidad.Id" />
                                                        <input name="Motivo" maxlength="500" required
                                                               class="w-full rounded-lg border border-slate-700 bg-slate-900 px-2.5 py-1.5 text-xs text-white outline-none transition-colors focus:border-primary"
                                                               placeholder="Motivo obligatorio" />
                                                        <button type="submit" class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-amber-500/40 bg-amber-500/10 px-2.5 py-1.5 text-xs font-bold text-amber-200 transition-colors hover:bg-amber-500/20">
                                                            <span class="material-symbols-outlined text-base">inventory_2</span>
                                                            Marcar faltante
                                                        </button>
                                                    </form>
                                                }

                                                @if (unidad.PuedeReintegrarAStock)
                                                {
                                                    <form method="post" asp-controller="Producto" asp-action="ReintegrarUnidadAStock" class="grid gap-1">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="ProductoUnidadId" value="@unidad.Id" />
                                                        <input name="Motivo" maxlength="500" required
                                                               class="w-full rounded-lg border border-slate-700 bg-slate-900 px-2.5 py-1.5 text-xs text-white outline-none transition-colors focus:border-primary"
                                                               placeholder="Motivo obligatorio" />
                                                        <button type="submit" class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-emerald-500/40 bg-emerald-500/10 px-2.5 py-1.5 text-xs font-bold text-emerald-200 transition-colors hover:bg-emerald-500/20">
                                                            <span class="material-symbols-outlined text-base">assignment_return</span>
                                                            Reintegrar a stock
                                                        </button>
                                                    </form>
                                                }

                                                @if (unidad.PuedeDarBaja)
                                                {
                                                    <form method="post" asp-controller="Producto" asp-action="DarUnidadBaja" class="grid gap-1">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="ProductoUnidadId" value="@unidad.Id" />
                                                        <input name="Motivo" maxlength="500" required
                                                               class="w-full rounded-lg border border-slate-700 bg-slate-900 px-2.5 py-1.5 text-xs text-white outline-none transition-colors focus:border-primary"
                                                               placeholder="Motivo obligatorio" />
                                                        <button type="submit" class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-red-500/40 bg-red-500/10 px-2.5 py-1.5 text-xs font-bold text-red-200 transition-colors hover:bg-red-500/20">
                                                            <span class="material-symbols-outlined text-base">block</span>
                                                            Dar de baja
                                                        </button>
                                                    </form>
                                                }
                                            </div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="px-4 py-10 text-center text-sm text-slate-400">
                                No hay unidades fisicas para los filtros seleccionados.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>
