@model ProductoUnidadesViewModel
@using TheBuryProject.Models.Enums

@{
    ViewData["Title"] = $"Unidades - {Model.Nombre}";
    var estados = Enum.GetValues<EstadoUnidad>();

    var conciliacion = Model.Conciliacion;
    var diferenciaCss = conciliacion.HayDiferencia
        ? "border-amber-500/30 bg-amber-500/10 text-amber-200"
        : "border-emerald-500/30 bg-emerald-500/10 text-emerald-200";
    var diferenciaTexto = conciliacion.DiferenciaStockVsUnidadesEnStock > 0
        ? $"+{conciliacion.DiferenciaStockVsUnidadesEnStock:G29}"
        : conciliacion.DiferenciaStockVsUnidadesEnStock.ToString("G29");
    var diferenciaPositiva = conciliacion.DiferenciaStockVsUnidadesEnStock > 0;
    var diferenciaNegativa = conciliacion.DiferenciaStockVsUnidadesEnStock < 0;
    var puedeAjustarStockAgregado = conciliacion.RequiereNumeroSerie && conciliacion.HayDiferencia;
    var ajusteAbsoluto = Math.Abs(conciliacion.DiferenciaStockVsUnidadesEnStock);
    var textoAjuste = diferenciaPositiva
        ? $"Reducir stock agregado en {ajusteAbsoluto:G29}"
        : $"Aumentar stock agregado en {ajusteAbsoluto:G29}";
    var estadoConciliacionTexto = diferenciaNegativa
        ? "Requiere revision"
        : conciliacion.HayDiferencia
            ? "Con diferencia"
            : "Conciliado";
    var hayDesgloseVisible = conciliacion.UnidadesVendidas > 0
        || conciliacion.UnidadesFaltantes > 0
        || conciliacion.UnidadesBaja > 0
        || conciliacion.UnidadesDevueltas > 0
        || conciliacion.UnidadesReservadas > 0
        || conciliacion.UnidadesEnReparacion > 0;
}

<div class="space-y-6">
    @if (TempData["Success"] != null)
    {
        <div class="rounded-lg border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-sm font-semibold text-emerald-200">
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm font-semibold text-red-200">
            @TempData["Error"]
        </div>
    }

    <section class="rounded-lg border border-slate-800 bg-slate-950/60 p-5">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div>
                <a asp-controller="Catalogo" asp-action="Index" class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-400 transition-colors hover:text-white">
                    <span class="material-symbols-outlined text-base">arrow_back</span>
                    Volver al Catalogo
                </a>
                <h1 class="mt-3 text-2xl font-black text-white">@Model.Nombre</h1>
                <div class="mt-2 flex flex-wrap items-center gap-2 text-sm text-slate-400">
                    <span class="font-mono">@Model.Codigo</span>
                    <span class="text-slate-700">/</span>
                    <span>Stock agregado: <strong class="text-slate-200">@Model.StockActual.ToString("G29")</strong></span>
                    <span class="inline-flex items-center rounded-full border px-2 py-0.5 text-xs font-bold @(Model.RequiereNumeroSerie ? "border-emerald-500/30 bg-emerald-500/10 text-emerald-300" : "border-amber-500/30 bg-amber-500/10 text-amber-300")">
                        @(Model.RequiereNumeroSerie ? "Trazabilidad individual requerida" : "No requiere trazabilidad individual")
                    </span>
                </div>
                @if (!Model.RequiereNumeroSerie)
                {
                    <p class="mt-2 text-xs text-amber-200">
                        No exige seleccion de unidad fisica en venta. Las unidades cargadas son trazabilidad operativa opcional.
                    </p>
                }
            </div>
            <div class="flex flex-wrap gap-2">
                <a asp-controller="MovimientoStock" asp-action="Kardex" asp-route-id="@Model.ProductoId"
                   class="inline-flex items-center gap-1.5 rounded-lg border border-slate-700 px-3 py-2 text-sm font-bold text-slate-200 transition-colors hover:bg-slate-800">
                    <span class="material-symbols-outlined text-base">receipt_long</span>
                    Ver Kardex SKU
                </a>
            </div>
        </div>
    </section>

    <nav class="sticky top-0 z-10 rounded-lg border border-slate-800 bg-slate-950/95 p-2 shadow-lg shadow-slate-950/20 backdrop-blur" aria-label="Modos de trabajo de unidades">
        <div class="flex gap-2 overflow-x-auto">
            <a href="#modo-unidades" class="inline-flex min-h-[40px] shrink-0 items-center gap-1.5 rounded-lg border border-primary/40 bg-primary/15 px-3 py-2 text-sm font-bold text-white transition-colors hover:bg-primary/25">
                <span class="material-symbols-outlined text-base">table_rows</span>
                Unidades
            </a>
            <a href="#modo-carga" class="inline-flex min-h-[40px] shrink-0 items-center gap-1.5 rounded-lg border border-slate-700 px-3 py-2 text-sm font-bold text-slate-300 transition-colors hover:bg-slate-800 hover:text-white">
                <span class="material-symbols-outlined text-base">add_circle</span>
                Carga
            </a>
            <a href="#modo-conciliacion" class="inline-flex min-h-[40px] shrink-0 items-center gap-1.5 rounded-lg border border-slate-700 px-3 py-2 text-sm font-bold text-slate-300 transition-colors hover:bg-slate-800 hover:text-white">
                <span class="material-symbols-outlined text-base">fact_check</span>
                Conciliacion
            </a>
            <a href="#modo-configuracion" class="inline-flex min-h-[40px] shrink-0 items-center gap-1.5 rounded-lg border border-slate-700 px-3 py-2 text-sm font-bold text-slate-300 transition-colors hover:bg-slate-800 hover:text-white">
                <span class="material-symbols-outlined text-base">tune</span>
                Configuracion
            </a>
        </div>
    </nav>

    <div id="modo-unidades" class="scroll-mt-32 space-y-4">
        <div class="flex flex-col gap-2 border-t border-slate-800 pt-4 md:flex-row md:items-end md:justify-between">
            <div>
                <p class="text-xs font-bold uppercase tracking-wider text-primary">Modo Unidades</p>
                <h2 class="mt-1 text-lg font-black text-white">Listado operativo</h2>
            </div>
            <a href="#modo-carga" class="inline-flex items-center gap-1.5 text-sm font-bold text-slate-300 transition-colors hover:text-white">
                <span class="material-symbols-outlined text-base">add_circle</span>
                Agregar o cargar unidades
            </a>
        </div>

    <section class="rounded-lg border border-slate-800 bg-slate-950/60 p-4">
        <h2 class="mb-3 text-xs font-bold uppercase tracking-wider text-slate-400">Resumen de unidades fisicas</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
            <div class="rounded-lg border border-slate-800 bg-slate-950 p-4">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Unidades listadas</p>
                <p class="mt-1 text-2xl font-black text-white">@Model.Unidades.Count</p>
            </div>
            @foreach (var resumen in Model.ResumenEstados)
            {
                <div class="rounded-lg border border-slate-800 bg-slate-950 p-4">
                    <p class="text-xs font-bold uppercase tracking-wider text-slate-500">@resumen.Estado</p>
                    <p class="mt-1 text-2xl font-black text-white">@resumen.Cantidad</p>
                </div>
            }
        </div>
    </section>

    <form method="get" asp-controller="Producto" asp-action="Unidades" asp-route-productoId="@Model.ProductoId"
          class="rounded-lg border border-slate-800 bg-slate-950/60 p-4">
        <div class="grid gap-3 lg:grid-cols-[1.2fr_1fr_auto] lg:items-end">
            <label class="block">
                <span class="text-xs font-bold uppercase tracking-wider text-slate-500">Codigo interno o serie</span>
                <input type="search" name="texto" value="@Model.Filtros.Texto"
                       class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white outline-none transition-colors focus:border-primary"
                       placeholder="Buscar unidad..." />
            </label>
            <label class="block">
                <span class="text-xs font-bold uppercase tracking-wider text-slate-500">Estado</span>
                <select name="estado" class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white outline-none transition-colors focus:border-primary">
                    <option value="">Todos</option>
                    @foreach (var estado in estados)
                    {
                        <option value="@estado" selected="@(Model.Filtros.Estado == estado)">@estado</option>
                    }
                </select>
            </label>
            <div class="flex flex-wrap gap-2">
                <button type="submit" class="inline-flex items-center gap-1.5 rounded-lg bg-primary px-4 py-2 text-sm font-bold text-white transition-colors hover:bg-primary/90">
                    <span class="material-symbols-outlined text-base">filter_alt</span>
                    Filtrar
                </button>
                <a asp-controller="Producto" asp-action="Unidades" asp-route-productoId="@Model.ProductoId"
                   class="inline-flex items-center gap-1.5 rounded-lg border border-slate-700 px-4 py-2 text-sm font-bold text-slate-300 transition-colors hover:bg-slate-800">
                    Limpiar
                </a>
            </div>
        </div>
        <div class="mt-3 flex flex-wrap gap-4 text-sm text-slate-300">
            <label class="inline-flex items-center gap-2">
                <input type="checkbox" name="soloDisponibles" value="true" checked="@Model.Filtros.SoloDisponibles" class="rounded border-slate-600 text-primary focus:ring-primary" />
                Solo disponibles
            </label>
            <label class="inline-flex items-center gap-2">
                <input type="checkbox" name="soloVendidas" value="true" checked="@Model.Filtros.SoloVendidas" class="rounded border-slate-600 text-primary focus:ring-primary" />
                Solo vendidas
            </label>
            <label class="inline-flex items-center gap-2">
                <input type="checkbox" name="soloSinNumeroSerie" value="true" checked="@Model.Filtros.SoloSinNumeroSerie" class="rounded border-slate-600 text-primary focus:ring-primary" />
                Sin numero de serie
            </label>
        </div>
    </form>

    <section id="listado-unidades" class="overflow-hidden rounded-lg border border-slate-800 bg-slate-950">
        <p class="px-4 pt-3 text-xs text-slate-500 lg:hidden" aria-hidden="true">Deslizá para ver más columnas →</p>
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-800">
                <thead class="bg-slate-900/70">
                    <tr>
                        <th scope="col" class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">Unidad</th>
                        <th scope="col" class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">Serie</th>
                        <th scope="col" class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">Estado</th>
                        <th scope="col" class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">Ubicacion</th>
                        <th scope="col" class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">Ingreso</th>
                        <th scope="col" class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">Cliente</th>
                        <th scope="col" class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">Venta</th>
                        <th scope="col" class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">Observaciones</th>
                        <th scope="col" class="px-4 py-3 text-right text-xs font-bold uppercase tracking-wider text-slate-400">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800">
                    @if (Model.Unidades.Any())
                    {
                        @foreach (var unidad in Model.Unidades)
                        {
                            <tr class="hover:bg-white/5">
                                <td class="px-4 py-3 font-mono text-sm text-white">@unidad.CodigoInternoUnidad</td>
                                <td class="px-4 py-3 text-sm text-slate-300">@(unidad.NumeroSerie ?? "-")</td>
                                <td class="px-4 py-3">
                                    <partial name="_EstadoUnidadBadge" model="unidad.Estado" />
                                </td>
                                <td class="px-4 py-3 text-sm text-slate-300">@(unidad.UbicacionActual ?? "-")</td>
                                <td class="px-4 py-3 text-sm text-slate-300">@unidad.FechaIngreso.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="px-4 py-3 text-sm text-slate-300">@(unidad.ClienteAsociado ?? "-")</td>
                                <td class="px-4 py-3 text-sm text-slate-300">
                                    @if (unidad.VentaDetalleId.HasValue)
                                    {
                                        <span>Detalle #@unidad.VentaDetalleId</span>
                                        @if (unidad.FechaVenta.HasValue)
                                        {
                                            <span class="block text-xs text-slate-500">@unidad.FechaVenta.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                        }
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                                <td class="max-w-xs px-4 py-3 text-sm text-slate-300">@(unidad.Observaciones ?? "-")</td>
                                <td class="px-4 py-3 text-right">
                                    <div class="flex min-w-[14rem] flex-col items-stretch gap-2">
                                        <a asp-controller="Producto" asp-action="UnidadHistorial" asp-route-unidadId="@unidad.Id"
                                           class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-slate-700 px-2.5 py-1.5 text-xs font-bold text-slate-200 transition-colors hover:bg-slate-800">
                                            <span class="material-symbols-outlined text-base">history</span>
                                            Ver historial
                                        </a>

                                        @if (unidad.PuedeMarcarFaltante || unidad.PuedeDarBaja || unidad.PuedeReintegrarAStock || unidad.PuedeFinalizarReparacion)
                                        {
                                            var modalAccionesId = $"acciones-unidad-{unidad.Id}";

                                            <button type="button"
                                                    onclick="document.getElementById('@modalAccionesId').showModal()"
                                                    class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-slate-700 px-2.5 py-1.5 text-xs font-bold text-slate-300 transition-colors hover:bg-slate-800 hover:text-white">
                                                <span class="material-symbols-outlined text-base">more_vert</span>
                                                Gestionar unidad
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="px-4 py-10 text-center text-sm text-slate-400">
                                No hay unidades fisicas para los filtros seleccionados.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    @foreach (var unidad in Model.Unidades)
    {
        @if (unidad.PuedeMarcarFaltante || unidad.PuedeDarBaja || unidad.PuedeReintegrarAStock || unidad.PuedeFinalizarReparacion)
        {
            var modalAccionesId = $"acciones-unidad-{unidad.Id}";
            var modalAccionesTituloId = $"acciones-unidad-titulo-{unidad.Id}";

            <dialog id="@modalAccionesId"
                    role="dialog"
                    aria-modal="true"
                    aria-labelledby="@modalAccionesTituloId"
                    class="w-[min(92vw,34rem)] rounded-lg border border-slate-700 bg-slate-950 p-0 text-left text-slate-200 shadow-2xl shadow-slate-950/70 backdrop:bg-slate-950/80">
                <div class="border-b border-slate-800 p-4">
                    <div class="flex items-start justify-between gap-3">
                        <div>
                            <p class="text-xs font-bold uppercase tracking-wider text-primary">Acciones operativas</p>
                            <h3 id="@modalAccionesTituloId" class="mt-1 text-lg font-black text-white">Unidad @unidad.CodigoInternoUnidad</h3>
                            <p class="mt-1 text-sm text-slate-400">Completa el motivo antes de aplicar un cambio de estado.</p>
                        </div>
                        <form method="dialog">
                            <button type="submit"
                                    class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-slate-700 text-slate-300 transition-colors hover:bg-slate-800 hover:text-white"
                                    aria-label="Cerrar acciones de unidad @unidad.CodigoInternoUnidad">
                                <span class="material-symbols-outlined text-base">close</span>
                            </button>
                        </form>
                    </div>
                </div>
                <div class="grid gap-3 p-4">
                    @if (unidad.PuedeMarcarFaltante)
                    {
                        <form method="post" asp-controller="Producto" asp-action="MarcarUnidadFaltante" class="grid gap-2 rounded-lg border border-amber-500/25 bg-amber-500/5 p-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ProductoUnidadId" value="@unidad.Id" />
                            <label for="motivo-faltante-@unidad.Id" class="sr-only">Motivo para marcar faltante</label>
                            <input id="motivo-faltante-@unidad.Id" name="Motivo" maxlength="500" required
                                   class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white outline-none transition-colors focus:border-primary"
                                   placeholder="Motivo obligatorio" />
                            <button type="submit" class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-amber-500/40 bg-amber-500/10 px-3 py-2 text-sm font-bold text-amber-200 transition-colors hover:bg-amber-500/20">
                                <span class="material-symbols-outlined text-base">inventory_2</span>
                                Marcar faltante
                            </button>
                        </form>
                    }

                    @if (unidad.PuedeReintegrarAStock)
                    {
                        <form method="post" asp-controller="Producto" asp-action="ReintegrarUnidadAStock" class="grid gap-2 rounded-lg border border-emerald-500/25 bg-emerald-500/5 p-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ProductoUnidadId" value="@unidad.Id" />
                            <label for="motivo-reintegrar-@unidad.Id" class="sr-only">Motivo para reintegrar a stock</label>
                            <input id="motivo-reintegrar-@unidad.Id" name="Motivo" maxlength="500" required
                                   class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white outline-none transition-colors focus:border-primary"
                                   placeholder="Motivo obligatorio" />
                            <button type="submit" class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-emerald-500/40 bg-emerald-500/10 px-3 py-2 text-sm font-bold text-emerald-200 transition-colors hover:bg-emerald-500/20">
                                <span class="material-symbols-outlined text-base">assignment_return</span>
                                Reintegrar a stock
                            </button>
                        </form>
                    }

                    @if (unidad.PuedeDarBaja)
                    {
                        <form method="post" asp-controller="Producto" asp-action="DarUnidadBaja" class="grid gap-2 rounded-lg border border-red-500/25 bg-red-500/5 p-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ProductoUnidadId" value="@unidad.Id" />
                            <label for="motivo-baja-@unidad.Id" class="sr-only">Motivo para dar de baja</label>
                            <input id="motivo-baja-@unidad.Id" name="Motivo" maxlength="500" required
                                   class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white outline-none transition-colors focus:border-primary"
                                   placeholder="Motivo obligatorio" />
                            <button type="submit" class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-red-500/40 bg-red-500/10 px-3 py-2 text-sm font-bold text-red-200 transition-colors hover:bg-red-500/20">
                                <span class="material-symbols-outlined text-base">block</span>
                                Dar de baja
                            </button>
                        </form>
                    }

                    @if (unidad.PuedeFinalizarReparacion)
                    {
                        <form method="post" asp-controller="Producto" asp-action="FinalizarReparacionUnidad" class="grid gap-2 rounded-lg border border-blue-500/25 bg-blue-500/5 p-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ProductoUnidadId" value="@unidad.Id" />
                            <select name="EstadoDestino" required
                                    class="w-full rounded-lg border border-blue-500/40 bg-slate-900 px-3 py-2 text-sm text-white outline-none transition-colors focus:border-blue-400">
                                <option value="">Destino de la reparacion...</option>
                                <option value="EnStock">Reintegrar a stock</option>
                                <option value="Baja">Dar de baja (no reparable)</option>
                                <option value="Devuelta">Marcar como devuelta</option>
                            </select>
                            <label for="motivo-reparacion-@unidad.Id" class="sr-only">Motivo para finalizar reparacion</label>
                            <input id="motivo-reparacion-@unidad.Id" name="Motivo" maxlength="500" required
                                   class="w-full rounded-lg border border-blue-500/40 bg-slate-900 px-3 py-2 text-sm text-white outline-none transition-colors focus:border-blue-400"
                                   placeholder="Motivo obligatorio" />
                            <button type="submit" class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-blue-500/40 bg-blue-500/10 px-3 py-2 text-sm font-bold text-blue-200 transition-colors hover:bg-blue-500/20">
                                <span class="material-symbols-outlined text-base">build_circle</span>
                                Finalizar reparacion
                            </button>
                        </form>
                    }
                </div>
            </dialog>
        }
    }
    </div>

    <div id="modo-carga" class="scroll-mt-32 space-y-4">
        <div class="flex flex-col gap-2 border-t border-slate-800 pt-4 md:flex-row md:items-end md:justify-between">
            <div>
                <p class="text-xs font-bold uppercase tracking-wider text-primary">Modo Carga</p>
                <h2 class="mt-1 text-lg font-black text-white">Alta individual y carga masiva</h2>
                <p class="mt-1 max-w-3xl text-sm text-slate-400">
                    Usa alta individual para una unidad puntual. Usa carga masiva cuando necesites crear varias unidades y revisar un preview antes de confirmar.
                </p>
            </div>
            <a href="#listado-unidades" class="inline-flex items-center gap-1.5 text-sm font-bold text-slate-300 transition-colors hover:text-white">
                <span class="material-symbols-outlined text-base">arrow_upward</span>
                Volver al listado
            </a>
        </div>

        <div class="grid gap-4 xl:grid-cols-[0.9fr_1.1fr]">
            <section class="rounded-lg border border-slate-800 bg-slate-950/60 p-4">
                <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
                    <div>
                        <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Alta individual</p>
                        <h2 class="mt-1 text-base font-black text-white">Crear una unidad puntual</h2>
                        <p class="mt-1 text-sm text-slate-400">Para registrar una unidad especifica. El codigo interno se genera automaticamente. El numero de serie es opcional. La unidad se creara en estado EnStock.</p>
                        <p class="mt-1 text-xs text-amber-200">Crear una unidad fisica no ajusta el stock agregado. El stock agregado sigue bajo MovimientoStockService.</p>
                    </div>
                    <span aria-hidden="true" class="inline-flex w-fit items-center gap-1.5 rounded border border-slate-800 bg-slate-900/60 px-2 py-0.5 text-xs font-bold text-slate-500">
                        <span class="material-symbols-outlined text-sm">looks_one</span>
                        Una unidad
                    </span>
                </div>

                <form method="post" asp-controller="Producto" asp-action="CrearUnidad" class="mt-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="CrearUnidad.ProductoId" value="@Model.ProductoId" />
                    <div asp-validation-summary="ModelOnly" class="mb-3 text-sm font-semibold text-red-300"></div>

                    <div class="grid gap-3 lg:grid-cols-[1fr_1fr_1.4fr_auto] xl:grid-cols-1">
                        <label class="block">
                            <span class="text-xs font-bold uppercase tracking-wider text-slate-500">Numero de serie</span>
                            <input asp-for="CrearUnidad.NumeroSerie" maxlength="100"
                                   class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white outline-none transition-colors focus:border-primary"
                                   placeholder="Opcional" />
                            <span asp-validation-for="CrearUnidad.NumeroSerie" class="mt-1 block text-xs font-semibold text-red-300"></span>
                        </label>
                        <label class="block">
                            <span class="text-xs font-bold uppercase tracking-wider text-slate-500">Ubicacion actual</span>
                            <input asp-for="CrearUnidad.UbicacionActual" maxlength="200"
                                   class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white outline-none transition-colors focus:border-primary"
                                   placeholder="Opcional" />
                            <span asp-validation-for="CrearUnidad.UbicacionActual" class="mt-1 block text-xs font-semibold text-red-300"></span>
                        </label>
                        <label class="block">
                            <span class="text-xs font-bold uppercase tracking-wider text-slate-500">Observaciones</span>
                            <input asp-for="CrearUnidad.Observaciones" maxlength="500"
                                   class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white outline-none transition-colors focus:border-primary"
                                   placeholder="Opcional" />
                            <span asp-validation-for="CrearUnidad.Observaciones" class="mt-1 block text-xs font-semibold text-red-300"></span>
                        </label>
                        <button type="submit" class="inline-flex min-h-[38px] items-center justify-center gap-1.5 rounded-lg bg-primary px-4 py-2 text-sm font-bold text-white transition-colors hover:bg-primary/90 lg:mt-5 xl:mt-0">
                            <span class="material-symbols-outlined text-base">add_circle</span>
                            Agregar unidad
                        </button>
                    </div>
                </form>
            </section>

            <section class="rounded-lg border border-slate-800 bg-slate-950/60 p-4">
                <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
                    <div>
                        <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Carga masiva</p>
                        <h2 class="mt-1 text-base font-black text-white">Carga masiva de unidades</h2>
                        <p class="mt-1 text-sm text-slate-400">Genera varias unidades sin serie o pega una serie por linea. Primero se muestra una previsualizacion para confirmar.</p>
                        <p class="mt-1 text-xs text-amber-200">La carga masiva no ajusta el stock agregado y no crea movimientos de stock SKU.</p>
                    </div>
                    <span aria-hidden="true" class="inline-flex w-fit items-center gap-1.5 rounded border border-slate-800 bg-slate-900/60 px-2 py-0.5 text-xs font-bold text-slate-500">
                        <span class="material-symbols-outlined text-sm">format_list_numbered</span>
                        Varias unidades
                    </span>
                </div>

                <form id="form-carga-masiva-unidades" method="post" asp-controller="Producto" asp-action="CrearUnidadesMasivas" class="mt-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="CargaMasiva.ProductoId" value="@Model.ProductoId" />

                    <div class="rounded-lg border border-slate-800 bg-slate-950 p-3">
                        <p class="text-xs font-bold uppercase tracking-wider text-primary">Paso 1</p>
                        <p class="mt-1 text-sm font-bold text-white">Preparar unidades para preview</p>
                        <div class="mt-3 grid gap-3 lg:grid-cols-[0.7fr_1.3fr_1fr_1.2fr]">
                            <label class="block">
                                <span class="text-xs font-bold uppercase tracking-wider text-slate-500">Cantidad sin serie</span>
                                <input asp-for="CargaMasiva.CantidadSinSerie" min="0" max="200" type="number"
                                       class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white outline-none transition-colors focus:border-primary" />
                                <span asp-validation-for="CargaMasiva.CantidadSinSerie" class="mt-1 block text-xs font-semibold text-red-300"></span>
                            </label>
                            <label class="block">
                                <span class="text-xs font-bold uppercase tracking-wider text-slate-500">Numeros de serie</span>
                                <textarea asp-for="CargaMasiva.NumerosSerieTexto" rows="5" maxlength="12000"
                                          class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white outline-none transition-colors focus:border-primary"
                                          placeholder="Una serie por linea"></textarea>
                                <span asp-validation-for="CargaMasiva.NumerosSerieTexto" class="mt-1 block text-xs font-semibold text-red-300"></span>
                            </label>
                            <label class="block">
                                <span class="text-xs font-bold uppercase tracking-wider text-slate-500">Ubicacion actual</span>
                                <input asp-for="CargaMasiva.UbicacionActual" maxlength="200"
                                       class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white outline-none transition-colors focus:border-primary"
                                       placeholder="Opcional" />
                                <span asp-validation-for="CargaMasiva.UbicacionActual" class="mt-1 block text-xs font-semibold text-red-300"></span>
                            </label>
                            <label class="block">
                                <span class="text-xs font-bold uppercase tracking-wider text-slate-500">Observaciones</span>
                                <textarea asp-for="CargaMasiva.Observaciones" rows="5" maxlength="500"
                                          class="mt-1 w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-white outline-none transition-colors focus:border-primary"
                                          placeholder="Opcional"></textarea>
                                <span asp-validation-for="CargaMasiva.Observaciones" class="mt-1 block text-xs font-semibold text-red-300"></span>
                            </label>
                        </div>
                    </div>

                    <div class="mt-4 rounded-lg border border-slate-800 bg-slate-950 p-3">
                        <p class="text-xs font-bold uppercase tracking-wider text-primary">Paso 2</p>
                        <p class="mt-1 text-sm font-bold text-white">Previsualizar y confirmar</p>
                        <p class="mt-1 text-xs text-slate-400">El boton Confirmar carga aparece solo cuando el preview esta listo y contiene unidades.</p>
                        <div class="mt-3 flex flex-wrap gap-2">
                            <button type="submit" name="CargaMasiva.Confirmar" value="false"
                                    class="inline-flex items-center gap-1.5 rounded-lg bg-primary px-4 py-2 text-sm font-bold text-white transition-colors hover:bg-primary/90">
                                <span class="material-symbols-outlined text-base">visibility</span>
                                Previsualizar
                            </button>
                            @if (Model.CargaMasiva.PreviewListo && Model.CargaMasiva.Preview.Any())
                            {
                                <button type="submit" name="CargaMasiva.Confirmar" value="true"
                                        class="inline-flex items-center gap-1.5 rounded-lg border border-emerald-500/40 bg-emerald-500/10 px-4 py-2 text-sm font-bold text-emerald-200 transition-colors hover:bg-emerald-500/20">
                                    <span class="material-symbols-outlined text-base">done_all</span>
                                    Confirmar carga
                                </button>
                            }
                        </div>
                    </div>

                    @if (Model.CargaMasiva.PreviewListo && Model.CargaMasiva.Preview.Any())
                    {
                        <div class="mt-4 overflow-hidden rounded-lg border border-emerald-500/30 bg-slate-950">
                            <div class="border-b border-slate-800 px-4 py-3">
                                <p class="text-xs font-bold uppercase tracking-wider text-emerald-300">Preview listo</p>
                                <p class="mt-1 text-sm font-bold text-white">Preview de carga: @Model.CargaMasiva.TotalUnidades unidades</p>
                                <p class="mt-1 text-xs text-slate-400">Todas se crearan en estado EnStock con codigo interno automatico.</p>
                            </div>
                            <div class="max-h-72 overflow-x-auto overflow-y-auto">
                                <table class="min-w-full divide-y divide-slate-800">
                                    <thead class="bg-slate-900/70">
                                        <tr>
                                            <th scope="col" class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">#</th>
                                            <th scope="col" class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">Serie</th>
                                            <th scope="col" class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-400">Estado inicial</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-800">
                                        @foreach (var item in Model.CargaMasiva.Preview)
                                        {
                                            <tr>
                                                <td class="px-4 py-2 text-sm text-slate-300">@item.Orden</td>
                                                <td class="px-4 py-2 text-sm text-slate-300">@(item.NumeroSerie ?? "Sin numero de serie")</td>
                                                <td class="px-4 py-2"><partial name="_EstadoUnidadBadge" model="(EstadoUnidad?)EstadoUnidad.EnStock" /></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </form>
            </section>
        </div>
    </div>

    <div id="modo-configuracion" class="scroll-mt-32 space-y-4">
        <div class="flex flex-col gap-2 border-t border-slate-800 pt-4 md:flex-row md:items-end md:justify-between">
            <div>
                <p class="text-xs font-bold uppercase tracking-wider text-primary">Modo Configuracion</p>
                <h2 class="mt-1 text-lg font-black text-white">Trazabilidad y reglas del producto</h2>
            </div>
            <a href="#modo-conciliacion" class="inline-flex items-center gap-1.5 text-sm font-bold text-slate-300 transition-colors hover:text-white">
                <span class="material-symbols-outlined text-base">fact_check</span>
                Revisar conciliacion
            </a>
        </div>

    <section class="rounded-lg border border-slate-800 bg-slate-950/60 p-5">
        @{
            var puedeDesactivar = Model.RequiereNumeroSerie && Model.Conciliacion.TotalUnidadesActivas == 0;
            var bloqueadaConUnidades = Model.RequiereNumeroSerie && Model.Conciliacion.TotalUnidadesActivas > 0;
        }
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h2 class="text-base font-black text-white">Trazabilidad individual</h2>
                <p class="mt-1 text-sm text-slate-400">
                    Controla si este producto exige selección de unidad física en cada venta.
                </p>
                @if (bloqueadaConUnidades)
                {
                    <p class="mt-2 text-xs text-amber-300">
                        Para desactivar, primero eliminá todas las unidades físicas registradas (@Model.Conciliacion.TotalUnidadesActivas unidad@(Model.Conciliacion.TotalUnidadesActivas != 1 ? "es" : "") activa@(Model.Conciliacion.TotalUnidadesActivas != 1 ? "s" : "")).
                    </p>
                }
            </div>
            <div class="flex flex-wrap items-center gap-3">
                @if (Model.RequiereNumeroSerie)
                {
                    <span class="inline-flex items-center gap-1.5 rounded-full border border-emerald-500/30 bg-emerald-500/10 px-3 py-1 text-sm font-bold text-emerald-300">
                        <span class="material-symbols-outlined text-base">verified</span>
                        Activada
                    </span>
                    @if (puedeDesactivar)
                    {
                        <form method="post" asp-controller="Producto" asp-action="DesactivarTrazabilidad" asp-route-productoId="@Model.ProductoId">
                            @Html.AntiForgeryToken()
                            <button type="submit"
                                    class="inline-flex items-center gap-1.5 rounded-lg border border-slate-600 px-3 py-1.5 text-sm font-bold text-slate-300 transition-colors hover:bg-slate-800">
                                <span class="material-symbols-outlined text-base">toggle_off</span>
                                Desactivar
                            </button>
                        </form>
                    }
                    else
                    {
                        <span class="inline-flex items-center gap-1.5 rounded-lg border border-slate-700 px-3 py-1.5 text-sm font-bold text-slate-500 cursor-not-allowed"
                              aria-disabled="true"
                              title="No se puede desactivar porque hay unidades físicas registradas">
                            <span class="material-symbols-outlined text-base">toggle_off</span>
                            Desactivar
                        </span>
                    }
                }
                else
                {
                    <span class="inline-flex items-center gap-1.5 rounded-full border border-slate-600 bg-slate-800 px-3 py-1 text-sm font-bold text-slate-400">
                        <span class="material-symbols-outlined text-base">remove_circle</span>
                        Desactivada
                    </span>
                    <form method="post" asp-controller="Producto" asp-action="ActivarTrazabilidad" asp-route-productoId="@Model.ProductoId">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                class="inline-flex items-center gap-1.5 rounded-lg border border-emerald-500/40 bg-emerald-500/10 px-3 py-1.5 text-sm font-bold text-emerald-200 transition-colors hover:bg-emerald-500/20">
                            <span class="material-symbols-outlined text-base">toggle_on</span>
                            Activar
                        </button>
                    </form>
                }
            </div>
        </div>
    </section>
    </div>

    <div id="modo-conciliacion" class="scroll-mt-32 space-y-4">
        <div class="flex flex-col gap-2 border-t border-slate-800 pt-4 md:flex-row md:items-end md:justify-between">
            <div>
                <p class="text-xs font-bold uppercase tracking-wider text-primary">Modo Conciliacion</p>
                <h2 class="mt-1 text-lg font-black text-white">Conciliacion de stock y unidades</h2>
                <p class="mt-1 max-w-3xl text-sm text-slate-400">
                    Compara el numero de stock del producto contra las unidades fisicas disponibles. Sirve para revisar desvios antes de tocar stock.
                </p>
            </div>
            <a href="#modo-unidades" class="inline-flex items-center gap-1.5 text-sm font-bold text-slate-300 transition-colors hover:text-white">
                <span class="material-symbols-outlined text-base">table_rows</span>
                Ver unidades
            </a>
        </div>

    <section class="rounded-lg border border-slate-800 bg-slate-950/60 p-5">
        <div class="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
            <div>
                <div class="flex flex-wrap items-center gap-2">
                    <h2 class="text-base font-black text-white">Conciliacion stock vs unidades fisicas</h2>
                    <span class="inline-flex items-center rounded-full border px-2 py-0.5 text-xs font-bold @diferenciaCss">
                        @(conciliacion.HayDiferencia ? "Diferencia detectada" : "Conciliado")
                    </span>
                </div>
                <p class="mt-2 max-w-4xl text-xs text-slate-400">
                    Compara stock agregado del SKU vs unidades fisicas en estado EnStock. Los ajustes modifican stock y actualizan Kardex.
                </p>
                @if (!conciliacion.RequiereNumeroSerie)
                {
                    <p class="mt-1 max-w-4xl text-xs text-amber-200">
                        Sin trazabilidad individual. Las unidades cargadas son solo trazabilidad operativa opcional.
                    </p>
                }
            </div>
            <div class="flex flex-wrap gap-2">
                <a href="#listado-unidades"
                   class="inline-flex items-center gap-1.5 text-sm font-bold text-slate-300 transition-colors hover:text-white">
                    <span class="material-symbols-outlined text-base">arrow_upward</span>
                    Volver al listado
                </a>
                @if (puedeAjustarStockAgregado)
                {
                    <a href="#ajuste-asistido"
                       class="inline-flex items-center gap-1.5 rounded-lg border border-amber-500/40 bg-amber-500/10 px-3 py-2 text-sm font-bold text-amber-200 transition-colors hover:bg-amber-500/20">
                        <span class="material-symbols-outlined text-base">tune</span>
                        Acciones de conciliacion
                    </a>
                }
                else if (!conciliacion.HayDiferencia)
                {
                    <span class="inline-flex items-center gap-1.5 rounded-lg border border-emerald-500/30 bg-emerald-500/10 px-3 py-2 text-sm font-bold text-emerald-200">
                        <span class="material-symbols-outlined text-base">check_circle</span>
                        Conciliado
                    </span>
                }
            </div>
        </div>

        <div class="mt-4 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
            <div class="rounded-lg border border-slate-800 bg-slate-950 p-4">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Stock agregado actual</p>
                <p class="mt-1 text-2xl font-black text-white">@conciliacion.StockActual.ToString("G29")</p>
                <p class="mt-1 text-xs text-slate-500">Valor numerico del producto.</p>
            </div>
            <div class="rounded-lg border border-slate-800 bg-slate-950 p-4">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Unidades fisicas disponibles</p>
                <p class="mt-1 text-2xl font-black text-white">@conciliacion.UnidadesEnStock</p>
                <p class="mt-1 text-xs text-slate-500">Unidades en estado EnStock.</p>
            </div>
            <div class="rounded-lg border @(conciliacion.HayDiferencia ? "border-amber-500/40 bg-amber-500/10" : "border-emerald-500/30 bg-emerald-500/10") p-4">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Diferencia</p>
                <p class="mt-1 text-2xl font-black @(conciliacion.HayDiferencia ? "text-amber-200" : "text-emerald-200")">@diferenciaTexto</p>
                <p class="mt-1 text-xs @(conciliacion.HayDiferencia ? "text-amber-200/70" : "text-emerald-200/70")">@estadoConciliacionTexto</p>
            </div>
            <div class="rounded-lg border border-slate-800 bg-slate-950 p-4">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Unidades registradas</p>
                <p class="mt-1 text-2xl font-black text-white">@conciliacion.TotalUnidadesRegistradas</p>
                <p class="mt-1 text-xs text-slate-500">Incluye estados no disponibles.</p>
            </div>
        </div>

        <div class="mt-3 rounded-lg border border-slate-800 bg-slate-950 px-4 py-3 text-sm text-slate-300">
            @if (diferenciaPositiva)
            {
                <p><strong class="text-amber-200">Con diferencia:</strong> el stock agregado es mayor que las unidades fisicas disponibles en estado EnStock. Puede representar stock sin identificar o stock agregado inflado. No se realizo ningun ajuste automatico.</p>
            }
            else if (diferenciaNegativa)
            {
                <p><strong class="text-amber-200">Requiere revision:</strong> hay mas unidades fisicas disponibles en estado EnStock que stock agregado. Conviene revisar el recuento antes de ajustar. No se realizo ningun ajuste automatico.</p>
            }
            else
            {
                <p><strong class="text-emerald-200">Conciliado:</strong> el stock agregado coincide con las unidades fisicas disponibles en estado EnStock. No se realizo ningun ajuste.</p>
            }
        </div>

        @if (hayDesgloseVisible)
        {
        <div class="mt-5 flex items-center gap-2 border-t border-slate-800 pt-4">
            <span class="material-symbols-outlined text-base text-slate-500">data_object</span>
            <h3 class="text-sm font-black text-slate-200">Desglose informativo de unidades registradas</h3>
        </div>
        <p class="mt-1 text-xs text-slate-500">
            Estos estados ayudan a explicar el desvio, pero no son el valor usado como unidades disponibles para conciliar.
        </p>

        <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6">
            <div class="rounded-lg border border-slate-800 bg-slate-950 p-3">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Vendidas</p>
                <p class="mt-1 text-xl font-black text-white">@conciliacion.UnidadesVendidas</p>
            </div>
            <div class="rounded-lg border border-slate-800 bg-slate-950 p-3">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Faltantes</p>
                <p class="mt-1 text-xl font-black text-white">@conciliacion.UnidadesFaltantes</p>
            </div>
            <div class="rounded-lg border border-slate-800 bg-slate-950 p-3">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Baja</p>
                <p class="mt-1 text-xl font-black text-white">@conciliacion.UnidadesBaja</p>
            </div>
            <div class="rounded-lg border border-slate-800 bg-slate-950 p-3">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Devueltas</p>
                <p class="mt-1 text-xl font-black text-white">@conciliacion.UnidadesDevueltas</p>
            </div>
            <div class="rounded-lg border border-slate-800 bg-slate-950 p-3">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Reservadas</p>
                <p class="mt-1 text-xl font-black text-white">@conciliacion.UnidadesReservadas</p>
            </div>
            <div class="rounded-lg border border-slate-800 bg-slate-950 p-3">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">En reparacion</p>
                <p class="mt-1 text-xl font-black text-white">@conciliacion.UnidadesEnReparacion</p>
            </div>
        </div>
        }

        <div class="mt-4 flex flex-wrap gap-x-6 gap-y-1 text-xs text-slate-500">
            <span>Ultimo movimiento stock: @(conciliacion.UltimoMovimientoStockFecha?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Sin movimientos")</span>
            <span>Ultimo movimiento unidad: @(conciliacion.UltimoMovimientoUnidadFecha?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Sin movimientos")</span>
        </div>

        @if (puedeAjustarStockAgregado)
        {
            <div id="ajuste-asistido" class="mt-5 rounded-lg border border-amber-500/30 bg-amber-500/10 p-4">
                <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                    <div>
                        <p class="text-xs font-bold uppercase tracking-wider text-amber-300">Accion sensible</p>
                        <h3 class="mt-1 text-base font-black text-amber-100">Ajuste asistido de stock agregado</h3>
                        <p class="mt-1 max-w-3xl text-sm text-amber-100/80">
                            Estas acciones modifican el stock agregado y actualizan Kardex. Cada accion recalcula la conciliacion en servidor antes de aplicar y no cambia estados de unidades fisicas.
                        </p>
                    </div>
                    <a href="#listado-unidades"
                       class="inline-flex shrink-0 items-center gap-1.5 rounded-lg border border-amber-500/30 px-3 py-2 text-sm font-bold text-amber-100 transition-colors hover:bg-amber-500/20">
                        <span class="material-symbols-outlined text-base">arrow_upward</span>
                        Revisar listado antes de ajustar
                    </a>
                </div>

                <div class="mt-3 grid gap-2 sm:grid-cols-2 lg:grid-cols-4 text-sm">
                    <div class="rounded border border-slate-700 bg-slate-950 p-3">
                        <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Stock agregado actual</p>
                        <p class="mt-1 font-black text-white">@conciliacion.StockActual.ToString("G29")</p>
                    </div>
                    <div class="rounded border border-slate-700 bg-slate-950 p-3">
                        <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Unidades disponibles</p>
                        <p class="mt-1 font-black text-white">@conciliacion.UnidadesEnStock</p>
                    </div>
                    <div class="rounded border border-amber-500/30 bg-amber-500/10 p-3">
                        <p class="text-xs font-bold uppercase tracking-wider text-amber-400">Ajuste requerido</p>
                        <p class="mt-1 font-black text-amber-200">@textoAjuste</p>
                    </div>
                    <div class="rounded border border-emerald-500/30 bg-emerald-500/10 p-3">
                        <p class="text-xs font-bold uppercase tracking-wider text-emerald-400">Resultado esperado</p>
                        <p class="mt-1 font-black text-emerald-200">@conciliacion.UnidadesEnStock</p>
                    </div>
                </div>

                @if (diferenciaNegativa)
                {
                    <div class="mt-4 rounded-lg border border-red-500/30 bg-red-500/10 p-3 text-sm text-red-100">
                        Hay unidades fisicas disponibles sin stock agregado suficiente. Si el recuento confirma esas unidades, ajustar hacia arriba libera el stock agregado usando MovimientoStock.
                    </div>
                    <form method="post" asp-controller="Producto" asp-action="AjustarStockAgregadoAUnidadesFisicas" class="mt-4">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="ProductoId" value="@conciliacion.ProductoId" />
                        <div class="flex flex-col gap-2 sm:flex-row sm:items-end">
                            <label class="block flex-1">
                                <span class="text-xs font-bold uppercase tracking-wider text-amber-400">Motivo obligatorio</span>
                                <input name="Motivo" maxlength="500" required
                                       class="mt-1 w-full rounded-lg border border-amber-500/40 bg-slate-950 px-3 py-2 text-sm text-white outline-none transition-colors focus:border-amber-400"
                                       placeholder="Ej: Recuento fisico confirma unidades disponibles" />
                            </label>
                            <button type="submit"
                                    class="inline-flex shrink-0 items-center gap-1.5 rounded-lg border border-amber-500/40 bg-amber-500/10 px-4 py-2 text-sm font-bold text-amber-200 transition-colors hover:bg-amber-500/20">
                                <span class="material-symbols-outlined text-base">add_task</span>
                                Ajustar stock agregado a unidades fisicas
                            </button>
                        </div>
                    </form>
                }
                else if (diferenciaPositiva)
                {
                    <div class="mt-4 grid gap-3 lg:grid-cols-3">
                        <div class="rounded-lg border border-slate-700 bg-slate-950 p-3">
                            <p class="text-sm font-bold text-white">Dejar stock sin identificar</p>
                            <p class="mt-1 text-xs text-slate-400">No genera cambios. Mantiene el desvio visible para revision posterior.</p>
                        </div>
                        <a href="#form-carga-masiva-unidades"
                           class="rounded-lg border border-emerald-500/30 bg-emerald-500/10 p-3 text-sm font-bold text-emerald-200 transition-colors hover:bg-emerald-500/20">
                            Crear unidades fisicas faltantes
                            <span class="mt-1 block text-xs font-medium text-emerald-200/70">Usa alta/carga masiva. No modifica StockActual.</span>
                        </a>
                        <form method="post" asp-controller="Producto" asp-action="AjustarStockAgregadoHaciaAbajo" class="rounded-lg border border-amber-500/30 bg-slate-950 p-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ProductoId" value="@conciliacion.ProductoId" />
                            <p class="mb-2 text-xs text-amber-200/70">Reduce stock agregado/sin identificar mediante MovimientoStock.</p>
                            <label class="block">
                                <span class="text-xs font-bold uppercase tracking-wider text-amber-400">Motivo obligatorio</span>
                                <input name="Motivo" maxlength="500" required
                                       class="mt-1 w-full rounded-lg border border-amber-500/40 bg-slate-900 px-3 py-2 text-sm text-white outline-none transition-colors focus:border-amber-400"
                                       placeholder="Ej: Recuento confirma stock agregado inflado" />
                            </label>
                            <button type="submit"
                                    class="mt-2 inline-flex w-full items-center justify-center gap-1.5 rounded-lg border border-amber-500/40 bg-amber-500/10 px-3 py-2 text-sm font-bold text-amber-200 transition-colors hover:bg-amber-500/20">
                                <span class="material-symbols-outlined text-base">remove_circle</span>
                                Ajustar stock agregado hacia abajo
                            </button>
                        </form>
                    </div>
                }
            </div>
        }
    </section>
    </div>
</div>
