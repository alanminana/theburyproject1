@model ProductoUnidadesGlobalViewModel
@{
    ViewData["Title"] = "Inventario global";
    var resumen = Model.Resumen;
    var filtros = Model.Filtros;
}

@section Styles {
    <style>
        /* invg- = inventario global integrado (tabs Unidades + Movimientos) */
        .invg-tabs { display: none; gap: .25rem; border-bottom: 1px solid #1e293b; }
        .invg-js .invg-tabs { display: flex; flex-wrap: wrap; }
        .invg-tab {
            display: inline-flex; align-items: center; gap: .4rem;
            padding: .6rem .95rem; font-size: .875rem; font-weight: 600; color: #94a3b8;
            background: transparent; border: 0; border-bottom: 2px solid transparent;
            cursor: pointer; border-radius: 6px 6px 0 0; white-space: nowrap;
        }
        .invg-tab .material-symbols-outlined { font-size: 18px; }
        .invg-tab:hover { color: #f1f5f9; background: rgba(148,163,184,.06); }
        .invg-tab[aria-selected="true"] { color: #fff; border-bottom-color: #f5c518; }
        .invg-tab:focus-visible { outline: 2px solid #f5c518; outline-offset: 2px; }
        .invg-mov-table { width: 100%; border-collapse: separate; border-spacing: 0; font-size: .85rem; }
        .invg-mov-table thead th {
            background: #0d1526; color: #64748b; font-size: .68rem; text-transform: uppercase;
            letter-spacing: .04em; text-align: left; padding: .7rem 1rem; border-bottom: 1px solid #1e293b; white-space: nowrap;
        }
        .invg-td { padding: .6rem 1rem; border-bottom: 1px solid rgba(30,41,59,.6); color: #cbd5e1; vertical-align: top; }
        .invg-strong { color: #e2e8f0; font-weight: 600; }
        .invg-sub { color: #64748b; font-size: .75rem; }
        .invg-mono { font-family: ui-monospace, monospace; }
        .invg-mov-state { padding: 2rem 1rem; text-align: center; color: #64748b; }
        .invg-mov-error { color: #fda4af; }
        .invg-chip {
            display: inline-flex; align-items: center; gap: .3rem; padding: .18rem .5rem;
            border-radius: 999px; font-size: .72rem; font-weight: 600; border: 1px solid transparent; white-space: nowrap;
        }
        .invg-chip-in { background: rgba(16,185,129,.1); color: #34d399; border-color: rgba(16,185,129,.28); }
        .invg-chip-out { background: rgba(248,113,113,.1); color: #f87171; border-color: rgba(248,113,113,.28); }
        .invg-chip-adj { background: rgba(245,158,11,.1); color: #fbbf24; border-color: rgba(245,158,11,.28); }
        .invg-chip-neutral { background: #1e293b; color: #e2e8f0; border-color: #334155; }
    </style>
}

<div class="erp-page-shell erp-page-shell-xl space-y-6" data-invg-root>

    @if (TempData["Success"] != null)
    {
        <div class="rounded-lg border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-sm font-semibold text-emerald-200">
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm font-semibold text-red-200">
            @TempData["Error"]
        </div>
    }

    <!-- Header -->
    <section class="rounded-lg border border-slate-800 bg-slate-950/60 p-5">
        <div class="erp-page-header">
            <div class="erp-page-header-main">
                <a asp-controller="Catalogo" asp-action="Index"
                   class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-400 transition-colors hover:text-white">
                    <span class="material-symbols-outlined text-base">arrow_back</span>
                    Volver al Catálogo
                </a>
                <h1 class="erp-page-title mt-3">Inventario global</h1>
                <p class="erp-page-subtitle">
                    Reúne las unidades físicas individuales y su estado operativo. Los movimientos de stock se consultan desde el historial general.
                </p>
            </div>
            <div class="erp-page-actions">
                <a asp-controller="MovimientoStock" asp-action="Index"
                   class="btn-erp-secondary btn-sm w-full sm:w-auto">
                    <span class="material-symbols-outlined text-sm">swap_vert</span>
                    Movimientos de inventario
                </a>
            </div>
        </div>
    </section>

    <!-- Tabs: experiencia integrada (solo con JS; sin JS se ve Unidades + link a Movimientos) -->
    <div class="invg-tabs" role="tablist" aria-label="Secciones de inventario">
        <button type="button" class="invg-tab" role="tab" data-invg-tab="unidades" aria-selected="true">
            <span class="material-symbols-outlined">inventory_2</span>Unidades físicas
        </button>
        <button type="button" class="invg-tab" role="tab" data-invg-tab="movimientos" aria-selected="false">
            <span class="material-symbols-outlined">swap_vert</span>Movimientos
        </button>
    </div>

    <!-- ===================== Panel: Unidades físicas ===================== -->
    <div data-invg-panel="unidades" class="space-y-6">

    <!-- KPIs / Resumen -->
    <section class="rounded-lg border border-slate-800 bg-slate-950/60 p-5">
        <h2 class="mb-4 text-sm font-bold uppercase tracking-widest text-slate-500">Resumen</h2>
        <div class="erp-kpi-grid">
            <div class="rounded-lg border border-slate-800 bg-slate-900/60 p-4 text-center">
                <p class="text-2xl font-black text-white">@resumen.TotalUnidades</p>
                <p class="mt-1 text-xs font-semibold text-slate-400">Total registradas</p>
            </div>
            <div class="rounded-lg border border-emerald-500/20 bg-emerald-500/5 p-4 text-center">
                <p class="text-2xl font-black text-emerald-300">@resumen.TotalEnStock</p>
                <p class="mt-1 text-xs font-semibold text-slate-400">En stock</p>
            </div>
            <div class="rounded-lg border border-sky-500/20 bg-sky-500/5 p-4 text-center">
                <p class="text-2xl font-black text-sky-300">@resumen.TotalVendidas</p>
                <p class="mt-1 text-xs font-semibold text-slate-400">Vendidas</p>
            </div>
            <div class="rounded-lg border border-red-500/20 bg-red-500/5 p-4 text-center">
                <p class="text-2xl font-black text-red-300">@resumen.TotalFaltantes</p>
                <p class="mt-1 text-xs font-semibold text-slate-400">Faltantes</p>
            </div>
            <div class="rounded-lg border border-slate-700/40 bg-slate-800/30 p-4 text-center">
                <p class="text-2xl font-black text-slate-400">@resumen.TotalBaja</p>
                <p class="mt-1 text-xs font-semibold text-slate-400">Baja</p>
            </div>
            @if (resumen.TotalDevueltas > 0)
            {
                <div class="rounded-lg border border-amber-500/20 bg-amber-500/5 p-4 text-center">
                    <p class="text-2xl font-black text-amber-300">@resumen.TotalDevueltas</p>
                    <p class="mt-1 text-xs font-semibold text-slate-400">Devueltas</p>
                </div>
            }
            @if (resumen.TotalEnReparacion > 0)
            {
                <div class="rounded-lg border border-purple-500/20 bg-purple-500/5 p-4 text-center">
                    <p class="text-2xl font-black text-purple-300">@resumen.TotalEnReparacion</p>
                    <p class="mt-1 text-xs font-semibold text-slate-400">En reparación</p>
                </div>
            }
            @if (resumen.TotalAnuladas > 0)
            {
                <div class="rounded-lg border border-slate-600/20 bg-slate-600/5 p-4 text-center">
                    <p class="text-2xl font-black text-slate-400">@resumen.TotalAnuladas</p>
                    <p class="mt-1 text-xs font-semibold text-slate-400">Anuladas</p>
                </div>
            }
            @if (resumen.TotalReservadas > 0)
            {
                <div class="rounded-lg border border-orange-500/20 bg-orange-500/5 p-4 text-center">
                    <p class="text-2xl font-black text-orange-300">@resumen.TotalReservadas</p>
                    <p class="mt-1 text-xs font-semibold text-slate-400">Reservadas</p>
                </div>
            }
        </div>
    </section>

    <!-- Filtros -->
    <section class="rounded-lg border border-slate-800 bg-slate-950/60 p-5">
        <h2 class="mb-4 text-sm font-bold uppercase tracking-widest text-slate-500">Filtros</h2>
        <form method="get" asp-controller="Producto" asp-action="UnidadesGlobal" class="space-y-4">
            <div class="erp-filter-grid">
                <div>
                    <label for="filtro-producto" class="mb-1 block text-xs font-bold text-slate-400">Producto</label>
                    <select id="filtro-producto" name="productoId" class="input-erp w-full">
                        <option value="">— Todos los productos —</option>
                        @foreach (SelectListItem item in ViewBag.ProductosDropdown)
                        {
                            <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                        }
                    </select>
                </div>
                <div>
                    <label for="filtro-estado" class="mb-1 block text-xs font-bold text-slate-400">Estado</label>
                    <select id="filtro-estado" name="estado" class="input-erp w-full">
                        <option value="">— Todos los estados —</option>
                        @foreach (SelectListItem item in ViewBag.EstadosDropdown)
                        {
                            <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                        }
                    </select>
                </div>
                <div>
                    <label for="filtro-texto" class="mb-1 block text-xs font-bold text-slate-400">Buscar</label>
                    <input id="filtro-texto" type="text" name="texto" value="@filtros.Texto"
                           placeholder="Código, serie, nombre de producto…"
                           class="input-erp w-full" />
                </div>
            </div>

            <div class="flex flex-wrap gap-4">
                <label class="inline-flex cursor-pointer items-center gap-2 text-sm font-semibold text-slate-300">
                    <input type="checkbox" name="soloDisponibles" value="true" @(filtros.SoloDisponibles ? "checked" : "")
                           class="rounded border-slate-600 bg-slate-800 text-primary" />
                    Solo disponibles
                </label>
                <label class="inline-flex cursor-pointer items-center gap-2 text-sm font-semibold text-slate-300">
                    <input type="checkbox" name="soloVendidas" value="true" @(filtros.SoloVendidas ? "checked" : "")
                           class="rounded border-slate-600 bg-slate-800 text-primary" />
                    Solo vendidas
                </label>
                <label class="inline-flex cursor-pointer items-center gap-2 text-sm font-semibold text-slate-300">
                    <input type="checkbox" name="soloFaltantes" value="true" @(filtros.SoloFaltantes ? "checked" : "")
                           class="rounded border-slate-600 bg-slate-800 text-primary" />
                    Solo faltantes
                </label>
                <label class="inline-flex cursor-pointer items-center gap-2 text-sm font-semibold text-slate-300">
                    <input type="checkbox" name="soloBaja" value="true" @(filtros.SoloBaja ? "checked" : "")
                           class="rounded border-slate-600 bg-slate-800 text-primary" />
                    Solo baja
                </label>
                <label class="inline-flex cursor-pointer items-center gap-2 text-sm font-semibold text-slate-300">
                    <input type="checkbox" name="soloDevueltas" value="true" @(filtros.SoloDevueltas ? "checked" : "")
                           class="rounded border-slate-600 bg-slate-800 text-primary" />
                    Solo devueltas
                </label>
                <label class="inline-flex cursor-pointer items-center gap-2 text-sm font-semibold text-slate-300">
                    <input type="checkbox" name="soloSinNumeroSerie" value="true" @(filtros.SoloSinNumeroSerie ? "checked" : "")
                           class="rounded border-slate-600 bg-slate-800 text-primary" />
                    Sin número de serie
                </label>
            </div>

            <div class="erp-filter-actions">
                <button type="submit" class="btn-erp-primary btn-sm">
                    <span class="material-symbols-outlined text-sm">search</span>
                    Filtrar
                </button>
                <a asp-controller="Producto" asp-action="UnidadesGlobal"
                   class="btn-erp-ghost btn-sm">
                    Limpiar
                </a>
            </div>
        </form>
    </section>

    <!-- Tabla de resultados -->
    <section class="rounded-lg border border-slate-800 bg-slate-950/60">
        <div class="flex items-center justify-between border-b border-slate-800 px-5 py-4">
            <h2 class="text-sm font-bold text-slate-300">
                Unidades físicas
                <span class="ml-2 text-xs font-normal text-slate-500">@Model.Items.Count resultado@(Model.Items.Count != 1 ? "s" : "")</span>
            </h2>
        </div>

        @if (!Model.Items.Any())
        {
            <div class="erp-empty-state">
                <span class="material-symbols-outlined">inventory_2</span>
                <p class="erp-empty-state__title">No se encontraron unidades con los filtros actuales.</p>
                <a asp-controller="Producto" asp-action="UnidadesGlobal" class="text-xs font-bold text-primary hover:underline">
                    Limpiar filtros
                </a>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="erp-table">
                    <thead>
                        <tr class="border-b border-slate-800 bg-slate-900/40 text-left text-xs font-bold uppercase tracking-wider text-slate-500">
                            <th scope="col" class="px-4 py-3">Producto</th>
                            <th scope="col" class="px-4 py-3">Código interno</th>
                            <th scope="col" class="px-4 py-3">N° serie</th>
                            <th scope="col" class="px-4 py-3">Estado</th>
                            <th scope="col" class="px-4 py-3">Ubicación</th>
                            <th scope="col" class="px-4 py-3">Cliente</th>
                            <th scope="col" class="px-4 py-3">Fecha venta</th>
                            <th scope="col" class="px-4 py-3">Ingreso</th>
                            <th scope="col" class="px-4 py-3 text-right">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-800/60">
                        @foreach (var item in Model.Items)
                        {
                            <tr class="hover:bg-slate-800/30 transition-colors">
                                <td class="px-4 py-3">
                                    <a asp-controller="Producto" asp-action="Unidades"
                                       asp-route-productoId="@item.ProductoId"
                                       class="font-semibold text-slate-200 hover:text-white hover:underline">
                                        @item.ProductoNombre
                                    </a>
                                    <div class="mt-0.5 font-mono text-xs text-slate-500">@item.ProductoCodigo</div>
                                </td>
                                <td class="px-4 py-3 font-mono text-xs text-slate-300">
                                    @item.CodigoInternoUnidad
                                </td>
                                <td class="px-4 py-3 font-mono text-xs text-slate-400">
                                    @(item.NumeroSerie ?? "—")
                                </td>
                                <td class="px-4 py-3">
                                    <partial name="_EstadoUnidadBadge" model="item.Estado" />
                                </td>
                                <td class="px-4 py-3 text-xs text-slate-400">
                                    @(item.UbicacionActual ?? "—")
                                </td>
                                <td class="px-4 py-3 text-xs text-slate-400">
                                    @(item.ClienteNombre ?? "—")
                                </td>
                                <td class="px-4 py-3 text-xs text-slate-400">
                                    @(item.FechaVenta.HasValue
                                        ? item.FechaVenta.Value.ToLocalTime().ToString("dd/MM/yyyy")
                                        : "—")
                                </td>
                                <td class="px-4 py-3 text-xs text-slate-400">
                                    @item.FechaIngreso.ToLocalTime().ToString("dd/MM/yyyy")
                                </td>
                                <td class="px-4 py-3">
                                    <div class="flex items-center justify-end gap-2">
                                        <a asp-controller="Producto" asp-action="UnidadHistorial"
                                           asp-route-unidadId="@item.Id"
                                           class="inline-flex items-center gap-1 rounded px-2 py-1 text-xs font-bold text-slate-400 transition-colors hover:bg-slate-800 hover:text-white"
                                           title="Ver historial de movimientos">
                                            <span class="material-symbols-outlined text-sm">history</span>
                                            Historial
                                        </a>
                                        <a asp-controller="Producto" asp-action="Unidades"
                                           asp-route-productoId="@item.ProductoId"
                                           class="inline-flex items-center gap-1 rounded px-2 py-1 text-xs font-bold text-slate-400 transition-colors hover:bg-slate-800 hover:text-white"
                                           title="Ver unidades del producto">
                                            <span class="material-symbols-outlined text-sm">inventory_2</span>
                                            Producto
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="border-t border-slate-800 px-5 py-3">
                <p class="text-xs text-slate-600">
                    Este reporte muestra unidades físicas individuales. No reemplaza el stock agregado ni el Kardex SKU.
                </p>
            </div>
        }
    </section>

    </div><!-- /panel unidades -->

    <!-- ===================== Panel: Movimientos ===================== -->
    <div data-invg-panel="movimientos" class="space-y-4" hidden>
        <section class="rounded-lg border border-slate-800 bg-slate-950/60">
            <div class="flex flex-col gap-2 border-b border-slate-800 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <h2 class="text-sm font-bold text-slate-300">Movimientos de inventario</h2>
                    <p id="invg-mov-summary" class="mt-0.5 text-xs text-slate-500">Cargá la pestaña para ver los movimientos recientes.</p>
                </div>
                <a asp-controller="MovimientoStock" asp-action="Index"
                   class="btn-erp-secondary btn-sm w-full sm:w-auto">
                    <span class="material-symbols-outlined text-sm">open_in_new</span>
                    Historial completo
                </a>
            </div>
            <div class="overflow-x-auto">
                <table class="invg-mov-table">
                    <thead>
                        <tr>
                            <th scope="col">Fecha</th>
                            <th scope="col">Tipo</th>
                            <th scope="col">Producto</th>
                            <th scope="col">Cantidad</th>
                            <th scope="col">Stock</th>
                            <th scope="col">Usuario</th>
                            <th scope="col">Referencia</th>
                        </tr>
                    </thead>
                    <tbody id="invg-mov-body">
                        <tr><td colspan="7" class="invg-mov-state">Cargando movimientos…</td></tr>
                    </tbody>
                </table>
            </div>
        </section>
    </div><!-- /panel movimientos -->

</div>

@section Scripts {
    <script src="~/js/inventario-global.js" asp-append-version="true"></script>
}
