@model ProductoUnidadesGlobalViewModel
@using TheBuryProject.Models.Enums
@{
    ViewData["Title"] = "Inventario físico de unidades";
    var resumen = Model.Resumen;
    var filtros = Model.Filtros;

    string BadgeCss(EstadoUnidad e) => e switch
    {
        EstadoUnidad.EnStock      => "border-emerald-500/30 bg-emerald-500/10 text-emerald-300",
        EstadoUnidad.Vendida      => "border-sky-500/30 bg-sky-500/10 text-sky-300",
        EstadoUnidad.Entregada    => "border-blue-500/30 bg-blue-500/10 text-blue-300",
        EstadoUnidad.Devuelta     => "border-amber-500/30 bg-amber-500/10 text-amber-300",
        EstadoUnidad.EnReparacion => "border-purple-500/30 bg-purple-500/10 text-purple-300",
        EstadoUnidad.Faltante     => "border-red-500/30 bg-red-500/10 text-red-300",
        EstadoUnidad.Baja         => "border-slate-600/30 bg-slate-600/10 text-slate-400",
        EstadoUnidad.Anulada      => "border-slate-600/30 bg-slate-600/10 text-slate-400",
        EstadoUnidad.Reservada    => "border-orange-500/30 bg-orange-500/10 text-orange-300",
        _                         => "border-slate-600/30 bg-slate-600/10 text-slate-400"
    };

    string EstadoLabel(EstadoUnidad e) => e switch
    {
        EstadoUnidad.EnStock      => "En stock",
        EstadoUnidad.Vendida      => "Vendida",
        EstadoUnidad.Entregada    => "Entregada",
        EstadoUnidad.Devuelta     => "Devuelta",
        EstadoUnidad.EnReparacion => "En reparación",
        EstadoUnidad.Faltante     => "Faltante",
        EstadoUnidad.Baja         => "Baja",
        EstadoUnidad.Anulada      => "Anulada",
        EstadoUnidad.Reservada    => "Reservada",
        _                         => e.ToString()
    };
}

<div class="space-y-6">

    @if (TempData["Success"] != null)
    {
        <div class="rounded-lg border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-sm font-semibold text-emerald-200">
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm font-semibold text-red-200">
            @TempData["Error"]
        </div>
    }

    <!-- Header -->
    <section class="rounded-lg border border-slate-800 bg-slate-950/60 p-5">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div>
                <a asp-controller="Catalogo" asp-action="Index"
                   class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-400 transition-colors hover:text-white">
                    <span class="material-symbols-outlined text-base">arrow_back</span>
                    Volver al Catálogo
                </a>
                <h1 class="mt-3 text-2xl font-black text-white">Inventario físico de unidades</h1>
                <p class="mt-1 text-sm text-slate-400">
                    Reporte global de unidades individuales. No reemplaza el stock agregado ni el Kardex SKU.
                </p>
            </div>
        </div>
    </section>

    <!-- KPIs / Resumen -->
    <section class="rounded-lg border border-slate-800 bg-slate-950/60 p-5">
        <h2 class="mb-4 text-sm font-bold uppercase tracking-widest text-slate-500">Resumen</h2>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5">
            <div class="rounded-lg border border-slate-800 bg-slate-900/60 p-4 text-center">
                <p class="text-2xl font-black text-white">@resumen.TotalUnidades</p>
                <p class="mt-1 text-xs font-semibold text-slate-400">Total registradas</p>
            </div>
            <div class="rounded-lg border border-emerald-500/20 bg-emerald-500/5 p-4 text-center">
                <p class="text-2xl font-black text-emerald-300">@resumen.TotalEnStock</p>
                <p class="mt-1 text-xs font-semibold text-slate-400">En stock</p>
            </div>
            <div class="rounded-lg border border-sky-500/20 bg-sky-500/5 p-4 text-center">
                <p class="text-2xl font-black text-sky-300">@resumen.TotalVendidas</p>
                <p class="mt-1 text-xs font-semibold text-slate-400">Vendidas</p>
            </div>
            <div class="rounded-lg border border-red-500/20 bg-red-500/5 p-4 text-center">
                <p class="text-2xl font-black text-red-300">@resumen.TotalFaltantes</p>
                <p class="mt-1 text-xs font-semibold text-slate-400">Faltantes</p>
            </div>
            <div class="rounded-lg border border-slate-700/40 bg-slate-800/30 p-4 text-center">
                <p class="text-2xl font-black text-slate-400">@resumen.TotalBaja</p>
                <p class="mt-1 text-xs font-semibold text-slate-400">Baja</p>
            </div>
            @if (resumen.TotalDevueltas > 0)
            {
                <div class="rounded-lg border border-amber-500/20 bg-amber-500/5 p-4 text-center">
                    <p class="text-2xl font-black text-amber-300">@resumen.TotalDevueltas</p>
                    <p class="mt-1 text-xs font-semibold text-slate-400">Devueltas</p>
                </div>
            }
            @if (resumen.TotalEnReparacion > 0)
            {
                <div class="rounded-lg border border-purple-500/20 bg-purple-500/5 p-4 text-center">
                    <p class="text-2xl font-black text-purple-300">@resumen.TotalEnReparacion</p>
                    <p class="mt-1 text-xs font-semibold text-slate-400">En reparación</p>
                </div>
            }
            @if (resumen.TotalAnuladas > 0)
            {
                <div class="rounded-lg border border-slate-600/20 bg-slate-600/5 p-4 text-center">
                    <p class="text-2xl font-black text-slate-400">@resumen.TotalAnuladas</p>
                    <p class="mt-1 text-xs font-semibold text-slate-400">Anuladas</p>
                </div>
            }
            @if (resumen.TotalReservadas > 0)
            {
                <div class="rounded-lg border border-orange-500/20 bg-orange-500/5 p-4 text-center">
                    <p class="text-2xl font-black text-orange-300">@resumen.TotalReservadas</p>
                    <p class="mt-1 text-xs font-semibold text-slate-400">Reservadas</p>
                </div>
            }
        </div>
    </section>

    <!-- Filtros -->
    <section class="rounded-lg border border-slate-800 bg-slate-950/60 p-5">
        <h2 class="mb-4 text-sm font-bold uppercase tracking-widest text-slate-500">Filtros</h2>
        <form method="get" asp-controller="Producto" asp-action="UnidadesGlobal" class="space-y-4">
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
                <div>
                    <label class="mb-1 block text-xs font-bold text-slate-400">Producto</label>
                    <select name="productoId" class="input-erp w-full">
                        <option value="">— Todos los productos —</option>
                        @foreach (SelectListItem item in ViewBag.ProductosDropdown)
                        {
                            <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="mb-1 block text-xs font-bold text-slate-400">Estado</label>
                    <select name="estado" class="input-erp w-full">
                        <option value="">— Todos los estados —</option>
                        @foreach (SelectListItem item in ViewBag.EstadosDropdown)
                        {
                            <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="mb-1 block text-xs font-bold text-slate-400">Buscar</label>
                    <input type="text" name="texto" value="@filtros.Texto"
                           placeholder="Código, serie, nombre de producto…"
                           class="input-erp w-full" />
                </div>
            </div>

            <div class="flex flex-wrap gap-4">
                <label class="inline-flex cursor-pointer items-center gap-2 text-sm font-semibold text-slate-300">
                    <input type="checkbox" name="soloDisponibles" value="true" @(filtros.SoloDisponibles ? "checked" : "")
                           class="rounded border-slate-600 bg-slate-800 text-primary" />
                    Solo disponibles
                </label>
                <label class="inline-flex cursor-pointer items-center gap-2 text-sm font-semibold text-slate-300">
                    <input type="checkbox" name="soloVendidas" value="true" @(filtros.SoloVendidas ? "checked" : "")
                           class="rounded border-slate-600 bg-slate-800 text-primary" />
                    Solo vendidas
                </label>
                <label class="inline-flex cursor-pointer items-center gap-2 text-sm font-semibold text-slate-300">
                    <input type="checkbox" name="soloFaltantes" value="true" @(filtros.SoloFaltantes ? "checked" : "")
                           class="rounded border-slate-600 bg-slate-800 text-primary" />
                    Solo faltantes
                </label>
                <label class="inline-flex cursor-pointer items-center gap-2 text-sm font-semibold text-slate-300">
                    <input type="checkbox" name="soloBaja" value="true" @(filtros.SoloBaja ? "checked" : "")
                           class="rounded border-slate-600 bg-slate-800 text-primary" />
                    Solo baja
                </label>
                <label class="inline-flex cursor-pointer items-center gap-2 text-sm font-semibold text-slate-300">
                    <input type="checkbox" name="soloDevueltas" value="true" @(filtros.SoloDevueltas ? "checked" : "")
                           class="rounded border-slate-600 bg-slate-800 text-primary" />
                    Solo devueltas
                </label>
                <label class="inline-flex cursor-pointer items-center gap-2 text-sm font-semibold text-slate-300">
                    <input type="checkbox" name="soloSinNumeroSerie" value="true" @(filtros.SoloSinNumeroSerie ? "checked" : "")
                           class="rounded border-slate-600 bg-slate-800 text-primary" />
                    Sin número de serie
                </label>
            </div>

            <div class="flex gap-2">
                <button type="submit" class="btn-erp-primary btn-sm">
                    <span class="material-symbols-outlined text-sm">search</span>
                    Filtrar
                </button>
                <a asp-controller="Producto" asp-action="UnidadesGlobal"
                   class="btn-erp-ghost btn-sm">
                    Limpiar
                </a>
            </div>
        </form>
    </section>

    <!-- Tabla de resultados -->
    <section class="rounded-lg border border-slate-800 bg-slate-950/60">
        <div class="flex items-center justify-between border-b border-slate-800 px-5 py-4">
            <h2 class="text-sm font-bold text-slate-300">
                Unidades
                <span class="ml-2 text-xs font-normal text-slate-500">@Model.Items.Count resultado@(Model.Items.Count != 1 ? "s" : "")</span>
            </h2>
        </div>

        @if (!Model.Items.Any())
        {
            <div class="flex flex-col items-center justify-center gap-3 px-5 py-16 text-center">
                <span class="material-symbols-outlined text-4xl text-slate-700">inventory_2</span>
                <p class="text-sm font-semibold text-slate-500">No se encontraron unidades con los filtros actuales.</p>
                <a asp-controller="Producto" asp-action="UnidadesGlobal" class="text-xs font-bold text-primary hover:underline">
                    Limpiar filtros
                </a>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-slate-800 bg-slate-900/40 text-left text-xs font-bold uppercase tracking-wider text-slate-500">
                            <th class="px-4 py-3">Producto</th>
                            <th class="px-4 py-3">Código interno</th>
                            <th class="px-4 py-3">N° serie</th>
                            <th class="px-4 py-3">Estado</th>
                            <th class="px-4 py-3">Ubicación</th>
                            <th class="px-4 py-3">Cliente</th>
                            <th class="px-4 py-3">Fecha venta</th>
                            <th class="px-4 py-3">Ingreso</th>
                            <th class="px-4 py-3 text-right">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-800/60">
                        @foreach (var item in Model.Items)
                        {
                            <tr class="hover:bg-slate-800/30 transition-colors">
                                <td class="px-4 py-3">
                                    <a asp-controller="Producto" asp-action="Unidades"
                                       asp-route-productoId="@item.ProductoId"
                                       class="font-semibold text-slate-200 hover:text-white hover:underline">
                                        @item.ProductoNombre
                                    </a>
                                    <div class="mt-0.5 font-mono text-xs text-slate-500">@item.ProductoCodigo</div>
                                </td>
                                <td class="px-4 py-3 font-mono text-xs text-slate-300">
                                    @item.CodigoInternoUnidad
                                </td>
                                <td class="px-4 py-3 font-mono text-xs text-slate-400">
                                    @(item.NumeroSerie ?? "—")
                                </td>
                                <td class="px-4 py-3">
                                    <span class="inline-flex items-center rounded-full border px-2 py-0.5 text-xs font-bold @BadgeCss(item.Estado)">
                                        @EstadoLabel(item.Estado)
                                    </span>
                                </td>
                                <td class="px-4 py-3 text-xs text-slate-400">
                                    @(item.UbicacionActual ?? "—")
                                </td>
                                <td class="px-4 py-3 text-xs text-slate-400">
                                    @(item.ClienteNombre ?? "—")
                                </td>
                                <td class="px-4 py-3 text-xs text-slate-400">
                                    @(item.FechaVenta.HasValue
                                        ? item.FechaVenta.Value.ToLocalTime().ToString("dd/MM/yyyy")
                                        : "—")
                                </td>
                                <td class="px-4 py-3 text-xs text-slate-400">
                                    @item.FechaIngreso.ToLocalTime().ToString("dd/MM/yyyy")
                                </td>
                                <td class="px-4 py-3">
                                    <div class="flex items-center justify-end gap-2">
                                        <a asp-controller="Producto" asp-action="UnidadHistorial"
                                           asp-route-unidadId="@item.Id"
                                           class="inline-flex items-center gap-1 rounded px-2 py-1 text-xs font-bold text-slate-400 transition-colors hover:bg-slate-800 hover:text-white"
                                           title="Ver historial de movimientos">
                                            <span class="material-symbols-outlined text-sm">history</span>
                                            Historial
                                        </a>
                                        <a asp-controller="Producto" asp-action="Unidades"
                                           asp-route-productoId="@item.ProductoId"
                                           class="inline-flex items-center gap-1 rounded px-2 py-1 text-xs font-bold text-slate-400 transition-colors hover:bg-slate-800 hover:text-white"
                                           title="Ver unidades del producto">
                                            <span class="material-symbols-outlined text-sm">inventory_2</span>
                                            Producto
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="border-t border-slate-800 px-5 py-3">
                <p class="text-xs text-slate-600">
                    Este reporte muestra unidades físicas individuales. No reemplaza el stock agregado ni el Kardex SKU.
                </p>
            </div>
        }
    </section>

</div>
