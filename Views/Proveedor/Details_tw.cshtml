@model TheBuryProject.ViewModels.ProveedorViewModel
@{
    ViewData["Title"] = $"Detalle - {Model.RazonSocial}";
    var cuitFormatted = Model.Cuit.Length == 11
        ? $"{Model.Cuit[..2]}-{Model.Cuit[2..10]}-{Model.Cuit[10]}"
        : Model.Cuit;
    var direccionCompleta = string.Join(", ",
        new[] { Model.Direccion, Model.Ciudad }.Where(s => !string.IsNullOrWhiteSpace(s)));
}

<!-- Header Actions -->
<div class="flex items-center justify-between mb-6">
    <nav aria-label="Breadcrumb" class="flex text-sm font-medium text-slate-500 dark:text-slate-400">
        <ol class="inline-flex items-center space-x-1 md:space-x-3">
            <li><a asp-controller="Catalogo" asp-action="Index" class="hover:text-primary no-underline">Inventario</a></li>
            <li><span class="mx-2 text-slate-400">/</span></li>
            <li><a asp-controller="Proveedor" asp-action="Index" class="hover:text-primary no-underline">Proveedores</a></li>
            <li><span class="mx-2 text-slate-400">/</span></li>
            <li class="text-slate-900 dark:text-slate-100">Detalle</li>
        </ol>
    </nav>
    <div class="flex gap-3">
        <a asp-action="Index"
           class="flex items-center gap-2 px-4 py-2 bg-slate-200 dark:bg-slate-800 hover:bg-slate-300 dark:hover:bg-slate-700 rounded-lg text-sm font-semibold transition-colors no-underline text-slate-900 dark:text-slate-100">
            <span class="material-symbols-outlined text-[20px]">arrow_back</span>
            Volver
        </a>
        <button type="button" onclick="ProveedorEditarModal.open(@Model.Id)"
                class="flex items-center gap-2 px-4 py-2 bg-primary hover:bg-blue-700 text-white rounded-lg text-sm font-semibold transition-colors shadow-lg shadow-primary/20">
            <span class="material-symbols-outlined text-[20px]">edit</span>
            Editar
        </button>
    </div>
</div>

<!-- Page Title -->
<div class="mb-8">
    <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white">Detalle de Proveedor</h1>
    <p class="mt-2 text-slate-600 dark:text-slate-400">Visualización completa de la información del proveedor y métricas financieras.</p>
</div>

<!-- Stats Row -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white dark:bg-slate-900/50 p-6 rounded-xl border border-slate-200 dark:border-slate-800 flex items-center gap-4">
        <div class="p-3 bg-primary/10 rounded-lg text-primary">
            <span class="material-symbols-outlined text-3xl">shopping_cart</span>
        </div>
        <div>
            <p class="text-sm font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Órdenes de Compra</p>
            <p class="text-2xl font-bold">@Model.TotalOrdenesCompra</p>
        </div>
    </div>
    <div class="bg-white dark:bg-slate-900/50 p-6 rounded-xl border border-slate-200 dark:border-slate-800 flex items-center gap-4">
        <div class="p-3 bg-emerald-500/10 rounded-lg text-emerald-500">
            <span class="material-symbols-outlined text-3xl">payments</span>
        </div>
        <div>
            <p class="text-sm font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Cheques Vigentes</p>
            <p class="text-2xl font-bold">@Model.ChequesVigentes</p>
        </div>
    </div>
    <div class="bg-white dark:bg-slate-900/50 p-6 rounded-xl border border-slate-200 dark:border-slate-800 flex items-center gap-4">
        <div class="p-3 bg-rose-500/10 rounded-lg text-rose-500">
            <span class="material-symbols-outlined text-3xl">account_balance_wallet</span>
        </div>
        <div>
            <p class="text-sm font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Deuda Estimada</p>
            <p class="text-2xl font-bold">$@Model.TotalDeuda.ToString("N0")</p>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Left Column: General Info -->
    <div class="lg:col-span-2 space-y-8">
        <section class="bg-white dark:bg-slate-900/50 rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-800/50 flex justify-between items-center">
                <h3 class="text-lg font-bold">Información General</h3>
                @if (Model.Activo)
                {
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-800">
                        <span class="w-1.5 h-1.5 mr-1.5 rounded-full bg-emerald-500"></span>
                        Activo
                    </span>
                }
                else
                {
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400 border border-slate-200 dark:border-slate-700">
                        <span class="w-1.5 h-1.5 mr-1.5 rounded-full bg-slate-400"></span>
                        Inactivo
                    </span>
                }
            </div>
            <div class="p-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase mb-1">Razón Social</label>
                        <p class="text-base font-medium">@Model.RazonSocial</p>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase mb-1">Nombre Fantasía</label>
                        <p class="text-base font-medium">@(Model.NombreFantasia ?? "—")</p>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase mb-1">CUIT</label>
                        <p class="text-base font-medium">@cuitFormatted</p>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase mb-1">Contacto Principal</label>
                        <p class="text-base font-medium">@(Model.Contacto ?? "—")</p>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase mb-1">Email</label>
                        @if (!string.IsNullOrEmpty(Model.Email))
                        {
                            <p class="text-base font-medium text-primary">@Model.Email</p>
                        }
                        else
                        {
                            <p class="text-base font-medium">—</p>
                        }
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase mb-1">Teléfono</label>
                        <p class="text-base font-medium">@(Model.Telefono ?? "—")</p>
                    </div>

                    <!-- Dirección row -->
                    <div class="md:col-span-2 border-t border-slate-100 dark:border-slate-800 pt-6 mt-2">
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            <div>
                                <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase mb-1">Ciudad / Provincia</label>
                                <p class="text-base font-medium">
                                    @{
                                        var ciudadProv = string.Join(", ",
                                            new[] { Model.Ciudad, Model.Provincia }.Where(s => !string.IsNullOrWhiteSpace(s)));
                                    }
                                    @(string.IsNullOrEmpty(ciudadProv) ? "—" : ciudadProv)
                                </p>
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase mb-1">Código Postal</label>
                                <p class="text-base font-medium">@(Model.CodigoPostal ?? "—")</p>
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase mb-1">Dirección</label>
                                <p class="text-base font-medium">@(Model.Direccion ?? "—")</p>
                            </div>
                        </div>
                    </div>

                    <!-- Aclaraciones -->
                    <div class="md:col-span-2">
                        <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase mb-1">Aclaraciones</label>
                        @if (!string.IsNullOrWhiteSpace(Model.Aclaraciones))
                        {
                            <div class="p-4 bg-slate-100 dark:bg-slate-800 rounded-lg text-sm text-slate-600 dark:text-slate-300">
                                @Model.Aclaraciones
                            </div>
                        }
                        else
                        {
                            <p class="text-base font-medium text-slate-400 italic">Sin aclaraciones</p>
                        }
                    </div>
                </div>
            </div>
        </section>

        <!-- Associated Products Section -->
        <section class="bg-white dark:bg-slate-900/50 rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-800/50">
                <h3 class="text-lg font-bold">Productos Asociados</h3>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm">
                    <thead class="bg-slate-50/50 dark:bg-slate-800/30 text-slate-500 uppercase text-[10px] font-bold tracking-widest">
                        <tr>
                            <th class="px-6 py-3">Producto</th>
                            <th class="px-6 py-3 text-center">Código</th>
                            <th class="px-6 py-3 text-center">Stock</th>
                            <th class="px-6 py-3 text-right">Precio Compra</th>
                        </tr>
                    </thead>
                    <tbody id="productos-tbody" class="divide-y divide-slate-100 dark:divide-slate-800">
                        <tr>
                            <td colspan="4" class="px-6 py-8 text-center text-sm text-slate-400">
                                <div class="flex items-center justify-center gap-2">
                                    <div class="w-5 h-5 border-2 border-primary border-t-transparent rounded-full animate-spin"></div>
                                    Cargando productos...
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div id="productos-footer" class="hidden p-4 text-center border-t border-slate-100 dark:border-slate-800">
                <span id="productos-count" class="text-primary text-sm font-semibold"></span>
            </div>
        </section>
    </div>

    <!-- Right Column: Taxonomy/Tags -->
    <div class="space-y-6">
        <!-- Location Card -->
        <div class="bg-white dark:bg-slate-900/50 rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden">
            <div class="h-48 w-full bg-slate-200 dark:bg-slate-800 flex items-center justify-center">
                <span class="material-symbols-outlined text-5xl text-primary">location_on</span>
            </div>
            <div class="p-4 flex items-start gap-3">
                <span class="material-symbols-outlined text-slate-400">place</span>
                <span class="text-sm">@(string.IsNullOrEmpty(direccionCompleta) ? "Sin dirección registrada" : direccionCompleta)</span>
            </div>
        </div>

        <!-- Categories -->
        <section class="bg-white dark:bg-slate-900/50 rounded-xl border border-slate-200 dark:border-slate-800 p-6">
            <h3 class="text-sm font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400 mb-4">Categorías Asociadas</h3>
            @if (Model.CategoriasAsociadas.Any())
            {
                <div class="flex flex-wrap gap-2">
                    @foreach (var cat in Model.CategoriasAsociadas)
                    {
                        <span class="px-3 py-1 bg-primary/10 text-primary rounded-full text-xs font-semibold border border-primary/20">@cat</span>
                    }
                </div>
            }
            else
            {
                <p class="text-sm text-slate-400 italic">Sin categorías asignadas</p>
            }
        </section>

        <!-- Brands -->
        <section class="bg-white dark:bg-slate-900/50 rounded-xl border border-slate-200 dark:border-slate-800 p-6">
            <h3 class="text-sm font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400 mb-4">Marcas Asociadas</h3>
            @if (Model.MarcasAsociadas.Any())
            {
                <div class="flex flex-wrap gap-2">
                    @foreach (var marca in Model.MarcasAsociadas)
                    {
                        <span class="px-3 py-1 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-full text-xs font-semibold border border-slate-200 dark:border-slate-700">@marca</span>
                    }
                </div>
            }
            else
            {
                <p class="text-sm text-slate-400 italic">Sin marcas asignadas</p>
            }
        </section>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════
     MODAL: Editar Proveedor (reutilizado del Index)
     ═══════════════════════════════════════════════════════════════ -->
@using TheBuryProject.Helpers
@{
    var (categorias, marcas, productos) = (Model.CategoriasDisponibles, Model.MarcasDisponibles, Model.ProductosDisponibles);
}
<div id="modal-editar-proveedor" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="ProveedorEditarModal.close()"></div>
    <div class="absolute right-0 top-0 h-full w-full max-w-7xl bg-white dark:bg-[#161d2c] shadow-2xl flex flex-col animate-slide-in-right">
        <header class="flex items-center justify-between px-8 py-5 border-b border-slate-200 dark:border-slate-800 bg-white/50 dark:bg-[#161d2c]/50 backdrop-blur-sm">
            <div>
                <nav class="flex items-center gap-2 text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">
                    <span>Proveedores</span>
                    <span class="material-symbols-outlined text-xs">chevron_right</span>
                    <span class="text-slate-900 dark:text-slate-100">Editar</span>
                </nav>
                <h2 class="text-3xl font-black tracking-tight text-slate-900 dark:text-slate-50">Editar Proveedor</h2>
            </div>
            <div class="flex gap-3">
                <button type="button" onclick="ProveedorEditarModal.close()"
                        class="px-5 py-2 rounded-lg border border-slate-200 dark:border-slate-700 text-sm font-bold hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
                    Cancelar
                </button>
                <button type="button" onclick="ProveedorEditarModal.submit()"
                        class="px-6 py-2 rounded-lg bg-primary text-white text-sm font-bold hover:bg-primary/90 transition-all shadow-lg shadow-primary/20">
                    Guardar Cambios
                </button>
            </div>
        </header>
        <div id="edit-loading-overlay" class="hidden absolute inset-0 z-10 bg-white/60 dark:bg-slate-900/60 flex items-center justify-center">
            <div class="flex flex-col items-center gap-3">
                <div class="w-8 h-8 border-4 border-primary border-t-transparent rounded-full animate-spin"></div>
                <span class="text-sm font-semibold text-slate-600 dark:text-slate-300">Cargando datos...</span>
            </div>
        </div>
        <div class="flex-1 overflow-y-auto px-8 py-8">
            <form id="form-editar-proveedor" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" />
                <input type="hidden" name="RowVersion" />
                <div class="max-w-7xl mx-auto grid grid-cols-12 gap-8">
                    <div class="col-span-12 lg:col-span-8 space-y-8">
                        <section id="edit-validation-summary" class="hidden p-6 rounded-xl border-2 border-dashed border-red-400/30 bg-red-50 dark:bg-red-900/10">
                            <div class="flex items-start gap-4">
                                <div class="p-2 rounded-full bg-red-100 dark:bg-red-900/30 text-red-500">
                                    <span class="material-symbols-outlined">error</span>
                                </div>
                                <div>
                                    <h3 class="text-sm font-bold text-red-600 dark:text-red-400 uppercase tracking-wider mb-1">Errores de Validación</h3>
                                    <ul id="edit-error-list" class="text-sm text-red-600 dark:text-red-400 list-disc pl-4 space-y-1"></ul>
                                </div>
                            </div>
                        </section>
                        <!-- 1. Datos Fiscales -->
                        <section class="space-y-6">
                            <div class="flex items-center gap-3">
                                <span class="w-8 h-8 flex items-center justify-center rounded-full bg-slate-900 dark:bg-slate-100 text-white dark:text-slate-900 text-xs font-bold">1</span>
                                <h3 class="text-xl font-bold">Datos Fiscales</h3>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">CUIT <span class="text-red-500">*</span></label>
                                    <input type="text" name="Cuit" maxlength="11"
                                           class="w-full px-4 py-2 rounded-lg bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none"
                                           placeholder="Ej: 30714421092" />
                                    <p class="text-[11px] text-slate-500 italic">11 dígitos sin guiones</p>
                                </div>
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Razón Social <span class="text-red-500">*</span></label>
                                    <input type="text" name="RazonSocial" maxlength="200"
                                           class="w-full px-4 py-2 rounded-lg bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none"
                                           placeholder="Ej: Empresa S.A." />
                                </div>
                                <div class="md:col-span-2 space-y-2">
                                    <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Nombre Fantasía</label>
                                    <input type="text" name="NombreFantasia" maxlength="200"
                                           class="w-full px-4 py-2 rounded-lg bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none"
                                           placeholder="Nombre comercial" />
                                </div>
                            </div>
                        </section>
                        <!-- 2. Datos de Contacto -->
                        <section class="space-y-6">
                            <div class="flex items-center gap-3">
                                <span class="w-8 h-8 flex items-center justify-center rounded-full bg-slate-900 dark:bg-slate-100 text-white dark:text-slate-900 text-xs font-bold">2</span>
                                <h3 class="text-xl font-bold">Datos de Contacto</h3>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Email Corporativo</label>
                                    <input type="email" name="Email" maxlength="100"
                                           class="w-full px-4 py-2 rounded-lg bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none"
                                           placeholder="contacto@empresa.com" />
                                </div>
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Teléfono</label>
                                    <input type="tel" name="Telefono" maxlength="50"
                                           class="w-full px-4 py-2 rounded-lg bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none"
                                           placeholder="+54 11 0000-0000" />
                                </div>
                                <div class="md:col-span-2 space-y-2">
                                    <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Contacto Principal (Nombre Completo)</label>
                                    <input type="text" name="Contacto" maxlength="200"
                                           class="w-full px-4 py-2 rounded-lg bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none"
                                           placeholder="Ej: Juan Pérez" />
                                </div>
                            </div>
                        </section>
                        <!-- 3. Cobertura de Catálogo -->
                        <section class="space-y-6">
                            <div class="flex items-center gap-3">
                                <span class="w-8 h-8 flex items-center justify-center rounded-full bg-slate-900 dark:bg-slate-100 text-white dark:text-slate-900 text-xs font-bold">3</span>
                                <h3 class="text-xl font-bold">Cobertura de Catálogo</h3>
                            </div>
                            <div class="space-y-6 p-6 rounded-xl bg-slate-50 dark:bg-slate-900/40 border border-slate-200 dark:border-slate-800">
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <div class="space-y-2">
                                        <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Categorías</label>
                                        <select name="CategoriasSeleccionadas" multiple
                                                class="w-full px-4 py-2 rounded-lg bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 focus:ring-2 focus:ring-primary h-32">
                                            @foreach (var cat in categorias)
                                            {
                                                <option value="@cat.Value">@cat.Text</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="space-y-2">
                                        <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Marcas Representadas</label>
                                        <select name="MarcasSeleccionadas" multiple
                                                class="w-full px-4 py-2 rounded-lg bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 focus:ring-2 focus:ring-primary h-32">
                                            @foreach (var m in marcas)
                                            {
                                                <option value="@m.Value">@m.Text</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                                <div class="space-y-4 pt-4 border-t border-slate-200 dark:border-slate-800">
                                    <div class="flex items-center justify-between">
                                        <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Selección de Productos Específicos</label>
                                        <div class="relative w-64">
                                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm">search</span>
                                            <input type="text" id="edit-producto-search"
                                                   class="w-full pl-9 pr-4 py-1.5 text-sm rounded-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 outline-none focus:ring-2 focus:ring-primary"
                                                   placeholder="Filtrar productos..." />
                                        </div>
                                    </div>
                                    <div id="edit-productos-grid" class="grid grid-cols-2 md:grid-cols-3 gap-3 max-h-60 overflow-y-auto">
                                        @foreach (var prod in productos)
                                        {
                                            <label class="edit-producto-item flex items-center gap-3 p-3 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 cursor-pointer hover:border-primary/50 transition-colors" data-nombre="@prod.Text.ToLower()">
                                                <input type="checkbox" name="ProductosSeleccionados" value="@prod.Value"
                                                       class="w-4 h-4 rounded text-primary focus:ring-primary bg-slate-100 dark:bg-slate-800 border-slate-300 dark:border-slate-700" />
                                                <span class="text-xs font-medium">@prod.Text</span>
                                            </label>
                                        }
                                    </div>
                                </div>
                            </div>
                        </section>
                        <!-- 4. Dirección -->
                        <section class="space-y-6">
                            <div class="flex items-center gap-3">
                                <span class="w-8 h-8 flex items-center justify-center rounded-full bg-slate-900 dark:bg-slate-100 text-white dark:text-slate-900 text-xs font-bold">4</span>
                                <h3 class="text-xl font-bold">Dirección</h3>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                                <div class="md:col-span-2 space-y-2">
                                    <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Calle y Número</label>
                                    <input type="text" name="Direccion" maxlength="300"
                                           class="w-full px-4 py-2 rounded-lg bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 focus:ring-2 focus:ring-primary outline-none"
                                           placeholder="Av. Siempre Viva 123" />
                                </div>
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Ciudad</label>
                                    <input type="text" name="Ciudad" maxlength="100"
                                           class="w-full px-4 py-2 rounded-lg bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 focus:ring-2 focus:ring-primary outline-none"
                                           placeholder="CABA" />
                                </div>
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Provincia</label>
                                    <select name="Provincia" class="w-full px-4 py-2 rounded-lg bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 focus:ring-2 focus:ring-primary outline-none">
                                        <option value="">— Seleccionar —</option>
                                        @foreach (var prov in DropdownConstants.Provincias)
                                        {
                                            <option value="@prov">@prov</option>
                                        }
                                    </select>
                                </div>
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Código Postal</label>
                                    <input type="text" name="CodigoPostal" maxlength="10"
                                           class="w-full px-4 py-2 rounded-lg bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 focus:ring-2 focus:ring-primary outline-none"
                                           placeholder="1425" />
                                </div>
                            </div>
                        </section>
                        <!-- 5. Información Adicional -->
                        <section class="space-y-6">
                            <div class="flex items-center gap-3">
                                <span class="w-8 h-8 flex items-center justify-center rounded-full bg-slate-900 dark:bg-slate-100 text-white dark:text-slate-900 text-xs font-bold">5</span>
                                <h3 class="text-xl font-bold">Información Adicional</h3>
                            </div>
                            <div class="space-y-4">
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Aclaraciones / Observaciones</label>
                                    <textarea name="Aclaraciones" maxlength="2000" rows="4"
                                              class="w-full px-4 py-3 rounded-lg bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 focus:ring-2 focus:ring-primary outline-none resize-none"
                                              placeholder="Notas adicionales sobre el proveedor..."></textarea>
                                </div>
                                <div class="flex items-center gap-3">
                                    <label class="relative inline-flex items-center cursor-pointer">
                                        <input type="checkbox" name="Activo" value="true" class="sr-only peer" />
                                        <div class="w-11 h-6 bg-slate-200 dark:bg-slate-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                                        <span class="ms-3 text-sm font-semibold text-slate-700 dark:text-slate-300">Proveedor Activo</span>
                                    </label>
                                </div>
                            </div>
                        </section>
                    </div>
                    <aside class="col-span-12 lg:col-span-4 space-y-6">
                        <div class="sticky top-0 space-y-6">
                            <div class="p-8 rounded-2xl bg-slate-900 text-white shadow-2xl relative overflow-hidden">
                                <div class="absolute -top-24 -right-24 w-64 h-64 bg-primary/20 rounded-full blur-3xl"></div>
                                <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-primary/10 rounded-full blur-3xl"></div>
                                <div class="relative z-10">
                                    <div class="flex items-center gap-3 mb-6">
                                        <span class="material-symbols-outlined text-primary">auto_awesome</span>
                                        <h4 class="text-xl font-bold">Guía de edición</h4>
                                    </div>
                                    <ul class="space-y-6">
                                        <li class="flex gap-4">
                                            <div class="flex-shrink-0 w-6 h-6 rounded-full border border-primary/50 flex items-center justify-center text-[10px] font-bold text-primary">1</div>
                                            <div>
                                                <p class="text-sm font-bold mb-1">Verificación de CUIT</p>
                                                <p class="text-xs text-slate-400 leading-relaxed">Asegúrese de que el CUIT sea válido ante la AFIP.</p>
                                            </div>
                                        </li>
                                        <li class="flex gap-4">
                                            <div class="flex-shrink-0 w-6 h-6 rounded-full border border-primary/50 flex items-center justify-center text-[10px] font-bold text-primary">2</div>
                                            <div>
                                                <p class="text-sm font-bold mb-1">Categorización</p>
                                                <p class="text-xs text-slate-400 leading-relaxed">Las categorías determinan en qué búsquedas aparece el proveedor.</p>
                                            </div>
                                        </li>
                                        <li class="flex gap-4">
                                            <div class="flex-shrink-0 w-6 h-6 rounded-full border border-primary/50 flex items-center justify-center text-[10px] font-bold text-primary">3</div>
                                            <div>
                                                <p class="text-sm font-bold mb-1">Concurrencia</p>
                                                <p class="text-xs text-slate-400 leading-relaxed">Si otro usuario editó este proveedor, se te notificará al guardar.</p>
                                            </div>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </aside>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const proveedorId = @Model.Id;
    </script>
    <script src="~/js/proveedor-detalles.js"></script>
    <script src="~/js/proveedor-editar-modal.js"></script>
}
