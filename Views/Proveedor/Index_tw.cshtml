                                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm">search</span>
                                            <input type="text" id="edit-producto-search"
                                                   class="w-full pl-9 pr-4 py-1.5 text-sm rounded-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 outline-none focus:ring-2 focus:ring-primary"
                                                   placeholder="Filtrar productos..." />
                                        </div>
                                    </div>
                                    <div id="edit-productos-grid" class="grid grid-cols-2 md:grid-cols-3 gap-3 max-h-60 overflow-y-auto">
                                        @foreach (var prod in Model.ProductosDisponibles)
                                        {
                                            <label class="edit-producto-item flex items-center gap-3 p-3 rounded-lg border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 cursor-pointer hover:border-primary/50 transition-colors" data-nombre="@prod.Text.ToLower()">
                                                <input type="checkbox" name="ProductosSeleccionados" value="@prod.Value"
                                                       class="w-4 h-4 rounded text-primary focus:ring-primary bg-slate-100 dark:bg-slate-800 border-slate-300 dark:border-slate-700" />
                                                <span class="text-xs font-medium">@prod.Text</span>
                                            </label>
                                        }
                                    </div>
                                </div>
                            </div>
                        </section>

                        <!-- 4. Dirección -->
                        <section class="space-y-6">
                            <div class="flex items-center gap-3">
                                <span class="w-8 h-8 flex items-center justify-center rounded-full bg-slate-900 dark:bg-slate-100 text-white dark:text-slate-900 text-xs font-bold">4</span>
                                <h3 class="text-xl font-bold">Dirección</h3>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                                <div class="md:col-span-2 space-y-2">
                                    <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Calle y Número</label>
                                    <input type="text" name="Direccion" maxlength="300"
                                           class="w-full px-4 py-2 rounded-lg bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 focus:ring-2 focus:ring-primary outline-none"
                                           placeholder="Av. Siempre Viva 123" />
                                </div>
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Ciudad</label>
                                    <input type="text" name="Ciudad" maxlength="100"
                                           class="w-full px-4 py-2 rounded-lg bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 focus:ring-2 focus:ring-primary outline-none"
                                           placeholder="CABA" />
                                </div>
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Provincia</label>
                                    <select name="Provincia" class="w-full px-4 py-2 rounded-lg bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 focus:ring-2 focus:ring-primary outline-none">
                                        <option value="">— Seleccionar —</option>
                                        @foreach (var prov in DropdownConstants.Provincias)
                                        {
                                            <option value="@prov">@prov</option>
                                        }
                                    </select>
                                </div>
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Código Postal</label>
                                    <input type="text" name="CodigoPostal" maxlength="10"
                                           class="w-full px-4 py-2 rounded-lg bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 focus:ring-2 focus:ring-primary outline-none"
                                           placeholder="1425" />
                                </div>
                            </div>
                        </section>

                        <!-- 5. Información Adicional -->
                        <section class="space-y-6">
                            <div class="flex items-center gap-3">
                                <span class="w-8 h-8 flex items-center justify-center rounded-full bg-slate-900 dark:bg-slate-100 text-white dark:text-slate-900 text-xs font-bold">5</span>
                                <h3 class="text-xl font-bold">Información Adicional</h3>
                            </div>
                            <div class="space-y-4">
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Aclaraciones / Observaciones</label>
                                    <textarea name="Aclaraciones" maxlength="2000" rows="4"
                                              class="w-full px-4 py-3 rounded-lg bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 focus:ring-2 focus:ring-primary outline-none resize-none"
                                              placeholder="Notas adicionales sobre el proveedor..."></textarea>
                                </div>
                                <div class="flex items-center gap-3">
                                    <label class="relative inline-flex items-center cursor-pointer">
                                        <input type="checkbox" name="Activo" value="true" class="sr-only peer" />
                                        <div class="w-11 h-6 bg-slate-200 dark:bg-slate-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                                        <span class="ms-3 text-sm font-semibold text-slate-700 dark:text-slate-300">Proveedor Activo</span>
                                    </label>
                                </div>
                            </div>
                        </section>
                    </div>

                    <!-- Side Panel Guide -->
                    <aside class="col-span-12 lg:col-span-4 space-y-6">
                        <div class="sticky top-0 space-y-6">
                            <div class="p-8 rounded-2xl bg-slate-900 text-white shadow-2xl relative overflow-hidden">
                                <div class="absolute -top-24 -right-24 w-64 h-64 bg-primary/20 rounded-full blur-3xl"></div>
                                <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-primary/10 rounded-full blur-3xl"></div>
                                <div class="relative z-10">
                                    <div class="flex items-center gap-3 mb-6">
                                        <span class="material-symbols-outlined text-primary">auto_awesome</span>
                                        <h4 class="text-xl font-bold">Guía de edición</h4>
                                    </div>
                                    <ul class="space-y-6">
                                        <li class="flex gap-4">
                                            <div class="flex-shrink-0 w-6 h-6 rounded-full border border-primary/50 flex items-center justify-center text-[10px] font-bold text-primary">1</div>
                                            <div>
                                                <p class="text-sm font-bold mb-1">Verificación de CUIT</p>
                                                <p class="text-xs text-slate-400 leading-relaxed">Asegúrese de que el CUIT sea válido ante la AFIP para evitar rechazos en facturación.</p>
                                            </div>
                                        </li>
                                        <li class="flex gap-4">
                                            <div class="flex-shrink-0 w-6 h-6 rounded-full border border-primary/50 flex items-center justify-center text-[10px] font-bold text-primary">2</div>
                                            <div>
                                                <p class="text-sm font-bold mb-1">Categorización</p>
                                                <p class="text-xs text-slate-400 leading-relaxed">Seleccionar correctamente las categorías permitirá que el proveedor aparezca en las búsquedas del catálogo.</p>
                                            </div>
                                        </li>
                                        <li class="flex gap-4">
                                            <div class="flex-shrink-0 w-6 h-6 rounded-full border border-primary/50 flex items-center justify-center text-[10px] font-bold text-primary">3</div>
                                            <div>
                                                <p class="text-sm font-bold mb-1">Concurrencia</p>
                                                <p class="text-xs text-slate-400 leading-relaxed">Si otro usuario editó este proveedor mientras lo tenías abierto, se te notificará al guardar.</p>
                                            </div>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </aside>
                </div>
            </form>
        </div>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div id="toast-error" class="fixed bottom-6 right-6 z-50 flex items-center gap-3 px-5 py-3 rounded-lg bg-red-600 text-white shadow-xl text-sm font-semibold animate-fade-in">
        <span class="material-symbols-outlined text-lg">error</span>
        @TempData["Error"]
    </div>
}
@if (TempData["Warning"] != null)
{
    <div id="toast-warning" class="fixed bottom-6 right-6 z-50 flex items-center gap-3 px-5 py-3 rounded-lg bg-amber-500 text-white shadow-xl text-sm font-semibold animate-fade-in">
        <span class="material-symbols-outlined text-lg">warning</span>
        @TempData["Warning"]
    </div>
}
@if (TempData["Success"] != null)
{
    <div id="toast-success" class="fixed bottom-6 right-6 z-50 flex items-center gap-3 px-5 py-3 rounded-lg bg-emerald-600 text-white shadow-xl text-sm font-semibold animate-fade-in">
        <span class="material-symbols-outlined text-lg">check_circle</span>
        @TempData["Success"]
    </div>
}

@section Scripts {
    <script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
    <script src="~/js/proveedor-module.js" asp-append-version="true"></script>
    <script src="~/js/proveedor-index.js" asp-append-version="true"></script>
    <script src="~/js/proveedor-crear-modal.js" asp-append-version="true"></script>
    <script src="~/js/proveedor-editar-modal.js" asp-append-version="true"></script>
}
