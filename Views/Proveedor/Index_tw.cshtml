@model ProveedorFilterViewModel
@using TheBuryProject.Helpers
@{
    ViewData["Title"] = "Gestión de Proveedores";
    ViewData["MetaDescription"] = "Administración de proveedores, contactos y órdenes de compra en el ERP TheBuryProject.";
    var proveedores = Model.Proveedores.ToList();
    var total = Model.TotalResultados;
    var activos = proveedores.Count(p => p.Activo);
}

@section Styles {
    <partial name="_ProveedorModuleStyles" />
}

@{
    var filtroProvActivo = !string.IsNullOrEmpty(Model.SearchTerm) || Model.SoloActivos;
}

<!-- Table Container -->
<div data-oc-scroll style="--oc-scroll-min-width: 58rem;" class="table-erp-wrapper">
    <div class="border-b border-slate-800 px-5 py-4">
        <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
            <div class="min-w-0">
                <h2 class="text-base font-bold text-white">Listado de proveedores</h2>
                <p class="text-sm text-slate-400">Revisá cobertura, contacto y estado desde una sola grilla operativa.</p>
            </div>
            <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center lg:justify-end">
                <div class="flex flex-wrap items-center gap-2">
                    <span class="badge-erp badge-erp-neutral">
                        <span class="material-symbols-outlined text-sm">table_rows</span>
                        @proveedores.Count visibles
                    </span>
                    <span class="badge-erp badge-erp-success">
                        <span class="material-symbols-outlined text-sm">check_circle</span>
                        @activos activos
                    </span>
                    @if (filtroProvActivo)
                    {
                        <span class="badge-erp badge-erp-primary">
                            <span class="material-symbols-outlined text-sm">filter_alt</span>
                            Filtros activos
                        </span>
                    }
                </div>
                <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
                    <a asp-controller="OrdenCompra" asp-action="Index"
                       class="btn-erp-ghost btn-sm no-underline sm:w-auto">
                        <span class="material-symbols-outlined text-[16px]">local_shipping</span>
                        Órdenes
                    </a>
                    <button type="button" data-proveedor-modal-action="open" data-proveedor-modal="create"
                            class="btn-erp-primary btn-sm sm:w-auto">
                        <span class="material-symbols-outlined text-[16px]">add</span>
                        Nuevo Proveedor
                    </button>
                </div>
            </div>
        </div>
    </div>

    <form asp-action="Index" method="get" id="form-filtros"
          class="border-b border-slate-800 bg-slate-900/30 p-4">
        <div class="flex flex-wrap items-end gap-4">
            <div class="min-w-[220px] flex-1">
                <label class="mb-1.5 block text-[10px] font-bold uppercase tracking-wider text-slate-400">Buscar proveedor</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-lg text-slate-400">search</span>
                    <input type="text" name="searchTerm" value="@Model.SearchTerm"
                           aria-label="Buscar proveedor por nombre, CUIT o razón social"
                           class="w-full rounded-lg border-none bg-slate-800 py-2 pl-10 pr-4 text-sm text-white placeholder:text-slate-500 transition-colors focus:ring-2 focus:ring-primary/50"
                           placeholder="Nombre, CUIT o razón social" />
                </div>
            </div>
            <div class="w-44">
                <label class="mb-1.5 block text-[10px] font-bold uppercase tracking-wider text-slate-400">Orden</label>
                <select name="orderBy" aria-label="Ordenar por" class="filter-select-erp">
                    <option value="razonsocial" selected="@(Model.OrderBy == "razonsocial" || string.IsNullOrEmpty(Model.OrderBy))">Razón Social</option>
                    <option value="cuit" selected="@(Model.OrderBy == "cuit")">CUIT</option>
                    <option value="email" selected="@(Model.OrderBy == "email")">Email</option>
                    <option value="telefono" selected="@(Model.OrderBy == "telefono")">Teléfono</option>
                </select>
            </div>
            <div class="w-40">
                <label class="mb-1.5 block text-[10px] font-bold uppercase tracking-wider text-slate-400">Dirección</label>
                <select name="orderDirection" aria-label="Dirección de orden" class="filter-select-erp">
                    <option value="asc" selected="@(Model.OrderDirection == "asc" || string.IsNullOrEmpty(Model.OrderDirection))">Ascendente</option>
                    <option value="desc" selected="@(Model.OrderDirection == "desc")">Descendente</option>
                </select>
            </div>
            <div class="w-40">
                <label class="mb-1.5 block text-[10px] font-bold uppercase tracking-wider text-slate-400">Estado</label>
                <label class="flex h-9 cursor-pointer select-none items-center gap-2 rounded-lg bg-slate-800 px-3 text-sm font-semibold text-slate-300">
                    <input type="checkbox" name="soloActivos" value="true" @(Model.SoloActivos ? "checked" : "")
                           class="rounded border-slate-700 bg-slate-900 text-primary focus:ring-primary/50" />
                    <span>Solo activos</span>
                </label>
            </div>
            <div class="flex gap-2">
                <button type="submit"
                        class="inline-flex h-9 items-center justify-center gap-2 rounded-lg bg-primary/10 px-3 text-sm font-bold text-primary-on-dark transition-colors hover:bg-primary hover:text-white"
                        title="Filtrar proveedores">
                    <span class="material-symbols-outlined text-lg">filter_list</span>
                    <span>Filtrar</span>
                </button>
                @if (filtroProvActivo)
                {
                    <a asp-action="Index"
                       class="inline-flex h-9 items-center justify-center rounded-lg bg-slate-800 px-3 text-slate-300 transition-colors hover:bg-slate-700 hover:text-white no-underline"
                       title="Limpiar filtros">
                        <span class="material-symbols-outlined text-lg">clear_all</span>
                    </a>
                }
            </div>
        </div>
    </form>

    <p data-oc-scroll-hint hidden class="px-5 pt-4 text-xs font-semibold uppercase tracking-[0.16em] text-slate-400 lg:hidden">
        Deslizá la tabla para ver contacto y acciones completas.
    </p>

    <div data-oc-scroll-shell>
        <div data-oc-scroll-fade="left" hidden></div>
        <div data-oc-scroll-fade="right" hidden></div>
        <div data-oc-scroll-region tabindex="0" role="region" aria-label="Listado de proveedores">
            <table data-oc-scroll-table class="w-full text-left border-collapse">
            <thead>
                <tr class="border-b border-slate-800 bg-slate-800/30">
                    <th class="px-5 py-3 text-xs font-bold uppercase tracking-wider text-slate-400">Proveedor</th>
                    <th class="px-5 py-3 text-xs font-bold uppercase tracking-wider text-slate-400">Productos</th>
                    <th class="px-5 py-3 text-xs font-bold uppercase tracking-wider text-slate-400">Contacto</th>
                    <th class="px-5 py-3 text-xs font-bold uppercase tracking-wider text-slate-400">Estado</th>
                    <th class="px-5 py-3 text-xs font-bold uppercase tracking-wider text-slate-400 text-right">Acciones</th>
                </tr>
            </thead>
            <tbody id="proveedores-tbody" class="divide-y divide-slate-800">
                @if (proveedores.Any())
                {
                    @foreach (var p in proveedores)
                    {
                        var cuitFormatted = p.Cuit.Length == 11
                            ? $"{p.Cuit[..2]}-{p.Cuit[2..10]}-{p.Cuit[10]}"
                            : p.Cuit;
                        var categorias = p.CategoriasAsociadas.Take(2).ToList();
                        var categoriasRestantes = p.CategoriasAsociadas.Count() - categorias.Count;

                        <tr data-proveedor-row-id="@p.Id" class="transition-colors hover:bg-white/5">
                            <td class="px-5 py-3">
                                <div class="min-w-0">
                                    <p class="truncate text-sm font-bold text-white">@p.RazonSocial</p>
                                    <p class="mt-0.5 flex flex-wrap items-center gap-1.5 text-[11px] text-slate-500">
                                        <span class="font-mono">@cuitFormatted</span>
                                        @if (!string.IsNullOrEmpty(p.NombreFantasia))
                                        {
                                            <span class="h-1 w-1 rounded-full bg-slate-700"></span>
                                            <span class="truncate max-w-[14rem]">@p.NombreFantasia</span>
                                        }
                                    </p>
                                </div>
                            </td>
                            <td class="px-5 py-3">
                                @if (categorias.Any())
                                {
                                    <div class="flex max-w-[18rem] flex-wrap gap-1">
                                        @foreach (var cat in categorias)
                                        {
                                            <span class="inline-flex max-w-[9rem] items-center truncate rounded-md border border-slate-700 bg-slate-800/70 px-2 py-0.5 text-[11px] font-semibold text-slate-300">@cat</span>
                                        }
                                        @if (categoriasRestantes > 0)
                                        {
                                            <span class="inline-flex items-center rounded-md border border-primary/20 bg-primary/10 px-2 py-0.5 text-[11px] font-bold text-primary-on-dark">+@categoriasRestantes</span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-xs text-slate-500">Sin productos</span>
                                }
                            </td>
                            <td class="px-5 py-3">
                                <div class="flex max-w-[17rem] flex-col gap-0.5 text-sm">
                                    @if (!string.IsNullOrEmpty(p.Contacto))
                                    {
                                        <span class="truncate font-semibold text-slate-200">@p.Contacto</span>
                                    }
                                    @if (!string.IsNullOrEmpty(p.Email))
                                    {
                                        <a href="mailto:@p.Email" class="flex items-center gap-1 truncate text-xs text-primary-on-dark hover:underline no-underline">
                                            <span class="material-symbols-outlined text-[14px]">mail</span>
                                            <span class="truncate">@p.Email</span>
                                        </a>
                                    }
                                    @if (!string.IsNullOrEmpty(p.Telefono))
                                    {
                                        <span class="flex items-center gap-1 text-xs text-slate-400">
                                            <span class="material-symbols-outlined text-[14px]">phone</span>
                                            @p.Telefono
                                        </span>
                                    }
                                    @if (string.IsNullOrEmpty(p.Contacto) && string.IsNullOrEmpty(p.Email) && string.IsNullOrEmpty(p.Telefono))
                                    {
                                        <span class="text-xs text-slate-500">Sin contacto</span>
                                    }
                                </div>
                            </td>
                            <td class="px-5 py-3">
                                @if (p.Activo)
                                {
                                    <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-500/10 px-2.5 py-1 text-xs font-bold text-emerald-400">
                                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                                        Activo
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-800 px-2.5 py-1 text-xs font-bold text-slate-400">
                                        <span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span>
                                        Inactivo
                                    </span>
                                }
                            </td>
                            <td class="px-5 py-3 text-right">
                                <div class="flex items-center justify-end gap-0.5">
                                    <a asp-action="Details" asp-route-id="@p.Id"
                                       class="row-action row-action--primary no-underline"
                                       title="Ver detalle"
                                       aria-label="Ver detalle de @p.RazonSocial">
                                        <span class="material-symbols-outlined">visibility</span>
                                        <span class="row-action__label">Ver</span>
                                    </a>
                                    <button type="button" data-proveedor-modal-action="open" data-proveedor-modal="edit" data-proveedor-id="@p.Id"
                                            class="row-action"
                                            title="Editar"
                                            aria-label="Editar @p.RazonSocial">
                                        <span class="material-symbols-outlined">edit</span>
                                        <span class="row-action__label">Editar</span>
                                    </button>
                                    <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="inline" data-proveedor-delete-form data-proveedor-name="@p.RazonSocial">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="row-action row-action--danger"
                                                title="Eliminar"
                                                aria-label="Eliminar @p.RazonSocial">
                                            <span class="material-symbols-outlined">delete</span>
                                            <span class="row-action__label">Eliminar</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
            </table>
        </div>
    </div>

    <!-- Empty State -->
    @if (!proveedores.Any())
    {
        <div class="flex flex-col items-center justify-center py-20 px-6 text-center">
            <div class="w-16 h-16 bg-slate-800 rounded-full flex items-center justify-center mb-4">
                <span class="material-symbols-outlined text-slate-400 text-3xl">search_off</span>
            </div>
            <h3 class="text-lg font-bold text-white">No se encontraron resultados</h3>
            <p class="text-slate-400 max-w-xs mt-1">No se encontraron proveedores que coincidan con la búsqueda actual.</p>
            <a asp-action="Index" class="mt-6 text-primary-on-dark font-semibold hover:underline flex items-center gap-1 no-underline">
                <span class="material-symbols-outlined text-[18px]">filter_alt_off</span>
                Limpiar filtros
            </a>
        </div>
    }

    <!-- Pagination Info -->
    @if (proveedores.Any())
    {
        <div class="flex flex-col gap-2 border-t border-slate-800 bg-slate-900/30 px-5 py-3 sm:flex-row sm:items-center sm:justify-between">
            <div class="text-xs text-slate-500">
                Mostrando <span class="font-semibold text-white">@proveedores.Count</span> de
                <span class="font-semibold text-white">@total</span> proveedores
            </div>
            <p class="text-xs text-slate-500">
                Las acciones de detalle, edición y eliminación están en la última columna.
            </p>
        </div>
    }
</div>

<!-- ═══════════════════════════════════════════════════════════════
     MODAL: Nuevo Proveedor
     ═══════════════════════════════════════════════════════════════ -->
<div id="modal-crear-proveedor" class="fixed inset-0 z-50 hidden">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" data-proveedor-modal-action="close" data-proveedor-modal="create"></div>

    <!-- Panel -->
    <div class="absolute right-0 top-0 h-full w-full max-w-6xl bg-[#161d2c] shadow-2xl flex flex-col animate-slide-in-right">
        <!-- Header -->
        <header class="flex items-center justify-between px-6 py-4 border-b border-slate-800 bg-[#161d2c]/80 backdrop-blur-sm">
            <div>
                <nav class="flex items-center gap-2 text-xs font-medium text-slate-400 mb-1">
                    <span>Proveedores</span>
                    <span class="material-symbols-outlined text-xs">chevron_right</span>
                    <span class="text-slate-100">Nuevo</span>
                </nav>
                <h2 class="text-2xl font-black tracking-tight text-slate-50">Nuevo Proveedor</h2>
            </div>
            <div class="flex gap-3">
                <button type="button" data-proveedor-modal-action="close" data-proveedor-modal="create"
                        class="px-4 py-2 rounded-lg border border-slate-700 text-sm font-bold hover:bg-slate-800 transition-colors">
                    Cancelar
                </button>
                <button type="button" data-proveedor-modal-action="submit" data-proveedor-modal="create"
                        class="px-5 py-2 rounded-lg bg-primary text-white text-sm font-bold hover:bg-primary/90 transition-colors shadow-lg shadow-primary/20">
                    Guardar Proveedor
                </button>
            </div>
        </header>

        <!-- Body -->
        <div class="flex-1 overflow-y-auto px-6 py-6">
            <form id="form-crear-proveedor" novalidate>
                @Html.AntiForgeryToken()
                <div class="max-w-6xl mx-auto grid grid-cols-12 gap-6">
                    <!-- Form Container -->
                    <div class="col-span-12 lg:col-span-8 space-y-6">

                        <!-- Validation Summary -->
                        <section id="proveedor-validation-summary" class="hidden p-4 rounded-lg border border-red-400/30 bg-red-900/10">
                            <div class="flex items-start gap-4">
                                <div class="p-2 rounded-full bg-red-900/30 text-red-500">
                                    <span class="material-symbols-outlined">error</span>
                                </div>
                                <div>
                                    <h3 class="text-sm font-bold text-red-400 uppercase tracking-wider mb-1">Errores de Validación</h3>
                                    <ul id="proveedor-error-list" class="text-sm text-red-400 list-disc pl-4 space-y-1"></ul>
                                </div>
                            </div>
                        </section>

                        <!-- 1. Datos Fiscales -->
                        <section class="space-y-5">
                            <div class="flex items-center gap-3">
                                <span class="flex size-7 items-center justify-center rounded-full bg-primary/15 text-xs font-bold text-primary-on-dark">1</span>
                                <h3 class="text-lg font-bold">Datos Fiscales</h3>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-300">CUIT <span class="text-red-500">*</span></label>
                                    <input type="text" name="Cuit" maxlength="11"
                                           class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent transition-colors outline-none"
                                           placeholder="Ej: 30714421092" />
                                    <p class="text-[11px] text-slate-500 italic">11 dígitos sin guiones</p>
                                </div>
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-300">Razón Social <span class="text-red-500">*</span></label>
                                    <input type="text" name="RazonSocial" maxlength="200"
                                           class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent transition-colors outline-none"
                                           placeholder="Ej: Empresa S.A." />
                                </div>
                                <div class="md:col-span-2 space-y-2">
                                    <label class="text-sm font-semibold text-slate-300">Nombre Fantasía</label>
                                    <input type="text" name="NombreFantasia" maxlength="200"
                                           class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent transition-colors outline-none"
                                           placeholder="Nombre comercial" />
                                </div>
                            </div>
                        </section>

                        <!-- 2. Datos de Contacto -->
                        <section class="space-y-5">
                            <div class="flex items-center gap-3">
                                <span class="flex size-7 items-center justify-center rounded-full bg-primary/15 text-xs font-bold text-primary-on-dark">2</span>
                                <h3 class="text-lg font-bold">Datos de Contacto</h3>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-300">Email Corporativo</label>
                                    <input type="email" name="Email" maxlength="100"
                                           class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent transition-colors outline-none"
                                           placeholder="contacto@empresa.com" />
                                </div>
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-300">Teléfono</label>
                                    <input type="tel" name="Telefono" maxlength="50"
                                           class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent transition-colors outline-none"
                                           placeholder="+54 11 0000-0000" />
                                </div>
                                <div class="md:col-span-2 space-y-2">
                                    <label class="text-sm font-semibold text-slate-300">Contacto Principal (Nombre Completo)</label>
                                    <input type="text" name="Contacto" maxlength="200"
                                           class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent transition-colors outline-none"
                                           placeholder="Ej: Juan Pérez" />
                                </div>
                            </div>
                        </section>

                        <!-- 3. Cobertura de Catálogo -->
                        <section class="space-y-4">
                            <div class="flex items-center gap-3">
                                <span class="flex size-7 items-center justify-center rounded-full bg-primary/15 text-xs font-bold text-primary-on-dark">3</span>
                                <h3 class="text-lg font-bold">Cobertura de Catálogo</h3>
                            </div>
                            <div class="p-4 rounded-lg bg-slate-900/40 border border-slate-800 space-y-3">
                                <div class="proveedor-product-picker" data-picker-id="crear" data-form-name="ProductosSeleccionados">
                                    <div class="relative">
                                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none text-[18px] text-slate-500">search</span>
                                        <input type="text"
                                               class="picker-search-input w-full rounded-lg bg-slate-800 border border-slate-700 pl-9 pr-4 py-2.5 text-sm text-white placeholder-slate-500 focus:outline-none focus:ring-1 focus:ring-primary/60 focus:border-primary/50 transition-colors"
                                               placeholder="Buscar producto por nombre, código, marca o categoría…"
                                               autocomplete="off">
                                        @* El dropdown se mueve al body vía JS (portal) para escapar del overflow del modal *@
                                        <div class="picker-dropdown" hidden></div>
                                    </div>
                                    <div class="picker-chips-container flex flex-wrap gap-1.5 mt-3 min-h-[1.75rem]"></div>
                                    <p class="text-xs text-slate-500 mt-2">
                                        <span class="picker-count-number font-semibold text-slate-300">0</span> seleccionados
                                    </p>
                                    <div class="picker-hidden-inputs"></div>
                                </div>
                            </div>
                        </section>

                        <!-- 4. Dirección -->
                        <section class="space-y-5">
                            <div class="flex items-center gap-3">
                                <span class="flex size-7 items-center justify-center rounded-full bg-primary/15 text-xs font-bold text-primary-on-dark">4</span>
                                <h3 class="text-lg font-bold">Dirección</h3>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
                                <div class="md:col-span-2 space-y-2">
                                    <label class="text-sm font-semibold text-slate-300">Calle y Número</label>
                                    <input type="text" name="Direccion" maxlength="300"
                                           class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-800 focus:ring-2 focus:ring-primary outline-none"
                                           placeholder="Av. Siempre Viva 123" />
                                </div>
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-300">Ciudad</label>
                                    <input type="text" name="Ciudad" maxlength="100"
                                           class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-800 focus:ring-2 focus:ring-primary outline-none"
                                           placeholder="CABA" />
                                </div>
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-300">Provincia</label>
                                    <select name="Provincia" class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-800 focus:ring-2 focus:ring-primary outline-none">
                                        <option value="">— Seleccionar —</option>
                                        @foreach (var prov in DropdownConstants.Provincias)
                                        {
                                            <option value="@prov">@prov</option>
                                        }
                                    </select>
                                </div>
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-300">Código Postal</label>
                                    <input type="text" name="CodigoPostal" maxlength="10"
                                           class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-800 focus:ring-2 focus:ring-primary outline-none"
                                           placeholder="1425" />
                                </div>
                            </div>
                        </section>

                        <!-- 5. Información Adicional -->
                        <section class="space-y-5">
                            <div class="flex items-center gap-3">
                                <span class="flex size-7 items-center justify-center rounded-full bg-primary/15 text-xs font-bold text-primary-on-dark">5</span>
                                <h3 class="text-lg font-bold">Información Adicional</h3>
                            </div>
                            <div class="space-y-4">
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-300">Aclaraciones / Observaciones</label>
                                    <textarea name="Aclaraciones" maxlength="2000" rows="4"
                                              class="w-full px-4 py-3 rounded-lg bg-slate-900 border border-slate-800 focus:ring-2 focus:ring-primary outline-none resize-none"
                                              placeholder="Notas adicionales sobre el proveedor..."></textarea>
                                </div>
                                <div class="flex items-center gap-3">
                                    <label class="relative inline-flex items-center cursor-pointer">
                                        <input type="checkbox" name="Activo" value="true" checked class="sr-only peer" />
                                        <div class="w-11 h-6 bg-slate-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-colors peer-checked:bg-primary"></div>
                                        <span class="ms-3 text-sm font-semibold text-slate-300">Proveedor Activo</span>
                                    </label>
                                </div>
                            </div>
                        </section>
                    </div>

                    <!-- Side Panel Guide -->
                    <aside class="col-span-12 lg:col-span-4 space-y-6">
                        <div class="sticky top-0 space-y-6">
                            <div class="rounded-lg border border-slate-800 bg-slate-900/70 p-5 text-white">
                                <div>
                                    <div class="flex items-center gap-3 mb-5">
                                        <span class="material-symbols-outlined text-primary-on-dark">rule</span>
                                        <h4 class="text-lg font-bold">Guía de carga</h4>
                                    </div>
                                    <ul class="space-y-4">
                                        <li class="flex gap-3">
                                            <div class="flex-shrink-0 w-6 h-6 rounded-full border border-primary/40 flex items-center justify-center text-[10px] font-bold text-primary-on-dark">1</div>
                                            <div>
                                                <p class="text-sm font-bold mb-1">Verificación de CUIT</p>
                                                <p class="text-xs text-slate-400 leading-relaxed">Asegúrese de que el CUIT sea válido ante la AFIP para evitar rechazos en facturación.</p>
                                            </div>
                                        </li>
                                        <li class="flex gap-3">
                                            <div class="flex-shrink-0 w-6 h-6 rounded-full border border-primary/40 flex items-center justify-center text-[10px] font-bold text-primary-on-dark">2</div>
                                            <div>
                                                <p class="text-sm font-bold mb-1">Categorización</p>
                                                <p class="text-xs text-slate-400 leading-relaxed">Seleccionar correctamente las categorías permitirá que el proveedor aparezca en las búsquedas del catálogo.</p>
                                            </div>
                                        </li>
                                        <li class="flex gap-3">
                                            <div class="flex-shrink-0 w-6 h-6 rounded-full border border-primary/40 flex items-center justify-center text-[10px] font-bold text-primary-on-dark">3</div>
                                            <div>
                                                <p class="text-sm font-bold mb-1">Contacto Principal</p>
                                                <p class="text-xs text-slate-400 leading-relaxed">Este será el destinatario predeterminado para el envío automático de órdenes de compra.</p>
                                            </div>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </aside>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════
     MODAL: Editar Proveedor
     ═══════════════════════════════════════════════════════════════ -->
<div id="modal-editar-proveedor" class="fixed inset-0 z-50 hidden">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" data-proveedor-modal-action="close" data-proveedor-modal="edit"></div>

    <!-- Panel -->
    <div class="absolute right-0 top-0 h-full w-full max-w-6xl bg-[#161d2c] shadow-2xl flex flex-col animate-slide-in-right">
        <!-- Header -->
        <header class="flex items-center justify-between px-6 py-4 border-b border-slate-800 bg-[#161d2c]/80 backdrop-blur-sm">
            <div>
                <nav class="flex items-center gap-2 text-xs font-medium text-slate-400 mb-1">
                    <span>Proveedores</span>
                    <span class="material-symbols-outlined text-xs">chevron_right</span>
                    <span class="text-slate-100">Editar</span>
                </nav>
                <h2 class="text-2xl font-black tracking-tight text-slate-50">Editar Proveedor</h2>
            </div>
            <div class="flex gap-3">
                <button type="button" data-proveedor-modal-action="close" data-proveedor-modal="edit"
                        class="px-4 py-2 rounded-lg border border-slate-700 text-sm font-bold hover:bg-slate-800 transition-colors">
                    Cancelar
                </button>
                <button type="button" data-proveedor-modal-action="submit" data-proveedor-modal="edit"
                        class="px-5 py-2 rounded-lg bg-primary text-white text-sm font-bold hover:bg-primary/90 transition-colors shadow-lg shadow-primary/20">
                    Guardar Cambios
                </button>
            </div>
        </header>

        <!-- Loading overlay -->
        <div id="edit-loading-overlay" class="hidden absolute inset-0 z-10 bg-slate-900/60 flex items-center justify-center">
            <div class="flex flex-col items-center gap-3">
                <div class="w-8 h-8 border-4 border-primary border-t-transparent rounded-full animate-spin"></div>
                <span class="text-sm font-semibold text-slate-300">Cargando datos...</span>
            </div>
        </div>

        <!-- Body -->
        <div class="flex-1 overflow-y-auto px-6 py-6">
            <form id="form-editar-proveedor" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" />
                <input type="hidden" name="RowVersion" />
                <div class="max-w-6xl mx-auto grid grid-cols-12 gap-6">
                    <!-- Form Container -->
                    <div class="col-span-12 lg:col-span-8 space-y-6">

                        <!-- Validation Summary -->
                        <section id="edit-validation-summary" class="hidden p-4 rounded-lg border border-red-400/30 bg-red-900/10">
                            <div class="flex items-start gap-4">
                                <div class="p-2 rounded-full bg-red-900/30 text-red-500">
                                    <span class="material-symbols-outlined">error</span>
                                </div>
                                <div>
                                    <h3 class="text-sm font-bold text-red-400 uppercase tracking-wider mb-1">Errores de Validación</h3>
                                    <ul id="edit-error-list" class="text-sm text-red-400 list-disc pl-4 space-y-1"></ul>
                                </div>
                            </div>
                        </section>

                        <!-- 1. Datos Fiscales -->
                        <section class="space-y-5">
                            <div class="flex items-center gap-3">
                                <span class="flex size-7 items-center justify-center rounded-full bg-primary/15 text-xs font-bold text-primary-on-dark">1</span>
                                <h3 class="text-lg font-bold">Datos Fiscales</h3>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-300">CUIT <span class="text-red-500">*</span></label>
                                    <input type="text" name="Cuit" maxlength="11"
                                           class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent transition-colors outline-none"
                                           placeholder="Ej: 30714421092" />
                                    <p class="text-[11px] text-slate-500 italic">11 dígitos sin guiones</p>
                                </div>
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-300">Razón Social <span class="text-red-500">*</span></label>
                                    <input type="text" name="RazonSocial" maxlength="200"
                                           class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent transition-colors outline-none"
                                           placeholder="Ej: Empresa S.A." />
                                </div>
                                <div class="md:col-span-2 space-y-2">
                                    <label class="text-sm font-semibold text-slate-300">Nombre Fantasía</label>
                                    <input type="text" name="NombreFantasia" maxlength="200"
                                           class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent transition-colors outline-none"
                                           placeholder="Nombre comercial" />
                                </div>
                            </div>
                        </section>

                        <!-- 2. Datos de Contacto -->
                        <section class="space-y-5">
                            <div class="flex items-center gap-3">
                                <span class="flex size-7 items-center justify-center rounded-full bg-primary/15 text-xs font-bold text-primary-on-dark">2</span>
                                <h3 class="text-lg font-bold">Datos de Contacto</h3>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-300">Email Corporativo</label>
                                    <input type="email" name="Email" maxlength="100"
                                           class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent transition-colors outline-none"
                                           placeholder="contacto@empresa.com" />
                                </div>
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-300">Teléfono</label>
                                    <input type="tel" name="Telefono" maxlength="50"
                                           class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent transition-colors outline-none"
                                           placeholder="+54 11 0000-0000" />
                                </div>
                                <div class="md:col-span-2 space-y-2">
                                    <label class="text-sm font-semibold text-slate-300">Contacto Principal (Nombre Completo)</label>
                                    <input type="text" name="Contacto" maxlength="200"
                                           class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-800 focus:ring-2 focus:ring-primary focus:border-transparent transition-colors outline-none"
                                           placeholder="Ej: Juan Pérez" />
                                </div>
                            </div>
                        </section>

                        <!-- 3. Cobertura de Catálogo -->
                        <section class="space-y-4">
                            <div class="flex items-center gap-3">
                                <span class="flex size-7 items-center justify-center rounded-full bg-primary/15 text-xs font-bold text-primary-on-dark">3</span>
                                <h3 class="text-lg font-bold">Cobertura de Catálogo</h3>
                            </div>
                            <div class="p-4 rounded-lg bg-slate-900/40 border border-slate-800 space-y-3">
                                <div class="proveedor-product-picker" data-picker-id="editar" data-form-name="ProductosSeleccionados">
                                    <div class="relative">
                                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none text-[18px] text-slate-500">search</span>
                                        <input type="text"
                                               class="picker-search-input w-full rounded-lg bg-slate-800 border border-slate-700 pl-9 pr-4 py-2.5 text-sm text-white placeholder-slate-500 focus:outline-none focus:ring-1 focus:ring-primary/60 focus:border-primary/50 transition-colors"
                                               placeholder="Buscar producto por nombre, código, marca o categoría…"
                                               autocomplete="off">
                                        @* El dropdown se mueve al body vía JS (portal) para escapar del overflow del modal *@
                                        <div class="picker-dropdown" hidden></div>
                                    </div>
                                    <div class="picker-chips-container flex flex-wrap gap-1.5 mt-3 min-h-[1.75rem]"></div>
                                    <p class="text-xs text-slate-500 mt-2">
                                        <span class="picker-count-number font-semibold text-slate-300">0</span> seleccionados
                                    </p>
                                    <div class="picker-hidden-inputs"></div>
                                </div>
                            </div>
                        </section>

                        <!-- 4. Dirección -->
                        <section class="space-y-5">
                            <div class="flex items-center gap-3">
                                <span class="flex size-7 items-center justify-center rounded-full bg-primary/15 text-xs font-bold text-primary-on-dark">4</span>
                                <h3 class="text-lg font-bold">Dirección</h3>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
                                <div class="md:col-span-2 space-y-2">
                                    <label class="text-sm font-semibold text-slate-300">Calle y Número</label>
                                    <input type="text" name="Direccion" maxlength="300"
                                           class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-800 focus:ring-2 focus:ring-primary outline-none"
                                           placeholder="Av. Siempre Viva 123" />
                                </div>
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-300">Ciudad</label>
                                    <input type="text" name="Ciudad" maxlength="100"
                                           class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-800 focus:ring-2 focus:ring-primary outline-none"
                                           placeholder="CABA" />
                                </div>
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-300">Provincia</label>
                                    <select name="Provincia" class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-800 focus:ring-2 focus:ring-primary outline-none">
                                        <option value="">— Seleccionar —</option>
                                        @foreach (var prov in DropdownConstants.Provincias)
                                        {
                                            <option value="@prov">@prov</option>
                                        }
                                    </select>
                                </div>
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-300">Código Postal</label>
                                    <input type="text" name="CodigoPostal" maxlength="10"
                                           class="w-full px-4 py-2 rounded-lg bg-slate-900 border border-slate-800 focus:ring-2 focus:ring-primary outline-none"
                                           placeholder="1425" />
                                </div>
                            </div>
                        </section>

                        <!-- 5. Información Adicional -->
                        <section class="space-y-5">
                            <div class="flex items-center gap-3">
                                <span class="flex size-7 items-center justify-center rounded-full bg-primary/15 text-xs font-bold text-primary-on-dark">5</span>
                                <h3 class="text-lg font-bold">Información Adicional</h3>
                            </div>
                            <div class="space-y-4">
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold text-slate-300">Aclaraciones / Observaciones</label>
                                    <textarea name="Aclaraciones" maxlength="2000" rows="4"
                                              class="w-full px-4 py-3 rounded-lg bg-slate-900 border border-slate-800 focus:ring-2 focus:ring-primary outline-none resize-none"
                                              placeholder="Notas adicionales sobre el proveedor..."></textarea>
                                </div>
                                <div class="flex items-center gap-3">
                                    <label class="relative inline-flex items-center cursor-pointer">
                                        <input type="checkbox" name="Activo" value="true" class="sr-only peer" />
                                        <div class="w-11 h-6 bg-slate-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-colors peer-checked:bg-primary"></div>
                                        <span class="ms-3 text-sm font-semibold text-slate-300">Proveedor Activo</span>
                                    </label>
                                </div>
                            </div>
                        </section>
                    </div>

                    <!-- Side Panel Guide -->
                    <aside class="col-span-12 lg:col-span-4 space-y-6">
                        <div class="sticky top-0 space-y-6">
                            <div class="rounded-lg border border-slate-800 bg-slate-900/70 p-5 text-white">
                                <div>
                                    <div class="flex items-center gap-3 mb-5">
                                        <span class="material-symbols-outlined text-primary-on-dark">rule</span>
                                        <h4 class="text-lg font-bold">Guía de edición</h4>
                                    </div>
                                    <ul class="space-y-4">
                                        <li class="flex gap-3">
                                            <div class="flex-shrink-0 w-6 h-6 rounded-full border border-primary/40 flex items-center justify-center text-[10px] font-bold text-primary-on-dark">1</div>
                                            <div>
                                                <p class="text-sm font-bold mb-1">Verificación de CUIT</p>
                                                <p class="text-xs text-slate-400 leading-relaxed">Asegúrese de que el CUIT sea válido ante la AFIP para evitar rechazos en facturación.</p>
                                            </div>
                                        </li>
                                        <li class="flex gap-3">
                                            <div class="flex-shrink-0 w-6 h-6 rounded-full border border-primary/40 flex items-center justify-center text-[10px] font-bold text-primary-on-dark">2</div>
                                            <div>
                                                <p class="text-sm font-bold mb-1">Categorización</p>
                                                <p class="text-xs text-slate-400 leading-relaxed">Seleccionar correctamente las categorías permitirá que el proveedor aparezca en las búsquedas del catálogo.</p>
                                            </div>
                                        </li>
                                        <li class="flex gap-3">
                                            <div class="flex-shrink-0 w-6 h-6 rounded-full border border-primary/40 flex items-center justify-center text-[10px] font-bold text-primary-on-dark">3</div>
                                            <div>
                                                <p class="text-sm font-bold mb-1">Concurrencia</p>
                                                <p class="text-xs text-slate-400 leading-relaxed">Si otro usuario editó este proveedor mientras lo tenías abierto, se te notificará al guardar.</p>
                                            </div>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </aside>
                </div>
            </form>
        </div>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div id="toast-error" class="fixed bottom-6 right-6 z-50 flex items-center gap-3 px-5 py-3 rounded-lg bg-red-600 text-white shadow-xl text-sm font-semibold animate-fade-in">
        <span class="material-symbols-outlined text-lg">error</span>
        @TempData["Error"]
    </div>
}
@if (TempData["Warning"] != null)
{
    <div id="toast-warning" class="fixed bottom-6 right-6 z-50 flex items-center gap-3 px-5 py-3 rounded-lg bg-amber-500 text-white shadow-xl text-sm font-semibold animate-fade-in">
        <span class="material-symbols-outlined text-lg">warning</span>
        @TempData["Warning"]
    </div>
}
@if (TempData["Success"] != null)
{
    <div id="toast-success" class="fixed bottom-6 right-6 z-50 flex items-center gap-3 px-5 py-3 rounded-lg bg-emerald-600 text-white shadow-xl text-sm font-semibold animate-fade-in">
        <span class="material-symbols-outlined text-lg">check_circle</span>
        @TempData["Success"]
    </div>
}

<script type="application/json" id="productos-picker-data">@Html.Raw(Model.ProductosPickerJson)</script>

@section Scripts {
    <script src="~/js/module-index.js" asp-append-version="true"></script>
    <script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
    <script src="~/js/proveedor-product-picker.js" asp-append-version="true"></script>
    <script src="~/js/proveedor-module.js" asp-append-version="true"></script>
    <script src="~/js/proveedor-index.js" asp-append-version="true"></script>
    <script src="~/js/proveedor-crear-modal.js" asp-append-version="true"></script>
    <script src="~/js/proveedor-editar-modal.js" asp-append-version="true"></script>
}
