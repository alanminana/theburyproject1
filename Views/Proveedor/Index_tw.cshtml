<div id="modal-editar-proveedor" class="fixed inset-0 z-50 hidden">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="ProveedorEditarModal.close()"></div>

    <!-- Panel -->
