@model List<TheBuryProject.ViewModels.RolViewModel>
@{
    ViewData["Title"] = "Seguridad";
}

<partial name="_SeguridadTabs" />

<!-- Tab Content: Roles -->
<div class="max-w-7xl mx-auto space-y-6">

    <!-- TempData Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="toast-msg flex items-center gap-4 bg-emerald-500/10 border border-emerald-500/20 p-4 rounded-xl">
            <div class="bg-emerald-500/20 text-emerald-500 p-2 rounded-lg">
                <span class="material-symbols-outlined">check_circle</span>
            </div>
            <div>
                <p class="text-emerald-500 text-sm font-bold leading-tight">Operación exitosa</p>
                <p class="text-emerald-500/80 text-xs font-medium">@TempData["Success"]</p>
            </div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="toast-msg flex items-center gap-4 bg-rose-500/10 border border-rose-500/20 p-4 rounded-xl">
            <div class="bg-rose-500/20 text-rose-500 p-2 rounded-lg">
                <span class="material-symbols-outlined">error</span>
            </div>
            <div>
                <p class="text-rose-500 text-sm font-bold leading-tight">Error</p>
                <p class="text-rose-500/80 text-xs font-medium">@TempData["Error"]</p>
            </div>
        </div>
    }

    <!-- Roles Grid -->
    @if (Model.Any())
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            @foreach (var rol in Model)
            {
                <div class="bg-white dark:bg-slate-900/50 rounded-xl border border-slate-200 dark:border-slate-800 p-5 hover:shadow-md transition-shadow group">
                    <div class="flex items-start justify-between gap-3">
                        <div class="flex items-center gap-3">
                            <div class="size-10 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-primary">shield_person</span>
                            </div>
                            <div>
                                <h4 class="text-sm font-bold text-slate-900 dark:text-white">@rol.Nombre</h4>
                                <p class="text-xs text-slate-500 mt-0.5">
                                    @rol.CantidadUsuarios @(rol.CantidadUsuarios == 1 ? "usuario" : "usuarios")
                                </p>
                            </div>
                        </div>
                        <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                            <a asp-action="Details" asp-route-id="@rol.Id"
                               class="p-1.5 hover:bg-primary/10 rounded-lg text-slate-400 hover:text-primary transition-colors"
                               title="Ver detalles">
                                <span class="material-symbols-outlined text-lg">visibility</span>
                            </a>
                            <a asp-action="AsignarPermisos" asp-route-id="@rol.Id"
                               class="p-1.5 hover:bg-slate-100 dark:hover:bg-slate-700 rounded-lg text-slate-400 transition-colors"
                               title="Gestionar permisos">
                                <span class="material-symbols-outlined text-lg">key</span>
                            </a>
                            <a asp-action="Edit" asp-route-id="@rol.Id"
                               class="p-1.5 hover:bg-slate-100 dark:hover:bg-slate-700 rounded-lg text-slate-400 transition-colors"
                               title="Editar">
                                <span class="material-symbols-outlined text-lg">edit</span>
                            </a>
                            @if (rol.CantidadUsuarios == 0)
                            {
                                <a asp-action="Delete" asp-route-id="@rol.Id"
                                   class="p-1.5 hover:bg-rose-50 dark:hover:bg-rose-900/20 rounded-lg text-slate-400 hover:text-rose-500 transition-colors"
                                   title="Eliminar">
                                    <span class="material-symbols-outlined text-lg">delete</span>
                                </a>
                            }
                        </div>
                    </div>

                    <!-- User count bar -->
                    <div class="mt-4 pt-3 border-t border-slate-100 dark:border-slate-800">
                        <div class="flex items-center justify-between text-xs mb-1.5">
                            <span class="text-slate-500">Usuarios asignados</span>
                            <span class="font-bold text-slate-700 dark:text-slate-300">@rol.CantidadUsuarios</span>
                        </div>
                        @{
                            var maxUsers = Model.Max(r => r.CantidadUsuarios);
                            var pct = maxUsers > 0 ? (int)Math.Round(100.0 * rol.CantidadUsuarios / maxUsers) : 0;
                        }
                        <div class="h-1.5 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
                            <div class="h-full bg-primary/60 rounded-full" style="width: @(pct)%"></div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="bg-white dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-xl p-16 text-center">
            <span class="material-symbols-outlined text-4xl text-slate-300 dark:text-slate-600">shield</span>
            <p class="text-sm text-slate-500 mt-2">No hay roles configurados.</p>
            <a asp-action="Create"
               class="inline-flex items-center gap-2 mt-4 px-4 py-2 rounded-lg bg-primary text-white text-xs font-bold hover:bg-primary/90 transition-all no-underline">
                <span class="material-symbols-outlined text-sm">add</span> Crear primer rol
            </a>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/seguridad-index.js" asp-append-version="true"></script>
}
