@model TheBuryProject.ViewModels.SeguridadEditarUsuarioViewModel
@{
    ViewData["Title"] = "Editar Usuario";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="max-w-5xl mx-auto space-y-8">
    <div class="flex items-start gap-3">
        @if (!string.IsNullOrWhiteSpace(returnUrl))
        {
            <a href="@returnUrl"
               class="mt-1 p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors no-underline text-inherit">
                <span class="material-symbols-outlined">arrow_back</span>
            </a>
        }
        else
        {
            <a asp-controller="Seguridad" asp-action="Index" asp-route-tab="usuarios"
               class="mt-1 p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors no-underline text-inherit">
                <span class="material-symbols-outlined">arrow_back</span>
            </a>
        }
        <div class="space-y-2">
            <div class="flex items-center gap-3 flex-wrap">
                <h1 class="text-3xl font-black tracking-tight text-slate-900 dark:text-white">Editar usuario</h1>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold @(Model.Activo ? "bg-emerald-500/10 text-emerald-600 dark:text-emerald-400" : "bg-slate-500/10 text-slate-600 dark:text-slate-300")">
                    @(Model.Activo ? "Activo" : "Inactivo")
                </span>
            </div>
            <p class="text-sm text-slate-500 dark:text-slate-400 max-w-3xl">
                Edición centralizada desde Seguridad. Acá se modifican datos de acceso, datos personales, roles, sucursal y estado de la cuenta.
            </p>
        </div>
    </div>

    <div class="rounded-2xl border border-amber-500/20 bg-amber-500/10 p-4 flex items-start gap-3">
        <span class="material-symbols-outlined text-amber-500 mt-0.5">info</span>
        <div>
            <p class="text-sm font-semibold text-amber-700 dark:text-amber-300">La contraseña no se edita en esta pantalla</p>
            <p class="text-xs text-amber-600/90 dark:text-amber-200 mt-1">
                El cambio o reseteo de contraseña sigue su flujo propio dentro del módulo Seguridad.
            </p>
        </div>
    </div>

    <form asp-controller="Seguridad" asp-action="EditUsuario" method="post" class="space-y-6">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="RowVersion" />
        @if (!string.IsNullOrWhiteSpace(returnUrl))
        {
            <input type="hidden" name="returnUrl" value="@returnUrl" />
        }

        <div asp-validation-summary="ModelOnly"
             class="empty:hidden rounded-xl border border-rose-500/20 bg-rose-500/10 px-4 py-3 text-sm text-rose-600 dark:text-rose-400"></div>

        <section class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/50 p-6 space-y-5">
            <div>
                <h2 class="text-lg font-bold text-slate-900 dark:text-white">Datos de acceso</h2>
                <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Identificación principal de la cuenta.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div class="space-y-2">
                    <label asp-for="UserName" class="text-sm font-semibold text-slate-700 dark:text-slate-300">Username</label>
                    <input asp-for="UserName"
                           class="w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 px-4 py-3 text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                    <span asp-validation-for="UserName" class="text-xs text-rose-500"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="Email" class="text-sm font-semibold text-slate-700 dark:text-slate-300">Email</label>
                    <input asp-for="Email"
                           class="w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 px-4 py-3 text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                    <span asp-validation-for="Email" class="text-xs text-rose-500"></span>
                </div>
            </div>
        </section>

        <section class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/50 p-6 space-y-5">
            <div>
                <h2 class="text-lg font-bold text-slate-900 dark:text-white">Datos personales</h2>
                <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Información descriptiva del usuario.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div class="space-y-2">
                    <label asp-for="Nombre" class="text-sm font-semibold text-slate-700 dark:text-slate-300">Nombre</label>
                    <input asp-for="Nombre"
                           class="w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 px-4 py-3 text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                    <span asp-validation-for="Nombre" class="text-xs text-rose-500"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="Apellido" class="text-sm font-semibold text-slate-700 dark:text-slate-300">Apellido</label>
                    <input asp-for="Apellido"
                           class="w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 px-4 py-3 text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                    <span asp-validation-for="Apellido" class="text-xs text-rose-500"></span>
                </div>

                <div class="space-y-2 md:col-span-2">
                    <label asp-for="Telefono" class="text-sm font-semibold text-slate-700 dark:text-slate-300">Teléfono</label>
                    <input asp-for="Telefono"
                           class="w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 px-4 py-3 text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                    <span asp-validation-for="Telefono" class="text-xs text-rose-500"></span>
                </div>
            </div>
        </section>

        <section class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/50 p-6 space-y-5">
            <div>
                <h2 class="text-lg font-bold text-slate-900 dark:text-white">Asignación</h2>
                <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Roles heredables, sucursal y estado de la cuenta.</p>
            </div>

            <div class="space-y-5">
                <div class="space-y-3">
                    <div class="flex items-center justify-between gap-3">
                        <label asp-for="RolesSeleccionados" class="text-sm font-semibold text-slate-700 dark:text-slate-300">Roles</label>
                        <span class="text-xs text-slate-500 dark:text-slate-400">Multi-select</span>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-800/30 p-3">
                        @if (Model.AllRoles.Any())
                        {
                            @foreach (var role in Model.AllRoles)
                            {
                                var isChecked = Model.RolesSeleccionados.Contains(role, StringComparer.OrdinalIgnoreCase);
                                <label class="flex items-start gap-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900/50 px-3 py-3 cursor-pointer hover:border-primary/40 transition-colors">
                                    <input type="checkbox"
                                           name="RolesSeleccionados"
                                           value="@role"
                                           @(isChecked ? "checked" : null)
                                           class="mt-0.5 size-4 rounded border-slate-300 dark:border-slate-600 text-primary focus:ring-primary/50" />
                                    <div class="min-w-0">
                                        <span class="text-sm font-semibold text-slate-900 dark:text-slate-100">@role</span>
                                        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">El usuario hereda permisos desde este rol.</p>
                                    </div>
                                </label>
                            }
                        }
                        else
                        {
                            <div class="sm:col-span-2 rounded-lg border border-dashed border-slate-300 dark:border-slate-700 px-4 py-6 text-center text-sm text-slate-500 dark:text-slate-400">
                                No hay roles disponibles para asignar.
                            </div>
                        }
                    </div>
                    <span asp-validation-for="RolesSeleccionados" class="text-xs text-rose-500"></span>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div class="space-y-2">
                        <label asp-for="SucursalId" class="text-sm font-semibold text-slate-700 dark:text-slate-300">Sucursal</label>
                        <select asp-for="SucursalId"
                                class="w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 px-4 py-3 text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors">
                            <option value="">Sin asignar</option>
                            @foreach (var sucursal in Model.AllSucursales)
                            {
                                <option value="@sucursal.Id">@sucursal.Nombre</option>
                            }
                        </select>
                        <span asp-validation-for="SucursalId" class="text-xs text-rose-500"></span>
                    </div>

                    <div class="flex items-end">
                        <label class="flex items-start gap-3 rounded-xl border border-slate-200 dark:border-slate-800 px-4 py-4 bg-slate-50 dark:bg-slate-800/30 cursor-pointer w-full">
                            <input asp-for="Activo"
                                   class="mt-0.5 size-4 rounded border-slate-300 dark:border-slate-600 text-primary focus:ring-primary/50" />
                            <div>
                                <span class="text-sm font-semibold text-slate-900 dark:text-white">Usuario activo</span>
                                <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Si se desmarca, la cuenta queda inactiva sin tocar la contraseña.</p>
                            </div>
                        </label>
                    </div>
                </div>
            </div>
        </section>

        <div class="flex items-center justify-between">
            @if (!string.IsNullOrWhiteSpace(returnUrl))
            {
                <a href="@returnUrl"
                   class="px-5 py-2.5 rounded-lg text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors no-underline">
                    Cancelar
                </a>
            }
            else
            {
                <a asp-controller="Seguridad" asp-action="Index" asp-route-tab="usuarios"
                   class="px-5 py-2.5 rounded-lg text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors no-underline">
                    Cancelar
                </a>
            }

            <button type="submit"
                    class="inline-flex items-center gap-2 px-6 py-2.5 rounded-lg bg-primary text-white text-sm font-semibold hover:bg-primary/90 transition-colors">
                <span class="material-symbols-outlined text-sm">save</span>
                Guardar cambios
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
