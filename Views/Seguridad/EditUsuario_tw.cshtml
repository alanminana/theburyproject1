@model TheBuryProject.ViewModels.SeguridadEditarUsuarioViewModel
@{
    ViewData["Title"] = "Editar Usuario";
    var returnUrl = ViewData["ReturnUrl"] as string;
    var backUrl = !string.IsNullOrWhiteSpace(returnUrl)
        ? returnUrl
        : Url.Action("Index", "Seguridad", new { tab = "usuarios" });
    var fullName = string.Join(" ", new[] { Model.Nombre, Model.Apellido }.Where(value => !string.IsNullOrWhiteSpace(value)));
    var displayName = !string.IsNullOrWhiteSpace(fullName) ? fullName : Model.UserName;
    var selectedRolesCount = Model.RolesSeleccionados.Count;
    var sucursalAsignada = Model.AllSucursales.FirstOrDefault(s => s.Id == Model.SucursalId)?.Nombre ?? "Sin asignar";
    var hasTelefono = !string.IsNullOrWhiteSpace(Model.Telefono);
}

@section Styles {
    <partial name="_SeguridadModuleStyles" />
}

<div class="max-w-5xl mx-auto space-y-8">
    <section class="bg-slate-900/50 border border-slate-800 rounded-2xl overflow-hidden shadow-sm">
        <div class="px-6 md:px-8 py-8 border-b border-slate-800">
            <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
                <div class="space-y-4">
                    <nav class="flex flex-wrap items-center gap-2 text-xs font-medium text-slate-400">
                        <a href="@backUrl" class="hover:text-primary transition-colors no-underline">Seguridad</a>
                        <span>/</span>
                        <span>Usuarios</span>
                        <span>/</span>
                        <span>Editar</span>
                    </nav>

                    <div class="space-y-3">
                        <div class="flex flex-wrap items-center gap-3">
                            <span class="inline-flex items-center gap-2 rounded-full border border-primary/15 bg-primary/5 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.2em] text-primary">
                                <span class="material-symbols-outlined text-sm">manage_accounts</span>
                                Editar Usuario
                            </span>
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold @(Model.Activo ? "bg-emerald-500/10 text-emerald-400" : "bg-slate-500/10 text-slate-300")">
                                @(Model.Activo ? "Activo" : "Inactivo")
                            </span>
                        </div>

                        <div>
                            <h1 class="text-3xl font-black tracking-tight text-white">@displayName</h1>
                            <p class="text-sm text-slate-400 mt-2 max-w-3xl">
                                Edición centralizada desde Seguridad. Acá se modifican datos de acceso, datos personales, roles, sucursal y estado de la cuenta sin tocar el flujo de credenciales.
                            </p>
                        </div>

                        <div class="flex flex-wrap items-center gap-2 text-xs font-medium text-slate-400">
                            <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-800 px-3 py-1">
                                <span class="material-symbols-outlined text-sm">alternate_email</span>
                                @Model.Email
                            </span>
                            <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-800 px-3 py-1">
                                <span class="material-symbols-outlined text-sm">badge</span>
                                @Model.UserName
                            </span>
                        </div>
                    </div>
                </div>

                <div class="flex w-full flex-col gap-3 sm:flex-row lg:w-auto">
                    <a href="@backUrl"
                       class="inline-flex w-full items-center justify-center gap-2 rounded-xl border border-slate-700 px-5 py-3 text-sm font-semibold text-slate-300 hover:bg-slate-800 transition-colors no-underline sm:w-auto">
                        <span class="material-symbols-outlined text-sm">arrow_back</span>
                        Volver a usuarios
                    </a>
                </div>
            </div>
        </div>

        <div class="px-6 md:px-8 py-6">
            <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 xl:grid-cols-4">
                <div class="rounded-xl border border-slate-800 bg-slate-800/40 px-4 py-4">
                    <p class="text-[11px] font-bold uppercase tracking-wider text-slate-400">Estado</p>
                    <p class="mt-2 text-2xl font-black text-white">@(Model.Activo ? "Activo" : "Inactivo")</p>
                    <p class="mt-1 text-xs text-slate-400">Control de habilitación de la cuenta.</p>
                </div>
                <div class="rounded-xl border border-slate-800 bg-slate-800/40 px-4 py-4">
                    <p class="text-[11px] font-bold uppercase tracking-wider text-slate-400">Roles asignados</p>
                    <p class="mt-2 text-2xl font-black text-white">@selectedRolesCount</p>
                    <p class="mt-1 text-xs text-slate-400">Permisos heredados desde RBAC.</p>
                </div>
                <div class="rounded-xl border border-slate-800 bg-slate-800/40 px-4 py-4">
                    <p class="text-[11px] font-bold uppercase tracking-wider text-slate-400">Sucursal</p>
                    <p class="mt-2 text-lg font-black text-white">@sucursalAsignada</p>
                    <p class="mt-1 text-xs text-slate-400">Contexto operativo principal del usuario.</p>
                </div>
                <div class="rounded-xl border border-slate-800 bg-slate-800/40 px-4 py-4">
                    <p class="text-[11px] font-bold uppercase tracking-wider text-slate-400">Contacto</p>
                    <p class="mt-2 text-2xl font-black text-white">@(hasTelefono ? "OK" : "--")</p>
                    <p class="mt-1 text-xs text-slate-400">@(hasTelefono ? Model.Telefono : "Sin teléfono cargado")</p>
                </div>
            </div>
        </div>
    </section>

    <div class="rounded-2xl border border-amber-500/20 bg-amber-500/10 p-4 flex items-start gap-3">
        <span class="material-symbols-outlined text-amber-500 mt-0.5">info</span>
        <div>
            <p class="text-sm font-semibold text-amber-300">La contraseña no se edita en esta pantalla</p>
            <p class="text-xs text-amber-600/90 text-amber-200 mt-1">
                El cambio o reseteo de contraseña sigue su flujo propio dentro del módulo Seguridad.
            </p>
        </div>
    </div>

    <form asp-controller="Seguridad" asp-action="EditUsuario" method="post" class="space-y-6">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="RowVersion" />
        @if (!string.IsNullOrWhiteSpace(returnUrl))
        {
            <input type="hidden" name="returnUrl" value="@returnUrl" />
        }

        <div asp-validation-summary="ModelOnly"
             class="empty:hidden rounded-xl border border-rose-500/20 bg-rose-500/10 px-4 py-3 text-sm text-rose-400"></div>

        <section class="rounded-2xl border border-slate-800 bg-slate-900/50 p-6 space-y-5">
            <div>
                <h2 class="text-lg font-bold text-white">Datos de acceso</h2>
                <p class="text-sm text-slate-400 mt-1">Identificación principal de la cuenta.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div class="space-y-2">
                    <label asp-for="UserName" class="text-sm font-semibold text-slate-300">Username</label>
                    <input asp-for="UserName"
                           class="w-full rounded-xl border border-slate-700 bg-slate-800 px-4 py-3 text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                    <span asp-validation-for="UserName" class="text-xs text-rose-500"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="Email" class="text-sm font-semibold text-slate-300">Email</label>
                    <input asp-for="Email"
                           class="w-full rounded-xl border border-slate-700 bg-slate-800 px-4 py-3 text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                    <span asp-validation-for="Email" class="text-xs text-rose-500"></span>
                </div>
            </div>
        </section>

        <section class="rounded-2xl border border-slate-800 bg-slate-900/50 p-6 space-y-5">
            <div>
                <h2 class="text-lg font-bold text-white">Datos personales</h2>
                <p class="text-sm text-slate-400 mt-1">Información descriptiva del usuario.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div class="space-y-2">
                    <label asp-for="Nombre" class="text-sm font-semibold text-slate-300">Nombre</label>
                    <input asp-for="Nombre"
                           class="w-full rounded-xl border border-slate-700 bg-slate-800 px-4 py-3 text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                    <span asp-validation-for="Nombre" class="text-xs text-rose-500"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="Apellido" class="text-sm font-semibold text-slate-300">Apellido</label>
                    <input asp-for="Apellido"
                           class="w-full rounded-xl border border-slate-700 bg-slate-800 px-4 py-3 text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                    <span asp-validation-for="Apellido" class="text-xs text-rose-500"></span>
                </div>

                <div class="space-y-2 md:col-span-2">
                    <label asp-for="Telefono" class="text-sm font-semibold text-slate-300">Teléfono</label>
                    <input asp-for="Telefono"
                           class="w-full rounded-xl border border-slate-700 bg-slate-800 px-4 py-3 text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors" />
                    <span asp-validation-for="Telefono" class="text-xs text-rose-500"></span>
                </div>
            </div>
        </section>

        <section class="rounded-2xl border border-slate-800 bg-slate-900/50 p-6 space-y-5">
            <div>
                <h2 class="text-lg font-bold text-white">Asignación</h2>
                <p class="text-sm text-slate-400 mt-1">Roles heredables, sucursal y estado de la cuenta.</p>
            </div>

            <div class="space-y-5">
                <div class="space-y-3">
                    <div class="flex items-center justify-between gap-3">
                        <label asp-for="RolesSeleccionados" class="text-sm font-semibold text-slate-300">Roles</label>
                        <span class="text-xs text-slate-400">Multi-select</span>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 rounded-xl border border-slate-800 bg-slate-800/30 p-3">
                        @if (Model.AllRoles.Any())
                        {
                            @foreach (var role in Model.AllRoles)
                            {
                                var isChecked = Model.RolesSeleccionados.Contains(role, StringComparer.OrdinalIgnoreCase);
                                <label class="flex items-start gap-3 rounded-lg border border-slate-700 bg-slate-900/50 px-3 py-3 cursor-pointer hover:border-primary/40 transition-colors">
                                    <input type="checkbox"
                                           name="RolesSeleccionados"
                                           value="@role"
                                           @(isChecked ? "checked" : null)
                                           class="mt-0.5 size-4 rounded border-slate-600 text-primary focus:ring-primary/50" />
                                    <div class="min-w-0">
                                        <span class="text-sm font-semibold text-slate-100">@role</span>
                                        <p class="text-xs text-slate-400 mt-1">El usuario hereda permisos desde este rol.</p>
                                    </div>
                                </label>
                            }
                        }
                        else
                        {
                            <div class="sm:col-span-2 rounded-lg border border-dashed border-slate-700 px-4 py-6 text-center text-sm text-slate-400">
                                No hay roles disponibles para asignar.
                            </div>
                        }
                    </div>
                    <span asp-validation-for="RolesSeleccionados" class="text-xs text-rose-500"></span>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div class="space-y-2">
                        <label asp-for="SucursalId" class="text-sm font-semibold text-slate-300">Sucursal</label>
                        <select asp-for="SucursalId"
                                class="w-full rounded-xl border border-slate-700 bg-slate-800 px-4 py-3 text-sm focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-colors">
                            <option value="">Sin asignar</option>
                            @foreach (var sucursal in Model.AllSucursales)
                            {
                                <option value="@sucursal.Id">@sucursal.Nombre</option>
                            }
                        </select>
                        <span asp-validation-for="SucursalId" class="text-xs text-rose-500"></span>
                    </div>

                    <div class="flex items-end">
                        <label class="flex items-start gap-3 rounded-xl border border-slate-800 px-4 py-4 bg-slate-800/30 cursor-pointer w-full">
                            <input asp-for="Activo"
                                   class="mt-0.5 size-4 rounded border-slate-600 text-primary focus:ring-primary/50" />
                            <div>
                                <span class="text-sm font-semibold text-white">Usuario activo</span>
                                <p class="text-xs text-slate-400 mt-1">Si se desmarca, la cuenta queda inactiva sin tocar la contraseña.</p>
                            </div>
                        </label>
                    </div>
                </div>
            </div>
        </section>

        <div id="edit-user-footer-actions" class="gap-3 rounded-2xl border border-slate-800 bg-slate-900/50 p-4 sm:px-6 sm:py-5">
            <a href="@backUrl"
               class="edit-user-footer-action inline-flex w-full items-center justify-center rounded-lg px-5 py-3 text-sm font-semibold text-slate-300 hover:bg-slate-800 transition-colors no-underline sm:w-auto">
                Cancelar
            </a>
            <button type="submit"
                    class="edit-user-footer-action inline-flex w-full items-center justify-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-white hover:bg-primary/90 transition-colors sm:w-auto">
                <span class="material-symbols-outlined text-sm">save</span>
                Guardar cambios
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
