@model SeguridadIndexViewModel
@{
    ViewData["Title"] = "Seguridad";
    ViewData["MetaDescription"] = "Gestión de usuarios, roles y permisos del sistema ERP TheBuryProject.";
}

@if (Model.ActiveTab == "usuarios" || Model.ActiveTab == "roles" || Model.ActiveTab == "permisos-rol" || Model.ActiveTab == "auditoria")
{
    <link rel="stylesheet" href="~/css/horizontal-scroll-affordance.css" asp-append-version="true" />
}

<div class="max-w-7xl mx-auto space-y-6">

    @if (Model.ActiveTab == "usuarios")
    {
        @if (Model.UsuariosTab != null)
        {
            <partial name="_SeguridadUsuariosTab" model="Model.UsuariosTab" />
        }
    }
    else if (Model.ActiveTab == "roles")
    {
        @if (Model.RolesTab != null)
        {
            <partial name="_SeguridadRolesTab" model="Model.RolesTab" />
        }
    }
    else if (Model.ActiveTab == "permisos-rol")
    {
        @if (Model.PermisosRolTab != null)
        {
            <partial name="_SeguridadPermisosRolTab" model="Model.PermisosRolTab" />
        }
    }
    else
    {
        @if (Model.AuditoriaTab != null)
        {
            <partial name="_SeguridadAuditoriaTab"
                     model="Model.AuditoriaTab"
                     view-data='new ViewDataDictionary(ViewData)
                     {
                         ["SeguridadAuditoriaFormAction"] = "Index",
                         ["SeguridadAuditoriaIncludeTab"] = true
                     }' />
        }
    }
</div>

@section Scripts {
    @if (Model.ActiveTab == "usuarios")
    {
        <script src="~/js/seguridad-module.js" asp-append-version="true"></script>
        <script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
        <script src="~/js/module-index.js" asp-append-version="true"></script>
        <script src="~/js/seguridad-index.js" asp-append-version="true"></script>
    }
    else if (Model.ActiveTab == "roles")
    {
        <script src="~/js/seguridad-module.js" asp-append-version="true"></script>
        <script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
        <script src="~/js/module-index.js" asp-append-version="true"></script>
        <script src="~/js/seguridad-roles.js" asp-append-version="true"></script>
    }
    else if (Model.ActiveTab == "permisos-rol")
    {
        <script src="~/js/seguridad-module.js" asp-append-version="true"></script>
        <script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
        <script src="~/js/seguridad-permisos-rol.js" asp-append-version="true"></script>
    }
    else if (Model.ActiveTab == "auditoria")
    {
        <script src="~/js/seguridad-module.js" asp-append-version="true"></script>
        <script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
        <script src="~/js/seguridad-auditoria.js" asp-append-version="true"></script>
    }
}
