@model CopiarPermisosRolViewModel
@{
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="fixed inset-0 z-[60]">
    <div id="copyPermissionsBackdrop" class="absolute inset-0 bg-slate-950/80 backdrop-blur-sm opacity-0 transition-opacity duration-300"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
        <div id="copyPermissionsCard" class="w-full max-w-xl bg-slate-900 rounded-2xl shadow-2xl border border-slate-800 overflow-hidden scale-95 opacity-0 transition-all duration-300">
            <div class="px-6 py-5 border-b border-slate-800 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="p-2 rounded-lg bg-amber-500/10 text-amber-500">
                        <span class="material-symbols-outlined">content_copy</span>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold text-white">Copiar permisos</h3>
                        <p class="text-xs text-slate-400 mt-1">Se reemplazarán los permisos actuales del rol destino.</p>
                    </div>
                </div>
                <button type="button" id="closeCopyPermissions" class="row-action">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <form id="formCopyPermissions" asp-controller="Seguridad" asp-action="CopyPermisosRol" method="post" class="space-y-0">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@returnUrl" />
                <input asp-for="RolDestinoId" type="hidden" />

                <div class="p-6 space-y-5">
                    <div id="copyPermissionsErrors" class="hidden rounded-lg border border-rose-500/20 bg-rose-500/10 px-4 py-3 text-sm text-rose-400">
                        <div id="copyPermissionsErrorList" class="space-y-1"></div>
                    </div>

                    <div class="rounded-xl border border-slate-700 bg-slate-800/50 p-4">
                        <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">Rol destino</p>
                        <p class="text-sm font-semibold text-white mt-2">@Model.RolDestinoNombre</p>
                    </div>

                    <div class="space-y-2">
                        <label asp-for="RolOrigenId" class="text-sm font-semibold text-slate-300">Rol origen</label>
                        <select asp-for="RolOrigenId" class="w-full bg-slate-800 border border-slate-700 rounded-lg text-sm px-4 py-3 focus:ring-primary text-white">
                            <option value="">Seleccionar rol origen...</option>
                            @foreach (var rol in Model.RolesDisponibles)
                            {
                                <option value="@rol.Id">@rol.Nombre@(rol.Activo ? string.Empty : " (Inactivo)")</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="px-6 py-5 bg-slate-800/30 flex items-center justify-end gap-3 border-t border-slate-800">
                    <button type="button" id="cancelCopyPermissions"
                            class="btn-erp-ghost">
                        Cancelar
                    </button>
                    <button type="submit" id="submitCopyPermissions"
                            class="btn-erp-primary">
                        <span class="material-symbols-outlined text-sm">content_copy</span>
                        Copiar permisos
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
