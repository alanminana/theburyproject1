@model CrearRolViewModel
@{
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="fixed inset-0 z-[60]">
    <div id="createRoleBackdrop" class="absolute inset-0 bg-slate-950/80 backdrop-blur-sm opacity-0 transition-opacity duration-300"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
        <div id="createRoleCard" class="w-full max-w-2xl bg-slate-900 rounded-2xl shadow-2xl border border-slate-800 overflow-hidden scale-95 opacity-0 transition-all duration-300">
            <div class="px-6 py-5 border-b border-slate-800 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="p-2 rounded-lg bg-primary/10 text-primary">
                        <span class="material-symbols-outlined">shield_person</span>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold text-white">Crear rol</h3>
                        <p class="text-xs text-slate-400 mt-1">Definí el rol base y después configurá sus permisos.</p>
                    </div>
                </div>
                <button type="button" id="closeCreateRole" class="row-action">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <form id="formCreateRole" asp-controller="Seguridad" asp-action="CreateRol" method="post" class="space-y-0">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@returnUrl" />

                <div class="p-6 space-y-5">
                    <div id="createRoleErrors" class="hidden rounded-lg border border-rose-500/20 bg-rose-500/10 px-4 py-3 text-sm text-rose-400">
                        <div id="createRoleErrorList" class="space-y-1"></div>
                    </div>

                    <div class="space-y-2">
                        <label asp-for="Nombre" class="text-sm font-semibold text-slate-300"></label>
                        <input asp-for="Nombre"
                               class="w-full bg-slate-800 border border-slate-700 rounded-lg text-sm px-4 py-3 focus:ring-primary text-white"
                               placeholder="Ej: Supervisor Comercial" />
                    </div>

                    <div class="space-y-2">
                        <label asp-for="Descripcion" class="text-sm font-semibold text-slate-300"></label>
                        <textarea asp-for="Descripcion" rows="4"
                                  class="w-full bg-slate-800 border border-slate-700 rounded-lg text-sm px-4 py-3 focus:ring-primary text-white resize-none"
                                  placeholder="Alcance funcional y criterio de uso del rol."></textarea>
                    </div>

                    <label class="flex items-start gap-3 p-4 rounded-xl border border-slate-700 bg-slate-800/50">
                        <input asp-for="Activo" class="mt-1 size-4 rounded border-slate-600 text-primary focus:ring-primary/50" />
                        <span class="space-y-1">
                            <span class="block text-sm font-semibold text-white">Rol activo</span>
                            <span class="block text-xs text-slate-400">Si queda inactivo, deja de ser utilizable en el flujo operativo y no debe aportar permisos efectivos.</span>
                        </span>
                    </label>
                </div>

                <div class="px-6 py-5 bg-slate-800/30 flex items-center justify-end gap-3 border-t border-slate-800">
                    <button type="button" id="cancelCreateRole"
                            class="btn-erp-ghost">
                        Cancelar
                    </button>
                    <button type="submit" id="submitCreateRole"
                            class="btn-erp-primary">
                        <span class="material-symbols-outlined text-sm">save</span>
                        Guardar rol
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
