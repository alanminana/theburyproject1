@model DuplicarRolViewModel
@{
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="fixed inset-0 z-[60]">
    <div id="duplicateRoleBackdrop" class="absolute inset-0 bg-slate-950/80 backdrop-blur-sm opacity-0 transition-opacity duration-300"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
        <div id="duplicateRoleCard" class="w-full max-w-2xl bg-slate-900 rounded-2xl shadow-2xl border border-slate-800 overflow-hidden scale-95 opacity-0 transition-all duration-300">
            <div class="px-6 py-5 border-b border-slate-800 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="p-2 rounded-lg bg-amber-500/10 text-amber-500">
                        <span class="material-symbols-outlined">content_copy</span>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold text-white">Duplicar rol</h3>
                        <p class="text-xs text-slate-400 mt-1">Se copiarán también los permisos del rol origen.</p>
                    </div>
                </div>
                <button type="button" id="closeDuplicateRole" class="row-action">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <form id="formDuplicateRole" asp-controller="Seguridad" asp-action="DuplicateRol" method="post" class="space-y-0">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@returnUrl" />
                <input asp-for="RolOrigenId" type="hidden" />

                <div class="p-6 space-y-5">
                    <div id="duplicateRoleErrors" class="hidden rounded-lg border border-rose-500/20 bg-rose-500/10 px-4 py-3 text-sm text-rose-400">
                        <div id="duplicateRoleErrorList" class="space-y-1"></div>
                    </div>

                    <div class="rounded-xl border border-slate-700 bg-slate-800/50 p-4">
                        <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">Rol origen</p>
                        <p class="text-sm font-semibold text-white mt-2">@Model.RolOrigenNombre</p>
                    </div>

                    <div class="space-y-2">
                        <label asp-for="Nombre" class="text-sm font-semibold text-slate-300"></label>
                        <input asp-for="Nombre"
                               class="w-full bg-slate-800 border border-slate-700 rounded-lg text-sm px-4 py-3 focus:ring-primary text-white" />
                    </div>

                    <div class="space-y-2">
                        <label asp-for="Descripcion" class="text-sm font-semibold text-slate-300"></label>
                        <textarea asp-for="Descripcion" rows="4"
                                  class="w-full bg-slate-800 border border-slate-700 rounded-lg text-sm px-4 py-3 focus:ring-primary text-white resize-none"></textarea>
                    </div>

                    <label class="flex items-start gap-3 p-4 rounded-xl border border-slate-700 bg-slate-800/50">
                        <input asp-for="Activo" class="mt-1 size-4 rounded border-slate-600 text-primary focus:ring-primary/50" />
                        <span class="space-y-1">
                            <span class="block text-sm font-semibold text-white">Rol activo</span>
                            <span class="block text-xs text-slate-400">El duplicado hereda permisos, pero el estado puede definirse ahora.</span>
                        </span>
                    </label>
                </div>

                <div class="px-6 py-5 bg-slate-800/30 flex items-center justify-end gap-3 border-t border-slate-800">
                    <button type="button" id="cancelDuplicateRole"
                            class="btn-erp-ghost">
                        Cancelar
                    </button>
                    <button type="submit" id="submitDuplicateRole"
                            class="btn-erp-primary">
                        <span class="material-symbols-outlined text-sm">content_copy</span>
                        Duplicar rol
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
