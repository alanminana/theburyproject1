<!DOCTYPE html>
<html class="dark" lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - TheBuryProject</title>

    <meta name="description"
          content="@(ViewData["MetaDescription"] as string ?? "Sistema de gestión integral TheBuryProject")" />

    <link rel="icon" type="image/png" href="~/ico/bury-logo-256.png" asp-append-version="true" />

    <!-- Fuentes locales: Inter + Material Symbols Outlined -->
    <link rel="stylesheet" href="~/css/local-fonts.css" asp-append-version="true" />

    <!-- Tailwind CSS v4 -->
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />

    <!-- App CSS -->
    <link rel="stylesheet" href="~/css/shared-components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)
</head>

<body class="app-layout text-slate-100 font-display" style="background-color:#101622;">
    <a href="#main-content" class="skip-link">Ir al contenido principal</a>

    @{
        string? currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        string? currentAction = ViewContext.RouteData.Values["action"]?.ToString();

        bool IsActive(string controller, string? action = null) =>
            string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) &&
            (action == null || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase));

        string NavClass(bool active) => active
            ? "flex items-center gap-3 px-3 py-2 rounded-lg bg-primary/20 text-primary-on-dark nav-item-active"
            : "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800 hover:text-slate-100 transition-colors cursor-pointer";

        string NavFont(bool active) => active ? "text-sm font-semibold" : "text-sm font-medium";

        string? NavCurrent(bool active) => active ? "page" : null;

        var canViewDashboard = User.TienePermiso("dashboard", "view");
        var canViewNotifications = User.TienePermiso("notificaciones", "view");
        var canViewVentas = User.TienePermiso("ventas", "view");
        var canViewCotizaciones = User.TienePermiso("cotizaciones", "view");
        var canViewClientes = User.TienePermiso("clientes", "view");
        var canViewInventario = canViewCotizaciones;
        var canViewProveedores = User.TienePermiso("proveedores", "view");
        var canViewCaja = User.TienePermiso("caja", "view");
        var canViewReportes = User.TienePermiso("reportes", "view");

        var canViewSeguridad = User.TieneCualquierPermiso(
            ("usuarios", "view"),
            ("roles", "view"),
            ("usuarios", "update"),
            ("roles", "create")
        );

        var canCreateTicket = User.TienePermiso("tickets", "create");
        var canViewTickets = User.TienePermiso("tickets", "view");
        var canViewConfiguracion = User.TienePermiso("configuracion", "view");

        var isDashboardActive = IsActive("Home") || IsActive("Dashboard");

        var showOperaciones = canViewVentas || canViewClientes;
        var showLogistica = canViewInventario || canViewProveedores || canViewCaja;
        var showReportes = canViewReportes;
        var showSistemas = canViewSeguridad || canViewTickets || canViewConfiguracion;
    }

    <div class="flex h-screen overflow-hidden">

        <!-- Sidebar -->
        <aside id="sidebar" class="shrink-0 border-r border-slate-700 flex flex-col" style="background-color:#0c111e;">

            <!-- Brand -->
            <a asp-controller="Home" asp-action="Index" title="TheBuryProject — Inicio"
               class="p-6 flex items-center gap-3 no-underline text-inherit overflow-hidden">

                <div
                    class="size-10 rounded-full shrink-0 overflow-hidden bg-slate-700 flex items-center justify-center">
                    <img src="~/ico/bury-logo-256.png" alt="TheBuryProject" class="w-full h-full object-contain" />
                </div>

                <div class="flex flex-col sidebar-label">
                    <h1 class="text-white text-sm font-bold leading-none whitespace-nowrap">
                        TheBuryProject
                    </h1>
                    <p class="text-slate-300 text-xs mt-1 whitespace-nowrap">
                        SISTEMA GESTIÓN
                    </p>
                </div>
            </a>

            <!-- Nav -->
            <nav class="flex-1 px-4 space-y-8 mt-4 overflow-y-auto overflow-x-hidden">

                @if (canViewDashboard)
                {
                    <div class="space-y-1">
                        <a class="@NavClass(isDashboardActive)" aria-current="@NavCurrent(isDashboardActive)"
                           asp-controller="Home" asp-action="Index" title="Dashboard">
                            <span class="material-symbols-outlined text-lg shrink-0" aria-hidden="true">dashboard</span>
                            <p class="@NavFont(isDashboardActive) sidebar-label">Dashboard</p>
                        </a>
                    </div>
                }

                @if (showOperaciones)
                {
                    <div>
                        <p class="px-3 text-[11px] font-bold text-slate-300 uppercase tracking-widest mb-2 sidebar-label">
                            Operaciones
                        </p>

                        <div class="space-y-1">
                            @if (canViewVentas)
                            {
                                var active = IsActive("Venta");

                                <a class="@NavClass(active)" aria-current="@NavCurrent(active)" asp-controller="Venta"
                                   asp-action="Index" title="Ventas">
                                    <span class="material-symbols-outlined text-lg shrink-0"
                                          aria-hidden="true">shopping_bag</span>
                                    <p class="@NavFont(active) sidebar-label">Ventas</p>
                                </a>
                            }

                          

                            @if (canViewClientes)
                            {
                                var active = IsActive("Cliente");

                                <a class="@NavClass(active)" aria-current="@NavCurrent(active)" asp-controller="Cliente"
                                   asp-action="Index" title="Clientes">
                                    <span class="material-symbols-outlined text-lg shrink-0" aria-hidden="true">group</span>
                                    <p class="@NavFont(active) sidebar-label">Clientes</p>
                                </a>
                            }
                        </div>
                    </div>
                }

                @if (showLogistica)
                {
                    <div>
                        <p class="px-3 text-[11px] font-bold text-slate-300 uppercase tracking-widest mb-2 sidebar-label">
                            Logística
                        </p>

                        <div class="space-y-1">
                            @if (canViewInventario)
                            {
                                var active = IsActive("Catalogo");

                                <a class="@NavClass(active)" aria-current="@NavCurrent(active)" asp-controller="Catalogo"
                                   asp-action="Index" title="Inventario">
                                    <span class="material-symbols-outlined text-lg shrink-0"
                                          aria-hidden="true">inventory_2</span>
                                    <p class="@NavFont(active) sidebar-label">Inventario</p>
                                </a>
                            }

                            @if (canViewProveedores)
                            {
                                var active = IsActive("Proveedor");

                                <a class="@NavClass(active)" aria-current="@NavCurrent(active)" asp-controller="Proveedor"
                                   asp-action="Index" title="Proveedores">
                                    <span class="material-symbols-outlined text-lg shrink-0"
                                          aria-hidden="true">local_shipping</span>
                                    <p class="@NavFont(active) sidebar-label">Proveedores</p>
                                </a>
                            }

                            @if (canViewCaja)
                            {
                                var active = IsActive("Caja");

                                <a class="@NavClass(active)" aria-current="@NavCurrent(active)" asp-controller="Caja"
                                   asp-action="Index" title="Cajas">
                                    <span class="material-symbols-outlined text-lg shrink-0"
                                          aria-hidden="true">point_of_sale</span>
                                    <p class="@NavFont(active) sidebar-label">Cajas</p>
                                </a>
                            }
                        </div>
                    </div>
                }

                @if (showReportes)
                {
                    var active = IsActive("Reporte", "Index");

                    <div>
                        <p class="px-3 text-[11px] font-bold text-slate-300 uppercase tracking-widest mb-2 sidebar-label">
                            Reportes
                        </p>

                        <div class="space-y-1">
                            <a class="@NavClass(active)" aria-current="@NavCurrent(active)" asp-controller="Reporte"
                               asp-action="Index" title="Reportes">
                                <span class="material-symbols-outlined text-lg shrink-0"
                                      aria-hidden="true">leaderboard</span>
                                <p class="@NavFont(active) sidebar-label">Reportes</p>
                            </a>
                        </div>
                    </div>
                }

                @if (showSistemas)
                {
                    <div>
                        <p class="px-3 text-[11px] font-bold text-slate-300 uppercase tracking-widest mb-2 sidebar-label">
                            Sistemas
                        </p>

                        <div class="space-y-1">
                            @if (canViewSeguridad)
                            {
                                var active = IsActive("Seguridad") || IsActive("Usuarios") || IsActive("Roles");

                                <a class="@NavClass(active)" aria-current="@NavCurrent(active)" asp-controller="Seguridad"
                                   asp-action="Index" title="Seguridad">
                                    <span class="material-symbols-outlined text-lg shrink-0" aria-hidden="true">security</span>
                                    <p class="@NavFont(active) sidebar-label">Seguridad</p>
                                </a>
                            }

                            @if (canViewTickets)
                            {
                                var active = IsActive("Ticket");

                                <a class="@NavClass(active)" aria-current="@NavCurrent(active)" asp-controller="Ticket"
                                   asp-action="Index" title="Tickets">
                                    <span class="material-symbols-outlined text-lg shrink-0"
                                          aria-hidden="true">bug_report</span>
                                    <p class="@NavFont(active) sidebar-label">Tickets</p>
                                </a>
                            }

                            @if (canViewConfiguracion)
                            {
                                var active = IsActive("PlantillaContratoCredito");

                                <a class="@NavClass(active)" aria-current="@NavCurrent(active)"
                                   asp-controller="PlantillaContratoCredito" asp-action="Index" title="Plantillas contrato">
                                    <span class="material-symbols-outlined text-lg shrink-0" aria-hidden="true">contract</span>
                                    <p class="@NavFont(active) sidebar-label">Plantillas contrato</p>
                                </a>
                            }
                        </div>
                    </div>
                }
            </nav>

            <!-- User info -->
            <div class="p-4 border-t border-slate-700">
                @{
                    var userRoles = User.Claims
                        .Where(c => c.Type == System.Security.Claims.ClaimTypes.Role)
                        .Select(c => c.Value)
                        .ToList();

                    var roleDisplay = userRoles.Any()
                        ? string.Join(", ", userRoles)
                        : "Usuario";
                }

                <div class="flex items-center gap-3 p-2 overflow-hidden">
                    <div
                        class="size-8 rounded-full bg-slate-700 overflow-hidden flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined text-slate-300 text-lg shrink-0"
                              aria-hidden="true">account_circle</span>
                    </div>

                    <div class="flex flex-col sidebar-label min-w-0">
                        <p class="text-xs font-bold text-white leading-none whitespace-nowrap truncate">
                            @(User.Identity?.Name ?? "?")
                        </p>
                        <p class="text-xs text-slate-300 mt-1 whitespace-nowrap truncate">
                            @roleDisplay
                        </p>
                    </div>
                </div>

                <form method="post" asp-area="Identity" asp-page="/Account/Logout"
                      asp-route-returnUrl="@Url.Action("Index", "Home", new { area = string.Empty })"
                      class="sidebar-label mt-1">

                    <button type="submit"
                            class="w-full flex items-center gap-2 px-3 py-2 rounded-lg text-slate-400 hover:bg-rose-500/10 hover:text-rose-500 transition-colors text-xs font-medium cursor-pointer border-0 bg-transparent">
                        <span class="material-symbols-outlined icon-erp" aria-hidden="true">logout</span>
                        <span>Cerrar sesión</span>
                    </button>
                </form>
            </div>

            <!-- Collapse toggle desktop -->
            <div class="hidden lg:flex p-3 border-t border-slate-700 justify-center">
                <button id="collapseSidebar" type="button"
                        class="p-2 rounded-lg hover:bg-slate-800 text-slate-400 hover:text-slate-200 transition-colors"
                        aria-label="Colapsar/expandir sidebar" title="Colapsar sidebar">
                    <span class="material-symbols-outlined text-lg transition-transform duration-300" id="collapseIcon"
                          aria-hidden="true">chevron_left</span>
                </button>
            </div>
        </aside>

        <!-- Overlay mobile -->
        <div id="sidebarOverlay" class="fixed inset-0 bg-black/50 z-40 hidden lg:hidden" aria-hidden="true"></div>

        <!-- Main content -->
        <main id="main-content" tabindex="-1" class="flex-1 flex flex-col overflow-hidden">

            <!-- Header -->
            <header class="h-16 border-b border-slate-700 flex items-center justify-between px-4 sm:px-6 lg:px-8"
                    style="background-color:#101622;">

                <div class="flex items-center gap-6 min-w-0">
                    <!-- Mobile toggle -->
                    <button id="toggleSidebar" type="button" class="p-2 rounded-lg hover:bg-slate-800 lg:hidden"
                            aria-label="Abrir/cerrar menú" aria-expanded="false" aria-controls="sidebar">
                        <span class="material-symbols-outlined icon-size-22" aria-hidden="true">menu</span>
                    </button>

                    <!-- Page title -->
                    <h2 class="text-lg font-bold text-white hidden lg:block truncate">
                        @ViewData["Title"]
                    </h2>

                    <div class="h-6 w-px bg-slate-700 hidden lg:block"></div>

                    <!-- Cotizaciones -->
                    <div class="hidden lg:flex gap-3">
                        <div
                            class="flex items-center gap-2 bg-slate-800 px-3 py-1 rounded-full border border-slate-700">
                            <span class="text-xs font-bold text-slate-300 uppercase tracking-tighter">Dolar Blue</span>
                            <span class="text-xs font-bold text-emerald-400">$1.245,00</span>
                        </div>

                        <div
                            class="flex items-center gap-2 bg-slate-800 px-3 py-1 rounded-full border border-slate-700">
                            <span class="text-xs font-bold text-slate-300 uppercase tracking-tighter">Tarjeta</span>
                            <span class="text-xs font-bold text-primary-on-dark">$1.482,50</span>
                        </div>

                        <div
                            class="flex items-center gap-2 bg-slate-800 px-3 py-1 rounded-full border border-slate-700">
                            <span class="text-xs font-bold text-slate-300 uppercase tracking-tighter">Oficial</span>
                            <span class="text-xs font-bold text-slate-300">$942,00</span>
                        </div>
                    </div>
                </div>

                <div class="flex items-center gap-4 shrink-0">
                    <!-- Notifications -->
                    @if (canViewNotifications)
                    {
                        <button type="button" aria-label="Notificaciones"
                                class="p-2 text-slate-400 hover:text-white transition-colors relative">
                            <span class="material-symbols-outlined icon-erp-lg" aria-hidden="true">notifications</span>
                            <span
                            class="absolute top-2 right-2 size-2 bg-red-500 rounded-full border-2 border-white border-background-dark"
                            aria-hidden="true"></span>
                        </button>
                    }

                    <!-- Search -->
                    <button type="button" aria-label="Buscar"
                            class="p-2 text-slate-400 hover:text-white transition-colors">
                        <span class="material-symbols-outlined icon-erp-lg" aria-hidden="true">search</span>
                    </button>

                    <!-- Ticket panel -->
                    @if (canViewTickets)
                    {
                        <button id="btn-open-ticket-panel" type="button"
                                class="p-2 text-slate-400 hover:text-white transition-colors" title="Incidentes"
                                aria-label="Panel de incidentes">
                            <span class="material-symbols-outlined icon-erp-lg" aria-hidden="true">assignment</span>
                        </button>
                    }

                    <div class="h-8 w-px bg-slate-700"></div>

                    <!-- Help -->
                    <button type="button" aria-label="Ayuda"
                            class="bg-primary/10 hover:bg-primary/20 text-primary-on-dark p-2 rounded-lg transition-colors">
                        <span class="material-symbols-outlined icon-erp-lg" aria-hidden="true">help</span>
                    </button>
                </div>
            </header>

            <!-- Page content -->
            <div class="flex-1 overflow-y-auto px-4 py-8 sm:px-6 lg:px-8" style="background-color:#101622;">
                @RenderBody()
            </div>
        </main>
    </div>

    <!-- Floating ticket button -->
    @if (canCreateTicket)
    {
        <button type="button" data-open-ticket-modal class="floating-ticket-action fixed bottom-6 right-6 z-40 flex items-center gap-2
            bg-slate-700 hover:bg-slate-600 border border-slate-600 hover:border-slate-500
            text-slate-200 text-sm px-4 py-2.5 rounded-full shadow-lg transition-colors"
                title="Reportar una incidencia o mejora">
            <span class="material-symbols-outlined icon-erp text-amber-400" aria-hidden="true">bug_report</span>
            <span class="hidden sm:inline">Reportar incidencia</span>
        </button>
    }

    <!-- Modals -->
    @await RenderSectionAsync("Modals", required: false)

    <partial name="_ConfirmModal" />

    @if (canCreateTicket)
    {
        <partial name="_TicketModal" />
    }

    @if (canViewTickets)
    {
        <partial name="_TicketPanel" />
    }

    <!-- Vendor JS -->
    <script src="~/lib/jquery/dist/jquery.min.js" asp-append-version="true"></script>

    <!-- App JS -->
    <script src="~/js/shared-ui.js" asp-append-version="true"></script>

    @if (canViewNotifications)
    {
        <script src="~/lib/signalr/signalr.min.js" asp-append-version="true"></script>

        <script src="~/js/notificaciones.js" asp-append-version="true"></script>
    }

    <script src="~/js/layout.js" asp-append-version="true"></script>

    @if (canCreateTicket)
    {
        <script src="~/js/ticket-modal.js" asp-append-version="true"></script>
    }

    @if (canViewTickets)
    {
        <script src="~/js/ticket-panel.js" asp-append-version="true"></script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
