@model SeguridadAuditoriaViewModel
@{
    Func<string, string> badgeClasses = accion => accion.ToLowerInvariant() switch
    {
        "crear" => "bg-emerald-900/30 text-emerald-400",
        "editar" => "bg-amber-900/30 text-amber-400",
        "eliminar" => "bg-rose-900/30 text-rose-400",
        "bloquear" => "bg-rose-900/30 text-rose-400",
        "desbloquear" => "bg-emerald-900/30 text-emerald-400",
        "reset password" => "bg-orange-900/30 text-orange-400",
        "permisos" => "bg-violet-900/30 text-violet-400",
        "login" => "bg-blue-900/30 text-blue-400",
        _ => "bg-slate-800 text-slate-300"
    };

    Func<string, string> getInitials = usuario =>
    {
        var parts = usuario.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length == 0
            ? "?"
            : string.Concat(parts.Take(2).Select(p => char.ToUpperInvariant(p[0])));
    };

    Func<int, string> avatarClasses = index => (index % 4) switch
    {
        0 => "bg-blue-900/30 text-blue-400",
        1 => "bg-violet-900/30 text-violet-400",
        2 => "bg-slate-800 text-slate-300",
        _ => "bg-cyan-900/30 text-cyan-400"
    };

    var totalResultados = Model.Registros.Count;
    var rangoMostrado = totalResultados == 0 ? "0-0" : $"1-{totalResultados}";
    var formAction = ViewData["SeguridadAuditoriaFormAction"]?.ToString() ?? "Auditoria";
    var includeTab = ViewData["SeguridadAuditoriaIncludeTab"] as bool? ?? false;
}

<div class="max-w-7xl mx-auto space-y-6">
    <form asp-controller="Seguridad" asp-action="@formAction" method="get"
          class="bg-slate-900/50 p-6 rounded-xl border border-slate-800 shadow-sm space-y-5">
        @if (includeTab)
        {
            <input type="hidden" name="tab" value="auditoria" />
        }

        <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
            <div class="space-y-1">
                <p class="text-sm font-semibold text-white">Filtros de consulta</p>
                <p class="text-xs text-slate-400">Acotá el histórico por actor, módulo, acción o rango de fechas antes de revisar la tabla completa.</p>
            </div>
            <div class="flex flex-wrap gap-2 text-xs font-medium text-slate-400">
                <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-800 px-3 py-1">
                    <span class="material-symbols-outlined text-sm">table_rows</span>
                    Mostrando @rangoMostrado
                </span>
                <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-800 px-3 py-1">
                    <span class="material-symbols-outlined text-sm">rule_settings</span>
                    @totalResultados resultados
                </span>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4 items-end">
            <div class="space-y-2">
                <label for="usuario" class="text-sm font-semibold text-slate-300">Usuario</label>
                <select id="usuario" name="usuario"
                        class="w-full bg-slate-800 border border-slate-700 rounded-lg text-sm px-4 py-3 focus:ring-primary text-white">
                    <option value="">Todos los usuarios</option>
                    @foreach (var usuario in Model.Usuarios)
                    {
                        if (string.Equals(Model.UsuarioSeleccionado, usuario, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@usuario" selected>@usuario</option>
                        }
                        else
                        {
                            <option value="@usuario">@usuario</option>
                        }
                    }
                </select>
            </div>

            <div class="space-y-2">
                <label for="modulo" class="text-sm font-semibold text-slate-300">Módulo</label>
                <select id="modulo" name="modulo"
                        class="w-full bg-slate-800 border border-slate-700 rounded-lg text-sm px-4 py-3 focus:ring-primary text-white">
                    <option value="">Todos los módulos</option>
                    @foreach (var modulo in Model.Modulos)
                    {
                        if (string.Equals(Model.ModuloSeleccionado, modulo, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@modulo" selected>@modulo</option>
                        }
                        else
                        {
                            <option value="@modulo">@modulo</option>
                        }
                    }
                </select>
            </div>

            <div class="space-y-2">
                <label for="accion" class="text-sm font-semibold text-slate-300">Acción</label>
                <select id="accion" name="accion"
                        class="w-full bg-slate-800 border border-slate-700 rounded-lg text-sm px-4 py-3 focus:ring-primary text-white">
                    <option value="">Todas las acciones</option>
                    @foreach (var accion in Model.Acciones)
                    {
                        if (string.Equals(Model.AccionSeleccionada, accion, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@accion" selected>@accion</option>
                        }
                        else
                        {
                            <option value="@accion">@accion</option>
                        }
                    }
                </select>
            </div>

            <div class="space-y-2">
                <label class="text-sm font-semibold text-slate-300">Rango de fechas</label>
                <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
                    <input id="desde" name="desde" type="date" value="@(Model.Desde?.ToString("yyyy-MM-dd"))"
                           class="w-full bg-slate-800 border border-slate-700 rounded-lg text-sm px-4 py-3 focus:ring-primary text-white" />
                    <input id="hasta" name="hasta" type="date" value="@(Model.Hasta?.ToString("yyyy-MM-dd"))"
                           class="w-full bg-slate-800 border border-slate-700 rounded-lg text-sm px-4 py-3 focus:ring-primary text-white" />
                </div>
            </div>

            <div class="flex flex-col gap-2 sm:flex-row">
                <button type="submit"
                        class="btn-erp-primary flex-1 justify-center">
                    <span class="material-symbols-outlined text-sm">filter_alt</span>
                    Buscar
                </button>
                @if (includeTab)
                {
                    <a asp-controller="Seguridad" asp-action="Index" asp-route-tab="auditoria"
                       class="btn-erp-ghost no-underline">
                        Limpiar
                    </a>
                }
                else
                {
                    <a asp-controller="Seguridad" asp-action="Auditoria"
                       class="btn-erp-ghost no-underline">
                        Limpiar
                    </a>
                }
            </div>
        </div>
    </form>

    <div class="bg-slate-900/50 rounded-xl border border-slate-800 overflow-hidden shadow-sm">
        <nav class="flex overflow-x-auto border-b border-slate-800">
            <a asp-controller="Seguridad" asp-action="Index" asp-route-tab="usuarios" class="shrink-0 border-b-2 border-transparent text-slate-400 hover:text-white hover:bg-white/5 px-5 py-3 text-sm font-bold no-underline transition-colors">Usuarios</a>
            <a asp-controller="Seguridad" asp-action="Index" asp-route-tab="roles" class="shrink-0 border-b-2 border-transparent text-slate-400 hover:text-white hover:bg-white/5 px-5 py-3 text-sm font-bold no-underline transition-colors">Roles</a>
            <a asp-controller="Seguridad" asp-action="Index" asp-route-tab="permisos-rol" class="shrink-0 border-b-2 border-transparent text-slate-400 hover:text-white hover:bg-white/5 px-5 py-3 text-sm font-bold no-underline transition-colors">Permisos de Rol</a>
            <a asp-controller="Seguridad" asp-action="Index" asp-route-tab="auditoria" class="shrink-0 border-b-2 border-primary text-primary bg-primary/10 px-5 py-3 text-sm font-bold no-underline transition-colors">Auditoría</a>
        </nav>
        <div class="border-b border-slate-800 px-6 py-5 bg-slate-900/40">
            <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
                <div class="space-y-1">
                    <p class="text-sm font-semibold text-white">Timeline de eventos auditados</p>
                    <p class="text-xs text-slate-400">Cada fila combina fecha, actor, acción y entidad afectada para acelerar revisión operativa.</p>
                </div>
                <div class="flex flex-wrap gap-2 text-xs font-medium text-slate-400">
                    <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-900 px-3 py-1 border border-slate-700">
                        <span class="material-symbols-outlined text-sm">summarize</span>
                        @totalResultados registros
                    </span>
                    <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-900 px-3 py-1 border border-slate-700">
                        <span class="material-symbols-outlined text-sm">calendar_month</span>
                        Rango @rangoMostrado
                    </span>
                </div>
            </div>
        </div>
        <div data-oc-scroll class="relative" style="--oc-scroll-min-width: 980px;">
            <div data-oc-scroll-hint hidden class="px-4 pt-4 text-xs font-semibold uppercase tracking-[0.16em] text-slate-400 lg:hidden">
                Deslizá para ver toda la auditoría
            </div>
            <div data-oc-scroll-shell class="relative">
                <div data-oc-scroll-fade="left" hidden class="absolute inset-y-0 left-0 z-10 w-6 bg-gradient-to-r from-slate-900 via-slate-900/95 to-transparent"></div>
                <div data-oc-scroll-fade="right" hidden class="absolute inset-y-0 right-0 z-10 w-6 bg-gradient-to-l from-slate-900 via-slate-900/95 to-transparent"></div>
                <div data-oc-scroll-region class="overflow-x-auto scroll-smooth" tabindex="0" role="region" aria-label="Registro de auditoría">
            <table data-oc-scroll-table class="w-full text-left border-collapse" style="min-width: var(--oc-scroll-min-width);">
                <thead>
                    <tr class="bg-slate-800/50 border-b border-slate-800">
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Fecha / Hora</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Usuario</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Acción</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Módulo</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Entidad</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-400">Detalle</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800">
                    @if (Model.Registros.Any())
                    {
                        @for (var i = 0; i < Model.Registros.Count; i++)
                        {
                            var registro = Model.Registros[i];

                            <tr class="hover:bg-slate-800/30 transition-colors">
                                <td class="px-6 py-4 whitespace-nowrap text-sm">
                                    <div class="font-medium text-white">@registro.FechaHora.ToString("dd MMM yyyy")</div>
                                    <div class="text-xs text-slate-400">@registro.FechaHora.ToString("HH:mm:ss")</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center gap-3">
                                        <div class="size-8 rounded-full flex items-center justify-center text-xs font-bold uppercase @avatarClasses(i)">
                                            @getInitials(registro.Usuario)
                                        </div>
                                        <span class="text-sm font-medium text-white">@registro.Usuario</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium uppercase @badgeClasses(registro.Accion)">
                                        @registro.Accion
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-400">@registro.Modulo</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-white">@registro.Entidad</td>
                                <td class="px-6 py-4 text-sm text-slate-400 max-w-xs">
                                    <span class="block truncate" title="@registro.Detalle">@registro.Detalle</span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="px-6 py-14 text-center">
                                <div class="inline-flex items-center justify-center size-14 rounded-full bg-slate-800 mb-4">
                                    <span class="material-symbols-outlined text-3xl text-slate-400 text-slate-500">history</span>
                                </div>
                                <p class="text-sm font-semibold text-slate-300">No hay registros para los filtros aplicados</p>
                                <p class="text-xs text-slate-500 mt-1">Probá cambiando usuario, módulo, acción o rango de fechas.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
                </div>
            </div>
        </div>

        <div class="px-6 py-4 flex flex-col gap-3 border-t border-slate-800 bg-slate-800/30 text-center sm:flex-row sm:items-center sm:justify-between sm:text-left">
            <span class="text-xs text-slate-500 font-medium">Mostrando @rangoMostrado de @totalResultados resultados</span>
            <div class="flex gap-1">
                <button type="button"
                        class="p-1 rounded border border-slate-700 text-slate-400 disabled:opacity-50"
                        disabled>
                    <span class="material-symbols-outlined text-base">chevron_left</span>
                </button>
                <button type="button" class="px-3 py-1 rounded bg-primary text-white text-xs font-bold">1</button>
                <button type="button"
                        class="p-1 rounded border border-slate-700 text-slate-400 disabled:opacity-50"
                        disabled>
                    <span class="material-symbols-outlined text-base">chevron_right</span>
                </button>
            </div>
        </div>
    </div>
</div>
