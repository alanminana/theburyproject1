@model SeguridadAuditoriaViewModel
@{
    Func<string, string> badgeClasses = accion => accion.ToLowerInvariant() switch
    {
        "crear" => "bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400",
        "editar" => "bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400",
        "eliminar" => "bg-rose-100 text-rose-800 dark:bg-rose-900/30 dark:text-rose-400",
        "bloquear" => "bg-rose-100 text-rose-800 dark:bg-rose-900/30 dark:text-rose-400",
        "desbloquear" => "bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400",
        "reset password" => "bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-400",
        "permisos" => "bg-violet-100 text-violet-800 dark:bg-violet-900/30 dark:text-violet-400",
        "login" => "bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400",
        _ => "bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-300"
    };

    Func<string, string> getInitials = usuario =>
    {
        var parts = usuario.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length == 0
            ? "?"
            : string.Concat(parts.Take(2).Select(p => char.ToUpperInvariant(p[0])));
    };

    Func<int, string> avatarClasses = index => (index % 4) switch
    {
        0 => "bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400",
        1 => "bg-violet-100 text-violet-700 dark:bg-violet-900/30 dark:text-violet-400",
        2 => "bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-300",
        _ => "bg-cyan-100 text-cyan-700 dark:bg-cyan-900/30 dark:text-cyan-400"
    };

    var totalResultados = Model.Registros.Count;
    var rangoMostrado = totalResultados == 0 ? "0-0" : $"1-{totalResultados}";
    var formAction = ViewData["SeguridadAuditoriaFormAction"]?.ToString() ?? "Auditoria";
    var includeTab = ViewData["SeguridadAuditoriaIncludeTab"] as bool? ?? false;
}

<div class="max-w-7xl mx-auto space-y-6">
    <div>
        <h3 class="text-2xl font-bold text-slate-900 dark:text-white">Registro de Auditoría</h3>
        <p class="text-slate-500 dark:text-slate-400 mt-1">
            Seguimiento histórico de actividades y cambios relevantes realizados en el sistema.
        </p>
    </div>

    <form asp-controller="Seguridad" asp-action="@formAction" method="get"
          class="bg-white dark:bg-slate-900/50 p-6 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
        @if (includeTab)
        {
            <input type="hidden" name="tab" value="auditoria" />
        }

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4 items-end">
            <div class="space-y-2">
                <label for="usuario" class="text-sm font-medium text-slate-700 dark:text-slate-300">Usuario</label>
                <select id="usuario" name="usuario"
                        class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-primary text-slate-900 dark:text-white">
                    <option value="">Todos los usuarios</option>
                    @foreach (var usuario in Model.Usuarios)
                    {
                        if (string.Equals(Model.UsuarioSeleccionado, usuario, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@usuario" selected>@usuario</option>
                        }
                        else
                        {
                            <option value="@usuario">@usuario</option>
                        }
                    }
                </select>
            </div>

            <div class="space-y-2">
                <label for="modulo" class="text-sm font-medium text-slate-700 dark:text-slate-300">Módulo</label>
                <select id="modulo" name="modulo"
                        class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-primary text-slate-900 dark:text-white">
                    <option value="">Todos los módulos</option>
                    @foreach (var modulo in Model.Modulos)
                    {
                        if (string.Equals(Model.ModuloSeleccionado, modulo, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@modulo" selected>@modulo</option>
                        }
                        else
                        {
                            <option value="@modulo">@modulo</option>
                        }
                    }
                </select>
            </div>

            <div class="space-y-2">
                <label for="accion" class="text-sm font-medium text-slate-700 dark:text-slate-300">Acción</label>
                <select id="accion" name="accion"
                        class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-primary text-slate-900 dark:text-white">
                    <option value="">Todas las acciones</option>
                    @foreach (var accion in Model.Acciones)
                    {
                        if (string.Equals(Model.AccionSeleccionada, accion, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@accion" selected>@accion</option>
                        }
                        else
                        {
                            <option value="@accion">@accion</option>
                        }
                    }
                </select>
            </div>

            <div class="space-y-2">
                <label class="text-sm font-medium text-slate-700 dark:text-slate-300">Rango de fechas</label>
                <div class="flex gap-2">
                    <input id="desde" name="desde" type="date" value="@(Model.Desde?.ToString("yyyy-MM-dd"))"
                           class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-primary text-slate-900 dark:text-white" />
                    <input id="hasta" name="hasta" type="date" value="@(Model.Hasta?.ToString("yyyy-MM-dd"))"
                           class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-primary text-slate-900 dark:text-white" />
                </div>
            </div>

            <div class="flex gap-2">
                <button type="submit"
                        class="flex-1 bg-primary hover:bg-primary/90 text-white font-bold py-2.5 rounded-lg transition-colors flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-sm">filter_alt</span>
                    Buscar
                </button>
                @if (includeTab)
                {
                    <a asp-controller="Seguridad" asp-action="Index" asp-route-tab="auditoria"
                       class="px-4 py-2.5 rounded-lg border border-slate-200 dark:border-slate-700 text-sm font-semibold text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors no-underline">
                        Limpiar
                    </a>
                }
                else
                {
                    <a asp-controller="Seguridad" asp-action="Auditoria"
                       class="px-4 py-2.5 rounded-lg border border-slate-200 dark:border-slate-700 text-sm font-semibold text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors no-underline">
                        Limpiar
                    </a>
                }
            </div>
        </div>
    </form>

    <div class="bg-white dark:bg-slate-900/50 rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse min-w-[980px]">
                <thead>
                    <tr class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-800">
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Fecha / Hora</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Usuario</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Acción</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Módulo</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Entidad</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Detalle</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 dark:divide-slate-800">
                    @if (Model.Registros.Any())
                    {
                        @for (var i = 0; i < Model.Registros.Count; i++)
                        {
                            var registro = Model.Registros[i];

                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors">
                                <td class="px-6 py-4 whitespace-nowrap text-sm">
                                    <div class="font-medium text-slate-900 dark:text-white">@registro.FechaHora.ToString("dd MMM yyyy")</div>
                                    <div class="text-xs text-slate-500 dark:text-slate-400">@registro.FechaHora.ToString("HH:mm:ss")</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center gap-3">
                                        <div class="size-8 rounded-full flex items-center justify-center text-xs font-bold uppercase @avatarClasses(i)">
                                            @getInitials(registro.Usuario)
                                        </div>
                                        <span class="text-sm font-medium text-slate-900 dark:text-white">@registro.Usuario</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium uppercase @badgeClasses(registro.Accion)">
                                        @registro.Accion
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 dark:text-slate-400">@registro.Modulo</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-slate-900 dark:text-white">@registro.Entidad</td>
                                <td class="px-6 py-4 text-sm text-slate-500 dark:text-slate-400 max-w-xs truncate" title="@registro.Detalle">
                                    @registro.Detalle
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="px-6 py-14 text-center">
                                <div class="inline-flex items-center justify-center size-14 rounded-full bg-slate-100 dark:bg-slate-800 mb-4">
                                    <span class="material-symbols-outlined text-3xl text-slate-400 dark:text-slate-500">history</span>
                                </div>
                                <p class="text-sm font-semibold text-slate-700 dark:text-slate-300">No hay registros para los filtros aplicados</p>
                                <p class="text-xs text-slate-500 mt-1">Probá cambiando usuario, módulo, acción o rango de fechas.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="px-6 py-4 flex items-center justify-between border-t border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-800/30">
            <span class="text-xs text-slate-500 font-medium">Mostrando @rangoMostrado de @totalResultados resultados</span>
            <div class="flex gap-1">
                <button type="button"
                        class="p-1 rounded border border-slate-200 dark:border-slate-700 text-slate-400 disabled:opacity-50"
                        disabled>
                    <span class="material-symbols-outlined text-base">chevron_left</span>
                </button>
                <button type="button" class="px-3 py-1 rounded bg-primary text-white text-xs font-bold">1</button>
                <button type="button"
                        class="p-1 rounded border border-slate-200 dark:border-slate-700 text-slate-400 disabled:opacity-50"
                        disabled>
                    <span class="material-symbols-outlined text-base">chevron_right</span>
                </button>
            </div>
        </div>
    </div>
</div>
