@model SeguridadPermisosRolViewModel
@{
    var currentUrl = Context.Request.Path + Context.Request.QueryString;
    var totalModules = Model.Filas.Count;
    var totalSelectedPermissions = Model.Filas.SelectMany(f => f.Celdas).Count(c => c.Seleccionado);
}

<div class="max-w-7xl mx-auto space-y-6">
    @if (TempData["Success"] != null)
    {
        <div class="toast-msg flex items-center gap-3 rounded-xl border border-emerald-500/20 bg-emerald-500/10 p-4 text-sm font-semibold text-emerald-400" role="status">
            <div class="bg-emerald-500/20 text-emerald-500 p-2 rounded-lg">
                <span class="material-symbols-outlined">check_circle</span>
            </div>
            <div>
                <p class="text-emerald-500 text-sm font-bold leading-tight">Operación exitosa</p>
                <p class="text-emerald-500/80 text-xs font-medium">@TempData["Success"]</p>
            </div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="toast-msg flex items-center gap-3 rounded-xl border border-rose-500/20 bg-rose-500/10 p-4 text-sm font-semibold text-rose-400" role="alert">
            <div class="bg-rose-500/20 text-rose-500 p-2 rounded-lg">
                <span class="material-symbols-outlined">error</span>
            </div>
            <div>
                <p class="text-rose-500 text-sm font-bold leading-tight">Error</p>
                <p class="text-rose-500/80 text-xs font-medium">@TempData["Error"]</p>
            </div>
        </div>
    }

    <div class="bg-slate-900/50 p-6 rounded-xl border border-slate-800 shadow-sm space-y-5">
        <div class="grid grid-cols-1 lg:grid-cols-[minmax(260px,320px)_minmax(0,1fr)_220px_auto] gap-4 items-end">
            <form method="get" asp-controller="Seguridad" asp-action="Index" class="contents">
                <input type="hidden" name="tab" value="permisos-rol" />

                <div class="space-y-2">
                    <label for="permissionRoleSelect" class="text-sm font-semibold text-slate-300">Rol</label>
                    <select id="permissionRoleSelect" name="roleId" class="w-full bg-slate-800 border border-slate-700 rounded-lg text-sm px-4 py-3 focus:ring-primary text-white" required>
                        <option value="">Seleccionar rol...</option>
                        @foreach (var rol in Model.Roles)
                        {
                            <option value="@rol.Id" selected="@(Model.RolSeleccionadoId == rol.Id ? "selected" : null)">
                                @rol.Nombre@(rol.Activo ? string.Empty : " (Inactivo)")
                            </option>
                        }
                    </select>
                </div>

                <div class="space-y-2">
                    <label for="searchPermissionModules" class="text-sm font-semibold text-slate-300">Buscar módulo</label>
                    <input id="searchPermissionModules" type="text" value="@Model.BuscarModulo"
                           class="w-full bg-slate-800 border border-slate-700 rounded-lg text-sm px-4 py-3 focus:ring-primary text-white"
                           placeholder="Ej: usuarios, ventas, caja..." />
                </div>

                <div class="space-y-2">
                    <label for="permissionGroupFilter" class="text-sm font-semibold text-slate-300">Grupo</label>
                    <select id="permissionGroupFilter" class="w-full bg-slate-800 border border-slate-700 rounded-lg text-sm px-4 py-3 focus:ring-primary text-white">
                        <option value="">Todos los grupos</option>
                        @foreach (var grupo in Model.Grupos)
                        {
                            <option value="@grupo" selected="@(Model.GrupoSeleccionado == grupo ? "selected" : null)">@grupo</option>
                        }
                    </select>
                </div>

                <div class="flex items-center gap-2 justify-end">
                    <button type="submit"
                            class="btn-erp-primary">
                        <span class="material-symbols-outlined text-sm">grid_view</span>
                        Cargar matriz
                    </button>
                    <button type="button" id="clearPermissionFilters"
                            class="btn-erp-ghost"
                            title="Limpiar filtros">
                        <span class="material-symbols-outlined text-lg">filter_list_off</span>
                    </button>
                </div>
            </form>
        </div>

        @if (Model.TieneRolSeleccionado)
        {
            <div class="flex flex-col gap-4 rounded-xl border border-primary/15 bg-primary/5 px-4 py-4 lg:flex-row lg:items-center lg:justify-between">
                <div class="space-y-3">
                    <div>
                        <p class="text-sm font-semibold text-white">Rol actual: @Model.RolSeleccionadoNombre</p>
                        <p class="text-xs text-slate-400 mt-1">Los permisos se guardan a nivel rol. Los usuarios los heredan automáticamente.</p>
                    </div>
                    <div class="flex flex-wrap gap-2 text-xs font-medium text-slate-400">
                        <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-900/70 px-3 py-1">
                            <span class="material-symbols-outlined text-sm">view_module</span>
                            @totalModules módulos
                        </span>
                        <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-900/70 px-3 py-1">
                            <span class="material-symbols-outlined text-sm">checklist</span>
                            <span id="permissionsSelectedPill">@totalSelectedPermissions</span> permisos activos
                        </span>
                    </div>
                </div>
                <div id="permissionsRoleActions" class="flex w-full flex-col gap-2 sm:flex-row lg:w-auto">
                    <button type="button" id="btnCopyPermissions"
                            data-seguridad-role-id="@Model.RolSeleccionadoId"
                            data-seguridad-return-url="@currentUrl"
                            class="permissions-role-action w-full sm:w-auto justify-center btn-erp-secondary">
                        <span class="material-symbols-outlined text-sm">content_copy</span>
                        Copiar permisos desde otro rol
                    </button>
                    <button type="submit" form="permissionsMatrixForm"
                            class="permissions-role-action w-full sm:w-auto justify-center btn-erp-primary">
                        <span class="material-symbols-outlined text-sm">save</span>
                        Guardar permisos
                    </button>
                </div>
            </div>
        }
    </div>

    @if (!Model.TieneRolSeleccionado)
    {
        <div class="bg-slate-900/50 rounded-xl border border-slate-800 overflow-hidden shadow-sm">
            <nav class="flex overflow-x-auto border-b border-slate-800">
                <a asp-controller="Seguridad" asp-action="Index" asp-route-tab="usuarios" class="shrink-0 border-b-2 border-transparent text-slate-400 hover:text-white hover:bg-white/5 px-5 py-3 text-sm font-bold no-underline transition-colors">Usuarios</a>
                <a asp-controller="Seguridad" asp-action="Index" asp-route-tab="roles" class="shrink-0 border-b-2 border-transparent text-slate-400 hover:text-white hover:bg-white/5 px-5 py-3 text-sm font-bold no-underline transition-colors">Roles</a>
                <a asp-controller="Seguridad" asp-action="Index" asp-route-tab="permisos-rol" class="shrink-0 border-b-2 border-primary text-primary bg-primary/10 px-5 py-3 text-sm font-bold no-underline transition-colors">Permisos de Rol</a>
                <a asp-controller="Seguridad" asp-action="Index" asp-route-tab="auditoria" class="shrink-0 border-b-2 border-transparent text-slate-400 hover:text-white hover:bg-white/5 px-5 py-3 text-sm font-bold no-underline transition-colors">Auditoría</a>
            </nav>
            <div class="p-12 text-center">
                <div class="inline-flex items-center justify-center size-16 rounded-full bg-slate-800 mb-4">
                    <span class="material-symbols-outlined text-3xl text-slate-400">admin_panel_settings</span>
                </div>
                <p class="text-sm font-semibold text-slate-300">Seleccioná un rol para configurar permisos</p>
                <p class="text-xs text-slate-500 mt-2">La matriz editable se habilita una vez elegido el rol destino.</p>
            </div>
        </div>
    }
    else
    {
        <form id="permissionsMatrixForm" asp-controller="Seguridad" asp-action="SavePermisosRol" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <input type="hidden" name="roleId" value="@Model.RolSeleccionadoId" />
            <input type="hidden" name="returnUrl" value="@currentUrl" />

            <div class="bg-slate-900/50 rounded-xl border border-slate-800 overflow-hidden shadow-sm">
                <nav class="flex overflow-x-auto border-b border-slate-800">
                    <a asp-controller="Seguridad" asp-action="Index" asp-route-tab="usuarios" class="shrink-0 border-b-2 border-transparent text-slate-400 hover:text-white hover:bg-white/5 px-5 py-3 text-sm font-bold no-underline transition-colors">Usuarios</a>
                    <a asp-controller="Seguridad" asp-action="Index" asp-route-tab="roles" class="shrink-0 border-b-2 border-transparent text-slate-400 hover:text-white hover:bg-white/5 px-5 py-3 text-sm font-bold no-underline transition-colors">Roles</a>
                    <a asp-controller="Seguridad" asp-action="Index" asp-route-tab="permisos-rol" class="shrink-0 border-b-2 border-primary text-primary bg-primary/10 px-5 py-3 text-sm font-bold no-underline transition-colors">Permisos de Rol</a>
                    <a asp-controller="Seguridad" asp-action="Index" asp-route-tab="auditoria" class="shrink-0 border-b-2 border-transparent text-slate-400 hover:text-white hover:bg-white/5 px-5 py-3 text-sm font-bold no-underline transition-colors">Auditoría</a>
                </nav>
                <div class="border-b border-slate-800 px-6 py-5 bg-slate-900/40">
                    <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
                        <div class="space-y-1">
                            <p class="text-sm font-semibold text-white">Matriz editable de permisos</p>
                            <p class="text-xs text-slate-400">Ajustá accesos por módulo y acción. Usá los atajos de fila o columna para acelerar cambios masivos.</p>
                        </div>
                        <div class="flex flex-wrap gap-2 text-xs font-medium text-slate-400">
                            <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-900 px-3 py-1 border border-slate-700">
                                <span class="material-symbols-outlined text-sm">table_rows</span>
                                <span id="permissionsVisiblePill">@Model.Filas.Count</span> módulos visibles
                            </span>
                            <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-900 px-3 py-1 border border-slate-700">
                                <span class="material-symbols-outlined text-sm">verified</span>
                                <span id="permissionsSelectedHeader">@totalSelectedPermissions</span> permisos seleccionados
                            </span>
                        </div>
                    </div>
                </div>
                <div data-oc-scroll class="relative" style="--oc-scroll-min-width: 1200px;">
                    <div data-oc-scroll-hint hidden class="px-4 pt-4 text-xs font-semibold uppercase tracking-[0.16em] text-slate-400 lg:hidden">
                        Deslizá para ver toda la matriz
                    </div>
                    <div data-oc-scroll-shell class="relative">
                        <div data-oc-scroll-fade="left" hidden class="absolute inset-y-0 left-0 z-10 w-6 bg-gradient-to-r from-slate-900 via-slate-900/95 to-transparent"></div>
                        <div data-oc-scroll-fade="right" hidden class="absolute inset-y-0 right-0 z-10 w-6 bg-gradient-to-l from-slate-900 via-slate-900/95 to-transparent"></div>
                        <div data-oc-scroll-region class="overflow-x-auto scroll-smooth" tabindex="0" role="region" aria-label="Matriz de permisos del rol seleccionado">
                    <table data-oc-scroll-table class="w-full text-left border-collapse" style="min-width: var(--oc-scroll-min-width);">
                        <thead class="bg-slate-800/50 border-b border-slate-800">
                            <tr>
                                <th class="px-4 py-4 text-[11px] font-bold text-slate-400 uppercase tracking-wider">Módulo / Submódulo</th>
                                @foreach (var columna in Model.Columnas)
                                {
                                    <th class="px-3 py-4 text-center text-[11px] font-bold text-slate-400 uppercase tracking-wider">
                                        <div class="space-y-2">
                                            <p>@columna.Label</p>
                                            <button type="button"
                                                    data-column-key="@columna.Key"
                                                    class="btn-select-column inline-flex items-center justify-center px-2 py-1 rounded-md text-[10px] font-semibold bg-slate-800 text-slate-300 hover:bg-primary/10 hover:text-primary transition-colors">
                                                Todo
                                            </button>
                                        </div>
                                    </th>
                                }
                            </tr>
                        </thead>
                        <tbody id="permissionsMatrixBody" class="divide-y divide-slate-800">
                            @foreach (var fila in Model.Filas)
                            {
                                var rowId = $"perm-row-{fila.ModuloId}";
                                var searchText = $"{fila.ModuloNombre} {fila.ModuloClave} {fila.Descripcion} {fila.Grupo}";

                                <tr class="permission-row hover:/50 hover:bg-slate-800/30 transition-colors"
                                    data-group="@fila.Grupo"
                                    data-search="@searchText">
                                    <td class="px-4 py-4 align-top">
                                        <div class="space-y-3">
                                            <div>
                                                <p class="text-sm font-semibold text-white">@fila.ModuloNombre</p>
                                                <div class="flex flex-wrap items-center gap-2 mt-2">
                                                    <span class="inline-flex px-2.5 py-1 rounded-full text-[11px] font-semibold bg-slate-800 text-slate-300">@fila.Grupo</span>
                                                    <span class="inline-flex px-2.5 py-1 rounded-full text-[11px] font-semibold bg-primary/10 text-primary">@fila.ModuloClave</span>
                                                </div>
                                                @if (!string.IsNullOrWhiteSpace(fila.Descripcion))
                                                {
                                                    <p class="text-xs text-slate-400 mt-2 max-w-md">@fila.Descripcion</p>
                                                }
                                            </div>
                                            <div class="flex flex-wrap gap-2">
                                                <button type="button"
                                                        data-row-id="@rowId"
                                                        class="btn-select-row inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-[11px] font-semibold bg-slate-800 text-slate-300 hover:bg-primary/10 hover:text-primary transition-colors">
                                                    <span class="material-symbols-outlined text-sm">done_all</span>
                                                    Toda fila
                                                </button>
                                                <button type="button"
                                                        data-row-id="@rowId"
                                                        class="btn-clear-row inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-[11px] font-semibold bg-slate-800 text-slate-300 hover:bg-rose-50 hover:text-rose-500 transition-colors">
                                                    <span class="material-symbols-outlined text-sm">cleaning_services</span>
                                                    Limpiar fila
                                                </button>
                                            </div>
                                        </div>
                                    </td>

                                    @foreach (var celda in fila.Celdas)
                                    {
                                        <td class="px-3 py-4 text-center" data-row-id="@rowId">
                                            @if (celda.Disponible && celda.AccionId.HasValue)
                                            {
                                                <label class="inline-flex items-center justify-center size-10 rounded-lg border border-slate-700 bg-slate-800 hover:border-primary/40 transition-colors cursor-pointer"
                                                       title="@celda.AccionNombre">
                                                    <input type="checkbox"
                                                           name="accionIds"
                                                           value="@celda.AccionId"
                                                           data-row-id="@rowId"
                                                           data-column-key="@celda.ColumnKey"
                                                           class="permission-checkbox size-4 rounded border-slate-600 text-primary focus:ring-primary/50 bg-transparent"
                                                           checked="@celda.Seleccionado" />
                                                </label>
                                            }
                                            else
                                            {
                                                <span class="text-slate-300 text-slate-600">-</span>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                        </div>
                    </div>
                </div>

                <div id="permissionsEmptyFilterState" class="hidden px-6 py-16 text-center border-t border-slate-800">
                    <p class="text-sm font-semibold text-slate-300">Sin módulos visibles</p>
                    <p class="text-xs text-slate-400 mt-2">Probá limpiando la búsqueda o el filtro de grupo.</p>
                </div>

                <div class="px-6 py-4 bg-slate-800/30 flex flex-col gap-2 border-t border-slate-800 text-center sm:flex-row sm:items-center sm:justify-between sm:text-left">
                    <p class="text-xs text-slate-500">
                        <span id="permissionsVisibleCount">@Model.Filas.Count</span> de @Model.Filas.Count módulos visibles
                    </p>
                    <p class="text-xs text-slate-500">
                        <span id="permissionsSelectedCount">@Model.Filas.SelectMany(f => f.Celdas).Count(c => c.Seleccionado)</span> permisos seleccionados
                    </p>
                </div>
            </div>
        </form>
    }
</div>

<div id="copyPermissionsContainer"></div>
