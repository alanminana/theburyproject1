@model SeguridadRolesTabViewModel
@{
    var currentUrl = Context.Request.Path + Context.Request.QueryString;
}

<div class="max-w-7xl mx-auto space-y-6">
    @if (TempData["Success"] != null)
    {
        <div class="toast-msg flex items-center gap-3 rounded-xl border border-emerald-500/20 bg-emerald-500/10 p-4 text-sm font-semibold text-emerald-400" role="status">
            <div class="bg-emerald-500/20 text-emerald-500 p-2 rounded-lg">
                <span class="material-symbols-outlined">check_circle</span>
            </div>
            <div>
                <p class="text-emerald-500 text-sm font-bold leading-tight">Operación exitosa</p>
                <p class="text-emerald-500/80 text-xs font-medium">@TempData["Success"]</p>
            </div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="toast-msg flex items-center gap-3 rounded-xl border border-rose-500/20 bg-rose-500/10 p-4 text-sm font-semibold text-rose-400" role="alert">
            <div class="bg-rose-500/20 text-rose-500 p-2 rounded-lg">
                <span class="material-symbols-outlined">error</span>
            </div>
            <div>
                <p class="text-rose-500 text-sm font-bold leading-tight">Error</p>
                <p class="text-rose-500/80 text-xs font-medium">@TempData["Error"]</p>
            </div>
        </div>
    }

    <div id="rolesActionFeedback"
         class="hidden rounded-xl border px-4 py-3 text-sm shadow-sm"
         role="alert"
         aria-live="polite"></div>

    <div class="filter-panel-erp">
        <button type="button"
                id="btn-toggle-filtros"
                data-expanded="false"
                class="flex w-full items-center justify-between gap-3 text-left">
            <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary text-[18px]">filter_alt</span>
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-primary">Búsqueda y filtros</p>
            </div>
            <span class="material-symbols-outlined filter-panel-erp__toggle-icon text-slate-400">expand_more</span>
        </button>

        <div id="filtros-body" class="filter-panel-erp__body" data-hidden="true">
            <div class="grid grid-cols-1 md:grid-cols-[minmax(0,1fr)_200px_auto] gap-4 pt-4">
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg">search</span>
                    <input id="searchRoles" type="text"
                           class="w-full pl-10 pr-4 py-2 bg-slate-800 border-none rounded-lg text-sm focus:ring-2 focus:ring-primary/50 text-white placeholder:text-slate-500"
                           placeholder="Buscar por nombre o descripción..." />
                </div>

                <select id="filterEstadoRol"
                        class="bg-slate-800 border-none rounded-lg text-sm px-4 py-2 focus:ring-primary text-white">
                    <option value="">Todos los estados</option>
                    <option value="activo">Activos</option>
                    <option value="inactivo">Inactivos</option>
                </select>

                <div class="flex items-center justify-end gap-2">
                    <button type="button" id="clearRolesFilters"
                            class="row-action"
                            title="Limpiar filtros">
                        <span class="material-symbols-outlined">filter_list_off</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-slate-900/50 rounded-xl border border-slate-800 overflow-hidden shadow-sm">
        <nav class="flex items-center overflow-x-auto border-b border-slate-800">
            <a asp-controller="Seguridad" asp-action="Index" asp-route-tab="usuarios" class="shrink-0 border-b-2 border-transparent text-slate-400 hover:text-white hover:bg-white/5 px-5 py-3 text-sm font-bold no-underline transition-colors">Usuarios</a>
            <a asp-controller="Seguridad" asp-action="Index" asp-route-tab="roles" class="shrink-0 border-b-2 border-primary text-primary bg-primary/10 px-5 py-3 text-sm font-bold no-underline transition-colors">Roles</a>
            <a asp-controller="Seguridad" asp-action="Index" asp-route-tab="permisos-rol" class="shrink-0 border-b-2 border-transparent text-slate-400 hover:text-white hover:bg-white/5 px-5 py-3 text-sm font-bold no-underline transition-colors">Permisos de Rol</a>
            <a asp-controller="Seguridad" asp-action="Index" asp-route-tab="auditoria" class="shrink-0 border-b-2 border-transparent text-slate-400 hover:text-white hover:bg-white/5 px-5 py-3 text-sm font-bold no-underline transition-colors">Auditoría</a>
            @if (User.TienePermiso("roles", "create"))
            {
                <div class="ml-auto shrink-0 px-3">
                    <button type="button"
                            data-seguridad-return-url="@currentUrl"
                            class="btn-open-create-role btn-erp-primary">
                        <span class="material-symbols-outlined text-sm">add</span>
                        Nuevo rol
                    </button>
                </div>
            }
        </nav>
        <div data-oc-scroll class="relative" style="--oc-scroll-min-width: 980px;">
            <div data-oc-scroll-hint hidden class="px-4 pt-4 text-xs font-semibold uppercase tracking-[0.16em] text-slate-400 lg:hidden">
                Deslizá para ver más columnas
            </div>
            <div data-oc-scroll-shell class="relative">
                <div data-oc-scroll-fade="left" hidden class="absolute inset-y-0 left-0 z-10 w-6 bg-gradient-to-r from-slate-900 via-slate-900/95 to-transparent"></div>
                <div data-oc-scroll-fade="right" hidden class="absolute inset-y-0 right-0 z-10 w-6 bg-gradient-to-l from-slate-900 via-slate-900/95 to-transparent"></div>
                <div data-oc-scroll-region class="overflow-x-auto scroll-smooth" tabindex="0" role="region" aria-label="Tabla de roles del módulo Seguridad">
            <table data-oc-scroll-table class="w-full text-left border-collapse" style="min-width: var(--oc-scroll-min-width);">
                <thead class="bg-slate-800/50 border-b border-slate-800">
                    <tr>
                        <th class="px-4 py-4 text-[11px] font-bold text-slate-400 uppercase tracking-wider">Nombre rol</th>
                        <th class="px-4 py-4 text-[11px] font-bold text-slate-400 uppercase tracking-wider">Descripción</th>
                        <th class="px-4 py-4 text-[11px] font-bold text-slate-400 uppercase tracking-wider">Estado</th>
                        <th class="px-4 py-4 text-[11px] font-bold text-slate-400 uppercase tracking-wider">Cantidad usuarios</th>
                        <th class="px-4 py-4 text-[11px] font-bold text-slate-400 uppercase tracking-wider text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody id="rolesTableBody" class="divide-y divide-slate-800">
                    @if (Model.Roles.Any())
                    {
                        @foreach (var rol in Model.Roles)
                        {
                            var estadoKey = rol.Activo ? "activo" : "inactivo";
                            var descripcion = string.IsNullOrWhiteSpace(rol.Descripcion) ? "Sin descripción" : rol.Descripcion;

                            <tr class="hover:bg-slate-800/30 transition-colors rol-row"
                                data-name="@rol.Nombre.ToLowerInvariant()"
                                data-description="@descripcion.ToLowerInvariant()"
                                data-estado="@estadoKey">
                                <td class="px-4 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="size-9 rounded-lg bg-primary/10 flex items-center justify-center text-primary shrink-0">
                                            <span class="material-symbols-outlined text-lg">shield_person</span>
                                        </div>
                                        <div class="min-w-0">
                                            <p class="text-sm font-semibold text-white truncate">@rol.Nombre</p>
                                            <p class="text-[11px] text-slate-400">@rol.CantidadPermisos permisos activos</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-4 py-4">
                                    <p class="text-sm text-slate-400 max-w-md truncate" title="@descripcion">@descripcion</p>
                                </td>
                                <td class="px-4 py-4">
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold @(rol.Activo ? "bg-emerald-500/10 text-emerald-400" : "bg-slate-500/10 text-slate-400")">
                                        <span class="size-1.5 rounded-full @(rol.Activo ? "bg-emerald-500" : "bg-slate-400")"></span>
                                        @(rol.Activo ? "Activo" : "Inactivo")
                                    </span>
                                </td>
                                <td class="px-4 py-4">
                                    <div class="space-y-1">
                                        <p class="text-sm font-semibold text-white">@rol.CantidadUsuarios</p>
                                        <p class="text-[11px] text-slate-400">@rol.CantidadUsuariosActivos activos</p>
                                    </div>
                                </td>
                                <td class="px-4 py-4 text-right">
                                    <div class="flex flex-wrap items-center justify-end gap-1.5">
                                        <a asp-controller="Seguridad" asp-action="RolDetails" asp-route-id="@rol.Id" asp-route-returnUrl="@currentUrl"
                                           class="row-action row-action--primary"
                                           title="Ver detalle">
                                            <span class="material-symbols-outlined">visibility</span>
                                            <span class="row-action__label">Ver</span>
                                        </a>
                                        @if (User.TienePermiso("roles", "update"))
                                        {
                                            <button type="button" data-seguridad-role-id="@rol.Id" data-seguridad-return-url="@currentUrl"
                                                    class="btn-edit-role row-action"
                                                    title="Editar">
                                                <span class="material-symbols-outlined">edit</span>
                                                <span class="row-action__label">Editar</span>
                                            </button>
                                        }
                                        @if (User.TienePermiso("roles", "create"))
                                        {
                                            <button type="button" data-seguridad-role-id="@rol.Id" data-seguridad-return-url="@currentUrl"
                                                    class="btn-duplicate-role row-action row-action--warning"
                                                    title="Duplicar">
                                                <span class="material-symbols-outlined">content_copy</span>
                                                <span class="row-action__label">Duplicar</span>
                                            </button>
                                        }
                                        @if (User.TienePermiso("roles", "update"))
                                        {
                                            <form asp-controller="Seguridad" asp-action="ToggleRolActivo" method="post" class="inline-flex">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@rol.Id" />
                                                <input type="hidden" name="activo" value="@(rol.Activo ? "false" : "true")" />
                                                <input type="hidden" name="returnUrl" value="@currentUrl" />
                                                <button type="submit"
                                                        class="row-action"
                                                        title="@(rol.Activo ? "Desactivar" : "Activar")">
                                                    <span class="material-symbols-outlined">@(rol.Activo ? "toggle_off" : "toggle_on")</span>
                                                    <span class="row-action__label">@(rol.Activo ? "Desactivar" : "Activar")</span>
                                                </button>
                                            </form>
                                        }
                                        <a asp-controller="Seguridad" asp-action="Index" asp-route-tab="permisos-rol" asp-route-roleId="@rol.Id"
                                           class="row-action row-action--primary"
                                           title="Configurar permisos">
                                            <span class="material-symbols-outlined">admin_panel_settings</span>
                                            <span class="row-action__label">Permisos</span>
                                        </a>
                                        @if (User.TienePermiso("roles", "delete"))
                                        {
                                            <form asp-controller="Seguridad" asp-action="DeleteRol" method="post"
                                                  class="inline-flex js-delete-role-form"
                                                  data-seguridad-role-name="@rol.Nombre"
                                                  data-seguridad-has-users="@(rol.CantidadUsuarios > 0 ? "true" : "false")">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@rol.Id" />
                                                <input type="hidden" name="returnUrl" value="@currentUrl" />
                                                <button type="submit"
                                                        class="row-action row-action--danger @(rol.CantidadUsuarios > 0 ? "row-action--disabled" : string.Empty)"
                                                        title="@(rol.CantidadUsuarios > 0 ? "El rol tiene usuarios asignados" : "Eliminar")">
                                                    <span class="material-symbols-outlined">delete</span>
                                                    <span class="row-action__label">Eliminar</span>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
                </div>
            </div>
        </div>

        @if (!Model.Roles.Any())
        {
            <div id="rolesEmptyState" class="px-6 py-16 text-center">
                <div class="inline-flex items-center justify-center size-16 rounded-full bg-slate-800 mb-4">
                    <span class="material-symbols-outlined text-3xl text-slate-400 text-slate-500">shield</span>
                </div>
                <p class="text-sm font-semibold text-slate-300 mb-1">No hay roles configurados</p>
                <p class="text-xs text-slate-500 mb-4">Creá el primer rol para empezar a organizar permisos por RBAC.</p>
                @if (User.TienePermiso("roles", "create"))
                {
                    <button type="button"
                            data-seguridad-return-url="@currentUrl"
                            class="btn-open-create-role btn-erp-primary">
                        <span class="material-symbols-outlined text-sm">add</span>
                        Nuevo rol
                    </button>
                }
            </div>
        }

        <div id="rolesEmptyFilterState" class="hidden px-6 py-16 text-center">
            <div class="inline-flex items-center justify-center size-16 rounded-full bg-slate-800 mb-4">
                <span class="material-symbols-outlined text-3xl text-slate-400 text-slate-500">search_off</span>
            </div>
            <p class="text-sm font-semibold text-slate-300 mb-1">Sin resultados</p>
            <p class="text-xs text-slate-500 mb-4">Probá ajustando los filtros de roles.</p>
            <button type="button" id="clearRolesFiltersEmpty"
                    class="btn-erp-ghost">
                <span class="material-symbols-outlined text-sm">filter_list_off</span>
                Limpiar filtros
            </button>
        </div>

        <div class="px-6 py-4 bg-slate-800/30 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between border-t border-slate-800">
            <p class="text-xs text-slate-500">
                <span id="rolesVisibleCount">@Model.Roles.Count</span> de @Model.Roles.Count roles
            </p>
            <p class="text-xs text-slate-500">@Model.Roles.Count(r => r.Activo) activos · @Model.Roles.Count(r => !r.Activo) inactivos</p>
        </div>
    </div>
</div>

<div id="createRoleContainer"></div>
<div id="editRoleContainer"></div>
<div id="duplicateRoleContainer"></div>
