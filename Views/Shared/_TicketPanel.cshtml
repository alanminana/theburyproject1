@using TheBuryProject.Models.Constants

@{
    var tpCanEdit    = User.TienePermiso(TicketConstants.Modulo, TicketConstants.Acciones.Editar);
    var tpCanStatus  = User.TienePermiso(TicketConstants.Modulo, TicketConstants.Acciones.CambiarEstado);
    var tpCanResolve = User.TienePermiso(TicketConstants.Modulo, TicketConstants.Acciones.Resolver);
    var tpCanCreate  = User.TienePermiso(TicketConstants.Modulo, TicketConstants.Acciones.Crear);
}

<div id="ticket-panel-overlay"
     class="fixed inset-0 z-[54] bg-black/40 hidden"
     aria-hidden="true"></div>

<aside id="ticket-panel"
       class="fixed inset-y-0 right-0 z-[55] flex w-[480px] max-w-full flex-col border-l border-slate-800 shadow-2xl translate-x-full transition-transform duration-300 ease-in-out"
       style="background-color:#101622;"
       role="complementary"
       aria-label="Panel de incidentes"
       aria-hidden="true"
       data-can-edit="@tpCanEdit.ToString().ToLowerInvariant()"
       data-can-status="@tpCanStatus.ToString().ToLowerInvariant()"
       data-can-resolve="@tpCanResolve.ToString().ToLowerInvariant()"
       data-can-create="@tpCanCreate.ToString().ToLowerInvariant()">

    <!-- Header -->
    <div class="flex shrink-0 items-center justify-between border-b border-slate-800 px-5 py-4">
        <div class="flex items-center gap-2">
            <button id="tp-back-btn"
                    type="button"
                    class="hidden p-1 rounded-lg text-slate-400 hover:text-white hover:bg-slate-800 transition-colors"
                    aria-label="Volver al listado">
                <span class="material-symbols-outlined text-xl">chevron_left</span>
            </button>
            <span class="material-symbols-outlined text-[18px] text-amber-400">assignment</span>
            <h2 id="tp-panel-title" class="text-sm font-bold text-white">Incidentes</h2>
        </div>
        <div class="flex items-center gap-2">
            @if (tpCanCreate)
            {
                <button id="tp-nuevo-btn"
                        type="button"
                        class="inline-flex items-center gap-1 rounded-lg bg-primary/10 px-3 py-1.5 text-xs font-bold text-primary hover:bg-primary/20 transition-colors"
                        data-open-ticket-modal>
                    <span class="material-symbols-outlined text-sm">add</span>
                    Nuevo
                </button>
            }
            <button id="tp-close-btn"
                    type="button"
                    class="p-1.5 rounded-lg text-slate-400 hover:text-white hover:bg-slate-800 transition-colors"
                    aria-label="Cerrar panel">
                <span class="material-symbols-outlined text-xl">close</span>
            </button>
        </div>
    </div>

    <!-- ── Vista Lista ── -->
    <div id="tp-view-lista" class="flex flex-1 flex-col overflow-hidden">

        <!-- Filtros -->
        <div class="shrink-0 border-b border-slate-800 px-4 py-3 flex flex-wrap gap-2">
            <input id="tp-filter-busqueda" type="text"
                   placeholder="Buscar..."
                   class="filter-input-erp flex-1 min-w-[100px]" />
            <select id="tp-filter-estado" class="filter-select-erp" style="width:112px">
                <option value="">Estado</option>
                <option value="0">Pendiente</option>
                <option value="1">En Curso</option>
                <option value="2">Resuelto</option>
                <option value="3">Cancelado</option>
            </select>
            <select id="tp-filter-tipo" class="filter-select-erp" style="width:112px">
                <option value="">Tipo</option>
                <option value="0">Error texto</option>
                <option value="1">Error funcional</option>
                <option value="2">Mejora</option>
                <option value="3">Nueva func.</option>
                <option value="4">Eliminación</option>
                <option value="5">Fusión</option>
                <option value="6">Otro</option>
            </select>
            <button id="tp-filter-btn" type="button"
                    class="p-2 rounded-lg bg-primary/10 text-primary hover:bg-primary/20 transition-colors"
                    title="Filtrar">
                <span class="material-symbols-outlined text-[18px]">filter_list</span>
            </button>
        </div>

        <!-- Cargando -->
        <div id="tp-lista-loading" class="hidden flex-1 items-center justify-center">
            <div class="flex flex-col items-center gap-3 text-slate-500">
                <span class="material-symbols-outlined text-3xl animate-spin">progress_activity</span>
                <span class="text-sm">Cargando tickets...</span>
            </div>
        </div>

        <!-- Error -->
        <div id="tp-lista-error" class="hidden flex-1 items-center justify-center px-6">
            <div class="flex flex-col items-center gap-3 text-center">
                <span class="material-symbols-outlined text-3xl text-red-400">error_outline</span>
                <p id="tp-lista-error-text" class="text-sm text-slate-400">Error al cargar los tickets.</p>
                <button type="button" id="tp-lista-retry"
                        class="text-xs text-primary hover:underline">Reintentar</button>
            </div>
        </div>

        <!-- Vacío -->
        <div id="tp-lista-empty" class="hidden flex-1 items-center justify-center px-6">
            <div class="flex flex-col items-center gap-3 text-center text-slate-500">
                <span class="material-symbols-outlined text-4xl">task_alt</span>
                <p class="text-sm font-semibold text-slate-400">Sin incidentes</p>
                <p class="text-xs">No hay tickets que coincidan con los filtros.</p>
            </div>
        </div>

        <!-- Items -->
        <ul id="tp-lista-items" class="flex-1 overflow-y-auto divide-y divide-slate-800/60"></ul>

        <!-- Cargar más -->
        <div id="tp-lista-more" class="hidden shrink-0 border-t border-slate-800 p-3 text-center">
            <button type="button" id="tp-load-more"
                    class="text-xs font-semibold text-primary hover:underline">Cargar más</button>
        </div>
    </div>

    <!-- ── Vista Detalle ── -->
    <div id="tp-view-detalle" class="hidden flex-1 flex-col overflow-hidden">

        <div id="tp-detalle-loading" class="flex-1 flex items-center justify-center">
            <div class="flex flex-col items-center gap-3 text-slate-500">
                <span class="material-symbols-outlined text-3xl animate-spin">progress_activity</span>
                <span class="text-sm">Cargando...</span>
            </div>
        </div>

        <div id="tp-detalle-content" class="hidden flex-1 overflow-y-auto px-5 py-4 space-y-5"></div>
    </div>
</aside>
