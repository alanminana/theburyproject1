@using System.Text.Json
@using TheBuryProject.Models.Entities
@{
    var estadosProductoJson = JsonSerializer.Serialize(
        Enum.GetValues<EstadoProductoDevuelto>()
            .Select(estado => new
            {
                value = (int)estado,
                label = estado.GetDisplayName()
            }));
}

<style>
    #modal-devolucion-venta .devolucion-quick-modal__panel {
        display: flex;
        max-height: min(calc(100vh - 2rem), 92vh);
        flex-direction: column;
    }

    #modal-devolucion-venta .devolucion-quick-modal__form {
        display: flex;
        height: 100%;
        max-height: 100%;
        min-height: 0;
        flex: 1 1 auto;
        flex-direction: column;
    }

    #modal-devolucion-venta [data-devolucion-modal-content] {
        flex: 1 1 auto;
        min-height: 0;
        overflow-y: auto;
    }

    #modal-devolucion-venta .devolucion-quick-modal__footer {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    #modal-devolucion-venta .devolucion-quick-modal__actions {
        display: flex;
        width: 100%;
        flex-direction: column-reverse;
        gap: 0.75rem;
    }

    #modal-devolucion-venta .devolucion-quick-modal__action-btn {
        width: 100%;
        min-height: 2.75rem;
    }

    @@media (min-width: 640px) {
        #modal-devolucion-venta .devolucion-quick-modal__footer {
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
        }

        #modal-devolucion-venta .devolucion-quick-modal__actions {
            width: auto;
            flex-direction: row;
        }

        #modal-devolucion-venta .devolucion-quick-modal__action-btn {
            width: auto;
        }
    }
</style>

<div id="modal-devolucion-venta"
     class="fixed inset-0 z-50 hidden"
     data-devolucion-modal
     role="dialog"
     aria-modal="true"
     aria-hidden="true"
     data-context-url="@Url.Action("GetQuickCreateContext", "Devolucion")"
     data-submit-url="@Url.Action("QuickCreate", "Devolucion")"
     data-estados-producto='@Html.Raw(estadosProductoJson)'>
    <div class="absolute inset-0 bg-slate-950/70 backdrop-blur-sm" data-devolucion-modal-action="close" aria-hidden="true"></div>
    <div class="relative flex min-h-screen items-center justify-center p-4 md:p-6">
        <div data-devolucion-modal-panel class="devolucion-quick-modal__panel relative flex w-full max-w-5xl overflow-hidden rounded-[28px] border border-slate-200 bg-white shadow-2xl dark:border-slate-800 dark:bg-slate-900">
            <form id="form-devolucion-venta" class="devolucion-quick-modal__form flex min-h-0 w-full flex-col">
                @Html.AntiForgeryToken()
                <input type="hidden" id="devolucion-venta-id" name="VentaId" />
                <input type="hidden" id="devolucion-cliente-id" name="ClienteId" />

                <div class="border-b border-slate-200 bg-[radial-gradient(circle_at_top_left,_rgba(59,130,246,0.12),_transparent_34%),linear-gradient(135deg,_rgba(15,23,42,0.02),_rgba(15,23,42,0))] px-4 py-5 dark:border-slate-800 dark:bg-[radial-gradient(circle_at_top_left,_rgba(59,130,246,0.18),_transparent_30%),linear-gradient(135deg,_rgba(15,23,42,0.45),_rgba(15,23,42,0.12))] sm:px-6">
                    <div class="flex items-start justify-between gap-4">
                        <div class="space-y-3">
                            <span class="inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/10 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.24em] text-primary">
                                <span class="material-symbols-outlined text-sm">assignment_return</span>
                                Devolución rápida
                            </span>
                            <div>
                                <h3 class="text-2xl font-black tracking-tight text-slate-900 dark:text-white">Resolver desde la venta</h3>
                                <p class="mt-1 max-w-2xl text-sm leading-relaxed text-slate-500 dark:text-slate-400">
                                    Definí qué producto vuelve, en qué estado ingresa y cómo se resuelve con el cliente sin salir del circuito operativo actual.
                                </p>
                            </div>
                            <div class="flex flex-wrap gap-2">
                                <span class="inline-flex items-center gap-2 rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600 dark:bg-slate-800 dark:text-slate-300">
                                    <span class="material-symbols-outlined text-sm">inventory_2</span>
                                    Selección por producto
                                </span>
                                <span class="inline-flex items-center gap-2 rounded-full bg-sky-500/10 px-3 py-1 text-xs font-semibold text-sky-700 dark:text-sky-300">
                                    <span class="material-symbols-outlined text-sm">payments</span>
                                    Resolución y caja
                                </span>
                                <span class="inline-flex items-center gap-2 rounded-full bg-emerald-500/10 px-3 py-1 text-xs font-semibold text-emerald-700 dark:text-emerald-300">
                                    <span class="material-symbols-outlined text-sm">fact_check</span>
                                    Registro inmediato
                                </span>
                            </div>
                        </div>

                        <button type="button"
                                class="rounded-2xl border border-slate-200 bg-white/80 p-2.5 text-slate-400 transition-colors hover:bg-white hover:text-slate-700 dark:border-slate-700 dark:bg-slate-900/80 dark:hover:bg-slate-900 dark:hover:text-slate-200"
                                data-devolucion-modal-action="close">
                            <span class="material-symbols-outlined">close</span>
                        </button>
                    </div>
                </div>

                <div data-devolucion-modal-content class="min-h-0 flex-1 overflow-y-auto px-4 py-5 sm:px-6">
                    <div id="devolucion-modal-error"
                         class="mb-4 hidden rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-semibold text-red-700 dark:border-red-500/20 dark:bg-red-500/10 dark:text-red-300">
                    </div>

                    <div id="devolucion-modal-loading" class="flex flex-col items-center justify-center gap-3 py-12">
                        <div class="size-10 animate-spin rounded-full border-2 border-primary border-t-transparent"></div>
                        <p class="text-sm font-medium text-slate-500 dark:text-slate-400">Cargando datos de la venta...</p>
                    </div>

                    <div id="devolucion-modal-body" class="hidden space-y-5">
                        <div class="grid gap-4 lg:grid-cols-[1.25fr_0.75fr]">
                            <div class="rounded-3xl border border-primary/15 bg-primary/5 p-4 shadow-sm dark:border-primary/20 dark:bg-primary/10">
                                <div class="flex flex-wrap items-center gap-2">
                                    <span class="rounded-full bg-primary px-3 py-1 text-[11px] font-black uppercase tracking-[0.18em] text-white" id="devolucion-numero-venta">Venta</span>
                                    <span class="rounded-full bg-white px-3 py-1 text-[11px] font-bold text-slate-600 shadow-sm dark:bg-slate-800 dark:text-slate-300" id="devolucion-tipo-pago">Pago</span>
                                    <span class="rounded-full bg-white px-3 py-1 text-[11px] font-bold text-slate-600 shadow-sm dark:bg-slate-800 dark:text-slate-300" id="devolucion-dias-venta">0 días</span>
                                </div>

                                <div class="mt-4 grid gap-3 md:grid-cols-3">
                                    <div class="rounded-2xl border border-white/70 bg-white/90 px-4 py-3 dark:border-slate-800 dark:bg-slate-950/40">
                                        <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">Cliente</p>
                                        <p class="mt-2 text-sm font-black text-slate-900 dark:text-white" id="devolucion-cliente-nombre">-</p>
                                    </div>
                                    <div class="rounded-2xl border border-white/70 bg-white/90 px-4 py-3 dark:border-slate-800 dark:bg-slate-950/40">
                                        <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">Fecha venta</p>
                                        <p class="mt-2 text-sm font-black text-slate-900 dark:text-white" id="devolucion-fecha-venta">-</p>
                                    </div>
                                    <div class="rounded-2xl border border-white/70 bg-white/90 px-4 py-3 dark:border-slate-800 dark:bg-slate-950/40">
                                        <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">Total venta</p>
                                        <p class="mt-2 text-lg font-black text-primary" id="devolucion-total-venta">$0.00</p>
                                    </div>
                                </div>
                            </div>

                            <div class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-800 dark:bg-slate-950/40">
                                <div class="flex items-start justify-between gap-3">
                                    <div>
                                        <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">Impacto operativo</p>
                                        <h4 class="mt-2 text-base font-black text-slate-900 dark:text-white">Qué pasa con esta devolución</h4>
                                    </div>
                                    <span class="material-symbols-outlined text-xl text-primary">rule</span>
                                </div>
                                <div id="devolucion-resolucion-helper"
                                     class="mt-4 rounded-2xl border border-primary/15 bg-primary/5 px-4 py-4 text-sm leading-relaxed text-slate-600 dark:border-primary/20 dark:bg-primary/10 dark:text-slate-200">
                                    Elegí la resolución para definir si corresponde nota de crédito, cambio o reembolso.
                                </div>
                                <div class="mt-4 flex flex-wrap gap-2">
                                    <span class="inline-flex items-center gap-2 rounded-full bg-slate-100 px-3 py-1 text-[11px] font-semibold text-slate-600 dark:bg-slate-800 dark:text-slate-300">
                                        <span class="material-symbols-outlined text-sm">inventory</span>
                                        Reingreso al completar
                                    </span>
                                    <span class="inline-flex items-center gap-2 rounded-full bg-slate-100 px-3 py-1 text-[11px] font-semibold text-slate-600 dark:bg-slate-800 dark:text-slate-300">
                                        <span class="material-symbols-outlined text-sm">request_quote</span>
                                        Caja solo en reembolso
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="grid gap-4 xl:grid-cols-[1fr_0.95fr]">
                            <div class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
                                <div class="mb-4">
                                    <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">Definición del caso</p>
                                    <h4 class="mt-2 text-base font-black text-slate-900 dark:text-white">Motivo y resolución</h4>
                                </div>

                                <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
                                    <div class="space-y-2">
                                        <label for="devolucion-motivo" class="text-sm font-bold text-slate-700 dark:text-slate-200">Motivo</label>
                                        <select id="devolucion-motivo"
                                                name="Motivo"
                                                class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-950 dark:text-white">
                                            @foreach (var motivo in Html.GetEnumSelectList<MotivoDevolucion>())
                                            {
                                                <option value="@motivo.Value">@motivo.Text</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="space-y-2 md:col-span-2">
                                        <label for="devolucion-tipo-resolucion" class="text-sm font-bold text-slate-700 dark:text-slate-200">Resolución</label>
                                        <select id="devolucion-tipo-resolucion"
                                                name="TipoResolucion"
                                                class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-950 dark:text-white">
                                            @foreach (var resolucion in Html.GetEnumSelectList<TipoResolucionDevolucion>())
                                            {
                                                <option value="@resolucion.Value">@resolucion.Text</option>
                                            }
                                        </select>
                                    </div>

                                    <label class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm dark:border-slate-800 dark:bg-slate-950/40">
                                        <input id="devolucion-registrar-caja"
                                               name="RegistrarEgresoCaja"
                                               type="checkbox"
                                               value="true"
                                               class="size-4 rounded border-slate-300 text-primary focus:ring-primary" />
                                        <input name="RegistrarEgresoCaja" type="hidden" value="false" />
                                        <span>
                                            <span class="block font-bold text-slate-900 dark:text-white">Reflejar en caja</span>
                                            <span class="block text-xs text-slate-500 dark:text-slate-400">Solo aplica al reembolso.</span>
                                        </span>
                                    </label>
                                </div>
                            </div>

                            <div class="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
                                <div class="mb-4">
                                    <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">Contexto del reclamo</p>
                                    <h4 class="mt-2 text-base font-black text-slate-900 dark:text-white">Descripción operativa</h4>
                                </div>

                                <div class="space-y-2">
                                    <label for="devolucion-descripcion" class="text-sm font-bold text-slate-700 dark:text-slate-200">Descripción</label>
                                    <textarea id="devolucion-descripcion"
                                              name="Descripcion"
                                              rows="6"
                                              minlength="20"
                                              maxlength="1000"
                                              class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-950 dark:text-white"
                                              placeholder="Describí qué pasó, qué observó el cliente y cómo se va a resolver."></textarea>
                                    <p class="text-xs leading-relaxed text-slate-500 dark:text-slate-400">Mínimo 20 caracteres. Usá este campo para dejar claro el contexto del reclamo, el diagnóstico y la acción acordada con el cliente.</p>
                                </div>
                            </div>
                        </div>

                        <div class="rounded-3xl border border-slate-200 bg-white shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
                            <div class="flex flex-wrap items-center justify-between gap-3 border-b border-slate-200 px-4 py-4 dark:border-slate-800 sm:px-5">
                                <div class="space-y-1">
                                    <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">Selección de productos</p>
                                    <h4 class="text-base font-black text-slate-900 dark:text-white">Qué vuelve al circuito</h4>
                                    <p class="text-sm text-slate-500 dark:text-slate-400">Marcá los ítems, definí la cantidad y el estado en que reingresan.</p>
                                </div>
                                <div class="rounded-full bg-primary/10 px-3 py-1.5 text-[11px] font-black uppercase tracking-[0.16em] text-primary" id="devolucion-total-seleccionado">
                                    Total seleccionado: $0.00
                                </div>
                            </div>

                            <div data-oc-scroll style="--oc-scroll-min-width: 34.25rem;" class="overflow-hidden">
                                <div class="border-b border-slate-200 bg-slate-50/70 px-4 py-3 dark:border-slate-800 dark:bg-slate-950/30">
                                    <p data-oc-scroll-hint hidden class="text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-500 dark:text-slate-400">
                                        Deslizá horizontalmente para completar producto, cantidad y estado.
                                    </p>
                                </div>
                                <div class="relative">
                                    <div data-oc-scroll-fade="left" hidden class="pointer-events-none absolute inset-y-0 left-0 z-[1] w-8 bg-gradient-to-r from-white via-white/95 to-transparent dark:from-slate-900 dark:via-slate-900/95"></div>
                                    <div data-oc-scroll-fade="right" hidden class="pointer-events-none absolute inset-y-0 right-0 z-[1] w-8 bg-gradient-to-l from-white via-white/95 to-transparent dark:from-slate-900 dark:via-slate-900/95"></div>
                                    <div data-oc-scroll-region tabindex="0" class="overflow-x-auto overscroll-x-contain">
                                        <table class="min-w-[var(--oc-scroll-min-width)] w-full text-sm">
                                            <thead class="bg-slate-50 text-[11px] uppercase tracking-wider text-slate-500 dark:bg-slate-900/60 dark:text-slate-400">
                                                <tr>
                                                    <th class="px-4 py-3 text-left">Selección</th>
                                                    <th class="px-4 py-3 text-left">Producto</th>
                                                    <th class="px-4 py-3 text-center">Disponible</th>
                                                    <th class="px-4 py-3 text-right">Precio</th>
                                                    <th class="px-4 py-3 text-center">Cantidad</th>
                                                    <th class="px-4 py-3 text-left">Estado</th>
                                                </tr>
                                            </thead>
                                            <tbody id="devolucion-items-body" class="divide-y divide-slate-100 dark:divide-slate-800"></tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="devolucion-quick-modal__footer flex flex-col gap-3 border-t border-slate-200 bg-slate-50/80 px-4 py-4 dark:border-slate-800 dark:bg-slate-950/40 sm:px-6 lg:flex-row lg:items-center lg:justify-between">
                    <p class="text-xs leading-relaxed text-slate-500 dark:text-slate-400">
                        El ingreso de stock se procesa cuando la devolución se completa. El reembolso impacta caja solo si lo indicás arriba.
                    </p>
                    <div class="devolucion-quick-modal__actions flex w-full flex-col-reverse gap-3 sm:w-auto sm:flex-row">
                        <button type="button"
                                class="devolucion-quick-modal__action-btn min-h-11 w-full rounded-xl border border-slate-300 px-5 py-2.5 text-sm font-bold text-slate-600 transition-colors hover:bg-slate-100 dark:border-slate-700 dark:text-slate-300 dark:hover:bg-slate-800 sm:w-auto"
                                data-devolucion-modal-action="close">
                            Cancelar
                        </button>
                        <button type="submit"
                                id="btn-submit-devolucion"
                                class="devolucion-quick-modal__action-btn min-h-11 w-full rounded-xl bg-primary px-5 py-2.5 text-sm font-black text-white shadow-lg shadow-primary/20 transition-colors hover:bg-primary/90 sm:w-auto">
                            Crear devolución
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="~/js/devolucion-module.js" asp-append-version="true"></script>
