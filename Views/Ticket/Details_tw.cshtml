@model TheBuryProject.ViewModels.TicketDetalleViewModel
@using TheBuryProject.Models.Constants
@using TheBuryProject.Models.Enums
@{
    ViewData["Title"] = $"Ticket #{Model.Id}";
    var canViewTicketPanel = User.TienePermiso(TicketConstants.Modulo, TicketConstants.Acciones.Ver);
    var canChangeTicketStatus = User.TienePermiso(TicketConstants.Modulo, TicketConstants.Acciones.CambiarEstado);
    var canResolveTicket = User.TienePermiso(TicketConstants.Modulo, TicketConstants.Acciones.Resolver);
    var canDeleteTicket = User.TienePermiso(TicketConstants.Modulo, TicketConstants.Acciones.Eliminar);
    var canManageTicket = User.TieneCualquierPermiso(
        (TicketConstants.Modulo, TicketConstants.Acciones.Editar),
        (TicketConstants.Modulo, TicketConstants.Acciones.CambiarEstado),
        (TicketConstants.Modulo, TicketConstants.Acciones.Resolver));
    var transicionesPermitidas = TicketUiHelper.GetTransicionesDisponibles(Model.Estado)
        .Where(estado => estado == EstadoTicket.Resuelto ? canResolveTicket : canChangeTicketStatus)
        .ToList();

    var estadoBadge = TicketUiHelper.EstadoBadgeClass(Model.Estado);
    var tipoBadge = Model.Tipo switch
    {
        TipoTicket.ErrorFuncional      => "badge-erp badge-erp-danger",
        TipoTicket.ErrorTexto          => "badge-erp badge-erp-warning",
        TipoTicket.Mejora              => "badge-erp badge-erp-primary",
        TipoTicket.NuevaFuncionalidad  => "badge-erp badge-erp-success",
        _                              => "badge-erp badge-erp-neutral",
    };
}

@section Styles {
    <partial name="_TicketModuleStyles" />
}

<div class="space-y-8">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Hero                                                       -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <section class="hero-erp sm:p-8">
        <header class="flex flex-col gap-6 xl:flex-row xl:items-start xl:justify-between">
            <div class="max-w-3xl space-y-4">
                <nav aria-label="Breadcrumb" class="flex text-sm font-medium text-slate-400">
                    <ol class="inline-flex flex-wrap items-center gap-y-1">
                        <li><span class="text-slate-500">Sistemas</span></li>
                        <li><span class="mx-2 text-slate-600">/</span></li>
                        <li><a asp-controller="Ticket" asp-action="Index" class="hover:text-primary no-underline">Tickets</a></li>
                        <li><span class="mx-2 text-slate-600">/</span></li>
                        <li class="text-slate-100">#@Model.Id</li>
                    </ol>
                </nav>

                <div class="space-y-3">
                    <div class="flex flex-wrap items-center gap-2">
                        <span class="@estadoBadge">@Model.EstadoNombre</span>
                        <span class="@tipoBadge">@Model.TipoNombre</span>
                    </div>
                    <div class="space-y-2">
                        <h1 class="text-2xl font-black tracking-tight text-white sm:text-3xl">@Model.Titulo</h1>
                        <p class="font-mono text-xs text-slate-500">Ticket #@Model.Id</p>
                    </div>
                    <div class="flex flex-wrap items-center gap-3 text-sm text-slate-400">
                        @if (!string.IsNullOrEmpty(Model.CreatedBy))
                        {
                            <span class="inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-950/40 px-3 py-1.5 font-semibold text-slate-300">
                                <span class="material-symbols-outlined text-sm">person</span>
                                @Model.CreatedBy
                            </span>
                        }
                        <span class="inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-950/40 px-3 py-1.5 font-semibold text-slate-300">
                            <span class="material-symbols-outlined text-sm">calendar_today</span>
                            @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                        </span>
                        @if (!string.IsNullOrEmpty(Model.ModuloOrigen))
                        {
                            <span class="inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-950/40 px-3 py-1.5 font-semibold text-slate-300">
                                <span class="material-symbols-outlined text-sm">layers</span>
                                @Model.ModuloOrigen
                            </span>
                        }
                    </div>
                </div>
            </div>

            <div class="flex w-full flex-col gap-3 sm:flex-row xl:w-auto xl:items-start">
                @if (canViewTicketPanel)
                {
                    <button type="button"
                            data-ticket-panel-open="@Model.Id"
                            class="btn-erp-primary no-underline">
                        <span class="material-symbols-outlined text-[20px]">manage_search</span>
                        Gestionar en panel
                    </button>
                }
                @foreach (var nuevoEstado in transicionesPermitidas)
                {
                    <button type="button"
                            class="btn-erp-ghost"
                            data-ticket-status-action
                            data-ticket-id="@Model.Id"
                            data-ticket-title="@Model.Titulo"
                            data-ticket-current-label="@Model.EstadoNombre"
                            data-ticket-new-status="@((int)nuevoEstado)"
                            data-ticket-new-label="@nuevoEstado.GetDisplayName()"
                            data-ticket-requires-description="@TicketUiHelper.RequiereDescripcion(nuevoEstado).ToString().ToLowerInvariant()">
                        <span class="material-symbols-outlined text-[20px]">@TicketUiHelper.EstadoIcon(nuevoEstado)</span>
                        @TicketUiHelper.AccionEstadoLabel(nuevoEstado)
                    </button>
                }
                @if (canDeleteTicket)
                {
                    <button type="button"
                            class="inline-flex items-center justify-center gap-2 rounded-lg bg-rose-500/10 px-4 py-2 text-sm font-bold text-rose-300 transition-colors hover:bg-rose-500 hover:text-white"
                            data-ticket-delete-action
                            data-ticket-id="@Model.Id"
                            data-ticket-title="@Model.Titulo">
                        <span class="material-symbols-outlined text-[20px]">delete</span>
                        Eliminar
                    </button>
                }
                <a asp-action="Index"
                   class="btn-erp-ghost no-underline">
                    <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                    Volver al listado
                </a>
            </div>
        </header>
    </section>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Contenido principal                                        -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">

        <!-- Columna principal -->
        <div class="lg:col-span-2 space-y-6">

            <!-- Descripción -->
            <section class="card-erp-panel">
                <div class="px-6 py-4 border-b border-slate-800 bg-slate-800/30">
                    <h2 class="text-base font-bold text-white flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary-on-dark text-lg">description</span>
                        Descripción del reporte
                    </h2>
                </div>
                <div class="p-6">
                    <p class="text-sm leading-relaxed text-slate-300 whitespace-pre-wrap">@Model.Descripcion</p>
                </div>
            </section>

            <!-- Resolución (solo si está resuelto) -->
            @if (!string.IsNullOrEmpty(Model.Resolucion))
            {
                <section class="card-erp-panel border-emerald-800/40">
                    <div class="px-6 py-4 border-b border-emerald-800/30 bg-emerald-900/10">
                        <h2 class="text-base font-bold text-emerald-300 flex items-center gap-2">
                            <span class="material-symbols-outlined text-emerald-400 text-lg">check_circle</span>
                            Resolución registrada
                        </h2>
                    </div>
                    <div class="p-6 space-y-3">
                        <p class="text-sm leading-relaxed text-slate-300 whitespace-pre-wrap">@Model.Resolucion</p>
                        <div class="flex flex-wrap gap-4 text-xs text-slate-500">
                            @if (!string.IsNullOrEmpty(Model.ResueltoPor))
                            {
                                <span class="flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[13px]">person</span>
                                    Resuelto por @Model.ResueltoPor
                                </span>
                            }
                            @if (Model.FechaResolucion.HasValue)
                            {
                                <span class="flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[13px]">event_available</span>
                                    @Model.FechaResolucion.Value.ToString("dd/MM/yyyy HH:mm")
                                </span>
                            }
                        </div>
                    </div>
                </section>
            }

            <!-- Checklist (si tiene ítems) -->
            @if (Model.ChecklistItems.Any())
            {
                <section class="card-erp-panel">
                    <div class="px-6 py-4 border-b border-slate-800 bg-slate-800/30">
                        <h2 class="text-base font-bold text-white flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary-on-dark text-lg">checklist</span>
                            Checklist
                            <span class="ml-auto text-xs font-normal text-slate-400">
                                @Model.ChecklistItems.Count(c => c.Completado) / @Model.ChecklistItems.Count completados
                            </span>
                        </h2>
                    </div>
                    <ul class="divide-y divide-slate-800">
                        @foreach (var item in Model.ChecklistItems.OrderBy(c => c.Orden))
                        {
                            <li class="flex items-start gap-3 px-6 py-3">
                                @if (item.Completado)
                                {
                                    <span class="mt-0.5 material-symbols-outlined text-emerald-400 text-lg shrink-0">check_circle</span>
                                    <div class="min-w-0">
                                        <p class="text-sm text-slate-500 line-through">@item.Descripcion</p>
                                        @if (!string.IsNullOrEmpty(item.CompletadoPor))
                                        {
                                            <p class="text-[11px] text-slate-600 mt-0.5">por @item.CompletadoPor</p>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="mt-0.5 material-symbols-outlined text-slate-600 text-lg shrink-0">radio_button_unchecked</span>
                                    <p class="text-sm text-slate-300">@item.Descripcion</p>
                                }
                            </li>
                        }
                    </ul>
                </section>
            }

            <!-- Adjuntos (si tiene) -->
            @if (Model.Adjuntos.Any())
            {
                <section class="card-erp-panel">
                    <div class="px-6 py-4 border-b border-slate-800 bg-slate-800/30">
                        <h2 class="text-base font-bold text-white flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary-on-dark text-lg">attach_file</span>
                            Adjuntos
                            <span class="ml-auto text-xs font-normal text-slate-400">@Model.Adjuntos.Count archivo@(Model.Adjuntos.Count == 1 ? "" : "s")</span>
                        </h2>
                    </div>
                    <ul class="divide-y divide-slate-800">
                        @foreach (var adj in Model.Adjuntos)
                        {
                            <li class="flex items-center gap-3 px-6 py-3">
                                <span class="material-symbols-outlined text-slate-400 text-lg shrink-0">insert_drive_file</span>
                                <div class="min-w-0 flex-1">
                                    <p class="truncate text-sm font-semibold text-slate-200">@adj.NombreArchivo</p>
                                    <p class="text-[11px] text-slate-500">
                                        @((adj.TamanoBytes / 1024.0).ToString("F1")) KB
                                        @if (!string.IsNullOrEmpty(adj.TipoMIME))
                                        {
                                            <span> &middot; @adj.TipoMIME</span>
                                        }
                                    </p>
                                </div>
                                <a href="/@adj.RutaArchivo" target="_blank" rel="noopener"
                                   class="shrink-0 inline-flex items-center gap-1 rounded-lg bg-slate-800 px-3 py-1.5 text-xs font-semibold text-slate-300 hover:bg-slate-700 hover:text-white transition-colors no-underline"
                                   title="Descargar @adj.NombreArchivo">
                                    <span class="material-symbols-outlined text-[14px]">download</span>
                                    Descargar
                                </a>
                            </li>
                        }
                    </ul>
                </section>
            }

        </div><!-- end left col -->

        <!-- Sidebar de datos -->
        <aside class="space-y-6">
            <div class="sticky top-6 space-y-6">

                <!-- Datos del ticket -->
                <section class="card-erp-panel">
                    <div class="px-5 py-4 border-b border-slate-800 bg-slate-800/30">
                        <h3 class="text-sm font-bold text-white">Información del ticket</h3>
                    </div>
                    <dl class="divide-y divide-slate-800 text-sm">
                        <div class="flex items-center justify-between px-5 py-3">
                            <dt class="text-xs font-semibold uppercase text-slate-500">ID</dt>
                            <dd class="font-mono text-slate-200">#@Model.Id</dd>
                        </div>
                        <div class="flex items-center justify-between px-5 py-3">
                            <dt class="text-xs font-semibold uppercase text-slate-500">Estado</dt>
                            <dd><span class="@estadoBadge">@Model.EstadoNombre</span></dd>
                        </div>
                        <div class="flex items-center justify-between px-5 py-3">
                            <dt class="text-xs font-semibold uppercase text-slate-500">Tipo</dt>
                            <dd><span class="@tipoBadge">@Model.TipoNombre</span></dd>
                        </div>
                        <div class="flex items-center justify-between px-5 py-3">
                            <dt class="text-xs font-semibold uppercase text-slate-500">Reportado por</dt>
                            <dd class="text-slate-200 text-right truncate max-w-[10rem]">@(Model.CreatedBy ?? "—")</dd>
                        </div>
                        <div class="flex items-center justify-between px-5 py-3">
                            <dt class="text-xs font-semibold uppercase text-slate-500">Creado</dt>
                            <dd class="text-slate-200">@Model.CreatedAt.ToString("dd/MM/yy HH:mm")</dd>
                        </div>
                        @if (Model.UpdatedAt.HasValue)
                        {
                            <div class="flex items-center justify-between px-5 py-3">
                                <dt class="text-xs font-semibold uppercase text-slate-500">Actualizado</dt>
                                <dd class="text-slate-200">@Model.UpdatedAt.Value.ToString("dd/MM/yy HH:mm")</dd>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.ModuloOrigen))
                        {
                            <div class="flex items-center justify-between px-5 py-3">
                                <dt class="text-xs font-semibold uppercase text-slate-500">Módulo</dt>
                                <dd class="text-slate-200 truncate max-w-[10rem]">@Model.ModuloOrigen</dd>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.VistaOrigen))
                        {
                            <div class="flex items-center justify-between px-5 py-3">
                                <dt class="text-xs font-semibold uppercase text-slate-500">Vista</dt>
                                <dd class="text-slate-400 text-right text-[11px] truncate max-w-[10rem]">@Model.VistaOrigen</dd>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.UrlOrigen))
                        {
                            <div class="flex items-center justify-between px-5 py-3">
                                <dt class="text-xs font-semibold uppercase text-slate-500">URL origen</dt>
                                <dd>
                                    <a href="@Model.UrlOrigen" class="text-primary-on-dark hover:underline text-[11px] truncate max-w-[10rem] block text-right no-underline">
                                        @Model.UrlOrigen
                                    </a>
                                </dd>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.ContextKey))
                        {
                            <div class="flex items-center justify-between px-5 py-3">
                                <dt class="text-xs font-semibold uppercase text-slate-500">Contexto</dt>
                                <dd class="font-mono text-[11px] text-slate-400 text-right truncate max-w-[10rem]">@Model.ContextKey</dd>
                            </div>
                        }
                    </dl>
                </section>

                @if (canViewTicketPanel)
                {
                    <section class="rounded-lg border border-slate-800 bg-slate-900/60 p-4 text-sm text-slate-400">
                        <div class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-primary-on-dark text-lg shrink-0 mt-0.5">info</span>
                            <div class="space-y-3">
                                <p class="leading-relaxed">
                                    @(canManageTicket
                                        ? "Las acciones de estado, resolución, checklist y adjuntos se gestionan desde el panel existente."
                                        : "Podés consultar este ticket en el panel existente. Las acciones de gestión dependen de tus permisos.")
                                </p>
                                <button type="button"
                                        data-ticket-panel-open="@Model.Id"
                                        class="inline-flex items-center gap-2 rounded-lg bg-primary/10 px-3 py-2 text-xs font-bold text-primary-on-dark transition-colors hover:bg-primary hover:text-white">
                                    <span class="material-symbols-outlined text-base">open_in_new</span>
                                    Abrir panel
                                </button>
                            </div>
                        </div>
                    </section>
                }

            </div>
        </aside>

    </div><!-- end grid -->

</div><!-- end space-y-8 -->

@if (transicionesPermitidas.Any() || canDeleteTicket)
{
    <partial name="_TicketActionModals" />
}

@section Scripts {
    <script src="~/js/ticket-module.js" asp-append-version="true"></script>
}
