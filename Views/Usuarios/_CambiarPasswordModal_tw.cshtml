@model TheBuryProject.ViewModels.CambiarPasswordUsuarioViewModel

<!-- Backdrop -->
<div id="changePassBackdrop"
     class="fixed inset-0 z-[60] bg-slate-950/80 backdrop-blur-sm opacity-0 transition-opacity duration-300">
</div>

<!-- Modal -->
<div id="changePassPanel"
     class="fixed inset-0 z-[60] flex items-center justify-center p-4 pointer-events-none">
    <div class="w-full max-w-lg bg-white dark:bg-slate-900 rounded-xl shadow-2xl border border-slate-200 dark:border-slate-800 overflow-hidden flex flex-col max-h-[90vh] pointer-events-auto scale-95 opacity-0 transition-all duration-300"
         id="changePassCard">

        <!-- Header -->
        <div class="px-6 py-5 border-b border-slate-200 dark:border-slate-800 flex justify-between items-center shrink-0">
            <div class="flex items-center gap-3">
                <div class="p-2 bg-primary/10 rounded-lg">
                    <span class="material-symbols-outlined text-primary">lock_reset</span>
                </div>
                <h2 class="text-xl font-bold text-slate-900 dark:text-white">Resetear Contraseña</h2>
            </div>
            <button type="button" id="closeChangePass"
                    class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <!-- Body -->
        <form id="formChangePass" asp-controller="Usuarios" asp-action="CambiarPassword" method="post" class="flex flex-col flex-1 overflow-hidden"
              data-required-length="@Model.RequiredLength"
              data-require-uppercase="@Model.RequireUppercase.ToString().ToLowerInvariant()"
              data-require-lowercase="@Model.RequireLowercase.ToString().ToLowerInvariant()"
              data-require-digit="@Model.RequireDigit.ToString().ToLowerInvariant()"
              data-require-symbol="@Model.RequireNonAlphanumeric.ToString().ToLowerInvariant()">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="UserName" />

            <div class="flex-1 overflow-y-auto p-6">
                <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed mb-6">
                    Definí una nueva contraseña para <strong class="text-slate-900 dark:text-white">@Model.UserName</strong>. Debe cumplir la política de seguridad vigente del sistema antes de confirmar el cambio.
                </p>

                <!-- Error container -->
                <div id="changePassErrors" class="hidden bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-900/50 rounded-lg p-4 flex gap-3 mb-5">
                    <span class="material-symbols-outlined text-red-500 shrink-0">error</span>
                    <div class="text-sm">
                        <p class="font-semibold text-red-800 dark:text-red-400">Error al resetear la contraseña</p>
                        <div id="changePassErrorList" class="text-red-700 dark:text-red-400/80 space-y-0.5"></div>
                    </div>
                </div>

                <div class="space-y-5">
                    <!-- Nueva contraseña -->
                    <div class="space-y-2">
                        <label asp-for="NewPassword" class="text-sm font-semibold text-slate-700 dark:text-slate-300">Nueva contraseña</label>
                        <div class="relative">
                            <input asp-for="NewPassword" type="password" placeholder="••••••••" required
                                   id="newPasswordInput"
                                   class="w-full bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-lg px-4 py-3 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all placeholder:text-slate-400" />
                            <button type="button" class="toggle-pass-visibility absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors" data-target="newPasswordInput">
                                <span class="material-symbols-outlined text-[20px]">visibility</span>
                            </button>
                        </div>
                        <!-- Strength bar -->
                        <div class="mt-2 space-y-2">
                            <div class="flex gap-1 h-1.5 w-full" id="strengthBars">
                                <div class="flex-1 bg-slate-200 dark:bg-slate-700 rounded-full transition-colors"></div>
                                <div class="flex-1 bg-slate-200 dark:bg-slate-700 rounded-full transition-colors"></div>
                                <div class="flex-1 bg-slate-200 dark:bg-slate-700 rounded-full transition-colors"></div>
                                <div class="flex-1 bg-slate-200 dark:bg-slate-700 rounded-full transition-colors"></div>
                            </div>
                            <div class="flex justify-between items-center">
                                <span id="strengthLabel" class="text-[11px] font-medium text-slate-400">Fortaleza: —</span>
                                <span class="text-[11px] text-slate-400">Política mínima requerida</span>
                            </div>
                        </div>
                        <div class="rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-800/30 p-4">
                            <p class="text-[11px] font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-3">Requisitos mínimos</p>
                            <div class="space-y-2 text-xs">
                                <div id="passwordRequirementLength" class="flex items-center gap-2 text-slate-500 dark:text-slate-400">
                                    <span class="material-symbols-outlined text-[16px]">radio_button_unchecked</span>
                                    Al menos @Model.RequiredLength caracteres
                                </div>
                                @if (Model.RequireUppercase)
                                {
                                    <div id="passwordRequirementUppercase" class="flex items-center gap-2 text-slate-500 dark:text-slate-400">
                                        <span class="material-symbols-outlined text-[16px]">radio_button_unchecked</span>
                                        Al menos una letra mayúscula
                                    </div>
                                }
                                @if (Model.RequireLowercase)
                                {
                                    <div id="passwordRequirementLowercase" class="flex items-center gap-2 text-slate-500 dark:text-slate-400">
                                        <span class="material-symbols-outlined text-[16px]">radio_button_unchecked</span>
                                        Al menos una letra minúscula
                                    </div>
                                }
                                @if (Model.RequireDigit)
                                {
                                    <div id="passwordRequirementDigit" class="flex items-center gap-2 text-slate-500 dark:text-slate-400">
                                        <span class="material-symbols-outlined text-[16px]">radio_button_unchecked</span>
                                        Al menos un número
                                    </div>
                                }
                                @if (Model.RequireNonAlphanumeric)
                                {
                                    <div id="passwordRequirementSymbol" class="flex items-center gap-2 text-slate-500 dark:text-slate-400">
                                        <span class="material-symbols-outlined text-[16px]">radio_button_unchecked</span>
                                        Al menos un símbolo
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Confirmar contraseña -->
                    <div class="space-y-2">
                        <label asp-for="ConfirmPassword" class="text-sm font-semibold text-slate-700 dark:text-slate-300">Confirmar nueva contraseña</label>
                        <div class="relative">
                            <input asp-for="ConfirmPassword" type="password" placeholder="••••••••" required
                                   id="confirmPasswordInput"
                                   class="w-full bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-lg px-4 py-3 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all placeholder:text-slate-400" />
                            <button type="button" class="toggle-pass-visibility absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors" data-target="confirmPasswordInput">
                                <span class="material-symbols-outlined text-[20px]">visibility</span>
                            </button>
                        </div>
                        <p id="matchIndicator" class="text-[11px] flex items-center gap-1 hidden">
                            <span class="material-symbols-outlined text-[14px]">check_circle</span>
                            Las contraseñas coinciden
                        </p>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="px-6 py-5 bg-slate-50 dark:bg-slate-800/30 flex flex-col sm:flex-row justify-end gap-3 border-t border-slate-200 dark:border-slate-800 shrink-0">
                <button type="button" id="cancelChangePass"
                        class="px-6 py-2.5 rounded-lg text-sm font-semibold text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors">
                    Cancelar
                </button>
                <button type="submit" id="submitChangePass"
                        class="px-6 py-2.5 rounded-lg text-sm font-semibold text-white bg-primary hover:bg-primary/90 shadow-lg shadow-primary/20 transition-all flex items-center justify-center gap-2">
                    Resetear contraseña
                </button>
            </div>
        </form>
    </div>
</div>
