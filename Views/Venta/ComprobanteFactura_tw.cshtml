@model FacturaComprobanteViewModel
@{
    Layout = null;
    var tituloFactura = $"Factura {Model.Factura.Tipo} {Model.Factura.Numero}";
}
<!doctype html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@tituloFactura</title>
    <style>
        :root {
            color: #111827;
            background: #f3f4f6;
            font-family: Arial, Helvetica, sans-serif;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            padding: 24px;
            background: #f3f4f6;
        }

        .page {
            width: min(960px, 100%);
            margin: 0 auto;
            background: #ffffff;
            border: 1px solid #d1d5db;
            padding: 32px;
        }

        .actions {
            width: min(960px, 100%);
            margin: 0 auto 16px;
            display: flex;
            justify-content: flex-end;
            gap: 8px;
        }

        .button {
            border: 1px solid #111827;
            background: #111827;
            color: #ffffff;
            padding: 10px 14px;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
        }

        .button-secondary {
            background: #ffffff;
            color: #111827;
        }

        .header {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 24px;
            border-bottom: 2px solid #111827;
            padding-bottom: 20px;
        }

        .brand {
            font-size: 24px;
            font-weight: 800;
            letter-spacing: 0;
        }

        .muted {
            color: #4b5563;
            font-size: 12px;
        }

        .invoice-box {
            min-width: 220px;
            border: 2px solid #111827;
            text-align: center;
        }

        .invoice-type {
            border-bottom: 2px solid #111827;
            padding: 8px;
            font-size: 32px;
            font-weight: 800;
        }

        .invoice-meta {
            padding: 12px;
            font-size: 13px;
            line-height: 1.7;
        }

        .badge {
            display: inline-block;
            border: 1px solid #991b1b;
            color: #991b1b;
            padding: 6px 10px;
            margin-top: 10px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 800;
            text-transform: uppercase;
        }

        .section-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-top: 24px;
        }

        .section {
            border: 1px solid #d1d5db;
            padding: 16px;
        }

        .section h2 {
            margin: 0 0 12px;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 0;
        }

        .field {
            display: grid;
            grid-template-columns: 120px 1fr;
            gap: 10px;
            margin: 7px 0;
            font-size: 13px;
        }

        .field span:first-child {
            color: #4b5563;
            font-weight: 700;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 24px;
            font-size: 13px;
        }

        th {
            background: #f3f4f6;
            border: 1px solid #d1d5db;
            padding: 9px;
            text-align: left;
            text-transform: uppercase;
            font-size: 11px;
        }

        td {
            border: 1px solid #d1d5db;
            padding: 9px;
            vertical-align: top;
        }

        .number {
            text-align: right;
            white-space: nowrap;
        }

        .totals {
            margin-top: 24px;
            margin-left: auto;
            width: min(360px, 100%);
            border: 1px solid #111827;
        }

        .total-row {
            display: grid;
            grid-template-columns: 1fr auto;
            border-bottom: 1px solid #d1d5db;
            padding: 10px 12px;
            font-size: 14px;
        }

        .total-row:last-child {
            border-bottom: 0;
            background: #111827;
            color: #ffffff;
            font-size: 18px;
            font-weight: 800;
        }

        .notes {
            margin-top: 24px;
            border-top: 1px solid #d1d5db;
            padding-top: 14px;
            font-size: 12px;
            color: #4b5563;
        }

        @@media (max-width: 720px) {
            body {
                padding: 12px;
            }

            .page {
                padding: 20px;
            }

            .header,
            .section-grid {
                grid-template-columns: 1fr;
            }

            .invoice-box {
                min-width: 0;
            }
        }

        @@media print {
            :root,
            body {
                background: #ffffff;
            }

            body {
                padding: 0;
            }

            .actions {
                display: none;
            }

            .page {
                width: 100%;
                border: 0;
                padding: 0;
            }
        }
    </style>
</head>
<body>
    <div class="actions">
        <button type="button" class="button button-secondary" onclick="history.back()">Volver</button>
        <button type="button" class="button" onclick="window.print()">Imprimir</button>
    </div>

    <main class="page">
        <header class="header">
            <div>
                <div class="brand">The Bury Project</div>
                <p class="muted">Comprobante de factura</p>
                @if (Model.Factura.Anulada)
                {
                    <span class="badge">Factura anulada</span>
                }
            </div>
            <div class="invoice-box">
                <div class="invoice-type">@Model.Factura.Tipo</div>
                <div class="invoice-meta">
                    <strong>Nro.</strong> @Model.Factura.Numero<br />
                    @if (!string.IsNullOrWhiteSpace(Model.Factura.PuntoVenta))
                    {
                        <strong>Punto de venta</strong> @Model.Factura.PuntoVenta<br />
                    }
                    <strong>Fecha</strong> @Model.Factura.FechaEmision.ToString("dd/MM/yyyy")
                </div>
            </div>
        </header>

        <section class="section-grid">
            <div class="section">
                <h2>Venta</h2>
                <div class="field"><span>Número</span><span>@Model.Venta.Numero</span></div>
                <div class="field"><span>Fecha</span><span>@Model.Venta.FechaVenta.ToString("dd/MM/yyyy HH:mm")</span></div>
                <div class="field"><span>Tipo de pago</span><span>@Model.Venta.TipoPago</span></div>
                <div class="field"><span>Estado</span><span>@Model.Venta.Estado</span></div>
                @if (!string.IsNullOrWhiteSpace(Model.Venta.VendedorNombre))
                {
                    <div class="field"><span>Vendedor</span><span>@Model.Venta.VendedorNombre</span></div>
                }
            </div>

            <div class="section">
                <h2>Cliente</h2>
                <div class="field"><span>Nombre</span><span>@Model.Cliente.Nombre</span></div>
                <div class="field"><span>Documento</span><span>@Model.Cliente.Documento</span></div>
                @if (!string.IsNullOrWhiteSpace(Model.Cliente.Telefono))
                {
                    <div class="field"><span>Teléfono</span><span>@Model.Cliente.Telefono</span></div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Cliente.Domicilio))
                {
                    <div class="field"><span>Domicilio</span><span>@Model.Cliente.Domicilio</span></div>
                }
            </div>
        </section>

        <table>
            <thead>
                <tr>
                    <th>Producto</th>
                    <th class="number">Cant.</th>
                    <th class="number">Precio</th>
                    <th class="number">Desc.</th>
                    <th>Alícuota</th>
                    <th class="number">Neto</th>
                    <th class="number">IVA</th>
                    <th class="number">Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var linea in Model.Lineas)
                {
                    <tr>
                        <td>
                            <strong>@linea.ProductoNombre</strong>
                            @if (!string.IsNullOrWhiteSpace(linea.ProductoCodigo))
                            {
                                <br /><span class="muted">@linea.ProductoCodigo</span>
                            }
                        </td>
                        <td class="number">@linea.Cantidad</td>
                        <td class="number">@linea.PrecioUnitario.ToString("C2")</td>
                        <td class="number">@linea.Descuento.ToString("C2")</td>
                        <td>@linea.AlicuotaIVANombre</td>
                        <td class="number">@linea.SubtotalNeto.ToString("C2")</td>
                        <td class="number">@linea.IVA.ToString("C2")</td>
                        <td class="number">@linea.Total.ToString("C2")</td>
                    </tr>
                }
            </tbody>
        </table>

        @if (Model.ResumenAlicuotas.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th>Resumen por alícuota</th>
                        <th class="number">Base imponible</th>
                        <th class="number">IVA</th>
                        <th class="number">Total</th>
                    </tr>
                </thead>
                <caption class="muted" style="caption-side: top; text-align: left; padding-bottom: 8px;">
                    El resumen por al&iacute;cuotas corresponde s&oacute;lo a productos.
                </caption>
                <tbody>
                    @foreach (var item in Model.ResumenAlicuotas)
                    {
                        <tr>
                            <td>@item.AlicuotaIVANombre (@item.PorcentajeIVA.ToString("0.##")%)</td>
                            <td class="number">@item.BaseImponible.ToString("C2")</td>
                            <td class="number">@item.IVA.ToString("C2")</td>
                            <td class="number">@item.Total.ToString("C2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <section class="totals">
            <div class="total-row"><span>Subtotal neto</span><strong>@Model.Totales.SubtotalNeto.ToString("C2")</strong></div>
            <div class="total-row"><span>IVA</span><strong>@Model.Totales.IVA.ToString("C2")</strong></div>
            @if (Model.Totales.RecargoDebitoAplicado > 0)
            {
                <div class="total-row"><span>Recargo d&eacute;bito</span><strong>@Model.Totales.RecargoDebitoAplicado.ToString("C2")</strong></div>
            }
            @if (Model.Totales.MontoAjustePlanAplicado.HasValue)
            {
                var montoAjuste = Model.Totales.MontoAjustePlanAplicado.Value;
                var pctAjuste = Model.Totales.PorcentajeAjustePlanAplicado;
                var esRecargo = montoAjuste > 0;
                var esDescuento = montoAjuste < 0;
                var etiqueta = esRecargo ? "Recargo por plan" : esDescuento ? "Descuento por plan" : "Ajuste por plan";
                var sufijoPct = pctAjuste.HasValue ? $" ({(pctAjuste.Value > 0 ? "+" : "")}{pctAjuste.Value:0.##}%)" : "";
                <div class="total-row"><span>@etiqueta@sufijoPct</span><strong>@montoAjuste.ToString("C2")</strong></div>
            }
            <div class="total-row"><span>Total</span><strong>@Model.Totales.Total.ToString("C2")</strong></div>
        </section>

        @if (!string.IsNullOrWhiteSpace(Model.Factura.CAE) ||
             Model.Factura.FechaVencimientoCAE.HasValue ||
             Model.Factura.Anulada ||
             !string.IsNullOrWhiteSpace(Model.Venta.Observaciones))
        {
            <section class="notes">
                @if (!string.IsNullOrWhiteSpace(Model.Factura.CAE))
                {
                    <p><strong>CAE:</strong> @Model.Factura.CAE</p>
                }
                @if (Model.Factura.FechaVencimientoCAE.HasValue)
                {
                    <p><strong>Vencimiento CAE:</strong> @Model.Factura.FechaVencimientoCAE.Value.ToString("dd/MM/yyyy")</p>
                }
                @if (Model.Factura.Anulada)
                {
                    <p><strong>Anulada:</strong> @Model.Factura.FechaAnulacion?.ToString("dd/MM/yyyy HH:mm") @Model.Factura.MotivoAnulacion</p>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Venta.Observaciones))
                {
                    <p><strong>Observaciones:</strong> @Model.Venta.Observaciones</p>
                }
            </section>
        }
    </main>
</body>
</html>
