                                                                                                                                </button>
                                                                                                                            </div>
                                                                                                                        </div>
                                                                                                                    </div>
                                                                                                                </div>
                                                                                                            }
                                                                                                        </div>
                                                                                                    </div>
                                                                                                </section>

                                                                                                <section id="step-panel-revision" role="tabpanel" aria-labelledby="step-btn-revision" class="hidden">
                                                                                                    <div class="venta-section">
                                                                                                        <div class="mb-6 flex items-start justify-between gap-4">
                                                                                                            <div class="flex items-center gap-3">
                                                                                                                <span
                                                                                                                class="w-8 h-8 shrink-0 flex items-center justify-center rounded-full bg-primary/15 text-primary text-xs font-bold">4</span>
                                                                                                                <div>
                                                                                                                    <h2 class="text-lg font-bold text-white">Revisión</h2>
                                                                                                                    <p class="text-sm text-slate-400">Resumen final antes de confirmar la operación.</p>
                                                                                                                </div>
                                                                                                            </div>
                                                                                                            <span id="revision-alertas-badge" class="badge-erp badge-erp-neutral hidden shrink-0">0
                                                                                                                alertas</span>
                                                                                                            </div>
                                                                                                            <div class="grid gap-4 md:grid-cols-2">
                                                                                                                <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                                                                                                                    <p class="text-[10px] font-bold uppercase tracking-[0.18em] text-slate-500">Cliente</p>
                                                                                                                    <p data-rev-cliente class="mt-2 text-sm font-bold text-white">Sin seleccionar</p>
                                                                                                                    <p data-rev-fecha class="mt-1 text-xs text-slate-400">Fecha sin definir</p>
                                                                                                                </div>
                                                                                                                <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                                                                                                                    <p class="text-[10px] font-bold uppercase tracking-[0.18em] text-slate-500">Pago</p>
                                                                                                                    <p data-rev-pago data-pago-summary class="mt-2 text-sm font-bold text-white">Sin definir
                                                                                                                    </p>
                                                                                                                    <p data-rev-items class="mt-1 text-xs text-slate-400">0 productos</p>
                                                                                                                </div>
                                                                                                            </div>
                                                                                                            <div id="revision-alertas" class="mt-4 rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                                                                                                                <p class="text-[10px] font-bold uppercase tracking-[0.18em] text-slate-500">Alertas</p>
                                                                                                                <p id="revision-alertas-vacio" class="mt-2 text-sm text-slate-400">Sin alertas activas.</p>
                                                                                                                <div id="revision-alertas-lista" class="mt-3 hidden space-y-2"></div>
                                                                                                            </div>
                                                                                                            <div class="mt-4 rounded-xl border border-slate-800 bg-slate-900/60 p-4">
                                                                                                                <div class="flex justify-between text-sm">
                                                                                                                    <span class="text-slate-400">Subtotal</span>
                                                                                                                    <span data-rev-subtotal class="font-semibold text-slate-200">$0,00</span>
                                                                                                                </div>
                                                                                                                <div class="mt-2 flex justify-between text-sm">
                                                                                                                    <span class="text-slate-400">Descuento</span>
                                                                                                                    <span data-rev-descuento class="font-semibold text-slate-200">-$0,00</span>
                                                                                                                </div>
                                                                                                                <div class="mt-2 flex justify-between text-sm">
                                                                                                                    <span class="text-slate-400">IVA</span>
                                                                                                                    <span data-rev-iva class="font-semibold text-slate-200">$0,00</span>
                                                                                                                </div>
                                                                                                                <div class="mt-3 flex items-center justify-between border-t border-slate-800 pt-3">
                                                                                                                    <span class="font-bold text-white">Total</span>
                                                                                                                    <span data-rev-total class="text-2xl font-black text-white">$0,00</span>
                                                                                                                </div>
                                                                                                            </div>
                                                                                                        </div>
                                                                                                    </section>

                                                                                                </div>
                                                                                                @* ── /Columna izquierda ─────────────────────────────────── *@

                                                                                                @* ── Sidebar derecha (resumen persistente) ───────────────── *@
                                                                                                <aside class="vm-sidebar flex flex-col gap-5 lg:col-span-4">

                                                                                                    @* ── Sección 5: Observaciones ────────────── *@
                                                                                                    @* El vendedor siempre es el usuario logueado; el backend lo resuelve (ResolverVendedorAsync) y no se muestra en el form. *@
                                                                                                    <section class="venta-section">

                                                                                                        <div>
                                                                                                            <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Observaciones</label>
                                                                                                            <textarea asp-for="Observaciones" id="Observaciones" class="venta-input h-28 resize-none"
                                                                                                                      placeholder="Notas internas sobre la venta..."></textarea>
                                                                                                        </div>
                                                                                                    </section>

                                                                                                    @* ── Sección 6: Totales y confirmación ──────────────── *@
                                                                                                    <section
                                                                                                        class="vm-totals overflow-hidden rounded-3xl bg-primary p-6 text-white shadow-xl shadow-primary/20">


                                                                                                        @* ── Recordatorio pre-confirmación (VENTAS-UX-1G) ── *@
                                                                                                        @if (!esCotizacion)
                                                                                                        {
                                                                                                            <div class="mb-4 flex items-start gap-2 rounded-lg border border-white/20 bg-white/10 p-3 text-xs text-white/80" role="note" aria-label="Revisá antes de confirmar"><span class="material-symbols-outlined text-sm shrink-0 mt-0.5 text-white/60" aria-hidden="true">checklist</span> <span>Verificá cliente, tipo de pago y total. Si hay alertas activas de mora, cupo o
                                                                                                                    documentación, revisalas antes de continuar.
                                                                                                                    <span class="mt-2 block text-white/90">
                                                                                                                        <span data-conf-cliente>Cliente sin seleccionar</span> ·
                                                                                                                        <span data-conf-items>0 productos</span> ·
                                                                                                                        <span data-conf-pago>Pago sin definir</span> ·
                                                                                                                        <span data-conf-total>$0,00</span> ·
                                                                                                                        <span data-conf-credito>Crédito no requerido</span>
                                                                                                                    </span>
                                                                                                                </span>
                                                                                                            </div>
                                                                                                        }

                                                                                                        <button type="submit" id="btn-confirmar" class="vm-btn-confirm">
                                                                                                            <span class="material-symbols-outlined">point_of_sale</span>
                                                                                                            @(esCotizacion ? "Guardar Cotización" : "Confirmar Transacción")
                                                                                                        </button>
                                                                                                        <p class="text-center text-[10px] mt-4 opacity-60">
                                                                                                            @(esCotizacion ? "Se guardará como cotización pendiente." : "Al confirmar, se generará la factura correspondiente.")
                                                                                                        </p>
                                                                                                    </section>

                                                                                                    <div class="flex flex-col gap-3 sm:flex-row">
                                                                                                        @if (!esCotizacion)
                                                                                                        {
                                                                                                            <a asp-controller="Cotizacion" asp-action="Index" class="btn-erp-ghost w-full flex-1 sm:w-auto">
                                                                                                                <span class="material-symbols-outlined text-sm">description</span> Ir al cotizador
                                                                                                            </a>
                                                                                                        }
                                                                                                        <button type="button" id="btn-imprimir-borrador" class="btn-erp-ghost w-full flex-1 sm:w-auto">
                                                                                                            <span class="material-symbols-outlined text-sm">print</span> Imprimir Borrador
                                                                                                        </button>
                                                                                                    </div>

                                                                                                </aside>
                                                                                                @* ── /Sidebar derecha ───────────────────────────────────── *@

                                                                                            </div>

                                                                                            @* Totales — fuente de verdad para JS (venta-create.js escribe estos ids;
                                                                                               venta-page-wizard.js los espeja hacia los spans visibles data-rev-*/data-mobile-total).
                                                                                               Se mantienen ocultos porque la presentación vive en el panel Revisión y la barra móvil. *@
                                                                                            <div class="hidden" aria-hidden="true">
                                                                                                <span data-side-cliente>Sin seleccionar</span>
                                                                                                <span data-side-items>0 productos</span>
                                                                                                <span data-side-pago>Sin definir</span>
                                                                                                <span id="total-subtotal" data-side-subtotal>$0,00</span>
                                                                                                <span id="total-descuento" data-side-descuento>-$0,00</span>
                                                                                                <span id="total-iva" data-side-iva>$0,00</span>
                                                                                                <span id="total-final" data-side-total>$0,00</span>
                                                                                                <input type="hidden" asp-for="Subtotal" id="hdn-subtotal" />
                                                                                                <input type="hidden" asp-for="Descuento" id="hdn-descuento" />
                                                                                                <input type="hidden" asp-for="IVA" id="hdn-iva" />
                                                                                                <input type="hidden" asp-for="Total" id="hdn-total" />
                                                                                            </div>

                                                                                            @* Inputs ocultos para el envío de detalles por POST *@
                                                                                            <div id="detalles-hidden-inputs" class="hidden"></div>

                                                                                        </form>

                                                                                    </div>


                                                                                    @* ══════════════════════════════════════════════════════════════════
   MODAL — Carga de documentación crediticia
   ══════════════════════════════════════════════════════════════════ *@
                                                                                    <div id="modal-documentacion" data-venta-modal="documentacion" class="fixed inset-0 z-50 hidden" aria-hidden="true">
                                                                                        <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" id="modal-documentacion-overlay"
                                                                                             data-venta-modal-action="close"></div>
                                                                                        <div class="relative flex items-center justify-center min-h-screen p-4">
                                                                                            <div class="relative bg-slate-900 rounded-2xl border border-slate-800 w-full max-w-lg shadow-2xl">
                                                                                                <div class="flex items-center justify-between p-6 border-b border-slate-800">
                                                                                                    <h3 class="text-lg font-bold text-white flex items-center gap-2">
                                                                                                        <span class="material-symbols-outlined text-primary">upload_file</span>
                                                                                                        Documentación Crediticia
                                                                                                    </h3>
                                                                                                    <button type="button" id="btn-cerrar-modal-doc" data-venta-modal-action="close"
                                                                                                            class="p-1 rounded-lg hover:bg-slate-800 transition-all">
                                                                                                        <span class="material-symbols-outlined text-slate-400">close</span>
                                                                                                    </button>
                                                                                                </div>
                                                                                                <div class="p-6 space-y-5">
                                                                                                    <div class="rounded-xl border border-primary/20 bg-primary/10 p-4 text-sm text-slate-300">
                                                                                                        Completá o renová la documentación faltante sin abandonar la operación.
                                                                                                        Cuando cierres el modal, podés volver a verificar elegibilidad.
                                                                                                    </div>
                                                                                                    <div class="space-y-3">
                                                                                                        <p class="text-xs font-bold text-slate-500 uppercase">Documentos pendientes</p>
                                                                                                        <div id="modal-lista-docs" class="space-y-2"></div>
                                                                                                    </div>
                                                                                                    <div class="border-2 border-dashed border-slate-700 rounded-xl p-6 text-center">
                                                                                                        <span class="material-symbols-outlined text-3xl text-slate-400 mb-2 block">cloud_upload</span>
                                                                                                        <p class="text-sm font-bold text-slate-400 mb-1">Subir documentación</p>
                                                                                                        <p class="text-[11px] text-slate-400 mb-3">PDF, JPG, PNG — máximo 10 MB</p>
                                                                                                        <label
                                                                                                            class="inline-flex items-center gap-2 px-4 py-2 bg-primary/10 text-primary text-xs font-bold rounded-lg cursor-pointer hover:bg-primary/20 transition-all">
                                                                                                            <span class="material-symbols-outlined text-sm">attach_file</span> Seleccionar archivo
                                                                                                            <input type="file" id="input-doc-archivo" accept=".pdf,.jpg,.jpeg,.png" class="hidden" />
                                                                                                        </label>
                                                                                                        <p id="doc-archivo-nombre" class="text-[11px] text-slate-500 mt-2 hidden"></p>
                                                                                                    </div>
                                                                                                    <div>
                                                                                                        <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Tipo de documento</label>
                                                                                                        <select id="select-tipo-documento"
                                                                                                                class="w-full text-sm bg-slate-800 border border-slate-700 rounded-lg px-3 py-2">
                                                                                                            <option value="">Seleccione tipo...</option>
                                                                                                        </select>
                                                                                                    </div>
                                                                                                    <div id="doc-upload-feedback" class="hidden p-3 rounded-lg text-xs font-bold"></div>
                                                                                                </div>
                                                                                                <div class="venta-create-doc-footer flex gap-3 border-t border-slate-800 p-6">
                                                                                                    <button type="button" id="btn-subir-documento"
                                                                                                            class="venta-create-doc-action inline-flex flex-1 items-center justify-center gap-2 rounded-xl bg-primary py-3 text-xs font-bold uppercase tracking-tighter text-white transition-all hover:bg-primary/90"
                                                                                                            disabled>
                                                                                                        <span class="material-symbols-outlined text-sm">upload</span> Subir Documento
                                                                                                    </button>
                                                                                                    <button type="button" id="btn-ir-documentacion" class="venta-create-doc-action btn-erp-ghost flex-1">
                                                                                                        <span class="material-symbols-outlined text-sm">open_in_new</span> Ir a Documentación
                                                                                                    </button>
                                                                                                </div>
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>

                                                                                    @section Styles {
                                                                                        <partial name="_VentaModuleStyles" />
                                                                                    }

                                                                                    @section Scripts {
                                                                                        <script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
                                                                                        <script src="~/js/venta-module.js" asp-append-version="true"></script>
                                                                                        <script src="~/js/venta-create.js" asp-append-version="true"></script>
                                                                                        <script src="~/js/venta-page-wizard.js" asp-append-version="true"></script>
                                                                                    }
