@model TheBuryProject.ViewModels.VentaViewModel
@using TheBuryProject.Models.Enums
@using TheBuryProject.Helpers
@{
    ViewData["Title"] = Model.Estado == EstadoVenta.Cotizacion ? "Nueva Cotización" : "Nueva Venta";
    var clientes = ViewBag.Clientes as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var productos = ViewBag.Productos as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var tiposPago = ViewBag.TiposPago as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>;
    var tarjetas = ViewBag.Tarjetas as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var creditos = ViewBag.Creditos as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var categorias = ViewBag.CategoriasFiltro as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var marcas = ViewBag.MarcasFiltro as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var vendedores = ViewBag.Vendedores as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var puedeDelegarVendedor = (bool)(ViewBag.PuedeDelegarVendedor ?? false);
    var ivaRate = (decimal)(ViewBag.IvaRate ?? 0.21m);
    var esCotizacion = Model.Estado == EstadoVenta.Cotizacion;
}

<!-- Validation Errors -->
@if (!ViewData.ModelState.IsValid)
{
    <div id="banner-errores" class="flex flex-1 flex-col items-start justify-between gap-4 rounded-xl border border-red-500/30 bg-red-500/10 p-5 sm:flex-row sm:items-center mb-6">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-red-500">error</span>
            <div class="flex flex-col gap-1">
                <p class="text-slate-900 dark:text-white text-base font-bold leading-tight">Corrige los errores antes de continuar</p>
                <div class="text-slate-600 dark:text-slate-400 text-sm font-normal">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p>@error.ErrorMessage</p>
                    }
                </div>
            </div>
        </div>
        <button type="button" onclick="this.closest('[id=banner-errores]').remove()"
                class="text-sm font-bold leading-normal flex items-center gap-2 text-slate-900 dark:text-white opacity-70 hover:opacity-100">
            Cerrar
        </button>
    </div>
}

<!-- Success/Warning/Error Toasts -->
@if (TempData["Success"] != null)
{
    <div class="toast-msg flex items-center gap-3 p-4 rounded-xl border border-green-500/30 bg-green-500/10 mb-4">
        <span class="material-symbols-outlined text-green-500">check_circle</span>
        <p class="text-green-700 dark:text-green-400 text-sm font-medium">@TempData["Success"]</p>
    </div>
}
@if (TempData["Warning"] != null)
{
    <div class="toast-msg flex items-center gap-3 p-4 rounded-xl border border-orange-500/30 bg-orange-500/10 mb-4">
        <span class="material-symbols-outlined text-orange-500">warning</span>
        <p class="text-orange-700 dark:text-orange-400 text-sm font-medium">@TempData["Warning"]</p>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="toast-msg flex items-center gap-3 p-4 rounded-xl border border-red-500/30 bg-red-500/10 mb-4">
        <span class="material-symbols-outlined text-red-500">error</span>
        <p class="text-red-700 dark:text-red-400 text-sm font-medium">@TempData["Error"]</p>
    </div>
}

<form id="venta-form" asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Estado" />
    <input type="hidden" asp-for="RowVersion" />
    <input type="hidden" id="hdn-iva-rate" value="@ivaRate" />

    <!-- Header Section -->
    <div class="mb-8">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
            <div>
                <h1 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">
                    @(esCotizacion ? "Nueva Cotización" : "Nueva Venta")
                </h1>
                <p class="text-slate-500 dark:text-slate-400 mt-1">Gestión profesional de transacciones y presupuestos corporativos.</p>
            </div>
            <div class="flex gap-3">
                <a asp-action="Index" class="px-5 py-2.5 rounded-lg border border-slate-300 dark:border-slate-700 font-bold text-sm hover:bg-slate-50 dark:hover:bg-slate-800 transition-all">Cancelar</a>
                <button type="submit" class="px-5 py-2.5 rounded-lg bg-primary text-white font-bold text-sm shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all">
                    Guardar Operación
                </button>
            </div>
        </div>

        <!-- System Status Banner -->
        <div id="banner-status" class="flex items-center justify-between p-4 rounded-xl border border-primary/20 bg-primary/5 dark:bg-primary/10">
            <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary">verified_user</span>
                <div>
                    <p class="text-slate-900 dark:text-white text-sm font-bold">Estado del Sistema: Operativo</p>
                    <p class="text-slate-500 dark:text-slate-400 text-xs">Todos los servicios de validación de crédito y AFIP están en línea.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Left Column: Main Form -->
        <div class="lg:col-span-2 flex flex-col gap-8">

            <!-- 1. General Data Section -->
            <section class="bg-white dark:bg-slate-900/50 p-6 rounded-xl border border-slate-200 dark:border-slate-800">
                <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">person</span> 1. Datos Generales
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <!-- Client Search -->
                    <div class="md:col-span-2">
                        <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Buscar Cliente</label>
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-400">search</span>
                            <input id="input-buscar-cliente" type="text" autocomplete="off"
                                   class="w-full pl-10 pr-4 py-3 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-white focus:ring-primary focus:border-primary"
                                   placeholder="Nombre, CUIT o DNI del cliente..." />
                            <div id="dropdown-clientes" class="absolute top-full left-0 w-full bg-white dark:bg-slate-800 mt-1 rounded-lg border border-slate-200 dark:border-slate-700 shadow-xl z-20 hidden max-h-60 overflow-y-auto"></div>
                        </div>
                        <input type="hidden" asp-for="ClienteId" id="hdn-cliente-id" />
                    </div>

                    <!-- Selected Client Info -->
                    <div id="info-cliente" class="md:col-span-2 hidden p-4 rounded-lg bg-slate-50 dark:bg-slate-800/50 border border-slate-100 dark:border-slate-800">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-3">
                                <div class="size-10 bg-primary/20 rounded-full flex items-center justify-center">
                                    <span class="material-symbols-outlined text-primary text-sm">person</span>
                                </div>
                                <div>
                                    <p id="info-cliente-nombre" class="text-sm font-bold text-slate-900 dark:text-white"></p>
                                    <p id="info-cliente-doc" class="text-xs text-slate-500"></p>
                                </div>
                            </div>
                            <button type="button" id="btn-limpiar-cliente" class="text-xs font-bold text-red-500 hover:underline">Cambiar</button>
                        </div>
                    </div>

                    <!-- Date -->
                    <div>
                        <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Fecha de Operación</label>
                        <input asp-for="FechaVenta" type="date"
                               class="w-full py-3 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-white focus:ring-primary focus:border-primary" />
                    </div>

                    <!-- Payment Type -->
                    <div>
                        <label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Forma de Pago</label>
                        <select asp-for="TipoPago" id="select-tipo-pago"
                                class="w-full py-3 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-white focus:ring-primary focus:border-primary">
                            @if (tiposPago != null)
                            {
                                @foreach (var tp in tiposPago)
                                {
                                    <option value="@tp.Value">@tp.Text</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <!-- Dynamic Info: Credit Notice (hidden by default) -->
                <div id="panel-aviso-credito" class="mt-6 p-4 rounded-lg bg-orange-500/10 border border-orange-500/20 hidden">
                    <div class="flex items-center gap-3 mb-2">
                        <span class="material-symbols-outlined text-orange-500">info</span>
                        <span class="text-orange-500 font-bold text-sm">Aviso de Crédito Personal</span>
                    </div>
                    <div class="grid grid-cols-3 gap-4 text-xs">
                        <div>
                            <p class="text-slate-500 dark:text-slate-400">Disponible</p>
                            <p id="credito-disponible" class="text-slate-900 dark:text-white font-bold">$0,00</p>
                        </div>
                        <div>
                            <p class="text-slate-500 dark:text-slate-400">Solicitado</p>
                            <p id="credito-solicitado" class="text-slate-900 dark:text-white font-bold">$0,00</p>
                        </div>
                        <div>
                            <p class="text-slate-500 dark:text-slate-400">Margen</p>
                            <p id="credito-margen" class="text-slate-900 dark:text-white font-bold">$0,00</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- 2. Products Section -->
            <section class="bg-white dark:bg-slate-900/50 p-6 rounded-xl border border-slate-200 dark:border-slate-800">
                <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">inventory_2</span> 2. Selección de Productos
                </h3>

                <!-- Advanced Filters -->
                <div class="grid grid-cols-1 md:grid-cols-4 gap-3 mb-6 p-4 bg-slate-50 dark:bg-slate-800/50 rounded-lg border border-slate-100 dark:border-slate-800">
                    <select id="filtro-categoria" class="text-xs bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-md">
                        <option value="">Categoría: Todas</option>
                        @if (categorias != null)
                        {
                            @foreach (var cat in categorias)
                            {
                                <option value="@cat.Value">@cat.Text</option>
                            }
                        }
                    </select>
                    <select id="filtro-marca" class="text-xs bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-md">
                        <option value="">Marca: Todas</option>
                        @if (marcas != null)
                        {
                            @foreach (var marca in marcas)
                            {
                                <option value="@marca.Value">@marca.Text</option>
                            }
                        }
                    </select>
                    <div class="flex gap-2">
                        <input id="filtro-precio-min" type="number" min="0" step="0.01" class="w-full text-xs bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-md" placeholder="Min $" />
                        <input id="filtro-precio-max" type="number" min="0" step="0.01" class="w-full text-xs bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-md" placeholder="Max $" />
                    </div>
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input id="filtro-solo-stock" type="checkbox" checked class="rounded text-primary focus:ring-primary bg-white dark:bg-slate-800 border-slate-200 dark:border-slate-700" />
                        <span class="text-xs text-slate-600 dark:text-slate-400 font-medium">Solo con stock</span>
                    </label>
                </div>

                <!-- Search and Quick Add -->
                <div class="flex flex-col gap-4 mb-8">
                    <div class="relative">
                        <input id="input-buscar-producto" type="text" autocomplete="off"
                               class="w-full py-3 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-white"
                               placeholder="Escriba código o nombre del producto..." />
                        <div id="dropdown-productos" class="absolute top-full left-0 w-full bg-white dark:bg-slate-800 mt-1 rounded-lg border border-slate-200 dark:border-slate-700 shadow-xl z-20 hidden max-h-72 overflow-y-auto"></div>
                    </div>
                    <div id="panel-agregar-producto" class="grid grid-cols-2 md:grid-cols-5 gap-3 hidden">
                        <div class="md:col-span-2">
                            <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">Producto Seleccionado</label>
                            <input id="txt-producto-seleccionado" type="text" readonly
                                   class="w-full text-sm bg-slate-100 dark:bg-slate-700 border-none rounded-lg text-slate-600 dark:text-slate-300" />
                            <input type="hidden" id="hdn-producto-id" />
                            <input type="hidden" id="hdn-producto-codigo" />
                            <input type="hidden" id="hdn-producto-precio" />
                            <input type="hidden" id="hdn-producto-stock" />
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">Cantidad</label>
                            <input id="txt-cantidad" type="number" min="1" value="1"
                                   class="w-full text-sm bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg" />
                            <p id="stock-error" class="hidden text-[9px] text-red-500 font-bold mt-1"></p>
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">Desc. %</label>
                            <input id="txt-descuento-item" type="number" min="0" max="100" value="0"
                                   class="w-full text-sm bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg" />
                        </div>
                        <div class="flex items-end">
                            <button type="button" id="btn-agregar-producto"
                                    class="w-full py-2 bg-primary text-white rounded-lg flex items-center justify-center gap-1 font-bold text-sm">
                                <span class="material-symbols-outlined text-sm">add</span> Añadir
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Product Table -->
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="border-b border-slate-200 dark:border-slate-800">
                                <th class="py-3 px-2 text-[10px] font-bold text-slate-500 uppercase">Cód.</th>
                                <th class="py-3 px-2 text-[10px] font-bold text-slate-500 uppercase">Producto</th>
                                <th class="py-3 px-2 text-[10px] font-bold text-slate-500 uppercase text-center">Cant.</th>
                                <th class="py-3 px-2 text-[10px] font-bold text-slate-500 uppercase text-right">Unitario</th>
                                <th class="py-3 px-2 text-[10px] font-bold text-slate-500 uppercase text-right">Desc.</th>
                                <th class="py-3 px-2 text-[10px] font-bold text-slate-500 uppercase text-right">Subtotal</th>
                                <th class="py-3 px-2 text-[10px] font-bold text-slate-500 uppercase text-right"></th>
                            </tr>
                        </thead>
                        <tbody id="tbody-detalles" class="divide-y divide-slate-100 dark:divide-slate-800/50">
                        </tbody>
                    </table>
                    <div id="detalles-vacio" class="text-center py-12 text-slate-400">
                        <span class="material-symbols-outlined text-4xl mb-2">shopping_cart</span>
                        <p class="text-sm">No hay productos agregados. Busque y añada productos arriba.</p>
                    </div>
                </div>
            </section>

            <!-- 3. Payment Details Section (Cards/Checks/Credit) -->
            <section id="seccion-detalle-cobro" class="bg-white dark:bg-slate-900/50 p-6 rounded-xl border border-slate-200 dark:border-slate-800">
                <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">credit_card</span> 3. Detalle de Cobro
                </h3>
                <div class="flex flex-col gap-8">

                    <!-- Card View -->
                    <div id="panel-tarjeta" class="p-6 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/30 hidden">
                        <h4 class="text-sm font-bold mb-4 flex items-center gap-2">
                            <span class="material-symbols-outlined text-sm">payments</span> Datos de Tarjeta
                        </h4>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <div>
                                <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Tarjeta</label>
                                <select id="select-tarjeta" name="DatosTarjeta.ConfiguracionTarjetaId"
                                        class="w-full text-sm bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg">
                                    <option value="">Seleccione tarjeta...</option>
                                    @if (tarjetas != null)
                                    {
                                        @foreach (var t in tarjetas)
                                        {
                                            <option value="@t.Value">@t.Text</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Cuotas</label>
                                <select id="select-cuotas-tarjeta" name="DatosTarjeta.CantidadCuotas"
                                        class="w-full text-sm bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg">
                                    <option value="1">1 Pago</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-slate-500 uppercase mb-1">N° Autorización</label>
                                <input type="text" name="DatosTarjeta.NumeroAutorizacion" id="txt-num-autorizacion-tarjeta"
                                       class="w-full text-sm bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg"
                                       placeholder="000000" />
                            </div>
                        </div>
                        <div id="panel-tarjeta-resumen" class="mt-4 flex flex-wrap gap-4 pt-4 border-t border-slate-200 dark:border-slate-700 hidden">
                            <div class="px-3 py-2 bg-primary/10 rounded-md">
                                <p class="text-[10px] text-primary font-bold uppercase">Monto por cuota</p>
                                <p id="tarjeta-monto-cuota" class="text-sm font-bold text-slate-900 dark:text-white">$0,00</p>
                            </div>
                            <div class="px-3 py-2 bg-slate-100 dark:bg-slate-700 rounded-md">
                                <p class="text-[10px] text-slate-500 font-bold uppercase">Total con interés</p>
                                <p id="tarjeta-total-interes" class="text-sm font-bold text-slate-900 dark:text-white">$0,00</p>
                            </div>
                            <div class="px-3 py-2 bg-slate-100 dark:bg-slate-700 rounded-md">
                                <p class="text-[10px] text-slate-500 font-bold uppercase">Recargo aplicado</p>
                                <p id="tarjeta-recargo" class="text-sm font-bold text-slate-900 dark:text-white">0%</p>
                            </div>
                        </div>
                    </div>

                    <!-- Check View -->
                    <div id="panel-cheque" class="p-6 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/30 hidden">
                        <h4 class="text-sm font-bold mb-4 flex items-center gap-2">
                            <span class="material-symbols-outlined text-sm">receipt_long</span> Datos del Cheque
                        </h4>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Número de Cheque</label>
                                <input type="text" name="DatosCheque.NumeroCheque" id="txt-num-cheque"
                                       class="w-full text-sm bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg"
                                       placeholder="Nº de cheque" />
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Banco</label>
                                <input type="text" name="DatosCheque.Banco" id="txt-banco-cheque"
                                       class="w-full text-sm bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg"
                                       placeholder="Nombre del banco" />
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Titular</label>
                                <input type="text" name="DatosCheque.Titular" id="txt-titular-cheque"
                                       class="w-full text-sm bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg"
                                       placeholder="Nombre del titular" />
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-slate-500 uppercase mb-1">CUIT</label>
                                <input type="text" name="DatosCheque.CUIT" id="txt-cuit-cheque"
                                       class="w-full text-sm bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg"
                                       placeholder="XX-XXXXXXXX-X" />
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Fecha de Emisión</label>
                                <input type="date" name="DatosCheque.FechaEmision" id="txt-fecha-emision-cheque"
                                       class="w-full text-sm bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg" />
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Fecha de Vencimiento</label>
                                <input type="date" name="DatosCheque.FechaVencimiento" id="txt-fecha-vencimiento-cheque"
                                       class="w-full text-sm bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg" />
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Monto</label>
                                <input type="number" step="0.01" name="DatosCheque.Monto" id="txt-monto-cheque"
                                       class="w-full text-sm bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg"
                                       placeholder="$0,00" />
                            </div>
                        </div>
                    </div>

                    <!-- Credit View -->
                    <div id="panel-credito-personal" class="p-6 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/30 hidden">
                        <h4 class="text-sm font-bold mb-4 flex items-center gap-2">
                            <span class="material-symbols-outlined text-sm">account_balance</span> Crédito Personal
                        </h4>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="md:col-span-2">
                                <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Seleccionar Crédito</label>
                                <select id="select-credito" name="CreditoId"
                                        class="w-full text-sm bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg">
                                    <option value="">Seleccione un crédito...</option>
                                    @if (creditos != null)
                                    {
                                        @foreach (var c in creditos)
                                        {
                                            <option value="@c.Value">@c.Text</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <div id="panel-credito-info" class="mt-4 pt-4 border-t border-slate-200 dark:border-slate-700 hidden">
                            <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                                <div class="px-3 py-2 bg-primary/10 rounded-md">
                                    <p class="text-[10px] text-primary font-bold uppercase">Crédito Nº</p>
                                    <p id="credito-info-numero" class="text-sm font-bold text-slate-900 dark:text-white">-</p>
                                </div>
                                <div class="px-3 py-2 bg-slate-100 dark:bg-slate-700 rounded-md">
                                    <p class="text-[10px] text-slate-500 font-bold uppercase">Monto Aprobado</p>
                                    <p id="credito-info-aprobado" class="text-sm font-bold text-slate-900 dark:text-white">$0,00</p>
                                </div>
                                <div class="px-3 py-2 bg-slate-100 dark:bg-slate-700 rounded-md">
                                    <p class="text-[10px] text-slate-500 font-bold uppercase">Saldo Disponible</p>
                                    <p id="credito-info-saldo" class="text-sm font-bold text-green-500">$0,00</p>
                                </div>
                                <div class="px-3 py-2 bg-slate-100 dark:bg-slate-700 rounded-md">
                                    <p class="text-[10px] text-slate-500 font-bold uppercase">Tasa Interés</p>
                                    <p id="credito-info-tasa" class="text-sm font-bold text-slate-900 dark:text-white">0%</p>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </section>

        </div>

        <!-- Right Column: Verification & Totals -->
        <div class="flex flex-col gap-8">

            <!-- 4. Credit Eligibility Verification -->
            <section id="seccion-verificacion-crediticia" class="bg-white dark:bg-slate-900/50 p-6 rounded-xl border border-slate-200 dark:border-slate-800">
                <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">verified</span> Verificación Crediticia
                </h3>
                <div class="flex flex-col gap-5">
                    <!-- Verify Button -->
                    <button type="button" id="btn-verificar-elegibilidad"
                            class="w-full py-4 bg-primary/10 text-primary rounded-xl font-bold hover:bg-primary/20 transition-all flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined">analytics</span> Verificar Elegibilidad
                    </button>

                    <!-- Result Panel -->
                    <div id="panel-resultado-verificacion" class="hidden space-y-4">
                        <!-- Badge -->
                        <div id="verificacion-badge" class="flex items-center justify-between p-3 rounded-lg">
                            <span class="text-xs font-bold text-slate-600 dark:text-slate-400">Resultado SCORE:</span>
                            <span id="verificacion-estado" class="px-2 py-1 rounded-md text-white text-[10px] font-black uppercase tracking-widest"></span>
                        </div>

                        <!-- Balance Info -->
                        <div class="space-y-3">
                            <div class="flex justify-between text-sm">
                                <span class="text-slate-500">Límite de Crédito:</span>
                                <span id="verificacion-limite" class="font-bold text-slate-900 dark:text-white">$0,00</span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-slate-500">Crédito Utilizado:</span>
                                <span id="verificacion-utilizado" class="font-bold text-slate-900 dark:text-white">$0,00</span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-slate-500">Cupo Disponible:</span>
                                <span id="verificacion-saldo" class="font-bold">$0,00</span>
                            </div>
                            <div class="h-1.5 w-full bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
                                <div id="verificacion-barra" class="h-full bg-primary w-0 transition-all duration-500"></div>
                            </div>
                        </div>

                        <!-- Sufficiency Indicator -->
                        <div id="panel-cupo-suficiente" class="p-3 rounded-lg bg-green-500/10 border border-green-500/20 hidden">
                            <p class="text-xs font-bold text-green-600 dark:text-green-400 flex items-center gap-2">
                                <span class="material-symbols-outlined text-sm">check_circle</span>
                                Cupo suficiente para esta operación
                            </p>
                        </div>
                        <div id="panel-cupo-insuficiente" class="p-3 rounded-lg bg-red-500/10 border border-red-500/20 hidden">
                            <p class="text-xs font-bold text-red-500 flex items-center gap-2">
                                <span class="material-symbols-outlined text-sm">block</span>
                                Cupo insuficiente — operación bloqueada
                            </p>
                            <p id="cupo-insuficiente-detalle" class="text-[11px] text-slate-500 mt-1"></p>
                        </div>
                    </div>

                    <!-- Motivos / Alertas -->
                    <div id="panel-motivos" class="hidden space-y-2">
                        <p class="text-[10px] font-bold text-slate-500 uppercase">Observaciones</p>
                        <div id="lista-motivos" class="space-y-1"></div>
                    </div>

                    <!-- Mora Alert -->
                    <div id="panel-alerta-mora" class="p-4 rounded-lg bg-red-500/10 border border-red-500/20 hidden">
                        <p class="text-xs font-bold text-red-500 flex items-center gap-2 mb-2">
                            <span class="material-symbols-outlined text-sm">warning</span> Alerta de Mora
                        </p>
                        <p id="alerta-mora-texto" class="text-[11px] text-slate-600 dark:text-slate-400"></p>
                    </div>

                    <!-- Documentation Section (shown when doc is incomplete) -->
                    <div id="panel-documentacion-faltante" class="hidden">
                        <div class="p-4 rounded-lg bg-amber-500/10 border border-amber-500/20">
                            <p class="text-xs font-bold text-amber-600 dark:text-amber-400 flex items-center gap-2 mb-3">
                                <span class="material-symbols-outlined text-sm">folder_off</span>
                                Documentación crediticia incompleta
                            </p>
                            <div id="lista-docs-faltantes" class="space-y-1 mb-3"></div>
                            <button type="button" id="btn-cargar-documentacion"
                                    class="w-full py-2.5 text-xs font-bold text-amber-700 dark:text-amber-300 bg-amber-500/20 rounded-lg hover:bg-amber-500/30 transition-all flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined text-sm">upload_file</span>
                                Cargar documentación crediticia
                            </button>
                        </div>
                    </div>

                    <!-- Exception Section -->
                    <div class="pt-4 border-t border-slate-200 dark:border-slate-800">
                        <input type="hidden" asp-for="AplicarExcepcionDocumental" id="hdn-aplicar-excepcion" />
                        <div id="panel-excepcion-inactiva">
                            <button type="button" id="btn-aplicar-excepcion"
                                    class="w-full py-3 text-xs font-bold text-orange-600 dark:text-orange-400 bg-orange-500/10 border border-orange-500/20 rounded-lg hover:bg-orange-500/20 transition-all flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined text-sm">shield_question</span>
                                Aplicar Excepción (omitir validaciones)
                            </button>
                        </div>
                        <div id="panel-excepcion-activa" class="hidden">
                            <div class="p-4 rounded-lg bg-orange-500/10 border border-orange-500/20">
                                <p class="text-xs font-bold text-orange-600 dark:text-orange-400 flex items-center gap-2 mb-3">
                                    <span class="material-symbols-outlined text-sm">shield_lock</span>
                                    Excepción activa — validaciones omitidas
                                </p>
                                <label class="block text-[10px] font-bold text-slate-500 uppercase mb-2">Motivo de la excepción</label>
                                <textarea asp-for="MotivoExcepcionDocumentalCreate" id="txt-excepcion-documental"
                                          class="w-full h-20 text-xs bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg focus:ring-primary"
                                          placeholder="Ingrese el motivo de la excepción..."></textarea>
                                <button type="button" id="btn-cancelar-excepcion"
                                        class="w-full mt-2 py-2 text-[11px] font-bold text-slate-500 bg-slate-100 dark:bg-slate-800 rounded-lg hover:bg-slate-200 dark:hover:bg-slate-700 transition-all">
                                    Cancelar excepción
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- 5. Seller & Observations -->
            <section class="bg-white dark:bg-slate-900/50 p-6 rounded-xl border border-slate-200 dark:border-slate-800">
                @if (puedeDelegarVendedor && vendedores != null)
                {
                    <div class="mb-4">
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Vendedor</label>
                        <select asp-for="VendedorUserId" asp-items="vendedores"
                                class="w-full text-sm bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg">
                            <option value="">Seleccione vendedor...</option>
                        </select>
                    </div>
                }
                else
                {
                    <div class="mb-4">
                        <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Vendedor</label>
                        <div class="flex items-center gap-3 p-3 bg-slate-50 dark:bg-slate-800 rounded-lg">
                            <div class="size-8 bg-primary/20 rounded-full flex items-center justify-center">
                                <span class="material-symbols-outlined text-primary text-sm">person</span>
                            </div>
                            <div>
                                <p class="text-sm font-bold">@(User.Identity?.Name ?? "Usuario")</p>
                                <p class="text-[10px] text-slate-500 uppercase">Vendedor asignado</p>
                            </div>
                        </div>
                    </div>
                }
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Observaciones</label>
                    <textarea asp-for="Observaciones"
                              class="w-full h-32 text-sm bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg focus:ring-primary"
                              placeholder="Notas internas sobre la venta..."></textarea>
                </div>
            </section>

            <!-- 6. Totals Panel -->
            <section class="bg-primary text-white p-6 rounded-xl shadow-xl shadow-primary/20">
                <h3 class="text-sm font-bold uppercase tracking-widest mb-6 opacity-80">Resumen de Totales</h3>
                <div class="space-y-3 mb-6">
                    <div class="flex justify-between text-sm">
                        <span class="opacity-70">Subtotal Neto</span>
                        <span id="total-subtotal" class="font-medium">$0,00</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="opacity-70">Descuento Global (<span id="total-descuento-label">0%</span>)</span>
                        <span id="total-descuento" class="font-medium">-$0,00</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="opacity-70">IVA (21%)</span>
                        <span id="total-iva" class="font-medium">$0,00</span>
                    </div>
                    <div class="pt-3 border-t border-white/20">
                        <div class="flex justify-between items-center">
                            <span class="text-lg font-bold">TOTAL FINAL</span>
                            <div class="text-right">
                                <span id="total-final" class="block text-3xl font-black">$0,00</span>
                                <span class="text-[10px] opacity-70">ARS pesos argentinos</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Hidden fields for totals -->
                <input type="hidden" asp-for="Subtotal" id="hdn-subtotal" />
                <input type="hidden" asp-for="Descuento" id="hdn-descuento" />
                <input type="hidden" asp-for="IVA" id="hdn-iva" />
                <input type="hidden" asp-for="Total" id="hdn-total" />

                <button type="submit" id="btn-confirmar"
                        class="w-full py-4 bg-white text-primary rounded-xl font-black text-sm uppercase tracking-wider hover:bg-slate-100 transition-all flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined">point_of_sale</span>
                    @(esCotizacion ? "Guardar Cotización" : "Confirmar Transacción")
                </button>
                <p class="text-center text-[10px] mt-4 opacity-60">
                    @(esCotizacion ? "Se guardará como cotización pendiente." : "Al confirmar, se generará la factura electrónica correspondiente.")
                </p>
            </section>

            <div class="flex gap-4">
                @if (!esCotizacion)
                {
                    <a asp-action="Cotizar" class="flex-1 py-3 border border-slate-300 dark:border-slate-700 rounded-xl font-bold text-xs uppercase tracking-tighter hover:bg-slate-50 dark:hover:bg-slate-800 transition-all flex items-center justify-center gap-1 text-center">
                        <span class="material-symbols-outlined text-sm">description</span> Guardar como Cotización
                    </a>
                }
                <button type="button" onclick="window.print()"
                        class="flex-1 py-3 border border-slate-300 dark:border-slate-700 rounded-xl font-bold text-xs uppercase tracking-tighter hover:bg-slate-50 dark:hover:bg-slate-800 transition-all flex items-center justify-center gap-1">
                    <span class="material-symbols-outlined text-sm">print</span> Imprimir Borrador
                </button>
            </div>
        </div>
    </div>

    <!-- Hidden container for dynamic detail inputs (form posting) -->
    <div id="detalles-hidden-inputs" class="hidden"></div>
</form>

<!-- Modal: Cargar Documentación Crediticia -->
<div id="modal-documentacion" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" id="modal-documentacion-overlay"></div>
    <div class="relative flex items-center justify-center min-h-screen p-4">
        <div class="relative bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 w-full max-w-lg shadow-2xl">
            <div class="flex items-center justify-between p-6 border-b border-slate-200 dark:border-slate-800">
                <h3 class="text-lg font-bold text-slate-900 dark:text-white flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">upload_file</span> Documentación Crediticia
                </h3>
                <button type="button" id="btn-cerrar-modal-doc" class="p-1 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-all">
                    <span class="material-symbols-outlined text-slate-400">close</span>
                </button>
            </div>
            <div class="p-6 space-y-5">
                <!-- Missing / Expired Documents List -->
                <div id="modal-docs-pendientes" class="space-y-3">
                    <p class="text-xs font-bold text-slate-500 uppercase">Documentos pendientes</p>
                    <div id="modal-lista-docs" class="space-y-2"></div>
                </div>

                <!-- Upload Area -->
                <div class="border-2 border-dashed border-slate-300 dark:border-slate-700 rounded-xl p-6 text-center">
                    <span class="material-symbols-outlined text-3xl text-slate-400 mb-2">cloud_upload</span>
                    <p class="text-sm font-bold text-slate-600 dark:text-slate-400 mb-1">Subir documentación</p>
                    <p class="text-[11px] text-slate-400 mb-3">PDF, JPG, PNG — máximo 10 MB</p>
                    <label class="inline-flex items-center gap-2 px-4 py-2 bg-primary/10 text-primary text-xs font-bold rounded-lg cursor-pointer hover:bg-primary/20 transition-all">
                        <span class="material-symbols-outlined text-sm">attach_file</span> Seleccionar archivo
                        <input type="file" id="input-doc-archivo" accept=".pdf,.jpg,.jpeg,.png" class="hidden" />
                    </label>
                    <p id="doc-archivo-nombre" class="text-[11px] text-slate-500 mt-2 hidden"></p>
                </div>

                <!-- Document Type Select -->
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Tipo de documento</label>
                    <select id="select-tipo-documento"
                            class="w-full text-sm bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg">
                        <option value="">Seleccione tipo...</option>
                    </select>
                </div>

                <!-- Upload feedback -->
                <div id="doc-upload-feedback" class="hidden p-3 rounded-lg text-xs font-bold"></div>
            </div>
            <div class="flex gap-3 p-6 border-t border-slate-200 dark:border-slate-800">
                <button type="button" id="btn-subir-documento"
                        class="flex-1 py-3 bg-primary text-white rounded-xl font-bold text-xs uppercase tracking-tighter hover:bg-primary/90 transition-all flex items-center justify-center gap-2"
                        disabled>
                    <span class="material-symbols-outlined text-sm">upload</span> Subir Documento
                </button>
                <button type="button" id="btn-ir-documentacion"
                        class="flex-1 py-3 border border-slate-300 dark:border-slate-700 rounded-xl font-bold text-xs uppercase tracking-tighter hover:bg-slate-50 dark:hover:bg-slate-800 transition-all flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-sm">open_in_new</span> Ir a Documentación
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/venta-create.js"></script>
}
