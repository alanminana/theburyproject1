@model TheBuryProject.ViewModels.VentaViewModel
@using TheBuryProject.Models.Enums
@using TheBuryProject.Helpers
@{
    ViewData["Title"] = Model.Estado == EstadoVenta.Cotizacion ? "Nueva Cotización" : "Nueva Venta";
    var clientes = ViewBag.Clientes as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var productos = ViewBag.Productos as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var tiposPago = ViewBag.TiposPago as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>;
    var tarjetas = ViewBag.Tarjetas as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var creditos = ViewBag.Creditos as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var categorias = ViewBag.CategoriasFiltro as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var marcas = ViewBag.MarcasFiltro as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var esCotizacion = Model.Estado == EstadoVenta.Cotizacion;
    var estadoLabel = esCotizacion ? "Cotización" : "Venta";
}

<div id="venta-create-page" class="mx-auto flex min-h-[calc(100dvh-5rem)] w-full flex-col px-4 py-4 sm:px-6 lg:px-8">

    @* ── Validation errors banner ───────────────────────────────────────
       Contenedor siempre presente: visible si el render trae errores (fallback
       sin JS) y rellenado dinámicamente por venta-create.js tras el submit AJAX.
       GOTCHA TW v4: no mezclar `hidden` + `flex`; se emite solo una de las dos. *@
    <div id="banner-errores"
         class="@(ViewData.ModelState.IsValid ? "hidden" : "flex") flex-1 flex-col items-start justify-between gap-4 rounded-xl border border-red-500/30 bg-red-500/10 p-5 sm:flex-row sm:items-center mb-5">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-red-500">error</span>
            <div class="flex flex-col gap-1">
                <p class="text-white text-base font-bold leading-tight">Corrige los errores antes de continuar</p>
                <div id="banner-errores-list" class="text-slate-400 text-sm">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p>@error.ErrorMessage</p>
                    }
                </div>
            </div>
        </div>
        <button type="button" id="btn-cerrar-banner-errores"
                class="text-sm font-bold text-white opacity-70 hover:opacity-100">Cerrar</button>
    </div>

    @* ── TempData toasts ───────────────────────────────────────────────── *@
    @if (TempData["Success"] != null)
    {
        <div class="toast-msg flex items-center gap-3 rounded-xl border border-emerald-500/20 bg-emerald-500/10 p-4 text-sm font-semibold text-emerald-400"
             role="status">
            <span class="material-symbols-outlined">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Warning"] != null)
    {
        <div class="toast-msg flex items-center gap-3 rounded-xl border border-amber-500/20 bg-amber-500/10 p-4 text-sm font-semibold text-amber-400"
             role="status">
            <span class="material-symbols-outlined">warning</span>
            @TempData["Warning"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="toast-msg flex items-center gap-3 rounded-xl border border-rose-500/20 bg-rose-500/10 p-4 text-sm font-semibold text-rose-400"
             role="alert">
            <span class="material-symbols-outlined">error</span>
            @TempData["Error"]
        </div>
    }

    <form id="venta-form" asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Estado" />
        <input type="hidden" asp-for="RowVersion" />

        @* ══════════════════════════════════════════════════════════════════
           HERO — cabecera con métricas en vivo
           ══════════════════════════════════════════════════════════════════ *@
        <section class="hero-erp mb-5">
            <div class="flex flex-col gap-6 xl:flex-row xl:items-start xl:justify-between">
                <div class="space-y-3">
                    <div class="flex flex-wrap items-center gap-2 text-xs font-semibold">
                        <span
                        class="inline-flex items-center rounded-full bg-slate-800 px-3 py-1 text-slate-400">Ventas</span>
                        <span class="text-slate-600">/</span>
                        <span
                            class="inline-flex items-center rounded-full bg-primary/10 px-3 py-1 text-primary">@estadoLabel
                            en curso</span>
                        </div>
                        <div>
                            <h1 class="text-3xl font-black tracking-tight text-white sm:text-4xl">
                                @(esCotizacion ? "Nueva Cotización" : "Nueva Venta")
                            </h1>
                            <p class="mt-2 text-sm text-slate-400 sm:text-base max-w-2xl">
                                @(esCotizacion
                                    ? "Prepará el presupuesto, validá crédito si hace falta y dejá la operación lista para seguimiento."
                                    : "Armá la venta, verificá elegibilidad crediticia y cerrá la operación sin salir de la pantalla.")
                            </p>
                        </div>
                    </div>

                    <div class="flex w-full flex-col gap-3 sm:flex-row xl:w-auto xl:min-w-60 xl:flex-col">
                        <a asp-action="Index" class="btn-erp-ghost h-11 w-full no-underline">Cancelar</a>
                        <button type="submit"
                                class="inline-flex h-11 w-full items-center justify-center rounded-xl bg-primary px-5 text-sm font-bold text-white shadow-lg shadow-primary/20 transition-colors hover:bg-primary/90">
                            Guardar Operación
                        </button>
                    </div>
                </div>

                <div class="mt-6 flex items-center justify-between gap-3">
                    <div role="tablist" class="flex gap-1 overflow-x-auto" aria-label="Pasos de la venta">
                        <button type="button" id="step-btn-cliente" role="tab" aria-selected="true"
                                aria-controls="step-panel-cliente" data-step="cliente" class="vm-step-tab vm-step-tab--active">
                            <span class="vm-step-tab__num">1</span>
                            Cliente
                        </button>
                        <button type="button" id="step-btn-productos" role="tab" aria-selected="false"
                                aria-controls="step-panel-productos" data-step="productos" class="vm-step-tab">
                            <span class="vm-step-tab__num">2</span>
                            Productos
                            <span id="detalle-items-badge" class="vm-step-tab__badge">0</span>
                        </button>
                        <button type="button" id="step-btn-pago" role="tab" aria-selected="false"
                                aria-controls="step-panel-pago" data-step="pago" class="vm-step-tab">
                            <span class="vm-step-tab__num">3</span>
                            Pago
                        </button>
                        <button type="button" id="step-btn-revision" role="tab" aria-selected="false"
                                aria-controls="step-panel-revision" data-step="revision" class="vm-step-tab">
                            <span class="vm-step-tab__num">4</span>
                            Revisión
                        </button>
                    </div>
                    <span id="vm-estado-global"
                          class="hidden shrink-0 items-center gap-1.5 rounded-full border border-slate-700 bg-slate-800/60 px-3 py-1 text-[10px] font-bold text-slate-400 sm:inline-flex">
                        Incompleta
                    </span>
                </div>

            </section>

            @* ══════════════════════════════════════════════════════════════════
           CUERPO — grilla 2/3 + 1/3
           ══════════════════════════════════════════════════════════════════ *@
            <div class="vm-mobile-summary-bar" role="region" aria-label="Resumen de compra">
                <div class="vm-mobile-summary-bar__info">
                    <span class="material-symbols-outlined vm-mobile-summary-bar__icon">receipt_long</span>
                    <span>Total: <strong id="vm-modal-sticky-total" data-mobile-total>$0,00</strong></span>
                </div>
                <button type="button" class="vm-btn-confirm-sm" data-wizard-submit-proxy="btn-confirmar">
                    <span class="material-symbols-outlined vm-btn-confirm-sm__icon">point_of_sale</span>
                    @(esCotizacion ? "Guardar" : "Confirmar")
                </button>
            </div>

            <div class="grid grid-cols-1 gap-5 lg:grid-cols-12 lg:items-start">

                @* ── Columna izquierda (2/3) ──────────────────────────────── *@
                <div class="flex flex-col gap-5 lg:col-span-8">

                    @* ── Sección 1: Datos generales ─────────────────────── *@
                    <section id="step-panel-cliente" role="tabpanel" aria-labelledby="step-btn-cliente">
                        <div class="venta-section">
                            <div class="mb-6 flex items-start justify-between gap-4">
                                <div class="flex items-center gap-3">
                                    <span
                                    class="w-8 h-8 shrink-0 flex items-center justify-center rounded-full bg-primary/15 text-primary text-xs font-bold">1</span>
                                    <div>
                                        <h2 class="text-lg font-bold text-white">Datos generales</h2>
                                        <p class="text-sm text-slate-400">Seleccioná el cliente, la fecha y el tipo de pago
                                            principal antes de armar el detalle.</p>
                                        </div>
                                    </div>
                                    <span class="badge-erp badge-erp-neutral shrink-0">
                                        <span class="material-symbols-outlined text-sm">person</span>
                                        Cliente + contexto
                                    </span>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

                                    @* Cliente *@
                                    <div class="md:col-span-2">
                                        <label class="venta-label" for="input-buscar-cliente">Buscar Cliente</label>
                                        <div class="relative">
                                            <span
                                            class="absolute left-3 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-400">search</span>
                                            <input id="input-buscar-cliente" type="text" autocomplete="off" class="venta-input"
                                                   style="padding-left: 2.5rem" placeholder="Nombre, CUIT o DNI del cliente..." />
                                            <div id="dropdown-clientes"
                                                 class="absolute top-full left-0 w-full bg-slate-800 mt-1 rounded-lg border border-slate-700 shadow-xl z-20 hidden max-h-60 overflow-y-auto">
                                            </div>
                                        </div>
                                        <input type="hidden" asp-for="ClienteId" id="hdn-cliente-id" />
                                    </div>

                                    @* Cliente seleccionado *@
                                    <div id="info-cliente"
                                         class="md:col-span-2 hidden rounded-2xl border border-primary/20 bg-primary/10 p-4">
                                        <div class="flex items-center justify-between">
                                            <div class="flex items-center gap-3">
                                                <div
                                                    class="size-10 bg-primary/20 rounded-full flex items-center justify-center">
                                                    <span class="material-symbols-outlined text-primary text-sm">person</span>
                                                </div>
                                                <div>
                                                    <p id="info-cliente-nombre" class="text-sm font-bold text-white"></p>
                                                    <p id="info-cliente-doc" class="text-xs text-slate-500"></p>
                                                </div>
                                            </div>
                                            <button type="button" id="btn-limpiar-cliente"
                                                    class="text-xs font-bold text-red-500 hover:underline">Cambiar</button>
                                        </div>
                                    </div>

                                    @* Fecha *@
                                    <div>
                                        <label class="venta-label" for="FechaVenta">Fecha de Operación</label>
                                        <input asp-for="FechaVenta" type="date" class="venta-input" />
                                    </div>

                                    @* Tipo de pago principal de la venta *@
                                    <div>
                                        <label class="venta-label" for="select-tipo-pago">Tipo de pago principal</label>
                                        <select asp-for="TipoPago" id="select-tipo-pago" class="venta-input">
                                            @if (tiposPago != null)
                                            {
                                                foreach (var tp in tiposPago)
                                                {
                                                    <option value="@tp.Value">@tp.Text</option>
                                                }
                                            }
                                        </select>
                                        <p class="mt-1 text-xs text-slate-400">
                                            Selecciona el medio principal de cobro para toda la venta.
                                        </p>
                                        <p id="configuracion-pagos-global-estado" class="mt-1 text-xs text-slate-500"
                                           aria-live="polite">
                                            Cargando configuracion global de pagos...
                                        </p>
                                    </div>
                                </div>

                                @* Aviso de crédito personal (oculto por defecto) *@
                                <div id="panel-aviso-credito"
                                     class="mt-6 p-4 rounded-lg bg-orange-500/10 border border-orange-500/20 hidden">
                                    <div class="flex items-center gap-2 mb-3">
                                        <span class="material-symbols-outlined text-orange-500 text-sm">info</span>
                                        <span class="text-orange-500 font-bold text-sm">Aviso de Crédito Personal</span>
                                    </div>
                                    <div class="grid grid-cols-3 gap-4 text-xs">
                                        <div>
                                            <p class="text-slate-400">Disponible</p>
                                            <p id="credito-disponible" class="text-white font-bold mt-0.5">$0,00</p>
                                        </div>
                                        <div>
                                            <p class="text-slate-400">Solicitado</p>
                                            <p id="credito-solicitado" class="text-white font-bold mt-0.5">$0,00</p>
                                        </div>
                                        <div>
                                            <p class="text-slate-400">Margen</p>
                                            <p id="credito-margen" class="text-white font-bold mt-0.5">$0,00</p>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </section>

                        @* ── Sección 2: Selección de productos ──────────────── *@
                        <section id="step-panel-productos" role="tabpanel" aria-labelledby="step-btn-productos" class="hidden">
                            <div class="venta-section">
                                <div class="mb-6 flex items-start justify-between gap-4">
                                    <div class="flex items-center gap-3">
                                        <span
                                        class="w-8 h-8 shrink-0 flex items-center justify-center rounded-full bg-primary/15 text-primary text-xs font-bold">2</span>
                                        <div>
                                            <h2 class="text-lg font-bold text-white">Selección de productos</h2>
                                            <p class="text-sm text-slate-400">Buscá artículos, afiná por filtros y revisá el
                                                detalle antes de pasar al cobro.</p>
                                            </div>
                                        </div>
                                        <span class="badge-erp badge-erp-neutral shrink-0">
                                            <span class="material-symbols-outlined text-sm">shopping_bag</span>
                                            0 productos
                                        </span>
                                    </div>

                                    @* Filtros avanzados *@
                                    <div
                                        class="grid grid-cols-1 gap-3 rounded-xl border border-slate-800 bg-slate-800/50 p-4 mb-5 md:grid-cols-4">
                                        <select id="filtro-categoria" class="venta-select text-xs">
                                            <option value="">Categoría: Todas</option>
                                            @if (categorias != null)
                                            {
                                                foreach (var cat in categorias)
                                                {
                                                    <option value="@cat.Value">@cat.Text</option>
                                                }
                                            }
                                        </select>
                                        <select id="filtro-marca" class="venta-select text-xs">
                                            <option value="">Marca: Todas</option>
                                            @if (marcas != null)
                                            {
                                                foreach (var marca in marcas)
                                                {
                                                    <option value="@marca.Value">@marca.Text</option>
                                                }
                                            }
                                        </select>
                                        <div class="flex gap-2">
                                            <input id="filtro-precio-min" type="number" min="0" step="0.01"
                                                   class="w-full venta-select text-xs" placeholder="Min $" />
                                            <input id="filtro-precio-max" type="number" min="0" step="0.01"
                                                   class="w-full venta-select text-xs" placeholder="Max $" />
                                        </div>
                                        <label class="flex items-center gap-2 cursor-pointer">
                                            <input id="filtro-solo-stock" type="checkbox" checked
                                                   class="rounded text-primary focus:ring-primary bg-slate-800 border-slate-700" />
                                            <span class="text-xs text-slate-400 font-medium">Solo con stock</span>
                                        </label>
                                    </div>

                                    @* Búsqueda de producto *@
                                    <div class="flex flex-col gap-4 mb-6">
                                        <div class="relative">
                                            <span
                                            class="absolute left-3 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-500 pointer-events-none">search</span>
                                            <input id="input-buscar-producto" type="text" autocomplete="off" class="venta-input"
                                                   style="padding-left: 2.5rem"
                                                   placeholder="Escriba código o nombre del producto..." />
                                            <div id="dropdown-productos"
                                                 class="absolute top-full left-0 w-full bg-slate-800 mt-1 rounded-lg border border-slate-700 shadow-xl z-20 hidden max-h-72 overflow-y-auto">
                                            </div>
                                        </div>

                                        @* Panel de agregar producto (mostrado por JS) *@
                                        <div id="panel-agregar-producto"
                                             class="hidden grid grid-cols-2 gap-3 rounded-xl border border-primary/20 bg-primary/10 p-4 md:grid-cols-5">
                                            <div class="md:col-span-2">
                                                <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">Producto
                                                    Seleccionado</label>
                                                    <input id="txt-producto-seleccionado" type="text" readonly
                                                           class="w-full text-sm bg-slate-700 border-none rounded-lg text-slate-300 px-3 py-2" />
                                                    <input type="hidden" id="hdn-producto-id" />
                                                    <input type="hidden" id="hdn-producto-codigo" />
                                                    <input type="hidden" id="hdn-producto-precio" />
                                                    <input type="hidden" id="hdn-producto-stock" />
                                                    <input type="hidden" id="hdn-producto-requiere-numero-serie" />
                                                </div>
                                                <div>
                                                    <label
                                                    class="block text-[10px] font-bold text-slate-500 uppercase mb-1">Cantidad</label>
                                                    <input id="txt-cantidad" type="number" min="1" value="1" class="venta-input" />
                                                    <p id="stock-error" class="hidden text-[9px] text-red-500 font-bold mt-1"></p>
                                                </div>
                                                @* Panel de origen de stock — visible solo en productos flexibles con unidades físicas
                                *@
                                                <div id="panel-origen-stock" class="hidden col-span-2 md:col-span-5">
                                                    <label class="block text-[10px] font-bold text-slate-500 uppercase mb-2">Origen del
                                                        stock</label>
                                                        <div class="flex flex-wrap gap-3">
                                                            <label
                                                                class="flex items-center gap-2 cursor-pointer rounded-lg border border-slate-600 bg-slate-700/50 px-3 py-2 hover:border-primary/50 has-checked:border-primary has-checked:bg-primary/10">
                                                                <input type="radio" id="radio-origen-no-trazado" name="origen-stock-radio"
                                                                       value="noTrazado" class="accent-primary" />
                                                                <span class="text-xs text-slate-300">Stock no trazado</span>
                                                                <span id="badge-stock-no-trazado"
                                                                      class="text-[10px] font-bold text-slate-400"></span>
                                                            </label>
                                                            <label id="label-origen-unidad"
                                                                   class="flex items-center gap-2 cursor-pointer rounded-lg border border-slate-600 bg-slate-700/50 px-3 py-2 hover:border-amber-500/50 has-checked:border-amber-500 has-checked:bg-amber-500/10">
                                                                <input type="radio" id="radio-origen-unidad" name="origen-stock-radio"
                                                                       value="unidadFisica" class="accent-amber-500" />
                                                                <span class="text-xs text-slate-300">Unidad física registrada</span>
                                                                <span id="badge-unidades-en-stock"
                                                                      class="text-[10px] font-bold text-amber-500"></span>
                                                            </label>
                                                        </div>
                                                        <p id="origen-stock-error" class="hidden mt-1 text-[11px] font-bold text-red-500">
                                                        </p>
                                                    </div>
                                                    <div id="panel-selector-unidad"
                                                         class="hidden col-span-2 md:col-span-5 rounded-lg border border-amber-500/20 bg-amber-500/10 p-3">
                                                        <label class="block text-[10px] font-bold text-amber-500 uppercase mb-1">Unidad
                                                            física</label>
                                                            <select id="select-producto-unidad" class="venta-input"
                                                                    aria-describedby="producto-unidad-ayuda producto-unidad-error">
                                                                <option value="">Seleccione una unidad disponible...</option>
                                                            </select>
                                                            <p id="producto-unidad-ayuda" class="mt-2 text-[11px] font-semibold text-amber-500">
                                                                Seleccioná una unidad física para vincularla a esta venta.
                                                            </p>
                                                            <p id="producto-unidad-error"
                                                               class="hidden mt-1 text-[11px] font-bold text-red-500"></p>
                                                            <div id="aviso-sin-unidades"
                                                                 class="hidden mt-2 rounded border border-amber-600/30 bg-amber-900/20 px-3 py-2 text-[11px] text-amber-300">
                                                                Cargá una unidad física desde
                                                                <a id="link-gestionar-unidades" href="#"
                                                                   class="font-bold underline hover:opacity-75" target="_blank">Gestionar unidades</a>
                                                                antes de vender.
                                                            </div>
                                                            </div>
                                                            <div id="advertencia-stock-sin-identificar"
                                                                 class="hidden col-span-2 md:col-span-5 flex items-start gap-2 rounded-lg border border-amber-500/20 bg-amber-500/10 px-3 py-2 text-[11px] text-amber-400">
                                                            </div>
                                                            <div>
                                                                <label class="block text-[10px] font-bold text-slate-500 uppercase mb-1">Desc.
                                                                    %</label>
                                                                    <input id="txt-descuento-item" type="number" min="0" max="100" value="0"
                                                                           class="venta-input" />
                                                                </div>
                                                                <div class="flex items-end">
                                                                    <button type="button" id="btn-agregar-producto"
                                                                            class="w-full py-2.5 bg-primary text-white rounded-lg flex items-center justify-center gap-1 font-bold text-sm hover:bg-primary/90 transition-colors">
                                                                        <span class="material-symbols-outlined text-sm">add</span> Añadir
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        </div>

                                                        @* Tabla de detalles *@
                                                        <div id="venta-detalles-scroll" data-oc-scroll class="venta-scroll-medium">
                                                            <p data-oc-scroll-hint hidden class="mb-3 text-xs font-medium text-slate-400 lg:hidden">
                                                                Deslizá la tabla para revisar cantidades, descuentos y subtotales completos.
                                                            </p>
                                                            <div data-oc-scroll-shell>
                                                                <div data-oc-scroll-fade="left" hidden></div>
                                                                <div data-oc-scroll-fade="right" hidden></div>
                                                                <div data-oc-scroll-region tabindex="0" role="region"
                                                                     aria-label="Detalle de productos de la venta">
                                                                    <table data-oc-scroll-table class="w-full text-left border-collapse">
                                                                        <thead>
                                                                            <tr class="border-b border-slate-800">
                                                                                <th class="py-3 px-2 text-[10px] font-bold text-slate-500 uppercase">
                                                                                    Cód.</th>
                                                                                    <th class="py-3 px-2 text-[10px] font-bold text-slate-500 uppercase">
                                                                                        Producto</th>
                                                                                        <th
                                                                                            class="py-3 px-2 text-[10px] font-bold text-slate-500 uppercase text-center">
                                                                                            Cant.</th>
                                                                                            <th
                                                                                                class="py-3 px-2 text-[10px] font-bold text-slate-500 uppercase text-right">
                                                                                                Unitario</th>
                                                                                                <th
                                                                                                    class="py-3 px-2 text-[10px] font-bold text-slate-500 uppercase text-right">
                                                                                                    Desc.</th>
                                                                                                    <th
                                                                                                        class="py-3 px-2 text-[10px] font-bold text-slate-500 uppercase text-right">
                                                                                                        Subtotal</th>
                                                                                                        <th class="py-3 px-2"></th>
                                                                                                    </tr>
                                                                                                </thead>
