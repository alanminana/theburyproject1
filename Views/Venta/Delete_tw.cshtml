@model VentaViewModel
@using TheBuryProject.Models.Enums
@{
    ViewData["Title"] = $"Eliminar {Model.Numero}";

    string estadoBg = Model.Estado switch
    {
        EstadoVenta.Cotizacion           => "bg-slate-800 text-slate-300 border-slate-700",
        EstadoVenta.Presupuesto          => "bg-blue-900/30 text-blue-400 border-blue-900/40",
        EstadoVenta.PendienteRequisitos  => "bg-amber-900/30 text-amber-400 border-amber-900/40",
        EstadoVenta.PendienteFinanciacion=> "bg-orange-900/30 text-orange-400 border-orange-900/40",
        _                                => "bg-slate-800 text-slate-300 border-slate-700"
    };

    string tipoPagoDisplay = Model.TipoPago switch
    {
        TipoPago.Efectivo        => "Efectivo",
        TipoPago.Transferencia   => "Transferencia",
        TipoPago.TarjetaDebito   => "Tarjeta Débito",
        TipoPago.TarjetaCredito  => "Tarjeta Crédito",
        TipoPago.Cheque          => "Cheque",
        TipoPago.CreditoPersonal => "Crédito Personal",
        TipoPago.MercadoPago     => "Mercado Pago",
        TipoPago.CuentaCorriente => "Cuenta Corriente",
        _                        => Model.TipoPago.ToString()
    };
}

@if (TempData["Error"] is string errorMsg)
{
    <div class="mb-4 flex items-center gap-3 rounded-lg border border-rose-500/20 bg-rose-500/10 p-4 text-rose-400">
        <span class="material-symbols-outlined">error</span>
        <p class="text-sm font-medium">@errorMsg</p>
    </div>
}

<div class="mx-auto flex max-w-4xl flex-col gap-6">

    <header class="flex flex-wrap items-start justify-between gap-4">
        <div class="flex items-start gap-3">
            <a asp-action="Details" asp-route-id="@Model.Id"
               class="flex h-10 w-10 items-center justify-center rounded-lg bg-slate-800 text-slate-200 transition-colors hover:bg-slate-700 no-underline"
               aria-label="Volver al detalle de la venta">
                <span class="material-symbols-outlined text-sm">arrow_back</span>
            </a>
            <div class="flex flex-col gap-1">
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-rose-500">Zona de riesgo</p>
                <h1 class="text-3xl font-black tracking-tight text-white">Eliminar venta</h1>
                <p class="max-w-2xl text-sm text-slate-400">
                    Revisá la información antes de confirmar. Solo se pueden eliminar ventas en estado Cotización o Presupuesto.
                </p>
            </div>
        </div>
        <span class="inline-flex items-center rounded-full border px-3 py-1 text-xs font-bold uppercase tracking-wide @estadoBg">
            @Model.EstadoDisplay
        </span>
    </header>

    <section class="rounded-xl border border-rose-900/40 bg-rose-950/20 p-5">
        <div class="flex items-start gap-3">
            <span class="material-symbols-outlined mt-0.5 text-rose-500">warning</span>
            <div class="space-y-1">
                <p class="text-sm font-bold text-rose-300">¿Confirmás la eliminación de esta venta?</p>
                <p class="text-sm text-rose-300/80">
                    La venta y sus ítems se eliminarán permanentemente del sistema. Esta operación no se puede deshacer.
                </p>
            </div>
        </div>
    </section>

    <section class="grid gap-6 lg:grid-cols-[minmax(0,1.65fr)_minmax(18rem,1fr)]">

        <div class="venta-section overflow-hidden shadow-sm">
            <div class="border-b border-slate-800 px-6 py-5">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary">shopping_bag</span>
                    <h2 class="text-lg font-bold text-white">Resumen de la venta</h2>
                </div>
            </div>
            <div class="grid gap-5 px-6 py-6 sm:grid-cols-2">
                <div class="space-y-1">
                    <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Número</p>
                    <p class="font-mono text-lg font-bold text-white">@Model.Numero</p>
                </div>
                <div class="space-y-1">
                    <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Cliente</p>
                    <p class="font-semibold text-white">@Model.ClienteNombre</p>
                    @if (!string.IsNullOrWhiteSpace(Model.ClienteDocumento))
                    {
                        <p class="text-xs text-slate-400">@Model.ClienteDocumento</p>
                    }
                </div>
                <div class="space-y-1">
                    <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Fecha</p>
                    <p class="font-medium text-white">@Model.FechaVenta.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
                <div class="space-y-1">
                    <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Forma de pago</p>
                    <p class="font-medium text-white">@tipoPagoDisplay</p>
                </div>
                <div class="space-y-1">
                    <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Ítems</p>
                    <p class="font-semibold text-white">@(Model.Detalles?.Count ?? 0)</p>
                </div>
                <div class="space-y-1">
                    <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Total</p>
                    <p class="text-xl font-black text-rose-400">@Model.Total.ToString("C2")</p>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.Observaciones))
                {
                    <div class="space-y-1 sm:col-span-2">
                        <p class="text-xs font-bold uppercase tracking-wider text-slate-400">Observaciones</p>
                        <p class="text-sm text-slate-300">@Model.Observaciones</p>
                    </div>
                }
            </div>
        </div>

        <aside class="venta-section p-5">
            <h2 class="text-base font-bold text-white">Antes de confirmar</h2>
            <ul class="mt-4 space-y-3 text-sm text-slate-300">
                <li class="flex items-start gap-2">
                    <span class="material-symbols-outlined mt-0.5 text-base text-slate-400">check_circle</span>
                    <span>La venta dejará de aparecer en el listado operativo.</span>
                </li>
                <li class="flex items-start gap-2">
                    <span class="material-symbols-outlined mt-0.5 text-base text-slate-400">check_circle</span>
                    <span>Los ítems asociados también se eliminarán.</span>
                </li>
                <li class="flex items-start gap-2">
                    <span class="material-symbols-outlined mt-0.5 text-base text-slate-400">info</span>
                    <span>Solo es posible eliminar ventas en Cotización o Presupuesto.</span>
                </li>
            </ul>

            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-6 flex flex-col gap-3">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <button type="submit"
                        class="inline-flex h-11 items-center justify-center gap-2 rounded-lg bg-rose-600 px-4 text-sm font-bold text-white shadow-lg shadow-rose-600/20 transition-colors hover:bg-rose-700">
                    <span class="material-symbols-outlined text-lg">delete</span>
                    Confirmar eliminación
                </button>

                <a asp-action="Details" asp-route-id="@Model.Id"
                   class="btn-erp-ghost h-11 no-underline">
                    Volver al detalle
                </a>
            </form>
        </aside>

    </section>
</div>

@section Scripts {
    <script src="~/js/shared-ui.js" asp-append-version="true"></script>
}
