@model VentaViewModel
@using TheBuryProject.Models.Enums
@{
    ViewData["Title"] = $"Venta {Model.Numero}";
    var detalles = Model.Detalles ?? new List<VentaDetalleViewModel>();
    var facturas = Model.Facturas ?? new List<FacturaViewModel>();
    var tieneFactura = facturas.Any(f => !f.Anulada);
    var facturaActiva = facturas.FirstOrDefault(f => !f.Anulada);
    var contratoVentaCredito = ViewBag.ContratoVentaCredito as ContratoVentaCreditoResumenViewModel;

    // Status badge mapping (Tailwind)
    string estadoBg = Model.Estado switch
    {
        EstadoVenta.Cotizacion          => "bg-slate-500/10 text-slate-400 border-slate-500/20",
        EstadoVenta.Presupuesto         => "bg-blue-500/10 text-blue-400 border-blue-500/20",
        EstadoVenta.Confirmada          => "bg-primary/10 text-primary border-primary/20",
        EstadoVenta.Facturada           => "bg-green-500/10 text-green-400 border-green-500/20",
        EstadoVenta.Entregada           => "bg-emerald-500/10 text-emerald-400 border-emerald-500/20",
        EstadoVenta.Cancelada           => "bg-red-500/10 text-red-400 border-red-500/20",
        EstadoVenta.PendienteRequisitos => "bg-amber-500/10 text-amber-400 border-amber-500/20",
        EstadoVenta.PendienteFinanciacion => "bg-orange-500/10 text-orange-400 border-orange-500/20",
        _                               => "bg-slate-500/10 text-slate-400 border-slate-500/20"
    };

    string tipoPagoDisplay = Model.TipoPago switch
    {
        TipoPago.Efectivo        => "Efectivo",
        TipoPago.Transferencia   => "Transferencia",
        TipoPago.TarjetaDebito   => "Tarjeta Débito",
        TipoPago.TarjetaCredito  => "Tarjeta Crédito",
        TipoPago.Cheque          => "Cheque",
        TipoPago.CreditoPersonal => "Crédito Personal",
        TipoPago.MercadoPago     => "Mercado Pago",
        TipoPago.CuentaCorriente => "Cuenta Corriente",
        _                        => Model.TipoPago.ToString()
    };

    string tipoPagoIcon = Model.TipoPago switch
    {
        TipoPago.Efectivo        => "payments",
        TipoPago.Transferencia   => "swap_horiz",
        TipoPago.TarjetaDebito   => "credit_card",
        TipoPago.TarjetaCredito  => "credit_card",
        TipoPago.Cheque          => "description",
        TipoPago.CreditoPersonal => "account_balance",
        TipoPago.MercadoPago     => "phone_iphone",
        TipoPago.CuentaCorriente => "account_balance_wallet",
        _                        => "payment"
    };

    var puedeCrearDevoluciones = User.TienePermiso("devoluciones", "create");
    var puedeVerCreditos = User.TienePermiso("creditos", "view");
    var puedeActualizarVentas = User.TienePermiso("ventas", "update");
    var puedeAutorizarVentas = User.TienePermiso("ventas", "authorize");
    var puedeRechazarVentas = User.TienePermiso("ventas", "reject");
    var puedeFacturarVentas = User.TienePermiso("ventas", "invoice");
    var puedeOperarVentas = (bool?)ViewBag.PuedeOperarVentas ?? false;
    var cantidadUnidades = detalles.Sum(d => d.Cantidad);
    var heroDescripcion = Model.Estado switch
    {
        EstadoVenta.Presupuesto => "Revisá el detalle, completá la configuración pendiente y prepará la aprobación o confirmación final.",
        EstadoVenta.Confirmada => "Supervisá el estado de la operación, la facturación y los movimientos asociados desde una sola vista.",
        EstadoVenta.Facturada => "Controlá productos, factura emitida y devoluciones disponibles sin salir del detalle.",
        EstadoVenta.Entregada => "Consultá el historial completo de la venta y los documentos vinculados a la entrega.",
        EstadoVenta.PendienteFinanciacion => "Verificá el detalle, configurá la financiación y resolvé pendientes operativos antes de cerrar la venta.",
        EstadoVenta.PendienteRequisitos => "Comprobá documentos y acciones necesarias para dejar la operación lista para confirmar.",
        EstadoVenta.Cancelada => "Auditá el detalle, el motivo y el historial de la operación cancelada.",
        _ => "Consultá el detalle, la cobranza y las acciones disponibles sobre la operación actual."
    };
    var facturacionResumen = tieneFactura
        ? facturaActiva?.Numero ?? "Factura emitida"
        : "Sin factura emitida";
    var facturacionDetalle = tieneFactura
        ? (Model.FechaFacturacion.HasValue
            ? $"Emitida el {Model.FechaFacturacion.Value:dd/MM/yyyy HH:mm}"
            : "Documento activo asociado")
        : "Se habilita cuando la venta está lista para facturar.";
}

<div class="mx-auto w-full max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="space-y-8">

        <!-- TempData Messages -->
        @if (TempData["Success"] != null)
        {
            <div class="toast-msg flex items-center gap-3 rounded-xl border border-emerald-500/20 bg-emerald-500/10 p-4 text-sm font-semibold text-emerald-400" role="status">
                <span class="material-symbols-outlined">check_circle</span>
                @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="toast-msg flex items-center gap-3 rounded-xl border border-rose-500/20 bg-rose-500/10 p-4 text-sm font-semibold text-rose-400" role="alert">
                <span class="material-symbols-outlined">error</span>
                @TempData["Error"]
            </div>
        }
        @if (TempData["Warning"] != null)
        {
            <div class="toast-msg flex items-center gap-3 rounded-xl border border-amber-500/20 bg-amber-500/10 p-4 text-sm font-semibold text-amber-400" role="status">
                <span class="material-symbols-outlined">warning</span>
                @TempData["Warning"]
            </div>
        }
        @if (TempData["Info"] != null)
        {
            <div class="toast-msg flex items-center gap-3 rounded-xl border border-sky-500/20 bg-sky-500/10 p-4 text-sm font-semibold text-sky-400" role="status">
                <span class="material-symbols-outlined">info</span>
                @TempData["Info"]
            </div>
        }
        @if (!puedeOperarVentas)
        {
            <div class="p-4 rounded-lg bg-amber-500/10 border border-amber-500/20 text-amber-300 text-sm font-bold flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                <div class="flex items-start gap-3">
                    <span class="material-symbols-outlined text-sm mt-0.5">warning</span>
                    <div>
                        <p>Sin caja abierta a su nombre.</p>
                        <p class="mt-1 font-medium text-amber-200/80">Abra una caja para habilitar confirmación, facturación, edición, cancelación y devoluciones.</p>
                    </div>
                </div>
                <a asp-controller="Caja" asp-action="Abrir"
                   class="btn-erp-warning btn-sm shrink-0 no-underline">
                    <span class="material-symbols-outlined text-[16px]">lock_open</span>
                    Abrir caja
                </a>
            </div>
        }

        <section class="hero-erp sm:p-8">
            <div class="flex flex-col gap-6 xl:flex-row xl:items-start xl:justify-between">
                <div class="space-y-4">
                    <div class="flex flex-wrap items-center gap-2 text-xs font-semibold">
                        <span class="inline-flex items-center rounded-full bg-slate-800 px-3 py-1 text-slate-300">Ventas</span>
                        <span class="text-slate-600">/</span>
                        <span class="inline-flex items-center rounded-full bg-primary/10 px-3 py-1 text-primary">@Model.Numero</span>
                    </div>
                    <div class="space-y-2">
                        <div class="flex flex-wrap items-center gap-3">
                            <h1 class="text-3xl font-black tracking-tight text-white sm:text-4xl">@Model.Numero</h1>
                            <span class="inline-flex items-center rounded-full border px-3 py-1 text-[10px] font-black uppercase tracking-widest @estadoBg">@Model.EstadoDisplay</span>
                        </div>
                        <p class="max-w-3xl text-sm text-slate-400 sm:text-base">@heroDescripcion</p>
                    </div>
                    <div class="flex flex-wrap gap-2 text-xs font-medium">
                        <span class="inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-3 py-1 text-primary">
                            <span class="material-symbols-outlined text-sm">payments</span>
                            @tipoPagoDisplay
                        </span>
                        <span class="inline-flex items-center gap-2 venta-info-pill">
                            <span class="material-symbols-outlined text-sm">schedule</span>
                            @Model.FechaVenta.ToString("dd/MM/yyyy HH:mm")
                        </span>
                        @if (tieneFactura)
                        {
                            <span class="inline-flex items-center gap-2 rounded-full border border-green-500/20 bg-green-500/10 px-3 py-1 text-green-400">
                                <span class="material-symbols-outlined text-sm">receipt</span>
                                @facturacionResumen
                            </span>
                        }
                    </div>
                </div>

                <div class="flex w-full flex-col gap-3 sm:flex-row xl:w-auto xl:min-w-[15rem] xl:flex-col">
                    <a asp-action="Index" class="btn-erp-ghost xl:w-full no-underline">
                        Volver a Ventas
                    </a>
                    <button type="button"
                            data-venta-action="print"
                            class="btn-erp-secondary xl:w-full">
                        <span class="material-symbols-outlined text-sm">print</span>
                        Imprimir
                    </button>
                </div>
            </div>

            <div class="mt-6 grid grid-cols-2 gap-3 xl:grid-cols-4">
                <article class="card-erp-metric">
                    <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-slate-400">Cliente</p>
                    <p class="mt-3 text-sm font-bold text-white">@Model.ClienteNombre</p>
                    <p class="mt-1 text-xs text-slate-400">@(string.IsNullOrWhiteSpace(Model.ClienteDocumento) ? "Sin documento registrado." : Model.ClienteDocumento)</p>
                </article>
                <article class="card-erp-metric">
                    <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-slate-400">Detalle</p>
                    <p class="mt-3 text-sm font-bold text-white">@detalles.Count @(detalles.Count == 1 ? "ítem" : "ítems")</p>
                    <p class="mt-1 text-xs text-slate-400">@cantidadUnidades @(cantidadUnidades == 1 ? "unidad registrada" : "unidades registradas")</p>
                </article>
                <article class="card-erp-metric-info">
                    <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-sky-400">Total</p>
                    <p class="mt-3 text-sm font-bold text-sky-300">@Model.Total.ToString("C2")</p>
                    <p class="mt-1 text-xs text-sky-400/80">Incluye IVA y descuentos aplicados a la venta.</p>
                </article>
                <article class="@(tieneFactura ? "card-erp-metric-success" : "card-erp-metric")">
                    <p class="text-[11px] font-bold uppercase tracking-[0.18em] @(tieneFactura ? "text-emerald-400" : "text-slate-400")">Facturación</p>
                    <p class="mt-3 text-sm font-bold @(tieneFactura ? "text-emerald-300" : "text-white")">@facturacionResumen</p>
                    <p class="mt-1 text-xs @(tieneFactura ? "text-emerald-400/80" : "text-slate-400")">@facturacionDetalle</p>
                </article>
            </div>
        </section>

        <!-- Main Grid -->
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-3 lg:items-start">

            <!-- Left Column: Details -->
            <div class="lg:col-span-2 space-y-8">

                <!-- Sale Info Card -->
                <section class="card-erp-panel-padded">
                    <div class="mb-6 flex flex-col gap-3 border-b border-slate-800 pb-4 sm:flex-row sm:items-start sm:justify-between">
                        <div class="flex items-start gap-2">
                            <span class="material-symbols-outlined mt-0.5 text-primary">receipt_long</span>
                            <div>
                                <p class="text-xs font-bold uppercase tracking-[0.18em] text-primary">Resumen</p>
                                <h2 class="mt-1 text-xl font-bold text-white">Información de la venta</h2>
                                <p class="mt-1 text-sm text-slate-400">Datos principales de la operación, del cliente y de la forma de cobro elegida.</p>
                            </div>
                        </div>
                        <span class="inline-flex items-center gap-2 self-start rounded-full badge-erp badge-erp-neutral">
                            <span class="material-symbols-outlined text-sm">@tipoPagoIcon</span>
                            @tipoPagoDisplay
                        </span>
                    </div>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                        <div>
                            <p class="text-[10px] font-bold text-slate-500 uppercase mb-1">Cliente</p>
                            <p class="text-sm font-bold text-white">@Model.ClienteNombre</p>
                            @if (!string.IsNullOrEmpty(Model.ClienteDocumento))
                            {
                                <p class="text-[11px] text-slate-400">@Model.ClienteDocumento</p>
                            }
                        </div>
                        <div>
                            <p class="text-[10px] font-bold text-slate-500 uppercase mb-1">Forma de Pago</p>
                            <div class="flex items-center gap-1.5">
                                <span class="material-symbols-outlined text-primary text-sm">@tipoPagoIcon</span>
                                <p class="text-sm font-bold text-white">@tipoPagoDisplay</p>
                            </div>
                        </div>
                        <div>
                            <p class="text-[10px] font-bold text-slate-500 uppercase mb-1">Vendedor</p>
                            <p class="text-sm font-bold text-white">@(Model.VendedorNombre ?? "—")</p>
                        </div>
                        <div>
                            <p class="text-[10px] font-bold text-slate-500 uppercase mb-1">Fecha</p>
                            <p class="text-sm font-bold text-white">@Model.FechaVenta.ToString("dd/MM/yyyy")</p>
                            <p class="text-[11px] text-slate-400">@Model.FechaVenta.ToString("HH:mm") hs</p>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Observaciones))
                    {
                        <div class="mt-4 p-3 bg-slate-800/50 rounded-lg">
                            <p class="text-[10px] font-bold text-slate-500 uppercase mb-1">Observaciones</p>
                            <p class="text-xs text-slate-400">@Model.Observaciones</p>
                        </div>
                    }
                </section>

                <!-- Line Items Table -->
                <section class="card-erp-panel">
                    <div class="flex flex-col gap-3 border-b border-slate-800 p-6 sm:flex-row sm:items-start sm:justify-between">
                        <div class="flex items-start gap-2">
                            <span class="material-symbols-outlined mt-0.5 text-primary">inventory_2</span>
                            <div>
                                <h2 class="text-xl font-bold text-white">Detalle de productos</h2>
                                <p class="mt-1 text-sm text-slate-400">Revisá cantidades, descuentos y subtotales completos antes de imprimir o facturar.</p>
                            </div>
                        </div>
                        <span class="inline-flex items-center gap-2 self-start rounded-full badge-erp badge-erp-neutral">
                            <span class="material-symbols-outlined text-sm">shopping_bag</span>
                            @detalles.Count @(detalles.Count == 1 ? "ítem" : "ítems")
                        </span>
                    </div>
                    <div id="venta-details-scroll" data-oc-scroll style="--oc-scroll-min-width: 42rem;">
                        <p data-oc-scroll-hint hidden class="px-6 pt-4 text-xs font-medium text-slate-400 lg:hidden">
                            Deslizá la tabla para revisar importes, descuentos y subtotales completos.
                        </p>
                        <div data-oc-scroll-shell class="px-0 pb-0">
                            <div data-oc-scroll-fade="left" hidden></div>
                            <div data-oc-scroll-fade="right" hidden></div>
                            <div data-oc-scroll-region tabindex="0" role="region" aria-label="Detalle de productos de la venta">
                                <table data-oc-scroll-table class="w-full text-sm">
                                    <thead>
                                        <tr class="bg-slate-800/50 text-[10px] font-black uppercase tracking-wider text-slate-500">
                                            <th class="px-6 py-3 text-left">Producto</th>
                                            <th class="px-4 py-3 text-center">Cant.</th>
                                            <th class="px-4 py-3 text-right">Precio Unit.</th>
                                            <th class="px-4 py-3 text-right">Descuento</th>
                                            <th class="px-6 py-3 text-right">Subtotal</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-800">
                                        @foreach (var item in detalles)
                                        {
                                            <tr class="transition-colors hover:bg-slate-800/30">
                                                <td class="px-6 py-4">
                                                    <p class="font-bold text-white">@item.ProductoNombre</p>
                                                    <p class="text-[11px] text-slate-400">@item.ProductoCodigo</p>
                                                </td>
                                                <td class="px-4 py-4 text-center font-medium">@item.Cantidad</td>
                                                <td class="px-4 py-4 text-right text-slate-300">@item.PrecioUnitario.ToString("C2")</td>
                                                <td class="px-4 py-4 text-right">
                                                    @if (item.Descuento > 0)
                                                    {
                                                        <span class="text-red-500">-@item.Descuento.ToString("C2")</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-slate-400">—</span>
                                                    }
                                                </td>
                                                <td class="px-6 py-4 text-right font-bold text-white">@item.Subtotal.ToString("C2")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Totals row -->
                    <div class="p-6 bg-slate-800/30 border-t border-slate-800">
                        <div class="flex flex-col items-end gap-2">
                            <div class="flex justify-between w-64 text-sm">
                                <span class="text-slate-500">Subtotal</span>
                                <span class="font-medium text-slate-300">@Model.Subtotal.ToString("C2")</span>
                            </div>
                            @if (Model.Descuento > 0)
                            {
                                <div class="flex justify-between w-64 text-sm">
                                    <span class="text-slate-500">Descuento</span>
                                    <span class="font-medium text-red-500">-@Model.Descuento.ToString("C2")</span>
                                </div>
                            }
                            <div class="flex justify-between w-64 text-sm">
                                <span class="text-slate-500">IVA</span>
                                <span class="font-medium text-slate-300">@Model.IVA.ToString("C2")</span>
                            </div>
                            <div class="flex justify-between w-64 text-lg pt-2 border-t border-slate-700">
                                <span class="font-bold text-white">Total</span>
                                <span class="font-black text-primary">@Model.Total.ToString("C2")</span>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Credit Info (if CreditoPersonal) -->
                @if (Model.TipoPago == TipoPago.CreditoPersonal && Model.CreditoId.HasValue)
                {
                    <section class="card-erp-panel-padded">
                        <div class="flex items-center gap-2 mb-6 border-b border-slate-800 pb-3">
                            <span class="material-symbols-outlined text-primary">account_balance</span>
                            <h2 class="text-white text-xl font-bold">Crédito Personal</h2>
                            @if (Model.CreditoConfigurado)
                            {
                                <span class="ml-auto px-2 py-0.5 rounded text-[10px] font-black bg-green-500/10 text-green-400 uppercase">Configurado</span>
                            }
                            else if (Model.CreditoPendienteConfiguracion)
                            {
                                <span class="ml-auto px-2 py-0.5 rounded text-[10px] font-black bg-orange-500/10 text-orange-400 uppercase">Pendiente</span>
                            }
                        </div>
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                            <div class="px-3 py-2 bg-primary/5 rounded-lg">
                                <p class="text-[10px] text-primary font-bold uppercase">Crédito Nº</p>
                                <p class="text-sm font-bold text-white">@(Model.CreditoNumero ?? "—")</p>
                            </div>
                            @if (Model.DatosCreditoPersonall != null)
                            {
                                <div class="venta-stat">
                                    <p class="text-[10px] text-slate-500 font-bold uppercase">Monto Financiado</p>
                                    <p class="text-sm font-bold text-white">@Model.DatosCreditoPersonall.MontoAFinanciar.ToString("C2")</p>
                                </div>
                                <div class="venta-stat">
                                    <p class="text-[10px] text-slate-500 font-bold uppercase">Cuotas</p>
                                    <p class="text-sm font-bold text-white">@Model.DatosCreditoPersonall.CantidadCuotas x @Model.DatosCreditoPersonall.MontoCuota.ToString("C2")</p>
                                </div>
                                <div class="venta-stat">
                                    <p class="text-[10px] text-slate-500 font-bold uppercase">Tasa Mensual</p>
                                    <p class="text-sm font-bold text-white">@Model.DatosCreditoPersonall.TasaInteresMensual.ToString("F2")%</p>
                                </div>
                            }
                            else
                            {
                                <div class="venta-stat col-span-3">
                                    <p class="text-xs text-slate-500 italic">Datos del crédito pendientes de configuración.</p>
                                </div>
                            }
                        </div>
                    </section>

                    @if (contratoVentaCredito != null)
                    {
                        <section class="card-erp-panel-padded">
                            <div class="mb-6 flex flex-col gap-3 border-b border-slate-800 pb-4 sm:flex-row sm:items-start sm:justify-between">
                                <div class="flex items-start gap-2">
                                    <span class="material-symbols-outlined mt-0.5 text-emerald-400">contract</span>
                                    <div>
                                        <p class="text-xs font-bold uppercase tracking-[0.18em] text-emerald-400">Contrato generado</p>
                                        <h2 class="mt-1 text-xl font-bold text-white">Documentación contractual</h2>
                                        <p class="mt-1 text-sm text-slate-400">Contrato y pagaré asociados a esta venta.</p>
                                    </div>
                                </div>
                                <span class="inline-flex items-center gap-2 self-start rounded-full border border-emerald-500/20 bg-emerald-500/10 px-3 py-1 text-xs font-bold text-emerald-300">
                                    <span class="material-symbols-outlined text-sm">check_circle</span>
                                    @contratoVentaCredito.EstadoDocumento
                                </span>
                            </div>
                            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
                                <div class="venta-stat">
                                    <p class="text-[10px] text-slate-500 font-bold uppercase">Contrato Nº</p>
                                    <p class="text-sm font-bold text-white">@contratoVentaCredito.NumeroContrato</p>
                                </div>
                                <div class="venta-stat">
                                    <p class="text-[10px] text-slate-500 font-bold uppercase">Pagaré Nº</p>
                                    <p class="text-sm font-bold text-white">@contratoVentaCredito.NumeroPagare</p>
                                </div>
                                <div class="venta-stat">
                                    <p class="text-[10px] text-slate-500 font-bold uppercase">Generación</p>
                                    <p class="text-sm font-bold text-white">@contratoVentaCredito.FechaGeneracionUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                                </div>
                                <div class="venta-stat">
                                    <p class="text-[10px] text-slate-500 font-bold uppercase">Usuario</p>
                                    <p class="text-sm font-bold text-white">@contratoVentaCredito.UsuarioGeneracion</p>
                                </div>
                            </div>
                            <div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                                <p class="text-xs text-slate-500">
                                    @(string.IsNullOrWhiteSpace(contratoVentaCredito.NombreArchivo) ? "PDF contractual generado." : contratoVentaCredito.NombreArchivo)
                                </p>
                                <a asp-controller="ContratoVentaCredito" asp-action="Ver" asp-route-ventaId="@contratoVentaCredito.VentaId"
                                   target="_blank" rel="noopener"
                                   class="btn-erp-secondary no-underline">
                                    <span class="material-symbols-outlined text-sm">print</span>
                                    Ver / imprimir contrato
                                </a>
                            </div>
                        </section>
                    }
                }

                <!-- Invoice Section (if facturada) -->
                @if (facturas.Any())
                {
                    <section class="card-erp-panel-padded">
                        <div class="flex items-center gap-2 mb-6 border-b border-slate-800 pb-3">
                            <span class="material-symbols-outlined text-primary">description</span>
                            <h2 class="text-white text-xl font-bold">Facturación</h2>
                        </div>
                        <div class="space-y-3">
                            @foreach (var factura in facturas)
                            {
                                <div class="flex items-center justify-between p-4 rounded-lg border @(factura.Anulada ? "bg-red-500/5 border-red-500/20" : "bg-green-500/5 border-green-500/20")">
                                    <div class="flex items-center gap-4">
                                        <div class="size-10 rounded-lg @(factura.Anulada ? "bg-red-500/10" : "bg-green-500/10") flex items-center justify-center">
                                            <span class="material-symbols-outlined text-sm @(factura.Anulada ? "text-red-500" : "text-green-500")">
                                                @(factura.Anulada ? "cancel" : "check_circle")
                                            </span>
                                        </div>
                                        <div>
                                            <p class="text-sm font-bold text-white">@(string.IsNullOrEmpty(factura.Numero) ? "Factura" : factura.Numero)</p>
                                            <p class="text-[11px] text-slate-400">
                                                Tipo @factura.Tipo · @factura.FechaEmision.ToString("dd/MM/yyyy")
                                                @if (factura.Anulada)
                                                {
                                                    <span class="text-red-500 font-bold"> · ANULADA @(factura.FechaAnulacion?.ToString("dd/MM/yyyy"))</span>
                                                }
                                            </p>
                                        </div>
                                    </div>
                                    <div class="text-right">
                                        <p class="text-sm font-black @(factura.Anulada ? "text-red-500 line-through" : "text-white")">@factura.Total.ToString("C2")</p>
                                        @if (!string.IsNullOrEmpty(factura.CAE))
                                        {
                                            <p class="text-[10px] text-slate-400">CAE: @factura.CAE</p>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </section>
                }

                <!-- Authorization Info (if applicable) -->
                @if (Model.RequiereAutorizacion)
                {
                    <section class="card-erp-panel-padded">
                        <div class="flex items-center gap-2 mb-4 border-b border-slate-800 pb-3">
                            <span class="material-symbols-outlined text-primary">admin_panel_settings</span>
                            <h2 class="text-white text-xl font-bold">Autorización</h2>
                        </div>
                        <div class="flex items-center gap-3 p-3 rounded-lg @(Model.EstadoAutorizacion == EstadoAutorizacionVenta.Autorizada ? "bg-green-500/10 border border-green-500/20" : Model.EstadoAutorizacion == EstadoAutorizacionVenta.Rechazada ? "bg-red-500/10 border border-red-500/20" : "bg-amber-500/10 border border-amber-500/20")">
                            <span class="material-symbols-outlined text-sm @(Model.EstadoAutorizacion == EstadoAutorizacionVenta.Autorizada ? "text-green-500" : Model.EstadoAutorizacion == EstadoAutorizacionVenta.Rechazada ? "text-red-500" : "text-amber-500")">
                                @(Model.EstadoAutorizacion == EstadoAutorizacionVenta.Autorizada ? "verified" : Model.EstadoAutorizacion == EstadoAutorizacionVenta.Rechazada ? "gpp_bad" : "hourglass_top")
                            </span>
                            <div>
                                <p class="text-sm font-bold text-white">@Model.EstadoAutorizacionDisplay</p>
                                @if (!string.IsNullOrEmpty(Model.UsuarioAutoriza))
                                {
                                    <p class="text-[11px] text-slate-400">@Model.UsuarioAutoriza · @Model.FechaAutorizacion?.ToString("dd/MM/yyyy HH:mm")</p>
                                }
                                @if (!string.IsNullOrEmpty(Model.MotivoAutorizacion))
                                {
                                    <p class="text-[11px] text-slate-500 mt-1">@Model.MotivoAutorizacion</p>
                                }
                                @if (!string.IsNullOrEmpty(Model.MotivoRechazo))
                                {
                                    <p class="text-[11px] text-red-500 mt-1">@Model.MotivoRechazo</p>
                                }
                            </div>
                        </div>
                    </section>
                }
            </div>

            <!-- Right Column: Actions & Timeline -->
            <div class="space-y-8">

                <!-- Actions Card -->
                <section class="card-erp-panel-padded">
                    <div class="flex items-center gap-2 mb-6 border-b border-slate-800 pb-3">
                        <span class="material-symbols-outlined text-primary">bolt</span>
                        <h2 class="text-white text-xl font-bold">Acciones</h2>
                    </div>
                    <div class="flex flex-col gap-3">

                        @* Configurar Crédito *@
                        @if (puedeOperarVentas && Model.PuedeConfigurarCredito && puedeVerCreditos)
                        {
                            <a asp-action="ConfigurarVenta" asp-controller="Credito"
                               asp-route-id="@Model.CreditoId" asp-route-ventaId="@Model.Id"
                               class="btn-erp-warning btn-erp-block no-underline">
                                <span class="material-symbols-outlined text-sm">settings</span> Configurar Crédito
                            </a>
                        }

                        @* Confirmar *@
                        @if (puedeOperarVentas && Model.PuedeConfirmar)
                        {
                            <form asp-action="Confirmar" method="post" id="form-confirmar">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <button type="submit" class="btn-erp-primary btn-erp-block">
                                    <span class="material-symbols-outlined text-sm">check_circle</span> Confirmar Venta
                                </button>
                            </form>
                        }

                        @* Facturar *@
                        @if (puedeOperarVentas && Model.PuedeFacturar && puedeFacturarVentas)
                        {
                            <a asp-action="Facturar" asp-route-id="@Model.Id"
                               class="btn-erp-success btn-erp-block no-underline">
                                <span class="material-symbols-outlined text-sm">receipt</span> Facturar
                            </a>
                        }

                        @* Imprimir Factura *@
                        @if (tieneFactura)
                        {
                            <button type="button" data-venta-action="print"
                                    class="btn-erp-secondary btn-erp-block">
                                <span class="material-symbols-outlined text-sm">print</span> Imprimir Factura
                            </button>
                        }

                        @* Autorizar *@
                        @if (puedeOperarVentas && Model.PuedeAutorizar && (puedeAutorizarVentas || puedeRechazarVentas))
                        {
                            <div class="flex flex-col gap-2 sm:flex-row">
                                @if (puedeAutorizarVentas)
                                {
                                    <form asp-action="Autorizar" method="post" class="flex-1">
                                        <input type="hidden" name="id" value="@Model.Id" />
                                        <button type="submit" class="btn-erp-success btn-erp-block">
                                            <span class="material-symbols-outlined text-sm">thumb_up</span> Autorizar
                                        </button>
                                    </form>
                                }
                                @if (puedeRechazarVentas)
                                {
                                    <form asp-action="Rechazar" method="post" class="flex-1">
                                        <input type="hidden" name="id" value="@Model.Id" />
                                        <button type="submit" class="btn-erp-danger btn-erp-block">
                                            <span class="material-symbols-outlined text-sm">thumb_down</span> Rechazar
                                        </button>
                                    </form>
                                }
                            </div>
                        }

                        @* Devolucion *@
                        @if (puedeOperarVentas && Model.PuedeCrearDevolucion && puedeCrearDevoluciones)
                        {
                            <button type="button"
                               data-open-devolucion-modal
                               data-venta-id="@Model.Id"
                               class="btn-erp-ghost btn-erp-block">
                                <span class="material-symbols-outlined text-sm">undo</span> Crear Devolución
                            </button>
                        }

                        @* Editar *@
                        @if (puedeOperarVentas && Model.PuedeEditar && puedeActualizarVentas)
                        {
                            <a asp-action="Edit" asp-route-id="@Model.Id"
                               class="btn-erp-ghost btn-erp-block no-underline">
                                <span class="material-symbols-outlined text-sm">edit</span> Editar Venta
                            </a>
                        }

                        <div class="border-t border-slate-800 pt-3 mt-1">
                            @* Cancelar *@
                            @if (puedeOperarVentas && Model.PuedeCancelar && Model.Estado != EstadoVenta.Facturada && Model.Estado != EstadoVenta.Entregada)
                            {
                                <a asp-action="Cancelar" asp-route-id="@Model.Id"
                                   class="btn-erp-danger btn-erp-block no-underline">
                                    <span class="material-symbols-outlined text-sm">cancel</span> Cancelar Venta
                                </a>
                            }

                            @* Anular Factura *@
                            @if (puedeOperarVentas && tieneFactura && facturaActiva != null && puedeFacturarVentas)
                            {
                                <button type="button"
                                        id="btn-anular-factura"
                                        data-factura-id="@facturaActiva.Id"
                                        data-factura-numero="@facturaActiva.Numero"
                                        data-venta-modal-action="open"
                                        data-venta-modal-target="anular-factura"
                                        class="btn-erp-danger btn-erp-block">
                                    <span class="material-symbols-outlined text-sm">block</span> Anular Factura
                                </button>
                            }
                        </div>
                    </div>
                </section>

                <!-- Status Timeline -->
                <section class="card-erp-panel-padded">
                    <div class="flex items-center gap-2 mb-6 border-b border-slate-800 pb-3">
                        <span class="material-symbols-outlined text-primary">timeline</span>
                        <h2 class="text-white text-xl font-bold">Historial</h2>
                    </div>
                    <div class="relative pl-6 space-y-6 before:absolute before:left-[9px] before:top-1 before:bottom-1 before:w-px before:bg-slate-700">
                        @* Created *@
                        <div class="relative flex items-start gap-3">
                            <div class="absolute -left-6 top-0.5 size-[18px] rounded-full bg-primary border-2 border-slate-900 z-10"></div>
                            <div>
                                <p class="text-xs font-bold text-white">Venta creada</p>
                                <p class="text-[11px] text-slate-400">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                            </div>
                        </div>

                        @* Confirmed *@
                        @if (Model.FechaConfirmacion.HasValue)
                        {
                            <div class="relative flex items-start gap-3">
                                <div class="absolute -left-6 top-0.5 size-[18px] rounded-full bg-primary border-2 border-slate-900 z-10"></div>
                                <div>
                                    <p class="text-xs font-bold text-white">Venta confirmada</p>
                                    <p class="text-[11px] text-slate-400">@Model.FechaConfirmacion.Value.ToString("dd/MM/yyyy HH:mm")</p>
                                </div>
                            </div>
                        }

                        @* Credit configured *@
                        @if (Model.FechaConfiguracionCredito.HasValue)
                        {
                            <div class="relative flex items-start gap-3">
                                <div class="absolute -left-6 top-0.5 size-[18px] rounded-full bg-blue-500 border-2 border-slate-900 z-10"></div>
                                <div>
                                    <p class="text-xs font-bold text-white">Crédito configurado</p>
                                    <p class="text-[11px] text-slate-400">@Model.FechaConfiguracionCredito.Value.ToString("dd/MM/yyyy HH:mm")</p>
                                </div>
                            </div>
                        }

                        @* Invoiced *@
                        @if (Model.FechaFacturacion.HasValue)
                        {
                            <div class="relative flex items-start gap-3">
                                <div class="absolute -left-6 top-0.5 size-[18px] rounded-full bg-green-500 border-2 border-slate-900 z-10"></div>
                                <div>
                                    <p class="text-xs font-bold text-white">Facturada</p>
                                    <p class="text-[11px] text-slate-400">@Model.FechaFacturacion.Value.ToString("dd/MM/yyyy HH:mm")</p>
                                    @if (facturaActiva != null)
                                    {
                                        <p class="text-[11px] text-primary font-bold">@facturaActiva.Numero</p>
                                    }
                                </div>
                            </div>
                        }

                        @* Delivered *@
                        @if (Model.FechaEntrega.HasValue)
                        {
                            <div class="relative flex items-start gap-3">
                                <div class="absolute -left-6 top-0.5 size-[18px] rounded-full bg-emerald-500 border-2 border-slate-900 z-10"></div>
                                <div>
                                    <p class="text-xs font-bold text-white">Entregada</p>
                                    <p class="text-[11px] text-slate-400">@Model.FechaEntrega.Value.ToString("dd/MM/yyyy HH:mm")</p>
                                </div>
                            </div>
                        }

                        @* Cancelled *@
                        @if (Model.FechaCancelacion.HasValue)
                        {
                            <div class="relative flex items-start gap-3">
                                <div class="absolute -left-6 top-0.5 size-[18px] rounded-full bg-red-500 border-2 border-slate-900 z-10"></div>
                                <div>
                                    <p class="text-xs font-bold text-red-500">Cancelada</p>
                                    <p class="text-[11px] text-slate-400">@Model.FechaCancelacion.Value.ToString("dd/MM/yyyy HH:mm")</p>
                                    @if (!string.IsNullOrEmpty(Model.MotivoCancelacion))
                                    {
                                        <p class="text-[11px] text-slate-500 mt-0.5">@Model.MotivoCancelacion</p>
                                    }
                                </div>
                            </div>
                        }

                        @* Pending dot if not final state *@
                        @if (Model.Estado != EstadoVenta.Cancelada && Model.Estado != EstadoVenta.Entregada)
                        {
                            <div class="relative flex items-start gap-3">
                                <div class="absolute -left-6 top-0.5 size-[18px] rounded-full bg-slate-700 border-2 border-slate-900 z-10 animate-pulse"></div>
                                <div>
                                    <p class="text-xs text-slate-400 italic">
                                        @(Model.Estado switch
                                        {
                                            EstadoVenta.Presupuesto => "Esperando confirmación",
                                            EstadoVenta.Confirmada => "Pendiente de facturación",
                                            EstadoVenta.Facturada => "Pendiente de entrega",
                                            EstadoVenta.PendienteRequisitos => "Requisitos pendientes",
                                            EstadoVenta.PendienteFinanciacion => "Pendiente de financiación",
                                            _ => "Próximo paso..."
                                        })
                                    </p>
                                </div>
                            </div>
                        }
                    </div>
                </section>

                <!-- Totals Summary Card (compact, dark) -->
                <section class="bg-slate-900/60 p-6 rounded-xl border border-slate-800 shadow-xl text-white">
                    <div class="space-y-3">
                        <div class="flex justify-between items-center text-sm">
                            <span class="text-slate-400">Subtotal</span>
                            <span class="text-slate-200">@Model.Subtotal.ToString("C2")</span>
                        </div>
                        @if (Model.Descuento > 0)
                        {
                            <div class="flex justify-between items-center text-sm">
                                <span class="text-slate-400">Descuento</span>
                                <span class="text-red-400">-@Model.Descuento.ToString("C2")</span>
                            </div>
                        }
                        <div class="flex justify-between items-center text-sm border-b border-slate-800 pb-3">
                            <span class="text-slate-400">IVA (21%)</span>
                            <span class="text-slate-200">@Model.IVA.ToString("C2")</span>
                        </div>
                        <div class="flex justify-between items-center pt-1">
                            <span class="text-slate-300 font-bold uppercase tracking-wider text-xs">Total</span>
                            <span class="text-2xl font-black text-white">@Model.Total.ToString("C2")</span>
                        </div>
                    </div>
                </section>
            </div>
        </div>

    </div>
</div>

@if (puedeOperarVentas && tieneFactura && facturaActiva != null && puedeFacturarVentas)
{
    <div id="modal-anular-factura"
         data-venta-modal="anular-factura"
         data-venta-modal-backdrop
         aria-hidden="true"
         class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 px-4 backdrop-blur-sm">
        <div class="w-full max-w-lg rounded-2xl bg-slate-900 p-6 shadow-2xl">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <h3 class="text-lg font-bold text-white">Anular factura</h3>
                    <p class="mt-1 text-sm text-slate-400">
                        Indicá el motivo de la anulación para la factura <span id="modal-anular-factura-numero" class="font-bold text-white">@facturaActiva.Numero</span>.
                    </p>
                </div>
                <button type="button"
                        data-venta-modal-action="close"
                        class="inline-flex size-9 items-center justify-center rounded-lg text-slate-400 transition-colors hover:bg-slate-800 hover:text-slate-200">
                    <span class="material-symbols-outlined text-base">close</span>
                </button>
            </div>

            <form asp-action="AnularFactura" method="post" id="form-anular-factura" class="mt-6 space-y-4">
                @Html.AntiForgeryToken()
                <input type="hidden" name="facturaId" id="anular-factura-id" value="@facturaActiva.Id" />

                <div class="rounded-2xl border border-red-500/20 bg-red-500/10 p-4 text-sm text-slate-300">
                    Esta acción revierte la factura activa de la venta y queda registrada en el historial operativo.
                </div>

                <div>
                    <label for="anular-factura-motivo" class="venta-label">Motivo de anulación</label>
                    <textarea id="anular-factura-motivo"
                              name="motivo"
                              rows="4"
                              required
                              placeholder="Describa el motivo de la anulación..."
                              class="venta-input"></textarea>
                </div>

                <div class="venta-details-modal-footer flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
                    <button type="button"
                            data-venta-modal-action="close"
                            class="venta-details-modal-action btn-erp-ghost sm:w-auto">
                        Cancelar
                    </button>
                    <button type="submit"
                            class="venta-details-modal-action w-full rounded-xl bg-red-600 px-4 py-3 text-sm font-bold text-white transition-colors hover:bg-red-700 sm:w-auto">
                        Confirmar anulación
                    </button>
                </div>
            </form>
        </div>
    </div>
}

@if (puedeOperarVentas && Model.PuedeCrearDevolucion && puedeCrearDevoluciones)
{
    <partial name="_VentaDevolucionModal" />
}

@section Styles {
    <partial name="_VentaModuleStyles" />
}

@section Scripts {
    <script src="~/js/horizontal-scroll-affordance.js" asp-append-version="true"></script>
    <script src="~/js/venta-module.js" asp-append-version="true"></script>
    <script src="~/js/venta-devolucion-modal.js" asp-append-version="true"></script>
    <script src="~/js/details-venta.js" asp-append-version="true"></script>
}
