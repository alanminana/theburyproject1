@model IEnumerable<TheBuryProject.ViewModels.VentaViewModel>
@using TheBuryProject.Models.Enums
@{
    ViewData["Title"] = "Módulo de Ventas";
    ViewData["MetaDescription"] = "Gestión de ventas, cotizaciones, presupuestos y autorizaciones del sistema ERP TheBuryProject.";
    var ventas = Model?.ToList() ?? new List<TheBuryProject.ViewModels.VentaViewModel>();
    var filter = ViewBag.Filter as TheBuryProject.ViewModels.VentaFilterViewModel ?? new TheBuryProject.ViewModels.VentaFilterViewModel();
    var clientes = ViewBag.Clientes as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var puedeCrear = (bool?)ViewBag.PuedeCrearVenta ?? false;
    var puedeOperarVentas = (bool?)ViewBag.PuedeOperarVentas ?? false;
    var puedeVerDevoluciones = User.TienePermiso("devoluciones", "view");
    var puedeCrearDevoluciones = User.TienePermiso("devoluciones", "create");
    var puedeConfigurarPagos = User.TienePermiso("configuraciones", "update");
    var pendientesAutorizacion = ventas.Count(v => v.EstadoAutorizacion == EstadoAutorizacionVenta.PendienteAutorizacion);
    var ventasHoy = ventas.Where(v => v.FechaVenta.Date == DateTime.Today && v.Estado != EstadoVenta.Cancelada).ToList();
    var totalHoy  = ventasHoy.Sum(v => v.Total);
}

<div class="space-y-6">

@if (!puedeOperarVentas)
{
    <div id="panel-caja-cerrada" class="mb-6 rounded-2xl border border-amber-500/20 bg-amber-500/10 px-5 py-4 text-amber-100">
        <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
            <div class="flex items-start gap-3">
                <span class="material-symbols-outlined mt-0.5 text-xl text-amber-300">point_of_sale</span>
                <div>
                    <p class="text-sm font-black uppercase tracking-wider">Sin caja abierta</p>
                    <p class="mt-1 text-sm font-medium">
                        No tiene una caja abierta a su nombre (<span class="font-mono font-bold">@(ViewBag.UserNameCaja ?? User.Identity?.Name ?? "?")</span>). Abra una caja para habilitar las operaciones de venta.
                    </p>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <a id="btn-abrir-caja" asp-controller="Caja" asp-action="Abrir"
                   class="inline-flex items-center justify-center gap-2 rounded-xl bg-amber-500 px-4 py-2.5 text-sm font-bold text-slate-950 transition-colors hover:bg-amber-400 no-underline">
                    <span class="material-symbols-outlined text-[18px]">lock_open</span>
                    Abrir caja
                </a>
                <a asp-controller="Caja" asp-action="Index"
                   class="inline-flex items-center justify-center gap-2 rounded-xl border border-amber-500/40 px-4 py-2.5 text-sm font-bold text-amber-200 transition-colors hover:bg-amber-500/20 no-underline">
                    <span class="material-symbols-outlined text-[18px]">point_of_sale</span>
                    Ver cajas
                </a>
            </div>
        </div>
    </div>
}

<!-- TempData Alerts -->
@if (TempData["Success"] != null)
{
    <div class="toast-msg flex items-center gap-3 rounded-xl border border-emerald-500/20 bg-emerald-500/10 p-4 text-sm font-semibold text-emerald-400" role="status">
        <span class="material-symbols-outlined">check_circle</span>
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="toast-msg flex items-center gap-3 rounded-xl border border-red-500/20 bg-red-500/10 p-4 text-sm font-semibold text-red-400" role="alert">
        <span class="material-symbols-outlined">error</span>
        @TempData["Error"]
    </div>
}
@if (TempData["Warning"] != null)
{
    <div class="toast-msg flex items-center gap-3 rounded-xl border border-amber-500/20 bg-amber-500/10 p-4 text-sm font-semibold text-amber-400" role="alert">
        <span class="material-symbols-outlined">warning</span>
        @TempData["Warning"]
    </div>
}

@{
    var filtroActivo  = filter.Numero != null || filter.FechaDesde != null || filter.FechaHasta != null
                     || filter.Estado != null || filter.TipoPago != null || filter.EstadoAutorizacion != null;
    var fechaDesdeStr = filter.FechaDesde?.ToString("yyyy-MM-dd") ?? "";
    var fechaHastaStr = filter.FechaHasta?.ToString("yyyy-MM-dd") ?? "";
}
<!-- Main Sales Panel -->
<section class="card-erp-panel overflow-hidden">
    <div class="flex flex-col gap-4 border-b border-slate-800 bg-slate-800/20 px-4 py-4 xl:flex-row xl:items-center xl:justify-between">
        <div class="flex flex-wrap items-center gap-3">
            <span class="shrink-0 border-b-2 border-primary bg-primary/10 px-5 py-3 text-sm font-bold text-primary">
                Ventas
            </span>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-800 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.16em] text-slate-300">
                <span class="material-symbols-outlined text-[14px] text-slate-400">today</span>
                Hoy
            </span>
            <span class="inline-flex items-center gap-1.5 rounded-full border border-slate-700 bg-slate-900/50 px-3 py-1 text-xs font-semibold text-slate-200">
                <span class="material-symbols-outlined text-[15px] text-slate-400">receipt_long</span>
                @ventasHoy.Count operacion@(ventasHoy.Count == 1 ? "" : "es")
            </span>
            <span class="inline-flex items-center gap-1.5 rounded-full border border-slate-700 bg-slate-900/50 px-3 py-1 text-xs font-semibold text-slate-200">
                <span class="material-symbols-outlined text-[15px] text-slate-400">payments</span>
                $@totalHoy.ToString("N0")
            </span>
            @if (pendientesAutorizacion > 0)
            {
                <span class="inline-flex items-center gap-1.5 rounded-full border border-amber-500/20 bg-amber-500/10 px-3 py-1 text-xs font-bold text-amber-400">
                    <span class="material-symbols-outlined text-[15px]">pending_actions</span>
                    @pendientesAutorizacion pendientes
                </span>
            }
        </div>
        <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center xl:justify-end">
            @if (puedeConfigurarPagos)
            {
                <button type="button" id="btn-configurar-recargo"
                        data-venta-modal-action="open"
                        data-venta-modal-target="configuracion-pagos"
                        class="btn-erp-ghost btn-sm sm:w-auto">
                    <span class="material-symbols-outlined text-sm">percent</span>
                    Recargo/Descuento
                </button>
            }
            @if (puedeVerDevoluciones)
            {
                <a asp-controller="Devolucion" asp-action="Index" asp-route-tab="devoluciones"
                   class="btn-erp-secondary btn-sm no-underline sm:w-auto">
                    <span class="material-symbols-outlined text-sm">assignment_return</span>
                    Devoluciones
                </a>
            }
            @if (puedeCrear)
            {
                <button type="button" id="btn-abrir-modal-crear-venta" class="btn-erp-primary btn-sm sm:w-auto">
                    <span class="material-symbols-outlined text-sm">add</span>
                    Nueva Venta
                </button>
            }
            else if (!puedeOperarVentas)
            {
                <button type="button" data-action="nueva-venta-bloqueada" class="btn-erp-primary btn-sm sm:w-auto">
                    <span class="material-symbols-outlined text-sm">add</span>
                    Nueva Venta
                </button>
                <span id="msg-caja-cerrada" class="sr-only" aria-live="polite"></span>
            }
        </div>
    </div>

    <div class="border-b border-slate-800 px-5 py-4">
        <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
            <div>
                <h2 class="text-base font-bold text-white">Listado principal de ventas</h2>
                <p class="text-sm text-slate-400">
                    Consultá estado, autorización, forma de pago y acciones disponibles sobre cada operación.
                </p>
            </div>
            <div class="flex flex-wrap items-center gap-2">
                <span class="badge-erp badge-erp-neutral">
                    <span class="material-symbols-outlined text-sm">table_rows</span>
                    @ventas.Count registros
                </span>
                @if (filtroActivo)
                {
                    <span class="badge-erp badge-erp-primary">
                        <span class="material-symbols-outlined text-sm">filter_alt</span>
                        Filtros activos
                    </span>
                }
                @if (pendientesAutorizacion > 0)
                {
                    <span class="badge-erp badge-erp-warning">
                        <span class="material-symbols-outlined text-sm">approval</span>
                        @pendientesAutorizacion por autorizar
                    </span>
                }
            </div>
        </div>
    </div>

    <form asp-action="Index" method="get" id="form-filtros"
          class="border-b border-slate-800 bg-slate-900/30 p-4">
        <div class="flex flex-wrap items-end gap-4">
            <div class="min-w-[200px] flex-1">
                <label class="mb-1.5 block text-[10px] font-bold uppercase tracking-wider text-slate-400">Buscar venta</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-lg text-slate-400">search</span>
                    <input type="text" name="Numero" value="@filter.Numero"
                           aria-label="Número de venta"
                           class="w-full rounded-lg border-none bg-slate-800 py-2 pl-10 pr-4 text-sm text-white placeholder:text-slate-500 transition-colors focus:ring-2 focus:ring-primary/50"
                           placeholder="Número #V-..." />
                </div>
            </div>
            <div class="w-40">
                <label class="mb-1.5 block text-[10px] font-bold uppercase tracking-wider text-slate-400">Desde</label>
                <input type="date" name="FechaDesde" value="@fechaDesdeStr"
                       aria-label="Fecha desde"
                       class="filter-input-erp" />
            </div>
            <div class="w-40">
                <label class="mb-1.5 block text-[10px] font-bold uppercase tracking-wider text-slate-400">Hasta</label>
                <input type="date" name="FechaHasta" value="@fechaHastaStr"
                       aria-label="Fecha hasta"
                       class="filter-input-erp" />
            </div>
            <div class="w-44">
                <label class="mb-1.5 block text-[10px] font-bold uppercase tracking-wider text-slate-400">Estado</label>
                <select name="Estado" aria-label="Estado de venta" class="filter-select-erp">
                    <option value="">Todos</option>
                    <option value="@EstadoVenta.Cotizacion" selected="@(filter.Estado == EstadoVenta.Cotizacion)">Cotización</option>
                    <option value="@EstadoVenta.Presupuesto" selected="@(filter.Estado == EstadoVenta.Presupuesto)">Presupuesto</option>
                    <option value="@EstadoVenta.Confirmada" selected="@(filter.Estado == EstadoVenta.Confirmada)">Confirmada</option>
                    <option value="@EstadoVenta.Facturada" selected="@(filter.Estado == EstadoVenta.Facturada)">Facturada</option>
                    <option value="@EstadoVenta.Entregada" selected="@(filter.Estado == EstadoVenta.Entregada)">Entregada</option>
                    <option value="@EstadoVenta.Cancelada" selected="@(filter.Estado == EstadoVenta.Cancelada)">Cancelada</option>
                    <option value="@EstadoVenta.PendienteRequisitos" selected="@(filter.Estado == EstadoVenta.PendienteRequisitos)">Pend. Requisitos</option>
                    <option value="@EstadoVenta.PendienteFinanciacion" selected="@(filter.Estado == EstadoVenta.PendienteFinanciacion)">Pend. Financiación</option>
                </select>
            </div>
            <div class="w-44">
                <label class="mb-1.5 block text-[10px] font-bold uppercase tracking-wider text-slate-400">Pago</label>
                <select name="TipoPago" aria-label="Tipo de pago" class="filter-select-erp">
                    <option value="">Todos</option>
                    <option value="@TipoPago.Efectivo" selected="@(filter.TipoPago == TipoPago.Efectivo)">Efectivo</option>
                    <option value="@TipoPago.Transferencia" selected="@(filter.TipoPago == TipoPago.Transferencia)">Transferencia</option>
                    <option value="@TipoPago.TarjetaDebito" selected="@(filter.TipoPago == TipoPago.TarjetaDebito)">Tarjeta Débito</option>
                    <option value="@TipoPago.TarjetaCredito" selected="@(filter.TipoPago == TipoPago.TarjetaCredito)">Tarjeta Crédito</option>
                    <option value="@TipoPago.Cheque" selected="@(filter.TipoPago == TipoPago.Cheque)">Cheque</option>
                    <option value="@TipoPago.CreditoPersonal" selected="@(filter.TipoPago == TipoPago.CreditoPersonal)">Crédito Personal</option>
                    <option value="@TipoPago.MercadoPago" selected="@(filter.TipoPago == TipoPago.MercadoPago)">MercadoPago</option>
                    <option value="@TipoPago.CuentaCorriente" selected="@(filter.TipoPago == TipoPago.CuentaCorriente)">Cuenta Corriente</option>
                </select>
            </div>
            <div class="w-44">
                <label class="mb-1.5 block text-[10px] font-bold uppercase tracking-wider text-slate-400">Autorización</label>
                <select name="EstadoAutorizacion" aria-label="Estado de autorización" class="filter-select-erp">
                    <option value="">Todas</option>
                    <option value="@EstadoAutorizacionVenta.NoRequiere" selected="@(filter.EstadoAutorizacion == EstadoAutorizacionVenta.NoRequiere)">No Requiere</option>
                    <option value="@EstadoAutorizacionVenta.PendienteAutorizacion" selected="@(filter.EstadoAutorizacion == EstadoAutorizacionVenta.PendienteAutorizacion)">Pendiente</option>
                    <option value="@EstadoAutorizacionVenta.Autorizada" selected="@(filter.EstadoAutorizacion == EstadoAutorizacionVenta.Autorizada)">Autorizada</option>
                    <option value="@EstadoAutorizacionVenta.Rechazada" selected="@(filter.EstadoAutorizacion == EstadoAutorizacionVenta.Rechazada)">Rechazada</option>
                </select>
            </div>
            <div class="flex gap-2">
                <button type="submit"
                        class="rounded-lg bg-primary/10 p-2.5 text-primary transition-colors hover:bg-primary hover:text-white"
                        title="Filtrar">
                    <span class="material-symbols-outlined text-lg">filter_list</span>
                </button>
                @if (filtroActivo)
                {
                    <a asp-action="Index"
                       class="rounded-lg bg-slate-800 p-2.5 text-slate-300 transition-colors hover:bg-slate-700 hover:text-white no-underline"
                       title="Limpiar filtros">
                        <span class="material-symbols-outlined text-lg">clear_all</span>
                    </a>
                }
            </div>
        </div>
    </form>

    <div id="ventas-index-scroll" data-oc-scroll class="relative" style="--oc-scroll-min-width: 72rem;">
        <p data-oc-scroll-hint hidden class="px-5 pt-4 text-xs font-semibold uppercase tracking-[0.16em] text-slate-400 lg:hidden">
            Deslizá la tabla para revisar estados, autorización, totales y acciones completas.
        </p>
        <div data-oc-scroll-shell class="relative">
            <div data-oc-scroll-fade="left" hidden class="absolute inset-y-0 left-0 z-10 w-6 bg-gradient-to-r from-slate-900 via-slate-900/95 to-transparent"></div>
            <div data-oc-scroll-fade="right" hidden class="absolute inset-y-0 right-0 z-10 w-6 bg-gradient-to-l from-slate-900 via-slate-900/95 to-transparent"></div>
            <div data-oc-scroll-region class="overflow-x-auto scroll-smooth" tabindex="0" role="region" aria-label="Listado principal de ventas">
                <table data-oc-scroll-table class="w-full text-left border-collapse" style="min-width: var(--oc-scroll-min-width);">
                    <thead>
                        <tr class="bg-slate-800/30 border-b border-slate-800">
                            <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider">Número</th>
                            <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider">Fecha</th>
                            <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider">Cliente</th>
                            <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider">Estado</th>
                            <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider">Autorización</th>
                            <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider">Tipo de Pago</th>
                            <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider text-right">Total</th>
                            <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-800">
            @if (ventas.Any())
            {
                @foreach (var v in ventas)
                {
                    var estadoBadge = v.Estado switch
                    {
                        EstadoVenta.Cotizacion           => ("bg-slate-800 text-slate-300", "Cotización"),
                        EstadoVenta.Presupuesto          => ("bg-blue-900/30 text-blue-400", "Presupuesto"),
                        EstadoVenta.Confirmada           => ("bg-emerald-900/30 text-emerald-400", "Confirmada"),
                        EstadoVenta.Facturada            => ("bg-emerald-900/30 text-emerald-400", "Facturada"),
                        EstadoVenta.Entregada            => ("bg-emerald-900/30 text-emerald-400", "Entregada"),
                        EstadoVenta.Cancelada            => ("bg-red-900/30 text-red-400", "Cancelada"),
                        EstadoVenta.PendienteRequisitos  => ("bg-amber-900/30 text-amber-400", "Pend. Requisitos"),
                        EstadoVenta.PendienteFinanciacion=> ("bg-amber-900/30 text-amber-400", "Pend. Financiación"),
                        _ => ("bg-slate-800 text-slate-300", v.EstadoDisplay)
                    };
                    var autorizacionBadge = v.EstadoAutorizacion switch
                    {
                        EstadoAutorizacionVenta.NoRequiere              => ("text-slate-400", "bg-slate-500", "No Requiere"),
                        EstadoAutorizacionVenta.PendienteAutorizacion   => ("text-amber-400", "bg-amber-500", "Pendiente"),
                        EstadoAutorizacionVenta.Autorizada              => ("text-blue-400", "bg-blue-400", "Aprobado"),
                        EstadoAutorizacionVenta.Rechazada               => ("text-red-400", "bg-red-400", "Rechazado"),
                        _ => ("text-slate-400", "bg-slate-500", v.EstadoAutorizacionDisplay)
                    };
                    var esCancelada = v.Estado == EstadoVenta.Cancelada;
                    var puedeDevolver = puedeOperarVentas && puedeCrearDevoluciones && v.PuedeCrearDevolucion && !esCancelada;
                    var puedeCancelarVenta = puedeOperarVentas && v.PuedeCancelar && !esCancelada;
                    var tipoPagoDisplay = v.TipoPago switch
                    {
                        TipoPago.Efectivo => "Efectivo",
                        TipoPago.Transferencia => "Transferencia",
                        TipoPago.TarjetaDebito => "Tarjeta Débito",
                        TipoPago.TarjetaCredito => "Tarjeta Crédito",
                        TipoPago.Cheque => "Cheque",
                        TipoPago.CreditoPersonal => "Crédito",
                        TipoPago.MercadoPago => "MercadoPago",
                        TipoPago.CuentaCorriente => "Cta. Corriente",
                        _ => v.TipoPago.ToString()
                    };

                    <tr class="hover:bg-slate-800/30 transition-colors">
                        <td class="px-6 py-4 text-sm font-semibold text-primary">@v.Numero</td>
                        <td class="px-6 py-4 text-sm text-slate-300 whitespace-nowrap">@v.FechaVenta.ToString("dd MMM yyyy")</td>
                        <td class="px-6 py-4 text-sm font-medium text-slate-100">@v.ClienteNombre</td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @estadoBadge.Item1 @(esCancelada ? "line-through" : "")">
                                @estadoBadge.Item2
                            </span>
                        </td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center gap-1.5 text-xs font-medium @autorizacionBadge.Item1">
                                <span class="w-1.5 h-1.5 rounded-full @autorizacionBadge.Item2"></span>
                                @autorizacionBadge.Item3
                            </span>
                        </td>
                        <td class="px-6 py-4 text-sm text-slate-300">@tipoPagoDisplay</td>
                        <td class="px-6 py-4 text-sm font-bold text-right @(esCancelada ? "text-slate-500" : "text-slate-100")">$@v.Total.ToString("N2")</td>
                        <td class="px-6 py-4">
                            <div class="flex flex-wrap items-center justify-center gap-1">
                                <a asp-action="Details" asp-route-id="@v.Id"
                                   class="row-action row-action--primary no-underline"
                                   title="Ver Venta">
                                    <span class="material-symbols-outlined">visibility</span>
                                    <span class="row-action__label">Ver</span>
                                </a>
                                @if (puedeDevolver)
                                {
                                    <button type="button"
                                            data-open-devolucion-modal
                                            data-venta-id="@v.Id"
                                            class="row-action row-action--warning"
                                            title="Devolver producto"
                                            aria-label="Devolver producto">
                                        <span class="material-symbols-outlined">assignment_return</span>
                                        <span class="row-action__label">Devolver</span>
                                    </button>
                                }
                                else if (puedeCrearDevoluciones)
                                {
                                    <span class="row-action row-action--disabled"
                                          title="@(puedeOperarVentas ? "Disponible solo para ventas confirmadas, facturadas o entregadas" : "Debe abrir una caja para operar en ventas")">
                                        <span class="material-symbols-outlined">assignment_return</span>
                                        <span class="row-action__label">Devolver</span>
                                    </span>
                                }
                                @if (puedeCancelarVenta)
                                {
                                    <a asp-action="Cancelar" asp-route-id="@v.Id"
                                       class="row-action row-action--danger no-underline"
                                       title="Anular">
                                        <span class="material-symbols-outlined">block</span>
                                        <span class="row-action__label">Anular</span>
                                    </a>
                                }
                                else
                                {
                                    <span class="row-action row-action--disabled"
                                          title="@(puedeOperarVentas ? "La venta no puede anularse en este estado" : "Debe abrir una caja para operar en ventas")">
                                        <span class="material-symbols-outlined">block</span>
                                        <span class="row-action__label">Anular</span>
                                    </span>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Empty State -->
    @if (!ventas.Any())
    {
        <div class="flex flex-col items-center justify-center py-20 px-6 text-center">
            <div class="w-16 h-16 bg-slate-800 rounded-full flex items-center justify-center mb-4">
                <span class="material-symbols-outlined text-slate-400 text-3xl">search_off</span>
            </div>
            <h3 class="text-lg font-bold text-white">No se encontraron ventas</h3>
            <p class="text-slate-400 max-w-xs mt-1">No hay ventas que coincidan con los filtros aplicados.</p>
            <a asp-action="Index" class="mt-6 text-primary font-semibold hover:underline flex items-center gap-1 no-underline">
                <span class="material-symbols-outlined text-[18px]">filter_alt_off</span>
                Limpiar filtros
            </a>
        </div>
    }
    <footer class="border-t border-slate-800 bg-slate-900/30 px-5 py-3">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
            <p class="text-sm text-slate-400">
                Mostrando <span class="font-bold text-white">@ventas.Count</span> resultados
            </p>
            <p class="text-xs text-slate-400">
                La última columna concentra seguimiento y acciones disponibles por operación.
            </p>
        </div>
    </footer>
</section>

</div>

<!-- ═══════════════════════════════════════════════════ -->
<!-- Modal: Configurar Recargos / Descuentos por Tipo de Pago -->
<!-- ═══════════════════════════════════════════════════ -->
<div id="modal-recargo" data-venta-modal="configuracion-pagos" class="fixed inset-0 z-50 hidden" aria-hidden="true">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" id="modal-recargo-overlay" data-venta-modal-action="close"></div>
    <div class="relative flex items-center justify-center min-h-screen p-4">
        <div class="relative bg-slate-900 rounded-2xl border border-slate-800 w-full max-w-3xl shadow-2xl max-h-[90vh] flex flex-col">

            <!-- Header -->
            <div class="flex items-center justify-between p-6 border-b border-slate-800 shrink-0">
                <h3 class="text-lg font-bold text-white flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">tune</span> Recargos y Descuentos por Tipo de Pago
                </h3>
                <button type="button" id="btn-cerrar-modal-recargo" data-venta-modal-action="close" class="p-1 rounded-lg hover:bg-slate-800 transition-all">
                    <span class="material-symbols-outlined text-slate-400">close</span>
                </button>
            </div>

            <!-- Body (scrollable) -->
            <div class="p-6 overflow-y-auto flex-1 space-y-1" id="modal-recargo-body">
                <!-- Loading -->
                <div id="recargo-loading" class="flex flex-col items-center justify-center py-12 gap-3">
                    <div class="size-8 border-2 border-primary border-t-transparent rounded-full animate-spin"></div>
                    <p class="text-xs text-slate-400">Cargando configuraciones…</p>
                </div>

                <!-- Error -->
                <div id="recargo-error" class="hidden p-4 rounded-lg bg-red-500/10 border border-red-500/20 text-red-500 text-sm font-bold"></div>

                <!-- Config list — injected by JS -->
                <div id="recargo-lista" class="hidden space-y-4"></div>
            </div>

            <!-- Footer -->
            <div class="grid gap-3 p-6 border-t border-slate-800 shrink-0 sm:flex sm:justify-end">
                <button type="button" id="btn-cancelar-recargos" data-venta-modal-action="close"
                        class="btn-erp-ghost sm:w-auto">
                    Cancelar
                </button>
                <button type="button" id="btn-guardar-recargos"
                        class="btn-erp-primary sm:w-auto sm:min-w-[14rem]">
                    <span class="material-symbols-outlined text-sm">save</span> Guardar Cambios
                </button>
            </div>
        </div>
    </div>
</div>

